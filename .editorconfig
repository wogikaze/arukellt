root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{ark,py,rs,js,ts,json,jsonc,toml,yml,yaml,sh,css,html,wit}]
indent_style = space
indent_size = 4

[*.md]
indent_style = space
indent_size = 4
trim_trailing_whitespace = false

[*.{expected,diag,lsp-expected,dap-expected}]
insert_final_newline = unset
trim_trailing_whitespace = unset

# Generated by the playground build; formatting belongs to its generator.
[docs/playground/dist/**]
insert_final_newline = unset
trim_trailing_whitespace = unset
