fn void_fn(a: i32, b: i32, c: i32) {
    let _x = a + b + c
}

fn non_void_fn(x: i32) -> i32 {
    x + 1
}

fn test_if_with_call() -> i32 {
    let a = 1
    let b = 2
    if a > 0 {
        // non-last: push(v, x) would be here
        void_fn(0, a, b)  // void call in if-branch
    } else {
        void_fn(0, b, a)
    }
    5
}

fn main() {
    let x = test_if_with_call()
    stdio::println(to_string(x))
}
