{
  "name": "arukellt-all-in-one",
  "displayName": "Arukellt All-in-One",
  "description": "VS Code support for Arukellt via the arukellt LSP server.",
  "version": "0.0.1",
  "publisher": "arukellt",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wogikaze/arukellt.git",
    "directory": "extensions/arukellt-all-in-one"
  },
  "engines": {
    "vscode": "^1.113.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:arukellt",
    "onCommand:arukellt.restartLanguageServer",
    "onCommand:arukellt.checkCurrentFile",
    "onCommand:arukellt.compileCurrentFile",
    "onCommand:arukellt.runCurrentFile",
    "onCommand:arukellt.showSetupDoctor",
    "onCommand:arukellt.showCommandGraph",
    "onCommand:arukellt.showEnvironmentDiff",
    "onCommand:arukellt.openDocs",
    "onCommand:arukellt.explainCode",
    "onCommand:arukellt.showPipeline",
    "onCommand:arukellt.securityReview",
    "onView:arukellt-project"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "arukellt",
        "aliases": [
          "Arukellt",
          "arukellt"
        ],
        "extensions": [
          ".ark"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "arukellt",
        "scopeName": "source.arukellt",
        "path": "./syntaxes/arukellt.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "arukellt",
        "path": "./snippets/arukellt.json"
      }
    ],
    "commands": [
      {
        "command": "arukellt.restartLanguageServer",
        "title": "Arukellt: Restart Language Server"
      },
      {
        "command": "arukellt.checkCurrentFile",
        "title": "Arukellt: Check Current File"
      },
      {
        "command": "arukellt.compileCurrentFile",
        "title": "Arukellt: Compile Current File"
      },
      {
        "command": "arukellt.runCurrentFile",
        "title": "Arukellt: Run Current File"
      },
      {
        "command": "arukellt.showSetupDoctor",
        "title": "Arukellt: Show Setup Doctor"
      },
      {
        "command": "arukellt.showCommandGraph",
        "title": "Arukellt: Show Command Graph"
      },
      {
        "command": "arukellt.showEnvironmentDiff",
        "title": "Arukellt: Show Environment Diff"
      },
      {
        "command": "arukellt.openDocs",
        "title": "Arukellt: Open Documentation"
      },
      {
        "command": "arukellt.explainCode",
        "title": "Arukellt: Explain Code"
      },
      {
        "command": "arukellt.showPipeline",
        "title": "Arukellt: Show Compiler Pipeline"
      },
      {
        "command": "arukellt.securityReview",
        "title": "Arukellt: Extension Security Review"
      },
      {
        "command": "arukellt.showOutput",
        "title": "Show Language Server Output",
        "category": "Arukellt"
      },
      {
        "command": "arukellt.refreshProjectTree",
        "title": "Refresh Project Tree",
        "category": "Arukellt",
        "icon": "$(refresh)"
      },
      {
        "command": "arukellt.toggleVerboseLogging",
        "title": "Toggle Verbose Logging",
        "category": "Arukellt"
      },
      {
        "command": "arukellt.runScript",
        "title": "Run Script",
        "category": "Arukellt"
      }
    ],
    "configuration": {
      "title": "Arukellt",
      "properties": {
        "arukellt.server.path": {
          "type": "string",
          "default": "arukellt",
          "description": "Path to the arukellt CLI used to launch the language server."
        },
        "arukellt.server.args": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string"
          },
          "description": "Additional arguments passed before the built-in `lsp` subcommand."
        },
        "arukellt.target": {
          "type": "string",
          "default": "wasm32-wasi-p1",
          "description": "Default target passed by extension commands such as check, compile, and run."
        },
        "arukellt.emit": {
          "type": "string",
          "default": "core-wasm",
          "description": "Default emit kind passed by extension compile commands."
        }
      }
    },
    "debuggers": [
      {
        "type": "arukellt",
        "label": "Arukellt Debug",
        "languages": [
          "arukellt"
        ],
        "configurationAttributes": {
          "launch": {
            "required": [
              "program"
            ],
            "properties": {
              "program": {
                "type": "string",
                "description": "Path to the .ark file to debug.",
                "default": "${file}"
              },
              "target": {
                "type": "string",
                "description": "Compilation target.",
                "default": "wasm32-wasi-p1"
              },
              "stopOnEntry": {
                "type": "boolean",
                "description": "Pause on the first statement.",
                "default": false
              }
            }
          }
        },
        "initialConfigurations": [
          {
            "type": "arukellt",
            "request": "launch",
            "name": "Debug Arukellt Program",
            "program": "${file}"
          }
        ],
        "configurationSnippets": [
          {
            "label": "Arukellt: Launch",
            "description": "Launch and debug an Arukellt (.ark) file.",
            "body": {
              "type": "arukellt",
              "request": "launch",
              "name": "Debug Arukellt Program",
              "program": "^\"\\${file}\""
            }
          }
        ]
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "arukellt",
          "title": "Arukellt",
          "icon": "$(code)"
        }
      ]
    },
    "views": {
      "arukellt": [
        {
          "id": "arukellt-project",
          "name": "Project",
          "icon": "$(folder)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "arukellt-project",
        "contents": "No Arukellt project found.\n[Initialize Project](command:arukellt.initProject)\nOpen a folder containing ark.toml to get started."
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "arukellt.refreshProjectTree",
          "when": "view == arukellt-project",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "arukellt.runCurrentFile",
          "when": "resourceLangId == arukellt",
          "group": "arukellt"
        },
        {
          "command": "arukellt.checkCurrentFile",
          "when": "resourceLangId == arukellt",
          "group": "arukellt"
        },
        {
          "command": "arukellt.compileCurrentFile",
          "when": "resourceLangId == arukellt",
          "group": "arukellt"
        }
      ],
      "editor/title": [
        {
          "command": "arukellt.runCurrentFile",
          "when": "resourceLangId == arukellt",
          "group": "navigation"
        }
      ],
      "explorer/context": [
        {
          "command": "arukellt.runCurrentFile",
          "when": "resourceLangId == arukellt",
          "group": "arukellt"
        }
      ]
    },
    "problemMatchers": [
      {
        "name": "arukellt",
        "owner": "arukellt",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(error|warning|info)\\[([A-Z]\\d+)\\]: (.+) at (.+):(\\d+):(\\d+)$",
          "severity": 1,
          "code": 2,
          "message": 3,
          "file": 4,
          "line": 5,
          "column": 6
        }
      },
      {
        "name": "arukellt-watch",
        "owner": "arukellt",
        "fileLocation": [
          "relative",
          "${workspaceFolder}"
        ],
        "pattern": {
          "regexp": "^(error|warning|info)\\[([A-Z]\\d+)\\]: (.+) at (.+):(\\d+):(\\d+)$",
          "severity": 1,
          "code": 2,
          "message": 3,
          "file": 4,
          "line": 5,
          "column": 6
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^\\[watch\\] file change detected",
          "endsPattern": "^\\[watch\\] compilation (finished|failed)"
        }
      }
    ],
    "taskDefinitions": [
      {
        "type": "arukellt",
        "required": [
          "task"
        ],
        "properties": {
          "task": {
            "type": "string",
            "description": "The Arukellt task to execute (check, compile, run, test, fmt, watch)"
          },
          "command": {
            "type": "string",
            "description": "The arukellt CLI command to run"
          },
          "isBackground": {
            "type": "boolean",
            "description": "Whether this is a background (watch) task"
          }
        }
      }
    ]
  },
  "scripts": {
    "lint": "node -e \"const ext=require('./src/extension.js'); const result=ext.verifyBootstrap(); if(!result.command){process.exit(1)}\"",
    "test": "vscode-test",
    "package": "vsce package",
    "build": "npm run package"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0"
  }
}
