// Gloss markup parser — generates an Event stream from Gloss Markdown.
//
// Gloss extends standard Markdown with five named features:
// - Ruby   ([base/reading])  — phonetic annotation above text
// - Anno   ({base/note1/note2/...}) — semantic annotation below text
// - Nest   (--- / ;;;) — explicit section-close markers
// - Math   ($…$ / $$…$$) — KaTeX math
// - Lint   — parser warnings collected in warnings as Warning values
//
// NOTE: This is a v0 arukellt transliteration of parser.rs.
// It demonstrates the language's expressiveness and limitations.
import io

fn str_find(s: String, needle: String) -> Option<i32> {
    let n = len(needle)
    let m = len(s)
    let mut i = 0
    while i + n <= m {
        if substring(s, i, i + n) == needle {
            return Some(i)
        }
        i = i + 1
    }
    None
}

fn str_char_count(s: String) -> i32 {
    len(s)
}

fn trim_start(s: String) -> String {
    let mut i = 0
    while i < len(s) && char_at(s, i) == 32 || char_at(s, i) == 9 || char_at(s, i) == 13 {
        i = i + 1
    }
    substring(s, i, len(s))
}

fn char_byte_len(c: i32) -> i32 {
    if c < 128 {
        1
    } else {
        if c < 224 {
            2
        } else {
            if c < 240 {
                3
            } else {
                4
            }
        }
    }
}

fn char_at_char_index(s: String, i: i32) -> i32 {
    char_at(s, i)
}

