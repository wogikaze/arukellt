                      "fontFamily": "JetBrains Mono",
                      "fontSize": 14,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "text",
                      "id": "jsRTg",
                      "name": "introText2",
                      "fill": "#A3A3A3",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "Whether you're building command-line tools, web servers, or exploring language design, mylang provides a productive and enjoyable development experience.",
                      "lineHeight": 1.7,
                      "fontFamily": "JetBrains Mono",
                      "fontSize": 14,
                      "fontWeight": "normal"
