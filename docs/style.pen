                    {
                      "type": "text",
                      "id": "Zo7Wv",
                      "name": "introText",
                      "fill": "#A3A3A3",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "mylang is a statically-typed, expression-based programming language designed for clarity and simplicity. It compiles to native machine code and features a clean syntax inspired by functional programming principles.",
