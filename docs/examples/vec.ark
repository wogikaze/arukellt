fn main() {
    let v = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    println(i32_to_string(len(v)))
    match get(v, 0) {
        Some(val) => println(i32_to_string(val)),
        None => println("out of bounds"),
    }
    match get(v, 1) {
        Some(val) => println(i32_to_string(val)),
        None => println("out of bounds"),
    }
    match get(v, 2) {
        Some(val) => println(i32_to_string(val)),
        None => println("out of bounds"),
    }
}
