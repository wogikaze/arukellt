use std::host::stdio

fn divide(a: i32, b: i32) -> Result<i32, String> {
    if b == 0 {
        Err(String_from("division by zero"))
    } else {
        Ok(a / b)
    }
}

fn main() {
    match divide(10, 2) {
        Result::Ok(v) => stdio::println(i32_to_string(v)),
        Result::Err(e) => stdio::println(e),
    }
    match divide(10, 0) {
        Result::Ok(v) => stdio::println(i32_to_string(v)),
        Result::Err(e) => stdio::println(e),
    }
}
