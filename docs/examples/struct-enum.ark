use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

enum Color {
    Red,
    Green,
    Blue,
}

fn main() {
    let p = Point { x: 10, y: 20 }
    stdio::println((p.x).to_string())
    stdio::println((p.y).to_string())
    let c = Color::Red
    match c {
        Color::Red => stdio::println("red"),
        Color::Green => stdio::println("green"),
        Color::Blue => stdio::println("blue"),
    }
}
