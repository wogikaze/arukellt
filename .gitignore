benchmarks/*.wasm
benchmarks/*.bench.wasm
benchmarks/results/*.wasm

# local-only reference specs (not tracked; cause docs-gen drift)
docs/spec/spec-*/

# bootstrap verification scratch directories
.bootstrap-build/
.compare-outputs-scratch/

# Node.js
**/node_modules/

# VS Code test downloads
**/.vscode-test/
