// Arukellt Parser - string import declaration syntax.

use lexer::tokens
use parser::core_ast_text_fields
use parser::core_ast_factory
use parser::core_api_cursor
use parser::core_api_expect
use parser::kinds
use parser::token_state

fn parse_import_decl(p: Parser) -> AstNode {
    let t = core_api_expect::expect_token(p, tokens::TK_IMPORT())
    let node = core_ast_factory::AstNode_new(kinds::NK_IMPORT(), core_api_expect::tok_span(t))
    core_api_cursor::skip_newlines(p)
    let path_tok = core_api_expect::expect_token(p, tokens::TK_STRING())
    core_ast_text_fields::AstNode_set_text(node, token_state::Token_text(path_tok))
    node
}
