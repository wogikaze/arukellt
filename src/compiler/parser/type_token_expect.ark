use lexer::tokens
use parser::core_api_expect

// Arukellt Parser - type parser token expectations.

fn expect_ident(p: Parser) -> Token {
    core_api_expect::expect_token(p, tokens::TK_IDENT())
}

fn expect_comma(p: Parser) -> Token {
    core_api_expect::expect_token(p, tokens::TK_COMMA())
}

fn expect_lparen(p: Parser) -> Token {
    core_api_expect::expect_token(p, tokens::TK_LPAREN())
}

fn expect_rparen(p: Parser) -> Token {
    core_api_expect::expect_token(p, tokens::TK_RPAREN())
}
