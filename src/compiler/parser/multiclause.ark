use parser::core_ast_span_fields
use parser::core_ast_children
// Arukellt Parser - multi-clause function desugaring

use parser::multiclause_base
use parser::multiclause_plain
use parser::multiclause_where

fn desugar_multiclause(clauses: Vec<AstNode>, is_pub: bool, where_bindings: Vec<AstNode>, is_async: bool) -> AstNode {
    let first = get_unchecked(clauses, 0)
    let fn_span = core_ast_span_fields::AstNode_span(first)
    let result = multiclause_base::build_multiclause_fn_base(first, is_pub, fn_span, is_async)
    let first_child_count = core_ast_children::AstNode_child_count(first)
    let param_count = first_child_count - 1
    if len(where_bindings) > 0 {
        return multiclause_where::desugar_multiclause_with_where(result, first, clauses, where_bindings, fn_span)
    }
    multiclause_plain::desugar_multiclause_plain(result, clauses, param_count, fn_span)
}
