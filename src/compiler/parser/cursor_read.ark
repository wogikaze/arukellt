use lexer::tokens
// Arukellt Parser - parser cursor read operations.

use parser::core_types
use parser::state_record
use parser::token_state

fn cur(p: Parser) -> Token {
    if state_record::parser_at_end(p) {
        let tok = token_state::Token_new(tokens::TK_EOF(), String_from(""), 0, 0)
        return tok
    }
    state_record::parser_current_token(p)
}

fn peek_kind(p: Parser) -> i32 {
    let t = cur(p)
    token_state::Token_kind(t)
}

fn at(p: Parser, kind: i32) -> bool {
    peek_kind(p) == kind
}

fn at_eof(p: Parser) -> bool {
    at(p, tokens::TK_EOF())
}

fn peek_text(p: Parser) -> String {
    let t = cur(p)
    token_state::Token_text(t)
}

// Peek token kind at an absolute token index (no newline skipping).
fn peek_kind_at_index(p: Parser, idx: i32) -> i32 {
    if idx >= state_record::parser_token_count(p) {
        return tokens::TK_EOF()
    }
    let t = state_record::parser_token_at(p, idx)
    token_state::Token_kind(t)
}

// Peek token text at an absolute token index (no newline skipping).
fn peek_text_at_index(p: Parser, idx: i32) -> String {
    if idx >= state_record::parser_token_count(p) {
        return String_new()
    }
    let t = state_record::parser_token_at(p, idx)
    token_state::Token_text(t)
}
