use parser::kinds
// Arukellt Parser - literal expression AST node display names


fn expr_literal_node_kind_name(kind: i32) -> String {
    if kind == kinds::NK_INT_LIT() {
        return String_from("IntLit")
    }
    if kind == kinds::NK_FLOAT_LIT() {
        return String_from("FloatLit")
    }
    if kind == kinds::NK_STRING_LIT() {
        return String_from("StringLit")
    }
    if kind == kinds::NK_BOOL_LIT() {
        return String_from("BoolLit")
    }
    String_new()
}
