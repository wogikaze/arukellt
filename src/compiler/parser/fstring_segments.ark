// Arukellt Parser - f-string segment scanning.

use lexer::scan
use parser::core_api_token
use parser::fstring_nodes

fn fstring_collect_segments(content: String, span: Span) -> Vec<AstNode> {
    let clen = len(content)
    let mut nodes: Vec<AstNode> = Vec_new_AstNode()
    let mut lit_start = 0
    let mut i = 0
    while i < clen {
        let c = char_at(content, i)
        if c == 123 {
            if i > lit_start {
                push(nodes, fstring_nodes::fstring_string_lit(substring(content, lit_start, i), span))
            }
            i = fstring_push_expr_segment(nodes, content, span, i)
            lit_start = i
        } else {
            i = i + 1
        }
    }
    if lit_start < clen {
        push(nodes, fstring_nodes::fstring_string_lit(substring(content, lit_start, clen), span))
    }
    nodes
}

fn fstring_push_expr_segment(nodes: Vec<AstNode>, content: String, span: Span, open_idx: i32) -> i32 {
    let clen = len(content)
    let expr_start = open_idx + 1
    let mut depth = 1
    let mut i = open_idx + 1
    while i < clen && depth > 0 {
        let ec = char_at(content, i)
        if ec == 123 {
            depth = depth + 1
        }
        if ec == 125 {
            depth = depth - 1
        }
        i = i + 1
    }
    let expr_text = substring(content, expr_start, i - 1)
    let toks = scan::tokenize(clone(expr_text))
    let sub_p = Parser_new(toks)
    let expr = parse_expr(sub_p)
    push(nodes, fstring_nodes::fstring_to_string_call(expr, span))
    i
}
