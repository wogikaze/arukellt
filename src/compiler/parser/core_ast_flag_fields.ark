use parser::ast_fields_record

fn AstNode_set_is_pub(node: AstNode, is_pub: bool) { ast_fields_record::ast_node_set_is_pub(node, is_pub) }
fn AstNode_set_is_mut(node: AstNode, is_mut: bool) { ast_fields_record::ast_node_set_is_mut(node, is_mut) }
fn AstNode_set_is_async(node: AstNode, is_async: bool) { ast_fields_record::ast_node_set_is_async(node, is_async) }
fn AstNode_is_async(node: AstNode) -> bool { ast_fields_record::ast_node_is_async(node) }
