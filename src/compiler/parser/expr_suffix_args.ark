use lexer::tokens
use parser::core_ast_children

fn parse_call_args(p: Parser, node: AstNode) {
    let mut first = true
    while !at(p, tokens::TK_RPAREN()) && !at_eof(p) {
        if !first {
            expect_token(p, tokens::TK_COMMA())
        }
        first = false
        skip_newlines(p)
        let arg = parse_expr(p)
        core_ast_children::AstNode_push_child(node, arg)
    }
    expect_token(p, tokens::TK_RPAREN())
}
