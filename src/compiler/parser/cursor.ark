use parser::cursor_advance
use parser::cursor_read

fn cur(p: Parser) -> Token {
    cursor_read::cur(p)
}

fn peek_kind(p: Parser) -> i32 {
    cursor_read::peek_kind(p)
}

fn at(p: Parser, kind: i32) -> bool {
    cursor_read::at(p, kind)
}

fn at_eof(p: Parser) -> bool {
    cursor_read::at_eof(p)
}

fn bump(p: Parser) -> Token {
    cursor_advance::bump(p)
}

fn skip_newlines(p: Parser) {
    cursor_advance::skip_newlines(p)
}

fn skip_only_newlines(p: Parser) {
    cursor_advance::skip_only_newlines(p)
}

fn peek_text(p: Parser) -> String {
    cursor_read::peek_text(p)
}

fn peek_kind_at_index(p: Parser, idx: i32) -> i32 {
    cursor_read::peek_kind_at_index(p, idx)
}

fn peek_text_at_index(p: Parser, idx: i32) -> String {
    cursor_read::peek_text_at_index(p, idx)
}
