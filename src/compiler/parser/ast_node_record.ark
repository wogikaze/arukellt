// Arukellt Parser - AST node record and constructors.

use parser::ast_span_record

pub struct AstNode {
    kind: i32,
    span: Span,
    text: String,
    int_val: i32,
    float_val: f64,
    op: i32,
    children: Vec<AstNode>,
    type_ann: Vec<AstNode>,
    is_mut: bool,
    is_pub: bool,
}

fn AstNode_new(kind: i32, span: Span) -> AstNode {
    AstNode { kind: kind, span: span, text: String_new(), int_val: 0, float_val: 0.0, op: 0, children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(), is_mut: false, is_pub: false }
}

fn AstNode_leaf(kind: i32, text: String, span: Span) -> AstNode {
    AstNode { kind: kind, span: span, text: text, int_val: 0, float_val: 0.0, op: 0, children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(), is_mut: false, is_pub: false }
}

fn AstNode_int(kind: i32, val: i32, span: Span) -> AstNode {
    AstNode { kind: kind, span: span, text: String_new(), int_val: val, float_val: 0.0, op: 0, children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(), is_mut: false, is_pub: false }
}

fn AstNode_float(kind: i32, val: f64, span: Span) -> AstNode {
    AstNode { kind: kind, span: span, text: String_new(), int_val: 0, float_val: val, op: 0, children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(), is_mut: false, is_pub: false }
}
