use lexer::tokens
use parser::kinds
use parser::core_ast_factory
use parser::core_ast_children
// Arukellt Parser - array literal comma tail.

use parser::core_api_cursor
use parser::core_api_expect

pub fn parse_array_lit_tail(p: Parser, t: Token, first_elem: AstNode) -> AstNode {
    let node = core_ast_factory::AstNode_new(kinds::NK_ARRAY_LIT(), core_api_expect::tok_span(t))
    core_ast_children::AstNode_push_child(node, first_elem)
    while core_api_cursor::peek_kind(p) == tokens::TK_COMMA() {
        p.pos = p.pos + 1
        core_api_cursor::skip_newlines(p)
        if core_api_cursor::at(p, tokens::TK_RBRACKET()) {
            break
        }
        let elem = parse_expr(p)
        core_ast_children::AstNode_push_child(node, elem)
        core_api_cursor::skip_newlines(p)
    }
    core_api_expect::expect_token(p, tokens::TK_RBRACKET())
    node
}
