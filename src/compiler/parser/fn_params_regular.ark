use lexer::tokens
use parser::kinds
use parser::core_ast_factory
use parser::core_ast_children
use parser::core_ast_type_ann
// Arukellt Parser - regular function parameter syntax

use parser::core_api_cursor
use parser::core_api_expect
use parser::token_state
use parser::types

fn parse_regular_fn_params(p: Parser, node: AstNode) {
    core_api_expect::expect_token(p, tokens::TK_LPAREN())
    let mut first = true
    while !core_api_cursor::at(p, tokens::TK_RPAREN()) && !core_api_cursor::at_eof(p) {
        if !first {
            core_api_expect::expect_token(p, tokens::TK_COMMA())
        }
        first = false
        core_api_cursor::skip_newlines(p)
        let pname = core_api_expect::expect_token(p, tokens::TK_IDENT())
        let pname_text = token_state::Token_text(pname)
        let param = core_ast_factory::AstNode_leaf(kinds::NK_IDENT(), clone(pname_text), core_api_expect::tok_span(pname))
        if eq(clone(pname_text), "self") && core_api_cursor::peek_kind(p) != tokens::TK_COLON() {
            core_ast_children::AstNode_push_child(node, param)
        } else {
            core_api_expect::expect_token(p, tokens::TK_COLON())
            core_api_cursor::skip_newlines(p)
            let pty = types::parse_type(p)
            core_ast_type_ann::AstNode_push_type_ann(param, pty)
            core_ast_children::AstNode_push_child(node, param)
        }
        core_api_cursor::skip_newlines(p)
    }
    core_api_expect::expect_token(p, tokens::TK_RPAREN())
}
