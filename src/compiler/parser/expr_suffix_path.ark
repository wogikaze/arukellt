use lexer::tokens
use parser::core_ast_text_fields
use parser::core_ast_span_fields
use parser::kinds
use parser::core_ast_factory
use parser::core_ast_children
// Arukellt Parser - path suffixes

use parser::core_api_cursor
use parser::core_api_expect
use parser::expr_prefix_struct_fields
use parser::expr_prefix_struct_probe
use parser::state_record
use parser::token_state
use parser::types

pub fn parse_path_suffix(p: Parser, lhs: AstNode) -> AstNode {
    p.pos = p.pos + 1
    let seg = expect_token(p, tokens::TK_IDENT())
    let node = AstNode_new(kinds::NK_PATH(), core_ast_span_fields::AstNode_span(lhs))
    core_ast_text_fields::AstNode_set_text(node, concat(core_ast_text_fields::AstNode_text(lhs), concat(String_from("::"), token_state::Token_text(seg))))
    core_ast_children::AstNode_push_child(node, lhs)
    if expr_prefix_struct_probe::next_prefix_is_struct_lit(p) {
        let lit = expr_prefix_struct_fields::parse_struct_lit_fields(p, seg)
        core_ast_text_fields::AstNode_set_text(lit, core_ast_text_fields::AstNode_text(node))
        return lit
    }
    // Turbofish: Type::function<T>() — parse explicit type arguments after path.
    // Only attempt when the token after < is an identifier (valid type start).
    // Use backtracking: if the type arg list is not properly closed with >,
    // restore position so < is treated as a binary less-than operator.
    if core_api_cursor::peek_kind(p) == tokens::TK_LT() {
        let saved_pos = state_record::parser_position(p)
        p.pos = p.pos + 1
        core_api_cursor::skip_newlines(p)
        if core_api_cursor::peek_kind(p) == tokens::TK_IDENT() {
            let type_args = parse_turbofish_type_args(p)
            if len(type_args) > 0 {
                let mut k = 0
                while k < len(type_args) {
                    core_ast_children::AstNode_push_child(node, get_unchecked(type_args, k))
                    k = k + 1
                }
                // Rewrite Vec::new<T>() path text to Vec_new_<T> so the
                // resolver/typechecker/lowering see the intrinsic name directly.
                let path_text = core_ast_text_fields::AstNode_text(node)
                if eq(clone(path_text), String_from("Vec::new")) {
                    let elem_name = core_ast_text_fields::AstNode_text(get_unchecked(type_args, 0))
                    core_ast_text_fields::AstNode_set_text(node, concat(String_from("Vec_new_"), elem_name))
                }
            } else {
                state_record::parser_set_position(p, saved_pos)
            }
        } else {
            state_record::parser_set_position(p, saved_pos)
        }
    }
    // Rewrite known builtin associated functions (no turbofish) to intrinsic names.
    // String::from(x) → String_from, i32::from(s) → parse_i32.
    // This lets the resolver/typechecker/lowering see the prelude function directly.
    let final_text = core_ast_text_fields::AstNode_text(node)
    if eq(clone(final_text), String_from("String::from")) {
        core_ast_text_fields::AstNode_set_text(node, String_from("String_from"))
    }
    if eq(clone(final_text), String_from("i32::from")) {
        core_ast_text_fields::AstNode_set_text(node, String_from("parse_i32"))
    }
    node
}

// Parse turbofish type arguments: < already consumed, parse type, type, ... >
// Returns a Vec of type AST nodes, or empty Vec if > not found (backtrack needed).
fn parse_turbofish_type_args(p: Parser) -> Vec<AstNode> {
    let args = Vec_new_AstNode()
    let mut first = true
    while true {
        core_api_cursor::skip_newlines(p)
        if core_api_cursor::peek_kind(p) == tokens::TK_GT() {
            p.pos = p.pos + 1
            return args
        }
        if core_api_cursor::peek_kind(p) == tokens::TK_SHR() {
            // Split >> into > and remaining >
            let t = core_api_cursor::cur(p)
            let gt_tok = token_state::Token_new(tokens::TK_GT(), String_from(">"), token_state::Token_start(t), token_state::Token_end(t))
            state_record::parser_set_current_token(p, gt_tok)
            return args
        }
        if !first {
            if core_api_cursor::peek_kind(p) != tokens::TK_COMMA() {
                return Vec_new_AstNode()
            }
            p.pos = p.pos + 1
            core_api_cursor::skip_newlines(p)
        }
        first = false
        if core_api_cursor::peek_kind(p) != tokens::TK_IDENT() {
            return Vec_new_AstNode()
        }
        let arg = types::parse_type(p)
        push(args, arg)
    }
    args
}
