use parser::fstring_nodes

fn fstring_concat_segments(nodes: Vec<AstNode>, span: Span) -> AstNode {
    let n = len(nodes)
    if n == 0 {
        return fstring_nodes::fstring_string_lit(String_new(), span)
    }
    if n == 1 {
        return get_unchecked(nodes, 0)
    }
    let mut result = get_unchecked(nodes, 0)
    let mut j = 1
    while j < n {
        result = fstring_nodes::fstring_concat_call(result, get_unchecked(nodes, j), span)
        j = j + 1
    }
    result
}
