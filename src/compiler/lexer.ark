}
String_from("UNKNOWN")
}
fn print_token(tok: Token) {
let kind_str = token_kind_name(tok.kind)
let pos_str = i32_to_string(tok.start)
if tok.kind == TK_IDENT() || tok.kind == TK_STRING() || tok.kind == TK_ERROR() {
stdio::println(concat(concat(concat(kind_str, "("), tok.text), ")"))
} else {
if tok.kind == TK_INT() {
stdio::println(concat(concat(concat(kind_str, "("), i32_to_string(tok.int_val)), ")"))
} else {
if tok.kind == TK_FLOAT() {
stdio::println(concat(concat(concat(kind_str, "("), f64_to_string(tok.float_val)), ")"))
} else {
if tok.kind == TK_BOOL() {
stdio::println(concat(concat(concat(kind_str, "("), tok.text), ")"))
} else {
if tok.kind == TK_NEWLINE() {
} else {
stdio::println(kind_str)
}
}
}
}
}
}
fn main() {
let source = String_from("fn main() {\n    let x: i32 = 42\n    stdio::println(i32_to_string(x))\n}\n")
let tokens = tokenize(source)
let mut i = 0
let mut done = false
while !done {
let tok = get_unchecked(tokens, i)
print_token(tok)
if tok.kind == TK_EOF() {
done = true
}
i = i + 1
}
stdio::println(String_from("Done."))
}
pub fn LEX_CODE_PREFIX() -> String {
String_from("LEX")
}
pub fn lex_diag_code_message(code: i32) -> String {
if code == LEX_E_UNTERMINATED_STRING() {
return String_from("unterminated string")
}
if code == LEX_E_UNTERMINATED_CHAR() {
return String_from("unterminated char literal")
}
if code == LEX_E_UNTERMINATED_FSTRING() {
return String_from("unterminated f-string")
}
if code == LEX_E_UNTERMINATED_ESCAPE() {
return String_from("unterminated escape")
}
if code == LEX_E_INVALID_NUMBER() {
return String_from("invalid number literal")
}
if code == LEX_E_UNKNOWN_CHAR() {
return String_from("unknown character")
}
String_from("lex error")
}
pub fn lex_diag_code_string(code: i32) -> String {
if code == LEX_E_UNTERMINATED_STRING() {
return String_from("LEX0001")
}
if code == LEX_E_UNTERMINATED_CHAR() {
return String_from("LEX0002")
}
if code == LEX_E_UNTERMINATED_FSTRING() {
return String_from("LEX0003")
}
if code == LEX_E_UNTERMINATED_ESCAPE() {
return String_from("LEX0004")
}
if code == LEX_E_INVALID_NUMBER() {
return String_from("LEX0005")
}
if code == LEX_E_UNKNOWN_CHAR() {
return String_from("LEX0006")
}
String_from("LEX0000")
}
fn lex_offset_to_span(file: String, source: String, offset: i32) -> DiagnosticSpan {
let n = len(source)
let mut bound = offset
if bound > n {
bound = n
}
let mut line = 1
let mut col = 1
let mut i = 0
while i < bound {
let c = char_at(source, i)
if c == 10 {
line = line + 1
col = 1
} else {
col = col + 1
}
i = i + 1
}
DiagnosticSpan_new(file, line, col)
}
pub fn lex_diagnostics(source: String, file: String) -> Vec<Diagnostic> {
let lex_result = lex_program(clone(source))
let mut out: Vec<Diagnostic> = Vec_new_Diagnostic()
let n = len(lex_result.diagnostics)
let mut i = 0
while i < n {
let ld = get_unchecked(lex_result.diagnostics, i)
let offset = ld.start
let mline = lex_offset_to_line(clone(source), offset)
let mcol = lex_offset_to_column(clone(source), offset)
let mfile = clone(file)
let mmsg = lex_diag_code_message(ld.code)
let mcode = lex_diag_code_string(ld.code)
let mspan = DiagnosticSpan { file: mfile, line: mline, column: mcol }
let d = Diagnostic { code: mcode, severity: SEV_ERROR(), span: mspan, message: mmsg }
push(out, d)
i = i + 1
}
out
}
pub fn lex_offset_to_line(source: String, offset: i32) -> i32 {
let n = len(source)
let mut bound = offset
if bound > n { bound = n }
let mut line = 1
let mut i = 0
while i < bound {
let c = char_at(source, i)
if c == 10 { line = line + 1 }
i = i + 1
}
line
}
pub fn lex_offset_to_column(source: String, offset: i32) -> i32 {
let n = len(source)
let mut bound = offset
if bound > n { bound = n }
let mut col = 1
let mut i = 0
while i < bound {
let c = char_at(source, i)
if c == 10 { col = 1 } else { col = col + 1 }
i = i + 1
}
col
}
