pub struct LexDiagnostic {
code: i32,
message: String,
start: i32,
end: i32,
}
pub struct LexResult {
tokens: Vec<Token>,
diagnostics: Vec<LexDiagnostic>,
}
fn classify_lex_error(message: String) -> i32 {
if eq(clone(message), String_from("unterminated string")) {
return LEX_E_UNTERMINATED_STRING()
}
if eq(clone(message), String_from("unterminated escape")) {
return LEX_E_UNTERMINATED_ESCAPE()
}
if eq(clone(message), String_from("unterminated char literal")) {
return LEX_E_UNTERMINATED_CHAR()
}
if eq(clone(message), String_from("unterminated f-string")) {
return LEX_E_UNTERMINATED_FSTRING()
}
if starts_with(clone(message), String_from("invalid")) {
return LEX_E_INVALID_NUMBER()
}
LEX_E_UNKNOWN_CHAR()
}
pub fn lex_program(source: String) -> LexResult {
let toks = tokenize(clone(source))
let mut diags: Vec<LexDiagnostic> = Vec_new_LexDiagnostic()
let n = len(toks)
let mut i = 0
while i < n {
let t = get_unchecked(toks, i)
if t.kind == TK_ERROR() {
let code = classify_lex_error(clone(t.text))
push(diags, LexDiagnostic { code: code, message: clone(t.text), start: t.start, end: t.end })
}
i = i + 1
}
LexResult { tokens: toks, diagnostics: diags }
}
pub fn token_kind_name(kind: i32) -> String {
if kind == TK_EOF() {
return String_from("EOF")
}
