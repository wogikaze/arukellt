struct Token {
kind: i32,
text: String,
int_val: i32,
float_val: f64,
start: i32,
end: i32,
}
fn Token_new(kind: i32, text: String, start: i32, end: i32) -> Token {
Token { kind: kind, text: text, int_val: 0, float_val: 0.0, start: start, end: end }
}
fn Token_int(val: i32, text: String, start: i32, end: i32) -> Token {
Token { kind: TK_INT(), text: text, int_val: val, float_val: 0.0, start: start, end: end }
}
fn Token_float(val: f64, text: String, start: i32, end: i32) -> Token {
Token { kind: TK_FLOAT(), text: text, int_val: 0, float_val: val, start: start, end: end }
}
struct Lexer {
src: String,
pos: i32,
src_len: i32,
}
fn Lexer_new(source: String) -> Lexer {
let n = len(source)
Lexer { src: source, pos: 0, src_len: n }
}
fn is_alpha(c: i32) -> bool {
c >= 65 && c <= 90 || c >= 97 && c <= 122 || c == 95
}
fn is_digit(c: i32) -> bool {
c >= 48 && c <= 57
}
fn is_hex_digit(c: i32) -> bool {
is_digit(c) || c >= 65 && c <= 70 || c >= 97 && c <= 102
}
fn is_alnum(c: i32) -> bool {
is_alpha(c) || is_digit(c)
}
fn is_whitespace_not_newline(c: i32) -> bool {
c == 32 || c == 9 || c == 13
}
fn digit_value(c: i32) -> i32 {
if c >= 48 && c <= 57 {
c - 48
} else {
if c >= 65 && c <= 70 {
c - 55
} else {
if c >= 97 && c <= 102 {
c - 87
} else {
-1
}
}
}
}
fn keyword_kind(word: String) -> i32 {
if eq(word, "fn") {
return TK_FN()
}
if eq(word, "struct") {
return TK_STRUCT()
}
if eq(word, "enum") {
return TK_ENUM()
}
if eq(word, "let") {
return TK_LET()
}
if eq(word, "mut") {
return TK_MUT()
}
if eq(word, "if") {
return TK_IF()
}
if eq(word, "else") {
return TK_ELSE()
}
if eq(word, "match") {
return TK_MATCH()
}
if eq(word, "while") {
return TK_WHILE()
}
if eq(word, "loop") {
return TK_LOOP()
}
if eq(word, "for") {
return TK_FOR()
}
if eq(word, "in") {
return TK_IN()
}
if eq(word, "break") {
return TK_BREAK()
}
if eq(word, "continue") {
return TK_CONTINUE()
}
if eq(word, "return") {
return TK_RETURN()
}
if eq(word, "pub") {
return TK_PUB()
}
if eq(word, "import") {
return TK_IMPORT()
}
if eq(word, "as") {
return TK_AS()
}
if eq(word, "trait") {
return TK_TRAIT()
}
if eq(word, "impl") {
return TK_IMPL()
}
if eq(word, "use") {
return TK_USE()
}
if eq(word, "where") {
return TK_WHERE()
}
if eq(word, "true") {
return TK_BOOL()
}
if eq(word, "false") {
return TK_BOOL()
}
0 - 1
}
fn peek(lex: Lexer) -> i32 {
if lex.pos >= lex.src_len {
-1
} else {
char_at(lex.src, lex.pos)
}
}
fn peek_at(lex: Lexer, offset: i32) -> i32 {
let p = lex.pos + offset
if p >= lex.src_len {
-1
} else {
char_at(lex.src, p)
}
}
fn advance(lex: Lexer) -> i32 {
let c = char_at(lex.src, lex.pos)
lex.pos = lex.pos + 1
c
}
fn skip_whitespace(lex: Lexer) {
while lex.pos < lex.src_len && is_whitespace_not_newline(peek(lex)) {
lex.pos = lex.pos + 1
}
}
fn skip_line_comment(lex: Lexer) {
while lex.pos < lex.src_len && char_at(lex.src, lex.pos) != 10 {
lex.pos = lex.pos + 1
}
}
fn skip_block_comment(lex: Lexer) {
lex.pos = lex.pos + 2
let mut depth = 1
while lex.pos < lex.src_len - 1 && depth > 0 {
let c = char_at(lex.src, lex.pos)
let c2 = char_at(lex.src, lex.pos + 1)
if c == 47 && c2 == 42 {
depth = depth + 1
lex.pos = lex.pos + 2
} else {
if c == 42 && c2 == 47 {
depth = depth - 1
lex.pos = lex.pos + 2
} else {
lex.pos = lex.pos + 1
}
}
}
}
fn lex_ident(lex: Lexer) -> Token {
let start = lex.pos
while lex.pos < lex.src_len && is_alnum(peek(lex)) {
lex.pos = lex.pos + 1
}
let word = substring(lex.src, start, lex.pos)
if eq(clone(word), "f") {
if lex.pos < lex.src_len && peek(lex) == 34 {
return lex_fstring(lex, start)
}
}
let kw = keyword_kind(clone(word))
if kw >= 0 {
Token_new(kw, word, start, lex.pos)
} else {
Token_new(TK_IDENT(), word, start, lex.pos)
}
}
fn lex_fstring(lex: Lexer, start: i32) -> Token {
lex.pos = lex.pos + 1
let content_start = lex.pos
let mut depth = 0
while lex.pos < lex.src_len {
let c = peek(lex)
if c == 34 && depth == 0 {
let content = substring(lex.src, content_start, lex.pos)
lex.pos = lex.pos + 1
return Token_new(TK_FSTRING(), content, start, lex.pos)
}
if c == 10 {
return Token_new(TK_ERROR(), String_from("unterminated f-string"), start, lex.pos)
}
if c == 123 {
depth = depth + 1
}
if c == 125 {
depth = depth - 1
}
lex.pos = lex.pos + 1
}
Token_new(TK_ERROR(), String_from("unterminated f-string"), start, lex.pos)
}
fn lex_number(lex: Lexer) -> Token {
