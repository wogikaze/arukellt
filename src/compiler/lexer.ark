pub fn tokenize(source: String) -> Vec<Token> {
let mut lex = Lexer_new(source)
let mut tokens: Vec<Token> = Vec_new_Token()
let mut done = false
while !done {
let tok = next_token(lex)
if tok.kind == TK_EOF() {
push(tokens, tok)
done = true
} else {
push(tokens, tok)
}
}
tokens
}
pub fn LEX_E_UNTERMINATED_STRING() -> i32 {
