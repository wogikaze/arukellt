}
let esc = peek(lex)
lex.pos = lex.pos + 1
if esc == 110 {
result = concat(result, String_from("\n"))
} else {
if esc == 116 {
result = concat(result, String_from("\t"))
} else {
if esc == 114 {
result = concat(result, String_from("\r"))
} else {
if esc == 92 {
result = concat(result, String_from("\\"))
} else {
if esc == 34 {
result = concat(result, String_from("\""))
} else {
result = concat(result, substring(lex.src, lex.pos - 1, lex.pos))
