// Arukellt Selfhost - main namespace: project_run
use std::host::fs
use std::host::process
use std::host::stdio
use std::toml
use compiler::session_parse
use driver::config_record
use driver::file
use driver::result_record
use main::args_record
use main::output
use parser::ast
use parser::kinds as parser_kinds

fn build_run_driver_config(opts: CliOptions) -> DriverConfig {
    let config = config_record::DriverConfig_default()
    config_record::config_set_target(config, args_record::cli_target(opts))
    config_record::config_set_opt_level(config, args_record::cli_opt_level(opts))
    config_record::config_set_emit_mode(config, String_from("wasm"))
    config
}

fn print_run_compile_errors(input_file: String, result: CompileResult) {
    let err_count = result_record::compile_result_error_count(result)
    let mut i = 0
    while i < err_count {
        let msg = result_record::compile_result_error_message_at(result, i)
        stdio::eprintln(output::format_error(clone(input_file), clone(msg)))
        i = i + 1
    }
}

fn exit_run_compile_error(input_file: String, result: CompileResult) {
    print_run_compile_errors(input_file, result)
    process::exit(1)
}

fn run_output_path(opts: CliOptions, input_file: String) -> String {
    if args_record::cli_has_output_file(opts) {
        return args_record::cli_output_file(opts)
    }
    let base = clone(input_file)
    let base_len = len(base)
    if base_len > 4 {
        let ext = substring(base, base_len - 4, base_len)
        if eq(ext, ".ark") {
            return concat(substring(base, 0, base_len - 4), String_from(".wasm"))
        }
    }
    concat(clone(base), String_from(".wasm"))
}

fn write_run_output(input_file: String, out_path: String, bytes: Vec<i32>) {
    let write_result = fs::write_bytes(clone(out_path), bytes)
    match write_result {
        Result::Ok(_) => {
            stdio::eprintln(concat(String_from("compiled "), concat(clone(input_file), concat(String_from(" -> "), clone(out_path)))))
            stdio::eprintln(String_from("run: execute with `wasmtime <output.wasm>`"))
        },
        Result::Err(e) => {
            stdio::eprintln(concat(String_from("error writing output: "), e))
            process::exit(1)
        },
    }
}

pub fn cmd_run(opts: CliOptions) {
    let input_file = args_record::cli_input_file(opts)
    let config = build_run_driver_config(opts)
    let result = file::compile_file(clone(input_file), config)
    if !result_record::compile_result_success(result) {
        exit_run_compile_error(clone(input_file), result)
        return
    }
    let out_path = run_output_path(opts, clone(input_file))
    write_run_output(input_file, out_path, result_record::compile_result_output_bytes(result))
}

// Arukellt Selfhost - CLI test command implementation
fn build_test_driver_config(opts: CliOptions) -> DriverConfig {
    let config = config_record::DriverConfig_default()
    config_record::config_set_target(config, args_record::cli_target(opts))
    if args_record::cli_has_wasi_version(opts) {
        config_record::config_set_wasi_version(config, args_record::cli_wasi_version(opts))
    }
    config_record::config_set_opt_level(config, args_record::cli_opt_level(opts))
    config_record::config_set_emit_mode(config, args_record::cli_emit_mode(opts))
    config_record::config_set_wit_paths(config, args_record::cli_wit_paths(opts))
    config_record::config_set_check_only(config, true)
    let allows = args_record::cli_lint_allow(opts)
    push(allows, String_from("W0003"))
    push(allows, String_from("W0005"))
    push(allows, String_from("W0006"))
    push(allows, String_from("W0007"))
    config_record::config_set_lint_allow(config, allows)
    config_record::config_set_lint_deny(config, args_record::cli_lint_deny(opts))
    config
}

fn exit_missing_test_input() {
    stdio::eprintln(String_from("test: specify .ark file(s) to test"))
    stdio::eprintln(String_from("  usage: arukellt-s1 test <file.ark>"))
    process::exit(2)
}

fn exit_test_failure() {
    process::exit(1)
}

fn print_test_start(input_file: String) {
    stdio::eprintln(concat(String_from("testing "), input_file))
}

fn print_test_pass(input_file: String, test_count: i32) {
    stdio::println(concat(String_from("  PASS  "), concat(input_file, concat(String_from("  ("), concat(to_string(test_count), String_from(" tests)"))))))
}

fn print_test_fail(input_file: String, result: CompileResult) {
    stdio::println(concat(String_from("  FAIL  "), clone(input_file)))
    let err_count = result_record::compile_result_error_count(result)
    let mut i = 0
    while i < err_count {
        let msg = result_record::compile_result_error_message_at(result, i)
        stdio::eprintln(concat(String_from("    "), clone(msg)))
        i = i + 1
    }
}

pub fn cmd_test(opts: CliOptions) {
    if args_record::cli_has_input_file(opts) {
        let input_file = args_record::cli_input_file(opts)
        print_test_start(clone(input_file))
        let test_count = discover_and_print_tests(clone(input_file))
        let config = build_test_driver_config(opts)
        let result = file::compile_file(clone(input_file), config)
        if result_record::compile_result_success(result) {
            print_test_pass(input_file, test_count)
        } else {
            print_test_fail(input_file, result)
            exit_test_failure()
        }
    } else {
        exit_missing_test_input()
    }
}

// Arukellt Selfhost - test declaration discovery (ADR-041).
// Parses the source file and prints discovered `test` declarations.
// Returns the number of discovered tests.
fn discover_and_print_tests(input_file: String) -> i32 {
    let read_result = fs::read_to_string(clone(input_file))
    let mut count = 0
    match read_result {
        Result::Ok(source) => {
            let decls = session_parse::session_parse_decls(source)
            count = collect_test_names(decls, String_new())
        },
        Result::Err(_) => {
        },
    }
    count
}

fn collect_test_names(decls: Vec<AstNode>, prefix: String) -> i32 {
    let n = len(decls)
    let mut count = 0
    let mut i = 0
    while i < n {
        let d = get_unchecked(decls, i)
        count = count + collect_test_name_node(d, clone(prefix))
        i = i + 1
    }
    count
}

fn collect_test_name_node(node: AstNode, prefix: String) -> i32 {
    let kind = ast::ast_node_kind(node)
    if kind == parser_kinds::NK_TEST_DECL() {
        print_test_entry(prefix, ast::ast_node_text(node))
        return 1
    }
    if kind == parser_kinds::NK_TEST_MOD() {
        let mod_name = ast::ast_node_text(node)
        let new_prefix = make_test_prefix(clone(prefix), clone(mod_name))
        let cc = ast::ast_node_child_count(node)
        let mut count = 0
        let mut i = 0
        while i < cc {
            let inner = ast::ast_node_child_at(node, i)
            count = count + collect_test_name_node(inner, clone(new_prefix))
            i = i + 1
        }
        return count
    }
    0
}

fn make_test_prefix(prefix: String, name: String) -> String {
    if len(clone(prefix)) == 0 {
        return name
    }
    concat(prefix, concat(String_from("::"), name))
}

fn print_test_entry(prefix: String, name: String) {
    if len(clone(prefix)) == 0 {
        stdio::eprintln(concat(String_from("  test  "), name))
        return
    }
    stdio::eprintln(concat(String_from("  test  "), concat(prefix, concat(String_from("::"), name))))
}

// Arukellt Selfhost - minimal TOML value extraction for CLI project metadata
// ── TOML Value Extraction ────────────────────────────────────────────────────
fn find_toml_value(content: String, key: String) -> String {
    toml::toml_find_value(content, key)
}
