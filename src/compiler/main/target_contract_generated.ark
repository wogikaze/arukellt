fn target_is_canonical(input: String) -> bool {
    if eq(clone(input), String_from("wasm32")) {
        return true
    }
    if eq(clone(input), String_from("wasm32-gc")) {
        return true
    }
    if eq(clone(input), String_from("native-cpp")) {
        return true
    }
    if eq(clone(input), String_from("native-llvm")) {
        return true
    }
    false
}

