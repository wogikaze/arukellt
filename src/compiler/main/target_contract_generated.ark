fn target_alias_message(input: String) -> String {
    if eq(clone(input), String_from("wasm32-wasi-p1")) {
        return String_from("W0002: target `wasm32-wasi-p1` is deprecated; use `--target wasm32 --wasi-version wasi-p1`")
    }
    if eq(clone(input), String_from("wasm32-wasi")) {
        return String_from("W0002: target `wasm32-wasi` is deprecated; use `--target wasm32 --wasi-version wasi-p1`")
    }
    if eq(clone(input), String_from("wasm32-wasi-p2")) {
        return String_from("W0002: target `wasm32-wasi-p2` is deprecated; use `--target wasm32-gc --wasi-version wasi-p2`")
    }
    if eq(clone(input), String_from("wasm-gc")) {
        return String_from("W0002: target `wasm-gc` is deprecated; use `--target wasm32-gc --wasi-version wasi-p2`")
    }
    if eq(clone(input), String_from("wasm-gc-wasi-p2")) {
        return String_from("W0002: target `wasm-gc-wasi-p2` is deprecated; use `--target wasm32-gc --wasi-version wasi-p2`")
    }
    if eq(clone(input), String_from("wasm32-wasi-p3")) {
        return String_from("W0002: target `wasm32-wasi-p3` is deprecated; use `--target wasm32-gc --wasi-version wasi-p3`")
    }
    if eq(clone(input), String_from("native")) {
        return String_from("target `native` is not accepted; use --target native-cpp or --target native-llvm")
    }
    if eq(clone(input), String_from("wasm32-freestanding")) {
        return String_from("target `wasm32-freestanding` is not accepted; choose a canonical target; freestanding is not supported")
    }
    String_new()
}
