// Arukellt Selfhost - manifest doc text/json rendering (#456).

use std::host::stdio
use std::text
use std::json::parser
use main::manifest_doc_lookup
use main::manifest_doc_record

fn doc_target_is_p1(target: String) -> bool {
    contains(clone(target), String_from("wasm32-wasi-p1"))
}

fn doc_target_is_p2(target: String) -> bool {
    contains(clone(target), String_from("wasm32-wasi-p2"))
}

fn doc_target_warning(e: manifest_doc_record::DocFnEntry, filter_target: String) -> String {
    if len(filter_target) == 0 {
        return String_new()
    }
    if doc_target_is_p1(clone(filter_target)) && manifest_doc_record::DocFnEntry_avail_t1(e) == 0 {
        return concat(String_from("Not available on "), clone(filter_target))
    }
    if doc_target_is_p2(clone(filter_target)) && manifest_doc_record::DocFnEntry_avail_t3(e) == 0 {
        return concat(String_from("Not available on "), clone(filter_target))
    }
    String_new()
}

fn doc_format_signature(e: manifest_doc_record::DocFnEntry) -> String {
    let mut sig = concat(String_from("fn "), manifest_doc_record::DocFnEntry_name(e))
    sig = text::builder_append(sig, String_from("("))
    let params = manifest_doc_record::DocFnEntry_params(e)
    if len(params) > 0 {
        sig = text::builder_append(sig, params)
    }
    sig = text::builder_append(sig, String_from(") -> "))
    let ret = manifest_doc_record::DocFnEntry_returns(e)
    if len(ret) > 0 {
        sig = text::builder_append(sig, ret)
    } else {
        sig = text::builder_append(sig, String_from("()"))
    }
    text::builder_build(sig)
}

pub fn doc_print_function(e: manifest_doc_record::DocFnEntry, filter_target: String) {
    let warn = doc_target_warning(e, clone(filter_target))
    if len(warn) > 0 {
        stdio::println(concat(String_from("warning: "), warn))
    }
    stdio::println(doc_format_signature(e))
    stdio::println(concat(String_from("  Module: "), manifest_doc_record::DocFnEntry_module(e)))
    let stab = manifest_doc_record::DocFnEntry_stability(e)
    if len(stab) > 0 {
        stdio::println(concat(String_from("  Stability: "), stab))
    }
    let tgt = manifest_doc_record::DocFnEntry_target(e)
    if len(tgt) > 0 {
        stdio::println(concat(String_from("  Supported on: "), tgt))
    } else {
        if manifest_doc_record::DocFnEntry_avail_t1(e) == 1 && manifest_doc_record::DocFnEntry_avail_t3(e) == 1 {
            stdio::println(String_from("  Supported on: wasm32-wasi-p1, wasm32-wasi-p2"))
        } else {
            if manifest_doc_record::DocFnEntry_avail_t3(e) == 1 {
                stdio::println(String_from("  Supported on: wasm32-wasi-p2"))
            }
        }
    }
    let doc = manifest_doc_record::DocFnEntry_doc(e)
    if len(doc) > 0 {
        stdio::println(String_from(""))
        stdio::println(concat(String_from("  "), doc))
    }
    let err = manifest_doc_record::DocFnEntry_errors(e)
    if len(err) > 0 {
        stdio::println(String_from(""))
        stdio::println(concat(String_from("  Errors: "), err))
    }
}

pub fn doc_emit_function_json(e: manifest_doc_record::DocFnEntry, filter_target: String) {
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("kind"), parser::json_str(String_from("function"))))
    push(fields, parser::json_field(String_from("name"), parser::json_str(manifest_doc_record::DocFnEntry_name(e))))
    push(fields, parser::json_field(String_from("module"), parser::json_str(manifest_doc_record::DocFnEntry_module(e))))
    push(fields, parser::json_field(String_from("params"), parser::json_str(manifest_doc_record::DocFnEntry_params(e))))
    push(fields, parser::json_field(String_from("returns"), parser::json_str(manifest_doc_record::DocFnEntry_returns(e))))
    push(fields, parser::json_field(String_from("stability"), parser::json_str(manifest_doc_record::DocFnEntry_stability(e))))
    push(fields, parser::json_field(String_from("avail_t1"), parser::json_bool(manifest_doc_record::DocFnEntry_avail_t1(e) == 1)))
    push(fields, parser::json_field(String_from("avail_t3"), parser::json_bool(manifest_doc_record::DocFnEntry_avail_t3(e) == 1)))
    let doc = manifest_doc_record::DocFnEntry_doc(e)
    if len(doc) > 0 {
        push(fields, parser::json_field(String_from("doc"), parser::json_str(doc)))
    }
    let warn = doc_target_warning(e, clone(filter_target))
    if len(warn) > 0 {
        push(fields, parser::json_field(String_from("target_warning"), parser::json_str(warn)))
    }
    stdio::println(parser::json_obj_string(fields))
}

pub fn doc_print_module(table: manifest_doc_record::DocManifestTable, module: String, filter_target: String) {
    let mid = manifest_doc_lookup::doc_find_module(table, clone(module))
    stdio::println(concat(String_from("module "), clone(module)))
    if mid >= 0 {
        let m = manifest_doc_record::DocManifestTable_module_at(table, mid)
        let stab = manifest_doc_record::DocModuleEntry_stability(m)
        if len(stab) > 0 {
            stdio::println(concat(String_from("  Stability: "), stab))
        }
        let tgt = manifest_doc_record::DocModuleEntry_target(m)
        if len(tgt) > 0 {
            stdio::println(concat(String_from("  Supported on: "), tgt))
        }
        let doc = manifest_doc_record::DocModuleEntry_doc(m)
        if len(doc) > 0 {
            stdio::println(String_from(""))
            stdio::println(concat(String_from("  "), doc))
        }
    }
    stdio::println(String_from(""))
    stdio::println(String_from("  Functions:"))
    let n = manifest_doc_record::DocManifestTable_function_count(table)
    let mut i = 0
    while i < n {
        let e = manifest_doc_record::DocManifestTable_function_at(table, i)
        if eq(manifest_doc_record::DocFnEntry_module(e), clone(module)) {
            let warn = doc_target_warning(e, clone(filter_target))
            let mut line = concat(String_from("    "), doc_format_signature(e))
            if len(warn) > 0 {
                line = text::builder_append(line, concat(String_from("  ["), concat(warn, String_from("]"))))
            }
            stdio::println(line)
        }
        i = i + 1
    }
}
