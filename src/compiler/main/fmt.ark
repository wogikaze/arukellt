// Arukellt Selfhost - CLI fmt command.

use std::host::fs
use std::host::process
use std::host::stdio
use diagnostics::record
use fmt
use main::args_record

pub fn cmd_fmt(opts: CliOptions) {
    let input_file = args_record::cli_input_file(opts)
    if len(input_file) == 0 {
        stdio::eprintln(String_from("usage: arukellt fmt <file.ark> [--check]"))
        process::exit(2)
        return
    }
    let read_result = fs::read_to_string(clone(input_file))
    match read_result {
        Result::Ok(text) => {
            let formatted_opt = fmt::format_source(text)
            match formatted_opt {
                Option::None => {
                    fmt_emit_parse_errors(text)
                    process::exit(1)
                },
                Option::Some(formatted) => {
                    if args_record::cli_fmt_check(opts) {
                        if !eq(clone(formatted), clone(text)) {
                            stdio::eprintln(concat(String_from("fmt check failed: "), clone(input_file)))
                            process::exit(1)
                        }
                        stdio::eprintln(concat(String_from("ok: "), clone(input_file)))
                        return
                    }
                    let write_result = fs::write_string(clone(input_file), clone(formatted))
                    match write_result {
                        Result::Ok(_) => {
                            stdio::eprintln(concat(String_from("formatted "), clone(input_file)))
                        },
                        Result::Err(e) => {
                            stdio::eprintln(concat(String_from("error writing formatted file: "), e))
                            process::exit(1)
                        },
                    }
                },
            }
        },
        Result::Err(e) => {
            stdio::eprintln(concat(String_from("error reading input: "), e))
            process::exit(1)
        },
    }
}

fn fmt_emit_parse_errors(text: String) {
    let count = fmt::format_parse_error_count(clone(text))
    let mut i = 0
    while i < count {
        let diag = fmt::format_parse_error_at(clone(text), i)
        stdio::eprintln(concat(record::diagnostic_code(diag), concat(String_from(": "), record::diagnostic_message(diag))))
        i = i + 1
    }
}
