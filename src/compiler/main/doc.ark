use std::host::process
use main::args_record
use main::doc_usage
use main::manifest_doc

pub fn cmd_doc(opts: CliOptions) {
    let symbol = args_record::cli_input_file(opts)
    if len(symbol) == 0 {
        doc_usage::print_doc_usage()
        process::exit(2)
        return
    }
    let json_out = args_record::cli_json_output(opts)
    let filter_target = args_record::cli_target(opts)
    manifest_doc::cmd_manifest_doc(clone(symbol), json_out, filter_target)
}
