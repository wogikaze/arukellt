                    }
                } else {
                    let is_catchall = pat.kind == NK_PAT_IDENT() || pat.kind == NK_PAT_WILDCARD()
                    let has_guard = arm_child_count == 3
                    if is_catchall {
                        if pat.kind == NK_PAT_IDENT() {
                            let bind_ca = ctx_alloc_local(ctx, clone(pat.text), VT_I32())
                            let get_ca = MirInst_new(MIR_LOCAL_GET())
                            get_ca.arg0 = scrut_idx
                            ctx_emit(ctx, get_ca)
                            let set_ca = MirInst_new(MIR_LOCAL_SET())
                            set_ca.arg0 = bind_ca
                            ctx_emit(ctx, set_ca)
                        }
                        if has_guard {
                            let guard = get_unchecked(arm_node.children, 1)
                            lower_expr(ctx, guard)
                            ctx_emit(ctx, MirInst_new(MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                        }
                    } else {
                        if pat.kind == NK_PAT_OR() {
                            let alt_count = len(pat.children)
                            let mut or_oi = 0
                            while or_oi < alt_count {
                                let or_alt = get_unchecked(pat.children, or_oi)
                                let get_or = MirInst_new(MIR_LOCAL_GET())
                                get_or.arg0 = compare_idx
                                ctx_emit(ctx, get_or)
                                lower_expr(ctx, or_alt)
                                let or_cmp = ctx_fresh_local(ctx, VT_I32())
                                ctx_emit(ctx, MirInst_binop(MIR_EQ(), or_cmp, compare_idx, or_cmp))
                                if or_oi > 0 {
                                    let or_dummy = ctx_fresh_local(ctx, VT_I32())
                                    ctx_emit(ctx, MirInst_binop(MIR_BIT_OR(), or_dummy, or_cmp, or_cmp))
                                }
                                or_oi = or_oi + 1
                            }
                            ctx_emit(ctx, MirInst_new(MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                        } else {
                            let get_inst = MirInst_new(MIR_LOCAL_GET())
                            get_inst.arg0 = compare_idx
                            ctx_emit(ctx, get_inst)
                            let pat_idx = lower_expr(ctx, pat)
                            let cmp_dest = ctx_fresh_local(ctx, VT_I32())
                            ctx_emit(ctx, MirInst_binop(MIR_EQ(), cmp_dest, compare_idx, pat_idx))
                            ctx_emit(ctx, MirInst_new(MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                            if is_payload_match && pat.kind == NK_PAT_VARIANT() && len(pat.children) > 0 {
                                let variant_name2 = clone(pat.text)
                                let mut bi2 = 0
                                while bi2 < len(pat.children) {
                                    let bind_pat2 = get_unchecked(pat.children, bi2)
                                    let mut field_is_f64_2 = ctx_struct_field_is_f64(ctx, clone(variant_name2), bi2 + 1)
                                    if !field_is_f64_2 && scrut_ok_is_f64 && bi2 == 0 {
                                        if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                            field_is_f64_2 = true
                                        }
                                    }
                                    let mut field_is_i64_2 = false
                                    if !field_is_f64_2 && scrut_ok_is_i64 && bi2 == 0 {
                                        if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                            field_is_i64_2 = true
                                        }
                                    }
                                    let mut bind_vt2 = VT_I32()
                                    if field_is_f64_2 {
                                        bind_vt2 = VT_F64()
                                    } else {
                                        if field_is_i64_2 {
                                            bind_vt2 = VT_I64()
                                        }
                                    }
                                    let bind_local2 = ctx_alloc_local(ctx, clone(bind_pat2.text), bind_vt2)
                                    if bind_vt2 == VT_I32() && scrut_ok_is_i32 && bi2 == 0 {
                                        if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                            ctx_set_local_type(ctx, bind_local2, String_from("i32"))
                                        }
                                    }
                                    let get_s3 = MirInst_new(MIR_LOCAL_GET())
                                    get_s3.arg0 = scrut_idx
                                    ctx_emit(ctx, get_s3)
                                    let sget3 = MirInst_new(MIR_STRUCT_GET())
                                    sget3.int_val = ctx_struct_field_offset(ctx, clone(variant_name2), bi2 + 1)
                                    if field_is_f64_2 {
                                        sget3.val_type = VT_F64()
                                    } else {
                                        if field_is_i64_2 {
                                            sget3.val_type = VT_I64()
                                        }
                                    }
                                    ctx_emit(ctx, sget3)
                                    let set_b2 = MirInst_new(MIR_LOCAL_SET())
                                    set_b2.arg0 = bind_local2
                                    ctx_emit(ctx, set_b2)
                                    bi2 = bi2 + 1
                                }
                            }
                            if has_guard {
                                let guard2 = get_unchecked(arm_node.children, 1)
                                lower_expr(ctx, guard2)
                                ctx_emit(ctx, MirInst_new(MIR_IF()))
                                ctx.nesting_depth = ctx.nesting_depth + 1
                                if_depth = if_depth + 1
                            }
                        }
                    }
                    let arm_result = lower_expr(ctx, body)
                    if arm_result >= 0 {
                        let arm_vt2 = ctx_local_vt(ctx, arm_result)
                        if arm_vt2 == VT_I64() || arm_vt2 == VT_F64() {
                            ctx_set_local_vt(ctx, result, arm_vt2)
                        }
                        let set_inst = MirInst_new(MIR_LOCAL_SET())
                        set_inst.arg0 = result
                        set_inst.arg1 = arm_result
                        ctx_emit(ctx, set_inst)
                    }
                    ctx_emit(ctx, MirInst_new(MIR_ELSE()))
                }
                arm = arm + 1
            }
            while if_depth > 0 {
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                if_depth = if_depth - 1
            }
            let get_result = MirInst_new(MIR_LOCAL_GET())
            get_result.arg0 = result
            ctx_emit(ctx, get_result)
            return result
        }
        return 0 - 1
    }
    if kind == NK_METHOD_CALL() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let receiver = get_unchecked(node.children, 0)
            let receiver_idx = lower_expr(ctx, receiver)
            let mut struct_name = String_from("")
            if receiver_idx >= 0 {
                struct_name = ctx_get_local_type(ctx, receiver_idx)
            }
            let method_name = clone(node.text)
            let callee_name = if len(struct_name) > 0 {
                concat(clone(struct_name), concat(String_from("::"), clone(method_name)))
            } else {
                clone(method_name)
            }
            let mut a = 1
            while a < child_count {
                let arg = get_unchecked(node.children, a)
                lower_expr(ctx, arg)
                a = a + 1
            }
            let call_ret_vt = ctx_fn_return_vt(ctx, clone(callee_name))
            let dest = ctx_fresh_local(ctx, call_ret_vt)
            let mut mcall_inst = MirInst_new(MIR_CALL())
            mcall_inst.str_val = callee_name
            mcall_inst.int_val = child_count
            mcall_inst.dest = dest
            ctx_emit(ctx, mcall_inst)
            let rtn = ctx_fn_return_type_name(ctx, clone(mcall_inst.str_val))
            if len(rtn) > 0 {
                ctx_set_local_type(ctx, dest, rtn)
            }
            if call_ret_vt == VT_VOID() {
                return 0 - 1
            }
            return dest
        }
        return 0 - 1
    }
    if kind == NK_BLOCK() {
        let child_count = len(node.children)
        let mut last_result = 0 - 1
        let mut s = 0
        while s < child_count {
            let stmt = get_unchecked(node.children, s)
            let stmt_result = lower_stmt(ctx, stmt)
            if s < child_count - 1 && stmt_result >= 0 {
                ctx_emit(ctx, MirInst_new(MIR_DROP()))
                last_result = 0 - 1
            } else {
                last_result = stmt_result
            }
            s = s + 1
        }
        return last_result
    }
    if kind == NK_ASSIGN() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let target = get_unchecked(node.children, 0)
            let value = get_unchecked(node.children, 1)
            let val_idx = lower_expr(ctx, value)
            if target.kind == NK_IDENT() {
                let local_idx = ctx_lookup_local(ctx, clone(target.text))
                if local_idx >= 0 && val_idx >= 0 {
                    let set_inst = MirInst_new(MIR_LOCAL_SET())
                    set_inst.arg0 = local_idx
                    set_inst.arg1 = val_idx
                    ctx_emit(ctx, set_inst)
                }
            }
            if target.kind == NK_FIELD_ACCESS() {
                let tc = len(target.children)
                if tc >= 1 {
                    let struct_node = get_unchecked(target.children, 0)
                    let mut struct_idx = 0
                    if struct_node.kind == NK_IDENT() {
                        struct_idx = ctx_lookup_local(ctx, clone(struct_node.text))
                    } else {
                        let raw_idx = lower_expr(ctx, struct_node)
                        let temp = ctx_fresh_local(ctx, VT_REF())
                        let save_inst = MirInst_new(MIR_LOCAL_SET())
                        save_inst.arg0 = temp
                        save_inst.arg1 = raw_idx
                        ctx_emit(ctx, save_inst)
                        struct_idx = temp
                    }
                    let set_inst = MirInst_new(MIR_STRUCT_SET())
                    set_inst.arg0 = struct_idx
                    set_inst.arg1 = val_idx
                    set_inst.str_val = clone(target.text)
                    let base_type = ctx_get_local_type(ctx, struct_idx)
                    let mut fi_assign = 0
                    if len(base_type) > 0 {
                        fi_assign = ctx_field_index(ctx, clone(base_type), clone(target.text))
                        set_inst.int_val = ctx_struct_field_offset(ctx, clone(base_type), fi_assign)
                        if ctx_struct_field_is_f64(ctx, clone(base_type), fi_assign) {
                            set_inst.val_type = VT_F64()
                        }
                    } else {
                        fi_assign = ctx_field_index_any(ctx, clone(target.text))
                        set_inst.int_val = fi_assign * 4
                    }
                    ctx_emit(ctx, set_inst)
                }
            }
        }
        return 0 - 1
    }
    if kind == NK_STRUCT_LIT() {
        let child_count = len(node.children)
        let struct_name = clone(node.text)
        let total_fields = ctx_struct_field_count(ctx, clone(struct_name))
        let dest = ctx_fresh_local(ctx, VT_REF())
        let new_inst = MirInst_new(MIR_STRUCT_NEW())
        new_inst.dest = dest
        new_inst.str_val = clone(struct_name)
        new_inst.int_val = ctx_struct_byte_size(ctx, clone(struct_name))
        ctx_emit(ctx, new_inst)
        ctx_set_local_type(ctx, dest, clone(struct_name))
        let mut base_idx = 0 - 1
        let mut has_base = false
        let mut f = 0
        while f < child_count {
            let field = get_unchecked(node.children, f)
            if field.kind == NK_RANGE() {
                let base_expr = get_unchecked(field.children, 0)
                base_idx = lower_expr(ctx, base_expr)
                let save_base = MirInst_new(MIR_LOCAL_SET())
                save_base.arg0 = base_idx
                ctx_emit(ctx, save_base)
                has_base = true
            }
            f = f + 1
        }
        if has_base {
            let mut fi = 0
            while fi < total_fields {
                let fname = ctx_struct_field_name(ctx, clone(struct_name), fi)
                let is_f64_field = ctx_struct_field_is_f64(ctx, clone(struct_name), fi)
                let mut field_vt = VT_I32()
                if is_f64_field {
                    field_vt = VT_F64()
                }
                let tmp = ctx_fresh_local(ctx, field_vt)
                let get_base = MirInst_new(MIR_LOCAL_GET())
                get_base.arg0 = base_idx
                get_base.dest = base_idx
                ctx_emit(ctx, get_base)
                let g = MirInst_new(MIR_STRUCT_GET())
                g.dest = tmp
                g.arg0 = base_idx
                g.str_val = clone(fname)
                g.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi)
                if is_f64_field {
                    g.val_type = VT_F64()
                }
                ctx_emit(ctx, g)
                let s = MirInst_new(MIR_STRUCT_SET())
                s.arg0 = dest
                s.arg1 = tmp
                s.str_val = clone(fname)
                s.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi)
                if is_f64_field {
                    s.val_type = VT_F64()
                }
                ctx_emit(ctx, s)
                fi = fi + 1
            }
        }
        f = 0
        while f < child_count {
            let field = get_unchecked(node.children, f)
            if field.kind != NK_RANGE() {
                let fc = len(field.children)
                if fc >= 1 {
                    let init = get_unchecked(field.children, 0)
                    let val_idx = lower_expr(ctx, init)
                    let fi_idx = ctx_field_index(ctx, clone(struct_name), clone(field.text))
                    let set_inst = MirInst_new(MIR_STRUCT_SET())
                    set_inst.arg0 = dest
                    set_inst.arg1 = val_idx
                    set_inst.str_val = clone(field.text)
                    set_inst.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi_idx)
                    if ctx_struct_field_is_f64(ctx, clone(struct_name), fi_idx) {
                        set_inst.val_type = VT_F64()
                    }
                    ctx_emit(ctx, set_inst)
                }
            }
            f = f + 1
        }
        let get_inst = MirInst_new(MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)
        return dest
    }
    if kind == NK_FIELD_ACCESS() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let base = get_unchecked(node.children, 0)
            let base_idx = lower_expr(ctx, base)
            let base_type = ctx_get_local_type(ctx, base_idx)
            let mut field_idx = 0
            let mut is_f64_field = false
            if len(base_type) > 0 {
                field_idx = ctx_field_index(ctx, clone(base_type), clone(node.text))
                is_f64_field = ctx_struct_field_is_f64(ctx, clone(base_type), field_idx)
            } else {
                field_idx = ctx_field_index_any(ctx, clone(node.text))
            }
            let mut dest_vt = VT_I32()
            if is_f64_field {
                dest_vt = VT_F64()
            }
            if len(base_type) > 0 {
                let ft_vt = ctx_get_field_type(ctx, clone(base_type), clone(node.text))
                if eq(clone(ft_vt), "i64") {
                    dest_vt = VT_I64()
                }
            }
            let dest = ctx_fresh_local(ctx, dest_vt)
            let get_inst = MirInst_new(MIR_STRUCT_GET())
            get_inst.dest = dest
            get_inst.arg0 = base_idx
            get_inst.str_val = clone(node.text)
            if len(base_type) > 0 {
                get_inst.int_val = ctx_struct_field_offset(ctx, clone(base_type), field_idx)
                if is_f64_field {
                    get_inst.val_type = VT_F64()
                }
                if dest_vt == VT_I64() {
                    get_inst.val_type = VT_I64()
                }
                let ft = ctx_get_field_type(ctx, clone(base_type), clone(node.text))
                if len(ft) > 0 {
                    ctx_set_local_type(ctx, dest, ft)
                }
            } else {
                get_inst.int_val = field_idx * 4
            }
            ctx_emit(ctx, get_inst)
            return dest
        }
        return 0 - 1
    }
    if kind == NK_ARRAY_LIT() {
        let child_count = len(node.children)
        let dest = ctx_fresh_local(ctx, VT_REF())
        let new_inst = MirInst_new(MIR_ARRAY_NEW())
        new_inst.dest = dest
        new_inst.int_val = child_count
        ctx_emit(ctx, new_inst)
        let mut e = 0
        while e < child_count {
            let elem = get_unchecked(node.children, e)
            let val_idx = lower_expr(ctx, elem)
            let set_inst = MirInst_new(MIR_ARRAY_SET())
            set_inst.arg0 = dest
            set_inst.arg1 = val_idx
            set_inst.int_val = e
            ctx_emit(ctx, set_inst)
            e = e + 1
        }
        let get_inst = MirInst_new(MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)
        return dest
    }
    if kind == NK_INDEX() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let base = get_unchecked(node.children, 0)
            let idx_expr = get_unchecked(node.children, 1)
            let base_idx = lower_expr(ctx, base)
            let index_idx = lower_expr(ctx, idx_expr)
            let dest = ctx_fresh_local(ctx, VT_I32())
            ctx_set_local_type(ctx, dest, String_from("i32"))
            let get_inst = MirInst_new(MIR_ARRAY_GET())
            get_inst.dest = dest
            get_inst.arg0 = base_idx
            get_inst.arg1 = index_idx
            ctx_emit(ctx, get_inst)
            return dest
        }
        return 0 - 1
    }
    if kind == NK_TRY() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let inner = get_unchecked(node.children, 0)
            let inner_idx = lower_expr(ctx, inner)
            let res_ptr = ctx_fresh_local(ctx, VT_I32())
            let save_res = MirInst_new(MIR_LOCAL_SET())
            save_res.arg0 = res_ptr
            save_res.arg1 = inner_idx
            ctx_emit(ctx, save_res)
            let tag_local = ctx_fresh_local(ctx, VT_I32())
            let get_ptr = MirInst_new(MIR_LOCAL_GET())
            get_ptr.arg0 = res_ptr
            ctx_emit(ctx, get_ptr)
            let sget_tag = MirInst_new(MIR_STRUCT_GET())
            sget_tag.int_val = 0
            ctx_emit(ctx, sget_tag)
            let set_tag = MirInst_new(MIR_LOCAL_SET())
            set_tag.arg0 = tag_local
            ctx_emit(ctx, set_tag)
            let get_tag = MirInst_new(MIR_LOCAL_GET())
            get_tag.arg0 = tag_local
            ctx_emit(ctx, get_tag)
            ctx_emit(ctx, MirInst_new(MIR_IF()))
            let get_ret = MirInst_new(MIR_LOCAL_GET())
            get_ret.arg0 = res_ptr
            ctx_emit(ctx, get_ret)
            let ret_inst = MirInst_new(MIR_RETURN())
            ctx_emit(ctx, ret_inst)
            ctx_emit(ctx, MirInst_new(MIR_END()))
            let result = ctx_fresh_local(ctx, VT_I32())
            let get_ok = MirInst_new(MIR_LOCAL_GET())
            get_ok.arg0 = res_ptr
            ctx_emit(ctx, get_ok)
            let sget_payload = MirInst_new(MIR_STRUCT_GET())
            sget_payload.int_val = 4
            ctx_emit(ctx, sget_payload)
            let set_result = MirInst_new(MIR_LOCAL_SET())
            set_result.arg0 = result
            ctx_emit(ctx, set_result)
            let get_result = MirInst_new(MIR_LOCAL_GET())
            get_result.arg0 = result
            ctx_emit(ctx, get_result)
            return result
        }
        return 0 - 1
    }
    if kind == NK_LOOP() {
        return lower_stmt(ctx, node)
    }
    if kind == NK_WHILE() {
        return lower_stmt(ctx, node)
    }
    if kind == NK_FOR() {
        return lower_stmt(ctx, node)
    }
    if kind == NK_CLOSURE() {
        let caps = Vec_new_String()
        let cap_child_count = len(node.children)
        if cap_child_count > 0 {
            let cap_body = get_unchecked(node.children, cap_child_count - 1)
            closure_collect_free(ctx, cap_body, node, caps)
        }
        let packed = closure_pack_caps(caps)
        let extra = len(caps)
        let synth = concat(String_from("__closure_"), to_string(ctx.closure_counter))
        ctx.closure_counter = ctx.closure_counter + 1
        let mf = mir_emit_closure_fn(ctx, synth, node, caps)
        push(ctx.module.functions, mf)
        push(ctx.fn_names, clone(mf.name))
        push(ctx.fn_return_vts, mf.return_type)
        push(ctx.fn_return_type_names, String_from(""))
        ctx.closure_last_synth = clone(mf.name)
        ctx.closure_last_caps = packed
        ctx.closure_last_extra = extra
        let dest = ctx_fresh_local(ctx, VT_I32())
        ctx_emit(ctx, MirInst_const_i32(0, dest))
        return dest
    }
    if kind == NK_RETURN() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let val_idx = lower_expr(ctx, expr)
            let ret_inst = MirInst_new(MIR_RETURN())
            ret_inst.arg0 = val_idx
            ctx_emit(ctx, ret_inst)
        } else {
            ctx_emit(ctx, MirInst_new(MIR_RETURN()))
        }
        return 0 - 1
    }
    if kind == NK_BREAK() {
        if ctx.loop_break_depth >= 0 {
            let br_inst = MirInst_new(MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_break_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    if kind == NK_CONTINUE() {
        if ctx.loop_continue_depth >= 0 {
            let br_inst = MirInst_new(MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_continue_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    ctx_emit(ctx, MirInst_new(MIR_NOP()))
    0 - 1
}

// Lower a statement node. Returns local index if it produces a value.
fn lower_stmt(ctx: LowerCtx, node: AstNode) -> i32 {
    let kind = node.kind
    if kind == NK_LET() {
        let mut vt = VT_I32()
        let ta_count = len(node.type_ann)
        if ta_count >= 1 {
            let ta_pre = get_unchecked(node.type_ann, 0)
            if eq(clone(ta_pre.text), "f64") {
                vt = VT_F64()
            } else {
                if eq(clone(ta_pre.text), "i64") || eq(clone(ta_pre.text), "u64") {
                    vt = VT_I64()
                }
            }
        }
        if vt == VT_I32() && ta_count == 0 && len(node.children) >= 1 {
            let init_peek = get_unchecked(node.children, 0)
            if init_peek.kind == NK_FLOAT_LIT() {
                vt = VT_F64()
            }
            if init_peek.kind == NK_BINARY() && len(init_peek.children) >= 2 {
                let lhs_peek = get_unchecked(init_peek.children, 0)
                let rhs_peek = get_unchecked(init_peek.children, 1)
                if lhs_peek.kind == NK_FLOAT_LIT() || rhs_peek.kind == NK_FLOAT_LIT() {
                    vt = VT_F64()
                }
            }
        }
        let child_count = len(node.children)
        let mut pre_val_idx = 0 - 1
        let mut pre_init_kind = 0 - 1
        if child_count >= 1 {
            let pre_init = get_unchecked(node.children, 0)
            pre_init_kind = pre_init.kind
            pre_val_idx = lower_expr(ctx, pre_init)
            if vt == VT_I32() && ta_count == 0 && pre_val_idx >= 0 {
                let inferred_vt = ctx_local_vt(ctx, pre_val_idx)
                if inferred_vt == VT_F64() || inferred_vt == VT_I64() {
                    vt = inferred_vt
                }
            }
        }
        let local_idx = ctx_alloc_local(ctx, clone(node.text), vt)
        if ta_count >= 1 {
            let ta = get_unchecked(node.type_ann, 0)
            let ta_name = clone(ta.text)
            if eq(clone(ta_name), "char") || eq(clone(ta_name), "u8") || eq(clone(ta_name), "u16") || eq(clone(ta_name), "u32") || eq(clone(ta_name), "u64") || eq(clone(ta_name), "i16") || eq(clone(ta_name), "i32") || eq(clone(ta_name), "i64") || eq(clone(ta_name), "bool") || eq(clone(ta_name), "f64") {
                ctx_set_local_type(ctx, local_idx, ta_name)
            } else {
                if ctx_struct_field_count(ctx, clone(ta_name)) > 0 {
                    ctx_set_local_type(ctx, local_idx, ta_name)
                }
            }
            if ta.kind == 91 {
                if eq(clone(ta_name), "Vec") {
                    if len(ta.children) >= 2 {
                        let elem_ty = get_unchecked(ta.children, 1)
                        ctx_set_local_type(ctx, local_idx, concat(String_from("vec:"), clone(elem_ty.text)))
                    } else {
                        ctx_set_local_type(ctx, local_idx, String_from("vec"))
                    }
                } else {
                    if eq(clone(ta_name), "Result") {
                        if len(ta.children) >= 2 {
                            let ok_ty = get_unchecked(ta.children, 1)
                            if eq(clone(ok_ty.text), "f64") {
                                ctx_set_local_type(ctx, local_idx, String_from("Result_f64"))
                            } else {
                                if eq(clone(ok_ty.text), "i64") {
                                    ctx_set_local_type(ctx, local_idx, String_from("Result_i64"))
                                }
                            }
                        }
                    } else {
                        if eq(clone(ta_name), "Option") {
                            if len(ta.children) >= 2 {
                                let some_ty = get_unchecked(ta.children, 1)
                                if eq(clone(some_ty.text), "f64") {
                                    ctx_set_local_type(ctx, local_idx, String_from("Option_f64"))
                                } else {
                                    if eq(clone(some_ty.text), "i64") {
                                        ctx_set_local_type(ctx, local_idx, String_from("Option_i64"))
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                if eq(clone(ta_name), "Vec") {
                    ctx_set_local_type(ctx, local_idx, String_from("vec"))
                }
            }
        }
        if child_count >= 1 {
            let init = get_unchecked(node.children, 0)
            let val_idx = pre_val_idx
            if val_idx >= 0 {
                if ctx_local_vt(ctx, val_idx) == VT_F64() && ctx_local_vt(ctx, local_idx) == VT_I32() {
                    ctx_set_local_vt(ctx, local_idx, VT_F64())
                }
                let mut actual_val_idx = val_idx
                if vt == VT_I64() && ctx_local_vt(ctx, val_idx) == VT_I32() {
                    let ext_dest = ctx_fresh_local(ctx, VT_I64())
                    let ext_inst = MirInst_new(MIR_EXTEND_I32_TO_I64())
                    ext_inst.dest = ext_dest
                    ext_inst.arg0 = val_idx
                    ctx_emit(ctx, ext_inst)
                    actual_val_idx = ext_dest
                }
                let set_inst = MirInst_new(MIR_LOCAL_SET())
                set_inst.arg0 = local_idx
                set_inst.arg1 = actual_val_idx
                ctx_emit(ctx, set_inst)
                let init_type = ctx_get_local_type(ctx, val_idx)
                if len(init_type) > 1 {
                    ctx_set_local_type(ctx, local_idx, init_type)
                }
                if ta_count == 0 && len(ctx_get_local_type(ctx, local_idx)) == 0 {
                    if pre_init_kind == NK_INT_LIT() {
                        ctx_set_local_type(ctx, local_idx, String_from("i32"))
                    } else {
                        if pre_init_kind == NK_FLOAT_LIT() {
                            ctx_set_local_type(ctx, local_idx, String_from("f64"))
                        } else {
                            if pre_init_kind == NK_BOOL_LIT() {
                                ctx_set_local_type(ctx, local_idx, String_from("bool"))
                            } else {
                                if pre_init_kind == NK_CHAR_LIT() {
                                    ctx_set_local_type(ctx, local_idx, String_from("char"))
                                }
                            }
                        }
                    }
                }
            }
            if pre_init_kind == NK_CLOSURE() {
                if !eq(clone(node.text), String_from("_")) {
                    closure_flush_pending_bind(ctx, clone(node.text))
                } else {
                    ctx.closure_last_synth = String_new()
                    ctx.closure_last_caps = String_new()
                    ctx.closure_last_extra = 0
                }
            }
        }
        return 0 - 1
    }
    if kind == NK_RETURN() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let val_idx = lower_expr(ctx, expr)
            let ret_inst = MirInst_new(MIR_RETURN())
            ret_inst.arg0 = val_idx
            ctx_emit(ctx, ret_inst)
        } else {
            ctx_emit(ctx, MirInst_new(MIR_RETURN()))
        }
        return 0 - 1
    }
    if kind == NK_WHILE() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let prev_break = ctx.loop_break_depth
            let prev_continue = ctx.loop_continue_depth
            ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth
            ctx_emit(ctx, MirInst_new(MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_continue_depth = ctx.nesting_depth
            let cond = get_unchecked(node.children, 0)
            let cond_idx = lower_expr(ctx, cond)
            let eqz_dest = ctx_fresh_local(ctx, VT_I32())
            let eqz_inst = MirInst_new(MIR_EQZ())
            eqz_inst.dest = eqz_dest
            eqz_inst.arg0 = cond_idx
            ctx_emit(ctx, eqz_inst)
            let br_break = MirInst_new(MIR_BR_IF())
            br_break.int_val = 1
            ctx_emit(ctx, br_break)
            let body = get_unchecked(node.children, 1)
            let _body_result = lower_expr(ctx, body)
            let br_loop = MirInst_new(MIR_BR())
            br_loop.int_val = 0
            ctx_emit(ctx, br_loop)
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx.loop_break_depth = prev_break
            ctx.loop_continue_depth = prev_continue
        }
        return 0 - 1
    }
    if kind == NK_LOOP() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let prev_break = ctx.loop_break_depth
            let prev_continue = ctx.loop_continue_depth
            let prev_break_local = ctx.loop_break_local
            let break_result = ctx_fresh_local(ctx, VT_I32())
            ctx.loop_break_local = break_result
            ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth
            ctx_emit(ctx, MirInst_new(MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_continue_depth = ctx.nesting_depth
            let body = get_unchecked(node.children, 0)
            let _body_result = lower_expr(ctx, body)
            let br_back = MirInst_new(MIR_BR())
            br_back.int_val = 0
            ctx_emit(ctx, br_back)
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx.loop_break_depth = prev_break
            ctx.loop_continue_depth = prev_continue
            ctx.loop_break_local = prev_break_local
            let get_result = MirInst_new(MIR_LOCAL_GET())
            get_result.arg0 = break_result
            ctx_emit(ctx, get_result)
            return break_result
        }
        return 0 - 1
    }
    if kind == NK_BREAK() {
        if ctx.loop_break_depth >= 0 {
            let break_children = len(node.children)
            if break_children > 0 && ctx.loop_break_local >= 0 {
                let break_val = get_unchecked(node.children, 0)
                let bv_idx = lower_expr(ctx, break_val)
                let set_inst = MirInst_new(MIR_LOCAL_SET())
                set_inst.arg0 = ctx.loop_break_local
                set_inst.arg1 = bv_idx
                ctx_emit(ctx, set_inst)
            }
            let br_inst = MirInst_new(MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_break_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    if kind == NK_CONTINUE() {
        if ctx.loop_continue_depth >= 0 {
            let br_inst = MirInst_new(MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_continue_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    if kind == NK_FOR() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let range = get_unchecked(node.children, 0)
            let body = get_unchecked(node.children, 1)
            let range_child_count = len(range.children)
            let mut is_values_call = range.kind == NK_CALL() && range_child_count >= 2
            let mut values_callee_match = false
            if is_values_call {
                let range_callee = get_unchecked(range.children, 0)
                values_callee_match = eq(clone(range_callee.text), "values")
            }
            if values_callee_match {
                let vec_arg = get_unchecked(range.children, 1)
                let vec_idx = lower_expr(ctx, vec_arg)
                let vec_local = ctx_fresh_local(ctx, VT_I32())
                let set_vec = MirInst_new(MIR_LOCAL_SET())
                set_vec.arg0 = vec_local
                set_vec.arg1 = vec_idx
                ctx_emit(ctx, set_vec)
                let get_vec_len = MirInst_new(MIR_LOCAL_GET())
                get_vec_len.arg0 = vec_local
                ctx_emit(ctx, get_vec_len)
                let len_call = MirInst_new(MIR_CALL())
                len_call.str_val = String_from("vec_len")
                len_call.int_val = 1
                let end_local = ctx_fresh_local(ctx, VT_I32())
                len_call.dest = end_local
                ctx_emit(ctx, len_call)
                let set_end = MirInst_new(MIR_LOCAL_SET())
                set_end.arg0 = end_local
                ctx_emit(ctx, set_end)
                let idx_var = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(0, idx_var))
                let set_idx_init = MirInst_new(MIR_LOCAL_SET())
                set_idx_init.arg0 = idx_var
                ctx_emit(ctx, set_idx_init)
                let iter_var = ctx_alloc_local(ctx, clone(node.text), VT_I32())
                let prev_break = ctx.loop_break_depth
                let prev_continue = ctx.loop_continue_depth
                ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_break_depth = ctx.nesting_depth
                ctx_emit(ctx, MirInst_new(MIR_LOOP()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_continue_depth = ctx.nesting_depth
                let get_idx_cmp = MirInst_new(MIR_LOCAL_GET())
                get_idx_cmp.arg0 = idx_var
                ctx_emit(ctx, get_idx_cmp)
                let get_end_cmp = MirInst_new(MIR_LOCAL_GET())
                get_end_cmp.arg0 = end_local
                ctx_emit(ctx, get_end_cmp)
                let cmp_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_binop(MIR_GTEQ(), cmp_dest, idx_var, end_local))
                let br_break = MirInst_new(MIR_BR_IF())
                br_break.int_val = 1
                ctx_emit(ctx, br_break)
                let get_vec_gu = MirInst_new(MIR_LOCAL_GET())
                get_vec_gu.arg0 = vec_local
                ctx_emit(ctx, get_vec_gu)
                let get_idx_gu = MirInst_new(MIR_LOCAL_GET())
                get_idx_gu.arg0 = idx_var
                ctx_emit(ctx, get_idx_gu)
                let gu_call = MirInst_new(MIR_CALL())
                gu_call.str_val = String_from("vec_get_unchecked")
                gu_call.int_val = 2
                gu_call.dest = iter_var
                ctx_emit(ctx, gu_call)
                let set_elem = MirInst_new(MIR_LOCAL_SET())
                set_elem.arg0 = iter_var
                ctx_emit(ctx, set_elem)
                let _body_result = lower_expr(ctx, body)
                let get_idx_inc = MirInst_new(MIR_LOCAL_GET())
                get_idx_inc.arg0 = idx_var
                ctx_emit(ctx, get_idx_inc)
                let one_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(1, one_dest))
                let add_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_binop(MIR_ADD(), add_dest, idx_var, one_dest))
                let set_idx = MirInst_new(MIR_LOCAL_SET())
                set_idx.arg0 = idx_var
                ctx_emit(ctx, set_idx)
                let br_loop = MirInst_new(MIR_BR())
                br_loop.int_val = 0
                ctx_emit(ctx, br_loop)
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                ctx.loop_break_depth = prev_break
                ctx.loop_continue_depth = prev_continue
            } else {
                if range_child_count >= 2 {
                    let start_node = get_unchecked(range.children, 0)
                    let end_node = get_unchecked(range.children, 1)
                    let start_idx = lower_expr(ctx, start_node)
                    let iter_var = ctx_alloc_local(ctx, clone(node.text), VT_I32())
                    let set_init = MirInst_new(MIR_LOCAL_SET())
                    set_init.arg0 = iter_var
                    set_init.arg1 = start_idx
                    ctx_emit(ctx, set_init)
                    let end_idx = lower_expr(ctx, end_node)
                    let end_local = ctx_fresh_local(ctx, VT_I32())
                    let set_end = MirInst_new(MIR_LOCAL_SET())
                    set_end.arg0 = end_local
                    set_end.arg1 = end_idx
                    ctx_emit(ctx, set_end)
                    let prev_break = ctx.loop_break_depth
                    let prev_continue = ctx.loop_continue_depth
                    ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
                    ctx.nesting_depth = ctx.nesting_depth + 1
                    ctx.loop_break_depth = ctx.nesting_depth
                    ctx_emit(ctx, MirInst_new(MIR_LOOP()))
                    ctx.nesting_depth = ctx.nesting_depth + 1
                    ctx.loop_continue_depth = ctx.nesting_depth
                    let get_iter = MirInst_new(MIR_LOCAL_GET())
                    get_iter.arg0 = iter_var
                    ctx_emit(ctx, get_iter)
                    let get_end = MirInst_new(MIR_LOCAL_GET())
                    get_end.arg0 = end_local
                    ctx_emit(ctx, get_end)
                    let cmp_dest = ctx_fresh_local(ctx, VT_I32())
                    ctx_emit(ctx, MirInst_binop(MIR_GTEQ(), cmp_dest, iter_var, end_local))
                    let br_break = MirInst_new(MIR_BR_IF())
                    br_break.int_val = 1
                    ctx_emit(ctx, br_break)
                    let _body_result = lower_expr(ctx, body)
                    let get_iter2 = MirInst_new(MIR_LOCAL_GET())
                    get_iter2.arg0 = iter_var
                    ctx_emit(ctx, get_iter2)
                    let one_dest = ctx_fresh_local(ctx, VT_I32())
                    ctx_emit(ctx, MirInst_const_i32(1, one_dest))
                    let add_dest = ctx_fresh_local(ctx, VT_I32())
                    ctx_emit(ctx, MirInst_binop(MIR_ADD(), add_dest, iter_var, one_dest))
                    let set_iter = MirInst_new(MIR_LOCAL_SET())
                    set_iter.arg0 = iter_var
                    ctx_emit(ctx, set_iter)
                    let br_loop = MirInst_new(MIR_BR())
                    br_loop.int_val = 0
                    ctx_emit(ctx, br_loop)
                    ctx_emit(ctx, MirInst_new(MIR_END()))
                    ctx.nesting_depth = ctx.nesting_depth - 1
                    ctx_emit(ctx, MirInst_new(MIR_END()))
                    ctx.nesting_depth = ctx.nesting_depth - 1
                    ctx.loop_break_depth = prev_break
                    ctx.loop_continue_depth = prev_continue
                } else {
                    if range.kind == NK_IDENT() {
                        let range_local_si = ctx_lookup_local(ctx, clone(range.text))
                        if range_local_si >= 0 {
                            let si_struct_type = ctx_get_local_type(ctx, range_local_si)
                            let si_next_callee = concat(clone(si_struct_type), String_from("::next"))
                            let si_next_vt = ctx_fn_return_vt(ctx, clone(si_next_callee))
                            if si_next_vt != 0 {
                                let si_iter_idx = lower_expr(ctx, range)
                                let si_iter_ptr = ctx_fresh_local(ctx, VT_I32())
                                let si_save_iter = MirInst_new(MIR_LOCAL_SET())
                                si_save_iter.arg0 = si_iter_ptr
                                ctx_emit(ctx, si_save_iter)
                                ctx_set_local_type(ctx, si_iter_ptr, clone(si_struct_type))
                                let si_iter_var = ctx_alloc_local(ctx, clone(node.text), VT_I32())
                                let si_ret_tn = ctx_fn_return_type_name(ctx, clone(si_next_callee))
                                let mut si_payload_type = String_from("")
                                if starts_with(clone(si_ret_tn), "option:") {
                                    si_payload_type = substring(si_ret_tn, 7, len(si_ret_tn))
                                }
                                if len(si_payload_type) > 0 {
                                    ctx_set_local_type(ctx, si_iter_var, clone(si_payload_type))
                                }
                                let si_opt_local = ctx_fresh_local(ctx, VT_I32())
                                let si_tag_local = ctx_fresh_local(ctx, VT_I32())
                                let si_none_tag = ctx_fresh_local(ctx, VT_I32())
                                let si_cmp_dest = ctx_fresh_local(ctx, VT_I32())
                                let si_prev_break = ctx.loop_break_depth
                                let si_prev_continue = ctx.loop_continue_depth
                                ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
                                ctx.nesting_depth = ctx.nesting_depth + 1
                                ctx.loop_break_depth = ctx.nesting_depth
                                ctx_emit(ctx, MirInst_new(MIR_LOOP()))
                                ctx.nesting_depth = ctx.nesting_depth + 1
                                ctx.loop_continue_depth = ctx.nesting_depth
                                let si_get_iter = MirInst_new(MIR_LOCAL_GET())
                                si_get_iter.arg0 = si_iter_ptr
                                ctx_emit(ctx, si_get_iter)
                                let si_next_call = MirInst_new(MIR_CALL())
                                si_next_call.str_val = clone(si_next_callee)
                                si_next_call.int_val = 1
                                si_next_call.dest = si_opt_local
                                ctx_emit(ctx, si_next_call)
                                let si_save_opt = MirInst_new(MIR_LOCAL_SET())
                                si_save_opt.arg0 = si_opt_local
                                ctx_emit(ctx, si_save_opt)
                                let si_get_opt_tag = MirInst_new(MIR_LOCAL_GET())
                                si_get_opt_tag.arg0 = si_opt_local
                                ctx_emit(ctx, si_get_opt_tag)
                                let si_sg_tag = MirInst_new(MIR_STRUCT_GET())
                                si_sg_tag.int_val = 0
                                si_sg_tag.val_type = VT_I32()
                                si_sg_tag.dest = si_tag_local
                                ctx_emit(ctx, si_sg_tag)
                                let si_save_tag = MirInst_new(MIR_LOCAL_SET())
                                si_save_tag.arg0 = si_tag_local
                                ctx_emit(ctx, si_save_tag)
                                let si_get_tag = MirInst_new(MIR_LOCAL_GET())
                                si_get_tag.arg0 = si_tag_local
                                ctx_emit(ctx, si_get_tag)
                                ctx_emit(ctx, MirInst_const_i32(1, si_none_tag))
                                ctx_emit(ctx, MirInst_binop(MIR_EQ(), si_cmp_dest, si_tag_local, si_none_tag))
                                let si_br_none = MirInst_new(MIR_BR_IF())
                                si_br_none.int_val = 1
                                ctx_emit(ctx, si_br_none)
                                let si_get_opt_val = MirInst_new(MIR_LOCAL_GET())
                                si_get_opt_val.arg0 = si_opt_local
                                ctx_emit(ctx, si_get_opt_val)
                                let si_sg_payload = MirInst_new(MIR_STRUCT_GET())
                                si_sg_payload.int_val = 4
                                si_sg_payload.val_type = VT_I32()
                                si_sg_payload.dest = si_iter_var
                                ctx_emit(ctx, si_sg_payload)
                                let si_save_payload = MirInst_new(MIR_LOCAL_SET())
                                si_save_payload.arg0 = si_iter_var
                                ctx_emit(ctx, si_save_payload)
                                let _si_body = lower_expr(ctx, body)
                                let si_br_loop = MirInst_new(MIR_BR())
                                si_br_loop.int_val = 0
                                ctx_emit(ctx, si_br_loop)
                                ctx_emit(ctx, MirInst_new(MIR_END()))
                                ctx.nesting_depth = ctx.nesting_depth - 1
                                ctx_emit(ctx, MirInst_new(MIR_END()))
                                ctx.nesting_depth = ctx.nesting_depth - 1
                                ctx.loop_break_depth = si_prev_break
                                ctx.loop_continue_depth = si_prev_continue
                            }
                        }
                    }
                }
            }
        }
        return 0 - 1
    }
    if kind == NK_EXPR_STMT() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let result = lower_expr(ctx, expr)
            return result
        }
        return 0 - 1
    }
    lower_expr(ctx, node)
}

pub fn lower_to_mir(decls: Vec<AstNode>, check_result: TypeCheckResult) -> MirModule {
    let m = MirModule_new()
    let decl_count = len(decls)
    let mut fn_names = Vec_new_String()
    let mut fn_return_vts = Vec_new_i32()
    let mut fn_return_type_names = Vec_new_String()
    let mut fn_index = 0
    let typed_fn_count = len(check_result.typed_fns)
    let mut mir_tr = MIR_LOWER_TRACE_FORCE()
    if mir_tr == 0 {
        mir_tr = MIR_LOWER_TRACE()
    }
    mir_lower_trace_line(mir_tr, -1, decl_count, typed_fn_count, 0, 0)
    let mut d = 0
    while d < decl_count {
        let decl = get_unchecked(decls, d)
        if decl.kind == NK_FN_DECL() {
            push(fn_names, clone(decl.text))
            let mut rvt = VT_I32()
            let mut rtn = String_from("")
            if fn_index < typed_fn_count {
                let tf = get_unchecked(check_result.typed_fns, fn_index)
                let rt_tag = tf.return_type.tag
                if rt_tag == 3 {
                    rvt = VT_F64()
                } else {
                    if rt_tag == 2 {
                        rvt = VT_I64()
                    } else {
                        if rt_tag == 7 || rt_tag == 8 || rt_tag == 0 {
                            rvt = VT_VOID()
                        } else {
                            if rt_tag == 10 {
                                let vec_type_args = tf.return_type.type_args
                                if len(vec_type_args) > 0 {
                                    let vec_elem = get_unchecked(vec_type_args, 0)
                                    let elem_tag = vec_elem.tag
                                    if elem_tag == 5 {
                                        rtn = String_from("vec:String")
                                    } else {
                                        if elem_tag == 1 {
                                            rtn = String_from("vec:i32")
                                        } else {
                                            if elem_tag == 2 {
                                                rtn = String_from("vec:i64")
                                            } else {
                                                if elem_tag == 3 {
                                                    rtn = String_from("vec:f64")
                                                } else {
                                                    rtn = String_from("vec:i32")
                                                }
                                            }
                                        }
                                    }
                                }
                            } else {
                                if rt_tag == 21 || rt_tag == 22 {
                                    rtn = clone(tf.return_type.name)
                                }
                            }
                        }
                    }
                }
            }
            push(fn_return_vts, rvt)
            push(fn_return_type_names, rtn)
            fn_index = fn_index + 1
        }
        if decl.kind == NK_IMPL_DECL() {
            let struct_name = clone(decl.text)
            let method_count = len(decl.children)
            let mut mi = 0
            while mi < method_count {
                let method = get_unchecked(decl.children, mi)
                let mangled = concat(clone(struct_name), concat(String_from("::"), clone(method.text)))
                push(fn_names, mangled)
                let mut mrvt = VT_VOID()
                let mut mrtn = String_from("")
                let ta_count = len(method.type_ann)
                let mut tai = 0
                while tai < ta_count {
                    let ta_node = get_unchecked(method.type_ann, tai)
                    if eq(clone(ta_node.text), "__return") {
                        if len(ta_node.children) > 0 {
                            let ret_node = get_unchecked(ta_node.children, 0)
                            let ret_text = clone(ret_node.text)
                            if eq(clone(ret_text), "f64") {
                                mrvt = VT_F64()
                                mrtn = String_from("f64")
                            } else {
                                if eq(clone(ret_text), "i64") {
                                    mrvt = VT_I64()
                                    mrtn = String_from("i64")
                                } else {
                                    if eq(clone(ret_text), "void") || eq(clone(ret_text), "()") {
                                        mrvt = VT_VOID()
                                    } else {
                                        if eq(clone(ret_text), "i32") || eq(clone(ret_text), "u32") || eq(clone(ret_text), "u8") || eq(clone(ret_text), "u16") || eq(clone(ret_text), "i16") || eq(clone(ret_text), "i8") {
                                            mrvt = VT_I32()
                                            mrtn = String_from("i32")
                                        } else {
                                            if eq(clone(ret_text), "bool") {
                                                mrvt = VT_I32()
                                                mrtn = String_from("bool")
                                            } else {
                                                if eq(clone(ret_text), "String") || eq(clone(ret_text), "str") {
                                                    mrvt = VT_I32()
                                                    mrtn = String_from("String")
                                                } else {
                                                    if ret_node.kind == 91 {
                                                        mrvt = VT_I32()
                                                        if eq(clone(ret_text), "Vec") && len(ret_node.children) >= 2 {
                                                            let elem_n = get_unchecked(ret_node.children, 1)
                                                            mrtn = concat(String_from("vec:"), clone(elem_n.text))
                                                        } else {
                                                            if eq(clone(ret_text), "Option") && len(ret_node.children) >= 2 {
                                                                let elem_n_opt = get_unchecked(ret_node.children, 1)
                                                                mrtn = concat(String_from("option:"), clone(elem_n_opt.text))
                                                            } else {
                                                                mrtn = clone(ret_text)
                                                            }
                                                        }
                                                    } else {
                                                        mrvt = VT_I32()
                                                        if len(ret_text) > 1 {
                                                            mrtn = ret_text
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        } else {
                            mrvt = VT_VOID()
                        }
                    }
                    tai = tai + 1
                }
                push(fn_return_vts, mrvt)
                push(fn_return_type_names, mrtn)
                fn_index = fn_index + 1
                mi = mi + 1
            }
        }
        d = d + 1
    }
    let mut ctx = LowerCtx_new(m)
    ctx.fn_names = fn_names
    ctx.fn_return_vts = fn_return_vts
    ctx.fn_return_type_names = fn_return_type_names
    ctx_register_builtin_variants(ctx)
    let mut sd = 0
    while sd < decl_count {
        let decl = get_unchecked(decls, sd)
        if decl.kind == 51 {
            push(ctx.struct_names, clone(decl.text))
            let fc = len(decl.children)
            push(ctx.struct_field_counts, fc)
            let mut fi = 0
            while fi < fc {
                let field = get_unchecked(decl.children, fi)
                push(ctx.struct_all_fields, clone(field.text))
                let mut field_type_str = String_from("")
                if len(field.type_ann) > 0 {
                    let fty = get_unchecked(field.type_ann, 0)
                    if fty.kind == 91 {
                        if eq(clone(fty.text), "Vec") {
                            if len(fty.children) >= 2 {
                                let elem_ty = get_unchecked(fty.children, 1)
                                field_type_str = concat(String_from("vec:"), clone(elem_ty.text))
                            }
                        }
                    } else {
                        if fty.kind == 90 {
                            let ty_text = clone(fty.text)
                            if eq(clone(ty_text), "u8") {
                                field_type_str = String_from("i32")
                            } else {
                                field_type_str = ty_text
                            }
                        }
                    }
                }
                push(ctx.struct_field_types, field_type_str)
                fi = fi + 1
            }
        }
        if decl.kind == 52 {
            let vc = len(decl.children)
            let mut has_payload = false
            let mut vcheck = 0
            while vcheck < vc {
                let vc_node = get_unchecked(decl.children, vcheck)
                if len(vc_node.type_ann) > 0 {
                    has_payload = true
                }
                vcheck = vcheck + 1
            }
            let mut vi = 0
            while vi < vc {
                let variant = get_unchecked(decl.children, vi)
                let full_name = concat(clone(decl.text), concat(String_from("::"), clone(variant.text)))
                push(ctx.variant_names, full_name)
                push(ctx.variant_tags, vi)
                if has_payload {
                    push(ctx.payload_variants, clone(full_name))
                    let payload_count = len(variant.type_ann)
                    push(ctx.struct_names, clone(full_name))
                    push(ctx.struct_field_counts, payload_count + 1)
                    push(ctx.struct_all_fields, String_from("_tag"))
                    push(ctx.struct_field_types, String_from(""))
                    let mut pfi = 0
                    while pfi < payload_count {
                        let pfield = get_unchecked(variant.type_ann, pfi)
                        push(ctx.struct_all_fields, concat(String_from("_"), to_string(pfi)))
                        if eq(clone(pfield.text), "f64") {
                            push(ctx.struct_field_types, String_from("f64"))
                        } else {
                            push(ctx.struct_field_types, String_from(""))
                        }
                        pfi = pfi + 1
                    }
                }
                vi = vi + 1
            }
        }
        sd = sd + 1
    }
    let mut i = 0
    let mut fn_idx = 0
    while i < decl_count {
        let decl = get_unchecked(decls, i)
        if decl.kind == NK_FN_DECL() {
            let tf = get_unchecked(check_result.typed_fns, fn_idx)
            let mf = MirFunction_new(clone(decl.text))
            ctx.func = mf
            ctx.local_names = Vec_new_String()
            ctx.local_indices = Vec_new_i32()
            ctx.local_types = Vec_new_String()
            ctx.local_type_indices = Vec_new_i32()
            ctx.local_type_start = len(ctx.local_types)
            mir_lower_trace_line(mir_tr, -2, fn_idx, 0, 0, 0)
            let child_count = len(decl.children)
            let body_idx = child_count - 1
            let mut p = 0
            while p < body_idx {
                let param = get_unchecked(decl.children, p)
                if param.kind == NK_IDENT() {
                    let mut pvt = VT_I32()
                    if len(param.type_ann) >= 1 {
                        let pta = get_unchecked(param.type_ann, 0)
                        if eq(clone(pta.text), "f64") {
                            pvt = VT_F64()
                        } else {
                            if eq(clone(pta.text), "i64") {
                                pvt = VT_I64()
                            }
                        }
                    }
                    let param_local = ctx_alloc_local(ctx, clone(param.text), pvt)
                    ctx_push_func_param(ctx, MirLocal { name: clone(param.text), val_type: pvt, ssa_name: clone(param.text), ssa_version: 0 - 1 })
                    if len(param.type_ann) >= 1 {
                        let p_ty = get_unchecked(param.type_ann, 0)
                        if p_ty.kind == 91 {
                            if eq(clone(p_ty.text), "Vec") && len(p_ty.children) >= 2 {
                                let p_elem = get_unchecked(p_ty.children, 1)
                                ctx_set_local_type(ctx, param_local, concat(String_from("vec:"), clone(p_elem.text)))
                            }
                        } else {
                            if p_ty.kind == 90 {
                                let p_ty_name = clone(p_ty.text)
                                if !eq(clone(p_ty_name), "i32") && !eq(clone(p_ty_name), "f64") && !eq(clone(p_ty_name), "i64") && !eq(clone(p_ty_name), "bool") && !eq(clone(p_ty_name), "String") && !eq(clone(p_ty_name), "u8") && !eq(clone(p_ty_name), "char") && len(p_ty_name) > 1 {
                                    ctx_set_local_type(ctx, param_local, p_ty_name)
                                }
                            }
                        }
                    }
                }
                p = p + 1
            }
            mir_lower_trace_ctx(mir_tr, ctx, 1)
            let rt_tag = tf.return_type.tag
            ctx_apply_fn_return_type_for_rt_tag(ctx, rt_tag)
            mir_lower_trace_ctx(mir_tr, ctx, 2)
            let entry = ctx_alloc_block(ctx)
            ctx.cur_block = entry
            mir_lower_trace_ctx(mir_tr, ctx, 3)
            if body_idx >= 0 {
                let body = get_unchecked(decl.children, body_idx)
                let result = lower_expr(ctx, body)
                if result >= 0 && ctx.func.return_type == VT_VOID() {
                    ctx_emit(ctx, MirInst_new(MIR_DROP()))
                }
                ctx_emit(ctx, MirInst_new(MIR_RETURN()))
            }
            mir_lower_trace_ctx(mir_tr, ctx, 4)
            push(ctx.module.functions, ctx.func)
            fn_idx = fn_idx + 1
        }
        if decl.kind == NK_IMPL_DECL() {
            let struct_name = clone(decl.text)
            let method_count = len(decl.children)
            let mut mi = 0
            while mi < method_count {
                let method = get_unchecked(decl.children, mi)
                let mangled = concat(clone(struct_name), concat(String_from("::"), clone(method.text)))
                let mf = MirFunction_new(clone(mangled))
                ctx.func = mf
                ctx.local_names = Vec_new_String()
                ctx.local_indices = Vec_new_i32()
                ctx.local_types = Vec_new_String()
                ctx.local_type_indices = Vec_new_i32()
                ctx.local_type_start = len(ctx.local_types)
                let m_child_count = len(method.children)
                let m_body_idx = m_child_count - 1
                let mut mp = 0
                while mp < m_body_idx {
                    let param = get_unchecked(method.children, mp)
                    if param.kind == NK_IDENT() {
                        let p_name = clone(param.text)
                        if eq(clone(p_name), "self") || eq(clone(p_name), "&self") || eq(clone(p_name), "&mut self") {
                            let self_local = ctx_alloc_local(ctx, String_from("self"), VT_I32())
                            ctx_push_func_param(ctx, MirLocal { name: String_from("self"), val_type: VT_I32(), ssa_name: String_from("self"), ssa_version: 0 - 1 })
                            ctx_set_local_type(ctx, self_local, clone(struct_name))
                        } else {
                            let mut pvt = VT_I32()
                            if len(param.type_ann) >= 1 {
                                let pta = get_unchecked(param.type_ann, 0)
                                if eq(clone(pta.text), "f64") {
                                    pvt = VT_F64()
                                } else {
                                    if eq(clone(pta.text), "i64") {
                                        pvt = VT_I64()
                                    }
                                }
                            }
                            let param_local = ctx_alloc_local(ctx, clone(p_name), pvt)
                            ctx_push_func_param(ctx, MirLocal { name: clone(p_name), val_type: pvt, ssa_name: clone(p_name), ssa_version: 0 - 1 })
                            if len(param.type_ann) >= 1 {
                                let p_ty = get_unchecked(param.type_ann, 0)
                                if p_ty.kind == 91 {
                                    if eq(clone(p_ty.text), "Vec") && len(p_ty.children) >= 2 {
                                        let p_elem = get_unchecked(p_ty.children, 1)
                                        ctx_set_local_type(ctx, param_local, concat(String_from("vec:"), clone(p_elem.text)))
                                    }
                                } else {
                                    if p_ty.kind == 90 {
                                        let p_ty_name = clone(p_ty.text)
                                        if !eq(clone(p_ty_name), "i32") && !eq(clone(p_ty_name), "f64") && !eq(clone(p_ty_name), "i64") && !eq(clone(p_ty_name), "bool") && !eq(clone(p_ty_name), "String") && !eq(clone(p_ty_name), "u8") && !eq(clone(p_ty_name), "char") && len(p_ty_name) > 1 {
                                            ctx_set_local_type(ctx, param_local, p_ty_name)
                                        }
                                    }
                                }
                            }
                        }
                    }
                    mp = mp + 1
                }
                let mrvt = ctx_fn_return_vt(ctx, clone(mangled))
                let mut mfunc = ctx.func
                mfunc.return_type = mrvt
                ctx.func = mfunc
                let entry = ctx_alloc_block(ctx)
                ctx.cur_block = entry
                if m_body_idx >= 0 {
                    let body = get_unchecked(method.children, m_body_idx)
                    let result = lower_expr(ctx, body)
                    if result >= 0 && ctx.func.return_type == VT_VOID() {
                        ctx_emit(ctx, MirInst_new(MIR_DROP()))
                    }
                    ctx_emit(ctx, MirInst_new(MIR_RETURN()))
                }
                push(ctx.module.functions, ctx.func)
                mi = mi + 1
            }
        }
        i = i + 1
    }
    ctx.module
}

// ── MIR Dump ─────────────────────────────────────────────────────────────────
pub fn dump_mir(m: MirModule) {
    mir_compute_dominance(m)
    mir_ssa_rename_module(m)
    let fn_count = len(m.functions)
    stdio::eprintln(concat(String_from("MIR module: "), concat(to_string(fn_count), String_from(" function(s)"))))
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        let block_count = len(f.blocks)
        let local_count = len(f.locals)
        stdio::eprintln(concat(String_from("  fn "), concat(clone(f.name), concat(String_from(" ("), concat(to_string(local_count), concat(String_from(" locals, "), concat(to_string(block_count), String_from(" blocks)"))))))))
        let mut b = 0
        while b < block_count {
            let block = get_unchecked(f.blocks, b)
            let phi_count = len(block.phis)
            let inst_count = len(block.instructions)
            let mut block_msg = concat(String_from("    bb"), to_string(b))
            block_msg = concat(block_msg, String_from(": phis="))
            block_msg = concat(block_msg, to_string(phi_count))
            block_msg = concat(block_msg, String_from(" instructions="))
            block_msg = concat(block_msg, to_string(inst_count))
            block_msg = concat(block_msg, String_from(" succs="))
            block_msg = concat(block_msg, mir_format_edges(block.succ0, block.succ1))
            block_msg = concat(block_msg, String_from(" preds="))
            block_msg = concat(block_msg, mir_format_block_ids(block.preds))
            block_msg = concat(block_msg, String_from(" idom="))
            block_msg = concat(block_msg, mir_format_edge(block.idom))
            block_msg = concat(block_msg, String_from(" df="))
            block_msg = concat(block_msg, mir_format_block_ids(block.dom_frontier))
            stdio::eprintln(block_msg)
            let mut p = 0
            while p < phi_count {
                let phi = get_unchecked(block.phis, p)
                stdio::eprintln(concat(String_from("      "), mir_format_phi(f, phi)))
                p = p + 1
            }
            let mut j = 0
            while j < inst_count {
                let inst = get_unchecked(block.instructions, j)
                stdio::eprintln(concat(String_from("      "), concat(mir_op_name(inst.op), concat(String_from(" -> "), mir_format_local_ref(f, inst.dest)))))
                j = j + 1
            }
            b = b + 1
        }
        i = i + 1
    }
    let str_count = len(m.string_constants)
    if str_count > 0 {
        stdio::eprintln(concat(String_from("  strings: "), to_string(str_count)))
    }
}

fn mir_op_name(op: i32) -> String {
    if op == MIR_CONST_I32() {
        return String_from("const.i32")
    }
    if op == MIR_CONST_I64() {
        return String_from("const.i64")
    }
    if op == MIR_CONST_F64() {
        return String_from("const.f64")
    }
    if op == MIR_CONST_STRING() {
        return String_from("const.string")
    }
    if op == MIR_LOCAL_GET() {
        return String_from("local.get")
    }
    if op == MIR_LOCAL_SET() {
        return String_from("local.set")
    }
    if op == MIR_ADD() {
        return String_from("add")
    }
    if op == MIR_SUB() {
        return String_from("sub")
    }
    if op == MIR_MUL() {
        return String_from("mul")
    }
    if op == MIR_DIV() {
        return String_from("div")
    }
    if op == MIR_MOD() {
        return String_from("mod")
    }
    if op == MIR_EQ() {
        return String_from("eq")
    }
    if op == MIR_NEQ() {
        return String_from("neq")
    }
    if op == MIR_LT() {
        return String_from("lt")
    }
    if op == MIR_LTEQ() {
        return String_from("le")
    }
    if op == MIR_GT() {
        return String_from("gt")
    }
    if op == MIR_GTEQ() {
        return String_from("ge")
    }
    if op == MIR_AND() {
        return String_from("and")
    }
    if op == MIR_OR() {
        return String_from("or")
    }
    if op == MIR_NEG() {
        return String_from("neg")
    }
    if op == MIR_NOT() {
        return String_from("not")
    }
    if op == MIR_CALL() {
        return String_from("call")
    }
    if op == MIR_RETURN() {
        return String_from("return")
    }
    if op == MIR_BR() {
        return String_from("br")
    }
    if op == MIR_BR_IF() {
        return String_from("br_if")
    }
    if op == MIR_BLOCK() {
        return String_from("block")
    }
    if op == MIR_LOOP() {
        return String_from("loop")
    }
    if op == MIR_IF() {
        return String_from("if")
    }
    if op == MIR_STRUCT_NEW() {
        return String_from("struct.new")
    }
    if op == MIR_STRUCT_GET() {
        return String_from("struct.get")
    }
    if op == MIR_STRUCT_SET() {
        return String_from("struct.set")
    }
    if op == MIR_ARRAY_NEW() {
        return String_from("array.new")
    }
    if op == MIR_ARRAY_GET() {
        return String_from("array.get")
    }
    if op == MIR_ARRAY_SET() {
        return String_from("array.set")
    }
    if op == MIR_ARRAY_LEN() {
        return String_from("array.len")
    }
    if op == MIR_DROP() {
        return String_from("drop")
    }
    if op == MIR_NOP() {
        return String_from("nop")
    }
    if op == MIR_UNREACHABLE() {
        return String_from("unreachable")
    }
    if op == MIR_PHI() {
        return String_from("phi")
    }
    String_from("?op")
}

fn mir_value_type_name(vt: i32) -> String {
    if vt == VT_I32() {
        return String_from("i32")
    }
    if vt == VT_I64() {
        return String_from("i64")
    }
    if vt == VT_F64() {
        return String_from("f64")
    }
    if vt == VT_REF() {
        return String_from("ref")
    }
    if vt == VT_VOID() {
        return String_from("void")
    }
    String_from("?")
}

fn mir_format_local_ref(f: MirFunction, local_id: i32) -> String {
    if local_id < 0 {
        return String_from("%-")
    }
    if local_id >= len(f.locals) {
        return concat(String_from("%"), to_string(local_id))
    }
    let local = get_unchecked(f.locals, local_id)
    if local.ssa_version >= 0 {
        let mut out = String_from("%")
        out = concat(out, clone(local.ssa_name))
        out = concat(out, String_from("."))
        return concat(out, to_string(local.ssa_version))
    }
    concat(String_from("%"), to_string(local_id))
}

fn mir_format_phi_args(f: MirFunction, args: Vec<MirPhiArg>) -> String {
    let count = len(args)
    let mut out = String_from("[")
    let mut i = 0
    while i < count {
        let arg = get_unchecked(args, i)
        if i > 0 {
            out = concat(out, String_from(", "))
        }
        out = concat(out, String_from("bb"))
        out = concat(out, to_string(arg.pred_block))
        out = concat(out, String_from(" -> "))
        out = concat(out, mir_format_local_ref(f, arg.local))
        i = i + 1
    }
    concat(out, String_from("]"))
}

fn mir_format_phi(f: MirFunction, phi: MirPhi) -> String {
    let mut out = mir_op_name(phi.op)
    out = concat(out, String_from(" "))
    out = concat(out, mir_format_local_ref(f, phi.dest))
    out = concat(out, String_from(" = "))
    out = concat(out, mir_format_phi_args(f, phi.args))
    out = concat(out, String_from(" : "))
    concat(out, mir_value_type_name(phi.val_type))
}

fn mir_format_block_ids(ids: Vec<i32>) -> String {
    let count = len(ids)
    let mut out = String_from("[")
    let mut i = 0
    while i < count {
        if i > 0 {
            out = concat(out, String_from(","))
        }
        out = concat(out, to_string(get_unchecked(ids, i)))
        i = i + 1
    }
    concat(out, String_from("]"))
}

fn mir_format_edge(edge: i32) -> String {
    if edge < 0 {
        return String_from("-")
    }
    to_string(edge)
}

fn mir_format_edges(succ0: i32, succ1: i32) -> String {
    concat(String_from("["), concat(mir_format_edge(succ0), concat(String_from(","), concat(mir_format_edge(succ1), String_from("]")))))
}

fn mir_expect_preds(f: MirFunction, block_id: i32, expected_count: i32, expected0: i32, expected1: i32) {
    let block = get_unchecked(f.blocks, block_id)
    let actual_count = len(block.preds)
    if actual_count != expected_count {
        let msg = concat(String_from("pred check failed for bb"), concat(to_string(block_id), concat(String_from(": expected count="), concat(to_string(expected_count), concat(String_from(" actual="), concat(to_string(actual_count), concat(String_from(" preds="), mir_format_block_ids(block.preds))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 && get_unchecked(block.preds, 0) != expected0 {
        let msg = concat(String_from("pred check failed for bb"), concat(to_string(block_id), concat(String_from(": expected preds="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.preds)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 1 && get_unchecked(block.preds, 1) != expected1 {
        let msg = concat(String_from("pred check failed for bb"), concat(to_string(block_id), concat(String_from(": expected preds="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.preds)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_idom(f: MirFunction, block_id: i32, expected_idom: i32) {
    let block = get_unchecked(f.blocks, block_id)
    if block.idom != expected_idom {
        let msg = concat(String_from("idom check failed for bb"), concat(to_string(block_id), concat(String_from(": expected="), concat(mir_format_edge(expected_idom), concat(String_from(" actual="), mir_format_edge(block.idom))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_frontier(f: MirFunction, block_id: i32, expected_count: i32, expected0: i32, expected1: i32) {
    let block = get_unchecked(f.blocks, block_id)
    let actual_count = len(block.dom_frontier)
    if actual_count != expected_count {
        let msg = concat(String_from("frontier check failed for bb"), concat(to_string(block_id), concat(String_from(": expected count="), concat(to_string(expected_count), concat(String_from(" actual="), concat(to_string(actual_count), concat(String_from(" frontier="), mir_format_block_ids(block.dom_frontier))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 && get_unchecked(block.dom_frontier, 0) != expected0 {
        let msg = concat(String_from("frontier check failed for bb"), concat(to_string(block_id), concat(String_from(": expected frontier="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.dom_frontier)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 1 && get_unchecked(block.dom_frontier, 1) != expected1 {
        let msg = concat(String_from("frontier check failed for bb"), concat(to_string(block_id), concat(String_from(": expected frontier="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.dom_frontier)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_phi(f: MirFunction, block_id: i32, expected_dest: i32, expected_vt: i32, expected_count: i32, expected_pred0: i32, expected_local0: i32, expected_pred1: i32, expected_local1: i32) {
    let block = get_unchecked(f.blocks, block_id)
    let actual_count = len(block.phis)
    if actual_count != 1 {
        let mut msg = concat(String_from("phi check failed for bb"), to_string(block_id))
        msg = concat(msg, String_from(": expected phi count=1 actual="))
        msg = concat(msg, to_string(actual_count))
        stdio::eprintln(msg)
        process::exit(1)
    }
    let phi = get_unchecked(block.phis, 0)
    if phi.op != MIR_PHI() || phi.dest != expected_dest || phi.val_type != expected_vt {
        let mut msg = concat(String_from("phi check failed for bb"), to_string(block_id))
        msg = concat(msg, String_from(": expected dest=%"))
        msg = concat(msg, to_string(expected_dest))
        msg = concat(msg, String_from(" type="))
        msg = concat(msg, mir_value_type_name(expected_vt))
        msg = concat(msg, String_from(" actual="))
        msg = concat(msg, mir_format_phi(f, phi))
        stdio::eprintln(msg)
        process::exit(1)
    }
    let arg_count = len(phi.args)
    if arg_count != expected_count {
        let mut msg = concat(String_from("phi arg count check failed for bb"), to_string(block_id))
        msg = concat(msg, String_from(": expected="))
        msg = concat(msg, to_string(expected_count))
        msg = concat(msg, String_from(" actual="))
        msg = concat(msg, to_string(arg_count))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 {
        let arg0 = get_unchecked(phi.args, 0)
        if arg0.pred_block != expected_pred0 || arg0.local != expected_local0 {
            let msg = concat(String_from("phi arg0 check failed for bb"), concat(to_string(block_id), concat(String_from(": actual="), mir_format_phi(f, phi))))
            stdio::eprintln(msg)
            process::exit(1)
        }
    }
    if expected_count > 1 {
        let arg1 = get_unchecked(phi.args, 1)
        if arg1.pred_block != expected_pred1 || arg1.local != expected_local1 {
            let msg = concat(String_from("phi arg1 check failed for bb"), concat(to_string(block_id), concat(String_from(": actual="), mir_format_phi(f, phi))))
            stdio::eprintln(msg)
            process::exit(1)
        }
    }
}

fn mir_expect_local_ssa(f: MirFunction, local_id: i32, expected_name: String, expected_version: i32) {
    if local_id < 0 || local_id >= len(f.locals) {
        stdio::eprintln(String_from("ssa local check failed: local id out of range"))
        process::exit(1)
    }
    let local = get_unchecked(f.locals, local_id)
    if !eq(clone(local.ssa_name), clone(expected_name)) || local.ssa_version != expected_version {
        let mut msg = concat(String_from("ssa local check failed for "), mir_format_local_ref(f, local_id))
        msg = concat(msg, String_from(": expected %"))
        msg = concat(msg, expected_name)
        msg = concat(msg, String_from("."))
        msg = concat(msg, to_string(expected_version))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_local_ref_eq(f: MirFunction, local_id: i32, expected: String, label: String) {
    let actual = mir_format_local_ref(f, local_id)
    if !eq(clone(actual), clone(expected)) {
        let mut msg = concat(String_from("ssa ref check failed for "), label)
        msg = concat(msg, String_from(": expected "))
        msg = concat(msg, expected)
        msg = concat(msg, String_from(" actual "))
        msg = concat(msg, actual)
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_phi_format(f: MirFunction, block_id: i32, phi_index: i32, expected: String) {
    if block_id < 0 || block_id >= len(f.blocks) {
        stdio::eprintln(String_from("phi format check failed: block out of range"))
        process::exit(1)
    }
    let block = get_unchecked(f.blocks, block_id)
    if phi_index < 0 || phi_index >= len(block.phis) {
        stdio::eprintln(String_from("phi format check failed: phi out of range"))
        process::exit(1)
    }
    let phi = get_unchecked(block.phis, phi_index)
    let actual = mir_format_phi(f, phi)
    if !eq(clone(actual), clone(expected)) {
        let mut msg = String_from("phi format check failed: expected ")
        msg = concat(msg, expected)
        msg = concat(msg, String_from(" actual "))
        msg = concat(msg, actual)
        stdio::eprintln(msg)
        process::exit(1)
    }
}

pub fn run_phi_representation_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("phi_repr_sample"))
    let cond = alloc_local(f, String_from("cond"), VT_I32())
    let then_val = alloc_local(f, String_from("then_val"), VT_I32())
    let else_val = alloc_local(f, String_from("else_val"), VT_I32())
    let join_val = alloc_local(f, String_from("join_val"), VT_I32())
    f.return_type = VT_I32()
    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)
    emit_inst(f, entry, MirInst_const_i32(1, cond))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb
    emit_inst(f, then_bb, MirInst_const_i32(10, then_val))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb
    emit_inst(f, else_bb, MirInst_const_i32(20, else_val))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb
    let phi = MirPhi_new(join_val, VT_I32())
    mir_phi_add_arg(phi, then_bb, then_val)
    mir_phi_add_arg(phi, else_bb, else_val)
    emit_phi(f, join_bb, phi)
    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = join_val
    emit_inst(f, join_bb, ret_inst)
    mir_compute_dominance_for_function(f)
    mir_ssa_rename_function(f)
    mir_expect_preds(f, join_bb, 2, then_bb, else_bb)
    mir_expect_frontier(f, then_bb, 1, join_bb, 0)
    mir_expect_frontier(f, else_bb, 1, join_bb, 0)
    mir_expect_phi(f, join_bb, join_val, VT_I32(), 2, then_bb, then_val, else_bb, else_val)
    mir_expect_local_ssa(f, cond, String_from("cond"), 1)
    mir_expect_local_ssa(f, then_val, String_from("then_val"), 1)
    mir_expect_local_ssa(f, else_val, String_from("else_val"), 1)
    mir_expect_local_ssa(f, join_val, String_from("join_val"), 1)
    mir_expect_phi_format(f, join_bb, 0, String_from("phi %join_val.1 = [bb1 -> %then_val.1, bb2 -> %else_val.1] : i32"))
    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR phi representation self-check OK."))
}

pub fn run_phi_insertion_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("phi_insert_sample"))
    let cond = alloc_local(f, String_from("cond"), VT_I32())
    let then_val = alloc_local(f, String_from("then_val"), VT_I32())
    let else_val = alloc_local(f, String_from("else_val"), VT_I32())
    let join_val = alloc_local(f, String_from("join_val"), VT_I32())
    f.return_type = VT_I32()
    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)
    emit_inst(f, entry, MirInst_const_i32(1, cond))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb
    emit_inst(f, then_bb, MirInst_const_i32(10, then_val))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb
    emit_inst(f, else_bb, MirInst_const_i32(20, else_val))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb
    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = join_val
    emit_inst(f, join_bb, ret_inst)
    mir_compute_dominance_for_function(f)
    if !mir_try_insert_simple_join_phi(f, join_bb, join_val) {
        stdio::eprintln(String_from("simple join phi insertion failed"))
        process::exit(1)
    }
    mir_ssa_rename_function(f)
    mir_expect_preds(f, join_bb, 2, then_bb, else_bb)
    mir_expect_frontier(f, then_bb, 1, join_bb, 0)
    mir_expect_frontier(f, else_bb, 1, join_bb, 0)
    mir_expect_phi(f, join_bb, join_val, VT_I32(), 2, then_bb, then_val, else_bb, else_val)
    mir_expect_local_ssa(f, cond, String_from("cond"), 1)
    mir_expect_local_ssa(f, then_val, String_from("then_val"), 1)
    mir_expect_local_ssa(f, else_val, String_from("else_val"), 1)
    mir_expect_local_ssa(f, join_val, String_from("join_val"), 1)
    mir_expect_phi_format(f, join_bb, 0, String_from("phi %join_val.1 = [bb1 -> %then_val.1, bb2 -> %else_val.1] : i32"))
    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR phi insertion self-check OK."))
}

pub fn run_phi_insertion_nested_join_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("phi_insert_nested_join_sample"))
    let cond_outer = alloc_local(f, String_from("cond_outer"), VT_I32())
    let cond_inner = alloc_local(f, String_from("cond_inner"), VT_I32())
    let inner_then_val = alloc_local(f, String_from("inner_then_val"), VT_I32())
    let inner_else_val = alloc_local(f, String_from("inner_else_val"), VT_I32())
    let inner_join_val = alloc_local(f, String_from("inner_join_val"), VT_I32())
    let outer_else_val = alloc_local(f, String_from("outer_else_val"), VT_I32())
    let outer_join_val = alloc_local(f, String_from("outer_join_val"), VT_I32())
    f.return_type = VT_I32()
    let entry = alloc_block(f)
    let outer_then_bb = alloc_block(f)
    let inner_then_bb = alloc_block(f)
    let inner_else_bb = alloc_block(f)
    let inner_join_bb = alloc_block(f)
    let outer_else_bb = alloc_block(f)
    let outer_join_bb = alloc_block(f)
    emit_inst(f, entry, MirInst_const_i32(1, cond_outer))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = outer_then_bb
    entry_block.succ1 = outer_else_bb
    emit_inst(f, outer_then_bb, MirInst_const_i32(1, cond_inner))
    let outer_then_block = get_unchecked(f.blocks, outer_then_bb)
    outer_then_block.succ0 = inner_then_bb
    outer_then_block.succ1 = inner_else_bb
    emit_inst(f, inner_then_bb, MirInst_const_i32(10, inner_then_val))
    let inner_then_block = get_unchecked(f.blocks, inner_then_bb)
    inner_then_block.succ0 = inner_join_bb
    emit_inst(f, inner_else_bb, MirInst_const_i32(20, inner_else_val))
    let inner_else_block = get_unchecked(f.blocks, inner_else_bb)
    inner_else_block.succ0 = inner_join_bb
    let inner_join_block = get_unchecked(f.blocks, inner_join_bb)
    inner_join_block.succ0 = outer_join_bb
    emit_inst(f, outer_else_bb, MirInst_const_i32(30, outer_else_val))
    let outer_else_block = get_unchecked(f.blocks, outer_else_bb)
    outer_else_block.succ0 = outer_join_bb
    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = outer_join_val
    emit_inst(f, outer_join_bb, ret_inst)
    mir_compute_dominance_for_function(f)
    if !mir_try_insert_simple_join_phi(f, inner_join_bb, inner_join_val) {
        stdio::eprintln(String_from("nested join phi insertion failed at inner join"))
        process::exit(1)
    }
    if !mir_try_insert_simple_join_phi(f, outer_join_bb, outer_join_val) {
        stdio::eprintln(String_from("nested join phi insertion failed at outer join"))
        process::exit(1)
    }
    mir_ssa_rename_function(f)
    mir_expect_phi(f, inner_join_bb, inner_join_val, VT_I32(), 2, inner_then_bb, inner_then_val, inner_else_bb, inner_else_val)
    mir_expect_phi(f, outer_join_bb, outer_join_val, VT_I32(), 2, inner_join_bb, inner_join_val, outer_else_bb, outer_else_val)
    mir_expect_phi_format(f, inner_join_bb, 0, String_from("phi %inner_join_val.1 = [bb2 -> %inner_then_val.1, bb3 -> %inner_else_val.1] : i32"))
    mir_expect_phi_format(f, outer_join_bb, 0, String_from("phi %outer_join_val.1 = [bb4 -> %inner_join_val.1, bb5 -> %outer_else_val.1] : i32"))
    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR nested phi insertion self-check OK."))
}

