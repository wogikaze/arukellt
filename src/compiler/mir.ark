// ── MIR Value Type Tags ─────────────────────────────────────────────────────
fn VT_I32() -> i32 {
    1
}

fn VT_I64() -> i32 {
    2
}

fn VT_F64() -> i32 {
    3
}

fn VT_REF() -> i32 {
    4
}

fn VT_VOID() -> i32 {
    0
}

// ── MIR Instruction ──────────────────────────────────────────────────────────
struct MirInst {
    op: i32,
    dest: i32,
    arg0: i32,
    arg1: i32,
    int_val: i32,
    float_val: f64,
    str_val: String,
    val_type: i32,
}

fn MirInst_new(op: i32) -> MirInst {
    MirInst { op: op, dest: 0 - 1, arg0: 0 - 1, arg1: 0 - 1, int_val: 0, float_val: 0.0, str_val: String_new(), val_type: VT_VOID() }
}

struct MirPhiArg {
    pred_block: i32,
    local: i32,
}

fn MirPhiArg_new(pred_block: i32, local: i32) -> MirPhiArg {
    MirPhiArg { pred_block: pred_block, local: local }
}

struct MirPhi {
    op: i32,
    dest: i32,
    val_type: i32,
    args: Vec<MirPhiArg>,
}

fn MirPhi_new(dest: i32, val_type: i32) -> MirPhi {
    MirPhi { op: MIR_PHI(), dest: dest, val_type: val_type, args: Vec_new_MirPhiArg() }
}

fn mir_phi_add_arg(phi: MirPhi, pred_block: i32, local: i32) {
    push(phi.args, MirPhiArg_new(pred_block, local))
}

fn MirInst_const_i32(val: i32, dest: i32) -> MirInst {
    MirInst { op: MIR_CONST_I32(), dest: dest, arg0: 0 - 1, arg1: 0 - 1, int_val: val, float_val: 0.0, str_val: String_new(), val_type: VT_I32() }
}

fn MirInst_const_i64_text(text: String, dest: i32) -> MirInst {
    MirInst { op: MIR_CONST_I64(), dest: dest, arg0: 0 - 1, arg1: 0 - 1, int_val: 0, float_val: 0.0, str_val: text, val_type: VT_I64() }
}

// Parse a decimal integer string as i64. Stops at the first non-digit character.
fn parse_decimal_as_i64(text: String) -> i64 {
    let n = len(text)
    let mut result: i64 = 0
    let mut i = 0
    let mut neg = false
    if i < n && char_at(text, i) == 45 {
        neg = true
        i = i + 1
    }
    let mut stop = false
    while i < n && !stop {
        let d = char_at(text, i)
        if d >= 48 && d <= 57 {
            result = result * 10 + i32_to_i64(d - 48)
        } else {
            if d == 95 {
            } else {
                stop = true
            }
        }
        i = i + 1
    }
    if neg {
        result = 0 - result
    }
    result
}

fn MirInst_const_string(val: String, dest: i32) -> MirInst {
    MirInst { op: MIR_CONST_STRING(), dest: dest, arg0: 0 - 1, arg1: 0 - 1, int_val: 0, float_val: 0.0, str_val: val, val_type: VT_REF() }
}

fn MirInst_const_f64(val: f64, dest: i32) -> MirInst {
    MirInst { op: MIR_CONST_F64(), dest: dest, arg0: 0 - 1, arg1: 0 - 1, int_val: 0, float_val: val, str_val: String_new(), val_type: VT_F64() }
}

fn MirInst_binop(op: i32, dest: i32, a: i32, b: i32) -> MirInst {
    MirInst { op: op, dest: dest, arg0: a, arg1: b, int_val: 0, float_val: 0.0, str_val: String_new(), val_type: VT_I32() }
}

// ── MIR Basic Block ──────────────────────────────────────────────────────────
struct MirBlock {
    id: i32,
    phis: Vec<MirPhi>,
    instructions: Vec<MirInst>,
    terminator: i32,
    succ0: i32,
    succ1: i32,
    preds: Vec<i32>,
    idom: i32,
    dom_set: Vec<i32>,
    dom_frontier: Vec<i32>,
}

fn MirBlock_new(id: i32) -> MirBlock {
    MirBlock { id: id, phis: Vec_new_MirPhi(), instructions: Vec_new_MirInst(), terminator: MIR_RETURN(), succ0: 0 - 1, succ1: 0 - 1, preds: Vec_new_i32(), idom: 0 - 1, dom_set: Vec_new_i32(), dom_frontier: Vec_new_i32() }
}

struct MirDomInfo {
    idom: Vec<i32>,
    frontier_offsets: Vec<i32>,
    frontier_lengths: Vec<i32>,
    frontier_blocks: Vec<i32>,
}

fn MirDomInfo_new() -> MirDomInfo {
    MirDomInfo { idom: Vec_new_i32(), frontier_offsets: Vec_new_i32(), frontier_lengths: Vec_new_i32(), frontier_blocks: Vec_new_i32() }
}

fn mir_push_unique_i32(ids: Vec<i32>, block_id: i32) {
    let pred_count = len(ids)
    let mut i = 0
    while i < pred_count {
        if get_unchecked(ids, i) == block_id {
            return
        }
        i = i + 1
    }
    push(ids, block_id)
}

fn mir_add_block_pred(block: MirBlock, pred_id: i32) {
    mir_push_unique_i32(block.preds, pred_id)
}

fn mir_copy_block_ids(ids: Vec<i32>) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(ids)
    let mut i = 0
    while i < count {
        push(out, get_unchecked(ids, i))
        i = i + 1
    }
    out
}

fn mir_collect_all_block_ids(f: MirFunction) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(f.blocks)
    let mut i = 0
    while i < count {
        push(out, i)
        i = i + 1
    }
    out
}

fn mir_block_ids_contains(ids: Vec<i32>, block_id: i32) -> bool {
    let count = len(ids)
    let mut i = 0
    while i < count {
        if get_unchecked(ids, i) == block_id {
            return true
        }
        i = i + 1
    }
    false
}

fn mir_same_block_id_set(a: Vec<i32>, b: Vec<i32>) -> bool {
    let count = len(a)
    if count != len(b) {
        return false
    }
    let mut i = 0
    while i < count {
        if get_unchecked(a, i) != get_unchecked(b, i) {
            return false
        }
        i = i + 1
    }
    true
}

fn mir_intersect_block_id_sets(a: Vec<i32>, b: Vec<i32>) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(a)
    let mut i = 0
    while i < count {
        let block_id = get_unchecked(a, i)
        if mir_block_ids_contains(b, block_id) {
            push(out, block_id)
        }
        i = i + 1
    }
    out
}

fn mir_add_pred_edge(f: MirFunction, pred_id: i32, succ_id: i32) {
    if succ_id < 0 {
        return
    }
    let block_count = len(f.blocks)
    if succ_id >= block_count {
        return
    }
    let succ = get_unchecked(f.blocks, succ_id)
    mir_add_block_pred(succ, pred_id)
}

fn mir_compute_predecessors_for_function(f: MirFunction) {
    let block_count = len(f.blocks)
    let mut i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.preds = Vec_new_i32()
        i = i + 1
    }
    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        let pred_id = block.id
        mir_add_pred_edge(f, pred_id, block.succ0)
        if block.succ1 != block.succ0 {
            mir_add_pred_edge(f, pred_id, block.succ1)
        }
        i = i + 1
    }
}

fn mir_compute_predecessors(m: MirModule) {
    let fn_count = len(m.functions)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        mir_compute_predecessors_for_function(f)
        i = i + 1
    }
}

fn mir_compute_dominance_for_function(f: MirFunction) {
    mir_compute_predecessors_for_function(f)
    let block_count = len(f.blocks)
    if block_count == 0 {
        return
    }
    let all_block_ids = mir_collect_all_block_ids(f)
    let mut i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.idom = 0 - 1
        block.dom_frontier = Vec_new_i32()
        if i == 0 {
            block.dom_set = Vec_new_i32()
            push(block.dom_set, block.id)
        } else {
            block.dom_set = mir_copy_block_ids(all_block_ids)
        }
        i = i + 1
    }
    let mut changed = true
    while changed {
        changed = false
        let mut b = 1
        while b < block_count {
            let block = get_unchecked(f.blocks, b)
            let pred_count = len(block.preds)
            let mut new_set = Vec_new_i32()
            if pred_count == 0 {
                push(new_set, block.id)
            } else {
                let first_pred = get_unchecked(block.preds, 0)
                let first_pred_block = get_unchecked(f.blocks, first_pred)
                new_set = mir_copy_block_ids(first_pred_block.dom_set)
                let mut pred_idx = 1
                while pred_idx < pred_count {
                    let pred_id = get_unchecked(block.preds, pred_idx)
                    let pred_block = get_unchecked(f.blocks, pred_id)
                    new_set = mir_intersect_block_id_sets(new_set, pred_block.dom_set)
                    pred_idx = pred_idx + 1
                }
            }
            mir_push_unique_i32(new_set, block.id)
            if !mir_same_block_id_set(block.dom_set, new_set) {
                block.dom_set = new_set
                changed = true
            }
            b = b + 1
        }
    }
    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.idom = 0 - 1
        if i != 0 {
            let strict_count = len(block.dom_set)
            let mut dom_idx = 0
            while dom_idx < strict_count {
                let candidate = get_unchecked(block.dom_set, dom_idx)
                if candidate != block.id {
                    let candidate_block = get_unchecked(f.blocks, candidate)
                    let mut is_idom = true
                    let mut other_idx = 0
                    while other_idx < strict_count {
                        let other = get_unchecked(block.dom_set, other_idx)
                        if other != block.id && other != candidate {
                            if !mir_block_ids_contains(candidate_block.dom_set, other) {
                                is_idom = false
                            }
                        }
                        other_idx = other_idx + 1
                    }
                    if is_idom {
                        block.idom = candidate
                    }
                }
                dom_idx = dom_idx + 1
            }
        }
        i = i + 1
    }
    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.dom_frontier = Vec_new_i32()
        i = i + 1
    }
    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        let pred_count = len(block.preds)
        if pred_count >= 2 {
            let mut pred_idx = 0
            while pred_idx < pred_count {
                let mut runner = get_unchecked(block.preds, pred_idx)
                while runner >= 0 && runner != block.idom {
                    let runner_block = get_unchecked(f.blocks, runner)
                    mir_push_unique_i32(runner_block.dom_frontier, block.id)
                    runner = runner_block.idom
                }
                pred_idx = pred_idx + 1
            }
        }
        i = i + 1
    }
}

fn mir_collect_dom_info_for_function(f: MirFunction) -> MirDomInfo {
    let info = MirDomInfo_new()
    let block_count = len(f.blocks)
    let mut i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        push(info.idom, block.idom)
        push(info.frontier_offsets, len(info.frontier_blocks))
        push(info.frontier_lengths, len(block.dom_frontier))
        let frontier_count = len(block.dom_frontier)
        let mut j = 0
        while j < frontier_count {
            push(info.frontier_blocks, get_unchecked(block.dom_frontier, j))
            j = j + 1
        }
        i = i + 1
    }
    info
}

fn mir_compute_dominance(m: MirModule) {
    let fn_count = len(m.functions)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        mir_compute_dominance_for_function(f)
        i = i + 1
    }
}

// ── MIR Function ─────────────────────────────────────────────────────────────
struct MirLocal {
    name: String,
    val_type: i32,
    ssa_name: String,
    ssa_version: i32,
}

struct MirFunction {
    name: String,
    params: Vec<MirLocal>,
    locals: Vec<MirLocal>,
    blocks: Vec<MirBlock>,
    return_type: i32,
    next_local: i32,
    next_block: i32,
}

fn MirFunction_new(name: String) -> MirFunction {
    MirFunction { name: name, params: Vec_new_MirLocal(), locals: Vec_new_MirLocal(), blocks: Vec_new_MirBlock(), return_type: VT_VOID(), next_local: 0, next_block: 0 }
}

fn alloc_local(f: MirFunction, name: String, vt: i32) -> i32 {
    let idx = f.next_local
    f.next_local = f.next_local + 1
    push(f.locals, MirLocal { name: clone(name), val_type: vt, ssa_name: name, ssa_version: 0 - 1 })
    idx
}

fn mir_locals_replace_at(locals: Vec<MirLocal>, at: i32, new_l: MirLocal) -> Vec<MirLocal> {
    let out = Vec_new_MirLocal()
    let n = len(locals)
    let mut i = 0
    while i < n {
        if i == at {
            push(out, new_l)
        } else {
            push(out, get_unchecked(locals, i))
        }
        i = i + 1
    }
    out
}

fn alloc_block(f: MirFunction) -> i32 {
    let idx = f.next_block
    f.next_block = f.next_block + 1
    push(f.blocks, MirBlock_new(idx))
    idx
}

fn ctx_alloc_block(ctx: LowerCtx) -> i32 {
    let mut f = ctx.func
    let idx = f.next_block
    f.next_block = f.next_block + 1
    let bs = f.blocks
    push(bs, MirBlock_new(idx))
    f.blocks = bs
    ctx.func = f
    idx
}

fn emit_inst(f: MirFunction, block_id: i32, inst: MirInst) {
    let block = get_unchecked(f.blocks, block_id)
    push(block.instructions, inst)
}

fn emit_phi(f: MirFunction, block_id: i32, phi: MirPhi) {
    let block = get_unchecked(f.blocks, block_id)
    push(block.phis, phi)
}

fn mir_local_vt_for_function(f: MirFunction, local_id: i32) -> i32 {
    if local_id >= 0 && local_id < len(f.locals) {
        let local = get_unchecked(f.locals, local_id)
        return local.val_type
    }
    VT_VOID()
}

fn mir_assign_local_ssa(f: MirFunction, local_id: i32, ssa_name: String, ssa_version: i32) {
    if local_id < 0 || local_id >= len(f.locals) {
        return
    }
    let local = get_unchecked(f.locals, local_id)
    local.ssa_name = ssa_name
    local.ssa_version = ssa_version
}

fn mir_assign_simple_join_phi_ssa(f: MirFunction, dest_local: i32, pred0_local: i32, pred1_local: i32) {
    if dest_local < 0 || dest_local >= len(f.locals) {
        return
    }
    let dest = get_unchecked(f.locals, dest_local)
    let ssa_name = clone(dest.name)
    mir_assign_local_ssa(f, pred0_local, clone(ssa_name), 1)
    mir_assign_local_ssa(f, pred1_local, clone(ssa_name), 2)
    mir_assign_local_ssa(f, dest_local, ssa_name, 3)
}

fn mir_find_last_value_local(block: MirBlock) -> i32 {
    let count = len(block.instructions)
    let mut i = count - 1
    while i >= 0 {
        let inst = get_unchecked(block.instructions, i)
        if inst.dest >= 0 && inst.val_type != VT_VOID() {
            return inst.dest
        }
        i = i - 1
    }
    let phi_count = len(block.phis)
    let mut p = phi_count - 1
    while p >= 0 {
        let phi = get_unchecked(block.phis, p)
        if phi.dest >= 0 {
            return phi.dest
        }
        p = p - 1
    }
    0 - 1
}

fn mir_try_insert_simple_join_phi(f: MirFunction, join_block_id: i32, dest_local: i32) -> bool {
    if join_block_id < 0 || join_block_id >= len(f.blocks) {
        return false
    }
    let join_block = get_unchecked(f.blocks, join_block_id)
    if len(join_block.phis) > 0 {
        return false
    }
    if len(join_block.preds) != 2 {
        return false
    }
    let pred0_id = get_unchecked(join_block.preds, 0)
    let pred1_id = get_unchecked(join_block.preds, 1)
    let pred0 = get_unchecked(f.blocks, pred0_id)
    let pred1 = get_unchecked(f.blocks, pred1_id)
    if !mir_block_ids_contains(pred0.dom_frontier, join_block_id) {
        return false
    }
    if !mir_block_ids_contains(pred1.dom_frontier, join_block_id) {
        return false
    }
    let pred0_local = mir_find_last_value_local(pred0)
    let pred1_local = mir_find_last_value_local(pred1)
    if pred0_local < 0 || pred1_local < 0 {
        return false
    }
    let dest_vt = mir_local_vt_for_function(f, dest_local)
    if dest_vt == VT_VOID() {
        return false
    }
    if mir_local_vt_for_function(f, pred0_local) != dest_vt {
        return false
    }
    if mir_local_vt_for_function(f, pred1_local) != dest_vt {
        return false
    }
    mir_assign_simple_join_phi_ssa(f, dest_local, pred0_local, pred1_local)
    let phi = MirPhi_new(dest_local, dest_vt)
    mir_phi_add_arg(phi, pred0_id, pred0_local)
    mir_phi_add_arg(phi, pred1_id, pred1_local)
    emit_phi(f, join_block_id, phi)
    true
}

// ── SSA renaming (after φ placement) ────────────────────────────────────────
//
// The selfhost MIR keeps φ nodes in the existing `MirPhi` representation. SSA
// renaming rewrites local references to distinct MIR local slots so dumps and
// self-checks can observe value IDs without requiring backend φ lowering.
struct MirSsaRenameState {
    original_local_count: i32,
    versions: Vec<i32>,
    current: Vec<i32>,
    exit_values: Vec<i32>,
}

fn mir_i32_vec_filled(count: i32, value: i32) -> Vec<i32> {
    let out = Vec_new_i32()
    let mut i = 0
    while i < count {
        push(out, value)
        i = i + 1
    }
    out
}

fn mir_i32_vec_replace_at(values: Vec<i32>, at: i32, value: i32) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(values)
    let mut i = 0
    while i < count {
        if i == at {
            push(out, value)
        } else {
            push(out, get_unchecked(values, i))
        }
        i = i + 1
    }
    out
}

fn MirSsaRenameState_new(original_local_count: i32, block_count: i32) -> MirSsaRenameState {
    MirSsaRenameState {
        original_local_count: original_local_count,
        versions: mir_i32_vec_filled(original_local_count, 0 - 1),
        current: mir_i32_vec_filled(original_local_count, 0 - 1),
        exit_values: mir_i32_vec_filled(original_local_count * block_count, 0 - 1),
    }
}

fn mir_ssa_exit_index(state: MirSsaRenameState, block_id: i32, local_id: i32) -> i32 {
    block_id * state.original_local_count + local_id
}

fn mir_ssa_set_current(state: MirSsaRenameState, local_id: i32, value_id: i32) {
    if local_id < 0 || local_id >= state.original_local_count {
        return
    }
    state.current = mir_i32_vec_replace_at(state.current, local_id, value_id)
}

fn mir_ssa_set_version(state: MirSsaRenameState, local_id: i32, version: i32) {
    if local_id < 0 || local_id >= state.original_local_count {
        return
    }
    state.versions = mir_i32_vec_replace_at(state.versions, local_id, version)
}

fn mir_ssa_current_for(state: MirSsaRenameState, local_id: i32) -> i32 {
    if local_id < 0 || local_id >= state.original_local_count {
        return local_id
    }
    let value_id = get_unchecked(state.current, local_id)
    if value_id >= 0 {
        return value_id
    }
    local_id
}

fn mir_ssa_pred_value_for(state: MirSsaRenameState, pred_block: i32, local_id: i32) -> i32 {
    if local_id < 0 || local_id >= state.original_local_count {
        return local_id
    }
    let idx = mir_ssa_exit_index(state, pred_block, local_id)
    if idx >= 0 && idx < len(state.exit_values) {
        let value_id = get_unchecked(state.exit_values, idx)
        if value_id >= 0 {
            return value_id
        }
    }
    local_id
}

fn mir_ssa_load_block_entry(state: MirSsaRenameState, block_id: i32) {
    if block_id < 0 {
        return
    }
    let next_current = Vec_new_i32()
    let mut i = 0
    while i < state.original_local_count {
        let idx = mir_ssa_exit_index(state, block_id, i)
        if idx >= 0 && idx < len(state.exit_values) {
            push(next_current, get_unchecked(state.exit_values, idx))
        } else {
            push(next_current, 0 - 1)
        }
        i = i + 1
    }
    state.current = next_current
}

fn mir_ssa_record_block_exit(state: MirSsaRenameState, block_id: i32) {
    let mut i = 0
    while i < state.original_local_count {
        let idx = mir_ssa_exit_index(state, block_id, i)
        if idx >= 0 && idx < len(state.exit_values) {
            state.exit_values = mir_i32_vec_replace_at(state.exit_values, idx, get_unchecked(state.current, i))
        }
        i = i + 1
    }
}

fn mir_ssa_append_value_slot(f: MirFunction, original_local: i32, ssa_name: String, ssa_version: i32) -> i32 {
    let source = get_unchecked(f.locals, original_local)
    let idx = len(f.locals)
    push(f.locals, MirLocal { name: clone(source.name), val_type: source.val_type, ssa_name: ssa_name, ssa_version: ssa_version })
    idx
}

fn mir_ssa_define_value(f: MirFunction, state: MirSsaRenameState, original_local: i32, ssa_name: String) -> i32 {
    if original_local < 0 || original_local >= state.original_local_count {
        return original_local
    }
    let old_version = get_unchecked(state.versions, original_local)
    let new_version = old_version + 1
    let mut value_id = original_local
    if old_version >= 0 {
        value_id = mir_ssa_append_value_slot(f, original_local, clone(ssa_name), new_version)
    } else {
        mir_assign_local_ssa(f, original_local, clone(ssa_name), new_version)
    }
    mir_ssa_set_version(state, original_local, new_version)
    mir_ssa_set_current(state, original_local, value_id)
    value_id
}

fn mir_ssa_rewrite_inst_uses(inst: MirInst, state: MirSsaRenameState) {
    if inst.arg0 >= 0 {
        inst.arg0 = mir_ssa_current_for(state, inst.arg0)
    }
    if inst.arg1 >= 0 {
        inst.arg1 = mir_ssa_current_for(state, inst.arg1)
    }
}

fn mir_is_pure_ssa_def(inst: MirInst) -> bool {
    let op = inst.op
    if op == MIR_LOCAL_GET() || op == MIR_LOCAL_SET() {
        return false
    }
    if inst.dest < 0 {
        return false
    }
    if inst.val_type == VT_VOID() {
        return false
    }
    if op == MIR_RETURN() {
        return false
    }
    if op == MIR_BR() || op == MIR_BR_IF() || op == MIR_BR_TABLE() {
        return false
    }
    if op == MIR_IF() || op == MIR_ELSE() || op == MIR_END() || op == MIR_BLOCK() || op == MIR_LOOP() {
        return false
    }
    if op == MIR_DROP() || op == MIR_NOP() || op == MIR_UNREACHABLE() {
        return false
    }
    true
}

fn mir_ssa_reset_local_slots(f: MirFunction) {
    let lc = len(f.locals)
    let mut i = 0
    while i < lc {
        let loc = get_unchecked(f.locals, i)
        loc.ssa_version = 0 - 1
        loc.ssa_name = clone(loc.name)
        i = i + 1
    }
}

fn mir_ssa_tag_function_params(f: MirFunction, state: MirSsaRenameState) {
    let pc = len(f.params)
    let mut pi = 0
    while pi < pc {
        let p = get_unchecked(f.params, pi)
        if pi < state.original_local_count {
            mir_assign_local_ssa(f, pi, clone(p.name), 0)
            mir_ssa_set_version(state, pi, 0)
            mir_ssa_set_current(state, pi, pi)
        }
        pi = pi + 1
    }
}

fn mir_ssa_rename_block(f: MirFunction, state: MirSsaRenameState, block_id: i32) {
    if block_id < 0 || block_id >= len(f.blocks) {
        return
    }
    let block = get_unchecked(f.blocks, block_id)
    if block.idom >= 0 {
        mir_ssa_load_block_entry(state, block.idom)
    }
    let pc = len(block.phis)
    let mut pi = 0
    while pi < pc {
        let phi = get_unchecked(block.phis, pi)
        let original_dest = phi.dest
        if original_dest >= 0 && original_dest < state.original_local_count {
            let ac = len(phi.args)
            let mut ai = 0
            while ai < ac {
                let a = get_unchecked(phi.args, ai)
                a.local = mir_ssa_pred_value_for(state, a.pred_block, a.local)
                ai = ai + 1
            }
            let dest_local = get_unchecked(f.locals, original_dest)
            phi.dest = mir_ssa_define_value(f, state, original_dest, clone(dest_local.name))
        }
        pi = pi + 1
    }
    let ic = len(block.instructions)
    let mut ii = 0
    while ii < ic {
        let inst = get_unchecked(block.instructions, ii)
        mir_ssa_rewrite_inst_uses(inst, state)
        if mir_is_pure_ssa_def(inst) {
            let original_dest = inst.dest
            if original_dest >= 0 && original_dest < state.original_local_count {
                let dest_local = get_unchecked(f.locals, original_dest)
                inst.dest = mir_ssa_define_value(f, state, original_dest, clone(dest_local.name))
            }
        }
        ii = ii + 1
    }
    mir_ssa_record_block_exit(state, block.id)
}

fn mir_ssa_rename_blocks(f: MirFunction, state: MirSsaRenameState) {
    let bc = len(f.blocks)
    let mut bi = 0
    while bi < bc {
        mir_ssa_rename_block(f, state, bi)
        bi = bi + 1
    }
}

fn mir_ssa_rename_function(f: MirFunction) {
    let original_local_count = len(f.locals)
    mir_ssa_reset_local_slots(f)
    let state = MirSsaRenameState_new(original_local_count, len(f.blocks))
    mir_ssa_tag_function_params(f, state)
    mir_ssa_rename_blocks(f, state)
}

fn mir_ssa_rename_module(m: MirModule) {
    let fn_count = len(m.functions)
    let mut i = 0
    while i < fn_count {
        mir_ssa_rename_function(get_unchecked(m.functions, i))
        i = i + 1
    }
}

// Preview parallel-copy lowering that replaces a φ after minimal SSA renaming.
// Each predecessor edge receives `merge_name <- ssa_operand`; the join block
// then uses the single merge slot instead of a φ (real insertion is future work).
fn mir_stdio_print_phi_elimination_preview(f: MirFunction, join_block_id: i32) {
    if join_block_id < 0 || join_block_id >= len(f.blocks) {
        return
    }
    let block = get_unchecked(f.blocks, join_block_id)
    let pc = len(block.phis)
    let mut pi = 0
    while pi < pc {
        let phi = get_unchecked(block.phis, pi)
        stdio::println(mir_format_phi(f, phi))
        if phi.dest < 0 || phi.dest >= len(f.locals) {
            pi = pi + 1
            continue
        }
        let dest_rec = get_unchecked(f.locals, phi.dest)
        let merge_name = clone(dest_rec.name)
        let ac = len(phi.args)
        let mut ai = 0
        while ai < ac {
            let a = get_unchecked(phi.args, ai)
            let mut line = String_from("phi_elim_copy bb")
            line = concat(line, to_string(a.pred_block))
            line = concat(line, String_from("->bb"))
            line = concat(line, to_string(join_block_id))
            line = concat(line, String_from(": "))
            line = concat(line, clone(merge_name))
            line = concat(line, String_from(" <- "))
            line = concat(line, mir_format_local_ref(f, a.local))
            stdio::println(line)
            ai = ai + 1
        }
        let mut tail = String_from("phi_elim_join bb")
        tail = concat(tail, to_string(join_block_id))
        tail = concat(tail, String_from(": "))
        tail = concat(tail, clone(merge_name))
        tail = concat(tail, String_from(" (phi removed)"))
        stdio::println(tail)
        pi = pi + 1
    }
}

// ── MIR Module ───────────────────────────────────────────────────────────────
struct MirModule {
    functions: Vec<MirFunction>,
    string_constants: Vec<String>,
}

fn MirModule_new() -> MirModule {
    MirModule { functions: Vec_new_MirFunction(), string_constants: Vec_new_String() }
}

fn intern_string(m: MirModule, s: String) -> i32 {
    let count = len(m.string_constants)
    let mut i = 0
    while i < count {
        let existing = get_unchecked(m.string_constants, i)
        if eq(clone(existing), clone(s)) {
            return i
        }
        i = i + 1
    }
    push(m.string_constants, s)
    count
}

