fn run_ssa_trivial_block_rename_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("ssa_trivial_block_sample"))
    let p = alloc_local(f, String_from("p"), VT_I32())
    push(f.params, MirLocal { name: String_from("p"), val_type: VT_I32(), ssa_name: String_from("p"), ssa_version: 0 - 1 })
    let t = alloc_local(f, String_from("t"), VT_I32())
    f.return_type = VT_I32()
    let bb0 = alloc_block(f)
    emit_inst(f, bb0, MirInst_const_i32(42, t))
    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = t
    emit_inst(f, bb0, ret_inst)
    mir_compute_dominance_for_function(f)
    mir_ssa_rename_function(f)
    mir_expect_local_ssa(f, p, String_from("p"), 0)
    mir_expect_local_ssa(f, t, String_from("t"), 1)
    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR SSA trivial-block rename self-check OK."))
}

fn run_ssa_sequential_def_rename_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("ssa_sequential_def_sample"))
    let t = alloc_local(f, String_from("t"), VT_I32())
    f.return_type = VT_I32()
    let bb0 = alloc_block(f)
    emit_inst(f, bb0, MirInst_const_i32(1, t))
    emit_inst(f, bb0, MirInst_const_i32(2, t))
    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = t
    emit_inst(f, bb0, ret_inst)
    mir_compute_dominance_for_function(f)
    mir_ssa_rename_function(f)
    mir_expect_local_ssa(f, t, String_from("t"), 1)
    let block = get_unchecked(f.blocks, bb0)
    let second_def = get_unchecked(block.instructions, 1)
    let ret = get_unchecked(block.instructions, 2)
    mir_expect_local_ref_eq(f, second_def.dest, String_from("%t.2"), String_from("sequential second def"))
    mir_expect_local_ref_eq(f, ret.arg0, String_from("%t.2"), String_from("sequential return use"))
    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR SSA sequential-def rename self-check OK."))
}

// ── Entry Point ──────────────────────────────────────────────────────────────
fn main() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("cfg_pred_sample"))
    let pa = alloc_local(f, String_from("a"), VT_I32())
    let pb = alloc_local(f, String_from("b"), VT_I32())
    let tmp = alloc_local(f, String_from("_t0"), VT_I32())
    f.return_type = VT_I32()
    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)
    emit_inst(f, entry, MirInst_new(MIR_LOCAL_GET()))
    emit_inst(f, entry, MirInst_new(MIR_LOCAL_GET()))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb
    emit_inst(f, then_bb, MirInst_new(MIR_LOCAL_GET()))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb
    emit_inst(f, else_bb, MirInst_new(MIR_LOCAL_GET()))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb
    emit_inst(f, join_bb, MirInst_binop(MIR_ADD(), tmp, pa, pb))
    emit_inst(f, join_bb, MirInst_new(MIR_RETURN()))
    mir_compute_dominance_for_function(f)
    mir_expect_preds(f, entry, 0, 0, 0)
    mir_expect_preds(f, then_bb, 1, entry, 0)
    mir_expect_preds(f, else_bb, 1, entry, 0)
    mir_expect_preds(f, join_bb, 2, then_bb, else_bb)
    mir_expect_idom(f, entry, 0 - 1)
    mir_expect_idom(f, then_bb, entry)
    mir_expect_idom(f, else_bb, entry)
    mir_expect_idom(f, join_bb, entry)
    mir_expect_frontier(f, entry, 0, 0, 0)
    mir_expect_frontier(f, then_bb, 1, join_bb, 0)
    mir_expect_frontier(f, else_bb, 1, join_bb, 0)
    mir_expect_frontier(f, join_bb, 0, 0, 0)
    let dom_info = mir_collect_dom_info_for_function(f)
    if len(dom_info.idom) != 4 {
        stdio::eprintln(String_from("dominance snapshot check failed: expected 4 idom entries"))
        process::exit(1)
    }
    push(m.functions, f)
    let s0 = intern_string(m, String_from("hello"))
    let s1 = intern_string(m, String_from("world"))
    let s2 = intern_string(m, String_from("hello"))
    stdio::println(concat(String_from("intern 'hello': "), to_string(s0)))
    stdio::println(concat(String_from("intern 'world': "), to_string(s1)))
    stdio::println(concat(String_from("intern 'hello' again: "), to_string(s2)))
    dump_mir(m)
    stdio::println(String_from("MIR predecessor self-check OK."))
    stdio::println(String_from("MIR dominance self-check OK."))
    stdio::println(String_from("MIR module OK."))
    run_phi_representation_smoke()
    run_phi_insertion_smoke()
    run_phi_insertion_nested_join_smoke()
    run_ssa_rename_smoke()
    run_phi_elimination_smoke()
    run_ssa_trivial_block_rename_smoke()
    run_ssa_sequential_def_rename_smoke()
}
