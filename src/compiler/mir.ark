// Arukellt Selfhost — MIR (Mid-level IR) + HIR→MIR Lowering
//
// Flattens the typed HIR tree into a flat list of basic blocks
// with explicit control flow, preparing for Wasm emission.

use std::host::stdio
use std::host::process

// ── MIR Instruction Tags ─────────────────────────────────────────────────────

fn MIR_CONST_I32() -> i32 { 1 }
fn MIR_CONST_I64() -> i32 { 2 }
fn MIR_CONST_F64() -> i32 { 3 }
fn MIR_CONST_BOOL() -> i32 { 4 }
fn MIR_CONST_STRING() -> i32 { 5 }
fn MIR_LOCAL_GET() -> i32 { 10 }
fn MIR_LOCAL_SET() -> i32 { 11 }
fn MIR_GLOBAL_GET() -> i32 { 12 }
fn MIR_GLOBAL_SET() -> i32 { 13 }
fn MIR_ADD() -> i32 { 20 }
fn MIR_SUB() -> i32 { 21 }
fn MIR_MUL() -> i32 { 22 }
fn MIR_DIV() -> i32 { 23 }
fn MIR_MOD() -> i32 { 24 }
fn MIR_EQ() -> i32 { 25 }
fn MIR_NEQ() -> i32 { 26 }
fn MIR_LT() -> i32 { 27 }
fn MIR_LTEQ() -> i32 { 28 }
fn MIR_GT() -> i32 { 29 }
fn MIR_GTEQ() -> i32 { 30 }
fn MIR_AND() -> i32 { 31 }
fn MIR_OR() -> i32 { 32 }
fn MIR_NEG() -> i32 { 33 }
fn MIR_NOT() -> i32 { 34 }
fn MIR_BIT_AND() -> i32 { 35 }
fn MIR_BIT_OR() -> i32 { 36 }
fn MIR_BIT_XOR() -> i32 { 37 }
fn MIR_SHL() -> i32 { 38 }
fn MIR_SHR() -> i32 { 39 }
fn MIR_CALL() -> i32 { 40 }
fn MIR_CALL_INDIRECT() -> i32 { 41 }
fn MIR_RETURN() -> i32 { 42 }
fn MIR_BR() -> i32 { 50 }
fn MIR_BR_IF() -> i32 { 51 }
fn MIR_BR_TABLE() -> i32 { 52 }
fn MIR_BLOCK() -> i32 { 53 }
fn MIR_LOOP() -> i32 { 54 }
fn MIR_IF() -> i32 { 55 }
fn MIR_ELSE() -> i32 { 56 }
fn MIR_END() -> i32 { 57 }
fn MIR_EQZ() -> i32 { 58 }
fn MIR_STRUCT_NEW() -> i32 { 60 }
fn MIR_STRUCT_GET() -> i32 { 61 }
fn MIR_STRUCT_SET() -> i32 { 62 }
fn MIR_ARRAY_NEW() -> i32 { 63 }
fn MIR_ARRAY_GET() -> i32 { 64 }
fn MIR_ARRAY_SET() -> i32 { 65 }
fn MIR_ARRAY_LEN() -> i32 { 66 }
fn MIR_DROP() -> i32 { 70 }
fn MIR_NOP() -> i32 { 71 }
fn MIR_UNREACHABLE() -> i32 { 72 }
fn MIR_PHI() -> i32 { 73 }

// ── MIR Value Type Tags ─────────────────────────────────────────────────────

fn VT_I32() -> i32 { 1 }
fn VT_I64() -> i32 { 2 }
fn VT_F64() -> i32 { 3 }
fn VT_REF() -> i32 { 4 }
fn VT_VOID() -> i32 { 0 }

// ── MIR Instruction ──────────────────────────────────────────────────────────

struct MirInst {
    op: i32,
    dest: i32,
    arg0: i32,
    arg1: i32,
    int_val: i32,
    float_val: f64,
    str_val: String,
    val_type: i32,
}

fn MirInst_new(op: i32) -> MirInst {
    MirInst {
        op: op, dest: 0 - 1, arg0: 0 - 1, arg1: 0 - 1,
        int_val: 0, float_val: 0.0, str_val: String_new(),
        val_type: VT_VOID(),
    }
}

struct MirPhiArg {
    pred_block: i32,
    local: i32,
}

fn MirPhiArg_new(pred_block: i32, local: i32) -> MirPhiArg {
    MirPhiArg { pred_block: pred_block, local: local }
}

struct MirPhi {
    op: i32,
    dest: i32,
    val_type: i32,
    args: Vec<MirPhiArg>,
}

fn MirPhi_new(dest: i32, val_type: i32) -> MirPhi {
    MirPhi {
        op: MIR_PHI(),
        dest: dest,
        val_type: val_type,
        args: Vec_new_MirPhiArg(),
    }
}

fn mir_phi_add_arg(phi: MirPhi, pred_block: i32, local: i32) {
    push(phi.args, MirPhiArg_new(pred_block, local))
}

fn MirInst_const_i32(val: i32, dest: i32) -> MirInst {
    MirInst {
        op: MIR_CONST_I32(), dest: dest, arg0: 0 - 1, arg1: 0 - 1,
        int_val: val, float_val: 0.0, str_val: String_new(),
        val_type: VT_I32(),
    }
}

fn MirInst_const_string(val: String, dest: i32) -> MirInst {
    MirInst {
        op: MIR_CONST_STRING(), dest: dest, arg0: 0 - 1, arg1: 0 - 1,
        int_val: 0, float_val: 0.0, str_val: val,
        val_type: VT_REF(),
    }
}

fn MirInst_const_f64(val: f64, dest: i32) -> MirInst {
    MirInst {
        op: MIR_CONST_F64(), dest: dest, arg0: 0 - 1, arg1: 0 - 1,
        int_val: 0, float_val: val, str_val: String_new(),
        val_type: VT_F64(),
    }
}

fn MirInst_binop(op: i32, dest: i32, a: i32, b: i32) -> MirInst {
    MirInst {
        op: op, dest: dest, arg0: a, arg1: b,
        int_val: 0, float_val: 0.0, str_val: String_new(),
        val_type: VT_I32(),
    }
}

// ── MIR Basic Block ──────────────────────────────────────────────────────────

struct MirBlock {
    id: i32,
    phis: Vec<MirPhi>,
    instructions: Vec<MirInst>,
    terminator: i32,
    succ0: i32,
    succ1: i32,
    preds: Vec<i32>,
    idom: i32,
    dom_set: Vec<i32>,
    dom_frontier: Vec<i32>,
}

fn MirBlock_new(id: i32) -> MirBlock {
    MirBlock {
        id: id,
        phis: Vec_new_MirPhi(),
        instructions: Vec_new_MirInst(),
        terminator: MIR_RETURN(),
        succ0: 0 - 1,
        succ1: 0 - 1,
        preds: Vec_new_i32(),
        idom: 0 - 1,
        dom_set: Vec_new_i32(),
        dom_frontier: Vec_new_i32(),
    }
}

struct MirDomInfo {
    idom: Vec<i32>,
    frontier_offsets: Vec<i32>,
    frontier_lengths: Vec<i32>,
    frontier_blocks: Vec<i32>,
}

fn MirDomInfo_new() -> MirDomInfo {
    MirDomInfo {
        idom: Vec_new_i32(),
        frontier_offsets: Vec_new_i32(),
        frontier_lengths: Vec_new_i32(),
        frontier_blocks: Vec_new_i32(),
    }
}

fn mir_push_unique_i32(ids: Vec<i32>, block_id: i32) {
    let pred_count = len(ids)
    let mut i = 0
    while i < pred_count {
        if get_unchecked(ids, i) == block_id {
            return
        }
        i = i + 1
    }
    push(ids, block_id)
}

fn mir_add_block_pred(block: MirBlock, pred_id: i32) {
    mir_push_unique_i32(block.preds, pred_id)
}

fn mir_copy_block_ids(ids: Vec<i32>) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(ids)
    let mut i = 0
    while i < count {
        push(out, get_unchecked(ids, i))
        i = i + 1
    }
    out
}

fn mir_collect_all_block_ids(f: MirFunction) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(f.blocks)
    let mut i = 0
    while i < count {
        push(out, i)
        i = i + 1
    }
    out
}

fn mir_block_ids_contains(ids: Vec<i32>, block_id: i32) -> bool {
    let count = len(ids)
    let mut i = 0
    while i < count {
        if get_unchecked(ids, i) == block_id {
            return true
        }
        i = i + 1
    }
    false
}

fn mir_same_block_id_set(a: Vec<i32>, b: Vec<i32>) -> bool {
    let count = len(a)
    if count != len(b) {
        return false
    }
    let mut i = 0
    while i < count {
        if get_unchecked(a, i) != get_unchecked(b, i) {
            return false
        }
        i = i + 1
    }
    true
}

fn mir_intersect_block_id_sets(a: Vec<i32>, b: Vec<i32>) -> Vec<i32> {
    let out = Vec_new_i32()
    let count = len(a)
    let mut i = 0
    while i < count {
        let block_id = get_unchecked(a, i)
        if mir_block_ids_contains(b, block_id) {
            push(out, block_id)
        }
        i = i + 1
    }
    out
}

fn mir_add_pred_edge(f: MirFunction, pred_id: i32, succ_id: i32) {
    if succ_id < 0 {
        return
    }
    let block_count = len(f.blocks)
    if succ_id >= block_count {
        return
    }
    let succ = get_unchecked(f.blocks, succ_id)
    mir_add_block_pred(succ, pred_id)
}

fn mir_compute_predecessors_for_function(f: MirFunction) {
    let block_count = len(f.blocks)
    let mut i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.preds = Vec_new_i32()
        i = i + 1
    }

    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        let pred_id = block.id
        mir_add_pred_edge(f, pred_id, block.succ0)
        if block.succ1 != block.succ0 {
            mir_add_pred_edge(f, pred_id, block.succ1)
        }
        i = i + 1
    }
}

fn mir_compute_predecessors(m: MirModule) {
    let fn_count = len(m.functions)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        mir_compute_predecessors_for_function(f)
        i = i + 1
    }
}

fn mir_compute_dominance_for_function(f: MirFunction) {
    mir_compute_predecessors_for_function(f)

    let block_count = len(f.blocks)
    if block_count == 0 {
        return
    }

    let all_block_ids = mir_collect_all_block_ids(f)
    let mut i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.idom = 0 - 1
        block.dom_frontier = Vec_new_i32()
        if i == 0 {
            block.dom_set = Vec_new_i32()
            push(block.dom_set, block.id)
        } else {
            block.dom_set = mir_copy_block_ids(all_block_ids)
        }
        i = i + 1
    }

    let mut changed = true
    while changed {
        changed = false
        let mut b = 1
        while b < block_count {
            let block = get_unchecked(f.blocks, b)
            let pred_count = len(block.preds)
            let mut new_set = Vec_new_i32()

            if pred_count == 0 {
                push(new_set, block.id)
            } else {
                let first_pred = get_unchecked(block.preds, 0)
                let first_pred_block = get_unchecked(f.blocks, first_pred)
                new_set = mir_copy_block_ids(first_pred_block.dom_set)

                let mut pred_idx = 1
                while pred_idx < pred_count {
                    let pred_id = get_unchecked(block.preds, pred_idx)
                    let pred_block = get_unchecked(f.blocks, pred_id)
                    new_set = mir_intersect_block_id_sets(new_set, pred_block.dom_set)
                    pred_idx = pred_idx + 1
                }
            }

            mir_push_unique_i32(new_set, block.id)
            if !mir_same_block_id_set(block.dom_set, new_set) {
                block.dom_set = new_set
                changed = true
            }

            b = b + 1
        }
    }

    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.idom = 0 - 1
        if i != 0 {
            let strict_count = len(block.dom_set)
            let mut dom_idx = 0
            while dom_idx < strict_count {
                let candidate = get_unchecked(block.dom_set, dom_idx)
                if candidate != block.id {
                    let candidate_block = get_unchecked(f.blocks, candidate)
                    let mut is_idom = true
                    let mut other_idx = 0
                    while other_idx < strict_count {
                        let other = get_unchecked(block.dom_set, other_idx)
                        if other != block.id && other != candidate {
                            if !mir_block_ids_contains(candidate_block.dom_set, other) {
                                is_idom = false
                            }
                        }
                        other_idx = other_idx + 1
                    }
                    if is_idom {
                        block.idom = candidate
                    }
                }
                dom_idx = dom_idx + 1
            }
        }
        i = i + 1
    }

    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        block.dom_frontier = Vec_new_i32()
        i = i + 1
    }

    i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        let pred_count = len(block.preds)
        if pred_count >= 2 {
            let mut pred_idx = 0
            while pred_idx < pred_count {
                let mut runner = get_unchecked(block.preds, pred_idx)
                while runner >= 0 && runner != block.idom {
                    let runner_block = get_unchecked(f.blocks, runner)
                    mir_push_unique_i32(runner_block.dom_frontier, block.id)
                    runner = runner_block.idom
                }
                pred_idx = pred_idx + 1
            }
        }
        i = i + 1
    }
}

fn mir_collect_dom_info_for_function(f: MirFunction) -> MirDomInfo {
    let info = MirDomInfo_new()
    let block_count = len(f.blocks)
    let mut i = 0
    while i < block_count {
        let block = get_unchecked(f.blocks, i)
        push(info.idom, block.idom)
        push(info.frontier_offsets, len(info.frontier_blocks))
        push(info.frontier_lengths, len(block.dom_frontier))

        let frontier_count = len(block.dom_frontier)
        let mut j = 0
        while j < frontier_count {
            push(info.frontier_blocks, get_unchecked(block.dom_frontier, j))
            j = j + 1
        }
        i = i + 1
    }
    info
}

fn mir_compute_dominance(m: MirModule) {
    let fn_count = len(m.functions)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        mir_compute_dominance_for_function(f)
        i = i + 1
    }
}

// ── MIR Function ─────────────────────────────────────────────────────────────

struct MirLocal {
    name: String,
    val_type: i32,
    ssa_name: String,
    ssa_version: i32,
}

struct MirFunction {
    name: String,
    params: Vec<MirLocal>,
    locals: Vec<MirLocal>,
    blocks: Vec<MirBlock>,
    return_type: i32,
    next_local: i32,
    next_block: i32,
}

fn MirFunction_new(name: String) -> MirFunction {
    MirFunction {
        name: name,
        params: Vec_new_MirLocal(),
        locals: Vec_new_MirLocal(),
        blocks: Vec_new_MirBlock(),
        return_type: VT_VOID(),
        next_local: 0,
        next_block: 0,
    }
}

fn alloc_local(f: MirFunction, name: String, vt: i32) -> i32 {
    let idx = f.next_local
    f.next_local = f.next_local + 1
    push(f.locals, MirLocal { name: clone(name), val_type: vt, ssa_name: name, ssa_version: 0 - 1 })
    idx
}

fn alloc_block(f: MirFunction) -> i32 {
    let idx = f.next_block
    f.next_block = f.next_block + 1
    push(f.blocks, MirBlock_new(idx))
    idx
}

fn emit_inst(f: MirFunction, block_id: i32, inst: MirInst) {
    let block = get_unchecked(f.blocks, block_id)
    push(block.instructions, inst)
}

fn emit_phi(f: MirFunction, block_id: i32, phi: MirPhi) {
    let block = get_unchecked(f.blocks, block_id)
    push(block.phis, phi)
}

fn mir_local_vt_for_function(f: MirFunction, local_id: i32) -> i32 {
    if local_id >= 0 && local_id < len(f.locals) {
        let local = get_unchecked(f.locals, local_id)
        return local.val_type
    }
    VT_VOID()
}

fn mir_assign_local_ssa(f: MirFunction, local_id: i32, ssa_name: String, ssa_version: i32) {
    if local_id < 0 || local_id >= len(f.locals) {
        return
    }
    let local = get_unchecked(f.locals, local_id)
    local.ssa_name = ssa_name
    local.ssa_version = ssa_version
}

fn mir_assign_simple_join_phi_ssa(f: MirFunction, dest_local: i32, pred0_local: i32, pred1_local: i32) {
    if dest_local < 0 || dest_local >= len(f.locals) {
        return
    }
    let dest = get_unchecked(f.locals, dest_local)
    let ssa_name = clone(dest.name)
    mir_assign_local_ssa(f, pred0_local, clone(ssa_name), 1)
    mir_assign_local_ssa(f, pred1_local, clone(ssa_name), 2)
    mir_assign_local_ssa(f, dest_local, ssa_name, 3)
}

fn mir_find_last_value_local(block: MirBlock) -> i32 {
    let count = len(block.instructions)
    let mut i = count - 1
    while i >= 0 {
        let inst = get_unchecked(block.instructions, i)
        if inst.dest >= 0 && inst.val_type != VT_VOID() {
            return inst.dest
        }
        i = i - 1
    }
    0 - 1
}

fn mir_try_insert_simple_join_phi(f: MirFunction, join_block_id: i32, dest_local: i32) -> bool {
    if join_block_id < 0 || join_block_id >= len(f.blocks) {
        return false
    }

    let join_block = get_unchecked(f.blocks, join_block_id)
    if len(join_block.phis) > 0 {
        return false
    }
    if len(join_block.preds) != 2 {
        return false
    }

    let pred0_id = get_unchecked(join_block.preds, 0)
    let pred1_id = get_unchecked(join_block.preds, 1)
    let pred0 = get_unchecked(f.blocks, pred0_id)
    let pred1 = get_unchecked(f.blocks, pred1_id)

    if !mir_block_ids_contains(pred0.dom_frontier, join_block_id) {
        return false
    }
    if !mir_block_ids_contains(pred1.dom_frontier, join_block_id) {
        return false
    }

    let pred0_local = mir_find_last_value_local(pred0)
    let pred1_local = mir_find_last_value_local(pred1)
    if pred0_local < 0 || pred1_local < 0 {
        return false
    }

    let dest_vt = mir_local_vt_for_function(f, dest_local)
    if dest_vt == VT_VOID() {
        return false
    }
    if mir_local_vt_for_function(f, pred0_local) != dest_vt {
        return false
    }
    if mir_local_vt_for_function(f, pred1_local) != dest_vt {
        return false
    }

    mir_assign_simple_join_phi_ssa(f, dest_local, pred0_local, pred1_local)

    let phi = MirPhi_new(dest_local, dest_vt)
    mir_phi_add_arg(phi, pred0_id, pred0_local)
    mir_phi_add_arg(phi, pred1_id, pred1_local)
    emit_phi(f, join_block_id, phi)
    true
}

// ── SSA renaming (minimal, after φ placement) ──────────────────────────────
//
// Assigns `ssa_name` / `ssa_version` on `MirLocal` so dumps and downstream
// passes can treat defs as SSA slots. φ operands share the dest's base name
// with versions 1..N; the φ result is version N+1. Parameters are v0. Remaining
// value-producing defs (no φ involvement) get v1.

fn mir_is_pure_ssa_def(inst: MirInst) -> bool {
    let op = inst.op
    if op == MIR_LOCAL_GET() || op == MIR_LOCAL_SET() {
        return false
    }
    if inst.dest < 0 {
        return false
    }
    if inst.val_type == VT_VOID() {
        return false
    }
    if op == MIR_RETURN() {
        return false
    }
    if op == MIR_BR() || op == MIR_BR_IF() || op == MIR_BR_TABLE() {
        return false
    }
    if op == MIR_IF() || op == MIR_ELSE() || op == MIR_END() || op == MIR_BLOCK() || op == MIR_LOOP() {
        return false
    }
    if op == MIR_DROP() || op == MIR_NOP() || op == MIR_UNREACHABLE() {
        return false
    }
    true
}

fn mir_ssa_rename_phis(f: MirFunction) {
    let bc = len(f.blocks)
    let mut bi = 0
    while bi < bc {
        let block = get_unchecked(f.blocks, bi)
        let pc = len(block.phis)
        let mut pi = 0
        while pi < pc {
            let phi = get_unchecked(block.phis, pi)
            let dest = phi.dest
            if dest < 0 || dest >= len(f.locals) {
                pi = pi + 1
                continue
            }
            let dest_local = get_unchecked(f.locals, dest)
            let base = clone(dest_local.name)
            let ac = len(phi.args)
            let mut ai = 0
            while ai < ac {
                let a = get_unchecked(phi.args, ai)
                mir_assign_local_ssa(f, a.local, clone(base), ai + 1)
                ai = ai + 1
            }
            mir_assign_local_ssa(f, dest, base, ac + 1)
            pi = pi + 1
        }
        bi = bi + 1
    }
}

fn mir_ssa_tag_function_params(f: MirFunction) {
    let pc = len(f.params)
    let mut pi = 0
    while pi < pc {
        let p = get_unchecked(f.params, pi)
        mir_assign_local_ssa(f, pi, clone(p.name), 0)
        pi = pi + 1
    }
}

fn mir_ssa_tag_linear_defs(f: MirFunction) {
    let bc = len(f.blocks)
    let mut bi = 0
    while bi < bc {
        let block = get_unchecked(f.blocks, bi)
        let ic = len(block.instructions)
        let mut ii = 0
        while ii < ic {
            let inst = get_unchecked(block.instructions, ii)
            if mir_is_pure_ssa_def(inst) {
                let d = inst.dest
                if d >= 0 && d < len(f.locals) {
                    let loc = get_unchecked(f.locals, d)
                    if loc.ssa_version < 0 {
                        mir_assign_local_ssa(f, d, clone(loc.name), 1)
                    }
                }
            }
            ii = ii + 1
        }
        bi = bi + 1
    }
}

fn mir_ssa_rename_function(f: MirFunction) {
    mir_ssa_rename_phis(f)
    mir_ssa_tag_function_params(f)
    mir_ssa_tag_linear_defs(f)
}

fn mir_ssa_rename_module(m: MirModule) {
    let fn_count = len(m.functions)
    let mut i = 0
    while i < fn_count {
        mir_ssa_rename_function(get_unchecked(m.functions, i))
        i = i + 1
    }
}

// ── MIR Module ───────────────────────────────────────────────────────────────

struct MirModule {
    functions: Vec<MirFunction>,
    string_constants: Vec<String>,
}

fn MirModule_new() -> MirModule {
    MirModule {
        functions: Vec_new_MirFunction(),
        string_constants: Vec_new_String(),
    }
}

fn intern_string(m: MirModule, s: String) -> i32 {
    let count = len(m.string_constants)
    let mut i = 0
    while i < count {
        let existing = get_unchecked(m.string_constants, i)
        if eq(clone(existing), clone(s)) {
            return i
        }
        i = i + 1
    }
    push(m.string_constants, s)
    count
}

// ── HIR→MIR Lowering ────────────────────────────────────────────────────────

struct MonoInstance {
    fn_name: String,
    mangled_name: String,
}

struct TypeCheckResult {
    error_count: i32,
    errors: Vec<String>,
    typed_fns: Vec<TypedFn>,
    mono_instances: Vec<MonoInstance>,
}

struct TypedFn {
    name: String,
    return_type: TypeInfo,
}

struct TypeInfo {
    tag: i32,
    name: String,
    type_args: Vec<TypeInfo>,
}

// AST node kinds (duplicated from parser — each file is compiled independently)
fn NK_INT_LIT() -> i32 { 1 }
fn NK_FLOAT_LIT() -> i32 { 2 }
fn NK_STRING_LIT() -> i32 { 3 }
fn NK_BOOL_LIT() -> i32 { 4 }
fn NK_CHAR_LIT() -> i32 { 23 }
fn NK_IDENT() -> i32 { 5 }
fn NK_BINARY() -> i32 { 6 }
fn NK_UNARY() -> i32 { 7 }
fn NK_CALL() -> i32 { 8 }
fn NK_FIELD_ACCESS() -> i32 { 9 }
fn NK_INDEX() -> i32 { 10 }
fn NK_STRUCT_LIT() -> i32 { 11 }
fn NK_ARRAY_LIT() -> i32 { 12 }
fn NK_IF_EXPR() -> i32 { 13 }
fn NK_CLOSURE() -> i32 { 15 }   // closure / lambda — lowered via lambda lifting (#499)
fn NK_BLOCK() -> i32 { 20 }
fn NK_ASSIGN() -> i32 { 18 }
fn NK_LET() -> i32 { 30 }
fn NK_RETURN() -> i32 { 31 }
fn NK_WHILE() -> i32 { 34 }
fn NK_LOOP() -> i32 { 35 }
fn NK_FOR() -> i32 { 36 }
fn NK_EXPR_STMT() -> i32 { 37 }
fn NK_BREAK() -> i32 { 32 }
fn NK_CONTINUE() -> i32 { 33 }
fn NK_FN_DECL() -> i32 { 50 }
fn NK_MATCH_EXPR() -> i32 { 14 }
fn NK_MATCH_ARM() -> i32 { 26 }
fn NK_PAT_LITERAL() -> i32 { 72 }
fn NK_PAT_WILDCARD() -> i32 { 71 }
fn NK_PAT_IDENT() -> i32 { 70 }
fn NK_PAT_VARIANT() -> i32 { 73 }
fn NK_PATH() -> i32 { 16 }
fn NK_RANGE() -> i32 { 19 }
fn NK_TRY() -> i32 { 25 }

// Binary operator tags
fn OP_ADD() -> i32 { 1 }
fn OP_SUB() -> i32 { 2 }
fn OP_MUL() -> i32 { 3 }
fn OP_DIV() -> i32 { 4 }
fn OP_MOD() -> i32 { 5 }
fn OP_EQ() -> i32 { 6 }
fn OP_NEQ() -> i32 { 7 }
fn OP_LT() -> i32 { 8 }
fn OP_LTEQ() -> i32 { 9 }
fn OP_GT() -> i32 { 10 }
fn OP_GTEQ() -> i32 { 11 }
fn OP_AND() -> i32 { 12 }
fn OP_OR() -> i32 { 13 }
fn OP_BIT_AND() -> i32 { 14 }
fn OP_BIT_OR() -> i32 { 15 }
fn OP_BIT_XOR() -> i32 { 16 }
fn OP_SHL() -> i32 { 17 }
fn OP_SHR() -> i32 { 18 }

// Unary operator tags
fn UOP_NEG() -> i32 { 1 }
fn UOP_NOT() -> i32 { 2 }

// Type tags
fn TY_I32() -> i32 { 1 }
fn TY_I64() -> i32 { 2 }
fn TY_F64() -> i32 { 3 }
fn TY_BOOL() -> i32 { 4 }
fn TY_STRING() -> i32 { 5 }
fn TY_UNIT() -> i32 { 7 }

// Lowering context: tracks the current function, block, local name→index map
struct LowerCtx {
    module: MirModule,
    func: MirFunction,
    cur_block: i32,
    local_names: Vec<String>,
    local_indices: Vec<i32>,
    fn_names: Vec<String>,
    fn_indices: Vec<i32>,
    // Return value type for each function (parallel to fn_names): VT_VOID=0, VT_I32=1, VT_F64=3
    fn_return_vts: Vec<i32>,
    loop_exit_block: i32,
    loop_cond_block: i32,
    nesting_depth: i32,
    loop_break_depth: i32,
    loop_continue_depth: i32,
    loop_break_local: i32,
    // Struct definitions: parallel arrays
    struct_names: Vec<String>,
    struct_field_counts: Vec<i32>,
    struct_all_fields: Vec<String>,
    struct_field_types: Vec<String>,
    // Local variable struct type tracking (parallel arrays)
    local_types: Vec<String>,
    local_type_indices: Vec<i32>,
    // Enum variant→tag mapping (parallel arrays)
    variant_names: Vec<String>,
    variant_tags: Vec<i32>,
    // Variant names that belong to payload enums (for heap allocation)
    payload_variants: Vec<String>,
    // Lambda-lifted closures (issue #499): synthetic fns + call-site capture injection
    closure_counter: i32,
    closure_last_synth: String,
    closure_last_caps: String,
    closure_last_extra: i32,
    closure_bind_names: Vec<String>,
    closure_bind_synth: Vec<String>,
    closure_bind_caps: Vec<String>,
    closure_bind_extra: Vec<i32>,
}

fn LowerCtx_new(m: MirModule) -> LowerCtx {
    LowerCtx {
        module: m,
        func: MirFunction_new(String_from("")),
        cur_block: 0,
        local_names: Vec_new_String(),
        local_indices: Vec_new_i32(),
        fn_names: Vec_new_String(),
        fn_indices: Vec_new_i32(),
        fn_return_vts: Vec_new_i32(),
        loop_exit_block: 0 - 1,
        loop_cond_block: 0 - 1,
        nesting_depth: 0,
        loop_break_depth: 0 - 1,
        loop_continue_depth: 0 - 1,
        loop_break_local: 0 - 1,
        struct_names: Vec_new_String(),
        struct_field_counts: Vec_new_i32(),
        struct_all_fields: Vec_new_String(),
        struct_field_types: Vec_new_String(),
        local_types: Vec_new_String(),
        local_type_indices: Vec_new_i32(),
        variant_names: Vec_new_String(),
        variant_tags: Vec_new_i32(),
        payload_variants: Vec_new_String(),
        closure_counter: 0,
        closure_last_synth: String_new(),
        closure_last_caps: String_new(),
        closure_last_extra: 0,
        closure_bind_names: Vec_new_String(),
        closure_bind_synth: Vec_new_String(),
        closure_bind_caps: Vec_new_String(),
        closure_bind_extra: Vec_new_i32(),
    }
}

// Look up return VT for a named function (VT_VOID=0 if not found or void, VT_I32=1, VT_F64=3)
fn ctx_fn_return_vt(ctx: LowerCtx, name: String) -> i32 {
    let fc = len(ctx.fn_names)
    let mut i = 0
    while i < fc {
        if eq(clone(get_unchecked(ctx.fn_names, i)), clone(name)) {
            return get_unchecked(ctx.fn_return_vts, i)
        }
        i = i + 1
    }
    // Known void stdlib/built-in functions
    let is_void_builtin =
        eq(clone(name), "stdio::println") || eq(clone(name), "println") ||
        eq(clone(name), "stdio::print")   || eq(clone(name), "print")   ||
        eq(clone(name), "stdio::eprintln") || eq(clone(name), "eprintln") ||
        eq(clone(name), "stdio::eprint")  || eq(clone(name), "eprint")  ||
        eq(clone(name), "process::exit")  || eq(clone(name), "host::process::exit") ||
        eq(clone(name), "push_char")      || eq(clone(name), "push")    ||
        eq(clone(name), "push_byte")
    if is_void_builtin {
        return VT_VOID()
    }
    // Unknown function: assume non-void (safe default for stdlib/builtins)
    VT_I32()
}

// Look up field index within a struct definition
fn ctx_field_index(ctx: LowerCtx, struct_name: String, field_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut fi = 0
            while fi < fc {
                let fn_name = get_unchecked(ctx.struct_all_fields, offset + fi)
                if eq(clone(fn_name), clone(field_name)) {
                    return fi
                }
                fi = fi + 1
            }
            return 0
        }
        offset = offset + fc
        si = si + 1
    }
    0
}

// Find field index by name searching ALL struct definitions
fn ctx_field_index_any(ctx: LowerCtx, field_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let fc = get_unchecked(ctx.struct_field_counts, si)
        let mut fi = 0
        while fi < fc {
            let fn_name = get_unchecked(ctx.struct_all_fields, offset + fi)
            if eq(clone(fn_name), clone(field_name)) {
                return fi
            }
            fi = fi + 1
        }
        offset = offset + fc
        si = si + 1
    }
    0
}

// Get field count for a struct by name
fn ctx_struct_field_count(ctx: LowerCtx, struct_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        if eq(clone(sn), clone(struct_name)) {
            return get_unchecked(ctx.struct_field_counts, si)
        }
        si = si + 1
    }
    0
}

// Get field name at index for a struct by name
fn ctx_struct_field_name(ctx: LowerCtx, struct_name: String, field_idx: i32) -> String {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            return clone(get_unchecked(ctx.struct_all_fields, offset + field_idx))
        }
        offset = offset + fc
        si = si + 1
    }
    String_from("")
}

// Get the type of a field (e.g., "vec:i32", "Inner", or "")
fn ctx_get_field_type(ctx: LowerCtx, struct_name: String, field_name: String) -> String {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut fi = 0
            while fi < fc {
                let fn_name = get_unchecked(ctx.struct_all_fields, offset + fi)
                if eq(clone(fn_name), clone(field_name)) {
                    return clone(get_unchecked(ctx.struct_field_types, offset + fi))
                }
                fi = fi + 1
            }
            return String_from("")
        }
        offset = offset + fc
        si = si + 1
    }
    String_from("")
}

// Compute byte offset for a field, accounting for f64 fields (8 bytes) vs i32 fields (4 bytes)
fn ctx_struct_field_offset(ctx: LowerCtx, struct_name: String, target_field_idx: i32) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut byte_off = 0
            let mut fi = 0
            while fi < target_field_idx && fi < fc {
                let ft = get_unchecked(ctx.struct_field_types, offset + fi)
                if eq(clone(ft), "f64") {
                    byte_off = byte_off + 8
                } else {
                    byte_off = byte_off + 4
                }
                fi = fi + 1
            }
            return byte_off
        }
        offset = offset + fc
        si = si + 1
    }
    target_field_idx * 4
}

// Compute total byte size of a struct
fn ctx_struct_byte_size(ctx: LowerCtx, struct_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut byte_off = 0
            let mut fi = 0
            while fi < fc {
                let ft = get_unchecked(ctx.struct_field_types, offset + fi)
                if eq(clone(ft), "f64") {
                    byte_off = byte_off + 8
                } else {
                    byte_off = byte_off + 4
                }
                fi = fi + 1
            }
            return byte_off
        }
        offset = offset + fc
        si = si + 1
    }
    0
}

// Check if a struct field at given index is f64
fn ctx_struct_field_is_f64(ctx: LowerCtx, struct_name: String, field_idx: i32) -> bool {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            if field_idx < fc {
                let ft = get_unchecked(ctx.struct_field_types, offset + field_idx)
                return eq(clone(ft), "f64")
            }
            return false
        }
        offset = offset + fc
        si = si + 1
    }
    false
}

// Track struct type for a local variable
fn ctx_set_local_type(ctx: LowerCtx, local_idx: i32, type_name: String) {
    push(ctx.local_types, clone(type_name))
    push(ctx.local_type_indices, local_idx)
}

fn ctx_get_local_type(ctx: LowerCtx, local_idx: i32) -> String {
    let count = len(ctx.local_type_indices)
    // Search backwards (latest assignment wins)
    let mut i = count - 1
    while i >= 0 {
        let idx = get_unchecked(ctx.local_type_indices, i)
        if idx == local_idx {
            return clone(get_unchecked(ctx.local_types, i))
        }
        i = i - 1
    }
    String_new()
}

fn ctx_variant_tag(ctx: LowerCtx, name: String) -> i32 {
    let count = len(ctx.variant_names)
    let mut i = 0
    while i < count {
        let vn = get_unchecked(ctx.variant_names, i)
        if eq(clone(vn), clone(name)) {
            return get_unchecked(ctx.variant_tags, i)
        }
        i = i + 1
    }
    0 - 1
}

fn ctx_is_payload_variant(ctx: LowerCtx, name: String) -> bool {
    let count = len(ctx.payload_variants)
    let mut i = 0
    while i < count {
        if eq(clone(get_unchecked(ctx.payload_variants, i)), clone(name)) {
            return true
        }
        i = i + 1
    }
    false
}

fn ctx_register_builtin_variants(ctx: LowerCtx) {
    // Option variants
    push(ctx.variant_names, String_from("Some"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("None"))
    push(ctx.variant_tags, 1)
    push(ctx.variant_names, String_from("Option::Some"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("Option::None"))
    push(ctx.variant_tags, 1)
    // Result variants
    push(ctx.variant_names, String_from("Ok"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("Err"))
    push(ctx.variant_tags, 1)
    push(ctx.variant_names, String_from("Result::Ok"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("Result::Err"))
    push(ctx.variant_tags, 1)
    // All Option/Result variants are payload enum variants
    push(ctx.payload_variants, String_from("Some"))
    push(ctx.payload_variants, String_from("None"))
    push(ctx.payload_variants, String_from("Ok"))
    push(ctx.payload_variants, String_from("Err"))
    push(ctx.payload_variants, String_from("Option::Some"))
    push(ctx.payload_variants, String_from("Option::None"))
    push(ctx.payload_variants, String_from("Result::Ok"))
    push(ctx.payload_variants, String_from("Result::Err"))
}

fn ctx_alloc_local(ctx: LowerCtx, name: String, vt: i32) -> i32 {
    let idx = alloc_local(ctx.func, clone(name), vt)
    push(ctx.local_names, name)
    push(ctx.local_indices, idx)
    idx
}

fn ctx_lookup_local(ctx: LowerCtx, name: String) -> i32 {
    let count = len(ctx.local_names)
    let mut i = count - 1
    while i >= 0 {
        let n = get_unchecked(ctx.local_names, i)
        if eq(clone(n), clone(name)) {
            return get_unchecked(ctx.local_indices, i)
        }
        i = i - 1
    }
    0 - 1
}

fn ctx_emit(ctx: LowerCtx, inst: MirInst) {
    emit_inst(ctx.func, ctx.cur_block, inst)
}

fn ctx_fresh_local(ctx: LowerCtx, vt: i32) -> i32 {
    let idx = ctx.func.next_local
    alloc_local(ctx.func, concat(String_from("_t"), to_string(idx)), vt)
    idx
}

fn closure_is_param_name(clos: AstNode, name: String) -> bool {
    let c = len(clos.children)
    if c <= 1 {
        return false
    }
    let mut i = 0
    while i < c - 1 {
        let p = get_unchecked(clos.children, i)
        if p.kind == NK_IDENT() && eq(clone(p.text), clone(name)) {
            return true
        }
        i = i + 1
    }
    false
}

fn closure_collect_free(ctx: LowerCtx, expr: AstNode, clos: AstNode, acc: Vec<String>) {
    if expr.kind == NK_CLOSURE() {
        return
    }
    if expr.kind == NK_IDENT() {
        if closure_is_param_name(clos, clone(expr.text)) {
            return
        }
        if ctx_lookup_local(ctx, clone(expr.text)) < 0 {
            return
        }
        let n = clone(expr.text)
        let mut j = len(acc) - 1
        let mut dup = false
        while j >= 0 && !dup {
            if eq(clone(get_unchecked(acc, j)), clone(n)) {
                dup = true
            }
            j = j - 1
        }
        if !dup {
            push(acc, n)
        }
        return
    }
    let cc = len(expr.children)
    let mut ci = 0
    while ci < cc {
        closure_collect_free(ctx, get_unchecked(expr.children, ci), clos, acc)
        ci = ci + 1
    }
}

fn closure_pack_caps(caps: Vec<String>) -> String {
    let mut s = String_new()
    let c = len(caps)
    let mut i = 0
    while i < c {
        if i > 0 {
            s = concat(s, String_from(","))
        }
        s = concat(s, clone(get_unchecked(caps, i)))
        i = i + 1
    }
    s
}

fn closure_emit_captured_args(ctx: LowerCtx, packed: String) {
    let mut start = 0
    let mut i = 0
    let L = len(packed)
    while i <= L {
        let at_end = i == L
        let mut is_comma = false
        if !at_end {
            if char_at(packed, i) == 44 {
                is_comma = true
            }
        }
        if at_end || is_comma {
            if i > start {
                let name = substring(packed, start, i)
                if len(name) > 0 {
                    let li = ctx_lookup_local(ctx, clone(name))
                    if li >= 0 {
                        let g = MirInst_new(MIR_LOCAL_GET())
                        g.arg0 = li
                        g.dest = li
                        ctx_emit(ctx, g)
                    }
                }
            }
            start = i + 1
        }
        i = i + 1
    }
}

fn closure_flush_pending_bind(ctx: LowerCtx, bind_name: String) {
    if len(ctx.closure_last_synth) == 0 {
        return
    }
    push(ctx.closure_bind_names, bind_name)
    push(ctx.closure_bind_synth, clone(ctx.closure_last_synth))
    push(ctx.closure_bind_caps, clone(ctx.closure_last_caps))
    push(ctx.closure_bind_extra, ctx.closure_last_extra)
    ctx.closure_last_synth = String_new()
    ctx.closure_last_caps = String_new()
    ctx.closure_last_extra = 0
}

fn ctx_closure_lookup(ctx: LowerCtx, name: String) -> i32 {
    let count = len(ctx.closure_bind_names)
    let mut i = count - 1
    while i >= 0 {
        if eq(clone(get_unchecked(ctx.closure_bind_names, i)), clone(name)) {
            return i
        }
        i = i - 1
    }
    0 - 1
}

fn mir_emit_closure_fn(ctx: LowerCtx, synth: String, clos: AstNode, caps: Vec<String>) -> MirFunction {
    let saved_func = ctx.func
    let saved_block = ctx.cur_block
    let saved_names = ctx.local_names
    let saved_indices = ctx.local_indices
    let saved_types = ctx.local_types
    let saved_tidx = ctx.local_type_indices

    let cap_n = len(caps)
    let cap_vts = Vec_new_i32()
    let mut cvi = 0
    while cvi < cap_n {
        let cname = clone(get_unchecked(caps, cvi))
        let cli = ctx_lookup_local(ctx, clone(cname))
        let mut pvt = VT_I32()
        if cli >= 0 {
            pvt = ctx_local_vt(ctx, cli)
        }
        push(cap_vts, pvt)
        cvi = cvi + 1
    }

    let mf = MirFunction_new(clone(synth))
    ctx.func = mf
    ctx.local_names = Vec_new_String()
    ctx.local_indices = Vec_new_i32()
    ctx.local_types = Vec_new_String()
    ctx.local_type_indices = Vec_new_i32()
    let entry = alloc_block(ctx.func)
    ctx.cur_block = entry

    let child_count = len(clos.children)
    let body = get_unchecked(clos.children, child_count - 1)

    let mut pi = 0
    while pi + 1 < child_count {
        let p = get_unchecked(clos.children, pi)
        if p.kind == NK_IDENT() {
            let pvt = VT_I32()
            let _idx = ctx_alloc_local(ctx, clone(p.text), pvt)
            push(ctx.func.params, MirLocal { name: clone(p.text), val_type: pvt, ssa_name: clone(p.text), ssa_version: 0 - 1 })
        }
        pi = pi + 1
    }

    let mut ci = 0
    while ci < cap_n {
        let cname = clone(get_unchecked(caps, ci))
        let pvt = get_unchecked(cap_vts, ci)
        let _idx2 = ctx_alloc_local(ctx, clone(cname), pvt)
        push(ctx.func.params, MirLocal { name: clone(cname), val_type: pvt, ssa_name: clone(cname), ssa_version: 0 - 1 })
        ci = ci + 1
    }

    ctx.func.return_type = VT_I32()

    let res = lower_expr(ctx, body)
    if res >= 0 {
        let ret_inst = MirInst_new(MIR_RETURN())
        ret_inst.arg0 = res
        ctx_emit(ctx, ret_inst)
    } else {
        ctx_emit(ctx, MirInst_new(MIR_RETURN()))
    }

    let out_fn = ctx.func
    ctx.func = saved_func
    ctx.cur_block = saved_block
    ctx.local_names = saved_names
    ctx.local_indices = saved_indices
    ctx.local_types = saved_types
    ctx.local_type_indices = saved_tidx
    out_fn
}

fn ctx_local_vt(ctx: LowerCtx, idx: i32) -> i32 {
    if idx >= 0 && idx < len(ctx.func.locals) {
        let loc = get_unchecked(ctx.func.locals, idx)
        return loc.val_type
    }
    VT_I32()
}

fn ctx_set_local_vt(ctx: LowerCtx, idx: i32, vt: i32) {
    if idx >= 0 && idx < len(ctx.func.locals) {
        let loc = get_unchecked(ctx.func.locals, idx)
        loc.val_type = vt
    }
}

fn binop_to_mir(op: i32) -> i32 {
    if op == OP_ADD() { return MIR_ADD() }
    if op == OP_SUB() { return MIR_SUB() }
    if op == OP_MUL() { return MIR_MUL() }
    if op == OP_DIV() { return MIR_DIV() }
    if op == OP_MOD() { return MIR_MOD() }
    if op == OP_EQ() { return MIR_EQ() }
    if op == OP_NEQ() { return MIR_NEQ() }
    if op == OP_LT() { return MIR_LT() }
    if op == OP_LTEQ() { return MIR_LTEQ() }
    if op == OP_GT() { return MIR_GT() }
    if op == OP_GTEQ() { return MIR_GTEQ() }
    if op == OP_AND() { return MIR_AND() }
    if op == OP_OR() { return MIR_OR() }
    if op == OP_BIT_AND() { return MIR_BIT_AND() }
    if op == OP_BIT_OR() { return MIR_BIT_OR() }
    if op == OP_BIT_XOR() { return MIR_BIT_XOR() }
    if op == OP_SHL() { return MIR_SHL() }
    if op == OP_SHR() { return MIR_SHR() }
    MIR_NOP()
}

// Lower an expression node, returns the local index holding the result.
// Returns -1 for void / statement-like expressions.
fn lower_expr(ctx: LowerCtx, node: AstNode) -> i32 {
    let kind = node.kind

    if kind == NK_INT_LIT() {
        let dest = ctx_fresh_local(ctx, VT_I32())
        ctx_emit(ctx, MirInst_const_i32(node.int_val, dest))
        return dest
    }

    if kind == NK_CHAR_LIT() {
        let dest = ctx_fresh_local(ctx, VT_I32())
        ctx_emit(ctx, MirInst_const_i32(node.int_val, dest))
        ctx_set_local_type(ctx, dest, String_from("char"))
        return dest
    }

    if kind == NK_FLOAT_LIT() {
        let dest = ctx_fresh_local(ctx, VT_F64())
        ctx_set_local_type(ctx, dest, String_from("f64"))
        ctx_emit(ctx, MirInst_const_f64(node.float_val, dest))
        return dest
    }

    if kind == NK_BOOL_LIT() {
        let dest = ctx_fresh_local(ctx, VT_I32())
        ctx_set_local_type(ctx, dest, String_from("bool"))
        let mut bval = 0
        if eq(clone(node.text), "true") {
            bval = 1
        }
        ctx_emit(ctx, MirInst_const_i32(bval, dest))
        return dest
    }

    // Pattern literal (used in match arms): same as int/string/bool literal
    if kind == NK_PAT_LITERAL() {
        let dest = ctx_fresh_local(ctx, VT_I32())
        ctx_emit(ctx, MirInst_const_i32(node.int_val, dest))
        return dest
    }

    // Pattern wildcard: no value needed (used as default arm)
    if kind == NK_PAT_WILDCARD() {
        return 0 - 1
    }

    // Pattern ident binding: treated as variable introduction (not needed for simple match)
    if kind == NK_PAT_IDENT() {
        return 0 - 1
    }

    // Pattern variant: look up the discriminant tag from enum definitions
    if kind == NK_PAT_VARIANT() {
        let tag = ctx_variant_tag(ctx, clone(node.text))
        if tag >= 0 {
            let dest = ctx_fresh_local(ctx, VT_I32())
            ctx_emit(ctx, MirInst_const_i32(tag, dest))
            return dest
        }
        return 0 - 1
    }

    // Path expression: enum variant constructor (e.g. Color::Green)
    if kind == NK_PATH() {
        let tag = ctx_variant_tag(ctx, clone(node.text))
        if tag >= 0 {
            if ctx_is_payload_variant(ctx, clone(node.text)) {
                // Payload enum: heap allocate [tag]
                let dest = ctx_fresh_local(ctx, VT_I32())
                let struct_inst = MirInst_new(MIR_STRUCT_NEW())
                struct_inst.dest = dest
                struct_inst.int_val = 4  // 1 field * 4 bytes (tag only)
                ctx_emit(ctx, struct_inst)
                let tag_tmp = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(tag, tag_tmp))
                let set_tag = MirInst_new(MIR_STRUCT_SET())
                set_tag.arg0 = dest
                set_tag.arg1 = tag_tmp
                set_tag.int_val = 0  // byte offset 0
                ctx_emit(ctx, set_tag)
                let get_r = MirInst_new(MIR_LOCAL_GET())
                get_r.arg0 = dest
                ctx_emit(ctx, get_r)
                return dest
            } else {
                // Simple enum: just push tag
                let dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(tag, dest))
                return dest
            }
        }
        // If not a variant, might be a qualified function call — handled by NK_CALL
        return 0 - 1
    }

    if kind == NK_STRING_LIT() {
        let str_idx = intern_string(ctx.module, clone(node.text))
        let dest = ctx_fresh_local(ctx, VT_REF())
        let str_inst = MirInst_const_string(clone(node.text), dest)
        str_inst.arg0 = str_idx  // store intern index for emitter
        ctx_emit(ctx, str_inst)
        return dest
    }

    if kind == NK_IDENT() {
        let idx = ctx_lookup_local(ctx, clone(node.text))
        if idx >= 0 {
            let inst = MirInst_new(MIR_LOCAL_GET())
            inst.arg0 = idx
            inst.dest = idx
            ctx_emit(ctx, inst)
            return idx
        }
        // Check if this is an enum variant name (e.g. None, Ok, Err)
        let ident_tag = ctx_variant_tag(ctx, clone(node.text))
        if ident_tag >= 0 {
            if ctx_is_payload_variant(ctx, clone(node.text)) {
                // Payload enum: heap allocate [tag] (fieldless variant of payload enum)
                let dest = ctx_fresh_local(ctx, VT_I32())
                let struct_inst = MirInst_new(MIR_STRUCT_NEW())
                struct_inst.dest = dest
                struct_inst.int_val = 4  // 1 tag * 4 bytes
                ctx_emit(ctx, struct_inst)
                // Store tag
                let tag_tmp = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(ident_tag, tag_tmp))
                let set_tag = MirInst_new(MIR_STRUCT_SET())
                set_tag.arg0 = dest
                set_tag.arg1 = tag_tmp
                set_tag.int_val = 0  // byte offset 0
                ctx_emit(ctx, set_tag)
                let get_r = MirInst_new(MIR_LOCAL_GET())
                get_r.arg0 = dest
                ctx_emit(ctx, get_r)
                return dest
            } else {
                // Simple enum: just push tag
                let dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(ident_tag, dest))
                return dest
            }
        }
        return 0 - 1
    }

    if kind == NK_BINARY() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let lhs = get_unchecked(node.children, 0)
            let rhs = get_unchecked(node.children, 1)
            let mir_op = binop_to_mir(node.op)

            // Short-circuit evaluation for && and ||
            if mir_op == MIR_AND() || mir_op == MIR_OR() {
                let l_idx = lower_expr(ctx, lhs)
                // Store lhs result in a temp local
                let sc_result = ctx_fresh_local(ctx, VT_I32())
                let set_sc = MirInst_new(MIR_LOCAL_SET())
                set_sc.arg0 = sc_result
                ctx_emit(ctx, set_sc)

                // Push condition for if
                let get_cond = MirInst_new(MIR_LOCAL_GET())
                get_cond.arg0 = sc_result
                ctx_emit(ctx, get_cond)

                // For ||: enter if-block when lhs is FALSY (evaluate rhs)
                if mir_op == MIR_OR() {
                    let eqz_inst = MirInst_new(MIR_NOT())
                    eqz_inst.dest = sc_result
                    eqz_inst.arg0 = sc_result
                    ctx_emit(ctx, eqz_inst)
                }

                // if (condition) { sc_result = rhs }
                ctx_emit(ctx, MirInst_new(MIR_IF()))
                let r_idx = lower_expr(ctx, rhs)
                let set_sc2 = MirInst_new(MIR_LOCAL_SET())
                set_sc2.arg0 = sc_result
                ctx_emit(ctx, set_sc2)
                ctx_emit(ctx, MirInst_new(MIR_END()))

                // Push final result
                let get_sc_final = MirInst_new(MIR_LOCAL_GET())
                get_sc_final.arg0 = sc_result
                ctx_emit(ctx, get_sc_final)
                return sc_result
            }

            let l_idx = lower_expr(ctx, lhs)
            let r_idx = lower_expr(ctx, rhs)
            // Determine val_type from operands (f64 if either operand is f64)
            let mut binop_vt = VT_I32()
            if ctx_local_vt(ctx, l_idx) == VT_F64() || ctx_local_vt(ctx, r_idx) == VT_F64() {
                binop_vt = VT_F64()
            }
            // Comparison ops always return i32 (boolean)
            let is_cmp = mir_op == MIR_EQ() || mir_op == MIR_NEQ() || mir_op == MIR_LT() || mir_op == MIR_LTEQ() || mir_op == MIR_GT() || mir_op == MIR_GTEQ()
            let mut dest_vt = binop_vt
            if is_cmp { dest_vt = VT_I32() }
            let dest = ctx_fresh_local(ctx, dest_vt)
            if is_cmp {
                ctx_set_local_type(ctx, dest, String_from("bool"))
            } else if dest_vt == VT_F64() {
                ctx_set_local_type(ctx, dest, String_from("f64"))
            } else {
                ctx_set_local_type(ctx, dest, String_from("i32"))
            }
            let binop_inst = MirInst_binop(mir_op, dest, l_idx, r_idx)
            binop_inst.val_type = binop_vt
            ctx_emit(ctx, binop_inst)
            return dest
        }
        return 0 - 1
    }

    if kind == NK_UNARY() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let operand = get_unchecked(node.children, 0)
            let o_idx = lower_expr(ctx, operand)
            let uvt = ctx_local_vt(ctx, o_idx)
            let dest = ctx_fresh_local(ctx, uvt)
            let mut mir_op = MIR_NOP()
            if node.op == UOP_NEG() { mir_op = MIR_NEG() }
            if node.op == UOP_NOT() { mir_op = MIR_NOT() }
            let inst = MirInst_new(mir_op)
            inst.dest = dest
            inst.arg0 = o_idx
            inst.val_type = uvt
            ctx_emit(ctx, inst)
            return dest
        }
        return 0 - 1
    }

    if kind == NK_CALL() {
        // children[0] = callee, children[1..] = arguments
        let child_count = len(node.children)
        if child_count >= 1 {
            let callee = get_unchecked(node.children, 0)

            // Check if this is a payload variant constructor (e.g. Some(42), Ok(val))
            let var_tag = ctx_variant_tag(ctx, clone(callee.text))
            if var_tag >= 0 && child_count > 1 {
                // Payload variant construction: allocate [tag, payload1, ...]
                // First lower all payload expressions and save to locals
                let mut payload_locals = Vec_new_i32()
                let mut payload_vts = Vec_new_i32()
                let mut total_bytes = 4  // tag is always 4 bytes (i32)
                let mut pa = 1
                while pa < child_count {
                    let parg = get_unchecked(node.children, pa)
                    let p_idx = lower_expr(ctx, parg)
                    let p_vt = ctx_local_vt(ctx, p_idx)
                    // Save value from stack to local (lower_expr leaves value on stack)
                    let save_local = ctx_fresh_local(ctx, p_vt)
                    let save_inst = MirInst_new(MIR_LOCAL_SET())
                    save_inst.arg0 = save_local
                    ctx_emit(ctx, save_inst)
                    push(payload_locals, save_local)
                    push(payload_vts, p_vt)
                    if p_vt == VT_F64() {
                        total_bytes = total_bytes + 8
                    } else {
                        total_bytes = total_bytes + 4
                    }
                    pa = pa + 1
                }
                let dest = ctx_fresh_local(ctx, VT_I32())
                let struct_inst = MirInst_new(MIR_STRUCT_NEW())
                struct_inst.dest = dest
                struct_inst.int_val = total_bytes
                ctx_emit(ctx, struct_inst)
                // Store tag (field 0, byte offset 0)
                let tag_tmp = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(var_tag, tag_tmp))
                let set_tag = MirInst_new(MIR_STRUCT_SET())
                set_tag.arg0 = dest
                set_tag.arg1 = tag_tmp
                set_tag.int_val = 0  // byte offset 0
                ctx_emit(ctx, set_tag)
                // Store payload fields with correct byte offsets
                let mut byte_off = 4  // after tag
                let mut pi = 0
                let payload_count = len(payload_locals)
                while pi < payload_count {
                    let p_local = get_unchecked(payload_locals, pi)
                    let p_vt = get_unchecked(payload_vts, pi)
                    // Push value on stack via LOCAL_GET
                    let get_val = MirInst_new(MIR_LOCAL_GET())
                    get_val.arg0 = p_local
                    ctx_emit(ctx, get_val)
                    let set_p = MirInst_new(MIR_STRUCT_SET())
                    set_p.arg0 = dest
                    set_p.arg1 = p_local
                    set_p.int_val = byte_off
                    if p_vt == VT_F64() {
                        set_p.val_type = VT_F64()
                        byte_off = byte_off + 8
                    } else {
                        byte_off = byte_off + 4
                    }
                    ctx_emit(ctx, set_p)
                    pi = pi + 1
                }
                // Push result pointer on stack
                let get_r = MirInst_new(MIR_LOCAL_GET())
                get_r.arg0 = dest
                ctx_emit(ctx, get_r)
                return dest
            }

            // Closure call: callee names a let-bound lambda; emit synthetic fn + capture args (#499)
            if callee.kind == NK_IDENT() {
                let clo_ix = ctx_closure_lookup(ctx, clone(callee.text))
                if clo_ix >= 0 {
                    let synth = clone(get_unchecked(ctx.closure_bind_synth, clo_ix))
                    let packed = clone(get_unchecked(ctx.closure_bind_caps, clo_ix))
                    let extra = get_unchecked(ctx.closure_bind_extra, clo_ix)
                    let mut ca = 1
                    while ca < child_count {
                        let carg = get_unchecked(node.children, ca)
                        let _ai = lower_expr(ctx, carg)
                        ca = ca + 1
                    }
                    closure_emit_captured_args(ctx, packed)
                    let c_dest = ctx_fresh_local(ctx, VT_I32())
                    let clo_call = MirInst_new(MIR_CALL())
                    clo_call.str_val = synth
                    clo_call.dest = c_dest
                    clo_call.int_val = (child_count - 1) + extra
                    ctx_emit(ctx, clo_call)
                    return c_dest
                }
            }

            let call_inst = MirInst_new(MIR_CALL())
            call_inst.str_val = clone(callee.text)
            let is_println = eq(clone(callee.text), "stdio::println") || eq(clone(callee.text), "println") || eq(clone(callee.text), "stdio::print") || eq(clone(callee.text), "print") || eq(clone(callee.text), "stdio::eprintln") || eq(clone(callee.text), "eprintln")
            // Lower arguments and track first arg index for type dispatch
            let mut first_arg_idx = 0 - 1
            let mut a = 1
            while a < child_count {
                let arg = get_unchecked(node.children, a)
                let mut arg_idx = lower_expr(ctx, arg)
                // Auto-convert println(integer) to println(to_string(integer))
                if is_println && a == 1 && arg_idx >= 0 {
                    let mut needs_convert = arg.kind == NK_INT_LIT() || arg.kind == NK_BOOL_LIT() || arg.kind == NK_CHAR_LIT() || arg.kind == NK_FLOAT_LIT()
                    if !needs_convert {
                        // Check if variable has a numeric type annotation
                        let lt = ctx_get_local_type(ctx, arg_idx)
                        if eq(clone(lt), "char") || eq(clone(lt), "u8") || eq(clone(lt), "u16") || eq(clone(lt), "u32") || eq(clone(lt), "i16") || eq(clone(lt), "i32") || eq(clone(lt), "i64") || eq(clone(lt), "bool") || eq(clone(lt), "f64") {
                            needs_convert = true
                        }
                    }
                    if !needs_convert && arg.kind == NK_CALL() && len(arg.children) > 0 {
                        // Check if callee is a known i32/bool-returning function
                        let call_callee = get_unchecked(arg.children, 0)
                        let cn = clone(call_callee.text)
                        // Bool-returning functions
                        if eq(clone(cn), "contains_i32") || eq(clone(cn), "contains_string") || eq(clone(cn), "contains_String") || eq(clone(cn), "contains") || eq(clone(cn), "is_empty") || eq(clone(cn), "is_some") || eq(clone(cn), "is_none") || eq(clone(cn), "starts_with") || eq(clone(cn), "ends_with") {
                            needs_convert = true
                            ctx_set_local_type(ctx, arg_idx, String_from("bool"))
                        }
                        // i32-returning functions
                        if eq(clone(cn), "len") || eq(clone(cn), "parse_i32") || eq(clone(cn), "abs") || eq(clone(cn), "min") || eq(clone(cn), "max") || eq(clone(cn), "sum_i32") || eq(clone(cn), "product_i32") || eq(clone(cn), "index_of") || eq(clone(cn), "clamp_i32") {
                            needs_convert = true
                            ctx_set_local_type(ctx, arg_idx, String_from("i32"))
                        }
                    }
                    if !needs_convert && arg.kind == NK_IDENT() {
                        // Check if the identifier has no struct type (likely an integer)
                        let lt2 = ctx_get_local_type(ctx, arg_idx)
                        if len(lt2) == 0 {
                            // No type info — could be integer or string
                            // Only auto-convert if the ident has a numeric type annotation in scope
                            // For now, skip auto-conversion for plain identifiers without type info
                            let _skip = 0
                        }
                    }
                    if needs_convert {
                        // Wrap with to_string / char_to_string / bool_to_string
                        let wrap_inst = MirInst_new(MIR_CALL())
                        let wrap_lt = ctx_get_local_type(ctx, arg_idx)
                        if eq(clone(wrap_lt), "char") || arg.kind == NK_CHAR_LIT() {
                            wrap_inst.str_val = String_from("char_to_string")
                        } else if eq(clone(wrap_lt), "bool") || arg.kind == NK_BOOL_LIT() {
                            wrap_inst.str_val = String_from("bool_to_string")
                        } else if eq(clone(wrap_lt), "f64") || arg.kind == NK_FLOAT_LIT() {
                            wrap_inst.str_val = String_from("f64_to_string")
                        } else {
                            wrap_inst.str_val = String_from("to_string")
                        }
                        let wrap_dest = ctx_fresh_local(ctx, VT_I32())
                        wrap_inst.dest = wrap_dest
                        wrap_inst.int_val = 1
                        ctx_emit(ctx, wrap_inst)
                        arg_idx = wrap_dest
                    }
                }
                if a == 1 {
                    first_arg_idx = arg_idx
                }
                a = a + 1
            }
            // Dispatch to_string to char_to_string/f64_to_string/bool_to_string when arg has specific type
            if eq(clone(call_inst.str_val), "to_string") {
                if first_arg_idx >= 0 {
                    let arg_type = ctx_get_local_type(ctx, first_arg_idx)
                    if eq(clone(arg_type), "char") {
                        call_inst.str_val = String_from("char_to_string")
                    } else if eq(clone(arg_type), "f64") {
                        call_inst.str_val = String_from("f64_to_string")
                    } else if eq(clone(arg_type), "bool") {
                        call_inst.str_val = String_from("bool_to_string")
                    } else if eq(clone(arg_type), "string") || eq(clone(arg_type), "String") {
                        // to_string on a string is identity — return arg directly
                        return first_arg_idx
                    }
                }
            }
            // Dispatch len/push/get_unchecked to vec variants when arg is vec type
            if eq(clone(call_inst.str_val), "len") {
                if first_arg_idx >= 0 {
                    let arg_type_len = ctx_get_local_type(ctx, first_arg_idx)
                    if eq(clone(arg_type_len), "vec:i32") || eq(clone(arg_type_len), "vec:String") || eq(clone(arg_type_len), "vec:Point") || eq(clone(arg_type_len), "vec:u8") || eq(clone(arg_type_len), "vec:f64") || eq(clone(arg_type_len), "vec:bool") || eq(clone(arg_type_len), "vec:MirInst") || eq(clone(arg_type_len), "vec:MirLocal") || eq(clone(arg_type_len), "vec:MirBlock") || eq(clone(arg_type_len), "vec:MirFunction") || eq(clone(arg_type_len), "vec:AstNode") || eq(clone(arg_type_len), "vec:Item") || eq(clone(arg_type_len), "vec:Container") || eq(clone(arg_type_len), "vec:Context") || eq(clone(arg_type_len), "vec:Holder") || eq(clone(arg_type_len), "vec:Inner") || eq(clone(arg_type_len), "vec:Outer") || eq(clone(arg_type_len), "vec:Token") || eq(clone(arg_type_len), "vec:Span") || eq(clone(arg_type_len), "vec:Diagnostic") || eq(clone(arg_type_len), "vec:TypedFn") || eq(clone(arg_type_len), "vec:WasmLocal") || eq(clone(arg_type_len), "vec:Pair") || eq(clone(arg_type_len), "vec:Node") {
                        call_inst.str_val = String_from("vec_len")
                    }
                }
            }
            if eq(clone(call_inst.str_val), "push") {
                if first_arg_idx >= 0 {
                    let arg_type_push = ctx_get_local_type(ctx, first_arg_idx)
                    if eq(clone(arg_type_push), "vec:i32") || eq(clone(arg_type_push), "vec:String") || eq(clone(arg_type_push), "vec:Point") || eq(clone(arg_type_push), "vec:u8") || eq(clone(arg_type_push), "vec:f64") || eq(clone(arg_type_push), "vec:bool") || eq(clone(arg_type_push), "vec:MirInst") || eq(clone(arg_type_push), "vec:MirLocal") || eq(clone(arg_type_push), "vec:MirBlock") || eq(clone(arg_type_push), "vec:MirFunction") || eq(clone(arg_type_push), "vec:AstNode") || eq(clone(arg_type_push), "vec:Item") || eq(clone(arg_type_push), "vec:Container") || eq(clone(arg_type_push), "vec:Context") || eq(clone(arg_type_push), "vec:Holder") || eq(clone(arg_type_push), "vec:Inner") || eq(clone(arg_type_push), "vec:Outer") || eq(clone(arg_type_push), "vec:Token") || eq(clone(arg_type_push), "vec:Span") || eq(clone(arg_type_push), "vec:Diagnostic") || eq(clone(arg_type_push), "vec:TypedFn") || eq(clone(arg_type_push), "vec:WasmLocal") || eq(clone(arg_type_push), "vec:Pair") || eq(clone(arg_type_push), "vec:Node") {
                        call_inst.str_val = String_from("vec_push")
                    }
                }
            }
            if eq(clone(call_inst.str_val), "get_unchecked") {
                if first_arg_idx >= 0 {
                    let arg_type_get = ctx_get_local_type(ctx, first_arg_idx)
                    if eq(clone(arg_type_get), "vec:i32") || eq(clone(arg_type_get), "vec:String") || eq(clone(arg_type_get), "vec:Point") || eq(clone(arg_type_get), "vec:u8") || eq(clone(arg_type_get), "vec:f64") || eq(clone(arg_type_get), "vec:bool") || eq(clone(arg_type_get), "vec:MirInst") || eq(clone(arg_type_get), "vec:MirLocal") || eq(clone(arg_type_get), "vec:MirBlock") || eq(clone(arg_type_get), "vec:MirFunction") || eq(clone(arg_type_get), "vec:AstNode") || eq(clone(arg_type_get), "vec:Item") || eq(clone(arg_type_get), "vec:Container") || eq(clone(arg_type_get), "vec:Context") || eq(clone(arg_type_get), "vec:Holder") || eq(clone(arg_type_get), "vec:Inner") || eq(clone(arg_type_get), "vec:Outer") || eq(clone(arg_type_get), "vec:Token") || eq(clone(arg_type_get), "vec:Span") || eq(clone(arg_type_get), "vec:Diagnostic") || eq(clone(arg_type_get), "vec:TypedFn") || eq(clone(arg_type_get), "vec:WasmLocal") || eq(clone(arg_type_get), "vec:Pair") || eq(clone(arg_type_get), "vec:Node") {
                        call_inst.str_val = String_from("vec_get_unchecked")
                    }
                }
            }
            if eq(clone(call_inst.str_val), "get") {
                if first_arg_idx >= 0 {
                    let arg_type_get2 = ctx_get_local_type(ctx, first_arg_idx)
                    if eq(clone(arg_type_get2), "vec:i32") || eq(clone(arg_type_get2), "vec:String") || eq(clone(arg_type_get2), "vec:Point") || eq(clone(arg_type_get2), "vec:u8") || eq(clone(arg_type_get2), "vec:f64") || eq(clone(arg_type_get2), "vec:bool") || eq(clone(arg_type_get2), "vec:MirInst") || eq(clone(arg_type_get2), "vec:MirLocal") || eq(clone(arg_type_get2), "vec:MirBlock") || eq(clone(arg_type_get2), "vec:MirFunction") || eq(clone(arg_type_get2), "vec:AstNode") || eq(clone(arg_type_get2), "vec:Item") || eq(clone(arg_type_get2), "vec:Container") || eq(clone(arg_type_get2), "vec:Context") || eq(clone(arg_type_get2), "vec:Holder") || eq(clone(arg_type_get2), "vec:Inner") || eq(clone(arg_type_get2), "vec:Outer") || eq(clone(arg_type_get2), "vec:Token") || eq(clone(arg_type_get2), "vec:Span") || eq(clone(arg_type_get2), "vec:Diagnostic") || eq(clone(arg_type_get2), "vec:TypedFn") || eq(clone(arg_type_get2), "vec:WasmLocal") || eq(clone(arg_type_get2), "vec:Pair") || eq(clone(arg_type_get2), "vec:Node") {
                        call_inst.str_val = String_from("vec_get")
                    }
                }
            }
            // Mark dest as vec type when calling Vec_new_*
            // Dispatch pop -> vec_pop
            if eq(clone(call_inst.str_val), "pop") {
                call_inst.str_val = String_from("vec_pop")
            }
            // Dispatch set -> vec_set
            if eq(clone(call_inst.str_val), "set") {
                call_inst.str_val = String_from("vec_set")
            }
            // unwrap, unwrap_or, is_empty pass through as-is (no rename needed)
            let dest = ctx_fresh_local(ctx, VT_I32())
            call_inst.dest = dest
            call_inst.int_val = child_count - 1
            let callee_name = clone(call_inst.str_val)
            if eq(clone(callee_name), "Vec_new_i32") {
                ctx_set_local_type(ctx, dest, String_from("vec:i32"))
            } else if eq(clone(callee_name), "Vec_new_String") {
                ctx_set_local_type(ctx, dest, String_from("vec:String"))
            } else if eq(clone(callee_name), "Vec_new_Point") {
                ctx_set_local_type(ctx, dest, String_from("vec:Point"))
            } else if eq(clone(callee_name), "Vec_new_MirInst") {
                ctx_set_local_type(ctx, dest, String_from("vec:MirInst"))
            } else if eq(clone(callee_name), "Vec_new_MirLocal") {
                ctx_set_local_type(ctx, dest, String_from("vec:MirLocal"))
            } else if eq(clone(callee_name), "Vec_new_MirBlock") {
                ctx_set_local_type(ctx, dest, String_from("vec:MirBlock"))
            } else if eq(clone(callee_name), "Vec_new_MirFunction") {
                ctx_set_local_type(ctx, dest, String_from("vec:MirFunction"))
            } else if eq(clone(callee_name), "Vec_new_AstNode") {
                ctx_set_local_type(ctx, dest, String_from("vec:AstNode"))
            } else if eq(clone(callee_name), "Vec_new_u8") {
                ctx_set_local_type(ctx, dest, String_from("vec:u8"))
            } else if eq(clone(callee_name), "Vec_new_f64") {
                ctx_set_local_type(ctx, dest, String_from("vec:f64"))
            } else if eq(clone(callee_name), "Vec_new_bool") {
                ctx_set_local_type(ctx, dest, String_from("vec:bool"))
            } else if eq(clone(callee_name), "Vec_new_Item") {
                ctx_set_local_type(ctx, dest, String_from("vec:Item"))
            } else if eq(clone(callee_name), "Vec_new_Container") {
                ctx_set_local_type(ctx, dest, String_from("vec:Container"))
            } else if eq(clone(callee_name), "Vec_new_Context") {
                ctx_set_local_type(ctx, dest, String_from("vec:Context"))
            } else if eq(clone(callee_name), "Vec_new_Holder") {
                ctx_set_local_type(ctx, dest, String_from("vec:Holder"))
            } else if eq(clone(callee_name), "Vec_new_Inner") {
                ctx_set_local_type(ctx, dest, String_from("vec:Inner"))
            } else if eq(clone(callee_name), "Vec_new_Outer") {
                ctx_set_local_type(ctx, dest, String_from("vec:Outer"))
            } else if eq(clone(callee_name), "Vec_new_Token") {
                ctx_set_local_type(ctx, dest, String_from("vec:Token"))
            } else if eq(clone(callee_name), "Vec_new_Span") {
                ctx_set_local_type(ctx, dest, String_from("vec:Span"))
            } else if eq(clone(callee_name), "Vec_new_Diagnostic") {
                ctx_set_local_type(ctx, dest, String_from("vec:Diagnostic"))
            } else if eq(clone(callee_name), "Vec_new_TypedFn") {
                ctx_set_local_type(ctx, dest, String_from("vec:TypedFn"))
            } else if eq(clone(callee_name), "Vec_new_WasmLocal") {
                ctx_set_local_type(ctx, dest, String_from("vec:WasmLocal"))
            } else if eq(clone(callee_name), "Vec_new_Pair") {
                ctx_set_local_type(ctx, dest, String_from("vec:Pair"))
            } else if eq(clone(callee_name), "Vec_new_Node") {
                ctx_set_local_type(ctx, dest, String_from("vec:Node"))
            }
            // Track string-returning functions
            if eq(clone(callee_name), "String_from") || eq(clone(callee_name), "concat") || eq(clone(callee_name), "clone") || eq(clone(callee_name), "to_string") || eq(clone(callee_name), "char_to_string") || eq(clone(callee_name), "bool_to_string") || eq(clone(callee_name), "f64_to_string") || eq(clone(callee_name), "substring") || eq(clone(callee_name), "trim") || eq(clone(callee_name), "to_uppercase") || eq(clone(callee_name), "to_lowercase") || eq(clone(callee_name), "replace") || eq(clone(callee_name), "string::repeat") {
                ctx_set_local_type(ctx, dest, String_from("string"))
            }
            // Propagate element type from vec_get_unchecked result
            if eq(clone(callee_name), "vec_get_unchecked") {
                if first_arg_idx >= 0 {
                    let vec_type = ctx_get_local_type(ctx, first_arg_idx)
                    if eq(clone(vec_type), "vec:Point") {
                        ctx_set_local_type(ctx, dest, String_from("Point"))
                    } else if eq(clone(vec_type), "vec:MirInst") {
                        ctx_set_local_type(ctx, dest, String_from("MirInst"))
                    } else if eq(clone(vec_type), "vec:MirLocal") {
                        ctx_set_local_type(ctx, dest, String_from("MirLocal"))
                    } else if eq(clone(vec_type), "vec:MirBlock") {
                        ctx_set_local_type(ctx, dest, String_from("MirBlock"))
                    } else if eq(clone(vec_type), "vec:MirFunction") {
                        ctx_set_local_type(ctx, dest, String_from("MirFunction"))
                    } else if eq(clone(vec_type), "vec:AstNode") {
                        ctx_set_local_type(ctx, dest, String_from("AstNode"))
                    } else if eq(clone(vec_type), "vec:i32") {
                        ctx_set_local_type(ctx, dest, String_from("i32"))
                    } else if eq(clone(vec_type), "vec:String") {
                        ctx_set_local_type(ctx, dest, String_from("String"))
                    } else if eq(clone(vec_type), "vec:u8") {
                        ctx_set_local_type(ctx, dest, String_from("u8"))
                    } else if eq(clone(vec_type), "vec:f64") {
                        ctx_set_local_type(ctx, dest, String_from("f64"))
                    } else if eq(clone(vec_type), "vec:bool") {
                        ctx_set_local_type(ctx, dest, String_from("bool"))
                    } else if eq(clone(vec_type), "vec:Item") {
                        ctx_set_local_type(ctx, dest, String_from("Item"))
                    } else if eq(clone(vec_type), "vec:Container") {
                        ctx_set_local_type(ctx, dest, String_from("Container"))
                    } else if eq(clone(vec_type), "vec:Context") {
                        ctx_set_local_type(ctx, dest, String_from("Context"))
                    } else if eq(clone(vec_type), "vec:Holder") {
                        ctx_set_local_type(ctx, dest, String_from("Holder"))
                    } else if eq(clone(vec_type), "vec:Inner") {
                        ctx_set_local_type(ctx, dest, String_from("Inner"))
                    } else if eq(clone(vec_type), "vec:Outer") {
                        ctx_set_local_type(ctx, dest, String_from("Outer"))
                    } else if eq(clone(vec_type), "vec:Token") {
                        ctx_set_local_type(ctx, dest, String_from("Token"))
                    } else if eq(clone(vec_type), "vec:Span") {
                        ctx_set_local_type(ctx, dest, String_from("Span"))
                    } else if eq(clone(vec_type), "vec:Diagnostic") {
                        ctx_set_local_type(ctx, dest, String_from("Diagnostic"))
                    } else if eq(clone(vec_type), "vec:TypedFn") {
                        ctx_set_local_type(ctx, dest, String_from("TypedFn"))
                    } else if eq(clone(vec_type), "vec:WasmLocal") {
                        ctx_set_local_type(ctx, dest, String_from("WasmLocal"))
                    } else if eq(clone(vec_type), "vec:Pair") {
                        ctx_set_local_type(ctx, dest, String_from("Pair"))
                    } else if eq(clone(vec_type), "vec:Node") {
                        ctx_set_local_type(ctx, dest, String_from("Node"))
                    }
                }
            }
            ctx_emit(ctx, call_inst)
            // If this user-defined function returns void, return -1 (no stack value)
            if ctx_fn_return_vt(ctx, clone(callee_name)) == VT_VOID() {
                return 0 - 1
            }
            return dest
        }
        return 0 - 1
    }

    if kind == NK_IF_EXPR() {
        // children[0] = condition, children[1] = then-block, children[2] = else-block (optional)
        let child_count = len(node.children)
        if child_count >= 2 {
            let cond = get_unchecked(node.children, 0)
            let cond_idx = lower_expr(ctx, cond)
            let result = ctx_fresh_local(ctx, VT_I32())

            // Emit structured IF/ELSE/END (Wasm structured control flow)
            ctx_emit(ctx, MirInst_new(MIR_IF()))
            ctx.nesting_depth = ctx.nesting_depth + 1

            // Then block
            let then_body = get_unchecked(node.children, 1)
            let then_result = lower_expr(ctx, then_body)
            if then_result >= 0 {
                let set_inst = MirInst_new(MIR_LOCAL_SET())
                set_inst.arg0 = result
                set_inst.arg1 = then_result
                ctx_emit(ctx, set_inst)
            }

            // Else block (optional)
            let mut else_result = 0 - 1
            if child_count >= 3 {
                ctx_emit(ctx, MirInst_new(MIR_ELSE()))
                let else_body = get_unchecked(node.children, 2)
                else_result = lower_expr(ctx, else_body)
                if else_result >= 0 {
                    let set_inst2 = MirInst_new(MIR_LOCAL_SET())
                    set_inst2.arg0 = result
                    set_inst2.arg1 = else_result
                    ctx_emit(ctx, set_inst2)
                }
            }

            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1

            // Only push result to stack if at least one branch produced a value
            if then_result >= 0 || else_result >= 0 {
                let get_inst = MirInst_new(MIR_LOCAL_GET())
                get_inst.arg0 = result
                get_inst.dest = result
                ctx_emit(ctx, get_inst)
                return result
            }
            // Void if-expression: no value on stack
            return 0 - 1
        }
        return 0 - 1
    }

    if kind == NK_MATCH_EXPR() {
        // children[0] = scrutinee, children[1..] = match arms (NK_MATCH_ARM)
        // Each arm: children[0]=pattern, children[1]=body (2 children) or
        //           children[0]=pattern, children[1]=guard, children[2]=body (3 children)
        let child_count = len(node.children)
        if child_count >= 2 {
            let scrutinee = get_unchecked(node.children, 0)
            let scrut_idx = lower_expr(ctx, scrutinee)
            // Save scrutinee value to its local (lower_expr pushes on stack;
            // we need it captured so LOCAL_GET works in arms)
            let save_scrut = MirInst_new(MIR_LOCAL_SET())
            save_scrut.arg0 = scrut_idx
            ctx_emit(ctx, save_scrut)
            let result = ctx_fresh_local(ctx, VT_I32())

            // Detect if this is a payload enum match (any arm has PAT_VARIANT with children)
            let mut is_payload_match = false
            let mut arm_scan = 1
            while arm_scan < child_count {
                let scan_arm = get_unchecked(node.children, arm_scan)
                if len(scan_arm.children) > 0 {
                    let scan_pat = get_unchecked(scan_arm.children, 0)
                    if scan_pat.kind == NK_PAT_VARIANT() && len(scan_pat.children) > 0 {
                        is_payload_match = true
                    }
                }
                arm_scan = arm_scan + 1
            }

            // Detect if scrutinee is Result<f64,...> or Option<f64>
            let scrut_type = ctx_get_local_type(ctx, scrut_idx)
            let scrut_ok_is_f64 = eq(clone(scrut_type), "Result_f64") || eq(clone(scrut_type), "Option_f64")

            // For payload enum match, extract the tag from the heap once
            let mut compare_idx = scrut_idx
            if is_payload_match {
                let tag_local = ctx_fresh_local(ctx, VT_I32())
                // LOCAL_GET scrut (push heap ptr)
                let get_s = MirInst_new(MIR_LOCAL_GET())
                get_s.arg0 = scrut_idx
                ctx_emit(ctx, get_s)
                // STRUCT_GET field=0 (load tag from ptr)
                let sget = MirInst_new(MIR_STRUCT_GET())
                sget.int_val = 0
                ctx_emit(ctx, sget)
                // LOCAL_SET tag_local (save tag)
                let set_tl = MirInst_new(MIR_LOCAL_SET())
                set_tl.arg0 = tag_local
                ctx_emit(ctx, set_tl)
                compare_idx = tag_local
            }

            // Use nested if/else chain for match arms (structured control flow)
            let arm_count = child_count - 1
            let mut arm = 1
            let mut if_depth = 0
            while arm < child_count {
                let arm_node = get_unchecked(node.children, arm)
                let arm_child_count = len(arm_node.children)
                let is_last = arm == child_count - 1

                let pat_idx_in_arm = 0
                let body_idx_in_arm = arm_child_count - 1
                let pat = get_unchecked(arm_node.children, pat_idx_in_arm)
                let body = get_unchecked(arm_node.children, body_idx_in_arm)

                if is_last {
                    // Last arm: default case
                    // Bind pattern variable if PAT_IDENT
                    if pat.kind == NK_PAT_IDENT() {
                        let bind_last = ctx_alloc_local(ctx, clone(pat.text), VT_I32())
                        let get_sl = MirInst_new(MIR_LOCAL_GET())
                        get_sl.arg0 = scrut_idx
                        ctx_emit(ctx, get_sl)
                        let set_sl = MirInst_new(MIR_LOCAL_SET())
                        set_sl.arg0 = bind_last
                        ctx_emit(ctx, set_sl)
                    }
                    // Bind payload variables if this arm has bindings
                    if is_payload_match && pat.kind == NK_PAT_VARIANT() && len(pat.children) > 0 {
                        let variant_name = clone(pat.text)
                        let mut bi = 0
                        while bi < len(pat.children) {
                            let bind_pat = get_unchecked(pat.children, bi)
                            // Determine field type from variant pseudo-struct (field bi+1 = payload field bi)
                            let mut field_is_f64 = ctx_struct_field_is_f64(ctx, clone(variant_name), bi + 1)
                            // Override: if scrutinee is Result<f64,...>/Option<f64> and variant is Ok/Some
                            if !field_is_f64 && scrut_ok_is_f64 && bi == 0 {
                                if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") || eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
                                    field_is_f64 = true
                                }
                            }
                            let mut bind_vt = VT_I32()
                            if field_is_f64 { bind_vt = VT_F64() }
                            let bind_local = ctx_alloc_local(ctx, clone(bind_pat.text), bind_vt)
                            let get_s2 = MirInst_new(MIR_LOCAL_GET())
                            get_s2.arg0 = scrut_idx
                            ctx_emit(ctx, get_s2)
                            let sget2 = MirInst_new(MIR_STRUCT_GET())
                            sget2.int_val = ctx_struct_field_offset(ctx, clone(variant_name), bi + 1)
                            if field_is_f64 { sget2.val_type = VT_F64() }
                            ctx_emit(ctx, sget2)
                            let set_b = MirInst_new(MIR_LOCAL_SET())
                            set_b.arg0 = bind_local
                            ctx_emit(ctx, set_b)
                            bi = bi + 1
                        }
                    }
                    // Check for guard (arm_child_count == 3)
                    if arm_child_count == 3 {
                        let guard_last = get_unchecked(arm_node.children, 1)
                        lower_expr(ctx, guard_last)
                        ctx_emit(ctx, MirInst_new(MIR_IF()))
                        ctx.nesting_depth = ctx.nesting_depth + 1
                        if_depth = if_depth + 1
                    }
                    let arm_result = lower_expr(ctx, body)
                    if arm_result >= 0 {
                        let set_inst = MirInst_new(MIR_LOCAL_SET())
                        set_inst.arg0 = result
                        set_inst.arg1 = arm_result
                        ctx_emit(ctx, set_inst)
                    }
                    if arm_child_count == 3 {
                        ctx_emit(ctx, MirInst_new(MIR_END()))
                        ctx.nesting_depth = ctx.nesting_depth - 1
                        if_depth = if_depth - 1
                    }
                } else {
                    let is_catchall = pat.kind == NK_PAT_IDENT() || pat.kind == NK_PAT_WILDCARD()
                    let has_guard = arm_child_count == 3

                    if is_catchall {
                        // Catch-all pattern: bind variable and check guard
                        if pat.kind == NK_PAT_IDENT() {
                            let bind_ca = ctx_alloc_local(ctx, clone(pat.text), VT_I32())
                            let get_ca = MirInst_new(MIR_LOCAL_GET())
                            get_ca.arg0 = scrut_idx
                            ctx_emit(ctx, get_ca)
                            let set_ca = MirInst_new(MIR_LOCAL_SET())
                            set_ca.arg0 = bind_ca
                            ctx_emit(ctx, set_ca)
                        }
                        if has_guard {
                            let guard = get_unchecked(arm_node.children, 1)
                            lower_expr(ctx, guard)
                            ctx_emit(ctx, MirInst_new(MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                        }
                    } else {
                        // Push tag/scrutinee value onto stack for comparison
                        let get_inst = MirInst_new(MIR_LOCAL_GET())
                        get_inst.arg0 = compare_idx
                        ctx_emit(ctx, get_inst)
                        // Compare against pattern tag
                        let pat_idx = lower_expr(ctx, pat)
                        let cmp_dest = ctx_fresh_local(ctx, VT_I32())
                        ctx_emit(ctx, MirInst_binop(MIR_EQ(), cmp_dest, compare_idx, pat_idx))

                        // IF (match)
                        ctx_emit(ctx, MirInst_new(MIR_IF()))
                        ctx.nesting_depth = ctx.nesting_depth + 1
                        if_depth = if_depth + 1

                        // Bind payload variables BEFORE guard (guard may reference them)
                        if is_payload_match && pat.kind == NK_PAT_VARIANT() && len(pat.children) > 0 {
                            let variant_name2 = clone(pat.text)
                            let mut bi2 = 0
                            while bi2 < len(pat.children) {
                                let bind_pat2 = get_unchecked(pat.children, bi2)
                                let mut field_is_f64_2 = ctx_struct_field_is_f64(ctx, clone(variant_name2), bi2 + 1)
                                // Override: if scrutinee is Result<f64,...>/Option<f64> and variant is Ok/Some
                                if !field_is_f64_2 && scrut_ok_is_f64 && bi2 == 0 {
                                    if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                        field_is_f64_2 = true
                                    }
                                }
                                let mut bind_vt2 = VT_I32()
                                if field_is_f64_2 { bind_vt2 = VT_F64() }
                                let bind_local2 = ctx_alloc_local(ctx, clone(bind_pat2.text), bind_vt2)
                                let get_s3 = MirInst_new(MIR_LOCAL_GET())
                                get_s3.arg0 = scrut_idx
                                ctx_emit(ctx, get_s3)
                                let sget3 = MirInst_new(MIR_STRUCT_GET())
                                sget3.int_val = ctx_struct_field_offset(ctx, clone(variant_name2), bi2 + 1)
                                if field_is_f64_2 { sget3.val_type = VT_F64() }
                                ctx_emit(ctx, sget3)
                                let set_b2 = MirInst_new(MIR_LOCAL_SET())
                                set_b2.arg0 = bind_local2
                                ctx_emit(ctx, set_b2)
                                bi2 = bi2 + 1
                            }
                        }

                        // Check guard if present
                        if has_guard {
                            let guard2 = get_unchecked(arm_node.children, 1)
                            lower_expr(ctx, guard2)
                            ctx_emit(ctx, MirInst_new(MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                        }
                    }

                    let arm_result = lower_expr(ctx, body)
                    if arm_result >= 0 {
                        let set_inst = MirInst_new(MIR_LOCAL_SET())
                        set_inst.arg0 = result
                        set_inst.arg1 = arm_result
                        ctx_emit(ctx, set_inst)
                    }

                    // ELSE (try next arm)
                    ctx_emit(ctx, MirInst_new(MIR_ELSE()))
                }
                arm = arm + 1
            }

            // Close all nested if/else
            while if_depth > 0 {
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                if_depth = if_depth - 1
            }

            // Push the match result onto the Wasm stack for the caller
            let get_result = MirInst_new(MIR_LOCAL_GET())
            get_result.arg0 = result
            ctx_emit(ctx, get_result)

            return result
        }
        return 0 - 1
    }

    if kind == NK_BLOCK() {
        let child_count = len(node.children)
        let mut last_result = 0 - 1
        let mut s = 0
        while s < child_count {
            let stmt = get_unchecked(node.children, s)
            last_result = lower_stmt(ctx, stmt)
            s = s + 1
        }
        return last_result
    }

    if kind == NK_ASSIGN() {
        // children[0] = target, children[1] = value
        let child_count = len(node.children)
        if child_count >= 2 {
            let target = get_unchecked(node.children, 0)
            let value = get_unchecked(node.children, 1)
            let val_idx = lower_expr(ctx, value)
            if target.kind == NK_IDENT() {
                let local_idx = ctx_lookup_local(ctx, clone(target.text))
                if local_idx >= 0 && val_idx >= 0 {
                    let set_inst = MirInst_new(MIR_LOCAL_SET())
                    set_inst.arg0 = local_idx
                    set_inst.arg1 = val_idx
                    ctx_emit(ctx, set_inst)
                }
            }
            if target.kind == NK_FIELD_ACCESS() {
                // struct field assignment: target.children[0] = struct, target.text = field
                let tc = len(target.children)
                if tc >= 1 {
                    let struct_node = get_unchecked(target.children, 0)
                    let mut struct_idx = 0
                    if struct_node.kind == NK_IDENT() {
                        // Simple base: look up local directly, no stack push
                        struct_idx = ctx_lookup_local(ctx, clone(struct_node.text))
                    } else {
                        // Complex base (chained field access): evaluate and save to temp
                        let raw_idx = lower_expr(ctx, struct_node)
                        let temp = ctx_fresh_local(ctx, VT_REF())
                        let save_inst = MirInst_new(MIR_LOCAL_SET())
                        save_inst.arg0 = temp
                        ctx_emit(ctx, save_inst)
                        struct_idx = temp
                    }
                    let set_inst = MirInst_new(MIR_STRUCT_SET())
                    set_inst.arg0 = struct_idx
                    set_inst.arg1 = val_idx
                    set_inst.str_val = clone(target.text)
                    // Resolve field index from struct type, then convert to byte offset
                    let base_type = ctx_get_local_type(ctx, struct_idx)
                    let mut fi_assign = 0
                    if len(base_type) > 0 {
                        fi_assign = ctx_field_index(ctx, clone(base_type), clone(target.text))
                        set_inst.int_val = ctx_struct_field_offset(ctx, clone(base_type), fi_assign)
                        if ctx_struct_field_is_f64(ctx, clone(base_type), fi_assign) {
                            set_inst.val_type = VT_F64()
                        }
                    } else {
                        fi_assign = ctx_field_index_any(ctx, clone(target.text))
                        set_inst.int_val = fi_assign * 4
                    }
                    ctx_emit(ctx, set_inst)
                }
            }
        }
        return 0 - 1
    }

    if kind == NK_STRUCT_LIT() {
        // text = struct name, children = field initializers
        // Each child: NK_IDENT with text=field_name, children[0]=value
        // If ..base is used, last child is NK_RANGE with children[0]=base expr
        let child_count = len(node.children)
        let struct_name = clone(node.text)
        let total_fields = ctx_struct_field_count(ctx, clone(struct_name))
        let dest = ctx_fresh_local(ctx, VT_REF())
        let new_inst = MirInst_new(MIR_STRUCT_NEW())
        new_inst.dest = dest
        new_inst.str_val = clone(struct_name)
        new_inst.int_val = ctx_struct_byte_size(ctx, clone(struct_name))
        ctx_emit(ctx, new_inst)

        // Track struct type for this local
        ctx_set_local_type(ctx, dest, clone(struct_name))

        // Check for spread base (NK_RANGE child)
        let mut base_idx = 0 - 1
        let mut has_base = false
        let mut f = 0
        while f < child_count {
            let field = get_unchecked(node.children, f)
            if field.kind == NK_RANGE() {
                // Lower the base expression (children[0] of the NK_RANGE node)
                let base_expr = get_unchecked(field.children, 0)
                base_idx = lower_expr(ctx, base_expr)
                has_base = true
            }
            f = f + 1
        }

        // If we have a spread base, first copy ALL fields from base
        if has_base {
            let mut fi = 0
            while fi < total_fields {
                let fname = ctx_struct_field_name(ctx, clone(struct_name), fi)
                let is_f64_field = ctx_struct_field_is_f64(ctx, clone(struct_name), fi)
                let mut field_vt = VT_I32()
                if is_f64_field { field_vt = VT_F64() }
                let tmp = ctx_fresh_local(ctx, field_vt)
                // Emit LOCAL_GET to push base ptr onto Wasm stack
                let get_base = MirInst_new(MIR_LOCAL_GET())
                get_base.arg0 = base_idx
                get_base.dest = base_idx
                ctx_emit(ctx, get_base)
                // STRUCT_GET reads from stack (base + offset), leaves value on stack
                let g = MirInst_new(MIR_STRUCT_GET())
                g.dest = tmp
                g.arg0 = base_idx
                g.str_val = clone(fname)
                g.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi)
                if is_f64_field { g.val_type = VT_F64() }
                ctx_emit(ctx, g)
                // STRUCT_SET consumes value from stack, stores into dest struct
                let s = MirInst_new(MIR_STRUCT_SET())
                s.arg0 = dest
                s.arg1 = tmp
                s.str_val = clone(fname)
                s.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi)
                if is_f64_field { s.val_type = VT_F64() }
                ctx_emit(ctx, s)
                fi = fi + 1
            }
        }

        // Then set explicitly provided fields (overwriting any base copies)
        f = 0
        while f < child_count {
            let field = get_unchecked(node.children, f)
            if field.kind != NK_RANGE() {
                let fc = len(field.children)
                if fc >= 1 {
                    let init = get_unchecked(field.children, 0)
                    let val_idx = lower_expr(ctx, init)
                    let fi_idx = ctx_field_index(ctx, clone(struct_name), clone(field.text))
                    let set_inst = MirInst_new(MIR_STRUCT_SET())
                    set_inst.arg0 = dest
                    set_inst.arg1 = val_idx
                    set_inst.str_val = clone(field.text)
                    set_inst.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi_idx)
                    if ctx_struct_field_is_f64(ctx, clone(struct_name), fi_idx) {
                        set_inst.val_type = VT_F64()
                    }
                    ctx_emit(ctx, set_inst)
                }
            }
            f = f + 1
        }

        // Push struct base pointer onto Wasm stack for caller
        let get_inst = MirInst_new(MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)

        return dest
    }

    if kind == NK_FIELD_ACCESS() {
        // children[0] = base struct expression, text = field name
        let child_count = len(node.children)
        if child_count >= 1 {
            let base = get_unchecked(node.children, 0)
            let base_idx = lower_expr(ctx, base)
            // Resolve field index and type from struct type
            let base_type = ctx_get_local_type(ctx, base_idx)
            let mut field_idx = 0
            let mut is_f64_field = false
            if len(base_type) > 0 {
                field_idx = ctx_field_index(ctx, clone(base_type), clone(node.text))
                is_f64_field = ctx_struct_field_is_f64(ctx, clone(base_type), field_idx)
            } else {
                field_idx = ctx_field_index_any(ctx, clone(node.text))
            }
            let mut dest_vt = VT_I32()
            if is_f64_field { dest_vt = VT_F64() }
            let dest = ctx_fresh_local(ctx, dest_vt)
            let get_inst = MirInst_new(MIR_STRUCT_GET())
            get_inst.dest = dest
            get_inst.arg0 = base_idx
            get_inst.str_val = clone(node.text)
            if len(base_type) > 0 {
                get_inst.int_val = ctx_struct_field_offset(ctx, clone(base_type), field_idx)
                if is_f64_field { get_inst.val_type = VT_F64() }
                // Propagate field type to dest for chained access / vec dispatch
                let ft = ctx_get_field_type(ctx, clone(base_type), clone(node.text))
                if len(ft) > 0 {
                    ctx_set_local_type(ctx, dest, ft)
                }
            } else {
                get_inst.int_val = field_idx * 4  // fallback: 4 bytes per field
            }
            ctx_emit(ctx, get_inst)
            return dest
        }
        return 0 - 1
    }

    if kind == NK_ARRAY_LIT() {
        // children = element expressions
        let child_count = len(node.children)
        let dest = ctx_fresh_local(ctx, VT_REF())
        let new_inst = MirInst_new(MIR_ARRAY_NEW())
        new_inst.dest = dest
        new_inst.int_val = child_count
        ctx_emit(ctx, new_inst)

        let mut e = 0
        while e < child_count {
            let elem = get_unchecked(node.children, e)
            let val_idx = lower_expr(ctx, elem)
            let set_inst = MirInst_new(MIR_ARRAY_SET())
            set_inst.arg0 = dest
            set_inst.arg1 = val_idx
            set_inst.int_val = e
            ctx_emit(ctx, set_inst)
            e = e + 1
        }

        // Push array base pointer onto Wasm stack for caller
        let get_inst = MirInst_new(MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)
        return dest
    }

    if kind == NK_INDEX() {
        // children[0] = base array, children[1] = index expression
        let child_count = len(node.children)
        if child_count >= 2 {
            let base = get_unchecked(node.children, 0)
            let idx_expr = get_unchecked(node.children, 1)
            let base_idx = lower_expr(ctx, base)
            let index_idx = lower_expr(ctx, idx_expr)
            let dest = ctx_fresh_local(ctx, VT_I32())
            ctx_set_local_type(ctx, dest, String_from("i32"))
            let get_inst = MirInst_new(MIR_ARRAY_GET())
            get_inst.dest = dest
            get_inst.arg0 = base_idx
            get_inst.arg1 = index_idx
            ctx_emit(ctx, get_inst)
            return dest
        }
        return 0 - 1
    }

    if kind == NK_TRY() {
        // expr? → if Ok, unwrap; if Err, return Err early
        // children[0] = inner expression (should return Result<T, E>)
        let child_count = len(node.children)
        if child_count >= 1 {
            let inner = get_unchecked(node.children, 0)
            let inner_idx = lower_expr(ctx, inner)
            // Save the result ptr
            let res_ptr = ctx_fresh_local(ctx, VT_I32())
            let save_res = MirInst_new(MIR_LOCAL_SET())
            save_res.arg0 = res_ptr
            ctx_emit(ctx, save_res)
            // Load tag
            let tag_local = ctx_fresh_local(ctx, VT_I32())
            let get_ptr = MirInst_new(MIR_LOCAL_GET())
            get_ptr.arg0 = res_ptr
            ctx_emit(ctx, get_ptr)
            let sget_tag = MirInst_new(MIR_STRUCT_GET())
            sget_tag.int_val = 0
            ctx_emit(ctx, sget_tag)
            let set_tag = MirInst_new(MIR_LOCAL_SET())
            set_tag.arg0 = tag_local
            ctx_emit(ctx, set_tag)
            // Check if Err (tag != 0): return the Result as-is
            let get_tag = MirInst_new(MIR_LOCAL_GET())
            get_tag.arg0 = tag_local
            ctx_emit(ctx, get_tag)
            ctx_emit(ctx, MirInst_new(MIR_IF()))
            let get_ret = MirInst_new(MIR_LOCAL_GET())
            get_ret.arg0 = res_ptr
            ctx_emit(ctx, get_ret)
            let ret_inst = MirInst_new(MIR_RETURN())
            ctx_emit(ctx, ret_inst)
            ctx_emit(ctx, MirInst_new(MIR_END()))
            // Ok path: extract payload (field 1)
            let result = ctx_fresh_local(ctx, VT_I32())
            let get_ok = MirInst_new(MIR_LOCAL_GET())
            get_ok.arg0 = res_ptr
            ctx_emit(ctx, get_ok)
            let sget_payload = MirInst_new(MIR_STRUCT_GET())
            sget_payload.int_val = 4
            ctx_emit(ctx, sget_payload)
            let set_result = MirInst_new(MIR_LOCAL_SET())
            set_result.arg0 = result
            ctx_emit(ctx, set_result)
            let get_result = MirInst_new(MIR_LOCAL_GET())
            get_result.arg0 = result
            ctx_emit(ctx, get_result)
            return result
        }
        return 0 - 1
    }

    // Loop expression: delegate to stmt handler which has full loop logic
    if kind == NK_LOOP() {
        return lower_stmt(ctx, node)
    }

    // While expression: delegate to stmt handler
    if kind == NK_WHILE() {
        return lower_stmt(ctx, node)
    }

    // For expression: delegate to stmt handler  
    if kind == NK_FOR() {
        return lower_stmt(ctx, node)
    }

    // NK_CLOSURE: lambda-lift to a synthetic function; captures passed at each call site (#499).
    if kind == NK_CLOSURE() {
        let caps = Vec_new_String()
        closure_collect_free(ctx, node, node, caps)
        let packed = closure_pack_caps(caps)
        let extra = len(caps)
        let synth = concat(String_from("__closure_"), to_string(ctx.closure_counter))
        ctx.closure_counter = ctx.closure_counter + 1
        let mf = mir_emit_closure_fn(ctx, synth, node, caps)
        push(ctx.module.functions, mf)
        push(ctx.fn_names, clone(mf.name))
        push(ctx.fn_return_vts, mf.return_type)
        ctx.closure_last_synth = clone(mf.name)
        ctx.closure_last_caps = packed
        ctx.closure_last_extra = extra
        let dest = ctx_fresh_local(ctx, VT_I32())
        ctx_emit(ctx, MirInst_const_i32(0, dest))
        return dest
    }

    // Unknown expression: emit NOP
    ctx_emit(ctx, MirInst_new(MIR_NOP()))
    0 - 1
}

// Lower a statement node. Returns local index if it produces a value.
fn lower_stmt(ctx: LowerCtx, node: AstNode) -> i32 {
    let kind = node.kind

    if kind == NK_LET() {
        // text = binding name, children[0] = init expr (if present)
        // Determine val_type from type annotation (default i32)
        let mut vt = VT_I32()
        let ta_count = len(node.type_ann)
        if ta_count >= 1 {
            let ta_pre = get_unchecked(node.type_ann, 0)
            if eq(clone(ta_pre.text), "f64") {
                vt = VT_F64()
            }
        }
        // Infer f64 from init expression when no annotation
        if vt == VT_I32() && ta_count == 0 && len(node.children) >= 1 {
            let init_peek = get_unchecked(node.children, 0)
            if init_peek.kind == NK_FLOAT_LIT() {
                vt = VT_F64()
            }
            // Check binary expr with float operands
            if init_peek.kind == NK_BINARY() && len(init_peek.children) >= 2 {
                let lhs_peek = get_unchecked(init_peek.children, 0)
                let rhs_peek = get_unchecked(init_peek.children, 1)
                if lhs_peek.kind == NK_FLOAT_LIT() || rhs_peek.kind == NK_FLOAT_LIT() {
                    vt = VT_F64()
                }
            }
        }
        let local_idx = ctx_alloc_local(ctx, clone(node.text), vt)

        // Check type annotation for primitive types and struct types
        if ta_count >= 1 {
            let ta = get_unchecked(node.type_ann, 0)
            let ta_name = clone(ta.text)
            if eq(clone(ta_name), "char") || eq(clone(ta_name), "u8") || eq(clone(ta_name), "u16") || eq(clone(ta_name), "u32") || eq(clone(ta_name), "i16") || eq(clone(ta_name), "i32") || eq(clone(ta_name), "i64") || eq(clone(ta_name), "bool") || eq(clone(ta_name), "f64") {
                ctx_set_local_type(ctx, local_idx, ta_name)
            } else if ctx_struct_field_count(ctx, clone(ta_name)) > 0 {
                // Known struct type from type annotation
                ctx_set_local_type(ctx, local_idx, ta_name)
            }
            // NK_TYPE_GENERIC = 91: Vec<T>, Result<T,E>, Option<T> annotation
            if ta.kind == 91 {
                if eq(clone(ta_name), "Vec") {
                    if len(ta.children) >= 2 {
                        let elem_ty = get_unchecked(ta.children, 1)
                        ctx_set_local_type(ctx, local_idx, concat(String_from("vec:"), clone(elem_ty.text)))
                    } else {
                        ctx_set_local_type(ctx, local_idx, String_from("vec"))
                    }
                } else if eq(clone(ta_name), "Result") {
                    if len(ta.children) >= 2 {
                        let ok_ty = get_unchecked(ta.children, 1)
                        if eq(clone(ok_ty.text), "f64") {
                            ctx_set_local_type(ctx, local_idx, String_from("Result_f64"))
                        }
                    }
                } else if eq(clone(ta_name), "Option") {
                    if len(ta.children) >= 2 {
                        let some_ty = get_unchecked(ta.children, 1)
                        if eq(clone(some_ty.text), "f64") {
                            ctx_set_local_type(ctx, local_idx, String_from("Option_f64"))
                        }
                    }
                }
            } else if eq(clone(ta_name), "Vec") {
                ctx_set_local_type(ctx, local_idx, String_from("vec"))
            }
        }

        let child_count = len(node.children)
        if child_count >= 1 {
            let init = get_unchecked(node.children, 0)
            let val_idx = lower_expr(ctx, init)
            if val_idx >= 0 {
                // Post-correct local VT if init is f64 but local was allocated as i32
                if ctx_local_vt(ctx, val_idx) == VT_F64() && ctx_local_vt(ctx, local_idx) == VT_I32() {
                    ctx_set_local_vt(ctx, local_idx, VT_F64())
                }
                let set_inst = MirInst_new(MIR_LOCAL_SET())
                set_inst.arg0 = local_idx
                set_inst.arg1 = val_idx
                ctx_emit(ctx, set_inst)
                // Propagate struct type from init expression to local
                let init_type = ctx_get_local_type(ctx, val_idx)
                if len(init_type) > 0 {
                    ctx_set_local_type(ctx, local_idx, init_type)
                }
                // Infer type from literal kind when no annotation and no propagated type
                if ta_count == 0 && len(ctx_get_local_type(ctx, local_idx)) == 0 {
                    if init.kind == NK_INT_LIT() {
                        ctx_set_local_type(ctx, local_idx, String_from("i32"))
                    } else if init.kind == NK_FLOAT_LIT() {
                        ctx_set_local_type(ctx, local_idx, String_from("f64"))
                    } else if init.kind == NK_BOOL_LIT() {
                        ctx_set_local_type(ctx, local_idx, String_from("bool"))
                    } else if init.kind == NK_CHAR_LIT() {
                        ctx_set_local_type(ctx, local_idx, String_from("char"))
                    }
                }
            }
            if init.kind == NK_CLOSURE() {
                if !eq(clone(node.text), String_from("_")) {
                    closure_flush_pending_bind(ctx, clone(node.text))
                } else {
                    ctx.closure_last_synth = String_new()
                    ctx.closure_last_caps = String_new()
                    ctx.closure_last_extra = 0
                }
            }
        }
        return 0 - 1
    }

    if kind == NK_RETURN() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let val_idx = lower_expr(ctx, expr)
            let ret_inst = MirInst_new(MIR_RETURN())
            ret_inst.arg0 = val_idx
            ctx_emit(ctx, ret_inst)
        } else {
            ctx_emit(ctx, MirInst_new(MIR_RETURN()))
        }
        return 0 - 1
    }

    if kind == NK_WHILE() {
        // children[0] = condition, children[1] = body
        let child_count = len(node.children)
        if child_count >= 2 {
            // Emit: block { loop { cond; i32.eqz; br_if 1; body; br 0; end; } end; }
            let prev_break = ctx.loop_break_depth
            let prev_continue = ctx.loop_continue_depth

            // BLOCK (break target)
            ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth

            // LOOP (continue target)
            ctx_emit(ctx, MirInst_new(MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_continue_depth = ctx.nesting_depth

            // Condition
            let cond = get_unchecked(node.children, 0)
            let cond_idx = lower_expr(ctx, cond)

            // i32.eqz (negate condition: break when cond is false)
            let eqz_dest = ctx_fresh_local(ctx, VT_I32())
            let eqz_inst = MirInst_new(MIR_EQZ())
            eqz_inst.dest = eqz_dest
            eqz_inst.arg0 = cond_idx
            ctx_emit(ctx, eqz_inst)

            // br_if 1 (break to outer block if cond is false)
            let br_break = MirInst_new(MIR_BR_IF())
            br_break.int_val = 1
            ctx_emit(ctx, br_break)

            // Body
            let body = get_unchecked(node.children, 1)
            let _body_result = lower_expr(ctx, body)

            // br 0 (loop back)
            let br_loop = MirInst_new(MIR_BR())
            br_loop.int_val = 0
            ctx_emit(ctx, br_loop)

            // END loop
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1

            // END block
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1

            ctx.loop_break_depth = prev_break
            ctx.loop_continue_depth = prev_continue
        }
        return 0 - 1
    }

    if kind == NK_LOOP() {
        // children[0] = body
        let child_count = len(node.children)
        if child_count >= 1 {
            let prev_break = ctx.loop_break_depth
            let prev_continue = ctx.loop_continue_depth
            let prev_break_local = ctx.loop_break_local

            // Allocate a local for break value
            let break_result = ctx_fresh_local(ctx, VT_I32())
            ctx.loop_break_local = break_result

            // BLOCK (break target)
            ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth

            // LOOP (continue target)
            ctx_emit(ctx, MirInst_new(MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_continue_depth = ctx.nesting_depth

            let body = get_unchecked(node.children, 0)
            let _body_result = lower_expr(ctx, body)

            // br 0 (loop back)
            let br_back = MirInst_new(MIR_BR())
            br_back.int_val = 0
            ctx_emit(ctx, br_back)

            // END loop
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1

            // END block
            ctx_emit(ctx, MirInst_new(MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1

            ctx.loop_break_depth = prev_break
            ctx.loop_continue_depth = prev_continue
            ctx.loop_break_local = prev_break_local

            // Push the break result local
            let get_result = MirInst_new(MIR_LOCAL_GET())
            get_result.arg0 = break_result
            ctx_emit(ctx, get_result)
            return break_result
        }
        return 0 - 1
    }

    if kind == NK_BREAK() {
        if ctx.loop_break_depth >= 0 {
            // If break has a value expression, store it in the break-result local
            let break_children = len(node.children)
            if break_children > 0 && ctx.loop_break_local >= 0 {
                let break_val = get_unchecked(node.children, 0)
                let _bv = lower_expr(ctx, break_val)
                let set_inst = MirInst_new(MIR_LOCAL_SET())
                set_inst.arg0 = ctx.loop_break_local
                ctx_emit(ctx, set_inst)
            }
            let br_inst = MirInst_new(MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_break_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }

    if kind == NK_CONTINUE() {
        if ctx.loop_continue_depth >= 0 {
            let br_inst = MirInst_new(MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_continue_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }

    // For loop: for i in start..end { body }
    // children[0] = range expr (NK_RANGE with children[0]=start, children[1]=end)
    // children[1] = body block
    // node.text = loop variable name
    if kind == NK_FOR() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let range = get_unchecked(node.children, 0)
            let body = get_unchecked(node.children, 1)

            // Get range bounds
            let range_child_count = len(range.children)
            // Check for values(vec) form: for x in values(v)
            // NK_CALL children: [0]=callee, [1..]=args
            let mut is_values_call = range.kind == NK_CALL() && range_child_count >= 2
            let mut values_callee_match = false
            if is_values_call {
                let range_callee = get_unchecked(range.children, 0)
                values_callee_match = eq(clone(range_callee.text), "values")
            }
            if values_callee_match {
                // for x in values(v) => for _i in 0..len(v), x = get_unchecked(v, _i)
                let vec_arg = get_unchecked(range.children, 1)
                let vec_idx = lower_expr(ctx, vec_arg)

                // Store vec ptr in a local (value is on stack from lower_expr)
                let vec_local = ctx_fresh_local(ctx, VT_I32())
                let set_vec = MirInst_new(MIR_LOCAL_SET())
                set_vec.arg0 = vec_local
                ctx_emit(ctx, set_vec)

                // Compute len(vec) via vec_len builtin: push vec, call vec_len, store result
                let get_vec_len = MirInst_new(MIR_LOCAL_GET())
                get_vec_len.arg0 = vec_local
                ctx_emit(ctx, get_vec_len)
                let len_call = MirInst_new(MIR_CALL())
                len_call.str_val = String_from("vec_len")
                len_call.int_val = 1
                let end_local = ctx_fresh_local(ctx, VT_I32())
                len_call.dest = end_local
                ctx_emit(ctx, len_call)
                // Store len result from stack
                let set_end = MirInst_new(MIR_LOCAL_SET())
                set_end.arg0 = end_local
                ctx_emit(ctx, set_end)

                // Hidden index variable starting at 0
                let idx_var = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(0, idx_var))
                let set_idx_init = MirInst_new(MIR_LOCAL_SET())
                set_idx_init.arg0 = idx_var
                ctx_emit(ctx, set_idx_init)

                // User-visible loop variable
                let iter_var = ctx_alloc_local(ctx, clone(node.text), VT_I32())

                let prev_break = ctx.loop_break_depth
                let prev_continue = ctx.loop_continue_depth

                // BLOCK (break target)
                ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_break_depth = ctx.nesting_depth

                // LOOP (continue target)
                ctx_emit(ctx, MirInst_new(MIR_LOOP()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_continue_depth = ctx.nesting_depth

                // Check: if idx >= len, break
                let get_idx_cmp = MirInst_new(MIR_LOCAL_GET())
                get_idx_cmp.arg0 = idx_var
                ctx_emit(ctx, get_idx_cmp)
                let get_end_cmp = MirInst_new(MIR_LOCAL_GET())
                get_end_cmp.arg0 = end_local
                ctx_emit(ctx, get_end_cmp)
                let cmp_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_binop(MIR_GTEQ(), cmp_dest, idx_var, end_local))
                let br_break = MirInst_new(MIR_BR_IF())
                br_break.int_val = 1
                ctx_emit(ctx, br_break)

                // x = get_unchecked(vec, idx): push vec, push idx, call, store to iter_var
                let get_vec_gu = MirInst_new(MIR_LOCAL_GET())
                get_vec_gu.arg0 = vec_local
                ctx_emit(ctx, get_vec_gu)
                let get_idx_gu = MirInst_new(MIR_LOCAL_GET())
                get_idx_gu.arg0 = idx_var
                ctx_emit(ctx, get_idx_gu)
                let gu_call = MirInst_new(MIR_CALL())
                gu_call.str_val = String_from("vec_get_unchecked")
                gu_call.int_val = 2
                gu_call.dest = iter_var
                ctx_emit(ctx, gu_call)
                let set_elem = MirInst_new(MIR_LOCAL_SET())
                set_elem.arg0 = iter_var
                ctx_emit(ctx, set_elem)

                // Body
                let _body_result = lower_expr(ctx, body)

                // Increment: idx = idx + 1
                let get_idx_inc = MirInst_new(MIR_LOCAL_GET())
                get_idx_inc.arg0 = idx_var
                ctx_emit(ctx, get_idx_inc)
                let one_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(1, one_dest))
                let add_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_binop(MIR_ADD(), add_dest, idx_var, one_dest))
                let set_idx = MirInst_new(MIR_LOCAL_SET())
                set_idx.arg0 = idx_var
                ctx_emit(ctx, set_idx)

                // br 0 (loop back)
                let br_loop = MirInst_new(MIR_BR())
                br_loop.int_val = 0
                ctx_emit(ctx, br_loop)

                // END loop
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1

                // END block
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1

                ctx.loop_break_depth = prev_break
                ctx.loop_continue_depth = prev_continue
            } else if range_child_count >= 2 {
                let start_node = get_unchecked(range.children, 0)
                let end_node = get_unchecked(range.children, 1)

                // Lower start — leaves value on stack
                let start_idx = lower_expr(ctx, start_node)

                // Create loop variable and store start value from stack
                let iter_var = ctx_alloc_local(ctx, clone(node.text), VT_I32())
                let set_init = MirInst_new(MIR_LOCAL_SET())
                set_init.arg0 = iter_var
                ctx_emit(ctx, set_init)

                // Lower end — leaves value on stack
                let end_idx = lower_expr(ctx, end_node)
                // Store end value to its local so we can reference it in the loop
                let end_local = ctx_fresh_local(ctx, VT_I32())
                let set_end = MirInst_new(MIR_LOCAL_SET())
                set_end.arg0 = end_local
                ctx_emit(ctx, set_end)

                let prev_break = ctx.loop_break_depth
                let prev_continue = ctx.loop_continue_depth

                // BLOCK (break target)
                ctx_emit(ctx, MirInst_new(MIR_BLOCK()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_break_depth = ctx.nesting_depth

                // LOOP (continue target)
                ctx_emit(ctx, MirInst_new(MIR_LOOP()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_continue_depth = ctx.nesting_depth

                // Check: if iter >= end, break
                let get_iter = MirInst_new(MIR_LOCAL_GET())
                get_iter.arg0 = iter_var
                ctx_emit(ctx, get_iter)
                let get_end = MirInst_new(MIR_LOCAL_GET())
                get_end.arg0 = end_local
                ctx_emit(ctx, get_end)
                let cmp_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_binop(MIR_GTEQ(), cmp_dest, iter_var, end_local))
                let br_break = MirInst_new(MIR_BR_IF())
                br_break.int_val = 1
                ctx_emit(ctx, br_break)

                // Body
                let _body_result = lower_expr(ctx, body)

                // Increment: iter = iter + 1
                let get_iter2 = MirInst_new(MIR_LOCAL_GET())
                get_iter2.arg0 = iter_var
                ctx_emit(ctx, get_iter2)
                let one_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_const_i32(1, one_dest))
                let add_dest = ctx_fresh_local(ctx, VT_I32())
                ctx_emit(ctx, MirInst_binop(MIR_ADD(), add_dest, iter_var, one_dest))
                let set_iter = MirInst_new(MIR_LOCAL_SET())
                set_iter.arg0 = iter_var
                ctx_emit(ctx, set_iter)

                // br 0 (loop back)
                let br_loop = MirInst_new(MIR_BR())
                br_loop.int_val = 0
                ctx_emit(ctx, br_loop)

                // END loop
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1

                // END block
                ctx_emit(ctx, MirInst_new(MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1

                ctx.loop_break_depth = prev_break
                ctx.loop_continue_depth = prev_continue
            }
        }
        return 0 - 1
    }

    if kind == NK_EXPR_STMT() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let result = lower_expr(ctx, expr)
            return result
        }
        return 0 - 1
    }

    // Expression in statement position
    lower_expr(ctx, node)
}

pub fn lower_to_mir(decls: Vec<AstNode>, check_result: TypeCheckResult) -> MirModule {
    let m = MirModule_new()

    // Build function name→index map from declarations
    let decl_count = len(decls)
    let mut fn_names = Vec_new_String()
    let mut fn_return_vts = Vec_new_i32()
    let mut fn_index = 0
    let typed_fn_count = len(check_result.typed_fns)
    let mut d = 0
    while d < decl_count {
        let decl = get_unchecked(decls, d)
        if decl.kind == NK_FN_DECL() {
            push(fn_names, clone(decl.text))
            // Record return vt for void detection: VT_VOID=0, VT_I32=1, VT_F64=3
            let mut rvt = VT_I32()
            if fn_index < typed_fn_count {
                let tf = get_unchecked(check_result.typed_fns, fn_index)
                let rt_tag = tf.return_type.tag
                if rt_tag == 3 {
                    rvt = VT_F64()
                } else if rt_tag == 7 || rt_tag == 8 || rt_tag == 0 {
                    rvt = VT_VOID()
                }
            }
            push(fn_return_vts, rvt)
            fn_index = fn_index + 1
        }
        d = d + 1
    }

    // Lower each function
    let mut ctx = LowerCtx_new(m)
    ctx.fn_names = fn_names
    ctx.fn_return_vts = fn_return_vts
    ctx_register_builtin_variants(ctx)

    // Collect struct definitions for field index resolution
    // NK_STRUCT_DECL = 51 (from parser.ark)
    let mut sd = 0
    while sd < decl_count {
        let decl = get_unchecked(decls, sd)
        if decl.kind == 51 {
            push(ctx.struct_names, clone(decl.text))
            let fc = len(decl.children)
            push(ctx.struct_field_counts, fc)
            let mut fi = 0
            while fi < fc {
                let field = get_unchecked(decl.children, fi)
                push(ctx.struct_all_fields, clone(field.text))
                // Track field types for type propagation through field access
                let mut field_type_str = String_from("")
                if len(field.type_ann) > 0 {
                    let fty = get_unchecked(field.type_ann, 0)
                    // NK_TYPE_GENERIC = 91 → Vec<X>, NK_TYPE_NAMED = 90
                    if fty.kind == 91 {
                        if eq(clone(fty.text), "Vec") {
                            if len(fty.children) >= 2 {
                                let elem_ty = get_unchecked(fty.children, 1)
                                field_type_str = concat(String_from("vec:"), clone(elem_ty.text))
                            }
                        }
                    } else if fty.kind == 90 {
                        let ty_text = clone(fty.text)
                        // Track f64 fields for proper layout; track struct types for chaining
                        if eq(clone(ty_text), "f64") {
                            field_type_str = String_from("f64")
                        } else if !eq(clone(ty_text), "i32") && !eq(clone(ty_text), "i64") && !eq(clone(ty_text), "bool") && !eq(clone(ty_text), "String") && !eq(clone(ty_text), "u8") {
                            field_type_str = ty_text
                        }
                    }
                }
                push(ctx.struct_field_types, field_type_str)
                fi = fi + 1
            }
        }
        // NK_ENUM_DECL = 52: collect variant→tag mapping
        if decl.kind == 52 {
            let vc = len(decl.children)
            // Check if any variant has fields (payload enum)
            // Note: variant fields are stored in type_ann, not children
            let mut has_payload = false
            let mut vcheck = 0
            while vcheck < vc {
                let vc_node = get_unchecked(decl.children, vcheck)
                if len(vc_node.type_ann) > 0 {
                    has_payload = true
                }
                vcheck = vcheck + 1
            }
            let mut vi = 0
            while vi < vc {
                let variant = get_unchecked(decl.children, vi)
                let full_name = concat(clone(decl.text), concat(String_from("::"), clone(variant.text)))
                push(ctx.variant_names, full_name)
                push(ctx.variant_tags, vi)
                if has_payload {
                    push(ctx.payload_variants, clone(full_name))
                    // Register payload variant as pseudo-struct for field type tracking
                    // Field 0 = tag (i32), Field 1+ = payload fields (from type_ann)
                    let payload_count = len(variant.type_ann)
                    push(ctx.struct_names, clone(full_name))
                    push(ctx.struct_field_counts, payload_count + 1)
                    // Field 0: tag
                    push(ctx.struct_all_fields, String_from("_tag"))
                    push(ctx.struct_field_types, String_from(""))
                    // Payload fields
                    let mut pfi = 0
                    while pfi < payload_count {
                        let pfield = get_unchecked(variant.type_ann, pfi)
                        push(ctx.struct_all_fields, concat(String_from("_"), to_string(pfi)))
                        // Check if payload field is f64
                        if eq(clone(pfield.text), "f64") {
                            push(ctx.struct_field_types, String_from("f64"))
                        } else {
                            push(ctx.struct_field_types, String_from(""))
                        }
                        pfi = pfi + 1
                    }
                }
                vi = vi + 1
            }
        }
        sd = sd + 1
    }

    let mut i = 0
    let mut fn_idx = 0
    while i < decl_count {
        let decl = get_unchecked(decls, i)
        if decl.kind == NK_FN_DECL() {
            let tf = get_unchecked(check_result.typed_fns, fn_idx)
            let mf = MirFunction_new(clone(decl.text))
            ctx.func = mf
            ctx.local_names = Vec_new_String()
            ctx.local_indices = Vec_new_i32()
            ctx.local_types = Vec_new_String()
            ctx.local_type_indices = Vec_new_i32()

            // Allocate parameters as locals AND register in f.params
            let child_count = len(decl.children)
            let body_idx = child_count - 1
            let mut p = 0
            while p < body_idx {
                let param = get_unchecked(decl.children, p)
                if param.kind == NK_IDENT() {
                    // Determine param val_type from type annotation
                    let mut pvt = VT_I32()
                    if len(param.type_ann) >= 1 {
                        let pta = get_unchecked(param.type_ann, 0)
                        if eq(clone(pta.text), "f64") {
                            pvt = VT_F64()
                        }
                    }
                    let param_local = ctx_alloc_local(ctx, clone(param.text), pvt)
                    push(ctx.func.params, MirLocal { name: clone(param.text), val_type: pvt, ssa_name: clone(param.text), ssa_version: 0 - 1 })
                    // Register type for Vec/struct parameters so len/get_unchecked dispatch works
                    if len(param.type_ann) >= 1 {
                        let p_ty = get_unchecked(param.type_ann, 0)
                        if p_ty.kind == 91 {  // NK_TYPE_GENERIC
                            if eq(clone(p_ty.text), "Vec") && len(p_ty.children) >= 2 {
                                let p_elem = get_unchecked(p_ty.children, 1)
                                ctx_set_local_type(ctx, param_local, concat(String_from("vec:"), clone(p_elem.text)))
                            }
                        } else if p_ty.kind == 90 {  // NK_TYPE_NAMED
                            let p_ty_name = clone(p_ty.text)
                            if !eq(clone(p_ty_name), "i32") && !eq(clone(p_ty_name), "f64") && !eq(clone(p_ty_name), "bool") && !eq(clone(p_ty_name), "String") && !eq(clone(p_ty_name), "u8") && !eq(clone(p_ty_name), "char") {
                                ctx_set_local_type(ctx, param_local, p_ty_name)
                            }
                        }
                    }
                }
                p = p + 1
            }

            // Set return type from type-check result
            // TY_I32=1, TY_I64=2, TY_F64=3, TY_BOOL=4, TY_STRING=5, TY_CHAR=6
            // TY_UNIT=7 means void, TY_UNKNOWN=0 means unresolved
            // TY_VEC=10, TY_OPTION=11, TY_RESULT=12, TY_STRUCT=21, TY_ENUM=22, TY_TUPLE=23
            let rt_tag = tf.return_type.tag
            if rt_tag == 3 {
                ctx.func.return_type = VT_F64()
            } else if rt_tag >= 1 && rt_tag <= 6 {
                // covers i32(1), i64(2), f64(3), bool(4), String(5), char(6)
                ctx.func.return_type = VT_I32()
            }
            // Struct/enum/vec/option/result/tuple return as i32 pointer
            if rt_tag >= 10 && rt_tag <= 12 {
                ctx.func.return_type = VT_I32()
            }
            if rt_tag >= 20 && rt_tag <= 23 {
                ctx.func.return_type = VT_I32()
            }

            // Create entry block
            let entry = alloc_block(ctx.func)
            ctx.cur_block = entry

            // Lower body (last child is the block)
            if body_idx >= 0 {
                let body = get_unchecked(decl.children, body_idx)
                let result = lower_expr(ctx, body)
                // Implicit return if function has return type
                if result >= 0 {
                    let ret_inst = MirInst_new(MIR_RETURN())
                    ret_inst.arg0 = result
                    ctx_emit(ctx, ret_inst)
                } else {
                    ctx_emit(ctx, MirInst_new(MIR_RETURN()))
                }
            }

            push(ctx.module.functions, ctx.func)
            fn_idx = fn_idx + 1
        }
        i = i + 1
    }

    mir_compute_dominance(ctx.module)
    mir_ssa_rename_module(ctx.module)
    ctx.module
}

// ── MIR Dump ─────────────────────────────────────────────────────────────────

pub fn dump_mir(m: MirModule) {
    mir_compute_dominance(m)
    mir_ssa_rename_module(m)
    let fn_count = len(m.functions)
    stdio::eprintln(concat(String_from("MIR module: "), concat(to_string(fn_count), String_from(" function(s)"))))
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        let block_count = len(f.blocks)
        let local_count = len(f.locals)
        stdio::eprintln(concat(String_from("  fn "), concat(clone(f.name), concat(String_from(" ("), concat(to_string(local_count), concat(String_from(" locals, "), concat(to_string(block_count), String_from(" blocks)"))))))))
        let mut b = 0
        while b < block_count {
            let block = get_unchecked(f.blocks, b)
            let phi_count = len(block.phis)
            let inst_count = len(block.instructions)
            let mut block_msg = concat(String_from("    bb"), to_string(b))
            block_msg = concat(block_msg, String_from(": phis="))
            block_msg = concat(block_msg, to_string(phi_count))
            block_msg = concat(block_msg, String_from(" instructions="))
            block_msg = concat(block_msg, to_string(inst_count))
            block_msg = concat(block_msg, String_from(" succs="))
            block_msg = concat(block_msg, mir_format_edges(block.succ0, block.succ1))
            block_msg = concat(block_msg, String_from(" preds="))
            block_msg = concat(block_msg, mir_format_block_ids(block.preds))
            block_msg = concat(block_msg, String_from(" idom="))
            block_msg = concat(block_msg, mir_format_edge(block.idom))
            block_msg = concat(block_msg, String_from(" df="))
            block_msg = concat(block_msg, mir_format_block_ids(block.dom_frontier))
            stdio::eprintln(block_msg)
            let mut p = 0
            while p < phi_count {
                let phi = get_unchecked(block.phis, p)
                stdio::eprintln(concat(String_from("      "), mir_format_phi(f, phi)))
                p = p + 1
            }
            let mut j = 0
            while j < inst_count {
                let inst = get_unchecked(block.instructions, j)
                stdio::eprintln(concat(String_from("      "), concat(mir_op_name(inst.op), concat(String_from(" -> "), mir_format_local_ref(f, inst.dest)))))
                j = j + 1
            }
            b = b + 1
        }
        i = i + 1
    }
    let str_count = len(m.string_constants)
    if str_count > 0 {
        stdio::eprintln(concat(String_from("  strings: "), to_string(str_count)))
    }
}

fn mir_op_name(op: i32) -> String {
    if op == MIR_CONST_I32() { return String_from("const.i32") }
    if op == MIR_CONST_I64() { return String_from("const.i64") }
    if op == MIR_CONST_F64() { return String_from("const.f64") }
    if op == MIR_CONST_STRING() { return String_from("const.string") }
    if op == MIR_LOCAL_GET() { return String_from("local.get") }
    if op == MIR_LOCAL_SET() { return String_from("local.set") }
    if op == MIR_ADD() { return String_from("add") }
    if op == MIR_SUB() { return String_from("sub") }
    if op == MIR_MUL() { return String_from("mul") }
    if op == MIR_DIV() { return String_from("div") }
    if op == MIR_MOD() { return String_from("mod") }
    if op == MIR_EQ() { return String_from("eq") }
    if op == MIR_NEQ() { return String_from("neq") }
    if op == MIR_LT() { return String_from("lt") }
    if op == MIR_LTEQ() { return String_from("le") }
    if op == MIR_GT() { return String_from("gt") }
    if op == MIR_GTEQ() { return String_from("ge") }
    if op == MIR_AND() { return String_from("and") }
    if op == MIR_OR() { return String_from("or") }
    if op == MIR_NEG() { return String_from("neg") }
    if op == MIR_NOT() { return String_from("not") }
    if op == MIR_CALL() { return String_from("call") }
    if op == MIR_RETURN() { return String_from("return") }
    if op == MIR_BR() { return String_from("br") }
    if op == MIR_BR_IF() { return String_from("br_if") }
    if op == MIR_BLOCK() { return String_from("block") }
    if op == MIR_LOOP() { return String_from("loop") }
    if op == MIR_IF() { return String_from("if") }
    if op == MIR_STRUCT_NEW() { return String_from("struct.new") }
    if op == MIR_STRUCT_GET() { return String_from("struct.get") }
    if op == MIR_STRUCT_SET() { return String_from("struct.set") }
    if op == MIR_ARRAY_NEW() { return String_from("array.new") }
    if op == MIR_ARRAY_GET() { return String_from("array.get") }
    if op == MIR_ARRAY_SET() { return String_from("array.set") }
    if op == MIR_ARRAY_LEN() { return String_from("array.len") }
    if op == MIR_DROP() { return String_from("drop") }
    if op == MIR_NOP() { return String_from("nop") }
    if op == MIR_UNREACHABLE() { return String_from("unreachable") }
    if op == MIR_PHI() { return String_from("phi") }
    String_from("?op")
}

fn mir_value_type_name(vt: i32) -> String {
    if vt == VT_I32() { return String_from("i32") }
    if vt == VT_I64() { return String_from("i64") }
    if vt == VT_F64() { return String_from("f64") }
    if vt == VT_REF() { return String_from("ref") }
    if vt == VT_VOID() { return String_from("void") }
    String_from("?")
}

fn mir_format_local_ref(f: MirFunction, local_id: i32) -> String {
    if local_id < 0 {
        return String_from("%-")
    }
    if local_id >= len(f.locals) {
        return concat(String_from("%"), to_string(local_id))
    }
    let local = get_unchecked(f.locals, local_id)
    if local.ssa_version >= 0 {
        let mut out = String_from("%")
        out = concat(out, clone(local.ssa_name))
        out = concat(out, String_from("."))
        return concat(out, to_string(local.ssa_version))
    }
    concat(String_from("%"), to_string(local_id))
}

fn mir_format_phi_args(f: MirFunction, args: Vec<MirPhiArg>) -> String {
    let count = len(args)
    let mut out = String_from("[")
    let mut i = 0
    while i < count {
        let arg = get_unchecked(args, i)
        if i > 0 {
            out = concat(out, String_from(", "))
        }
        out = concat(out, String_from("bb"))
        out = concat(out, to_string(arg.pred_block))
        out = concat(out, String_from(" -> "))
        out = concat(out, mir_format_local_ref(f, arg.local))
        i = i + 1
    }
    concat(out, String_from("]"))
}

fn mir_format_phi(f: MirFunction, phi: MirPhi) -> String {
    let mut out = mir_op_name(phi.op)
    out = concat(out, String_from(" "))
    out = concat(out, mir_format_local_ref(f, phi.dest))
    out = concat(out, String_from(" = "))
    out = concat(out, mir_format_phi_args(f, phi.args))
    out = concat(out, String_from(" : "))
    concat(out, mir_value_type_name(phi.val_type))
}

fn mir_format_block_ids(ids: Vec<i32>) -> String {
    let count = len(ids)
    let mut out = String_from("[")
    let mut i = 0
    while i < count {
        if i > 0 {
            out = concat(out, String_from(","))
        }
        out = concat(out, to_string(get_unchecked(ids, i)))
        i = i + 1
    }
    concat(out, String_from("]"))
}

fn mir_format_edge(edge: i32) -> String {
    if edge < 0 {
        return String_from("-")
    }
    to_string(edge)
}

fn mir_format_edges(succ0: i32, succ1: i32) -> String {
    concat(String_from("["), concat(mir_format_edge(succ0), concat(String_from(","), concat(mir_format_edge(succ1), String_from("]")))))
}

fn mir_expect_preds(f: MirFunction, block_id: i32, expected_count: i32, expected0: i32, expected1: i32) {
    let block = get_unchecked(f.blocks, block_id)
    let actual_count = len(block.preds)
    if actual_count != expected_count {
        let msg = concat(String_from("pred check failed for bb"), concat(to_string(block_id), concat(String_from(": expected count="), concat(to_string(expected_count), concat(String_from(" actual="), concat(to_string(actual_count), concat(String_from(" preds="), mir_format_block_ids(block.preds))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 && get_unchecked(block.preds, 0) != expected0 {
        let msg = concat(String_from("pred check failed for bb"), concat(to_string(block_id), concat(String_from(": expected preds="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.preds)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 1 && get_unchecked(block.preds, 1) != expected1 {
        let msg = concat(String_from("pred check failed for bb"), concat(to_string(block_id), concat(String_from(": expected preds="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.preds)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_idom(f: MirFunction, block_id: i32, expected_idom: i32) {
    let block = get_unchecked(f.blocks, block_id)
    if block.idom != expected_idom {
        let msg = concat(String_from("idom check failed for bb"), concat(to_string(block_id), concat(String_from(": expected="), concat(mir_format_edge(expected_idom), concat(String_from(" actual="), mir_format_edge(block.idom))))) )
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_frontier(f: MirFunction, block_id: i32, expected_count: i32, expected0: i32, expected1: i32) {
    let block = get_unchecked(f.blocks, block_id)
    let actual_count = len(block.dom_frontier)
    if actual_count != expected_count {
        let msg = concat(String_from("frontier check failed for bb"), concat(to_string(block_id), concat(String_from(": expected count="), concat(to_string(expected_count), concat(String_from(" actual="), concat(to_string(actual_count), concat(String_from(" frontier="), mir_format_block_ids(block.dom_frontier))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 && get_unchecked(block.dom_frontier, 0) != expected0 {
        let msg = concat(String_from("frontier check failed for bb"), concat(to_string(block_id), concat(String_from(": expected frontier="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.dom_frontier)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 1 && get_unchecked(block.dom_frontier, 1) != expected1 {
        let msg = concat(String_from("frontier check failed for bb"), concat(to_string(block_id), concat(String_from(": expected frontier="), concat(String_from("["), concat(to_string(expected0), concat(String_from(","), concat(to_string(expected1), concat(String_from("] actual="), mir_format_block_ids(block.dom_frontier)))))))))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

fn mir_expect_phi(f: MirFunction, block_id: i32, expected_dest: i32, expected_vt: i32, expected_count: i32, expected_pred0: i32, expected_local0: i32, expected_pred1: i32, expected_local1: i32) {
    let block = get_unchecked(f.blocks, block_id)
    let actual_count = len(block.phis)
    if actual_count != 1 {
        let mut msg = concat(String_from("phi check failed for bb"), to_string(block_id))
        msg = concat(msg, String_from(": expected phi count=1 actual="))
        msg = concat(msg, to_string(actual_count))
        stdio::eprintln(msg)
        process::exit(1)
    }
    let phi = get_unchecked(block.phis, 0)
    if phi.op != MIR_PHI() || phi.dest != expected_dest || phi.val_type != expected_vt {
        let mut msg = concat(String_from("phi check failed for bb"), to_string(block_id))
        msg = concat(msg, String_from(": expected dest=%"))
        msg = concat(msg, to_string(expected_dest))
        msg = concat(msg, String_from(" type="))
        msg = concat(msg, mir_value_type_name(expected_vt))
        msg = concat(msg, String_from(" actual="))
        msg = concat(msg, mir_format_phi(f, phi))
        stdio::eprintln(msg)
        process::exit(1)
    }
    let arg_count = len(phi.args)
    if arg_count != expected_count {
        let mut msg = concat(String_from("phi arg count check failed for bb"), to_string(block_id))
        msg = concat(msg, String_from(": expected="))
        msg = concat(msg, to_string(expected_count))
        msg = concat(msg, String_from(" actual="))
        msg = concat(msg, to_string(arg_count))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 {
        let arg0 = get_unchecked(phi.args, 0)
        if arg0.pred_block != expected_pred0 || arg0.local != expected_local0 {
            let msg = concat(String_from("phi arg0 check failed for bb"), concat(to_string(block_id), concat(String_from(": actual="), mir_format_phi(f, phi))))
            stdio::eprintln(msg)
            process::exit(1)
        }
    }
    if expected_count > 1 {
        let arg1 = get_unchecked(phi.args, 1)
        if arg1.pred_block != expected_pred1 || arg1.local != expected_local1 {
            let msg = concat(String_from("phi arg1 check failed for bb"), concat(to_string(block_id), concat(String_from(": actual="), mir_format_phi(f, phi))))
            stdio::eprintln(msg)
            process::exit(1)
        }
    }
}

fn mir_expect_local_ssa(f: MirFunction, local_id: i32, expected_name: String, expected_version: i32) {
    if local_id < 0 || local_id >= len(f.locals) {
        stdio::eprintln(String_from("ssa local check failed: local id out of range"))
        process::exit(1)
    }
    let local = get_unchecked(f.locals, local_id)
    if !eq(clone(local.ssa_name), clone(expected_name)) || local.ssa_version != expected_version {
        let mut msg = concat(String_from("ssa local check failed for "), mir_format_local_ref(f, local_id))
        msg = concat(msg, String_from(": expected %"))
        msg = concat(msg, expected_name)
        msg = concat(msg, String_from("."))
        msg = concat(msg, to_string(expected_version))
        stdio::eprintln(msg)
        process::exit(1)
    }
}

pub fn run_phi_representation_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("phi_repr_sample"))
    let cond = alloc_local(f, String_from("cond"), VT_I32())
    let then_val = alloc_local(f, String_from("then_val"), VT_I32())
    let else_val = alloc_local(f, String_from("else_val"), VT_I32())
    let join_val = alloc_local(f, String_from("join_val"), VT_I32())
    f.return_type = VT_I32()

    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)

    emit_inst(f, entry, MirInst_const_i32(1, cond))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb

    emit_inst(f, then_bb, MirInst_const_i32(10, then_val))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb

    emit_inst(f, else_bb, MirInst_const_i32(20, else_val))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb

    let phi = MirPhi_new(join_val, VT_I32())
    mir_phi_add_arg(phi, then_bb, then_val)
    mir_phi_add_arg(phi, else_bb, else_val)
    emit_phi(f, join_bb, phi)

    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = join_val
    emit_inst(f, join_bb, ret_inst)

    mir_compute_dominance_for_function(f)
    mir_ssa_rename_function(f)
    mir_expect_preds(f, join_bb, 2, then_bb, else_bb)
    mir_expect_frontier(f, then_bb, 1, join_bb, 0)
    mir_expect_frontier(f, else_bb, 1, join_bb, 0)
    mir_expect_phi(f, join_bb, join_val, VT_I32(), 2, then_bb, then_val, else_bb, else_val)
    mir_expect_local_ssa(f, cond, String_from("cond"), 1)
    mir_expect_local_ssa(f, then_val, String_from("join_val"), 1)
    mir_expect_local_ssa(f, else_val, String_from("join_val"), 2)
    mir_expect_local_ssa(f, join_val, String_from("join_val"), 3)

    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR phi representation self-check OK."))
}

pub fn run_phi_insertion_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("phi_insert_sample"))
    let cond = alloc_local(f, String_from("cond"), VT_I32())
    let then_val = alloc_local(f, String_from("then_val"), VT_I32())
    let else_val = alloc_local(f, String_from("else_val"), VT_I32())
    let join_val = alloc_local(f, String_from("join_val"), VT_I32())
    f.return_type = VT_I32()

    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)

    emit_inst(f, entry, MirInst_const_i32(1, cond))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb

    emit_inst(f, then_bb, MirInst_const_i32(10, then_val))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb

    emit_inst(f, else_bb, MirInst_const_i32(20, else_val))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb

    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = join_val
    emit_inst(f, join_bb, ret_inst)

    mir_compute_dominance_for_function(f)
    if !mir_try_insert_simple_join_phi(f, join_bb, join_val) {
        stdio::eprintln(String_from("simple join phi insertion failed"))
        process::exit(1)
    }

    mir_ssa_rename_function(f)

    mir_expect_preds(f, join_bb, 2, then_bb, else_bb)
    mir_expect_frontier(f, then_bb, 1, join_bb, 0)
    mir_expect_frontier(f, else_bb, 1, join_bb, 0)
    mir_expect_phi(f, join_bb, join_val, VT_I32(), 2, then_bb, then_val, else_bb, else_val)
    mir_expect_local_ssa(f, cond, String_from("cond"), 1)
    mir_expect_local_ssa(f, then_val, String_from("join_val"), 1)
    mir_expect_local_ssa(f, else_val, String_from("join_val"), 2)
    mir_expect_local_ssa(f, join_val, String_from("join_val"), 3)

    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR phi insertion self-check OK."))
}

fn run_ssa_rename_smoke() {
    let m = MirModule_new()
    let f = MirFunction_new(String_from("ssa_rename_sample"))
    let cond = alloc_local(f, String_from("cond"), VT_I32())
    let then_val = alloc_local(f, String_from("then_val"), VT_I32())
    let else_val = alloc_local(f, String_from("else_val"), VT_I32())
    let join_val = alloc_local(f, String_from("join_val"), VT_I32())
    f.return_type = VT_I32()

    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)

    emit_inst(f, entry, MirInst_const_i32(1, cond))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb

    emit_inst(f, then_bb, MirInst_const_i32(10, then_val))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb

    emit_inst(f, else_bb, MirInst_const_i32(20, else_val))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb

    let phi = MirPhi_new(join_val, VT_I32())
    mir_phi_add_arg(phi, then_bb, then_val)
    mir_phi_add_arg(phi, else_bb, else_val)
    emit_phi(f, join_bb, phi)

    let ret_inst = MirInst_new(MIR_RETURN())
    ret_inst.arg0 = join_val
    emit_inst(f, join_bb, ret_inst)

    mir_compute_dominance_for_function(f)
    mir_ssa_rename_function(f)

    mir_expect_local_ssa(f, cond, String_from("cond"), 1)
    mir_expect_local_ssa(f, then_val, String_from("join_val"), 1)
    mir_expect_local_ssa(f, else_val, String_from("join_val"), 2)
    mir_expect_local_ssa(f, join_val, String_from("join_val"), 3)

    push(m.functions, f)
    dump_mir(m)
    stdio::println(String_from("MIR SSA rename self-check OK."))
}

// ── Entry Point ──────────────────────────────────────────────────────────────

fn main() {
    let m = MirModule_new()

    // Build a simple diamond-shaped CFG to self-check predecessor computation.
    let f = MirFunction_new(String_from("cfg_pred_sample"))
    let pa = alloc_local(f, String_from("a"), VT_I32())
    let pb = alloc_local(f, String_from("b"), VT_I32())
    let tmp = alloc_local(f, String_from("_t0"), VT_I32())
    f.return_type = VT_I32()

    let entry = alloc_block(f)
    let then_bb = alloc_block(f)
    let else_bb = alloc_block(f)
    let join_bb = alloc_block(f)

    emit_inst(f, entry, MirInst_new(MIR_LOCAL_GET()))
    emit_inst(f, entry, MirInst_new(MIR_LOCAL_GET()))
    let entry_block = get_unchecked(f.blocks, entry)
    entry_block.succ0 = then_bb
    entry_block.succ1 = else_bb

    emit_inst(f, then_bb, MirInst_new(MIR_LOCAL_GET()))
    let then_block = get_unchecked(f.blocks, then_bb)
    then_block.succ0 = join_bb

    emit_inst(f, else_bb, MirInst_new(MIR_LOCAL_GET()))
    let else_block = get_unchecked(f.blocks, else_bb)
    else_block.succ0 = join_bb

    emit_inst(f, join_bb, MirInst_binop(MIR_ADD(), tmp, pa, pb))
    emit_inst(f, join_bb, MirInst_new(MIR_RETURN()))

    mir_compute_dominance_for_function(f)
    mir_expect_preds(f, entry, 0, 0, 0)
    mir_expect_preds(f, then_bb, 1, entry, 0)
    mir_expect_preds(f, else_bb, 1, entry, 0)
    mir_expect_preds(f, join_bb, 2, then_bb, else_bb)
    mir_expect_idom(f, entry, 0 - 1)
    mir_expect_idom(f, then_bb, entry)
    mir_expect_idom(f, else_bb, entry)
    mir_expect_idom(f, join_bb, entry)
    mir_expect_frontier(f, entry, 0, 0, 0)
    mir_expect_frontier(f, then_bb, 1, join_bb, 0)
    mir_expect_frontier(f, else_bb, 1, join_bb, 0)
    mir_expect_frontier(f, join_bb, 0, 0, 0)

    let dom_info = mir_collect_dom_info_for_function(f)
    if len(dom_info.idom) != 4 {
        stdio::eprintln(String_from("dominance snapshot check failed: expected 4 idom entries"))
        process::exit(1)
    }

    push(m.functions, f)

    // Intern some strings
    let s0 = intern_string(m, String_from("hello"))
    let s1 = intern_string(m, String_from("world"))
    let s2 = intern_string(m, String_from("hello"))
    stdio::println(concat(String_from("intern 'hello': "), to_string(s0)))
    stdio::println(concat(String_from("intern 'world': "), to_string(s1)))
    stdio::println(concat(String_from("intern 'hello' again: "), to_string(s2)))

    dump_mir(m)
    stdio::println(String_from("MIR predecessor self-check OK."))
    stdio::println(String_from("MIR dominance self-check OK."))
    stdio::println(String_from("MIR module OK."))
    run_phi_representation_smoke()
    run_phi_insertion_smoke()
    run_ssa_rename_smoke()
}
