// Arukellt Selfhost - post-unroll const folding for MIR opt passes.

use mir::inst_accessors_operands
use mir::inst_accessors_shape
use mir::inst_const_i32
use mir::inst_record
use mir::opcodes

const NOT_FOUND: i32 = 0 - 1

fn mir_opt_local_const_value(insts: Vec<MirInst>, end_idx: i32, local_idx: i32) -> i32 {
    let mut i = end_idx - 1
    while i >= 0 {
        let inst = get_unchecked(insts, i)
        let op = inst_accessors_shape::MirInst_op(inst)
        if op == opcodes::MIR_CONST_I32() && inst_accessors_operands::MirInst_dest(inst) == local_idx {
            return inst_record::mir_inst_int_val(inst)
        }
        if op == opcodes::MIR_LOCAL_SET() && inst_accessors_operands::MirInst_arg0(inst) == local_idx {
            return NOT_FOUND
        }
        i = i - 1
    }
    NOT_FOUND
}

fn mir_opt_const_fold_insts(insts: Vec<MirInst>) -> Vec<MirInst> {
    let out = Vec_new_MirInst()
    for i in 0..len(insts) {
        let inst = get_unchecked(insts, i)
        let op = inst_accessors_shape::MirInst_op(inst)
        if op == opcodes::MIR_ADD() || op == opcodes::MIR_SUB() || op == opcodes::MIR_MUL() {
            let a = inst_accessors_operands::MirInst_arg0(inst)
            let b = inst_accessors_operands::MirInst_arg1(inst)
            let av = mir_opt_local_const_value(insts, i, a)
            let bv = mir_opt_local_const_value(insts, i, b)
            if av >= 0 && bv >= 0 {
                let dest = inst_accessors_operands::MirInst_dest(inst)
                let folded_val = if op == opcodes::MIR_ADD() {
                    av + bv
                } else if op == opcodes::MIR_SUB() {
                    av - bv
                } else {
                    av * bv
                }
                push(out, inst_const_i32::MirInst_const_i32(folded_val, dest))
                continue
            }
        }
        push(out, inst)
    }
    out
}
