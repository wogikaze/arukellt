//
// The wasm32-gc path gates loop_unroll and licm until they are independently
// verified GC-safe. gc_hint is already enabled; see docs/compiler/t3-reachability.md.

use mir::module_functions
use mir::types
use mir_opt::async_lower
use mir_opt::gc_hint
use mir_opt::licm
use mir_opt::loop_unroll
use mir_opt::stdlib_inline
use mir_opt::target_gate

fn mir_opt_optimize_module(m: MirModule, opt_level: i32, target: String) -> MirModule {
    let m = async_lower::async_lower_optimize_module(m)
    if opt_level >= 1 {
        stdlib_inline::stdlib_inline_module(m)
    }
    stdlib_inline::stdlib_resolve_normal_calls(m)
    if opt_level < 2 {
        return m
    }
    let t3 = target_gate::mir_opt_is_t3_target(clone(target))
    let fn_count = module_functions::MirModule_function_count(m)
    let updated = Vec_new_MirFunction()
    let mut fi = 0
    while fi < fn_count {
        let f = module_functions::MirModule_function_at(m, fi)
        if !t3 {
            loop_unroll::run_loop_unroll(f)
            licm::run_licm(f)
        }
        gc_hint::run_gc_hint(f)
        push(updated, f)
        fi = fi + 1
    }
    module_functions::MirModule_set_functions(m, updated)
    m
}
