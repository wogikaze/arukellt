                                                                                                                                                                                                                                                                                                                                                                        let err_msg = "parse error: invalid integer"
                                                                                                                                                                                                                                                                                                                                                                        let err_len = len(err_msg)
                                                                                                                                                                                                                                                                                                                                                                        let mut ei = 0
                                                                                                                                                                                                                                                                                                                                                                        while ei < err_len {
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_base)
