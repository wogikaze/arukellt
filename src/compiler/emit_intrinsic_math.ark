// Handler for: eq
pub fn emit_eq(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                        let s_a = ctx.scratch_base
                                                                                                                                        let s_b = ctx.scratch_base + 1
                                                                                                                                        let s_la = ctx.scratch_base + 2
                                                                                                                                        let s_i = ctx.scratch_base + 3
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                        emit_writer::emit_byte(w, 71)
                                                                                                                                        emit_writer::emit_byte(w, 4)
                                                                                                                                        emit_writer::emit_byte(w, 127)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                        emit_writer::emit_leb128_s(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, 5)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                        emit_writer::emit_leb128_s(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                        emit_writer::emit_byte(w, 3)
                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                        emit_writer::emit_byte(w, 78)
                                                                                                                                        emit_writer::emit_byte(w, 13)
                                                                                                                                        emit_writer::emit_leb128_u(w, 1)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                        emit_writer::emit_byte(w, 45)
                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                        emit_writer::emit_byte(w, 45)
                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, 71)
                                                                                                                                        emit_writer::emit_byte(w, 4)
                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                        emit_writer::emit_leb128_s(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                        emit_writer::emit_leb128_u(w, inst.dest)
                                                                                                                                        emit_writer::emit_byte(w, 12)
                                                                                                                                        emit_writer::emit_leb128_u(w, 2)
                                                                                                                                        emit_writer::emit_byte(w, 11)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                        emit_writer::emit_leb128_s(w, 1)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, 12)
                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                        emit_writer::emit_byte(w, 11)
                                                                                                                                        emit_writer::emit_byte(w, 11)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_i)
                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                        emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                        emit_writer::emit_byte(w, 78)
                                                                                                                                        emit_writer::emit_byte(w, 11)
    true
}


