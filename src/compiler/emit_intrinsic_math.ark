                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4 + ei)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                            let ch = char_at(err_msg, ei)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, ch)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 58)
