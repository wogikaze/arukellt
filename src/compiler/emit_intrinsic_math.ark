// Handler for: sqrt, math::sqrt
pub fn emit_sqrt(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                        emit_writer::emit_byte(w, 159)
    true
}


// Handler for: parse_f64, text::parse_f64
pub fn emit_parse_f64(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                            let s_str = ctx.scratch_base + 0
                                                                                                                                                                                                            let s_len_local = ctx.scratch_base + 1
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_len_local)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_PF_RESULT())
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_F64_CONST())
                                                                                                                                                                                                            emit_writer::emit_f64(w, 0.0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_F64_STORE())
                                                                                                                                                                                                            emit_writer::emit_byte(w, 3)
                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_P_I())
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_P_NEG())
