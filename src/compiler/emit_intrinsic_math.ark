// Handler for: f64_bits_lo
pub fn emit_f64_bits_lo(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                            let f_tmp = ctx.scratch_base + 12
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, f_tmp)
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_I32BUF())
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, f_tmp)
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_F64_STORE())
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 3)
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_I32BUF())
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
    true
}


// Handler for: f64_bits_hi
pub fn emit_f64_bits_hi(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                let f_tmp2 = ctx.scratch_base + 12
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, f_tmp2)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_I32BUF())
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, f_tmp2)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_F64_STORE())
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 3)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_I32BUF() + 4)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
    true
}


