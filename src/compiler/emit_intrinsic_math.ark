                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LT_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_AND())
    true
}


// Handler for: core::range_len, range_len
pub fn emit_range_len(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                let s_range = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_GT_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_SELECT())
    true
}


// Handler for: pow_i32, math::pow_i32
pub fn emit_pow_i32(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    let s_base = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    let s_exp = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    let s_result = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_exp)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_base)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_result)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_BLOCK())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOOP())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_exp)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_EQZ())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_BR_IF())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_result)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_base)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_result)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_exp)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_exp)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_BR())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_result)
    true
}


// Handler for: gcd, math::gcd
pub fn emit_gcd(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let s_a = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let s_b = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let s_t = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BLOCK())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOOP())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_EQZ())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BR_IF())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_t)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_REM_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_t)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BR())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_a)
    true
}


// Handler for: memory_copy
pub fn emit_memory_copy(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 252)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 10)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
    false
}


// Handler for: memory_fill
pub fn emit_memory_fill(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 252)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 11)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
    false
}

