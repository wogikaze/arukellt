use collections::vec_extend
use typechecker::contract_mono
use typechecker::contract_env_mono_record
use typechecker::contract_env_record

fn merge_mono_instances(dst: TypeEnv, src: TypeEnv) {
    let src_instances = contract_env_mono_record::type_env_mono_instances(src)
    let count = len(src_instances)
    let mut i = 0
    while i < count {
        let incoming = get_unchecked(src_instances, i)
        let incoming_mangled = contract_mono::MonoInstance_mangled_name(incoming)
        let dst_instances = contract_env_mono_record::type_env_mono_instances(dst)
        let dst_count = len(dst_instances)
        let mut found = false
        let mut j = 0
        while j < dst_count {
            let existing = get_unchecked(dst_instances, j)
            if eq(contract_mono::MonoInstance_mangled_name(existing), clone(incoming_mangled)) {
                found = true
            }
            j = j + 1
        }
        if !found {
            push(dst.mono_instances, incoming)
        }
        i = i + 1
    }
}

fn merge_type_env(dst: TypeEnv, src: TypeEnv) {
    let err_count = src.error_count
    let mut e = 0
    while e < err_count {
        push(dst.errors, clone(get_unchecked(src.errors, e)))
        dst.error_count = dst.error_count + 1
        e = e + 1
    }
    vec_extend::Vec_extend_Diagnostic(dst.diagnostics, src.diagnostics)
    vec_extend::Vec_extend_Diagnostic(dst.warnings, src.warnings)
    vec_extend::Vec_extend_String_clone(dst.tracked_binding_names, src.tracked_binding_names)
    vec_extend::Vec_extend_i32(dst.tracked_binding_spans_start, src.tracked_binding_spans_start)
    vec_extend::Vec_extend_i32(dst.tracked_binding_spans_end, src.tracked_binding_spans_end)
    vec_extend::Vec_extend_i32(dst.tracked_binding_used, src.tracked_binding_used)
    merge_mono_instances(dst, src)
    vec_extend::Vec_extend_MonoCallSite(dst.mono_call_sites, src.mono_call_sites)
}

fn type_env_for_fn_check(parent: TypeEnv) -> TypeEnv {
    let child = contract_env_record::TypeEnv_new()
    child.trait_impls = parent.trait_impls
    child.trait_methods = parent.trait_methods
    child.current_fn_type_params = parent.current_fn_type_params
    child.current_fn_bounds = parent.current_fn_bounds
    child
}
