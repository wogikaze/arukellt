// Arukellt Typechecker - typed function result contract.

use typechecker::contract_types_record

struct TypedFn {
    name: String,
    return_type: TypeInfo,
}

fn TypedFn_new(name: String, return_type: TypeInfo) -> TypedFn {
    TypedFn { name: name, return_type: return_type }
}

fn TypedFn_name(fn_info: TypedFn) -> String {
    clone(fn_info.name)
}

fn TypedFn_return_type(fn_info: TypedFn) -> TypeInfo {
    fn_info.return_type
}
