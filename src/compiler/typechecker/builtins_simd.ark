    if eq(clone(name), String_from("__simd_f64x2_div")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_neg")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_sqrt")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_abs")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_eq")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_ne")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_lt")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_le")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_gt")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_ge")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_min")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_max")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_ceil")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_floor")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_trunc")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_nearest")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_promote_low_f32x4")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_convert_low_i32x4_s")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_convert_low_i32x4_u")) { return simple_type(commands::TY_V128()) }

    // i32x4 (except extract_lane -> i32)
    if eq(clone(name), String_from("__simd_i32x4_splat")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_i32x4_replace_lane")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_i32x4_add")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_i32x4_sub")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_i32x4_mul")) { return simple_type(commands::TY_V128()) }
