use typechecker::kinds
// Arukellt Typechecker - SIMD intrinsic builtin call return types.

use typechecker::contract_type_access
use typechecker::contract_type_constructors

fn simple_type(tag: i32) -> TypeInfo {
    contract_type_constructors::TypeInfo_simple(tag)
}

fn simd_builtin_call_return_type(name: String) -> TypeInfo {
    // v128-returning functions (default for SIMD lane ops)
    // v128 raw bitwise (except any_true -> i32)
    if eq(clone(name), String_from("__simd_v128_and")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_v128_or")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_v128_xor")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_v128_not")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_v128_andnot")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_v128_bitselect")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_v128_const")) { return simple_type(commands::TY_V128()) }

    // f32x4 (except extract_lane -> f32)
    if eq(clone(name), String_from("__simd_f32x4_splat")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_replace_lane")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_add")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_sub")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_mul")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_div")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_neg")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_sqrt")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_abs")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_eq")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_ne")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_lt")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_le")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_gt")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_ge")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_min")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_max")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_ceil")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_floor")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_trunc")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f32x4_nearest")) { return simple_type(commands::TY_V128()) }

    // f64x2 (except extract_lane -> f64)
    if eq(clone(name), String_from("__simd_f64x2_splat")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_replace_lane")) { return simple_type(commands::TY_V128()) }
    if eq(clone(name), String_from("__simd_f64x2_add")) { return simple_type(commands::TY_V128()) }
