use typechecker::kinds
use typechecker::ast_access
use typechecker::ast_decl_predicates
use typechecker::contract_fn_sig
use typechecker::contract_result_state
use typechecker::sigs

fn typed_fn_sig(node: AstNode) -> FnSig {
    if ast_decl_predicates::node_is_const_decl(node) {
        return sigs::fn_sig_from_const_decl(node)
    }
    sigs::fn_sig_from_fn_decl(node)
}

fn typed_fn_param_types(node: AstNode) -> Vec<TypeInfo> {
    let sig = typed_fn_sig(node)
    let result = Vec_new_TypeInfo()
    let count = contract_fn_sig::FnSig_param_count(sig)
    let mut i = 0
    while i < count {
        push(result, contract_fn_sig::FnSig_param_at(sig, i))
        i = i + 1
    }
    result
}

fn typed_fn_return_type(node: AstNode) -> TypeInfo {
    contract_fn_sig::FnSig_return_type(typed_fn_sig(node))
}

fn append_typed_fn(result: TypeCheckResult, node: AstNode) {
    contract_result_state::typecheck_result_push_typed_fn(
        result,
        ast_access::node_text(node),
        typed_fn_param_types(node),
        typed_fn_return_type(node)
    )
}
