use typechecker::kinds
use typechecker::ast_access
use typechecker::body_params
use typechecker::body_returns
use typechecker::contract_env_record
use typechecker::contract_fn_sig
use typechecker::contract_type_access
use typechecker::infer
use typechecker::scope
use typechecker::sigs

fn check_fn_body(env: TypeEnv, fn_sigs: Vec<FnSig>, enum_defs: Vec<EnumInfo>, fn_node: AstNode) {
    let sig = sigs::lookup_fn_sig(env, fn_sigs, ast_access::node_text(fn_node))
    check_fn_body_with_sig(env, fn_sigs, enum_defs, fn_node, sig)
}

fn check_fn_body_with_sig(env: TypeEnv, fn_sigs: Vec<FnSig>, enum_defs: Vec<EnumInfo>, fn_node: AstNode, sig: FnSig) {
    let scope = scope::LocalScope_new()
    body_params::bind_fn_params_from_sig(scope, fn_node, sig)
    body_params::set_fn_type_params_from_sig(env, sig)
    let child_count = ast_access::node_child_count(fn_node)
    if child_count > 0 {
        let body = ast_access::node_child_at(fn_node, child_count - 1)
        infer::check_stmt(env, scope, fn_sigs, enum_defs, body)
        contract_env_record::type_env_finalize_unused_bindings(env)
        let return_tag = contract_type_access::TypeInfo_tag(contract_fn_sig::FnSig_return_type(sig))
        if return_tag != commands::TY_UNKNOWN() && return_tag != commands::TY_UNIT() {
            body_returns::check_fn_body_return_contract(env, scope, fn_sigs, enum_defs, sig, body)
        }
    }
}

// Typecheck a `test` declaration body (ADR-041). Test bodies are checked in
// the module environment with a fresh empty local scope. No params, no
// return contract. Test mod recurses into child test decls.
fn check_test_body(env: TypeEnv, fn_sigs: Vec<FnSig>, enum_defs: Vec<EnumInfo>, node: AstNode) {
    if ast_access::node_kind_is(node, kinds::NK_TEST_MOD()) {
        let cc = ast_access::node_child_count(node)
        let mut i = 0
        while i < cc {
            check_test_body(env, fn_sigs, enum_defs, ast_access::node_child_at(node, i))
            i = i + 1
        }
        return
    }
    // NK_TEST_DECL
    let scope = scope::LocalScope_new()
    let cc = ast_access::node_child_count(node)
    if cc > 0 {
        let body = ast_access::node_child_at(node, cc - 1)
        infer::check_stmt(env, scope, fn_sigs, enum_defs, body)
        contract_env_record::type_env_finalize_unused_bindings(env)
    }
}
