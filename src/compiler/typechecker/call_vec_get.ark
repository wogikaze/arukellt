use typechecker::kinds
// Arukellt Typechecker - Vec element access call return types.

use typechecker::ast_access
use typechecker::contract_type_access
use typechecker::contract_type_constructors
use typechecker::contract_type_mutation

fn try_infer_vec_get_return(env: TypeEnv, scope: LocalScope, fn_sigs: Vec<FnSig>, enum_defs: Vec<EnumInfo>, node: AstNode) -> TypeInfo {
    if ast_access::node_child_count(node) < 2 {
        return contract_type_constructors::TypeInfo_simple(commands::TY_UNKNOWN())
    }
    let vec_node = ast_access::node_child_at(node, 1)
    let _idx_ty = infer_expr(env, scope, fn_sigs, enum_defs, ast_access::node_child_at(node, 2))
    let vec_ty = infer_expr(env, scope, fn_sigs, enum_defs, vec_node)
    return vec_get_option_type(vec_ty)
}

fn vec_get_option_type(vec_ty: TypeInfo) -> TypeInfo {
    if contract_type_access::TypeInfo_tag(vec_ty) != commands::TY_VEC() {
        return contract_type_constructors::TypeInfo_simple(commands::TY_UNKNOWN())
    }
    if contract_type_access::TypeInfo_type_arg_count(vec_ty) < 1 {
        return contract_type_constructors::TypeInfo_simple(commands::TY_UNKNOWN())
    }
    let elem_ty = contract_type_access::TypeInfo_type_arg_at(vec_ty, 0)
    let mut opt_ty = contract_type_constructors::TypeInfo_simple(commands::TY_OPTION())
    contract_type_mutation::TypeInfo_push_type_arg(opt_ty, elem_ty)
    opt_ty
}
