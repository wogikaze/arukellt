use typechecker::kinds
use typechecker::contract_fn_sig
use typechecker::contract_type_constructors
use collections::name_index

fn simple_type(tag: i32) -> TypeInfo {
    contract_type_constructors::TypeInfo_simple(tag)
}

fn lookup_fn_sig(env: TypeEnv, fn_sigs: Vec<FnSig>, name: String) -> FnSig {
    let index = name_index::name_index_get(env.fn_sig_index, name)
    if index >= 0 && index < len(fn_sigs) {
        return get_unchecked(fn_sigs, index)
    }
    contract_fn_sig::FnSig_empty(simple_type(commands::TY_UNKNOWN()))
}
