use typechecker::ast_access
use typechecker::contract_fn_sig
use typechecker::instantiate
use typechecker::unify

fn constrain_generic_method_args(
    env: TypeEnv,
    scope: LocalScope,
    fn_sigs: Vec<FnSig>,
    enum_defs: Vec<EnumInfo>,
    node: AstNode,
    sig: FnSig,
    recv_ty: TypeInfo,
    explicit_args: i32,
    infer_env: TypeEnv,
    var_names: Vec<String>,
    var_types: Vec<TypeInfo>
) -> TypeInfo {
    let p0 = contract_fn_sig::FnSig_param_at(sig, 0)
    let inst_p0 = instantiate::instantiate_type(p0, var_names, var_types)
    unify::unify(infer_env, inst_p0, recv_ty)
    let mut a = 0
    while a < explicit_args {
        let arg_node = ast_access::node_child_at(node, a + 1)
        let arg_ty = infer_expr(env, scope, fn_sigs, enum_defs, arg_node)
        let pty = contract_fn_sig::FnSig_param_at(sig, a + 1)
        let inst_pt = instantiate::instantiate_type(pty, var_names, var_types)
        unify::unify(infer_env, inst_pt, arg_ty)
        a = a + 1
    }
    inst_p0
}
