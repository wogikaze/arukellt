// Comparison operator kinds.
fn OP_EQ() -> i32 { 6 }
fn OP_NEQ() -> i32 { 7 }
fn OP_LT() -> i32 { 8 }
fn OP_LTEQ() -> i32 { 9 }
fn OP_GT() -> i32 { 10 }
fn OP_GTEQ() -> i32 { 11 }

// Logical operator kinds.
fn OP_AND() -> i32 { 12 }
fn OP_OR() -> i32 { 13 }

// Unknown type tag.
fn TY_UNKNOWN() -> i32 { 0 }

// Numeric primitive type tags.
fn TY_I32() -> i32 { 1 }
fn TY_I64() -> i32 { 2 }
fn TY_F64() -> i32 { 3 }

// Bool primitive type tag.
fn TY_BOOL() -> i32 { 4 }

// Text primitive type tags.
fn TY_STRING() -> i32 { 5 }
fn TY_CHAR() -> i32 { 6 }

// Control type tags.
fn TY_UNIT() -> i32 { 7 }
fn TY_NEVER() -> i32 { 8 }

// Collection type tags.
fn TY_VEC() -> i32 { 10 }
fn TY_OPTION() -> i32 { 11 }
fn TY_RESULT() -> i32 { 12 }
fn TY_HASHMAP() -> i32 { 13 }
fn TY_FUTURE() -> i32 { 14 }
fn TY_STREAM() -> i32 { 15 }
fn TY_TUPLE() -> i32 { 23 }

// Nominal and callable type tags.
fn TY_FN() -> i32 { 20 }
fn TY_STRUCT() -> i32 { 21 }
fn TY_ENUM() -> i32 { 22 }
fn TY_RESOURCE() -> i32 { 24 }

// Inference type tags.
fn TY_TYPE_VAR() -> i32 { 30 }
