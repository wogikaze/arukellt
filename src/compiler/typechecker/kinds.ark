fn NK_FLOAT_LIT() -> i32 { 2 }
fn NK_STRING_LIT() -> i32 { 3 }
fn NK_BOOL_LIT() -> i32 { 4 }
fn NK_IDENT() -> i32 { 5 }

// Operator expression node kinds.
fn NK_BINARY() -> i32 { 6 }
fn NK_UNARY() -> i32 { 7 }
