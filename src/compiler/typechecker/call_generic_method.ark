use std::text
use typechecker::kinds
use typechecker::ast_access
use typechecker::call_generic_common
use typechecker::call_generic_method_args
use typechecker::call_generic_resolve
use typechecker::contract_fn_sig
use typechecker::contract_type_access
use typechecker::infer_env_scope
use typechecker::instantiate
use typechecker::mono
use typechecker::traits
use typechecker::unify

fn infer_generic_method_call_expr(env: TypeEnv, scope: LocalScope, fn_sigs: Vec<FnSig>, enum_defs: Vec<EnumInfo>, node: AstNode, sig: FnSig, recv_ty: TypeInfo, explicit_args: i32) -> TypeInfo {
    let infer_env = infer_env_scope::borrow_generic_infer_env()
    let var_names = Vec_new_String()
    let var_types = Vec_new_TypeInfo()
    call_generic_common::append_generic_type_vars(infer_env, sig, var_names, var_types)
    let inst_p0 = call_generic_method_args::constrain_generic_method_args(env, scope, fn_sigs, enum_defs, node, sig, recv_ty, explicit_args, infer_env, var_names, var_types)
    let inst_ret = instantiate::instantiate_type(contract_fn_sig::FnSig_return_type(sig), var_names, var_types)
    let ret_ty = call_generic_resolve::resolve_call_return_type(infer_env, inst_ret)
    if call_generic_resolve::has_unresolved_fresh_type_arg(infer_env, var_types) {
        return ret_ty
    }
    let resolved_type_args = call_generic_common::resolve_type_args(infer_env, var_types)
    traits::enforce_fn_sig_bounds(env, infer_env, sig, var_types)
    let resolved_recv_ty = unify::resolve_type_deep(infer_env, inst_p0)
    let method_name = ast_access::node_text(node)
    let mut mono_fn_name = clone(method_name)
    let type_prefix = type_name_for_mono(resolved_recv_ty)
    if len(type_prefix) > 0 {
        mono_fn_name = text::builder_append(type_prefix, concat(String_from("::"), method_name))
    }
    let mangled_name = mono::record_mono_instance(env, clone(mono_fn_name), resolved_type_args)
    mono::record_mono_call_site(env, ast_access::node_span_start(node), mono_fn_name, mangled_name)
    ret_ty
}

// Map a receiver TypeInfo to the type name used for mono instance naming.
// Returns empty string for types that don't have a type prefix.
fn type_name_for_mono(ty: TypeInfo) -> String {
    let tag = contract_type_access::TypeInfo_tag(ty)
    if tag == commands::TY_VEC() {
        return String_from("Vec")
    }
    if tag == commands::TY_STRING() {
        return String_from("String")
    }
    if tag == commands::TY_STRUCT() {
        let name = contract_type_access::TypeInfo_name(ty)
        if len(name) > 0 {
            return name
        }
    }
    String_new()
}
