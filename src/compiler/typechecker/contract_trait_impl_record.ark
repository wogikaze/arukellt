use typechecker::contract_types_record

struct TraitImplInfo {
    trait_name: String,
    self_ty: TypeInfo,
}

fn TraitImplInfo_new(trait_name: String, self_ty: TypeInfo) -> TraitImplInfo {
    TraitImplInfo { trait_name: trait_name, self_ty: self_ty }
}

fn trait_impl_info_trait_name(info: TraitImplInfo) -> String {
    clone(info.trait_name)
}

fn trait_impl_info_self_ty(info: TraitImplInfo) -> TypeInfo {
    info.self_ty
}
