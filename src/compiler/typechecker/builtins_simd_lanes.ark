// i8x16 (except extract_lane_s/u, all_true, bitmask -> i32)
fn simd_return_i8x16(name: String) -> bool {
    if eq(clone(name), String_from("__simd_i8x16_splat")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_replace_lane")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_add")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_sub")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_mul")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_neg")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_abs")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_add_sat_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_add_sat_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_sub_sat_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_sub_sat_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_eq")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_ne")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_lt_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_le_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_gt_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_ge_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_lt_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_le_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_gt_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_ge_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_min_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_max_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_min_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_max_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_shl")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_shr_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_shr_u")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_narrow_i16x8_s")) { return true }
    if eq(clone(name), String_from("__simd_i8x16_narrow_i16x8_u")) { return true }
    false
}

// i16x8 (except extract_lane_s/u -> i32)
fn simd_return_i16x8(name: String) -> bool {
    if eq(clone(name), String_from("__simd_i16x8_splat")) { return true }
    if eq(clone(name), String_from("__simd_i16x8_replace_lane")) { return true }
    if eq(clone(name), String_from("__simd_i16x8_add")) { return true }
    if eq(clone(name), String_from("__simd_i16x8_sub")) { return true }
    if eq(clone(name), String_from("__simd_i16x8_mul")) { return true }
