// Arukellt HIR - primitive type display names.

use hir::type_contracts
use hir::kinds

fn primitive_type_name(ty: HirType) -> String {
    let tag = type_contracts::HirType_tag(ty)
    if tag == commands::TY_I32() { return String_from("i32") }
    if tag == commands::TY_I64() { return String_from("i64") }
    if tag == commands::TY_F64() { return String_from("f64") }
    if tag == commands::TY_F32() { return String_from("f32") }
    if tag == commands::TY_BOOL() { return String_from("bool") }
    if tag == commands::TY_STRING() { return String_from("String") }
    if tag == commands::TY_CHAR() { return String_from("char") }
    if tag == commands::TY_UNIT() { return String_from("()") }
    if tag == commands::TY_NEVER() { return String_from("!") }
    String_new()
}
