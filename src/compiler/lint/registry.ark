// Arukellt Selfhost - lint rule registry.
//
// Defines all lint rules with id, severity, category, and description.
// Used by `arukellt lint --list` and severity override filtering.

use diagnostics::codes
use diagnostics::severity

// Lint severity levels: Allow (suppress), Warn (default), Deny (escalate to error).
fn LINT_ALLOW() -> i32 { 0 }
fn LINT_WARN() -> i32 { 1 }
fn LINT_DENY() -> i32 { 2 }

// Lint categories.
fn CAT_CORRECTNESS() -> String { String_from("correctness") }
fn CAT_STYLE() -> String { String_from("style") }
fn CAT_MIGRATION() -> String { String_from("migration") }
fn CAT_PERFORMANCE() -> String { String_from("performance") }
fn CAT_DOCS() -> String { String_from("docs") }

struct LintRule {
    code: String,
    name: String,
    default_severity: i32,
    category: String,
    description: String,
}

fn LintRule_new(code: String, name: String, default_severity: i32, category: String, description: String) -> LintRule {
    LintRule { code: code, name: name, default_severity: default_severity, category: category, description: description }
}

fn lint_rule_code(rule: LintRule) -> String { clone(rule.code) }
fn lint_rule_name(rule: LintRule) -> String { clone(rule.name) }
fn lint_rule_default_severity(rule: LintRule) -> i32 { rule.default_severity }
fn lint_rule_category(rule: LintRule) -> String { clone(rule.category) }
fn lint_rule_description(rule: LintRule) -> String { clone(rule.description) }

// Total number of registered lint rules.
fn lint_rule_count() -> i32 { 10 }

// Return the LintRule at the given index (0-based).
fn lint_rule_at(index: i32) -> LintRule {
    if index == 0 {
        return LintRule_new(codes::DIAG_WARN_SHARED_MUT_ALIAS(), String_from("shared-mut-alias"), LINT_WARN(), CAT_CORRECTNESS(), String_from("possible unintended sharing of reference type"))
    }
    if index == 1 {
        return LintRule_new(codes::DIAG_WARN_DEPRECATED_TARGET_ALIAS(), String_from("deprecated-target-alias"), LINT_WARN(), CAT_MIGRATION(), String_from("deprecated target alias"))
    }
    if index == 2 {
        return LintRule_new(codes::DIAG_WARN_UNUSED_SYMBOL(), String_from("unused-symbol"), LINT_WARN(), CAT_STYLE(), String_from("unused symbol"))
    }
    if index == 3 {
        return LintRule_new(codes::DIAG_WARN_WASM_VALIDATION(), String_from("wasm-validation"), LINT_DENY(), CAT_CORRECTNESS(), String_from("generated Wasm module failed validation"))
    }
    if index == 4 {
        return LintRule_new(codes::DIAG_WARN_CAPABILITY_STUB(), String_from("capability-stub"), LINT_WARN(), CAT_CORRECTNESS(), String_from("non-exportable function skipped from component exports"))
    }
    if index == 5 {
        return LintRule_new(codes::DIAG_WARN_UNUSED_IMPORT(), String_from("unused-import"), LINT_WARN(), CAT_STYLE(), String_from("unused import"))
    }
    if index == 6 {
        return LintRule_new(codes::DIAG_WARN_UNUSED_BINDING(), String_from("unused-binding"), LINT_WARN(), CAT_STYLE(), String_from("unused binding"))
    }
    if index == 7 {
        return LintRule_new(codes::DIAG_WARN_DOC_DRIFT(), String_from("doc-drift"), LINT_WARN(), CAT_DOCS(), String_from("documentation drift"))
    }
    if index == 8 {
        return LintRule_new(codes::DIAG_WARN_DEPRECATED_API(), String_from("deprecated-api"), LINT_WARN(), CAT_MIGRATION(), String_from("deprecated API usage"))
    }
    LintRule_new(codes::DIAG_WARN_COMPONENT_LOWERING_NOTE(), String_from("component-lowering-note"), LINT_WARN(), CAT_DOCS(), String_from("component lowering note"))
}

// Look up a lint rule by its W-code string. Returns -1 if not found.
fn lint_rule_index_by_code(code: String) -> i32 {
    let count = lint_rule_count()
    let mut i = 0
    while i < count {
        if eq(lint_rule_code(lint_rule_at(i)), clone(code)) {
            return i
        }
        i = i + 1
    }
    -1
}

// Look up a lint rule by its short name (e.g. "unused-import"). Returns -1 if not found.
fn lint_rule_index_by_name(name: String) -> i32 {
    let count = lint_rule_count()
    let mut i = 0
    while i < count {
        if eq(lint_rule_name(lint_rule_at(i)), clone(name)) {
            return i
        }
        i = i + 1
    }
    -1
}

// Format a single lint rule as a list line: "  W0006  unused-import      warn  style  unused import".
fn format_lint_rule_line(rule: LintRule) -> String {
    let mut out = String_from("  ")
    out = concat(out, lint_rule_code(rule))
    out = concat(out, String_from("  "))
    out = concat(out, lint_rule_name(rule))
    out = concat(out, String_from("  "))
    out = concat(out, severity_label(lint_rule_default_severity(rule)))
    out = concat(out, String_from("  "))
    out = concat(out, lint_rule_category(rule))
    out = concat(out, String_from("  "))
    out = concat(out, lint_rule_description(rule))
    out
}

fn severity_label(sev: i32) -> String {
    if sev == LINT_ALLOW() {
        return String_from("allow")
    }
    if sev == LINT_DENY() {
        return String_from("deny")
    }
    String_from("warn")
}

// Format the full `arukellt lint --list` output.
pub fn format_lint_rule_list() -> String {
    let mut out = String_from("lint rules:\n")
    let count = lint_rule_count()
    let mut i = 0
    while i < count {
        out = concat(out, format_lint_rule_line(lint_rule_at(i)))
        out = concat(out, String_from("\n"))
        i = i + 1
    }
    out
}

// Resolve the effective severity for a diagnostic code given allow/deny overrides.
// Returns LINT_ALLOW (suppress), LINT_WARN (default), or LINT_DENY (error).
pub fn effective_severity(code: String, allow_codes: Vec<String>, deny_codes: Vec<String>) -> i32 {
    let allow_count = len(allow_codes)
    let mut ai = 0
    while ai < allow_count {
        if eq(clone(get_unchecked(allow_codes, ai)), clone(code)) {
            return LINT_ALLOW()
        }
        ai = ai + 1
    }
    let deny_count = len(deny_codes)
    let mut di = 0
    while di < deny_count {
        if eq(clone(get_unchecked(deny_codes, di)), clone(code)) {
            return LINT_DENY()
        }
        di = di + 1
    }
    let idx = lint_rule_index_by_code(clone(code))
    if idx < 0 {
        return LINT_WARN()
    }
    lint_rule_default_severity(lint_rule_at(idx))
}

// Check whether a diagnostic should be suppressed (allow).
// Matches either by W-code (e.g. "W0006") or by rule name (e.g. "unused-import").
pub fn should_suppress(code: String, allow_codes: Vec<String>) -> bool {
    let count = len(allow_codes)
    let mut i = 0
    while i < count {
        let entry = get_unchecked(allow_codes, i)
        // Direct W-code match
        if eq(clone(entry), clone(code)) {
            return true
        }
        // Rule name match: resolve the name to a W-code and compare
        let resolved = resolve_rule_code(clone(entry))
        if len(clone(resolved)) > 0 && eq(clone(resolved), clone(code)) {
            return true
        }
        i = i + 1
    }
    false
}

// Check whether a diagnostic should be escalated to an error (deny).
// Matches either by W-code (e.g. "W0006") or by rule name (e.g. "unused-import").
pub fn should_deny(code: String, deny_codes: Vec<String>) -> bool {
    let count = len(deny_codes)
    let mut i = 0
    while i < count {
        let entry = get_unchecked(deny_codes, i)
        if eq(clone(entry), clone(code)) {
            return true
        }
        let resolved = resolve_rule_code(clone(entry))
        if len(clone(resolved)) > 0 && eq(clone(resolved), clone(code)) {
            return true
        }
        i = i + 1
    }
    false
}

// Resolve a CLI --allow/--deny argument (either a W-code or a rule name) to a W-code.
// Returns empty string if not recognized.
pub fn resolve_rule_code(arg: String) -> String {
    let idx = lint_rule_index_by_code(clone(arg))
    if idx >= 0 {
        return lint_rule_code(lint_rule_at(idx))
    }
    let name_idx = lint_rule_index_by_name(clone(arg))
    if name_idx >= 0 {
        return lint_rule_code(lint_rule_at(name_idx))
    }
    String_new()
}
