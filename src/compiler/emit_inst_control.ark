// Arukellt Selfhost — Wasm Binary Emitter: Emit Inst Control
//
// Extracted from emitter.ark for module-level organization.

use emit_opcodes
use emit_writer

pub fn emit_br(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_BR())
    emit_writer::emit_leb128_u(w, inst.int_val)
}

pub fn emit_br_if(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_BR_IF())
    emit_writer::emit_leb128_u(w, inst.int_val)
}

pub fn emit_block(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_BLOCK())
    emit_writer::emit_byte(w, 64)
}

pub fn emit_loop(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_LOOP())
    emit_writer::emit_byte(w, 64)
}

pub fn emit_if(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_IF())
    emit_writer::emit_byte(w, 64)
}

pub fn emit_else(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_ELSE())
}

pub fn emit_end(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    emit_writer::emit_byte(w, emit_opcodes::OP_END())
}
