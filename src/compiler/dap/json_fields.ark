//
// Delegates to std::json (issue #704).

use std::json

pub fn dap_get_str(json_str: String, key: String) -> String {
    json::json_get_str(json_str, key)
}

pub fn dap_get_str_after(json_str: String, key: String, from: i32) -> String {
    json::json_get_str_after(json_str, key, from)
}

pub fn dap_get_int(json_str: String, key: String) -> i32 {
    json::json_get_int(json_str, key)
}
