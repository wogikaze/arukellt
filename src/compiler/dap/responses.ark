fn dap_init_evt(seq: i32) -> String {
    let mut body = text::builder_new()
    body = text::builder_append(body, String_from("{\"seq\":"))
    body = text::builder_append(body, to_string(seq))
    body = text::builder_append(body, String_from(",\"type\":\"event\",\"event\":\"initialized\"}"))
    text::builder_build(body)
}
