    body = text::builder_append(body, String_from(",\"type\":\"response\",\"request_seq\":"))
    body = text::builder_append(body, to_string(request_seq))
    body = text::builder_append(body, String_from(",\"success\":true,\"command\":\"disconnect\",\"body\":{}}"))
