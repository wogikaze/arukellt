// Arukellt Selfhost - DAP JSON key lookup

fn dap_find_key(json: String, key: String, from: i32) -> i32 {
	let needle = concat(String_from("\""), concat(clone(key), String_from("\"")))
	let n = len(json)
	let nlen = len(needle)
	if from >= n {
		return -1
	}
	let tail = substring(clone(json), from, n)
	let rel = index_of(tail, clone(needle))
	if rel < 0 {
		return -1
	}
	from + rel + nlen
}
