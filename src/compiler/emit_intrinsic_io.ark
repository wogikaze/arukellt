                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                            let err_msg_wb = "file write error"
                                                                                                                                                                                                                            let mut ebi_wb = 0
                                                                                                                                                                                                                            while ebi_wb < 16 {
                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4 + ebi_wb)
                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, char_at(err_msg_wb, ebi_wb))
                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE8())
                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                ebi_wb = ebi_wb + 1
                                                                                                                                                                                                                            }
                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_FS_STRPTR())
                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
