fn native_c_capability_is_supported(op: i32) -> bool {
    op == opcodes::MIR_CONST_I32() ||
    op == opcodes::MIR_CONST_I64() ||
    op == opcodes::MIR_CONST_F64() ||
    op == opcodes::MIR_CONST_BOOL() ||
    op == opcodes::MIR_CONST_STRING() ||
    op == opcodes::MIR_LOCAL_GET() ||
