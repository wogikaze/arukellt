    op == opcodes::MIR_MOD() ||
    op == opcodes::MIR_EQ() ||
    op == opcodes::MIR_NEQ() ||
    op == opcodes::MIR_LT() ||
    op == opcodes::MIR_LTEQ() ||
    op == opcodes::MIR_GT() ||
    op == opcodes::MIR_GTEQ() ||
    op == opcodes::MIR_AND() ||
    op == opcodes::MIR_OR() ||
    op == opcodes::MIR_NEG() ||
    op == opcodes::MIR_NOT() ||
    op == opcodes::MIR_BIT_AND() ||
    op == opcodes::MIR_BIT_OR() ||
    op == opcodes::MIR_BIT_XOR() ||
    op == opcodes::MIR_SHL() ||
    op == opcodes::MIR_SHR() ||
    op == opcodes::MIR_CALL() ||
    op == opcodes::MIR_RETURN() ||
    op == opcodes::MIR_EXTEND_I32_TO_I64() ||
    op == opcodes::MIR_TRUNC_I64_TO_I32() ||
    op == opcodes::MIR_BR() ||
    op == opcodes::MIR_BR_IF() ||
    op == opcodes::MIR_BLOCK() ||
    op == opcodes::MIR_LOOP() ||
    op == opcodes::MIR_IF() ||
    op == opcodes::MIR_ELSE() ||
    op == opcodes::MIR_END() ||
    op == opcodes::MIR_EQZ() ||
    op == opcodes::MIR_STRUCT_NEW() ||
    op == opcodes::MIR_STRUCT_GET() ||
    op == opcodes::MIR_STRUCT_SET() ||
    op == opcodes::MIR_DROP() ||
    op == opcodes::MIR_NOP() ||
    op == opcodes::MIR_UNREACHABLE()
}

