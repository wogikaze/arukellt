    }
    if op == opcodes::MIR_GC_STRUCT_SET() {
        return String_from("planned phase 2")
    }
    if op == opcodes::MIR_REF_FUNC() {
        return String_from("planned phase 3")
    }
    String_from("unknown capability")
}

fn native_c_capability_is_supported(op: i32) -> bool {
    op == opcodes::MIR_CONST_I32() ||
    op == opcodes::MIR_RETURN()
}
