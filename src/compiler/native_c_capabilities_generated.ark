        return String_from("unsupported: future and async are outside the native-cpp MVP scope")
    }
    if op == opcodes::MIR_AWAIT() {
        return String_from("unsupported: future and async are outside the native-cpp MVP scope")
    }
    if op == opcodes::MIR_BR_ON_CAST() {
        return String_from("planned phase 3")
    }
    if op == opcodes::MIR_BR_ON_CAST_FAIL() {
        return String_from("planned phase 3")
    }
    if op == opcodes::MIR_REF_TEST() {
