// Arukellt Selfhost — MIR Lowering
//
// Extracted from mir.ark for module-level organization.

use std::host::env
use std::host::stdio
use mir_ir
use mir_opcodes
use mir_type_info

// Lowering context: tracks the current function, block, local name→index map
struct LowerCtx {
    module: MirModule,
    func: MirFunction,
    cur_block: i32,
    local_names: Vec<String>,
    local_indices: Vec<i32>,
    fn_names: Vec<String>,
    fn_indices: Vec<i32>,
    fn_return_vts: Vec<i32>,
    fn_return_type_names: Vec<String>,
    loop_exit_block: i32,
    loop_cond_block: i32,
    nesting_depth: i32,
    loop_break_depth: i32,
    loop_continue_depth: i32,
    loop_break_local: i32,
    struct_names: Vec<String>,
    struct_field_counts: Vec<i32>,
    struct_all_fields: Vec<String>,
    struct_field_types: Vec<String>,
    local_types: Vec<String>,
    local_type_indices: Vec<i32>,
    variant_names: Vec<String>,
    variant_tags: Vec<i32>,
    payload_variants: Vec<String>,
    closure_counter: i32,
    closure_last_synth: String,
    closure_last_caps: String,
    closure_last_extra: i32,
    closure_bind_names: Vec<String>,
    closure_bind_synth: Vec<String>,
    closure_bind_caps: Vec<String>,
    closure_bind_extra: Vec<i32>,
    local_type_start: i32,
    mono_call_starts: Vec<i32>,
    mono_call_targets: Vec<String>,
    mono_call_sources: Vec<String>,
    mono_call_used: Vec<i32>,
}

fn LowerCtx_new(m: MirModule) -> LowerCtx {
    LowerCtx { module: m, func: mir_ir::MirFunction_new(String_from("")), cur_block: 0, local_names: Vec_new_String(), local_indices: Vec_new_i32(), fn_names: Vec_new_String(), fn_indices: Vec_new_i32(), fn_return_vts: Vec_new_i32(), fn_return_type_names: Vec_new_String(), loop_exit_block: 0 - 1, loop_cond_block: 0 - 1, nesting_depth: 0, loop_break_depth: 0 - 1, loop_continue_depth: 0 - 1, loop_break_local: 0 - 1, struct_names: Vec_new_String(), struct_field_counts: Vec_new_i32(), struct_all_fields: Vec_new_String(), struct_field_types: Vec_new_String(), local_types: Vec_new_String(), local_type_indices: Vec_new_i32(), variant_names: Vec_new_String(), variant_tags: Vec_new_i32(), payload_variants: Vec_new_String(), closure_counter: 0, closure_last_synth: String_new(), closure_last_caps: String_new(), closure_last_extra: 0, closure_bind_names: Vec_new_String(), closure_bind_synth: Vec_new_String(), closure_bind_caps: Vec_new_String(), closure_bind_extra: Vec_new_i32(), local_type_start: 0, mono_call_starts: Vec_new_i32(), mono_call_targets: Vec_new_String(), mono_call_sources: Vec_new_String(), mono_call_used: Vec_new_i32() }
}

fn mono_safe_name(name: String) -> String {
    let mut out = String_from("")
    let n = len(name)
    let mut i = 0
    while i < n {
        let ch = char_at(name, i)
        if ch == 60 || ch == 62 || ch == 44 || ch == 58 || ch == 32 {
            out = concat(out, String_from("_"))
        } else {
            out = concat(out, substring(name, i, i + 1))
        }
        i = i + 1
    }
    out
}

fn mono_instance_count_for(instances: Vec<MonoInstance>, fn_name: String) -> i32 {
    let count = len(instances)
    let mut found = 0
    let mut i = 0
    while i < count {
        let mi = get_unchecked(instances, i)
        let mut is_marker = false
        if len(mi.type_args) > 0 {
            let marker_ty = get_unchecked(mi.type_args, 0)
            is_marker = marker_ty.tag < 0
        }
        if !is_marker && eq(clone(mi.fn_name), clone(fn_name)) {
            found = found + 1
        }
        i = i + 1
    }
    found
}

fn mono_instance_mangled_at(instances: Vec<MonoInstance>, fn_name: String, ordinal: i32) -> String {
    let count = len(instances)
    let mut seen = 0
    let mut i = 0
    while i < count {
        let mi = get_unchecked(instances, i)
        let mut is_marker = false
        if len(mi.type_args) > 0 {
            let marker_ty = get_unchecked(mi.type_args, 0)
            is_marker = marker_ty.tag < 0
        }
        if !is_marker && eq(clone(mi.fn_name), clone(fn_name)) {
            if seen == ordinal {
                return clone(mi.mangled_name)
            }
            seen = seen + 1
        }
        i = i + 1
    }
    String_from("")
}

fn ctx_mono_lookup_call(ctx: LowerCtx, span_start: i32) -> String {
    let count = len(ctx.mono_call_starts)
    let mut i = 0
    while i < count {
        if get_unchecked(ctx.mono_call_starts, i) == span_start {
            return clone(get_unchecked(ctx.mono_call_targets, i))
        }
        i = i + 1
    }
    String_from("")
}

fn mir_short_name(name: String) -> String {
    let nlen = len(name)
    let mut colon_pos = 0 - 1
    let mut ci = nlen - 1
    while ci >= 0 {
        if char_at(name, ci) == 58 {
            colon_pos = ci
            ci = 0 - 1
        }
        ci = ci - 1
    }
    if colon_pos >= 0 {
        return substring(name, colon_pos + 1, nlen)
    }
    clone(name)
}

fn mir_mark_reachable_name(functions: Vec<MirFunction>, reachable: Vec<i32>, name: String) -> bool {
    let count = len(functions)
    let mut i = 0
    while i < count {
        let f = get_unchecked(functions, i)
        if eq(clone(f.name), clone(name)) {
            if get_unchecked(reachable, i) == 0 {
                set(reachable, i, 1)
                return true
            }
            return false
        }
        i = i + 1
    }
    let short = mir_short_name(clone(name))
    if !eq(clone(short), clone(name)) {
        let mut j = 0
        while j < count {
            let f = get_unchecked(functions, j)
            if eq(clone(f.name), clone(short)) {
                if get_unchecked(reachable, j) == 0 {
                    set(reachable, j, 1)
                    return true
                }
                return false
            }
            j = j + 1
        }
    }
    false
}

fn mir_prune_unreachable(m: MirModule) -> i32 {
    let fn_count = len(m.functions)
    if fn_count == 0 {
        return 0
    }
    let reachable = Vec_new_i32()
    let mut i = 0
    while i < fn_count {
        push(reachable, 0)
        i = i + 1
    }
    let mut root_count = 0
    if mir_mark_reachable_name(m.functions, reachable, String_from("main")) {
        root_count = root_count + 1
    }
    if mir_mark_reachable_name(m.functions, reachable, String_from("_start")) {
        root_count = root_count + 1
    }
    if root_count == 0 {
        return 0
    }
    let mut changed = true
    while changed {
        changed = false
        let mut fi = 0
        while fi < fn_count {
            if get_unchecked(reachable, fi) != 0 {
                let f = get_unchecked(m.functions, fi)
                let block_count = len(f.blocks)
                let mut bi = 0
                while bi < block_count {
                    let block = get_unchecked(f.blocks, bi)
                    let inst_count = len(block.instructions)
                    let mut ii = 0
                    while ii < inst_count {
                        let inst = get_unchecked(block.instructions, ii)
                        if inst.op == mir_opcodes::MIR_CALL() {
                            if mir_mark_reachable_name(m.functions, reachable, clone(inst.str_val)) {
                                changed = true
                            }
                        }
                        ii = ii + 1
                    }
                    bi = bi + 1
                }
            }
            fi = fi + 1
        }
    }
    let kept = Vec_new_MirFunction()
    let mut pruned = 0
    i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        if get_unchecked(reachable, i) != 0 {
            push(kept, f)
        } else {
            pruned = pruned + 1
        }
        i = i + 1
    }
    m.functions = kept
    m.mono_pruned_count = pruned
    pruned
}

fn ctx_has_fn_name(ctx: LowerCtx, name: String) -> bool {
    let fc = len(ctx.fn_names)
    let mut i = 0
    while i < fc {
        if eq(clone(get_unchecked(ctx.fn_names, i)), clone(name)) {
            return true
        }
        i = i + 1
    }
    false
}

// Look up return VT for a named function (VT_VOID=0 if not found or void, VT_I32=1, VT_F64=3)
fn ctx_fn_return_vt(ctx: LowerCtx, name: String) -> i32 {
    let fc = len(ctx.fn_names)
    let mut i = 0
    while i < fc {
        if eq(clone(get_unchecked(ctx.fn_names, i)), clone(name)) {
            return get_unchecked(ctx.fn_return_vts, i)
        }
        i = i + 1
    }
    let nlen = len(name)
    let mut colon_pos = 0 - 1
    let mut ci = nlen - 1
    while ci >= 0 {
        if char_at(name, ci) == 58 {
            colon_pos = ci
            ci = 0 - 1
        }
        ci = ci - 1
    }
    if colon_pos >= 0 {
        let short = substring(name, colon_pos + 1, nlen)
        let mut j = 0
        while j < fc {
            if eq(clone(get_unchecked(ctx.fn_names, j)), clone(short)) {
                return get_unchecked(ctx.fn_return_vts, j)
            }
            j = j + 1
        }
    }
    let mut bare_name = clone(name)
    if len(bare_name) > 12 && char_at(bare_name, 0) == 95 && char_at(bare_name, 1) == 95 {
        bare_name = substring(bare_name, 12, len(bare_name))
    }
    let is_void_builtin = eq(clone(bare_name), "stdio::println") || eq(clone(bare_name), "println") || eq(clone(bare_name), "stdio::print") || eq(clone(bare_name), "print") || eq(clone(bare_name), "stdio::eprintln") || eq(clone(bare_name), "eprintln") || eq(clone(bare_name), "stdio::eprint") || eq(clone(bare_name), "eprint") || eq(clone(bare_name), "process::exit") || eq(clone(bare_name), "host::process::exit") || eq(clone(bare_name), "push_char") || eq(clone(bare_name), "push") || eq(clone(bare_name), "push_byte") || eq(clone(bare_name), "push_i64") || eq(clone(bare_name), "push_f64") || eq(clone(bare_name), "sort_i32") || eq(clone(bare_name), "sort_i64") || eq(clone(bare_name), "sort_f64") || eq(clone(bare_name), "reverse_String") || eq(clone(bare_name), "assert") || eq(clone(bare_name), "assert_eq") || eq(clone(bare_name), "assert_ne") || eq(clone(bare_name), "assert_eq_str") || eq(clone(bare_name), "assert_eq_i64") || eq(clone(bare_name), "memory_copy") || eq(clone(bare_name), "memory_fill") || eq(clone(bare_name), "HashMap_i32_i32_insert") || eq(clone(bare_name), "HashMap_i32_String_insert") || eq(clone(bare_name), "HashMap_String_i32_insert") || eq(clone(bare_name), "HashMap_String_String_insert") || eq(clone(bare_name), "hashmap_set") || eq(clone(bare_name), "hashmap_clear") || eq(clone(bare_name), "hashset_insert") || eq(clone(bare_name), "hashset_remove") || eq(clone(bare_name), "hashset_str_insert") || eq(clone(bare_name), "hashset_str_remove")
    if is_void_builtin {
        return mir_ir::VT_VOID()
    }
    if eq(clone(bare_name), "i32_to_i64") || eq(clone(bare_name), "u32_to_u64") {
        return mir_ir::VT_I64()
    }
    mir_ir::VT_I32()
}

// Look up return struct type name for a named function (empty string if not a struct return)
fn ctx_fn_return_type_name(ctx: LowerCtx, name: String) -> String {
    let fc = len(ctx.fn_names)
    let mut i = 0
    while i < fc {
        if eq(clone(get_unchecked(ctx.fn_names, i)), clone(name)) {
            return clone(get_unchecked(ctx.fn_return_type_names, i))
        }
        i = i + 1
    }
    let nlen = len(name)
    let mut colon_pos = 0 - 1
    let mut ci = nlen - 1
    while ci >= 0 {
        if char_at(name, ci) == 58 {
            colon_pos = ci
            ci = 0 - 1
        }
        ci = ci - 1
    }
    if colon_pos >= 0 {
        let short = substring(name, colon_pos + 1, nlen)
        let mut j = 0
        while j < fc {
            if eq(clone(get_unchecked(ctx.fn_names, j)), clone(short)) {
                return clone(get_unchecked(ctx.fn_return_type_names, j))
            }
            j = j + 1
        }
    }
    String_from("")
}

// Returns true (1) if a function with the given name is registered in fn_names.
fn ctx_fn_exists(ctx: LowerCtx, name: String) -> i32 {
    let fc = len(ctx.fn_names)
    let mut i = 0
    while i < fc {
        if eq(clone(get_unchecked(ctx.fn_names, i)), clone(name)) {
            return 1
        }
        i = i + 1
    }
    0
}

// Look up field index within a struct definition
fn ctx_field_index(ctx: LowerCtx, struct_name: String, field_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut fi = 0
            while fi < fc {
                let fn_name = get_unchecked(ctx.struct_all_fields, offset + fi)
                if eq(clone(fn_name), clone(field_name)) {
                    return fi
                }
                fi = fi + 1
            }
            return 0
        }
        offset = offset + fc
        si = si + 1
    }
    0
}

// Find field index by name searching ALL struct definitions
fn ctx_field_index_any(ctx: LowerCtx, field_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let fc = get_unchecked(ctx.struct_field_counts, si)
        let mut fi = 0
        while fi < fc {
            let fn_name = get_unchecked(ctx.struct_all_fields, offset + fi)
            if eq(clone(fn_name), clone(field_name)) {
                return fi
            }
            fi = fi + 1
        }
        offset = offset + fc
        si = si + 1
    }
    0
}

// Get field count for a struct by name
fn ctx_struct_field_count(ctx: LowerCtx, struct_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        if eq(clone(sn), clone(struct_name)) {
            return get_unchecked(ctx.struct_field_counts, si)
        }
        si = si + 1
    }
    0
}

// Get field name at index for a struct by name
fn ctx_struct_field_name(ctx: LowerCtx, struct_name: String, field_idx: i32) -> String {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            return clone(get_unchecked(ctx.struct_all_fields, offset + field_idx))
        }
        offset = offset + fc
        si = si + 1
    }
    String_from("")
}

// Get the type of a field (e.g., "vec:i32", "Inner", or "")
fn ctx_get_field_type(ctx: LowerCtx, struct_name: String, field_name: String) -> String {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut fi = 0
            while fi < fc {
                let fn_name = get_unchecked(ctx.struct_all_fields, offset + fi)
                if eq(clone(fn_name), clone(field_name)) {
                    return clone(get_unchecked(ctx.struct_field_types, offset + fi))
                }
                fi = fi + 1
            }
            return String_from("")
        }
        offset = offset + fc
        si = si + 1
    }
    String_from("")
}

// Compute byte offset for a field, accounting for f64 fields (8 bytes) vs i32 fields (4 bytes)
fn ctx_struct_field_offset(ctx: LowerCtx, struct_name: String, target_field_idx: i32) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut byte_off = 0
            let mut fi = 0
            while fi < target_field_idx && fi < fc {
                let ft = get_unchecked(ctx.struct_field_types, offset + fi)
                if eq(clone(ft), "f64") {
                    byte_off = byte_off + 8
                } else {
                    byte_off = byte_off + 4
                }
                fi = fi + 1
            }
            return byte_off
        }
        offset = offset + fc
        si = si + 1
    }
    target_field_idx * 4
}

// Compute total byte size of a struct
fn ctx_struct_byte_size(ctx: LowerCtx, struct_name: String) -> i32 {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            let mut byte_off = 0
            let mut fi = 0
            while fi < fc {
                let ft = get_unchecked(ctx.struct_field_types, offset + fi)
                if eq(clone(ft), "f64") {
                    byte_off = byte_off + 8
                } else {
                    byte_off = byte_off + 4
                }
                fi = fi + 1
            }
            return byte_off
        }
        offset = offset + fc
        si = si + 1
    }
    0
}

// Check if a struct field at given index is f64
fn ctx_struct_field_is_f64(ctx: LowerCtx, struct_name: String, field_idx: i32) -> bool {
    let sc = len(ctx.struct_names)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = get_unchecked(ctx.struct_names, si)
        let fc = get_unchecked(ctx.struct_field_counts, si)
        if eq(clone(sn), clone(struct_name)) {
            if field_idx < fc {
                let ft = get_unchecked(ctx.struct_field_types, offset + field_idx)
                return eq(clone(ft), "f64")
            }
            return false
        }
        offset = offset + fc
        si = si + 1
    }
    false
}

// Track struct type for a local variable
fn ctx_set_local_type(ctx: LowerCtx, local_idx: i32, type_name: String) {
    push(ctx.local_types, clone(type_name))
    push(ctx.local_type_indices, local_idx)
}

fn ctx_get_local_type(ctx: LowerCtx, local_idx: i32) -> String {
    let count = len(ctx.local_type_indices)
    let mut i = count - 1
    while i >= ctx.local_type_start {
        let idx = get_unchecked(ctx.local_type_indices, i)
        if idx == local_idx {
            return clone(get_unchecked(ctx.local_types, i))
        }
        i = i - 1
    }
    String_new()
}

fn ctx_variant_tag(ctx: LowerCtx, name: String) -> i32 {
    let count = len(ctx.variant_names)
    let mut i = 0
    while i < count {
        let vn = get_unchecked(ctx.variant_names, i)
        if eq(clone(vn), clone(name)) {
            return get_unchecked(ctx.variant_tags, i)
        }
        i = i + 1
    }
    0 - 1
}

fn ctx_is_payload_variant(ctx: LowerCtx, name: String) -> bool {
    let count = len(ctx.payload_variants)
    let mut i = 0
    while i < count {
        if eq(clone(get_unchecked(ctx.payload_variants, i)), clone(name)) {
            return true
        }
        i = i + 1
    }
    false
}

fn ctx_register_builtin_variants(ctx: LowerCtx) {
    push(ctx.variant_names, String_from("Some"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("None"))
    push(ctx.variant_tags, 1)
    push(ctx.variant_names, String_from("Option::Some"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("Option::None"))
    push(ctx.variant_tags, 1)
    push(ctx.variant_names, String_from("Ok"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("Err"))
    push(ctx.variant_tags, 1)
    push(ctx.variant_names, String_from("Result::Ok"))
    push(ctx.variant_tags, 0)
    push(ctx.variant_names, String_from("Result::Err"))
    push(ctx.variant_tags, 1)
    push(ctx.payload_variants, String_from("Some"))
    push(ctx.payload_variants, String_from("None"))
    push(ctx.payload_variants, String_from("Ok"))
    push(ctx.payload_variants, String_from("Err"))
    push(ctx.payload_variants, String_from("Option::Some"))
    push(ctx.payload_variants, String_from("Option::None"))
    push(ctx.payload_variants, String_from("Result::Ok"))
    push(ctx.payload_variants, String_from("Result::Err"))
}

fn ctx_alloc_local(ctx: LowerCtx, name: String, vt: i32) -> i32 {
    let mut f = ctx.func
    let idx = mir_ir::alloc_local(f, clone(name), vt)
    ctx.func = f
    push(ctx.local_names, name)
    push(ctx.local_indices, idx)
    idx
}

fn ctx_lookup_local(ctx: LowerCtx, name: String) -> i32 {
    let count = len(ctx.local_names)
    let mut i = count - 1
    while i >= 0 {
        let n = get_unchecked(ctx.local_names, i)
        if eq(clone(n), clone(name)) {
            return get_unchecked(ctx.local_indices, i)
        }
        i = i - 1
    }
    0 - 1
}

fn ctx_emit(ctx: LowerCtx, inst: MirInst) {
    let mut f = ctx.func
    mir_ir::emit_inst(f, ctx.cur_block, inst)
    ctx.func = f
}

fn ctx_fresh_local(ctx: LowerCtx, vt: i32) -> i32 {
    let mut f = ctx.func
    let idx = f.next_local
    mir_ir::alloc_local(f, concat(String_from("_t"), to_string(idx)), vt)
    ctx.func = f
    idx
}

fn closure_is_param_name(clos: AstNode, name: String) -> bool {
    let c = len(clos.children)
    if c <= 1 {
        return false
    }
    let mut i = 0
    while i < c - 1 {
        let p = get_unchecked(clos.children, i)
        if p.kind == mir_type_info::NK_IDENT() && eq(clone(p.text), clone(name)) {
            return true
        }
        i = i + 1
    }
    false
}

fn closure_collect_free(ctx: LowerCtx, expr: AstNode, clos: AstNode, acc: Vec<String>) {
    if expr.kind == mir_type_info::NK_CLOSURE() {
        return
    }
    if expr.kind == mir_type_info::NK_IDENT() {
        if closure_is_param_name(clos, clone(expr.text)) {
            return
        }
        if ctx_lookup_local(ctx, clone(expr.text)) < 0 {
            return
        }
        let n = clone(expr.text)
        let mut j = len(acc) - 1
        let mut dup = false
        while j >= 0 && !dup {
            if eq(clone(get_unchecked(acc, j)), clone(n)) {
                dup = true
            }
            j = j - 1
        }
        if !dup {
            push(acc, n)
        }
        return
    }
    let cc = len(expr.children)
    let mut ci = 0
    while ci < cc {
        closure_collect_free(ctx, get_unchecked(expr.children, ci), clos, acc)
        ci = ci + 1
    }
}

fn closure_pack_caps(caps: Vec<String>) -> String {
    let mut s = String_new()
    let c = len(caps)
    let mut i = 0
    while i < c {
        if i > 0 {
            s = concat(s, String_from(","))
        }
        s = concat(s, clone(get_unchecked(caps, i)))
        i = i + 1
    }
    s
}

fn closure_emit_captured_args(ctx: LowerCtx, packed: String) {
    let mut start = 0
    let mut i = 0
    let L = len(packed)
    while i <= L {
        let at_end = i == L
        let mut is_comma = false
        if !at_end {
            if char_at(packed, i) == 44 {
                is_comma = true
            }
        }
        if at_end || is_comma {
            if i > start {
                let name = substring(packed, start, i)
                if len(name) > 0 {
                    let li = ctx_lookup_local(ctx, clone(name))
                    if li >= 0 {
                        let g = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                        g.arg0 = li
                        g.dest = li
                        ctx_emit(ctx, g)
                    }
                }
            }
            start = i + 1
        }
        i = i + 1
    }
}

fn closure_flush_pending_bind(ctx: LowerCtx, bind_name: String) {
    if len(ctx.closure_last_synth) == 0 {
        return
    }
    push(ctx.closure_bind_names, bind_name)
    push(ctx.closure_bind_synth, clone(ctx.closure_last_synth))
    push(ctx.closure_bind_caps, clone(ctx.closure_last_caps))
    push(ctx.closure_bind_extra, ctx.closure_last_extra)
    ctx.closure_last_synth = String_new()
    ctx.closure_last_caps = String_new()
    ctx.closure_last_extra = 0
}

fn ctx_closure_lookup(ctx: LowerCtx, name: String) -> i32 {
    let count = len(ctx.closure_bind_names)
    let mut i = count - 1
    while i >= 0 {
        if eq(clone(get_unchecked(ctx.closure_bind_names, i)), clone(name)) {
            return i
        }
        i = i - 1
    }
    0 - 1
}

fn mir_emit_closure_fn(ctx: LowerCtx, synth: String, clos: AstNode, caps: Vec<String>) -> MirFunction {
    let saved_func = ctx.func
    let saved_block = ctx.cur_block
    let saved_names = ctx.local_names
    let saved_indices = ctx.local_indices
    let saved_types = ctx.local_types
    let saved_tidx = ctx.local_type_indices
    let saved_type_start = ctx.local_type_start
    let cap_n = len(caps)
    let cap_vts = Vec_new_i32()
    let mut cvi = 0
    while cvi < cap_n {
        let cname = clone(get_unchecked(caps, cvi))
        let cli = ctx_lookup_local(ctx, clone(cname))
        let mut pvt = mir_ir::VT_I32()
        if cli >= 0 {
            pvt = ctx_local_vt(ctx, cli)
        }
        push(cap_vts, pvt)
        cvi = cvi + 1
    }
    let mf = mir_ir::MirFunction_new(clone(synth))
    ctx.func = mf
    ctx.local_names = Vec_new_String()
    ctx.local_indices = Vec_new_i32()
    ctx.local_types = Vec_new_String()
    ctx.local_type_indices = Vec_new_i32()
    ctx.local_type_start = 0
    let entry = mir_ir::ctx_alloc_block(ctx)
    ctx.cur_block = entry
    let child_count = len(clos.children)
    let body = get_unchecked(clos.children, child_count - 1)
    let mut pi = 0
    while pi + 1 < child_count {
        let p = get_unchecked(clos.children, pi)
        if p.kind == mir_type_info::NK_IDENT() {
            let pvt = mir_ir::VT_I32()
            let _idx = ctx_alloc_local(ctx, clone(p.text), pvt)
            let mut fparam = ctx.func
            push(fparam.params, MirLocal { name: clone(p.text), val_type: pvt, type_name: String_new(), ssa_name: clone(p.text), ssa_version: 0 - 1 })
            ctx.func = fparam
        }
        pi = pi + 1
    }
    let mut ci = 0
    while ci < cap_n {
        let cname = clone(get_unchecked(caps, ci))
        let pvt = get_unchecked(cap_vts, ci)
        let _idx2 = ctx_alloc_local(ctx, clone(cname), pvt)
        let mut fparam2 = ctx.func
        push(fparam2.params, MirLocal { name: clone(cname), val_type: pvt, type_name: String_new(), ssa_name: clone(cname), ssa_version: 0 - 1 })
        ctx.func = fparam2
        ci = ci + 1
    }
    let mut fret = ctx.func
    fret.return_type = mir_ir::VT_I32()
    ctx.func = fret
    let res = lower_expr(ctx, body)
    if res >= 0 {
        let ret_inst = mir_ir::MirInst_new(mir_opcodes::MIR_RETURN())
        ret_inst.arg0 = res
        ctx_emit(ctx, ret_inst)
    } else {
        ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_RETURN()))
    }
    let out_fn = ctx.func
    ctx.func = saved_func
    ctx.cur_block = saved_block
    ctx.local_names = saved_names
    ctx.local_indices = saved_indices
    ctx.local_types = saved_types
    ctx.local_type_indices = saved_tidx
    ctx.local_type_start = saved_type_start
    out_fn
}

fn ctx_local_vt(ctx: LowerCtx, idx: i32) -> i32 {
    if idx >= 0 && idx < len(ctx.func.locals) {
        let loc = get_unchecked(ctx.func.locals, idx)
        return loc.val_type
    }
    mir_ir::VT_I32()
}

fn ctx_set_local_vt(ctx: LowerCtx, idx: i32, vt: i32) {
    if idx >= 0 && idx < len(ctx.func.locals) {
        let mut f = ctx.func
        let loc = get_unchecked(f.locals, idx)
        loc.val_type = vt
        f.locals = mir_ir::mir_locals_replace_at(f.locals, idx, loc)
        ctx.func = f
    }
}

// When MIR_LOWER_TRACE=1 in the environment, lower_to_mir prints five integers per phase:
// phase, len(params), len(locals), len(blocks), return_type tag.
fn MIR_LOWER_TRACE() -> i32 {
    match env::var(String_from("MIR_LOWER_TRACE")) {
        Option::Some(s) => {
            if eq(s, String_from("1")) {
                return 1
            }
            0
        },
        None => 0,
    }
}

// Set to 1 in source to force mir_lower trace without env (e.g. if env::var is unavailable).
fn MIR_LOWER_TRACE_FORCE() -> i32 {
    0
}

fn mir_lower_trace_line(on: i32, phase: i32, np: i32, nl: i32, nb: i32, rt: i32) {
    if on == 0 {
        return
    }
    let mut s = to_string(phase)
    s = concat(s, String_from(" "))
    s = concat(s, to_string(np))
    s = concat(s, String_from(" "))
    s = concat(s, to_string(nl))
    s = concat(s, String_from(" "))
    s = concat(s, to_string(nb))
    s = concat(s, String_from(" "))
    s = concat(s, to_string(rt))
    stdio::eprintln(s)
}

fn mir_lower_trace_ctx(on: i32, ctx: LowerCtx, phase: i32) {
    if on == 0 {
        return
    }
    let f = ctx.func
    mir_lower_trace_line(on, phase, len(f.params), len(f.locals), len(f.blocks), f.return_type)
}

fn ctx_push_func_param(ctx: LowerCtx, ml: MirLocal) {
    let mut f = ctx.func
    push(f.params, ml)
    ctx.func = f
}

fn ctx_apply_fn_return_type_for_rt_tag(ctx: LowerCtx, rt_tag: i32) {
    let mut f = ctx.func
    if rt_tag == 3 {
        f.return_type = mir_ir::VT_F64()
    } else {
        if rt_tag == 2 {
            f.return_type = mir_ir::VT_I64()
        } else {
            if rt_tag >= 1 && rt_tag <= 6 {
                f.return_type = mir_ir::VT_I32()
            }
        }
    }
    if rt_tag >= 10 && rt_tag <= 12 {
        f.return_type = mir_ir::VT_I32()
    }
    if rt_tag >= 20 && rt_tag <= 23 {
        f.return_type = mir_ir::VT_I32()
    }
    ctx.func = f
}

fn mir_decl_return_type_name(fn_node: AstNode) -> String {
    let ta_count = len(fn_node.type_ann)
    let mut i = 0
    while i < ta_count {
        let ann = get_unchecked(fn_node.type_ann, i)
        if eq(clone(ann.text), "__return") {
            if len(ann.children) > 0 {
                let ret_node = get_unchecked(ann.children, 0)
                if ret_node.kind == 91 {
                    if eq(clone(ret_node.text), "Option") && len(ret_node.children) >= 2 {
                        let elem = get_unchecked(ret_node.children, 1)
                        return concat(String_from("Option:"), clone(elem.text))
                    }
                    if eq(clone(ret_node.text), "Result") && len(ret_node.children) >= 3 {
                        let ok_ty = get_unchecked(ret_node.children, 1)
                        let err_ty = get_unchecked(ret_node.children, 2)
                        return concat(String_from("Result:"), concat(clone(ok_ty.text), concat(String_from(":"), clone(err_ty.text))))
                    }
                }
                return clone(ret_node.text)
            }
            return String_from("()")
        }
        i = i + 1
    }
    String_from("()")
}

fn mir_param_type_name_from_ann(ty: AstNode) -> String {
    if ty.kind == 91 {
        if eq(clone(ty.text), "Option") && len(ty.children) >= 2 {
            let elem = get_unchecked(ty.children, 1)
            return concat(String_from("Option:"), clone(elem.text))
        }
        if eq(clone(ty.text), "Result") && len(ty.children) >= 3 {
            let ok_ty = get_unchecked(ty.children, 1)
            let err_ty = get_unchecked(ty.children, 2)
            return concat(String_from("Result:"), concat(clone(ok_ty.text), concat(String_from(":"), clone(err_ty.text))))
        }
    }
    if ty.kind == 93 && len(ty.children) == 2 {
        let a = get_unchecked(ty.children, 0)
        let b = get_unchecked(ty.children, 1)
        return concat(String_from("Tuple:"), concat(clone(a.text), concat(String_from(":"), clone(b.text))))
    }
    clone(ty.text)
}

fn binop_to_mir(op: i32) -> i32 {
    if op == mir_type_info::OP_ADD() {
        return mir_opcodes::MIR_ADD()
    }
    if op == mir_type_info::OP_SUB() {
        return mir_opcodes::MIR_SUB()
    }
    if op == mir_type_info::OP_MUL() {
        return mir_opcodes::MIR_MUL()
    }
    if op == mir_type_info::OP_DIV() {
        return mir_opcodes::MIR_DIV()
    }
    if op == mir_type_info::OP_MOD() {
        return mir_opcodes::MIR_MOD()
    }
    if op == mir_type_info::OP_EQ() {
        return mir_opcodes::MIR_EQ()
    }
    if op == mir_type_info::OP_NEQ() {
        return mir_opcodes::MIR_NEQ()
    }
    if op == mir_type_info::OP_LT() {
        return mir_opcodes::MIR_LT()
    }
    if op == mir_type_info::OP_LTEQ() {
        return mir_opcodes::MIR_LTEQ()
    }
    if op == mir_type_info::OP_GT() {
        return mir_opcodes::MIR_GT()
    }
    if op == mir_type_info::OP_GTEQ() {
        return mir_opcodes::MIR_GTEQ()
    }
    if op == mir_type_info::OP_AND() {
        return mir_opcodes::MIR_AND()
    }
    if op == mir_type_info::OP_OR() {
        return mir_opcodes::MIR_OR()
    }
    if op == mir_type_info::OP_BIT_AND() {
        return mir_opcodes::MIR_BIT_AND()
    }
    if op == mir_type_info::OP_BIT_OR() {
        return mir_opcodes::MIR_BIT_OR()
    }
    if op == mir_type_info::OP_BIT_XOR() {
        return mir_opcodes::MIR_BIT_XOR()
    }
    if op == mir_type_info::OP_SHL() {
        return mir_opcodes::MIR_SHL()
    }
    if op == mir_type_info::OP_SHR() {
        return mir_opcodes::MIR_SHR()
    }
    mir_opcodes::MIR_NOP()
}

// Quickly peek at the expected VT of an expression without lowering it.
// Only handles the common cases; returns VT_I32 for everything else.
fn peek_expr_vt(ctx: LowerCtx, node: AstNode) -> i32 {
    if node.kind == mir_type_info::NK_IDENT() {
        let idx = ctx_lookup_local(ctx, clone(node.text))
        if idx >= 0 {
            return ctx_local_vt(ctx, idx)
        }
    }
    if node.kind == mir_type_info::NK_FLOAT_LIT() {
        return mir_ir::VT_F64()
    }
    mir_ir::VT_I32()
}

// Lower an expression node, returns the local index holding the result.
// Returns -1 for void / statement-like expressions.
fn lower_expr(ctx: LowerCtx, node: AstNode) -> i32 {
    let kind = node.kind
    if kind == mir_type_info::NK_INT_LIT() {
        let raw_text = clone(node.text)
        let raw_len = len(raw_text)
        let mut is_i64_literal = false
        let is_hex_or_bin = raw_len >= 2 && char_at(raw_text, 0) == 48 && char_at(raw_text, 1) == 120 || char_at(raw_text, 1) == 88 || char_at(raw_text, 1) == 98 || char_at(raw_text, 1) == 66
        let mut has_small_suffix = false
        let mut has_64_suffix = false
        if raw_len >= 2 {
            let last = char_at(raw_text, raw_len - 1)
            let prev = char_at(raw_text, raw_len - 2)
            if last == 56 && (prev == 105 || prev == 117) {
                has_small_suffix = true
            }
            if raw_len >= 3 {
                let last3a = char_at(raw_text, raw_len - 3)
                let last3b = char_at(raw_text, raw_len - 2)
                let last3c = char_at(raw_text, raw_len - 1)
                if (last3a == 105 || last3a == 117) && last3b == 49 && last3c == 54 {
                    has_small_suffix = true
                }
                if (last3a == 105 || last3a == 117) && last3b == 51 && last3c == 50 {
                    has_small_suffix = true
                }
                if (last3a == 105 || last3a == 117) && last3b == 54 && last3c == 52 {
                    has_64_suffix = true
                }
            }
        }
        if !is_hex_or_bin && !has_small_suffix {
            let as_i64 = mir_ir::parse_decimal_as_i64(clone(raw_text))
            let as_i32_ext = i32_to_i64(node.int_val)
            if as_i64 != as_i32_ext {
                is_i64_literal = true
            }
        }
        if has_64_suffix {
            is_i64_literal = true
        }
        if is_i64_literal {
            let dest = ctx_fresh_local(ctx, mir_ir::VT_I64())
            ctx_emit(ctx, mir_ir::MirInst_const_i64_text(raw_text, dest))
            return dest
        }
        let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
        ctx_emit(ctx, mir_ir::MirInst_const_i32(node.int_val, dest))
        return dest
    }
    if kind == mir_type_info::NK_CHAR_LIT() {
        let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
        ctx_emit(ctx, mir_ir::MirInst_const_i32(node.int_val, dest))
        ctx_set_local_type(ctx, dest, String_from("char"))
        return dest
    }
    if kind == mir_type_info::NK_FLOAT_LIT() {
        let dest = ctx_fresh_local(ctx, mir_ir::VT_F64())
        ctx_set_local_type(ctx, dest, String_from("f64"))
        ctx_emit(ctx, mir_ir::MirInst_const_f64(node.float_val, dest))
        return dest
    }
    if kind == mir_type_info::NK_BOOL_LIT() {
        let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
        ctx_set_local_type(ctx, dest, String_from("bool"))
        let mut bval = 0
        if eq(clone(node.text), "true") {
            bval = 1
        }
        ctx_emit(ctx, mir_ir::MirInst_const_i32(bval, dest))
        return dest
    }
    if kind == mir_type_info::NK_PAT_LITERAL() {
        let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
        let mut pval = node.int_val
        if eq(clone(node.text), "true") {
            pval = 1
        }
        if eq(clone(node.text), "false") {
            pval = 0
        }
        ctx_emit(ctx, mir_ir::MirInst_const_i32(pval, dest))
        return dest
    }
    if kind == mir_type_info::NK_PAT_WILDCARD() {
        return 0 - 1
    }
    if kind == mir_type_info::NK_PAT_IDENT() {
        return 0 - 1
    }
    if kind == mir_type_info::NK_PAT_VARIANT() {
        let tag = ctx_variant_tag(ctx, clone(node.text))
        if tag >= 0 {
            let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx_emit(ctx, mir_ir::MirInst_const_i32(tag, dest))
            return dest
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_PATH() {
        let tag = ctx_variant_tag(ctx, clone(node.text))
        if tag >= 0 {
            if ctx_is_payload_variant(ctx, clone(node.text)) {
                let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                let struct_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_NEW())
                struct_inst.dest = dest
                struct_inst.int_val = 4
                ctx_emit(ctx, struct_inst)
                let tag_tmp = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_const_i32(tag, tag_tmp))
                let set_tag = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_SET())
                set_tag.arg0 = dest
                set_tag.arg1 = tag_tmp
                set_tag.int_val = 0
                ctx_emit(ctx, set_tag)
                let get_r = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_r.arg0 = dest
                ctx_emit(ctx, get_r)
                return dest
            } else {
                let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_const_i32(tag, dest))
                return dest
            }
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_STRING_LIT() {
        let str_idx = mir_ir::intern_string(ctx.module, clone(node.text))
        let dest = ctx_fresh_local(ctx, mir_ir::VT_REF())
        let str_inst = mir_ir::MirInst_const_string(clone(node.text), dest)
        str_inst.arg0 = str_idx
        ctx_emit(ctx, str_inst)
        return dest
    }
    if kind == mir_type_info::NK_IDENT() {
        let idx = ctx_lookup_local(ctx, clone(node.text))
        if idx >= 0 {
            let inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            inst.arg0 = idx
            inst.dest = idx
            ctx_emit(ctx, inst)
            return idx
        }
        let ident_tag = ctx_variant_tag(ctx, clone(node.text))
        if ident_tag >= 0 {
            if ctx_is_payload_variant(ctx, clone(node.text)) {
                let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                let struct_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_NEW())
                struct_inst.dest = dest
                struct_inst.int_val = 4
                ctx_emit(ctx, struct_inst)
                let tag_tmp = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_const_i32(ident_tag, tag_tmp))
                let set_tag = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_SET())
                set_tag.arg0 = dest
                set_tag.arg1 = tag_tmp
                set_tag.int_val = 0
                ctx_emit(ctx, set_tag)
                let get_r = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_r.arg0 = dest
                ctx_emit(ctx, get_r)
                return dest
            } else {
                let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_const_i32(ident_tag, dest))
                return dest
            }
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_BINARY() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let lhs = get_unchecked(node.children, 0)
            let rhs = get_unchecked(node.children, 1)
            let mir_op = binop_to_mir(node.op)
            if mir_op == mir_opcodes::MIR_AND() || mir_op == mir_opcodes::MIR_OR() {
                let l_idx = lower_expr(ctx, lhs)
                let sc_result = ctx_fresh_local(ctx, mir_ir::VT_I32())
                let set_sc = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_sc.arg0 = sc_result
                ctx_emit(ctx, set_sc)
                let get_cond = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_cond.arg0 = sc_result
                ctx_emit(ctx, get_cond)
                if mir_op == mir_opcodes::MIR_OR() {
                    let eqz_inst = mir_ir::MirInst_new(mir_opcodes::MIR_NOT())
                    eqz_inst.dest = sc_result
                    eqz_inst.arg0 = sc_result
                    ctx_emit(ctx, eqz_inst)
                }
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                let r_idx = lower_expr(ctx, rhs)
                let set_sc2 = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_sc2.arg0 = sc_result
                ctx_emit(ctx, set_sc2)
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                let get_sc_final = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_sc_final.arg0 = sc_result
                ctx_emit(ctx, get_sc_final)
                return sc_result
            }
            let l_peek_vt = peek_expr_vt(ctx, lhs)
            let r_peek_vt = peek_expr_vt(ctx, rhs)
            let mut binop_vt = mir_ir::VT_I32()
            if l_peek_vt == mir_ir::VT_F64() || r_peek_vt == mir_ir::VT_F64() {
                binop_vt = mir_ir::VT_F64()
            } else {
                if l_peek_vt == mir_ir::VT_I64() || r_peek_vt == mir_ir::VT_I64() {
                    binop_vt = mir_ir::VT_I64()
                }
            }
            let l_idx = lower_expr(ctx, lhs)
            let ov_ltype = ctx_get_local_type(ctx, l_idx)
            let ov_is_primitive = len(ov_ltype) == 0 || eq(clone(ov_ltype), "i32") || eq(clone(ov_ltype), "i64") || eq(clone(ov_ltype), "f64") || eq(clone(ov_ltype), "bool") || eq(clone(ov_ltype), "char") || eq(clone(ov_ltype), "String") || eq(clone(ov_ltype), "string") || starts_with(clone(ov_ltype), "vec:") || starts_with(clone(ov_ltype), "option:")
            if !ov_is_primitive {
                let mut ov_method = String_from("")
                if mir_op == mir_opcodes::MIR_ADD() {
                    ov_method = String_from("add")
                } else {
                    if mir_op == mir_opcodes::MIR_SUB() {
                        ov_method = String_from("sub")
                    } else {
                        if mir_op == mir_opcodes::MIR_MUL() {
                            ov_method = String_from("mul")
                        } else {
                            if mir_op == mir_opcodes::MIR_DIV() {
                                ov_method = String_from("div")
                            } else {
                                if mir_op == mir_opcodes::MIR_EQ() {
                                    ov_method = String_from("eq")
                                } else {
                                    if mir_op == mir_opcodes::MIR_NEQ() {
