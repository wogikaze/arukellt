            let scrut_ok_is_f64 = eq(clone(scrut_type), "Result_f64") || eq(clone(scrut_type), "Option_f64")
            let scrut_ok_is_i64 = eq(clone(scrut_type), "Result_i64") || eq(clone(scrut_type), "Option_i64")
            let scrut_ok_is_i32 = eq(clone(scrut_type), "Option_i32") || eq(clone(scrut_type), "Result_i32")
            let mut compare_idx = scrut_idx
            if is_payload_match {
                let tag_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
                let get_s = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_s.arg0 = scrut_idx
                ctx_emit(ctx, get_s)
                let sget = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
                sget.int_val = 0
                ctx_emit(ctx, sget)
                let set_tl = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_tl.arg0 = tag_local
                ctx_emit(ctx, set_tl)
                compare_idx = tag_local
            }
            let arm_count = child_count - 1
            let mut arm = 1
            let mut if_depth = 0
            while arm < child_count {
                let arm_node = get_unchecked(node.children, arm)
                let arm_child_count = len(arm_node.children)
                let is_last = arm == child_count - 1
                let pat_idx_in_arm = 0
                let body_idx_in_arm = arm_child_count - 1
                let pat = get_unchecked(arm_node.children, pat_idx_in_arm)
                let body = get_unchecked(arm_node.children, body_idx_in_arm)
                if is_last {
                    if pat.kind == mir_type_info::NK_PAT_IDENT() {
                        let bind_last = ctx_alloc_local(ctx, clone(pat.text), mir_ir::VT_I32())
                        let get_sl = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                        get_sl.arg0 = scrut_idx
                        ctx_emit(ctx, get_sl)
                        let set_sl = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                        set_sl.arg0 = bind_last
                        ctx_emit(ctx, set_sl)
                    }
                    if is_payload_match && pat.kind == mir_type_info::NK_PAT_VARIANT() && len(pat.children) > 0 {
                        let variant_name = clone(pat.text)
                        let mut bi = 0
                        while bi < len(pat.children) {
                            let bind_pat = get_unchecked(pat.children, bi)
                            let mut field_is_f64 = ctx_struct_field_is_f64(ctx, clone(variant_name), bi + 1)
                            if !field_is_f64 && scrut_ok_is_f64 && bi == 0 {
                                if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") || eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
                                    field_is_f64 = true
                                }
                            }
                            let mut field_is_i64 = false
                            if !field_is_f64 && scrut_ok_is_i64 && bi == 0 {
                                if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") || eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
                                    field_is_i64 = true
                                }
                            }
                            let mut bind_vt = mir_ir::VT_I32()
                            if field_is_f64 {
                                bind_vt = mir_ir::VT_F64()
                            } else {
                                if field_is_i64 {
                                    bind_vt = mir_ir::VT_I64()
                                }
                            }
                            let bind_local = ctx_alloc_local(ctx, clone(bind_pat.text), bind_vt)
                            if bind_vt == mir_ir::VT_I32() && scrut_ok_is_i32 && bi == 0 {
                                if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") || eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
                                    ctx_set_local_type(ctx, bind_local, String_from("i32"))
                                }
                            }
                            let get_s2 = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                            get_s2.arg0 = scrut_idx
                            ctx_emit(ctx, get_s2)
                            let sget2 = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
                            sget2.int_val = ctx_struct_field_offset(ctx, clone(variant_name), bi + 1)
                            if field_is_f64 {
                                sget2.val_type = mir_ir::VT_F64()
                            } else {
                                if field_is_i64 {
                                    sget2.val_type = mir_ir::VT_I64()
                                }
                            }
                            ctx_emit(ctx, sget2)
                            let set_b = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                            set_b.arg0 = bind_local
                            ctx_emit(ctx, set_b)
                            bi = bi + 1
                        }
                    }
                    if arm_child_count == 3 {
                        let guard_last = get_unchecked(arm_node.children, 1)
                        lower_expr(ctx, guard_last)
                        ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                        ctx.nesting_depth = ctx.nesting_depth + 1
                        if_depth = if_depth + 1
                    }
                    let arm_result = lower_expr(ctx, body)
                    if arm_result >= 0 {
                        let arm_vt = ctx_local_vt(ctx, arm_result)
                        if arm_vt == mir_ir::VT_I64() || arm_vt == mir_ir::VT_F64() {
                            ctx_set_local_vt(ctx, result, arm_vt)
                        }
                        let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                        set_inst.arg0 = result
                        ctx_emit(ctx, set_inst)
                    }
                    if arm_child_count == 3 {
                        ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                        ctx.nesting_depth = ctx.nesting_depth - 1
                        if_depth = if_depth - 1
                    }
                } else {
                    let is_catchall = pat.kind == mir_type_info::NK_PAT_IDENT() || pat.kind == mir_type_info::NK_PAT_WILDCARD()
                    let has_guard = arm_child_count == 3
                    if is_catchall {
                        if pat.kind == mir_type_info::NK_PAT_IDENT() {
                            let bind_ca = ctx_alloc_local(ctx, clone(pat.text), mir_ir::VT_I32())
                            let get_ca = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                            get_ca.arg0 = scrut_idx
                            ctx_emit(ctx, get_ca)
                            let set_ca = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                            set_ca.arg0 = bind_ca
                            ctx_emit(ctx, set_ca)
                        }
                        if has_guard {
                            let guard = get_unchecked(arm_node.children, 1)
                            lower_expr(ctx, guard)
                            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                        }
                    } else {
                        if pat.kind == mir_type_info::NK_PAT_OR() {
                            let alt_count = len(pat.children)
                            let mut or_oi = 0
                            while or_oi < alt_count {
                                let or_alt = get_unchecked(pat.children, or_oi)
                                let get_or = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                                get_or.arg0 = compare_idx
                                ctx_emit(ctx, get_or)
                                lower_expr(ctx, or_alt)
                                let or_cmp = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_EQ(), or_cmp, compare_idx, or_cmp))
                                if or_oi > 0 {
                                    let or_dummy = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                    ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_BIT_OR(), or_dummy, or_cmp, or_cmp))
                                }
                                or_oi = or_oi + 1
                            }
                            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                        } else {
                            let get_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                            get_inst.arg0 = compare_idx
                            ctx_emit(ctx, get_inst)
                            let pat_idx = lower_expr(ctx, pat)
                            let cmp_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                            ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_EQ(), cmp_dest, compare_idx, pat_idx))
                            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                            ctx.nesting_depth = ctx.nesting_depth + 1
                            if_depth = if_depth + 1
                            if is_payload_match && pat.kind == mir_type_info::NK_PAT_VARIANT() && len(pat.children) > 0 {
                                let variant_name2 = clone(pat.text)
                                let mut bi2 = 0
                                while bi2 < len(pat.children) {
                                    let bind_pat2 = get_unchecked(pat.children, bi2)
                                    let mut field_is_f64_2 = ctx_struct_field_is_f64(ctx, clone(variant_name2), bi2 + 1)
                                    if !field_is_f64_2 && scrut_ok_is_f64 && bi2 == 0 {
                                        if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                            field_is_f64_2 = true
                                        }
                                    }
                                    let mut field_is_i64_2 = false
                                    if !field_is_f64_2 && scrut_ok_is_i64 && bi2 == 0 {
                                        if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                            field_is_i64_2 = true
                                        }
                                    }
                                    let mut bind_vt2 = mir_ir::VT_I32()
                                    if field_is_f64_2 {
                                        bind_vt2 = mir_ir::VT_F64()
                                    } else {
                                        if field_is_i64_2 {
                                            bind_vt2 = mir_ir::VT_I64()
                                        }
                                    }
                                    let bind_local2 = ctx_alloc_local(ctx, clone(bind_pat2.text), bind_vt2)
                                    if bind_vt2 == mir_ir::VT_I32() && scrut_ok_is_i32 && bi2 == 0 {
                                        if eq(clone(variant_name2), "Ok") || eq(clone(variant_name2), "Result::Ok") || eq(clone(variant_name2), "Some") || eq(clone(variant_name2), "Option::Some") {
                                            ctx_set_local_type(ctx, bind_local2, String_from("i32"))
                                        }
                                    }
                                    let get_s3 = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                                    get_s3.arg0 = scrut_idx
                                    ctx_emit(ctx, get_s3)
                                    let sget3 = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
                                    sget3.int_val = ctx_struct_field_offset(ctx, clone(variant_name2), bi2 + 1)
                                    if field_is_f64_2 {
                                        sget3.val_type = mir_ir::VT_F64()
                                    } else {
                                        if field_is_i64_2 {
                                            sget3.val_type = mir_ir::VT_I64()
                                        }
                                    }
                                    ctx_emit(ctx, sget3)
                                    let set_b2 = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                                    set_b2.arg0 = bind_local2
                                    ctx_emit(ctx, set_b2)
                                    bi2 = bi2 + 1
                                }
                            }
                            if has_guard {
                                let guard2 = get_unchecked(arm_node.children, 1)
                                lower_expr(ctx, guard2)
                                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                                ctx.nesting_depth = ctx.nesting_depth + 1
                                if_depth = if_depth + 1
                            }
                        }
                    }
                    let arm_result = lower_expr(ctx, body)
                    if arm_result >= 0 {
                        let arm_vt2 = ctx_local_vt(ctx, arm_result)
                        if arm_vt2 == mir_ir::VT_I64() || arm_vt2 == mir_ir::VT_F64() {
                            ctx_set_local_vt(ctx, result, arm_vt2)
                        }
                        let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                        set_inst.arg0 = result
                        ctx_emit(ctx, set_inst)
                    }
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_ELSE()))
                }
                arm = arm + 1
            }
            while if_depth > 0 {
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                if_depth = if_depth - 1
            }
            let get_result = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_result.arg0 = result
            ctx_emit(ctx, get_result)
            return result
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_METHOD_CALL() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let receiver = get_unchecked(node.children, 0)
            let receiver_idx = lower_expr(ctx, receiver)
            let mut struct_name = String_from("")
            if receiver_idx >= 0 {
                struct_name = ctx_get_local_type(ctx, receiver_idx)
            }
            let method_name = clone(node.text)
            let mut callee_name = if len(struct_name) > 0 {
                concat(clone(struct_name), concat(String_from("::"), clone(method_name)))
            } else {
                clone(method_name)
            }
            let mut a = 1
            let mut first_method_arg_idx = 0 - 1
            while a < child_count {
                let arg = get_unchecked(node.children, a)
                let method_arg_idx = lower_expr(ctx, arg)
                if a == 1 {
                    first_method_arg_idx = method_arg_idx
                }
                a = a + 1
            }
            let mut method_mono_resolved_by_type = false
            if first_method_arg_idx >= 0 {
                let mut method_mono_type_key = ctx_get_local_type(ctx, first_method_arg_idx)
                if len(method_mono_type_key) == 0 {
                    let method_arg_vt = ctx_local_vt(ctx, first_method_arg_idx)
                    if method_arg_vt == mir_ir::VT_I64() {
                        method_mono_type_key = String_from("i64")
                    } else {
                        if method_arg_vt == mir_ir::VT_F64() {
                            method_mono_type_key = String_from("f64")
                        } else {
                            method_mono_type_key = String_from("i32")
                        }
                    }
                }
                if eq(clone(method_mono_type_key), String_from("string")) {
                    method_mono_type_key = String_from("String")
                }
                if len(method_mono_type_key) > 0 {
                    let method_mono_candidate = mono_safe_name(concat(clone(callee_name), concat(String_from("__"), method_mono_type_key)))
                    if ctx_has_fn_name(ctx, clone(method_mono_candidate)) {
                        callee_name = method_mono_candidate
                        method_mono_resolved_by_type = true
                    }
                }
            }
            if !method_mono_resolved_by_type {
                let mono_target = ctx_mono_lookup_call(ctx, node.span.start)
                if len(mono_target) > 0 {
                    callee_name = mono_target
                } else {
                    let mono_count_by_name = len(ctx.mono_call_sources)
                    let mut mono_i_by_name = 0
                    let mut mono_done_by_name = false
                    while mono_i_by_name < mono_count_by_name && !mono_done_by_name {
                        if get_unchecked(ctx.mono_call_used, mono_i_by_name) == 0 && eq(clone(get_unchecked(ctx.mono_call_sources, mono_i_by_name)), clone(callee_name)) {
                            callee_name = clone(get_unchecked(ctx.mono_call_targets, mono_i_by_name))
                            set(ctx.mono_call_used, mono_i_by_name, 1)
                            mono_done_by_name = true
                        }
                        mono_i_by_name = mono_i_by_name + 1
                    }
                }
            }
            let call_ret_vt = ctx_fn_return_vt(ctx, clone(callee_name))
            let dest = ctx_fresh_local(ctx, call_ret_vt)
            let mut mcall_inst = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
            mcall_inst.str_val = callee_name
            mcall_inst.int_val = child_count
            mcall_inst.dest = dest
            ctx_emit(ctx, mcall_inst)
            let rtn = ctx_fn_return_type_name(ctx, clone(mcall_inst.str_val))
            if len(rtn) > 0 {
                ctx_set_local_type(ctx, dest, rtn)
            }
            if call_ret_vt == mir_ir::VT_VOID() {
                return 0 - 1
            }
            return dest
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_BLOCK() {
        let child_count = len(node.children)
        let mut last_result = 0 - 1
        let mut s = 0
        while s < child_count {
            let stmt = get_unchecked(node.children, s)
            let stmt_result = lower_stmt(ctx, stmt)
            if s < child_count - 1 && stmt_result >= 0 {
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_DROP()))
                last_result = 0 - 1
            } else {
                last_result = stmt_result
            }
            s = s + 1
        }
        return last_result
    }
    if kind == mir_type_info::NK_ASSIGN() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let target = get_unchecked(node.children, 0)
            let value = get_unchecked(node.children, 1)
            let val_idx = lower_expr(ctx, value)
            if target.kind == mir_type_info::NK_IDENT() {
                let local_idx = ctx_lookup_local(ctx, clone(target.text))
                if local_idx >= 0 && val_idx >= 0 {
                    let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                    set_inst.arg0 = local_idx
                    ctx_emit(ctx, set_inst)
                }
            }
            if target.kind == mir_type_info::NK_FIELD_ACCESS() {
                let tc = len(target.children)
                if tc >= 1 {
                    let struct_node = get_unchecked(target.children, 0)
                    let mut struct_idx = 0
                    if struct_node.kind == mir_type_info::NK_IDENT() {
                        struct_idx = ctx_lookup_local(ctx, clone(struct_node.text))
                    } else {
                        let raw_idx = lower_expr(ctx, struct_node)
                        let temp = ctx_fresh_local(ctx, mir_ir::VT_REF())
                        let save_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                        save_inst.arg0 = temp
                        ctx_emit(ctx, save_inst)
                        struct_idx = temp
                    }
                    let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_SET())
                    set_inst.arg0 = struct_idx
                    set_inst.arg1 = val_idx
                    set_inst.str_val = clone(target.text)
                    let base_type = ctx_get_local_type(ctx, struct_idx)
                    let mut fi_assign = 0
                    if len(base_type) > 0 {
                        fi_assign = ctx_field_index(ctx, clone(base_type), clone(target.text))
                        set_inst.int_val = ctx_struct_field_offset(ctx, clone(base_type), fi_assign)
                        if ctx_struct_field_is_f64(ctx, clone(base_type), fi_assign) {
                            set_inst.val_type = mir_ir::VT_F64()
                        }
                    } else {
                        fi_assign = ctx_field_index_any(ctx, clone(target.text))
                        set_inst.int_val = fi_assign * 4
                    }
                    ctx_emit(ctx, set_inst)
                }
            }
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_STRUCT_LIT() {
        let child_count = len(node.children)
        let struct_name = clone(node.text)
        let total_fields = ctx_struct_field_count(ctx, clone(struct_name))
        let dest = ctx_fresh_local(ctx, mir_ir::VT_REF())
        let new_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_NEW())
        new_inst.dest = dest
        new_inst.str_val = clone(struct_name)
        new_inst.int_val = ctx_struct_byte_size(ctx, clone(struct_name))
        ctx_emit(ctx, new_inst)
        ctx_set_local_type(ctx, dest, clone(struct_name))
        let mut base_idx = 0 - 1
        let mut has_base = false
        let mut f = 0
        while f < child_count {
            let field = get_unchecked(node.children, f)
            if field.kind == mir_type_info::NK_RANGE() {
                let base_expr = get_unchecked(field.children, 0)
                base_idx = lower_expr(ctx, base_expr)
                let save_base = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                save_base.arg0 = base_idx
                ctx_emit(ctx, save_base)
                has_base = true
            }
            f = f + 1
        }
        if has_base {
            let mut fi = 0
            while fi < total_fields {
                let fname = ctx_struct_field_name(ctx, clone(struct_name), fi)
                let is_f64_field = ctx_struct_field_is_f64(ctx, clone(struct_name), fi)
                let mut field_vt = mir_ir::VT_I32()
                if is_f64_field {
                    field_vt = mir_ir::VT_F64()
                }
                let tmp = ctx_fresh_local(ctx, field_vt)
                let get_base = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_base.arg0 = base_idx
                get_base.dest = base_idx
                ctx_emit(ctx, get_base)
                let g = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
                g.dest = tmp
                g.arg0 = base_idx
                g.str_val = clone(fname)
                g.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi)
                if is_f64_field {
                    g.val_type = mir_ir::VT_F64()
                }
                ctx_emit(ctx, g)
                let s = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_SET())
                s.arg0 = dest
                s.arg1 = tmp
                s.str_val = clone(fname)
                s.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi)
                if is_f64_field {
                    s.val_type = mir_ir::VT_F64()
                }
                ctx_emit(ctx, s)
                fi = fi + 1
            }
        }
        f = 0
        while f < child_count {
            let field = get_unchecked(node.children, f)
            if field.kind != mir_type_info::NK_RANGE() {
                let fc = len(field.children)
                if fc >= 1 {
                    let init = get_unchecked(field.children, 0)
                    let val_idx = lower_expr(ctx, init)
                    let fi_idx = ctx_field_index(ctx, clone(struct_name), clone(field.text))
                    let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_SET())
                    set_inst.arg0 = dest
                    set_inst.arg1 = val_idx
                    set_inst.str_val = clone(field.text)
                    set_inst.int_val = ctx_struct_field_offset(ctx, clone(struct_name), fi_idx)
                    if ctx_struct_field_is_f64(ctx, clone(struct_name), fi_idx) {
                        set_inst.val_type = mir_ir::VT_F64()
                    }
                    ctx_emit(ctx, set_inst)
                }
            }
            f = f + 1
        }
        let get_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)
        return dest
    }
    if kind == mir_type_info::NK_TUPLE() {
        let child_count = len(node.children)
        let mut field_locals = Vec_new_i32()
        let mut field_vts = Vec_new_i32()
        let mut total_bytes = 0
        let mut ti = 0
        while ti < child_count {
            let child = get_unchecked(node.children, ti)
            let child_idx = lower_expr(ctx, child)
            let child_vt = ctx_local_vt(ctx, child_idx)
            let save_local = ctx_fresh_local(ctx, child_vt)
            let save_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            save_inst.arg0 = save_local
            save_inst.arg1 = child_idx
            ctx_emit(ctx, save_inst)
            push(field_locals, save_local)
            push(field_vts, child_vt)
            if child_vt == mir_ir::VT_F64() {
                total_bytes = total_bytes + 8
            } else {
                total_bytes = total_bytes + 4
            }
            ti = ti + 1
        }
        let dest = ctx_fresh_local(ctx, mir_ir::VT_REF())
        let new_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_NEW())
        new_inst.dest = dest
        new_inst.int_val = total_bytes
        ctx_emit(ctx, new_inst)
        let mut byte_off = 0
        ti = 0
        while ti < child_count {
            let field_local = get_unchecked(field_locals, ti)
            let field_vt = get_unchecked(field_vts, ti)
            let get_val = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_val.arg0 = field_local
            ctx_emit(ctx, get_val)
            let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_SET())
            set_inst.arg0 = dest
            set_inst.arg1 = field_local
            set_inst.int_val = byte_off
            if field_vt == mir_ir::VT_F64() {
                set_inst.val_type = mir_ir::VT_F64()
                byte_off = byte_off + 8
            } else {
                if field_vt == mir_ir::VT_I64() {
                    set_inst.val_type = mir_ir::VT_I64()
                }
                byte_off = byte_off + 4
            }
            ctx_emit(ctx, set_inst)
            ti = ti + 1
        }
        let get_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)
        return dest
    }
    if kind == mir_type_info::NK_FIELD_ACCESS() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let base = get_unchecked(node.children, 0)
            let base_idx = lower_expr(ctx, base)
            let base_type = ctx_get_local_type(ctx, base_idx)
            let mut field_idx = 0
            let mut is_f64_field = false
            if len(base_type) > 0 {
                field_idx = ctx_field_index(ctx, clone(base_type), clone(node.text))
                is_f64_field = ctx_struct_field_is_f64(ctx, clone(base_type), field_idx)
            } else {
                field_idx = ctx_field_index_any(ctx, clone(node.text))
            }
            let mut dest_vt = mir_ir::VT_I32()
            if is_f64_field {
                dest_vt = mir_ir::VT_F64()
            }
            if len(base_type) > 0 {
                let ft_vt = ctx_get_field_type(ctx, clone(base_type), clone(node.text))
                if eq(clone(ft_vt), "i64") {
                    dest_vt = mir_ir::VT_I64()
                }
            }
            let dest = ctx_fresh_local(ctx, dest_vt)
            let get_inst = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
            get_inst.dest = dest
            get_inst.arg0 = base_idx
            get_inst.str_val = clone(node.text)
            if len(base_type) > 0 {
                get_inst.int_val = ctx_struct_field_offset(ctx, clone(base_type), field_idx)
                if is_f64_field {
                    get_inst.val_type = mir_ir::VT_F64()
                }
                if dest_vt == mir_ir::VT_I64() {
                    get_inst.val_type = mir_ir::VT_I64()
                }
                let ft = ctx_get_field_type(ctx, clone(base_type), clone(node.text))
                if len(ft) > 0 {
                    ctx_set_local_type(ctx, dest, ft)
                }
            } else {
                get_inst.int_val = field_idx * 4
            }
            ctx_emit(ctx, get_inst)
            return dest
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_ARRAY_LIT() {
        let child_count = len(node.children)
        let dest = ctx_fresh_local(ctx, mir_ir::VT_REF())
        let new_inst = mir_ir::MirInst_new(mir_opcodes::MIR_ARRAY_NEW())
        new_inst.dest = dest
        new_inst.int_val = child_count
        ctx_emit(ctx, new_inst)
        let mut e = 0
        while e < child_count {
            let elem = get_unchecked(node.children, e)
            let val_idx = lower_expr(ctx, elem)
            let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_ARRAY_SET())
            set_inst.arg0 = dest
            set_inst.arg1 = val_idx
            set_inst.int_val = e
            ctx_emit(ctx, set_inst)
            e = e + 1
        }
        let get_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
        get_inst.arg0 = dest
        get_inst.dest = dest
        ctx_emit(ctx, get_inst)
        return dest
    }
    if kind == mir_type_info::NK_INDEX() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let base = get_unchecked(node.children, 0)
            let idx_expr = get_unchecked(node.children, 1)
            let base_idx = lower_expr(ctx, base)
            let index_idx = lower_expr(ctx, idx_expr)
            let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx_set_local_type(ctx, dest, String_from("i32"))
            let get_inst = mir_ir::MirInst_new(mir_opcodes::MIR_ARRAY_GET())
            get_inst.dest = dest
            get_inst.arg0 = base_idx
            get_inst.arg1 = index_idx
            ctx_emit(ctx, get_inst)
            return dest
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_TRY() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let inner = get_unchecked(node.children, 0)
            let inner_idx = lower_expr(ctx, inner)
            let res_ptr = ctx_fresh_local(ctx, mir_ir::VT_I32())
            let save_res = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            save_res.arg0 = res_ptr
            ctx_emit(ctx, save_res)
            let tag_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
            let get_ptr = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_ptr.arg0 = res_ptr
            ctx_emit(ctx, get_ptr)
            let sget_tag = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
            sget_tag.int_val = 0
            ctx_emit(ctx, sget_tag)
            let set_tag = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            set_tag.arg0 = tag_local
            ctx_emit(ctx, set_tag)
            let get_tag = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_tag.arg0 = tag_local
            ctx_emit(ctx, get_tag)
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
            let get_ret = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_ret.arg0 = res_ptr
            ctx_emit(ctx, get_ret)
            let ret_inst = mir_ir::MirInst_new(mir_opcodes::MIR_RETURN())
            ctx_emit(ctx, ret_inst)
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            let result = ctx_fresh_local(ctx, mir_ir::VT_I32())
            let get_ok = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_ok.arg0 = res_ptr
            ctx_emit(ctx, get_ok)
            let sget_payload = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
            sget_payload.int_val = 4
            ctx_emit(ctx, sget_payload)
            let set_result = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            set_result.arg0 = result
            ctx_emit(ctx, set_result)
            let get_result = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_result.arg0 = result
            ctx_emit(ctx, get_result)
            return result
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_LOOP() {
        return lower_stmt(ctx, node)
    }
    if kind == mir_type_info::NK_WHILE() {
        return lower_stmt(ctx, node)
    }
    if kind == mir_type_info::NK_FOR() {
        return lower_stmt(ctx, node)
    }
    if kind == mir_type_info::NK_COMPREHENSION() {
        // [expr for x in iter if filter]
        // children[0] = element expr, children[1] = iter expr, children[2] = filter (optional)
        // text = loop variable name
        let comp_child_count = len(node.children)
        if comp_child_count >= 2 {
            let elem_expr = get_unchecked(node.children, 0)
            let iter_expr = get_unchecked(node.children, 1)
            let comp_var_name = clone(node.text)
            // Lower the iterator expression to get the Vec
            let comp_vec_idx = lower_expr(ctx, iter_expr)
            let comp_vec_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
            let comp_set_vec = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            comp_set_vec.arg0 = comp_vec_local
            ctx_emit(ctx, comp_set_vec)
            ctx_set_local_type(ctx, comp_vec_local, String_from("vec:i32"))
            // Create result Vec
            let comp_result_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
            let comp_new_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
            comp_new_call.str_val = String_from("Vec_new_i32")
            comp_new_call.int_val = 0
            comp_new_call.dest = comp_result_local
            ctx_emit(ctx, comp_new_call)
            let comp_set_result = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            comp_set_result.arg0 = comp_result_local
            comp_set_result.arg1 = comp_result_local
            ctx_emit(ctx, comp_set_result)
            ctx_set_local_type(ctx, comp_result_local, String_from("vec:i32"))
            // Get vec_len of iterator
            let comp_get_len = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_len.arg0 = comp_vec_local
            ctx_emit(ctx, comp_get_len)
            let comp_len_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
            comp_len_call.str_val = String_from("vec_len")
            comp_len_call.int_val = 1
            let comp_end_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
            comp_len_call.dest = comp_end_local
            ctx_emit(ctx, comp_len_call)
            let comp_set_end = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            comp_set_end.arg0 = comp_end_local
            ctx_emit(ctx, comp_set_end)
            // Index counter
            let comp_idx_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx_emit(ctx, mir_ir::MirInst_const_i32(0, comp_idx_local))
            let comp_set_idx_init = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            comp_set_idx_init.arg0 = comp_idx_local
            ctx_emit(ctx, comp_set_idx_init)
            // Allocate loop variable local
            let comp_iter_var = ctx_alloc_local(ctx, clone(comp_var_name), mir_ir::VT_I32())
            // Loop block
            let comp_prev_break = ctx.loop_break_depth
            let comp_prev_continue = ctx.loop_continue_depth
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth
            ctx.loop_continue_depth = ctx.nesting_depth
            // Compare idx < len
            let comp_get_idx_cmp = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_idx_cmp.arg0 = comp_idx_local
            ctx_emit(ctx, comp_get_idx_cmp)
            let comp_get_end_cmp = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_end_cmp.arg0 = comp_end_local
            ctx_emit(ctx, comp_get_end_cmp)
            let comp_cmp_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_GTEQ(), comp_cmp_dest, comp_idx_local, comp_end_local))
            let comp_br_break = mir_ir::MirInst_new(mir_opcodes::MIR_BR_IF())
            comp_br_break.int_val = 1
            ctx_emit(ctx, comp_br_break)
            // vec_get_unchecked(vec, idx) -> loop variable
            let comp_get_vec_gu = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_vec_gu.arg0 = comp_vec_local
            ctx_emit(ctx, comp_get_vec_gu)
            let comp_get_idx_gu = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_idx_gu.arg0 = comp_idx_local
            ctx_emit(ctx, comp_get_idx_gu)
            let comp_gu_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
            comp_gu_call.str_val = String_from("vec_get_unchecked")
            comp_gu_call.int_val = 2
            comp_gu_call.dest = comp_iter_var
            ctx_emit(ctx, comp_gu_call)
            let comp_set_elem = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            comp_set_elem.arg0 = comp_iter_var
            ctx_emit(ctx, comp_set_elem)
            // Optional filter
            if comp_child_count > 2 {
                let filter_expr = get_unchecked(node.children, 2)
                let _filter_idx = lower_expr(ctx, filter_expr)
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_IF()))
                // Push vec pointer onto stack before element expression
                let comp_get_result_push = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                comp_get_result_push.arg0 = comp_result_local
                ctx_emit(ctx, comp_get_result_push)
                // Lower element expression (puts value on stack)
                let _comp_elem_idx = lower_expr(ctx, elem_expr)
                // Call push(vec, value) — emitter pops value then vec from stack
                let comp_push_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
                comp_push_call.str_val = String_from("push")
                comp_push_call.int_val = 2
                ctx_emit(ctx, comp_push_call)
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            } else {
                // No filter: push vec pointer onto stack, then element expression, then call push
                let comp_get_result_pf = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                comp_get_result_pf.arg0 = comp_result_local
                ctx_emit(ctx, comp_get_result_pf)
                let _comp_elem_idx = lower_expr(ctx, elem_expr)
                let comp_push_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
                comp_push_call.str_val = String_from("push")
                comp_push_call.int_val = 2
                ctx_emit(ctx, comp_push_call)
            }
            // Increment index
            let comp_get_idx_inc = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_idx_inc.arg0 = comp_idx_local
            ctx_emit(ctx, comp_get_idx_inc)
            let comp_one_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx_emit(ctx, mir_ir::MirInst_const_i32(1, comp_one_dest))
            let comp_add_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_ADD(), comp_add_dest, comp_idx_local, comp_one_dest))
            let comp_set_idx = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
            comp_set_idx.arg0 = comp_idx_local
            ctx_emit(ctx, comp_set_idx)
            // br back
            let comp_br_loop = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            comp_br_loop.int_val = 0
            ctx_emit(ctx, comp_br_loop)
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx.loop_break_depth = comp_prev_break
            ctx.loop_continue_depth = comp_prev_continue
            // Return result local
            let comp_get_result_final = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            comp_get_result_final.arg0 = comp_result_local
            comp_get_result_final.dest = comp_result_local
            ctx_emit(ctx, comp_get_result_final)
            return comp_result_local
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_CLOSURE() {
        let caps = Vec_new_String()
        let cap_child_count = len(node.children)
        if cap_child_count > 0 {
            let cap_body = get_unchecked(node.children, cap_child_count - 1)
            closure_collect_free(ctx, cap_body, node, caps)
        }
        let packed = closure_pack_caps(caps)
        let extra = len(caps)
        let synth = concat(String_from("__closure_"), to_string(ctx.closure_counter))
        ctx.closure_counter = ctx.closure_counter + 1
        let mf = mir_emit_closure_fn(ctx, synth, node, caps)
        push(ctx.module.functions, mf)
        push(ctx.fn_names, clone(mf.name))
        push(ctx.fn_return_vts, mf.return_type)
        push(ctx.fn_return_type_names, String_from(""))
        ctx.closure_last_synth = clone(mf.name)
        ctx.closure_last_caps = packed
        ctx.closure_last_extra = extra
        let dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
        ctx_emit(ctx, mir_ir::MirInst_const_i32(0, dest))
        return dest
    }
    if kind == mir_type_info::NK_RETURN() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let val_idx = lower_expr(ctx, expr)
            let ret_inst = mir_ir::MirInst_new(mir_opcodes::MIR_RETURN())
            ret_inst.arg0 = val_idx
            ctx_emit(ctx, ret_inst)
        } else {
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_RETURN()))
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_BREAK() {
        if ctx.loop_break_depth >= 0 {
            let br_inst = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_break_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_CONTINUE() {
        if ctx.loop_continue_depth >= 0 {
            let br_inst = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_continue_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_NOP()))
    0 - 1
}

// Lower a statement node. Returns local index if it produces a value.
fn lower_stmt(ctx: LowerCtx, node: AstNode) -> i32 {
    let kind = node.kind
    if kind == mir_type_info::NK_LET() {
        let mut vt = mir_ir::VT_I32()
        let ta_count = len(node.type_ann)
        if ta_count >= 1 {
            let ta_pre = get_unchecked(node.type_ann, 0)
            if eq(clone(ta_pre.text), "f64") {
                vt = mir_ir::VT_F64()
            } else {
                if eq(clone(ta_pre.text), "i64") || eq(clone(ta_pre.text), "u64") {
                    vt = mir_ir::VT_I64()
                }
            }
        }
        if vt == mir_ir::VT_I32() && ta_count == 0 && len(node.children) >= 1 {
            let init_peek = get_unchecked(node.children, 0)
            if init_peek.kind == mir_type_info::NK_FLOAT_LIT() {
                vt = mir_ir::VT_F64()
            }
            if init_peek.kind == mir_type_info::NK_BINARY() && len(init_peek.children) >= 2 {
                let lhs_peek = get_unchecked(init_peek.children, 0)
                let rhs_peek = get_unchecked(init_peek.children, 1)
                if lhs_peek.kind == mir_type_info::NK_FLOAT_LIT() || rhs_peek.kind == mir_type_info::NK_FLOAT_LIT() {
                    vt = mir_ir::VT_F64()
                }
            }
        }
        let child_count = len(node.children)
        let mut pre_val_idx = 0 - 1
        let mut pre_init_kind = 0 - 1
        if child_count >= 1 {
            let pre_init = get_unchecked(node.children, 0)
            pre_init_kind = pre_init.kind
            pre_val_idx = lower_expr(ctx, pre_init)
            if vt == mir_ir::VT_I32() && ta_count == 0 && pre_val_idx >= 0 {
                let inferred_vt = ctx_local_vt(ctx, pre_val_idx)
                if inferred_vt == mir_ir::VT_F64() || inferred_vt == mir_ir::VT_I64() {
                    vt = inferred_vt
                }
            }
        }
        let local_idx = ctx_alloc_local(ctx, clone(node.text), vt)
        if ta_count >= 1 {
            let ta = get_unchecked(node.type_ann, 0)
            let ta_name = clone(ta.text)
            if eq(clone(ta_name), "char") || eq(clone(ta_name), "u8") || eq(clone(ta_name), "u16") || eq(clone(ta_name), "u32") || eq(clone(ta_name), "u64") || eq(clone(ta_name), "i16") || eq(clone(ta_name), "i32") || eq(clone(ta_name), "i64") || eq(clone(ta_name), "bool") || eq(clone(ta_name), "f64") {
                ctx_set_local_type(ctx, local_idx, ta_name)
            } else {
                if ctx_struct_field_count(ctx, clone(ta_name)) > 0 {
                    ctx_set_local_type(ctx, local_idx, ta_name)
                }
            }
            if ta.kind == 91 {
                if eq(clone(ta_name), "Vec") {
                    if len(ta.children) >= 2 {
                        let elem_ty = get_unchecked(ta.children, 1)
                        ctx_set_local_type(ctx, local_idx, concat(String_from("vec:"), clone(elem_ty.text)))
                    } else {
                        ctx_set_local_type(ctx, local_idx, String_from("vec"))
                    }
                } else {
                    if eq(clone(ta_name), "Result") {
                        if len(ta.children) >= 2 {
                            let ok_ty = get_unchecked(ta.children, 1)
                            if eq(clone(ok_ty.text), "f64") {
                                ctx_set_local_type(ctx, local_idx, String_from("Result_f64"))
                            } else {
                                if eq(clone(ok_ty.text), "i64") {
                                    ctx_set_local_type(ctx, local_idx, String_from("Result_i64"))
                                }
                            }
                        }
                    } else {
                        if eq(clone(ta_name), "Option") {
                            if len(ta.children) >= 2 {
                                let some_ty = get_unchecked(ta.children, 1)
                                if eq(clone(some_ty.text), "f64") {
                                    ctx_set_local_type(ctx, local_idx, String_from("Option_f64"))
                                } else {
                                    if eq(clone(some_ty.text), "i64") {
                                        ctx_set_local_type(ctx, local_idx, String_from("Option_i64"))
                                    }
                                }
                            }
                        }
                    }
                }
            } else {
                if eq(clone(ta_name), "Vec") {
                    ctx_set_local_type(ctx, local_idx, String_from("vec"))
                }
            }
        }
        if child_count >= 1 {
            let init = get_unchecked(node.children, 0)
            let val_idx = pre_val_idx
            if val_idx >= 0 {
                if ctx_local_vt(ctx, val_idx) == mir_ir::VT_F64() && ctx_local_vt(ctx, local_idx) == mir_ir::VT_I32() {
                    ctx_set_local_vt(ctx, local_idx, mir_ir::VT_F64())
                }
                let mut actual_val_idx = val_idx
                if vt == mir_ir::VT_I64() && ctx_local_vt(ctx, val_idx) == mir_ir::VT_I32() {
                    let ext_dest = ctx_fresh_local(ctx, mir_ir::VT_I64())
                    let ext_inst = mir_ir::MirInst_new(mir_opcodes::MIR_EXTEND_I32_TO_I64())
                    ext_inst.dest = ext_dest
                    ext_inst.arg0 = val_idx
                    ctx_emit(ctx, ext_inst)
                    actual_val_idx = ext_dest
                }
                let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_inst.arg0 = local_idx
                ctx_emit(ctx, set_inst)
                let init_type = ctx_get_local_type(ctx, val_idx)
                if len(init_type) > 1 {
                    ctx_set_local_type(ctx, local_idx, init_type)
                }
                if ta_count == 0 && len(ctx_get_local_type(ctx, local_idx)) == 0 {
                    if pre_init_kind == mir_type_info::NK_INT_LIT() {
                        ctx_set_local_type(ctx, local_idx, String_from("i32"))
                    } else {
                        if pre_init_kind == mir_type_info::NK_FLOAT_LIT() {
                            ctx_set_local_type(ctx, local_idx, String_from("f64"))
                        } else {
                            if pre_init_kind == mir_type_info::NK_BOOL_LIT() {
                                ctx_set_local_type(ctx, local_idx, String_from("bool"))
                            } else {
                                if pre_init_kind == mir_type_info::NK_CHAR_LIT() {
                                    ctx_set_local_type(ctx, local_idx, String_from("char"))
                                }
                            }
                        }
                    }
                }
            }
            if pre_init_kind == mir_type_info::NK_CLOSURE() {
                if !eq(clone(node.text), String_from("_")) {
                    closure_flush_pending_bind(ctx, clone(node.text))
                } else {
                    ctx.closure_last_synth = String_new()
                    ctx.closure_last_caps = String_new()
                    ctx.closure_last_extra = 0
                }
            }
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_RETURN() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let val_idx = lower_expr(ctx, expr)
            let ret_inst = mir_ir::MirInst_new(mir_opcodes::MIR_RETURN())
            ret_inst.arg0 = val_idx
            ctx_emit(ctx, ret_inst)
        } else {
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_RETURN()))
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_WHILE() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let prev_break = ctx.loop_break_depth
            let prev_continue = ctx.loop_continue_depth
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_continue_depth = ctx.nesting_depth
            let cond = get_unchecked(node.children, 0)
            let cond_idx = lower_expr(ctx, cond)
            let eqz_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
            let eqz_inst = mir_ir::MirInst_new(mir_opcodes::MIR_EQZ())
            eqz_inst.dest = eqz_dest
            eqz_inst.arg0 = cond_idx
            ctx_emit(ctx, eqz_inst)
            let br_break = mir_ir::MirInst_new(mir_opcodes::MIR_BR_IF())
            br_break.int_val = 1
            ctx_emit(ctx, br_break)
            let body = get_unchecked(node.children, 1)
            let _body_result = lower_expr(ctx, body)
            let br_loop = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            br_loop.int_val = 0
            ctx_emit(ctx, br_loop)
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx.loop_break_depth = prev_break
            ctx.loop_continue_depth = prev_continue
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_LOOP() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let prev_break = ctx.loop_break_depth
            let prev_continue = ctx.loop_continue_depth
            let prev_break_local = ctx.loop_break_local
            let break_result = ctx_fresh_local(ctx, mir_ir::VT_I32())
            ctx.loop_break_local = break_result
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_BLOCK()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_break_depth = ctx.nesting_depth
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_LOOP()))
            ctx.nesting_depth = ctx.nesting_depth + 1
            ctx.loop_continue_depth = ctx.nesting_depth
            let body = get_unchecked(node.children, 0)
            let _body_result = lower_expr(ctx, body)
            let br_back = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            br_back.int_val = 0
            ctx_emit(ctx, br_back)
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
            ctx.nesting_depth = ctx.nesting_depth - 1
            ctx.loop_break_depth = prev_break
            ctx.loop_continue_depth = prev_continue
            ctx.loop_break_local = prev_break_local
            let get_result = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
            get_result.arg0 = break_result
            ctx_emit(ctx, get_result)
            return break_result
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_BREAK() {
        if ctx.loop_break_depth >= 0 {
            let break_children = len(node.children)
            if break_children > 0 && ctx.loop_break_local >= 0 {
                let break_val = get_unchecked(node.children, 0)
                let bv_idx = lower_expr(ctx, break_val)
                let set_inst = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_inst.arg0 = ctx.loop_break_local
                ctx_emit(ctx, set_inst)
            }
            let br_inst = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_break_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_CONTINUE() {
        if ctx.loop_continue_depth >= 0 {
            let br_inst = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
            br_inst.int_val = ctx.nesting_depth - ctx.loop_continue_depth
            ctx_emit(ctx, br_inst)
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_FOR() {
        let child_count = len(node.children)
        if child_count >= 2 {
            let range = get_unchecked(node.children, 0)
            let body = get_unchecked(node.children, 1)
            let range_child_count = len(range.children)
            let mut is_values_call = range.kind == mir_type_info::NK_CALL() && range_child_count >= 2
            let mut values_callee_match = false
            if is_values_call {
                let range_callee = get_unchecked(range.children, 0)
                values_callee_match = eq(clone(range_callee.text), "values")
            }
            if values_callee_match {
                let vec_arg = get_unchecked(range.children, 1)
                let vec_idx = lower_expr(ctx, vec_arg)
                let vec_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
                let set_vec = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_vec.arg0 = vec_local
                ctx_emit(ctx, set_vec)
                let get_vec_len = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_vec_len.arg0 = vec_local
                ctx_emit(ctx, get_vec_len)
                let len_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
                len_call.str_val = String_from("vec_len")
                len_call.int_val = 1
                let end_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
                len_call.dest = end_local
                ctx_emit(ctx, len_call)
                let set_end = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_end.arg0 = end_local
                ctx_emit(ctx, set_end)
                let idx_var = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_const_i32(0, idx_var))
                let set_idx_init = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_idx_init.arg0 = idx_var
                ctx_emit(ctx, set_idx_init)
                let iter_var = ctx_alloc_local(ctx, clone(node.text), mir_ir::VT_I32())
                let prev_break = ctx.loop_break_depth
                let prev_continue = ctx.loop_continue_depth
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_BLOCK()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_break_depth = ctx.nesting_depth
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_LOOP()))
                ctx.nesting_depth = ctx.nesting_depth + 1
                ctx.loop_continue_depth = ctx.nesting_depth
                let get_idx_cmp = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_idx_cmp.arg0 = idx_var
                ctx_emit(ctx, get_idx_cmp)
                let get_end_cmp = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_end_cmp.arg0 = end_local
                ctx_emit(ctx, get_end_cmp)
                let cmp_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_GTEQ(), cmp_dest, idx_var, end_local))
                let br_break = mir_ir::MirInst_new(mir_opcodes::MIR_BR_IF())
                br_break.int_val = 1
                ctx_emit(ctx, br_break)
                let get_vec_gu = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_vec_gu.arg0 = vec_local
                ctx_emit(ctx, get_vec_gu)
                let get_idx_gu = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_idx_gu.arg0 = idx_var
                ctx_emit(ctx, get_idx_gu)
                let gu_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
                gu_call.str_val = String_from("vec_get_unchecked")
                gu_call.int_val = 2
                gu_call.dest = iter_var
                ctx_emit(ctx, gu_call)
                let set_elem = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_elem.arg0 = iter_var
                ctx_emit(ctx, set_elem)
                let _body_result = lower_expr(ctx, body)
                let get_idx_inc = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                get_idx_inc.arg0 = idx_var
                ctx_emit(ctx, get_idx_inc)
                let one_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_const_i32(1, one_dest))
                let add_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_ADD(), add_dest, idx_var, one_dest))
                let set_idx = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                set_idx.arg0 = idx_var
                ctx_emit(ctx, set_idx)
                let br_loop = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
                br_loop.int_val = 0
                ctx_emit(ctx, br_loop)
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                ctx.nesting_depth = ctx.nesting_depth - 1
                ctx.loop_break_depth = prev_break
                ctx.loop_continue_depth = prev_continue
            } else {
                if range_child_count >= 2 {
                    let start_node = get_unchecked(range.children, 0)
                    let end_node = get_unchecked(range.children, 1)
                    let start_idx = lower_expr(ctx, start_node)
                    let iter_var = ctx_alloc_local(ctx, clone(node.text), mir_ir::VT_I32())
                    let set_init = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                    set_init.arg0 = iter_var
                    ctx_emit(ctx, set_init)
                    let end_idx = lower_expr(ctx, end_node)
                    let end_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
                    let set_end = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                    set_end.arg0 = end_local
                    ctx_emit(ctx, set_end)
                    let prev_break = ctx.loop_break_depth
                    let prev_continue = ctx.loop_continue_depth
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_BLOCK()))
                    ctx.nesting_depth = ctx.nesting_depth + 1
                    ctx.loop_break_depth = ctx.nesting_depth
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_LOOP()))
                    ctx.nesting_depth = ctx.nesting_depth + 1
                    ctx.loop_continue_depth = ctx.nesting_depth
                    let get_iter = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                    get_iter.arg0 = iter_var
                    ctx_emit(ctx, get_iter)
                    let get_end = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                    get_end.arg0 = end_local
                    ctx_emit(ctx, get_end)
                    let cmp_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                    ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_GTEQ(), cmp_dest, iter_var, end_local))
                    let br_break = mir_ir::MirInst_new(mir_opcodes::MIR_BR_IF())
                    br_break.int_val = 1
                    ctx_emit(ctx, br_break)
                    let _body_result = lower_expr(ctx, body)
                    let get_iter2 = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                    get_iter2.arg0 = iter_var
                    ctx_emit(ctx, get_iter2)
                    let one_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                    ctx_emit(ctx, mir_ir::MirInst_const_i32(1, one_dest))
                    let add_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                    ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_ADD(), add_dest, iter_var, one_dest))
                    let set_iter = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                    set_iter.arg0 = iter_var
                    ctx_emit(ctx, set_iter)
                    let br_loop = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
                    br_loop.int_val = 0
                    ctx_emit(ctx, br_loop)
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                    ctx.nesting_depth = ctx.nesting_depth - 1
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                    ctx.nesting_depth = ctx.nesting_depth - 1
                    ctx.loop_break_depth = prev_break
                    ctx.loop_continue_depth = prev_continue
                } else {
                    if range.kind == mir_type_info::NK_IDENT() {
                        let range_local_si = ctx_lookup_local(ctx, clone(range.text))
                        if range_local_si >= 0 {
                            let si_struct_type = ctx_get_local_type(ctx, range_local_si)
                            let si_next_callee = concat(clone(si_struct_type), String_from("::next"))
                            let si_next_vt = ctx_fn_return_vt(ctx, clone(si_next_callee))
                            if si_next_vt != 0 {
                                let si_iter_idx = lower_expr(ctx, range)
                                let si_iter_ptr = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                let si_save_iter = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                                si_save_iter.arg0 = si_iter_ptr
                                ctx_emit(ctx, si_save_iter)
                                ctx_set_local_type(ctx, si_iter_ptr, clone(si_struct_type))
                                let si_iter_var = ctx_alloc_local(ctx, clone(node.text), mir_ir::VT_I32())
                                let si_ret_tn = ctx_fn_return_type_name(ctx, clone(si_next_callee))
                                let mut si_payload_type = String_from("")
                                if starts_with(clone(si_ret_tn), "option:") {
                                    si_payload_type = substring(si_ret_tn, 7, len(si_ret_tn))
                                }
                                if len(si_payload_type) > 0 {
                                    ctx_set_local_type(ctx, si_iter_var, clone(si_payload_type))
                                }
                                let si_opt_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                let si_tag_local = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                let si_none_tag = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                let si_cmp_dest = ctx_fresh_local(ctx, mir_ir::VT_I32())
                                let si_prev_break = ctx.loop_break_depth
                                let si_prev_continue = ctx.loop_continue_depth
                                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_BLOCK()))
                                ctx.nesting_depth = ctx.nesting_depth + 1
                                ctx.loop_break_depth = ctx.nesting_depth
                                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_LOOP()))
                                ctx.nesting_depth = ctx.nesting_depth + 1
                                ctx.loop_continue_depth = ctx.nesting_depth
                                let si_get_iter = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                                si_get_iter.arg0 = si_iter_ptr
                                ctx_emit(ctx, si_get_iter)
                                let si_next_call = mir_ir::MirInst_new(mir_opcodes::MIR_CALL())
                                si_next_call.str_val = clone(si_next_callee)
                                si_next_call.int_val = 1
                                si_next_call.dest = si_opt_local
                                ctx_emit(ctx, si_next_call)
                                let si_save_opt = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                                si_save_opt.arg0 = si_opt_local
                                ctx_emit(ctx, si_save_opt)
                                let si_get_opt_tag = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                                si_get_opt_tag.arg0 = si_opt_local
                                ctx_emit(ctx, si_get_opt_tag)
                                let si_sg_tag = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
                                si_sg_tag.int_val = 0
                                si_sg_tag.val_type = mir_ir::VT_I32()
                                si_sg_tag.dest = si_tag_local
                                ctx_emit(ctx, si_sg_tag)
                                let si_save_tag = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                                si_save_tag.arg0 = si_tag_local
                                ctx_emit(ctx, si_save_tag)
                                let si_get_tag = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                                si_get_tag.arg0 = si_tag_local
                                ctx_emit(ctx, si_get_tag)
                                ctx_emit(ctx, mir_ir::MirInst_const_i32(1, si_none_tag))
                                ctx_emit(ctx, mir_ir::MirInst_binop(mir_opcodes::MIR_EQ(), si_cmp_dest, si_tag_local, si_none_tag))
                                let si_br_none = mir_ir::MirInst_new(mir_opcodes::MIR_BR_IF())
                                si_br_none.int_val = 1
                                ctx_emit(ctx, si_br_none)
                                let si_get_opt_val = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_GET())
                                si_get_opt_val.arg0 = si_opt_local
                                ctx_emit(ctx, si_get_opt_val)
                                let si_sg_payload = mir_ir::MirInst_new(mir_opcodes::MIR_STRUCT_GET())
                                si_sg_payload.int_val = 4
                                si_sg_payload.val_type = mir_ir::VT_I32()
                                si_sg_payload.dest = si_iter_var
                                ctx_emit(ctx, si_sg_payload)
                                let si_save_payload = mir_ir::MirInst_new(mir_opcodes::MIR_LOCAL_SET())
                                si_save_payload.arg0 = si_iter_var
                                ctx_emit(ctx, si_save_payload)
                                let _si_body = lower_expr(ctx, body)
                                let si_br_loop = mir_ir::MirInst_new(mir_opcodes::MIR_BR())
                                si_br_loop.int_val = 0
                                ctx_emit(ctx, si_br_loop)
                                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                                ctx.nesting_depth = ctx.nesting_depth - 1
                                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_END()))
                                ctx.nesting_depth = ctx.nesting_depth - 1
                                ctx.loop_break_depth = si_prev_break
                                ctx.loop_continue_depth = si_prev_continue
                            }
                        }
                    }
                }
            }
        }
        return 0 - 1
    }
    if kind == mir_type_info::NK_EXPR_STMT() {
        let child_count = len(node.children)
        if child_count >= 1 {
            let expr = get_unchecked(node.children, 0)
            let result = lower_expr(ctx, expr)
            return result
        }
        return 0 - 1
    }
    lower_expr(ctx, node)
}

fn lower_to_mir_impl(decls: Vec<AstNode>, check_result: TypeCheckResult, prune_enabled: bool) -> MirModule {
    let m = mir_ir::MirModule_new()
    let decl_count = len(decls)
    let mut fn_names = Vec_new_String()
    let mut fn_return_vts = Vec_new_i32()
    let mut fn_return_type_names = Vec_new_String()
    let mut fn_index = 0
    let typed_fn_count = len(check_result.typed_fns)
    let mut mir_tr = MIR_LOWER_TRACE_FORCE()
    if mir_tr == 0 {
        mir_tr = MIR_LOWER_TRACE()
    }
    mir_lower_trace_line(mir_tr, -1, decl_count, typed_fn_count, 0, 0)
    let mut entry_main_decl_index = 0 - 1
    let mut scan_main = 0
    while scan_main < decl_count {
        let scan_decl = get_unchecked(decls, scan_main)
        if scan_decl.kind == mir_type_info::NK_FN_DECL() {
            if eq(clone(scan_decl.text), String_from("main")) {
                entry_main_decl_index = scan_main
            }
        }
        scan_main = scan_main + 1
    }
    let mut d = 0
    while d < decl_count {
        let decl = get_unchecked(decls, d)
        if decl.kind == mir_type_info::NK_FN_DECL() {
            let mut rvt = mir_ir::VT_I32()
            let mut rtn = String_from("")
            if fn_index < typed_fn_count {
                let tf = get_unchecked(check_result.typed_fns, fn_index)
                let rt_tag = tf.return_type.tag
                if rt_tag == 3 {
                    rvt = mir_ir::VT_F64()
                } else {
                    if rt_tag == 2 {
                        rvt = mir_ir::VT_I64()
                    } else {
                        if rt_tag == 7 || rt_tag == 8 || rt_tag == 0 {
                            rvt = mir_ir::VT_VOID()
                        } else {
                            if rt_tag == 10 {
                                let vec_type_args = tf.return_type.type_args
                                if len(vec_type_args) > 0 {
                                    let vec_elem = get_unchecked(vec_type_args, 0)
                                    let elem_tag = vec_elem.tag
                                    if elem_tag == 5 {
                                        rtn = String_from("vec:String")
                                    } else {
                                        if elem_tag == 1 {
                                            rtn = String_from("vec:i32")
                                        } else {
                                            if elem_tag == 2 {
                                                rtn = String_from("vec:i64")
                                            } else {
                                                if elem_tag == 3 {
                                                    rtn = String_from("vec:f64")
                                                } else {
                                                    rtn = String_from("vec:i32")
                                                }
                                            }
                                        }
                                    }
                                }
                            } else {
                                if rt_tag == 21 || rt_tag == 22 {
                                    rtn = clone(tf.return_type.name)
                                }
                            }
                        }
                    }
                }
            }
            let skip_shadow_main = eq(clone(decl.text), String_from("main")) && d != entry_main_decl_index
            if !skip_shadow_main {
                push(fn_names, clone(decl.text))
                push(fn_return_vts, rvt)
                push(fn_return_type_names, clone(rtn))
                let mono_count = mono_instance_count_for(check_result.mono_instances, clone(decl.text))
                if mono_count > 0 {
                    let mut mono_i = 0
                    while mono_i < mono_count {
                        let mono_name = mono_instance_mangled_at(check_result.mono_instances, clone(decl.text), mono_i)
                        push(fn_names, mono_safe_name(mono_name))
                        push(fn_return_vts, rvt)
                        push(fn_return_type_names, clone(rtn))
                        mono_i = mono_i + 1
                    }
                }
            }
            fn_index = fn_index + 1
        }
        if decl.kind == mir_type_info::NK_IMPL_DECL() {
            let struct_name = clone(decl.text)
            let method_count = len(decl.children)
            let mut mi = 0
            while mi < method_count {
                let method = get_unchecked(decl.children, mi)
                let mangled = concat(clone(struct_name), concat(String_from("::"), clone(method.text)))
                push(fn_names, mangled)
                let mut mrvt = mir_ir::VT_VOID()
                let mut mrtn = String_from("")
                let ta_count = len(method.type_ann)
                let mut tai = 0
                while tai < ta_count {
                    let ta_node = get_unchecked(method.type_ann, tai)
                    if eq(clone(ta_node.text), "__return") {
                        if len(ta_node.children) > 0 {
                            let ret_node = get_unchecked(ta_node.children, 0)
                            let ret_text = clone(ret_node.text)
                            if eq(clone(ret_text), "f64") {
                                mrvt = mir_ir::VT_F64()
                                mrtn = String_from("f64")
                            } else {
                                if eq(clone(ret_text), "i64") || eq(clone(ret_text), "u64") {
                                    mrvt = mir_ir::VT_I64()
                                    mrtn = clone(ret_text)
                                } else {
                                    if eq(clone(ret_text), "void") || eq(clone(ret_text), "()") {
                                        mrvt = mir_ir::VT_VOID()
                                    } else {
                                        if eq(clone(ret_text), "i32") || eq(clone(ret_text), "u32") || eq(clone(ret_text), "u8") || eq(clone(ret_text), "u16") || eq(clone(ret_text), "i16") || eq(clone(ret_text), "i8") {
                                            mrvt = mir_ir::VT_I32()
                                            mrtn = String_from("i32")
                                        } else {
                                            if eq(clone(ret_text), "bool") {
                                                mrvt = mir_ir::VT_I32()
                                                mrtn = String_from("bool")
                                            } else {
                                                if eq(clone(ret_text), "String") || eq(clone(ret_text), "str") {
                                                    mrvt = mir_ir::VT_I32()
                                                    mrtn = String_from("String")
                                                } else {
                                                    if ret_node.kind == 91 {
                                                        mrvt = mir_ir::VT_I32()
                                                        if eq(clone(ret_text), "Vec") && len(ret_node.children) >= 2 {
                                                            let elem_n = get_unchecked(ret_node.children, 1)
                                                            mrtn = concat(String_from("vec:"), clone(elem_n.text))
                                                        } else {
                                                            if eq(clone(ret_text), "Option") && len(ret_node.children) >= 2 {
                                                                let elem_n_opt = get_unchecked(ret_node.children, 1)
                                                                mrtn = concat(String_from("option:"), clone(elem_n_opt.text))
                                                            } else {
                                                                mrtn = clone(ret_text)
                                                            }
                                                        }
                                                    } else {
                                                        mrvt = mir_ir::VT_I32()
                                                        if len(ret_text) > 1 {
                                                            mrtn = ret_text
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        } else {
                            mrvt = mir_ir::VT_VOID()
                        }
                    }
                    tai = tai + 1
                }
                push(fn_return_vts, mrvt)
                push(fn_return_type_names, mrtn)
                let method_mono_count = mono_instance_count_for(check_result.mono_instances, clone(mangled))
                if method_mono_count > 0 {
                    let mut method_mono_i = 0
                    while method_mono_i < method_mono_count {
                        let method_mono_name = mono_instance_mangled_at(check_result.mono_instances, clone(mangled), method_mono_i)
                        push(fn_names, mono_safe_name(method_mono_name))
                        push(fn_return_vts, mrvt)
                        push(fn_return_type_names, clone(mrtn))
                        method_mono_i = method_mono_i + 1
                    }
                }
                fn_index = fn_index + 1
                mi = mi + 1
            }
        }
        d = d + 1
    }
    let mut ctx = LowerCtx_new(m)
    ctx.fn_names = fn_names
    ctx.fn_return_vts = fn_return_vts
    ctx.fn_return_type_names = fn_return_type_names
    let mono_site_count = len(check_result.mono_instances)
    let mut mono_site_i = 0
    while mono_site_i < mono_site_count {
        let site_marker = get_unchecked(check_result.mono_instances, mono_site_i)
        let mut is_marker_entry = false
        if len(site_marker.type_args) > 0 {
            let span_ty = get_unchecked(site_marker.type_args, 0)
            let is_marker = span_ty.tag < 0
            is_marker_entry = is_marker
            if is_marker {
            let safe_target = mono_safe_name(clone(site_marker.mangled_name))
            let mut has_target = false
            let mut target_i = 0
            while target_i < len(ctx.fn_names) {
                if eq(clone(get_unchecked(ctx.fn_names, target_i)), clone(safe_target)) {
                    has_target = true
                }
                target_i = target_i + 1
            }
            if has_target {
                push(ctx.mono_call_starts, 0 - span_ty.tag - 1000)
                push(ctx.mono_call_targets, safe_target)
            }
            }
        }
        if !is_marker_entry {
            let safe_target2 = mono_safe_name(clone(site_marker.mangled_name))
            let mut has_target2 = false
            let mut target2_i = 0
            while target2_i < len(ctx.fn_names) {
                if eq(clone(get_unchecked(ctx.fn_names, target2_i)), clone(safe_target2)) {
                    has_target2 = true
                }
                target2_i = target2_i + 1
            }
            if has_target2 {
                push(ctx.mono_call_sources, clone(site_marker.fn_name))
                push(ctx.mono_call_targets, safe_target2)
                push(ctx.mono_call_used, 0)
            }
        }
        mono_site_i = mono_site_i + 1
    }
    if mir_tr != 0 {
        stdio::eprintln(concat(String_from("mir-lower mono rewrites: "), to_string(len(ctx.mono_call_sources))))
    }
    ctx_register_builtin_variants(ctx)
    let mut sd = 0
    while sd < decl_count {
        let decl = get_unchecked(decls, sd)
        if decl.kind == 51 {
            push(ctx.struct_names, clone(decl.text))
            let fc = len(decl.children)
            push(ctx.struct_field_counts, fc)
            let mut fi = 0
            while fi < fc {
                let field = get_unchecked(decl.children, fi)
                push(ctx.struct_all_fields, clone(field.text))
                let mut field_type_str = String_from("")
                if len(field.type_ann) > 0 {
                    let fty = get_unchecked(field.type_ann, 0)
                    if fty.kind == 91 {
                        if eq(clone(fty.text), "Vec") {
                            if len(fty.children) >= 2 {
                                let elem_ty = get_unchecked(fty.children, 1)
                                field_type_str = concat(String_from("vec:"), clone(elem_ty.text))
                            }
                        }
                    } else {
                        if fty.kind == 90 {
                            let ty_text = clone(fty.text)
                            if eq(clone(ty_text), "u8") {
                                field_type_str = String_from("i32")
                            } else {
                                field_type_str = ty_text
                            }
                        }
                    }
                }
                push(ctx.struct_field_types, field_type_str)
                fi = fi + 1
            }
        }
        if decl.kind == 52 {
            let vc = len(decl.children)
            let mut has_payload = false
            let mut vcheck = 0
            while vcheck < vc {
                let vc_node = get_unchecked(decl.children, vcheck)
                if len(vc_node.type_ann) > 0 {
                    has_payload = true
                }
                vcheck = vcheck + 1
            }
            let mut vi = 0
            while vi < vc {
                let variant = get_unchecked(decl.children, vi)
                let full_name = concat(clone(decl.text), concat(String_from("::"), clone(variant.text)))
                push(ctx.variant_names, full_name)
                push(ctx.variant_tags, vi)
                if has_payload {
                    push(ctx.payload_variants, clone(full_name))
                    let payload_count = len(variant.type_ann)
                    push(ctx.struct_names, clone(full_name))
                    push(ctx.struct_field_counts, payload_count + 1)
                    push(ctx.struct_all_fields, String_from("_tag"))
                    push(ctx.struct_field_types, String_from(""))
                    let mut pfi = 0
                    while pfi < payload_count {
                        let pfield = get_unchecked(variant.type_ann, pfi)
                        push(ctx.struct_all_fields, concat(String_from("_"), to_string(pfi)))
                        if eq(clone(pfield.text), "f64") {
                            push(ctx.struct_field_types, String_from("f64"))
                        } else {
                            push(ctx.struct_field_types, String_from(""))
                        }
                        pfi = pfi + 1
                    }
                }
                vi = vi + 1
            }
        }
        sd = sd + 1
    }
    let mut i = 0
    let mut fn_idx = 0
    while i < decl_count {
        let decl = get_unchecked(decls, i)
        if decl.kind == mir_type_info::NK_FN_DECL() {
            let skip_shadow_main = eq(clone(decl.text), String_from("main")) && i != entry_main_decl_index
            if !skip_shadow_main {
                let mono_emit_count_raw = mono_instance_count_for(check_result.mono_instances, clone(decl.text))
                let mono_emit_count = mono_emit_count_raw + 1
                let mut mono_emit_i = 0
                while mono_emit_i < mono_emit_count {
                    let mut emit_fn_name = clone(decl.text)
                    if mono_emit_i > 0 {
                        emit_fn_name = mono_safe_name(mono_instance_mangled_at(check_result.mono_instances, clone(decl.text), mono_emit_i - 1))
                    }
            let tf = get_unchecked(check_result.typed_fns, fn_idx)
            let mf = mir_ir::MirFunction_new(emit_fn_name)
            ctx.func = mf
            ctx.local_names = Vec_new_String()
            ctx.local_indices = Vec_new_i32()
            ctx.local_types = Vec_new_String()
            ctx.local_type_indices = Vec_new_i32()
            ctx.local_type_start = len(ctx.local_types)
            mir_lower_trace_line(mir_tr, -2, fn_idx, 0, 0, 0)
            let child_count = len(decl.children)
            let body_idx = child_count - 1
            let mut p = 0
            while p < body_idx {
                let param = get_unchecked(decl.children, p)
                if param.kind == mir_type_info::NK_IDENT() {
                    let mut pvt = mir_ir::VT_I32()
                    let mut p_type_name = String_new()
                    if len(param.type_ann) >= 1 {
                        let pta = get_unchecked(param.type_ann, 0)
                        p_type_name = mir_param_type_name_from_ann(pta)
                        if eq(clone(pta.text), "f64") {
                            pvt = mir_ir::VT_F64()
                        } else {
                            if eq(clone(pta.text), "i64") || eq(clone(pta.text), "u64") {
                                pvt = mir_ir::VT_I64()
                            }
                        }
                    }
                    let param_local = ctx_alloc_local(ctx, clone(param.text), pvt)
                    ctx_push_func_param(ctx, MirLocal { name: clone(param.text), val_type: pvt, type_name: p_type_name, ssa_name: clone(param.text), ssa_version: 0 - 1 })
                    if len(param.type_ann) >= 1 {
                        let p_ty = get_unchecked(param.type_ann, 0)
                        if p_ty.kind == 91 {
                            if eq(clone(p_ty.text), "Vec") && len(p_ty.children) >= 2 {
                                let p_elem = get_unchecked(p_ty.children, 1)
                                ctx_set_local_type(ctx, param_local, concat(String_from("vec:"), clone(p_elem.text)))
                            }
                            if eq(clone(p_ty.text), "Option") && len(p_ty.children) >= 2 {
                                let p_elem2 = get_unchecked(p_ty.children, 1)
                                if eq(clone(p_elem2.text), "i64") {
                                    ctx_set_local_type(ctx, param_local, String_from("Option_i64"))
                                } else {
                                    if eq(clone(p_elem2.text), "f64") {
                                        ctx_set_local_type(ctx, param_local, String_from("Option_f64"))
                                    } else {
                                        if eq(clone(p_elem2.text), "i32") {
                                            ctx_set_local_type(ctx, param_local, String_from("Option_i32"))
                                        }
                                    }
                                }
                            }
                        } else {
                            if p_ty.kind == 90 {
                                let p_ty_name = clone(p_ty.text)
                                if !eq(clone(p_ty_name), "i32") && !eq(clone(p_ty_name), "f64") && !eq(clone(p_ty_name), "i64") && !eq(clone(p_ty_name), "bool") && !eq(clone(p_ty_name), "String") && !eq(clone(p_ty_name), "u8") && !eq(clone(p_ty_name), "char") && len(p_ty_name) > 1 {
                                    ctx_set_local_type(ctx, param_local, p_ty_name)
                                }
                            }
                        }
                    }
                }
                p = p + 1
            }
            mir_lower_trace_ctx(mir_tr, ctx, 1)
            let rt_tag = tf.return_type.tag
            ctx_apply_fn_return_type_for_rt_tag(ctx, rt_tag)
            let mut typed_func = ctx.func
            typed_func.return_type_name = mir_decl_return_type_name(decl)
            ctx.func = typed_func
            mir_lower_trace_ctx(mir_tr, ctx, 2)
            let entry = mir_ir::ctx_alloc_block(ctx)
            ctx.cur_block = entry
            mir_lower_trace_ctx(mir_tr, ctx, 3)
            if body_idx >= 0 {
                let body = get_unchecked(decl.children, body_idx)
                let result = lower_expr(ctx, body)
                if result >= 0 && ctx.func.return_type == mir_ir::VT_VOID() {
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_DROP()))
                }
                ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_RETURN()))
            }
            mir_lower_trace_ctx(mir_tr, ctx, 4)
            push(ctx.module.functions, ctx.func)
                    mono_emit_i = mono_emit_i + 1
                }
            }
            fn_idx = fn_idx + 1
        }
        if decl.kind == mir_type_info::NK_IMPL_DECL() {
            let struct_name = clone(decl.text)
            let method_count = len(decl.children)
            let mut mi = 0
            while mi < method_count {
                let method = get_unchecked(decl.children, mi)
                let mangled = concat(clone(struct_name), concat(String_from("::"), clone(method.text)))
                let method_mono_emit_count_raw = mono_instance_count_for(check_result.mono_instances, clone(mangled))
                let method_mono_emit_count = method_mono_emit_count_raw + 1
                let mut method_mono_emit_i = 0
                while method_mono_emit_i < method_mono_emit_count {
                let mut emit_method_name = clone(mangled)
                if method_mono_emit_i > 0 {
                    emit_method_name = mono_safe_name(mono_instance_mangled_at(check_result.mono_instances, clone(mangled), method_mono_emit_i - 1))
                }
                let mf = mir_ir::MirFunction_new(emit_method_name)
                ctx.func = mf
                ctx.local_names = Vec_new_String()
                ctx.local_indices = Vec_new_i32()
                ctx.local_types = Vec_new_String()
                ctx.local_type_indices = Vec_new_i32()
                ctx.local_type_start = len(ctx.local_types)
                let m_child_count = len(method.children)
                let m_body_idx = m_child_count - 1
                let mut mp = 0
                while mp < m_body_idx {
                    let param = get_unchecked(method.children, mp)
                    if param.kind == mir_type_info::NK_IDENT() {
                        let p_name = clone(param.text)
                        if eq(clone(p_name), "self") || eq(clone(p_name), "&self") || eq(clone(p_name), "&mut self") {
                            let self_local = ctx_alloc_local(ctx, String_from("self"), mir_ir::VT_I32())
                            ctx_push_func_param(ctx, MirLocal { name: String_from("self"), val_type: mir_ir::VT_I32(), type_name: clone(struct_name), ssa_name: String_from("self"), ssa_version: 0 - 1 })
                            ctx_set_local_type(ctx, self_local, clone(struct_name))
                        } else {
                            let mut pvt = mir_ir::VT_I32()
                            let mut p_type_name = String_new()
                            if len(param.type_ann) >= 1 {
                                let pta = get_unchecked(param.type_ann, 0)
                                p_type_name = mir_param_type_name_from_ann(pta)
                                if eq(clone(pta.text), "f64") {
                                    pvt = mir_ir::VT_F64()
                                } else {
                                    if eq(clone(pta.text), "i64") {
                                        pvt = mir_ir::VT_I64()
                                    }
                                }
                            }
                            let param_local = ctx_alloc_local(ctx, clone(p_name), pvt)
                            ctx_push_func_param(ctx, MirLocal { name: clone(p_name), val_type: pvt, type_name: p_type_name, ssa_name: clone(p_name), ssa_version: 0 - 1 })
                            if len(param.type_ann) >= 1 {
                                let p_ty = get_unchecked(param.type_ann, 0)
                                if p_ty.kind == 91 {
                                    if eq(clone(p_ty.text), "Vec") && len(p_ty.children) >= 2 {
                                        let p_elem = get_unchecked(p_ty.children, 1)
                                        ctx_set_local_type(ctx, param_local, concat(String_from("vec:"), clone(p_elem.text)))
                                    }
                                } else {
                                    if p_ty.kind == 90 {
                                        let p_ty_name = clone(p_ty.text)
                                        if !eq(clone(p_ty_name), "i32") && !eq(clone(p_ty_name), "f64") && !eq(clone(p_ty_name), "i64") && !eq(clone(p_ty_name), "bool") && !eq(clone(p_ty_name), "String") && !eq(clone(p_ty_name), "u8") && !eq(clone(p_ty_name), "char") && len(p_ty_name) > 1 {
                                            ctx_set_local_type(ctx, param_local, p_ty_name)
                                        }
                                    }
                                }
                            }
                        }
                    }
                    mp = mp + 1
                }
                let mrvt = ctx_fn_return_vt(ctx, clone(mangled))
                let mut mfunc = ctx.func
                mfunc.return_type = mrvt
                mfunc.return_type_name = mir_decl_return_type_name(method)
                ctx.func = mfunc
                let entry = mir_ir::ctx_alloc_block(ctx)
                ctx.cur_block = entry
                if m_body_idx >= 0 {
                    let body = get_unchecked(method.children, m_body_idx)
                    let result = lower_expr(ctx, body)
                    if result >= 0 && ctx.func.return_type == mir_ir::VT_VOID() {
                        ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_DROP()))
                    }
                    ctx_emit(ctx, mir_ir::MirInst_new(mir_opcodes::MIR_RETURN()))
                }
                push(ctx.module.functions, ctx.func)
                method_mono_emit_i = method_mono_emit_i + 1
                }
                mi = mi + 1
            }
        }
        i = i + 1
    }
    if prune_enabled {
        let _mono_pruned = mir_prune_unreachable(ctx.module)
    }
    ctx.module
}

pub fn lower_to_mir(decls: Vec<AstNode>, check_result: TypeCheckResult) -> MirModule {
    lower_to_mir_impl(decls, check_result, true)
}

pub fn lower_to_mir_no_prune(decls: Vec<AstNode>, check_result: TypeCheckResult) -> MirModule {
    lower_to_mir_impl(decls, check_result, false)
}
