use lexer::number_suffix

fn lex_binary_number(lex: Lexer, start: i32) -> Token {
    lex.pos = lex.pos + 2
    let mut val: i32 = 0
    while lex.pos < lex.src_len && peek(lex) == 48 || peek(lex) == 49 || peek(lex) == 95 {
        let d = peek(lex)
        if d != 95 {
            val = val * 2 + d - 48
        }
        lex.pos = lex.pos + 1
    }
    number_suffix::try_eat_type_suffix(lex)
    let text = substring(lex.src, start, lex.pos)
    Token_int(val, text, start, lex.pos)
}
