use lexer::tokens
use lexer::char_class
use lexer::keywords

fn lex_ident(lex: Lexer) -> Token {
    let start = lex.pos
    while lex.pos < lex.src_len && char_class::is_alnum(peek(lex)) {
        lex.pos = lex.pos + 1
    }
    let word = substring(lex.src, start, lex.pos)
    if eq(clone(word), "f") {
        if lex.pos < lex.src_len && peek(lex) == 34 {
            return lex_fstring(lex, start)
        }
    }
    let kw = keywords::keyword_kind(clone(word))
    if kw >= 0 {
        Token_new(kw, word, start, lex.pos)
    } else {
        Token_new(tokens::TK_IDENT(), word, start, lex.pos)
    }
}

fn lex_fstring(lex: Lexer, start: i32) -> Token {
    lex.pos = lex.pos + 1
    let content_start = lex.pos
    let mut depth = 0
    while lex.pos < lex.src_len {
        let c = peek(lex)
        if c == 34 && depth == 0 {
            let content = substring(lex.src, content_start, lex.pos)
            lex.pos = lex.pos + 1
            return Token_new(tokens::TK_FSTRING(), content, start, lex.pos)
        }
        if c == 10 {
            return Token_new(tokens::TK_ERROR(), String_from("unterminated f-string"), start, lex.pos)
        }
        if c == 123 {
            depth = depth + 1
        }
        if c == 125 {
            depth = depth - 1
        }
        lex.pos = lex.pos + 1
    }
    Token_new(tokens::TK_ERROR(), String_from("unterminated f-string"), start, lex.pos)
}
