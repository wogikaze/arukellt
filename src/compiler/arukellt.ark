// Arukellt Self-Hosted Compiler — merged single-file build
// Generated from: lexer.ark, parser.ark, resolver.ark, typechecker.ark,
//                 mir.ark, emitter.ark, driver.ark, main.ark

use std::host::stdio
use std::host::fs
use std::host::env


// Arukellt Lexer — Self-hosted tokenizer for the Arukellt language.
//
// Produces a Vec of Token values from source text.
// Covers: keywords, identifiers, integer/float literals, string literals,
//         operators, delimiters, comments, newlines.


// ── Token Kind Tags ──────────────────────────────────────────────────────────
// Using i32 constants instead of enum because the self-hosted lexer
// needs to be simple and avoid complex enum dispatch.

fn TK_EOF() -> i32 { 0 }
fn TK_IDENT() -> i32 { 1 }
fn TK_INT() -> i32 { 2 }
fn TK_FLOAT() -> i32 { 3 }
fn TK_STRING() -> i32 { 4 }
fn TK_BOOL() -> i32 { 5 }
fn TK_NEWLINE() -> i32 { 6 }
fn TK_ERROR() -> i32 { 7 }

// Keywords
fn TK_FN() -> i32 { 10 }
fn TK_STRUCT() -> i32 { 11 }
fn TK_ENUM() -> i32 { 12 }
fn TK_LET() -> i32 { 13 }
fn TK_MUT() -> i32 { 14 }
fn TK_IF() -> i32 { 15 }
fn TK_ELSE() -> i32 { 16 }
fn TK_MATCH() -> i32 { 17 }
fn TK_WHILE() -> i32 { 18 }
fn TK_LOOP() -> i32 { 19 }
fn TK_FOR() -> i32 { 20 }
fn TK_IN() -> i32 { 21 }
fn TK_BREAK() -> i32 { 22 }
fn TK_CONTINUE() -> i32 { 23 }
fn TK_RETURN() -> i32 { 24 }
fn TK_PUB() -> i32 { 25 }
fn TK_IMPORT() -> i32 { 26 }
fn TK_AS() -> i32 { 27 }
fn TK_TRAIT() -> i32 { 28 }
fn TK_IMPL() -> i32 { 29 }
fn TK_USE() -> i32 { 30 }

// Operators
fn TK_PLUS() -> i32 { 40 }
fn TK_MINUS() -> i32 { 41 }
fn TK_STAR() -> i32 { 42 }
fn TK_SLASH() -> i32 { 43 }
fn TK_PERCENT() -> i32 { 44 }
fn TK_EQ() -> i32 { 45 }
fn TK_EQEQ() -> i32 { 46 }
fn TK_BANGEQ() -> i32 { 47 }
fn TK_LT() -> i32 { 48 }
fn TK_LTEQ() -> i32 { 49 }
fn TK_GT() -> i32 { 50 }
fn TK_GTEQ() -> i32 { 51 }
fn TK_AMPAMP() -> i32 { 52 }
fn TK_PIPEPIPE() -> i32 { 53 }
fn TK_BANG() -> i32 { 54 }
fn TK_AMP() -> i32 { 55 }
fn TK_PIPE() -> i32 { 56 }
fn TK_CARET() -> i32 { 57 }
fn TK_TILDE() -> i32 { 58 }
fn TK_SHL() -> i32 { 59 }
fn TK_SHR() -> i32 { 60 }

// Delimiters
fn TK_LPAREN() -> i32 { 70 }
fn TK_RPAREN() -> i32 { 71 }
fn TK_LBRACE() -> i32 { 72 }
fn TK_RBRACE() -> i32 { 73 }
fn TK_LBRACKET() -> i32 { 74 }
fn TK_RBRACKET() -> i32 { 75 }
fn TK_COMMA() -> i32 { 76 }
fn TK_SEMI() -> i32 { 77 }
fn TK_DOT() -> i32 { 78 }
fn TK_DOTDOT() -> i32 { 79 }
fn TK_ARROW() -> i32 { 80 }
fn TK_FATARROW() -> i32 { 81 }
fn TK_QUESTION() -> i32 { 82 }
fn TK_COLON() -> i32 { 83 }
fn TK_COLONCOLON() -> i32 { 84 }
fn TK_UNDERSCORE() -> i32 { 85 }

// ── Token ────────────────────────────────────────────────────────────────────

struct Token {
    kind: i32,
    text: String,
    int_val: i32,
    float_val: f64,
    start: i32,
    end: i32,
}

fn Token_new(kind: i32, text: String, start: i32, end: i32) -> Token {
    Token { kind: kind, text: text, int_val: 0, float_val: 0.0, start: start, end: end }
}

fn Token_int(val: i32, text: String, start: i32, end: i32) -> Token {
    Token { kind: TK_INT(), text: text, int_val: val, float_val: 0.0, start: start, end: end }
}

fn Token_float(val: f64, text: String, start: i32, end: i32) -> Token {
    Token { kind: TK_FLOAT(), text: text, int_val: 0, float_val: val, start: start, end: end }
}

// ── Lexer State ──────────────────────────────────────────────────────────────

struct Lexer {
    src: String,
    pos: i32,
    src_len: i32,
}

fn Lexer_new(source: String) -> Lexer {
    let n = len(source)
    Lexer { src: source, pos: 0, src_len: n }
}

// ── Character Helpers ────────────────────────────────────────────────────────

fn is_alpha(c: i32) -> bool {
    (c >= 65 && c <= 90) || (c >= 97 && c <= 122) || c == 95
}

fn is_digit(c: i32) -> bool {
    c >= 48 && c <= 57
}

fn is_hex_digit(c: i32) -> bool {
    is_digit(c) || (c >= 65 && c <= 70) || (c >= 97 && c <= 102)
}

fn is_alnum(c: i32) -> bool {
    is_alpha(c) || is_digit(c)
}

fn is_whitespace_not_newline(c: i32) -> bool {
    c == 32 || c == 9 || c == 13
}

fn digit_value(c: i32) -> i32 {
    if c >= 48 && c <= 57 { c - 48 }
    else if c >= 65 && c <= 70 { c - 55 }
    else if c >= 97 && c <= 102 { c - 87 }
    else { -1 }
}

// ── Keyword Lookup ───────────────────────────────────────────────────────────

fn keyword_kind(word: String) -> i32 {
    if eq(word, "fn") { return TK_FN() }
    if eq(word, "struct") { return TK_STRUCT() }
    if eq(word, "enum") { return TK_ENUM() }
    if eq(word, "let") { return TK_LET() }
    if eq(word, "mut") { return TK_MUT() }
    if eq(word, "if") { return TK_IF() }
    if eq(word, "else") { return TK_ELSE() }
    if eq(word, "match") { return TK_MATCH() }
    if eq(word, "while") { return TK_WHILE() }
    if eq(word, "loop") { return TK_LOOP() }
    if eq(word, "for") { return TK_FOR() }
    if eq(word, "in") { return TK_IN() }
    if eq(word, "break") { return TK_BREAK() }
    if eq(word, "continue") { return TK_CONTINUE() }
    if eq(word, "return") { return TK_RETURN() }
    if eq(word, "pub") { return TK_PUB() }
    if eq(word, "import") { return TK_IMPORT() }
    if eq(word, "as") { return TK_AS() }
    if eq(word, "trait") { return TK_TRAIT() }
    if eq(word, "impl") { return TK_IMPL() }
    if eq(word, "use") { return TK_USE() }
    if eq(word, "true") { return TK_BOOL() }
    if eq(word, "false") { return TK_BOOL() }
    0 - 1
}

// ── Core Lexer Methods ──────────────────────────────────────────────────────

fn peek(lex: Lexer) -> i32 {
    if lex.pos >= lex.src_len { -1 }
    else { char_at(lex.src, lex.pos) }
}

fn peek_at(lex: Lexer, offset: i32) -> i32 {
    let p = lex.pos + offset
    if p >= lex.src_len { -1 }
    else { char_at(lex.src, p) }
}

fn advance(lex: Lexer) -> i32 {
    let c = char_at(lex.src, lex.pos)
    lex.pos = lex.pos + 1
    c
}

fn skip_whitespace(lex: Lexer) {
    while lex.pos < lex.src_len && is_whitespace_not_newline(peek(lex)) {
        lex.pos = lex.pos + 1
    }
}

fn skip_line_comment(lex: Lexer) {
    while lex.pos < lex.src_len && char_at(lex.src, lex.pos) != 10 {
        lex.pos = lex.pos + 1
    }
}

fn skip_block_comment(lex: Lexer) {
    // Skip past the opening /*
    lex.pos = lex.pos + 2
    let mut depth = 1
    while lex.pos < lex.src_len - 1 && depth > 0 {
        let c = char_at(lex.src, lex.pos)
        let c2 = char_at(lex.src, lex.pos + 1)
        if c == 47 && c2 == 42 {
            depth = depth + 1
            lex.pos = lex.pos + 2
        } else if c == 42 && c2 == 47 {
            depth = depth - 1
            lex.pos = lex.pos + 2
        } else {
            lex.pos = lex.pos + 1
        }
    }
}

// ── Lex Identifier / Keyword ─────────────────────────────────────────────────

fn lex_ident(lex: Lexer) -> Token {
    let start = lex.pos
    while lex.pos < lex.src_len && is_alnum(peek(lex)) {
        lex.pos = lex.pos + 1
    }
    let word = substring(lex.src, start, lex.pos)
    let kw = keyword_kind(clone(word))
    if kw >= 0 {
        Token_new(kw, word, start, lex.pos)
    } else {
        Token_new(TK_IDENT(), word, start, lex.pos)
    }
}

// ── Lex Number ───────────────────────────────────────────────────────────────

fn lex_number(lex: Lexer) -> Token {
    let start = lex.pos
    let c0 = peek(lex)

    // Hex: 0x...
    if c0 == 48 && lex.pos + 1 < lex.src_len {
        let c1 = peek_at(lex, 1)
        if c1 == 120 || c1 == 88 {
            lex.pos = lex.pos + 2
            let mut val: i32 = 0
            while lex.pos < lex.src_len && (is_hex_digit(peek(lex)) || peek(lex) == 95) {
                let d = peek(lex)
                if d != 95 {
                    val = val * 16 + digit_value(d)
                }
                lex.pos = lex.pos + 1
            }
            let text = substring(lex.src, start, lex.pos)
            return Token_int(val, text, start, lex.pos)
        }
        // Binary: 0b...
        if c1 == 98 || c1 == 66 {
            lex.pos = lex.pos + 2
            let mut val: i32 = 0
            while lex.pos < lex.src_len && (peek(lex) == 48 || peek(lex) == 49 || peek(lex) == 95) {
                let d = peek(lex)
                if d != 95 {
                    val = val * 2 + (d - 48)
                }
                lex.pos = lex.pos + 1
            }
            let text = substring(lex.src, start, lex.pos)
            return Token_int(val, text, start, lex.pos)
        }
    }

    // Decimal integer or float
    let mut val: i32 = 0
    while lex.pos < lex.src_len && (is_digit(peek(lex)) || peek(lex) == 95) {
        let d = peek(lex)
        if d != 95 {
            val = val * 10 + (d - 48)
        }
        lex.pos = lex.pos + 1
    }

    // Check for float: dot followed by digit
    let mut is_float = false
    if lex.pos < lex.src_len && peek(lex) == 46 {
        if lex.pos + 1 < lex.src_len && is_digit(peek_at(lex, 1)) {
            is_float = true
            lex.pos = lex.pos + 1
            while lex.pos < lex.src_len && (is_digit(peek(lex)) || peek(lex) == 95) {
                lex.pos = lex.pos + 1
            }
        }
    }

    // Scientific notation: e/E
    if lex.pos < lex.src_len && (peek(lex) == 101 || peek(lex) == 69) {
        is_float = true
        lex.pos = lex.pos + 1
        if lex.pos < lex.src_len && (peek(lex) == 43 || peek(lex) == 45) {
            lex.pos = lex.pos + 1
        }
        while lex.pos < lex.src_len && is_digit(peek(lex)) {
            lex.pos = lex.pos + 1
        }
    }

    let text = substring(lex.src, start, lex.pos)
    if is_float {
        // Workaround: extract f64 from match to avoid codegen bug
        // with match returning structs containing f64 fields
        let f_result = parse_f64(clone(text))
        let mut fv: f64 = 0.0
        let mut parse_ok = true
        match f_result {
            Ok(v) => { fv = v },
            Err(_e) => { parse_ok = false },
        }
        if parse_ok {
            return Token_float(fv, text, start, lex.pos)
        }
        Token_new(TK_ERROR(), text, start, lex.pos)
    } else {
        Token_int(val, text, start, lex.pos)
    }
}

// ── Lex String ───────────────────────────────────────────────────────────────

fn lex_string(lex: Lexer) -> Token {
    let start = lex.pos
    lex.pos = lex.pos + 1  // skip opening "
    let mut has_escape = false
    let content_start = lex.pos
    // First pass: check if there are escapes
    let mut scan = lex.pos
    while scan < lex.src_len {
        let sc = char_at(lex.src, scan)
        if sc == 34 || sc == 10 { break }
        if sc == 92 { has_escape = true; break }
        scan = scan + 1
    }
    if !has_escape {
        // Fast path: no escapes, just substring
        while lex.pos < lex.src_len {
            let c = peek(lex)
            if c == 34 {
                let text = substring(lex.src, content_start, lex.pos)
                lex.pos = lex.pos + 1
                return Token_new(TK_STRING(), text, start, lex.pos)
            }
            if c == 10 {
                return Token_new(TK_ERROR(), String_from("unterminated string"), start, lex.pos)
            }
            lex.pos = lex.pos + 1
        }
        return Token_new(TK_ERROR(), String_from("unterminated string"), start, lex.pos)
    }
    // Slow path: has escapes, build via concat + substring spans
    let mut result = String_new()
    let mut span_start = lex.pos
    while lex.pos < lex.src_len {
        let c = peek(lex)
        if c == 34 {
            if span_start < lex.pos {
                result = concat(result, substring(lex.src, span_start, lex.pos))
            }
            lex.pos = lex.pos + 1
            return Token_new(TK_STRING(), result, start, lex.pos)
        }
        if c == 10 {
            return Token_new(TK_ERROR(), String_from("unterminated string"), start, lex.pos)
        }
        if c == 92 {
            // Flush pending span
            if span_start < lex.pos {
                result = concat(result, substring(lex.src, span_start, lex.pos))
            }
            lex.pos = lex.pos + 1
            if lex.pos >= lex.src_len {
                return Token_new(TK_ERROR(), String_from("unterminated escape"), start, lex.pos)
            }
            let esc = peek(lex)
            lex.pos = lex.pos + 1
            if esc == 110 { result = concat(result, String_from("\n")) }
            else if esc == 116 { result = concat(result, String_from("\t")) }
            else if esc == 114 { result = concat(result, String_from("\r")) }
            else if esc == 92 { result = concat(result, String_from("\\")) }
            else if esc == 34 { result = concat(result, String_from("\"")) }
            else {
                // Unknown escape: include the char as-is
                result = concat(result, substring(lex.src, lex.pos - 1, lex.pos))
            }
            span_start = lex.pos
        } else {
            lex.pos = lex.pos + 1
        }
    }
    Token_new(TK_ERROR(), String_from("unterminated string"), start, lex.pos)
}

// ── Main Tokenize ────────────────────────────────────────────────────────────

fn next_token(lex: Lexer) -> Token {
    skip_whitespace(lex)

    if lex.pos >= lex.src_len {
        return Token_new(TK_EOF(), String_from(""), lex.pos, lex.pos)
    }

    let start = lex.pos
    let c = peek(lex)

    // Newline
    if c == 10 {
        lex.pos = lex.pos + 1
        return Token_new(TK_NEWLINE(), String_from("\n"), start, lex.pos)
    }

    // Comments
    if c == 47 && lex.pos + 1 < lex.src_len {
        let c2 = peek_at(lex, 1)
        if c2 == 47 {
            skip_line_comment(lex)
            return next_token(lex)
        }
        if c2 == 42 {
            skip_block_comment(lex)
            return next_token(lex)
        }
    }

    // Identifiers and keywords
    if is_alpha(c) {
        return lex_ident(lex)
    }

    // Numbers
    if is_digit(c) {
        return lex_number(lex)
    }

    // String literal
    if c == 34 {
        return lex_string(lex)
    }

    // Two-character operators
    lex.pos = lex.pos + 1

    if c == 61 {
        if peek(lex) == 61 { lex.pos = lex.pos + 1; return Token_new(TK_EQEQ(), String_from("=="), start, lex.pos) }
        if peek(lex) == 62 { lex.pos = lex.pos + 1; return Token_new(TK_FATARROW(), String_from("=>"), start, lex.pos) }
        return Token_new(TK_EQ(), String_from("="), start, lex.pos)
    }
    if c == 33 {
        if peek(lex) == 61 { lex.pos = lex.pos + 1; return Token_new(TK_BANGEQ(), String_from("!="), start, lex.pos) }
        return Token_new(TK_BANG(), String_from("!"), start, lex.pos)
    }
    if c == 60 {
        if peek(lex) == 61 { lex.pos = lex.pos + 1; return Token_new(TK_LTEQ(), String_from("<="), start, lex.pos) }
        if peek(lex) == 60 { lex.pos = lex.pos + 1; return Token_new(TK_SHL(), String_from("<<"), start, lex.pos) }
        return Token_new(TK_LT(), String_from("<"), start, lex.pos)
    }
    if c == 62 {
        if peek(lex) == 61 { lex.pos = lex.pos + 1; return Token_new(TK_GTEQ(), String_from(">="), start, lex.pos) }
        if peek(lex) == 62 { lex.pos = lex.pos + 1; return Token_new(TK_SHR(), String_from(">>"), start, lex.pos) }
        return Token_new(TK_GT(), String_from(">"), start, lex.pos)
    }
    if c == 38 {
        if peek(lex) == 38 { lex.pos = lex.pos + 1; return Token_new(TK_AMPAMP(), String_from("&&"), start, lex.pos) }
        return Token_new(TK_AMP(), String_from("&"), start, lex.pos)
    }
    if c == 124 {
        if peek(lex) == 124 { lex.pos = lex.pos + 1; return Token_new(TK_PIPEPIPE(), String_from("||"), start, lex.pos) }
        return Token_new(TK_PIPE(), String_from("|"), start, lex.pos)
    }
    if c == 45 {
        if peek(lex) == 62 { lex.pos = lex.pos + 1; return Token_new(TK_ARROW(), String_from("->"), start, lex.pos) }
        return Token_new(TK_MINUS(), String_from("-"), start, lex.pos)
    }
    if c == 58 {
        if peek(lex) == 58 { lex.pos = lex.pos + 1; return Token_new(TK_COLONCOLON(), String_from("::"), start, lex.pos) }
        return Token_new(TK_COLON(), String_from(":"), start, lex.pos)
    }
    if c == 46 {
        if peek(lex) == 46 { lex.pos = lex.pos + 1; return Token_new(TK_DOTDOT(), String_from(".."), start, lex.pos) }
        return Token_new(TK_DOT(), String_from("."), start, lex.pos)
    }

    // Single-character tokens
    if c == 43 { return Token_new(TK_PLUS(), String_from("+"), start, lex.pos) }
    if c == 42 { return Token_new(TK_STAR(), String_from("*"), start, lex.pos) }
    if c == 47 { return Token_new(TK_SLASH(), String_from("/"), start, lex.pos) }
    if c == 37 { return Token_new(TK_PERCENT(), String_from("%"), start, lex.pos) }
    if c == 94 { return Token_new(TK_CARET(), String_from("^"), start, lex.pos) }
    if c == 126 { return Token_new(TK_TILDE(), String_from("~"), start, lex.pos) }
    if c == 40 { return Token_new(TK_LPAREN(), String_from("("), start, lex.pos) }
    if c == 41 { return Token_new(TK_RPAREN(), String_from(")"), start, lex.pos) }
    if c == 123 { return Token_new(TK_LBRACE(), String_from("{"), start, lex.pos) }
    if c == 125 { return Token_new(TK_RBRACE(), String_from("}"), start, lex.pos) }
    if c == 91 { return Token_new(TK_LBRACKET(), String_from("["), start, lex.pos) }
    if c == 93 { return Token_new(TK_RBRACKET(), String_from("]"), start, lex.pos) }
    if c == 44 { return Token_new(TK_COMMA(), String_from(","), start, lex.pos) }
    if c == 59 { return Token_new(TK_SEMI(), String_from(";"), start, lex.pos) }
    if c == 63 { return Token_new(TK_QUESTION(), String_from("?"), start, lex.pos) }

    // Unknown character
    Token_new(TK_ERROR(), substring(lex.src, start, lex.pos), start, lex.pos)
}

fn tokenize(source: String) -> Vec<Token> {
    let mut lex = Lexer_new(source)
    let mut tokens: Vec<Token> = Vec_new_Token()
    let mut done = false
    while !done {
        let tok = next_token(lex)
        if tok.kind == TK_EOF() {
            push(tokens, tok)
            done = true
        } else {
            push(tokens, tok)
        }
    }
    tokens
}

// ── Token Display Helpers ────────────────────────────────────────────────────

fn token_kind_name(kind: i32) -> String {
    if kind == TK_EOF() { return String_from("EOF") }
    if kind == TK_IDENT() { return String_from("IDENT") }
    if kind == TK_INT() { return String_from("INT") }
    if kind == TK_FLOAT() { return String_from("FLOAT") }
    if kind == TK_STRING() { return String_from("STRING") }
    if kind == TK_BOOL() { return String_from("BOOL") }
    if kind == TK_NEWLINE() { return String_from("NEWLINE") }
    if kind == TK_ERROR() { return String_from("ERROR") }
    if kind == TK_FN() { return String_from("FN") }
    if kind == TK_STRUCT() { return String_from("STRUCT") }
    if kind == TK_ENUM() { return String_from("ENUM") }
    if kind == TK_LET() { return String_from("LET") }
    if kind == TK_MUT() { return String_from("MUT") }
    if kind == TK_IF() { return String_from("IF") }
    if kind == TK_ELSE() { return String_from("ELSE") }
    if kind == TK_MATCH() { return String_from("MATCH") }
    if kind == TK_WHILE() { return String_from("WHILE") }
    if kind == TK_LOOP() { return String_from("LOOP") }
    if kind == TK_FOR() { return String_from("FOR") }
    if kind == TK_IN() { return String_from("IN") }
    if kind == TK_BREAK() { return String_from("BREAK") }
    if kind == TK_CONTINUE() { return String_from("CONTINUE") }
    if kind == TK_RETURN() { return String_from("RETURN") }
    if kind == TK_PUB() { return String_from("PUB") }
    if kind == TK_IMPORT() { return String_from("IMPORT") }
    if kind == TK_AS() { return String_from("AS") }
    if kind == TK_USE() { return String_from("USE") }
    if kind == TK_PLUS() { return String_from("PLUS") }
    if kind == TK_MINUS() { return String_from("MINUS") }
    if kind == TK_STAR() { return String_from("STAR") }
    if kind == TK_SLASH() { return String_from("SLASH") }
    if kind == TK_EQ() { return String_from("EQ") }
    if kind == TK_EQEQ() { return String_from("EQEQ") }
    if kind == TK_BANGEQ() { return String_from("BANGEQ") }
    if kind == TK_LT() { return String_from("LT") }
    if kind == TK_GT() { return String_from("GT") }
    if kind == TK_ARROW() { return String_from("ARROW") }
    if kind == TK_FATARROW() { return String_from("FATARROW") }
    if kind == TK_COLON() { return String_from("COLON") }
    if kind == TK_COLONCOLON() { return String_from("COLONCOLON") }
    if kind == TK_LPAREN() { return String_from("LPAREN") }
    if kind == TK_RPAREN() { return String_from("RPAREN") }
    if kind == TK_LBRACE() { return String_from("LBRACE") }
    if kind == TK_RBRACE() { return String_from("RBRACE") }
    if kind == TK_COMMA() { return String_from("COMMA") }
    if kind == TK_DOT() { return String_from("DOT") }
    String_from("UNKNOWN")
}

fn print_token(tok: Token) {
    let kind_str = token_kind_name(tok.kind)
    let pos_str = i32_to_string(tok.start)
    if tok.kind == TK_IDENT() || tok.kind == TK_STRING() || tok.kind == TK_ERROR() {
        stdio::println(concat(concat(concat(kind_str, "("), tok.text), ")"))
    } else if tok.kind == TK_INT() {
        stdio::println(concat(concat(concat(kind_str, "("), i32_to_string(tok.int_val)), ")"))
    } else if tok.kind == TK_FLOAT() {
        stdio::println(concat(concat(concat(kind_str, "("), f64_to_string(tok.float_val)), ")"))
    } else if tok.kind == TK_BOOL() {
        stdio::println(concat(concat(concat(kind_str, "("), tok.text), ")"))
    } else if tok.kind == TK_NEWLINE() {
        // skip printing newlines to reduce noise
    } else {
        stdio::println(kind_str)
    }
}

// Arukellt Parser — Self-hosted recursive descent + Pratt parser.
//
// Consumes a Vec<Token> from the lexer and produces an AST.
// Uses i32 tag constants for node kinds (same pattern as lexer).


// ── AST Node Kind Tags ──────────────────────────────────────────────────────

// Expressions
fn NK_INT_LIT() -> i32 { 1 }
fn NK_FLOAT_LIT() -> i32 { 2 }
fn NK_STRING_LIT() -> i32 { 3 }
fn NK_BOOL_LIT() -> i32 { 4 }
fn NK_IDENT() -> i32 { 5 }
fn NK_BINARY() -> i32 { 6 }
fn NK_UNARY() -> i32 { 7 }
fn NK_CALL() -> i32 { 8 }
fn NK_FIELD_ACCESS() -> i32 { 9 }
fn NK_INDEX() -> i32 { 10 }
fn NK_STRUCT_LIT() -> i32 { 11 }
fn NK_ARRAY_LIT() -> i32 { 12 }
fn NK_IF_EXPR() -> i32 { 13 }
fn NK_MATCH_EXPR() -> i32 { 14 }
fn NK_CLOSURE() -> i32 { 15 }
fn NK_PATH() -> i32 { 16 }
fn NK_TUPLE() -> i32 { 17 }
fn NK_ASSIGN() -> i32 { 18 }
fn NK_RANGE() -> i32 { 19 }
fn NK_BLOCK() -> i32 { 20 }
fn NK_METHOD_CALL() -> i32 { 21 }
fn NK_FSTRING() -> i32 { 22 }
fn NK_CHAR_LIT() -> i32 { 23 }

// Statements
fn NK_LET() -> i32 { 30 }
fn NK_RETURN() -> i32 { 31 }
fn NK_BREAK() -> i32 { 32 }
fn NK_CONTINUE() -> i32 { 33 }
fn NK_WHILE() -> i32 { 34 }
fn NK_LOOP() -> i32 { 35 }
fn NK_FOR() -> i32 { 36 }
fn NK_EXPR_STMT() -> i32 { 37 }

// Declarations
fn NK_FN_DECL() -> i32 { 50 }
fn NK_STRUCT_DECL() -> i32 { 51 }
fn NK_ENUM_DECL() -> i32 { 52 }
fn NK_IMPORT() -> i32 { 53 }
fn NK_USE() -> i32 { 54 }
fn NK_TRAIT_DECL() -> i32 { 55 }
fn NK_IMPL_DECL() -> i32 { 56 }

// Patterns
fn NK_PAT_IDENT() -> i32 { 70 }
fn NK_PAT_WILDCARD() -> i32 { 71 }
fn NK_PAT_LITERAL() -> i32 { 72 }
fn NK_PAT_VARIANT() -> i32 { 73 }
fn NK_PAT_STRUCT() -> i32 { 74 }
fn NK_PAT_TUPLE() -> i32 { 75 }

// Types
fn NK_TYPE_NAMED() -> i32 { 90 }
fn NK_TYPE_GENERIC() -> i32 { 91 }
fn NK_TYPE_FN() -> i32 { 92 }
fn NK_TYPE_TUPLE() -> i32 { 93 }
fn NK_TYPE_OPTION() -> i32 { 94 }
fn NK_TYPE_RESULT() -> i32 { 95 }

// Binary operators
fn OP_ADD() -> i32 { 1 }
fn OP_SUB() -> i32 { 2 }
fn OP_MUL() -> i32 { 3 }
fn OP_DIV() -> i32 { 4 }
fn OP_MOD() -> i32 { 5 }
fn OP_EQ() -> i32 { 6 }
fn OP_NEQ() -> i32 { 7 }
fn OP_LT() -> i32 { 8 }
fn OP_LTEQ() -> i32 { 9 }
fn OP_GT() -> i32 { 10 }
fn OP_GTEQ() -> i32 { 11 }
fn OP_AND() -> i32 { 12 }
fn OP_OR() -> i32 { 13 }
fn OP_BIT_AND() -> i32 { 14 }
fn OP_BIT_OR() -> i32 { 15 }
fn OP_BIT_XOR() -> i32 { 16 }
fn OP_SHL() -> i32 { 17 }
fn OP_SHR() -> i32 { 18 }

// Unary operators
fn UOP_NEG() -> i32 { 1 }
fn UOP_NOT() -> i32 { 2 }
fn UOP_BITNOT() -> i32 { 3 }

// ── Span ─────────────────────────────────────────────────────────────────────

struct Span {
    start: i32,
    end: i32,
}

fn Span_new(start: i32, end: i32) -> Span {
    Span { start: start, end: end }
}

fn Span_empty() -> Span {
    Span { start: 0, end: 0 }
}

// ── AST Node ─────────────────────────────────────────────────────────────────
// Uniform node: kind + tagged data fields.
// Children stored in a Vec<AstNode> for compound nodes.

struct AstNode {
    kind: i32,
    span: Span,
    text: String,
    int_val: i32,
    float_val: f64,
    op: i32,
    children: Vec<AstNode>,
    type_ann: Vec<AstNode>,
    is_mut: bool,
    is_pub: bool,
}

fn AstNode_new(kind: i32, span: Span) -> AstNode {
    AstNode {
        kind: kind, span: span, text: String_new(),
        int_val: 0, float_val: 0.0, op: 0,
        children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(),
        is_mut: false, is_pub: false,
    }
}

fn AstNode_leaf(kind: i32, text: String, span: Span) -> AstNode {
    AstNode {
        kind: kind, span: span, text: text,
        int_val: 0, float_val: 0.0, op: 0,
        children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(),
        is_mut: false, is_pub: false,
    }
}

fn AstNode_int(val: i32, span: Span) -> AstNode {
    AstNode {
        kind: NK_INT_LIT(), span: span, text: String_new(),
        int_val: val, float_val: 0.0, op: 0,
        children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(),
        is_mut: false, is_pub: false,
    }
}

fn AstNode_float(val: f64, span: Span) -> AstNode {
    AstNode {
        kind: NK_FLOAT_LIT(), span: span, text: String_new(),
        int_val: 0, float_val: val, op: 0,
        children: Vec_new_AstNode(), type_ann: Vec_new_AstNode(),
        is_mut: false, is_pub: false,
    }
}

// ── Parse Error ──────────────────────────────────────────────────────────────

struct ParseError {
    message: String,
    span: Span,
}

fn ParseError_new(msg: String, span: Span) -> ParseError {
    ParseError { message: msg, span: span }
}

// ── Parser State ─────────────────────────────────────────────────────────────

struct Parser {
    tokens: Vec<Token>,
    pos: i32,
    token_count: i32,
    errors: Vec<ParseError>,
}

fn Parser_new(tokens: Vec<Token>) -> Parser {
    let count = len(tokens)
    Parser { tokens: tokens, pos: 0, token_count: count, errors: Vec_new_ParseError() }
}

// ── Parser Helpers ───────────────────────────────────────────────────────────

fn cur(p: Parser) -> Token {
    if p.pos >= p.token_count {
        // Synthesize EOF
        let tok = Token { kind: TK_EOF(), text: String_from(""), int_val: 0, float_val: 0.0, start: 0, end: 0 }
        return tok
    }
    get_unchecked(p.tokens, p.pos)
}

fn peek_kind(p: Parser) -> i32 {
    let t = cur(p)
    t.kind
}

fn at(p: Parser, kind: i32) -> bool {
    peek_kind(p) == kind
}

fn at_eof(p: Parser) -> bool {
    at(p, TK_EOF())
}

fn bump(p: Parser) -> Token {
    let t = cur(p)
    p.pos = p.pos + 1
    t
}

fn skip_newlines(p: Parser) {
    while peek_kind(p) == TK_NEWLINE() {
        p.pos = p.pos + 1
    }
}

fn expect_token(p: Parser, kind: i32) -> Token {
    skip_newlines(p)
    let t = cur(p)
    if t.kind == kind {
        p.pos = p.pos + 1
        return t
    }
    let err = ParseError_new(
        concat(String_from("expected token kind "), concat(to_string(kind), concat(String_from(", got "), to_string(t.kind)))),
        Span_new(t.start, t.end)
    )
    push(p.errors, err)
    t
}

fn tok_span(t: Token) -> Span {
    Span_new(t.start, t.end)
}

fn error(p: Parser, msg: String) {
    let t = cur(p)
    push(p.errors, ParseError_new(msg, tok_span(t)))
}

// ── Precedence (Pratt) ──────────────────────────────────────────────────────

fn prefix_bp(kind: i32) -> i32 {
    if kind == TK_MINUS() { return 23 }
    if kind == TK_BANG() { return 23 }
    if kind == TK_TILDE() { return 23 }
    0
}

fn infix_bp_left(kind: i32) -> i32 {
    if kind == TK_PIPEPIPE() { return 3 }
    if kind == TK_AMPAMP() { return 5 }
    if kind == TK_PIPE() { return 7 }
    if kind == TK_CARET() { return 9 }
    if kind == TK_AMP() { return 11 }
    if kind == TK_EQEQ() || kind == TK_BANGEQ() { return 13 }
    if kind == TK_LT() || kind == TK_LTEQ() || kind == TK_GT() || kind == TK_GTEQ() { return 15 }
    if kind == TK_SHL() || kind == TK_SHR() { return 17 }
    if kind == TK_PLUS() || kind == TK_MINUS() { return 19 }
    if kind == TK_STAR() || kind == TK_SLASH() || kind == TK_PERCENT() { return 21 }
    0
}

fn infix_bp_right(kind: i32) -> i32 {
    if kind == TK_PIPEPIPE() { return 4 }
    if kind == TK_AMPAMP() { return 6 }
    if kind == TK_PIPE() { return 8 }
    if kind == TK_CARET() { return 10 }
    if kind == TK_AMP() { return 12 }
    if kind == TK_EQEQ() || kind == TK_BANGEQ() { return 14 }
    if kind == TK_LT() || kind == TK_LTEQ() || kind == TK_GT() || kind == TK_GTEQ() { return 16 }
    if kind == TK_SHL() || kind == TK_SHR() { return 18 }
    if kind == TK_PLUS() || kind == TK_MINUS() { return 20 }
    if kind == TK_STAR() || kind == TK_SLASH() || kind == TK_PERCENT() { return 22 }
    0
}

fn token_to_binop(kind: i32) -> i32 {
    if kind == TK_PLUS() { return OP_ADD() }
    if kind == TK_MINUS() { return OP_SUB() }
    if kind == TK_STAR() { return OP_MUL() }
    if kind == TK_SLASH() { return OP_DIV() }
    if kind == TK_PERCENT() { return OP_MOD() }
    if kind == TK_EQEQ() { return OP_EQ() }
    if kind == TK_BANGEQ() { return OP_NEQ() }
    if kind == TK_LT() { return OP_LT() }
    if kind == TK_LTEQ() { return OP_LTEQ() }
    if kind == TK_GT() { return OP_GT() }
    if kind == TK_GTEQ() { return OP_GTEQ() }
    if kind == TK_AMPAMP() { return OP_AND() }
    if kind == TK_PIPEPIPE() { return OP_OR() }
    if kind == TK_AMP() { return OP_BIT_AND() }
    if kind == TK_PIPE() { return OP_BIT_OR() }
    if kind == TK_CARET() { return OP_BIT_XOR() }
    if kind == TK_SHL() { return OP_SHL() }
    if kind == TK_SHR() { return OP_SHR() }
    0
}

fn token_to_unop(kind: i32) -> i32 {
    if kind == TK_MINUS() { return UOP_NEG() }
    if kind == TK_BANG() { return UOP_NOT() }
    if kind == TK_TILDE() { return UOP_BITNOT() }
    0
}

// ── Type Parsing ─────────────────────────────────────────────────────────────

fn parse_type(p: Parser) -> AstNode {
    skip_newlines(p)
    let t = cur(p)

    if t.kind == TK_IDENT() {
        p.pos = p.pos + 1
        let base = AstNode_leaf(NK_TYPE_NAMED(), clone(t.text), tok_span(t))

        // Check for generic: Type<T1, T2>
        if peek_kind(p) == TK_LT() {
            p.pos = p.pos + 1
            let node = AstNode_new(NK_TYPE_GENERIC(), tok_span(t))
            node.text = clone(t.text)
            push(node.children, base)
            let mut first = true
            while !at(p, TK_GT()) && !at_eof(p) {
                if !first { expect_token(p, TK_COMMA()) }
                first = false
                skip_newlines(p)
                let arg = parse_type(p)
                push(node.children, arg)
            }
            expect_token(p, TK_GT())
            return node
        }
        return base
    }

    if t.kind == TK_LPAREN() {
        // Tuple type or fn type
        p.pos = p.pos + 1
        let node = AstNode_new(NK_TYPE_TUPLE(), tok_span(t))
        let mut first = true
        while !at(p, TK_RPAREN()) && !at_eof(p) {
            if !first { expect_token(p, TK_COMMA()) }
            first = false
            skip_newlines(p)
            let elem = parse_type(p)
            push(node.children, elem)
        }
        expect_token(p, TK_RPAREN())

        // Check for fn type: (T1, T2) -> Ret
        if peek_kind(p) == TK_ARROW() {
            p.pos = p.pos + 1
            let fn_type = AstNode_new(NK_TYPE_FN(), tok_span(t))
            fn_type.children = node.children
            let ret = parse_type(p)
            push(fn_type.type_ann, ret)
            return fn_type
        }
        return node
    }

    // Fallback: error
    error(p, concat(String_from("expected type, got "), to_string(t.kind)))
    AstNode_leaf(NK_TYPE_NAMED(), String_from("_error"), tok_span(t))
}

// ── Pattern Parsing ──────────────────────────────────────────────────────────

fn parse_pattern(p: Parser) -> AstNode {
    skip_newlines(p)
    let t = cur(p)

    // Wildcard: _
    if t.kind == TK_UNDERSCORE() {
        p.pos = p.pos + 1
        return AstNode_leaf(NK_PAT_WILDCARD(), String_from("_"), tok_span(t))
    }

    // Literal patterns
    if t.kind == TK_INT() {
        p.pos = p.pos + 1
        let node = AstNode_int(t.int_val, tok_span(t))
        node.kind = NK_PAT_LITERAL()
        return node
    }
    if t.kind == TK_STRING() {
        p.pos = p.pos + 1
        return AstNode_leaf(NK_PAT_LITERAL(), clone(t.text), tok_span(t))
    }
    if t.kind == TK_BOOL() {
        p.pos = p.pos + 1
        return AstNode_leaf(NK_PAT_LITERAL(), clone(t.text), tok_span(t))
    }

    // Identifier or variant: Name or Name::Variant(fields)
    if t.kind == TK_IDENT() {
        p.pos = p.pos + 1

        // Check for path: Enum::Variant
        if peek_kind(p) == TK_COLONCOLON() {
            p.pos = p.pos + 1
            let variant_tok = expect_token(p, TK_IDENT())
            let node = AstNode_new(NK_PAT_VARIANT(), tok_span(t))
            node.text = concat(clone(t.text), concat(String_from("::"), clone(variant_tok.text)))

            // Check for fields: Variant(x, y)
            if peek_kind(p) == TK_LPAREN() {
                p.pos = p.pos + 1
                let mut first = true
                while !at(p, TK_RPAREN()) && !at_eof(p) {
                    if !first { expect_token(p, TK_COMMA()) }
                    first = false
                    skip_newlines(p)
                    let field_pat = parse_pattern(p)
                    push(node.children, field_pat)
                }
                expect_token(p, TK_RPAREN())
            }
            return node
        }

        // Simple variant without path: Some(x), None, Ok(v), Err(e)
        if peek_kind(p) == TK_LPAREN() {
            let node = AstNode_new(NK_PAT_VARIANT(), tok_span(t))
            node.text = clone(t.text)
            p.pos = p.pos + 1
            let mut first = true
            while !at(p, TK_RPAREN()) && !at_eof(p) {
                if !first { expect_token(p, TK_COMMA()) }
                first = false
                skip_newlines(p)
                let field_pat = parse_pattern(p)
                push(node.children, field_pat)
            }
            expect_token(p, TK_RPAREN())
            return node
        }

        // Plain identifier binding
        return AstNode_leaf(NK_PAT_IDENT(), clone(t.text), tok_span(t))
    }

    error(p, String_from("expected pattern"))
    AstNode_leaf(NK_PAT_WILDCARD(), String_from("_"), tok_span(t))
}

// ── Expression Parsing (Pratt) ──────────────────────────────────────────────

fn parse_expr(p: Parser) -> AstNode {
    parse_expr_bp(p, 0)
}

fn parse_expr_bp(p: Parser, min_bp: i32) -> AstNode {
    skip_newlines(p)
    let mut lhs = parse_prefix(p)

    while true {
        skip_newlines(p)
        let k = peek_kind(p)
        if k == TK_EOF() || k == TK_NEWLINE() || k == TK_RBRACE() || k == TK_RPAREN()
            || k == TK_RBRACKET() || k == TK_COMMA() || k == TK_SEMI()
            || k == TK_FATARROW() || k == TK_LBRACE() || k == TK_COLON() {
            break
        }

        // Assignment: x = expr
        if k == TK_EQ() {
            if min_bp <= 1 {
                p.pos = p.pos + 1
                skip_newlines(p)
                let rhs = parse_expr_bp(p, 1)
                let node = AstNode_new(NK_ASSIGN(), lhs.span)
                push(node.children, lhs)
                push(node.children, rhs)
                lhs = node
                continue
            }
            break
        }

        // Range: a..b
        if k == TK_DOTDOT() {
            if min_bp <= 2 {
                p.pos = p.pos + 1
                let rhs = parse_expr_bp(p, 2)
                let node = AstNode_new(NK_RANGE(), lhs.span)
                push(node.children, lhs)
                push(node.children, rhs)
                lhs = node
                continue
            }
            break
        }

        // Field access: expr.field or method call: expr.method(args)
        if k == TK_DOT() {
            p.pos = p.pos + 1
            skip_newlines(p)
            let field_tok = expect_token(p, TK_IDENT())

            // Method call: expr.method(args)
            if peek_kind(p) == TK_LPAREN() {
                p.pos = p.pos + 1
                let node = AstNode_new(NK_METHOD_CALL(), lhs.span)
                node.text = clone(field_tok.text)
                push(node.children, lhs)
                let mut first = true
                while !at(p, TK_RPAREN()) && !at_eof(p) {
                    if !first { expect_token(p, TK_COMMA()) }
                    first = false
                    skip_newlines(p)
                    let arg = parse_expr(p)
                    push(node.children, arg)
                }
                expect_token(p, TK_RPAREN())
                lhs = node
                continue
            }

            let node = AstNode_new(NK_FIELD_ACCESS(), lhs.span)
            node.text = clone(field_tok.text)
            push(node.children, lhs)
            lhs = node
            continue
        }

        // Index: expr[index]
        if k == TK_LBRACKET() {
            p.pos = p.pos + 1
            let idx = parse_expr(p)
            expect_token(p, TK_RBRACKET())
            let node = AstNode_new(NK_INDEX(), lhs.span)
            push(node.children, lhs)
            push(node.children, idx)
            lhs = node
            continue
        }

        // Call: expr(args)
        if k == TK_LPAREN() {
            p.pos = p.pos + 1
            let node = AstNode_new(NK_CALL(), lhs.span)
            push(node.children, lhs)
            let mut first = true
            while !at(p, TK_RPAREN()) && !at_eof(p) {
                if !first { expect_token(p, TK_COMMA()) }
                first = false
                skip_newlines(p)
                let arg = parse_expr(p)
                push(node.children, arg)
            }
            expect_token(p, TK_RPAREN())
            lhs = node
            continue
        }

        // Path: ident::ident (only valid postfix after call check)
        if k == TK_COLONCOLON() {
            p.pos = p.pos + 1
            let seg = expect_token(p, TK_IDENT())
            let node = AstNode_new(NK_PATH(), lhs.span)
            node.text = concat(lhs.text, concat(String_from("::"), clone(seg.text)))
            push(node.children, lhs)
            lhs = node
            continue
        }

        // Binary operator
        let lbp = infix_bp_left(k)
        if lbp == 0 { break }
        if lbp < min_bp { break }

        let op_tok = bump(p)
        let rbp = infix_bp_right(k)
        let rhs = parse_expr_bp(p, rbp)
        let node = AstNode_new(NK_BINARY(), lhs.span)
        node.op = token_to_binop(k)
        push(node.children, lhs)
        push(node.children, rhs)
        lhs = node
    }
    lhs
}

fn parse_prefix(p: Parser) -> AstNode {
    skip_newlines(p)
    let t = cur(p)

    // Unary operators
    let ubp = prefix_bp(t.kind)
    if ubp > 0 {
        p.pos = p.pos + 1
        let operand = parse_expr_bp(p, ubp)
        let node = AstNode_new(NK_UNARY(), tok_span(t))
        node.op = token_to_unop(t.kind)
        push(node.children, operand)
        return node
    }

    // Literals
    if t.kind == TK_INT() {
        p.pos = p.pos + 1
        return AstNode_int(t.int_val, tok_span(t))
    }
    if t.kind == TK_FLOAT() {
        p.pos = p.pos + 1
        return AstNode_float(t.float_val, tok_span(t))
    }
    if t.kind == TK_STRING() {
        p.pos = p.pos + 1
        return AstNode_leaf(NK_STRING_LIT(), clone(t.text), tok_span(t))
    }
    if t.kind == TK_BOOL() {
        p.pos = p.pos + 1
        return AstNode_leaf(NK_BOOL_LIT(), clone(t.text), tok_span(t))
    }

    // Identifier
    if t.kind == TK_IDENT() {
        p.pos = p.pos + 1

        // Struct literal: Name { field: val, ... }
        if peek_kind(p) == TK_LBRACE() {
            // Lookahead: if next after { is ident followed by :, it's a struct literal
            let save = p.pos
            p.pos = p.pos + 1  // skip {
            skip_newlines(p)
            let maybe_field = cur(p)
            let mut is_struct_lit = false
            if maybe_field.kind == TK_IDENT() {
                let save2 = p.pos
                p.pos = p.pos + 1
                skip_newlines(p)
                if peek_kind(p) == TK_COLON() {
                    is_struct_lit = true
                }
                p.pos = save2
            }
            if maybe_field.kind == TK_RBRACE() {
                is_struct_lit = true
            }
            p.pos = save

            if is_struct_lit {
                p.pos = p.pos + 1  // skip {
                let node = AstNode_new(NK_STRUCT_LIT(), tok_span(t))
                node.text = clone(t.text)
                let mut first = true
                while !at(p, TK_RBRACE()) && !at_eof(p) {
                    skip_newlines(p)
                    if at(p, TK_RBRACE()) { break }
                    if !first { expect_token(p, TK_COMMA()) }
                    first = false
                    skip_newlines(p)
                    let fname = expect_token(p, TK_IDENT())
                    expect_token(p, TK_COLON())
                    skip_newlines(p)
                    let fval = parse_expr(p)
                    let field = AstNode_new(NK_IDENT(), tok_span(fname))
                    field.text = clone(fname.text)
                    push(field.children, fval)
                    push(node.children, field)
                }
                skip_newlines(p)
                expect_token(p, TK_RBRACE())
                return node
            }
        }

        return AstNode_leaf(NK_IDENT(), clone(t.text), tok_span(t))
    }

    // Grouped expression: (expr) or tuple: (a, b)
    if t.kind == TK_LPAREN() {
        p.pos = p.pos + 1
        skip_newlines(p)
        if at(p, TK_RPAREN()) {
            p.pos = p.pos + 1
            return AstNode_new(NK_TUPLE(), tok_span(t))
        }
        let first_expr = parse_expr(p)
        skip_newlines(p)
        if at(p, TK_COMMA()) {
            // Tuple
            let node = AstNode_new(NK_TUPLE(), tok_span(t))
            push(node.children, first_expr)
            while at(p, TK_COMMA()) {
                p.pos = p.pos + 1
                skip_newlines(p)
                if at(p, TK_RPAREN()) { break }
                let elem = parse_expr(p)
                push(node.children, elem)
                skip_newlines(p)
            }
            expect_token(p, TK_RPAREN())
            return node
        }
        expect_token(p, TK_RPAREN())
        return first_expr
    }

    // Array literal: [a, b, c]
    if t.kind == TK_LBRACKET() {
        p.pos = p.pos + 1
        let node = AstNode_new(NK_ARRAY_LIT(), tok_span(t))
        let mut first = true
        while !at(p, TK_RBRACKET()) && !at_eof(p) {
            if !first { expect_token(p, TK_COMMA()) }
            first = false
            skip_newlines(p)
            let elem = parse_expr(p)
            push(node.children, elem)
            skip_newlines(p)
        }
        expect_token(p, TK_RBRACKET())
        return node
    }

    // If expression
    if t.kind == TK_IF() {
        return parse_if_expr(p)
    }

    // Match expression
    if t.kind == TK_MATCH() {
        return parse_match_expr(p)
    }

    // Block expression
    if t.kind == TK_LBRACE() {
        return parse_block(p)
    }

    error(p, concat(String_from("unexpected token in expression: "), to_string(t.kind)))
    p.pos = p.pos + 1
    AstNode_leaf(NK_IDENT(), String_from("_error"), tok_span(t))
}

// ── If Expression ────────────────────────────────────────────────────────────

fn parse_if_expr(p: Parser) -> AstNode {
    let t = expect_token(p, TK_IF())
    let node = AstNode_new(NK_IF_EXPR(), tok_span(t))
    skip_newlines(p)
    let cond = parse_expr(p)
    push(node.children, cond)
    skip_newlines(p)
    let then_block = parse_block(p)
    push(node.children, then_block)
    skip_newlines(p)
    if peek_kind(p) == TK_ELSE() {
        p.pos = p.pos + 1
        skip_newlines(p)
        if peek_kind(p) == TK_IF() {
            let elif = parse_if_expr(p)
            push(node.children, elif)
        } else {
            let else_block = parse_block(p)
            push(node.children, else_block)
        }
    }
    node
}

// ── Match Expression ─────────────────────────────────────────────────────────

fn parse_match_expr(p: Parser) -> AstNode {
    let t = expect_token(p, TK_MATCH())
    let node = AstNode_new(NK_MATCH_EXPR(), tok_span(t))
    skip_newlines(p)
    let scrutinee = parse_expr(p)
    push(node.children, scrutinee)
    skip_newlines(p)
    expect_token(p, TK_LBRACE())
    skip_newlines(p)
    while !at(p, TK_RBRACE()) && !at_eof(p) {
        skip_newlines(p)
        if at(p, TK_RBRACE()) { break }
        let pat = parse_pattern(p)
        skip_newlines(p)
        expect_token(p, TK_FATARROW())
        skip_newlines(p)
        let body = parse_expr_or_block(p)
        // Match arm: pattern => body stored as pair in children
        let arm = AstNode_new(NK_TUPLE(), pat.span)
        push(arm.children, pat)
        push(arm.children, body)
        push(node.children, arm)
        skip_newlines(p)
        // Optional comma between arms
        if peek_kind(p) == TK_COMMA() { p.pos = p.pos + 1 }
        skip_newlines(p)
    }
    expect_token(p, TK_RBRACE())
    node
}

fn parse_expr_or_block(p: Parser) -> AstNode {
    skip_newlines(p)
    if peek_kind(p) == TK_LBRACE() {
        return parse_block(p)
    }
    parse_expr(p)
}

// ── Block ────────────────────────────────────────────────────────────────────

fn parse_block(p: Parser) -> AstNode {
    let t = expect_token(p, TK_LBRACE())
    let node = AstNode_new(NK_BLOCK(), tok_span(t))
    skip_newlines(p)
    while !at(p, TK_RBRACE()) && !at_eof(p) {
        skip_newlines(p)
        if at(p, TK_RBRACE()) { break }
        let stmt = parse_stmt(p)
        push(node.children, stmt)
        skip_newlines(p)
    }
    expect_token(p, TK_RBRACE())
    node
}

// ── Statement Parsing ────────────────────────────────────────────────────────

fn parse_stmt(p: Parser) -> AstNode {
    skip_newlines(p)
    let k = peek_kind(p)

    if k == TK_LET() { return parse_let(p) }
    if k == TK_RETURN() { return parse_return(p) }
    if k == TK_BREAK() { return parse_break(p) }
    if k == TK_CONTINUE() { return parse_continue(p) }
    if k == TK_WHILE() { return parse_while(p) }
    if k == TK_LOOP() { return parse_loop(p) }
    if k == TK_FOR() { return parse_for(p) }

    // Expression statement
    let expr = parse_expr(p)
    let node = AstNode_new(NK_EXPR_STMT(), expr.span)
    push(node.children, expr)
    node
}

fn parse_let(p: Parser) -> AstNode {
    let t = expect_token(p, TK_LET())
    let node = AstNode_new(NK_LET(), tok_span(t))
    skip_newlines(p)

    // mut keyword
    if peek_kind(p) == TK_MUT() {
        p.pos = p.pos + 1
        node.is_mut = true
    }

    let name = expect_token(p, TK_IDENT())
    node.text = clone(name.text)

    // Optional type annotation: : Type
    if peek_kind(p) == TK_COLON() {
        p.pos = p.pos + 1
        skip_newlines(p)
        let ty = parse_type(p)
        push(node.type_ann, ty)
    }

    // Initializer: = expr
    if peek_kind(p) == TK_EQ() {
        p.pos = p.pos + 1
        skip_newlines(p)
        let init = parse_expr(p)
        push(node.children, init)
    }

    node
}

fn parse_return(p: Parser) -> AstNode {
    let t = expect_token(p, TK_RETURN())
    let node = AstNode_new(NK_RETURN(), tok_span(t))
    skip_newlines(p)
    let k = peek_kind(p)
    if k != TK_NEWLINE() && k != TK_RBRACE() && k != TK_EOF() {
        let val = parse_expr(p)
        push(node.children, val)
    }
    node
}

fn parse_break(p: Parser) -> AstNode {
    let t = expect_token(p, TK_BREAK())
    AstNode_new(NK_BREAK(), tok_span(t))
}

fn parse_continue(p: Parser) -> AstNode {
    let t = expect_token(p, TK_CONTINUE())
    AstNode_new(NK_CONTINUE(), tok_span(t))
}

fn parse_while(p: Parser) -> AstNode {
    let t = expect_token(p, TK_WHILE())
    let node = AstNode_new(NK_WHILE(), tok_span(t))
    skip_newlines(p)
    let cond = parse_expr(p)
    push(node.children, cond)
    skip_newlines(p)
    let body = parse_block(p)
    push(node.children, body)
    node
}

fn parse_loop(p: Parser) -> AstNode {
    let t = expect_token(p, TK_LOOP())
    let node = AstNode_new(NK_LOOP(), tok_span(t))
    skip_newlines(p)
    let body = parse_block(p)
    push(node.children, body)
    node
}

fn parse_for(p: Parser) -> AstNode {
    let t = expect_token(p, TK_FOR())
    let node = AstNode_new(NK_FOR(), tok_span(t))
    skip_newlines(p)
    let binding = expect_token(p, TK_IDENT())
    node.text = clone(binding.text)
    expect_token(p, TK_IN())
    skip_newlines(p)
    let iter = parse_expr(p)
    push(node.children, iter)
    skip_newlines(p)
    let body = parse_block(p)
    push(node.children, body)
    node
}

// ── Declaration Parsing ──────────────────────────────────────────────────────

fn parse_decl(p: Parser) -> AstNode {
    skip_newlines(p)
    let k = peek_kind(p)

    let mut is_pub = false
    if k == TK_PUB() {
        is_pub = true
        p.pos = p.pos + 1
        skip_newlines(p)
    }

    let k2 = peek_kind(p)
    if k2 == TK_FN() { let d = parse_fn_decl(p); d.is_pub = is_pub; return d }
    if k2 == TK_STRUCT() { let d = parse_struct_decl(p); d.is_pub = is_pub; return d }
    if k2 == TK_ENUM() { let d = parse_enum_decl(p); d.is_pub = is_pub; return d }
    if k2 == TK_TRAIT() { let d = parse_trait_decl(p); d.is_pub = is_pub; return d }
    if k2 == TK_IMPL() { let d = parse_impl_decl(p); d.is_pub = is_pub; return d }
    if k2 == TK_USE() { return parse_use_decl(p) }
    if k2 == TK_IMPORT() { return parse_import_decl(p) }

    // Fall through to statement
    parse_stmt(p)
}

fn parse_fn_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_FN())
    let node = AstNode_new(NK_FN_DECL(), tok_span(t))
    let name = expect_token(p, TK_IDENT())
    node.text = clone(name.text)

    // Generic params: <T, U>
    if peek_kind(p) == TK_LT() {
        p.pos = p.pos + 1
        let mut first = true
        while !at(p, TK_GT()) && !at_eof(p) {
            if !first { expect_token(p, TK_COMMA()) }
            first = false
            skip_newlines(p)
            let gp = expect_token(p, TK_IDENT())
            let gpn = AstNode_leaf(NK_TYPE_NAMED(), clone(gp.text), tok_span(gp))
            push(node.type_ann, gpn)
        }
        expect_token(p, TK_GT())
    }

    // Parameters
    expect_token(p, TK_LPAREN())
    let mut first = true
    while !at(p, TK_RPAREN()) && !at_eof(p) {
        if !first { expect_token(p, TK_COMMA()) }
        first = false
        skip_newlines(p)
        let pname = expect_token(p, TK_IDENT())
        let param = AstNode_leaf(NK_IDENT(), clone(pname.text), tok_span(pname))
        expect_token(p, TK_COLON())
        skip_newlines(p)
        let pty = parse_type(p)
        push(param.type_ann, pty)
        push(node.children, param)
        skip_newlines(p)
    }
    expect_token(p, TK_RPAREN())

    // Return type
    if peek_kind(p) == TK_ARROW() {
        p.pos = p.pos + 1
        skip_newlines(p)
        let ret = parse_type(p)
        // Store return type at int_val=1 marker position and add to type_ann
        let ret_node = AstNode_new(NK_TYPE_NAMED(), ret.span)
        ret_node.text = String_from("__return")
        push(ret_node.children, ret)
        push(node.type_ann, ret_node)
    }

    // Body
    skip_newlines(p)
    let body = parse_block(p)
    push(node.children, body)
    node
}

fn parse_struct_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_STRUCT())
    let node = AstNode_new(NK_STRUCT_DECL(), tok_span(t))
    let name = expect_token(p, TK_IDENT())
    node.text = clone(name.text)

    // Generic params
    if peek_kind(p) == TK_LT() {
        p.pos = p.pos + 1
        let mut first = true
        while !at(p, TK_GT()) && !at_eof(p) {
            if !first { expect_token(p, TK_COMMA()) }
            first = false
            skip_newlines(p)
            let gp = expect_token(p, TK_IDENT())
            let gpn = AstNode_leaf(NK_TYPE_NAMED(), clone(gp.text), tok_span(gp))
            push(node.type_ann, gpn)
        }
        expect_token(p, TK_GT())
    }

    skip_newlines(p)
    expect_token(p, TK_LBRACE())
    skip_newlines(p)
    let mut first = true
    while !at(p, TK_RBRACE()) && !at_eof(p) {
        skip_newlines(p)
        if at(p, TK_RBRACE()) { break }
        if !first { expect_token(p, TK_COMMA()) }
        first = false
        skip_newlines(p)
        let fname = expect_token(p, TK_IDENT())
        expect_token(p, TK_COLON())
        skip_newlines(p)
        let fty = parse_type(p)
        let field = AstNode_leaf(NK_IDENT(), clone(fname.text), tok_span(fname))
        push(field.type_ann, fty)
        push(node.children, field)
        skip_newlines(p)
    }
    expect_token(p, TK_RBRACE())
    node
}

fn parse_enum_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_ENUM())
    let node = AstNode_new(NK_ENUM_DECL(), tok_span(t))
    let name = expect_token(p, TK_IDENT())
    node.text = clone(name.text)

    // Generic params
    if peek_kind(p) == TK_LT() {
        p.pos = p.pos + 1
        let mut first = true
        while !at(p, TK_GT()) && !at_eof(p) {
            if !first { expect_token(p, TK_COMMA()) }
            first = false
            skip_newlines(p)
            let gp = expect_token(p, TK_IDENT())
            let gpn = AstNode_leaf(NK_TYPE_NAMED(), clone(gp.text), tok_span(gp))
            push(node.type_ann, gpn)
        }
        expect_token(p, TK_GT())
    }

    skip_newlines(p)
    expect_token(p, TK_LBRACE())
    skip_newlines(p)
    while !at(p, TK_RBRACE()) && !at_eof(p) {
        skip_newlines(p)
        if at(p, TK_RBRACE()) { break }
        let vname = expect_token(p, TK_IDENT())
        let variant = AstNode_leaf(NK_IDENT(), clone(vname.text), tok_span(vname))

        // Variant fields: Variant(Type1, Type2)
        if peek_kind(p) == TK_LPAREN() {
            p.pos = p.pos + 1
            let mut first = true
            while !at(p, TK_RPAREN()) && !at_eof(p) {
                if !first { expect_token(p, TK_COMMA()) }
                first = false
                skip_newlines(p)
                let vty = parse_type(p)
                push(variant.type_ann, vty)
            }
            expect_token(p, TK_RPAREN())
        }

        push(node.children, variant)
        skip_newlines(p)
        if peek_kind(p) == TK_COMMA() { p.pos = p.pos + 1 }
        skip_newlines(p)
    }
    expect_token(p, TK_RBRACE())
    node
}

fn parse_trait_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_TRAIT())
    let node = AstNode_new(NK_TRAIT_DECL(), tok_span(t))
    let name = expect_token(p, TK_IDENT())
    node.text = clone(name.text)
    skip_newlines(p)
    expect_token(p, TK_LBRACE())
    skip_newlines(p)
    while !at(p, TK_RBRACE()) && !at_eof(p) {
        skip_newlines(p)
        if at(p, TK_RBRACE()) { break }
        let member = parse_fn_decl(p)
        push(node.children, member)
        skip_newlines(p)
    }
    expect_token(p, TK_RBRACE())
    node
}

fn parse_impl_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_IMPL())
    let node = AstNode_new(NK_IMPL_DECL(), tok_span(t))
    let name = expect_token(p, TK_IDENT())
    node.text = clone(name.text)
    skip_newlines(p)
    expect_token(p, TK_LBRACE())
    skip_newlines(p)
    while !at(p, TK_RBRACE()) && !at_eof(p) {
        skip_newlines(p)
        if at(p, TK_RBRACE()) { break }
        let member = parse_fn_decl(p)
        push(node.children, member)
        skip_newlines(p)
    }
    expect_token(p, TK_RBRACE())
    node
}

fn parse_use_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_USE())
    let node = AstNode_new(NK_USE(), tok_span(t))
    skip_newlines(p)
    // use std::host::module
    let mut path = String_new()
    let first_seg = expect_token(p, TK_IDENT())
    path = clone(first_seg.text)
    while peek_kind(p) == TK_COLONCOLON() {
        p.pos = p.pos + 1
        let seg = expect_token(p, TK_IDENT())
        path = concat(path, concat(String_from("::"), clone(seg.text)))
    }
    node.text = path
    node
}

fn parse_import_decl(p: Parser) -> AstNode {
    let t = expect_token(p, TK_IMPORT())
    let node = AstNode_new(NK_IMPORT(), tok_span(t))
    skip_newlines(p)
    let path_tok = expect_token(p, TK_STRING())
    node.text = clone(path_tok.text)
    node
}

// ── Top-level Module ─────────────────────────────────────────────────────────

fn parse_module(p: Parser) -> Vec<AstNode> {
    let mut decls: Vec<AstNode> = Vec_new_AstNode()
    skip_newlines(p)
    while !at_eof(p) {
        skip_newlines(p)
        if at_eof(p) { break }
        let d = parse_decl(p)
        push(decls, d)
        skip_newlines(p)
    }
    decls
}

// ── AST Display Helpers ──────────────────────────────────────────────────────

fn node_kind_name(kind: i32) -> String {
    if kind == NK_INT_LIT() { return String_from("IntLit") }
    if kind == NK_FLOAT_LIT() { return String_from("FloatLit") }
    if kind == NK_STRING_LIT() { return String_from("StringLit") }
    if kind == NK_BOOL_LIT() { return String_from("BoolLit") }
    if kind == NK_IDENT() { return String_from("Ident") }
    if kind == NK_BINARY() { return String_from("Binary") }
    if kind == NK_UNARY() { return String_from("Unary") }
    if kind == NK_CALL() { return String_from("Call") }
    if kind == NK_FIELD_ACCESS() { return String_from("FieldAccess") }
    if kind == NK_INDEX() { return String_from("Index") }
    if kind == NK_STRUCT_LIT() { return String_from("StructLit") }
    if kind == NK_ARRAY_LIT() { return String_from("ArrayLit") }
    if kind == NK_IF_EXPR() { return String_from("If") }
    if kind == NK_MATCH_EXPR() { return String_from("Match") }
    if kind == NK_CLOSURE() { return String_from("Closure") }
    if kind == NK_PATH() { return String_from("Path") }
    if kind == NK_TUPLE() { return String_from("Tuple") }
    if kind == NK_ASSIGN() { return String_from("Assign") }
    if kind == NK_RANGE() { return String_from("Range") }
    if kind == NK_BLOCK() { return String_from("Block") }
    if kind == NK_METHOD_CALL() { return String_from("MethodCall") }
    if kind == NK_LET() { return String_from("Let") }
    if kind == NK_RETURN() { return String_from("Return") }
    if kind == NK_WHILE() { return String_from("While") }
    if kind == NK_LOOP() { return String_from("Loop") }
    if kind == NK_FOR() { return String_from("For") }
    if kind == NK_EXPR_STMT() { return String_from("ExprStmt") }
    if kind == NK_FN_DECL() { return String_from("FnDecl") }
    if kind == NK_STRUCT_DECL() { return String_from("StructDecl") }
    if kind == NK_ENUM_DECL() { return String_from("EnumDecl") }
    if kind == NK_IMPORT() { return String_from("Import") }
    if kind == NK_USE() { return String_from("Use") }
    if kind == NK_TRAIT_DECL() { return String_from("TraitDecl") }
    if kind == NK_IMPL_DECL() { return String_from("ImplDecl") }
    if kind == NK_PAT_IDENT() { return String_from("PatIdent") }
    if kind == NK_PAT_WILDCARD() { return String_from("PatWild") }
    if kind == NK_PAT_LITERAL() { return String_from("PatLit") }
    if kind == NK_PAT_VARIANT() { return String_from("PatVariant") }
    if kind == NK_TYPE_NAMED() { return String_from("TypeNamed") }
    if kind == NK_TYPE_GENERIC() { return String_from("TypeGeneric") }
    if kind == NK_TYPE_FN() { return String_from("TypeFn") }
    if kind == NK_TYPE_TUPLE() { return String_from("TypeTuple") }
    String_from("Unknown")
}

fn print_ast(node: AstNode, depth: i32) {
    let mut indent = String_new()
    let mut d = 0
    while d < depth {
        indent = concat(indent, String_from("  "))
        d = d + 1
    }
    let kind_str = node_kind_name(node.kind)
    let mut line = concat(indent, kind_str)
    if len(node.text) > 0 {
        line = concat(line, concat(String_from("("), concat(clone(node.text), String_from(")"))))
    }
    if node.kind == NK_INT_LIT() {
        line = concat(line, concat(String_from("("), concat(to_string(node.int_val), String_from(")"))))
    }
    stdio::println(line)
    let mut i = 0
    let child_count = len(node.children)
    while i < child_count {
        let child = get_unchecked(node.children, i)
        print_ast(child, depth + 1)
        i = i + 1
    }
}

// Arukellt Selfhost — Resolver (Name Binding and Imports)
//
// Walks the AST and builds a scope chain, binding each identifier
// to its declaration. Reports undefined and duplicate names.


// ── Symbol Tags ──────────────────────────────────────────────────────────────

fn SYM_LOCAL() -> i32 { 1 }
fn SYM_PARAM() -> i32 { 2 }
fn SYM_FN() -> i32 { 3 }
fn SYM_STRUCT() -> i32 { 4 }
fn SYM_ENUM() -> i32 { 5 }
fn SYM_VARIANT() -> i32 { 6 }
fn SYM_IMPORT() -> i32 { 7 }
fn SYM_BUILTIN() -> i32 { 8 }
fn SYM_MODULE() -> i32 { 9 }

// ── Symbol ───────────────────────────────────────────────────────────────────

struct Symbol {
    name: String,
    kind: i32,
    scope_depth: i32,
    decl_index: i32,
    is_mut: bool,
}

fn Symbol_new(name: String, kind: i32, depth: i32, index: i32) -> Symbol {
    Symbol { name: name, kind: kind, scope_depth: depth, decl_index: index, is_mut: false }
}

// ── Scope ────────────────────────────────────────────────────────────────────

struct Scope {
    symbols: Vec<Symbol>,
    parent_depth: i32,
}

fn Scope_new(parent: i32) -> Scope {
    Scope { symbols: Vec_new_Symbol(), parent_depth: parent }
}

// ── Resolve Context ──────────────────────────────────────────────────────────

struct ResolveCtx {
    scopes: Vec<Scope>,
    current_depth: i32,
    error_count: i32,
    errors: Vec<String>,
    next_decl_index: i32,
}

fn ResolveCtx_new() -> ResolveCtx {
    let mut ctx = ResolveCtx {
        scopes: Vec_new_Scope(),
        current_depth: 0,
        error_count: 0,
        errors: Vec_new_String(),
        next_decl_index: 0,
    }
    // Push global scope
    push(ctx.scopes, Scope_new(0 - 1))
    // Register builtins
    register_builtins(ctx)
    ctx
}

fn push_scope(ctx: ResolveCtx) {
    ctx.current_depth = ctx.current_depth + 1
    push(ctx.scopes, Scope_new(ctx.current_depth - 1))
}

fn pop_scope(ctx: ResolveCtx) {
    ctx.current_depth = ctx.current_depth - 1
}

fn define(ctx: ResolveCtx, name: String, kind: i32) {
    let idx = ctx.next_decl_index
    ctx.next_decl_index = ctx.next_decl_index + 1
    let sym = Symbol_new(clone(name), kind, ctx.current_depth, idx)
    // Add to current scope
    let scope = get_unchecked(ctx.scopes, ctx.current_depth)
    // Check for duplicates at current depth
    let sym_count = len(scope.symbols)
    let mut i = 0
    while i < sym_count {
        let existing = get_unchecked(scope.symbols, i)
        if eq(clone(existing.name), clone(name)) && existing.scope_depth == ctx.current_depth {
            resolve_error(ctx, concat(String_from("duplicate definition: "), clone(name)))
            return
        }
        i = i + 1
    }
    push(scope.symbols, sym)
}

fn lookup(ctx: ResolveCtx, name: String) -> i32 {
    // Search from current scope to global
    let mut depth = ctx.current_depth
    while depth >= 0 {
        let scope = get_unchecked(ctx.scopes, depth)
        let sym_count = len(scope.symbols)
        let mut i = sym_count - 1
        while i >= 0 {
            let sym = get_unchecked(scope.symbols, i)
            if eq(clone(sym.name), clone(name)) {
                return sym.decl_index
            }
            i = i - 1
        }
        depth = depth - 1
    }
    0 - 1  // not found
}

fn resolve_error(ctx: ResolveCtx, msg: String) {
    ctx.error_count = ctx.error_count + 1
    push(ctx.errors, msg)
}

// ── Builtin Registration ─────────────────────────────────────────────────────

fn register_builtins(ctx: ResolveCtx) {
    define(ctx, String_from("println"), SYM_BUILTIN())
    define(ctx, String_from("print"), SYM_BUILTIN())
    define(ctx, String_from("to_string"), SYM_BUILTIN())
    define(ctx, String_from("len"), SYM_BUILTIN())
    define(ctx, String_from("push"), SYM_BUILTIN())
    define(ctx, String_from("get"), SYM_BUILTIN())
    define(ctx, String_from("get_unchecked"), SYM_BUILTIN())
    define(ctx, String_from("concat"), SYM_BUILTIN())
    define(ctx, String_from("substring"), SYM_BUILTIN())
    define(ctx, String_from("clone"), SYM_BUILTIN())
    define(ctx, String_from("eq"), SYM_BUILTIN())
    define(ctx, String_from("char_at"), SYM_BUILTIN())
    define(ctx, String_from("String_from"), SYM_BUILTIN())
    define(ctx, String_from("String_new"), SYM_BUILTIN())
    define(ctx, String_from("Vec_new_i32"), SYM_BUILTIN())
    define(ctx, String_from("Vec_new_String"), SYM_BUILTIN())
    define(ctx, String_from("parse_f64"), SYM_BUILTIN())
    define(ctx, String_from("parse_i32"), SYM_BUILTIN())
    define(ctx, String_from("i32_to_string"), SYM_BUILTIN())
    define(ctx, String_from("i64_to_string"), SYM_BUILTIN())
    define(ctx, String_from("f64_to_string"), SYM_BUILTIN())
    define(ctx, String_from("bool_to_string"), SYM_BUILTIN())
    define(ctx, String_from("char_to_string"), SYM_BUILTIN())
    define(ctx, String_from("args"), SYM_BUILTIN())
    define(ctx, String_from("exit"), SYM_BUILTIN())
    // Modules
    define(ctx, String_from("stdio"), SYM_MODULE())
    define(ctx, String_from("fs"), SYM_MODULE())
}

// ── Resolve Module ───────────────────────────────────────────────────────────

fn resolve_module(decls: Vec<AstNode>) -> ResolveCtx {
    let ctx = ResolveCtx_new()
    let count = len(decls)

    // First pass: register all top-level names
    let mut i = 0
    while i < count {
        let d = get_unchecked(decls, i)
        if d.kind == NK_FN_DECL() {
            define(ctx, clone(d.text), SYM_FN())
        } else if d.kind == NK_STRUCT_DECL() {
            define(ctx, clone(d.text), SYM_STRUCT())
        } else if d.kind == NK_ENUM_DECL() {
            define(ctx, clone(d.text), SYM_ENUM())
        } else if d.kind == NK_USE() {
            define(ctx, clone(d.text), SYM_IMPORT())
        }
        i = i + 1
    }

    // Second pass: resolve bodies
    let mut j = 0
    while j < count {
        let d = get_unchecked(decls, j)
        if d.kind == NK_FN_DECL() {
            resolve_fn(ctx, d)
        } else if d.kind == NK_ENUM_DECL() {
            resolve_enum(ctx, d)
        }
        j = j + 1
    }

    ctx
}

fn resolve_fn(ctx: ResolveCtx, node: AstNode) {
    push_scope(ctx)

    // Register parameters
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count - 1 {
        let param = get_unchecked(node.children, i)
        if param.kind == NK_IDENT() {
            define(ctx, clone(param.text), SYM_PARAM())
        }
        i = i + 1
    }

    // Resolve body (last child is block)
    if child_count > 0 {
        let body = get_unchecked(node.children, child_count - 1)
        resolve_node(ctx, body)
    }

    pop_scope(ctx)
}

fn resolve_enum(ctx: ResolveCtx, node: AstNode) {
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let variant = get_unchecked(node.children, i)
        let full_name = concat(clone(node.text), concat(String_from("::"), clone(variant.text)))
        define(ctx, full_name, SYM_VARIANT())
        i = i + 1
    }
}

fn resolve_node(ctx: ResolveCtx, node: AstNode) {
    if node.kind == NK_IDENT() {
        let idx = lookup(ctx, clone(node.text))
        if idx < 0 {
            resolve_error(ctx, concat(String_from("undefined name: "), clone(node.text)))
        }
        return
    }

    if node.kind == NK_LET() {
        // Resolve initializer before defining the binding
        let child_count = len(node.children)
        if child_count > 0 {
            let init = get_unchecked(node.children, 0)
            resolve_node(ctx, init)
        }
        define(ctx, clone(node.text), SYM_LOCAL())
        return
    }

    if node.kind == NK_BLOCK() {
        push_scope(ctx)
        let child_count = len(node.children)
        let mut i = 0
        while i < child_count {
            let child = get_unchecked(node.children, i)
            resolve_node(ctx, child)
            i = i + 1
        }
        pop_scope(ctx)
        return
    }

    if node.kind == NK_FOR() {
        push_scope(ctx)
        // Resolve iterator
        if len(node.children) > 0 {
            let iter = get_unchecked(node.children, 0)
            resolve_node(ctx, iter)
        }
        // Define loop variable
        define(ctx, clone(node.text), SYM_LOCAL())
        // Resolve body
        if len(node.children) > 1 {
            let body = get_unchecked(node.children, 1)
            resolve_node(ctx, body)
        }
        pop_scope(ctx)
        return
    }

    // Default: recurse into children
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let child = get_unchecked(node.children, i)
        resolve_node(ctx, child)
        i = i + 1
    }
}

// ── Dump ─────────────────────────────────────────────────────────────────────

fn dump_scope(ctx: ResolveCtx) {
    let scope_count = len(ctx.scopes)
    let mut i = 0
    while i < scope_count {
        let scope = get_unchecked(ctx.scopes, i)
        let sym_count = len(scope.symbols)
        stdio::eprintln(concat(String_from("scope["), concat(to_string(i), concat(String_from("] ("), concat(to_string(sym_count), String_from(" symbols)"))))))
        let mut j = 0
        while j < sym_count {
            let sym = get_unchecked(scope.symbols, j)
            let kind_str = sym_kind_name(sym.kind)
            stdio::eprintln(concat(String_from("  "), concat(kind_str, concat(String_from(" "), clone(sym.name)))))
            j = j + 1
        }
        i = i + 1
    }
    if ctx.error_count > 0 {
        stdio::eprintln(concat(to_string(ctx.error_count), String_from(" resolve error(s)")))
    }
}

fn sym_kind_name(kind: i32) -> String {
    if kind == SYM_LOCAL() { return String_from("local") }
    if kind == SYM_PARAM() { return String_from("param") }
    if kind == SYM_FN() { return String_from("fn") }
    if kind == SYM_STRUCT() { return String_from("struct") }
    if kind == SYM_ENUM() { return String_from("enum") }
    if kind == SYM_VARIANT() { return String_from("variant") }
    if kind == SYM_IMPORT() { return String_from("import") }
    if kind == SYM_BUILTIN() { return String_from("builtin") }
    if kind == SYM_MODULE() { return String_from("module") }
    String_from("unknown")
}

// Arukellt Selfhost — Type Checker
//
// Performs type inference, unification, and generates typed HIR.
// Uses a substitution-based unification approach.


// ── Type Tags (from hir.ark) ─────────────────────────────────────────────────

fn TY_UNKNOWN() -> i32 { 0 }
fn TY_I32() -> i32 { 1 }
fn TY_I64() -> i32 { 2 }
fn TY_F64() -> i32 { 3 }
fn TY_BOOL() -> i32 { 4 }
fn TY_STRING() -> i32 { 5 }
fn TY_CHAR() -> i32 { 6 }
fn TY_UNIT() -> i32 { 7 }
fn TY_NEVER() -> i32 { 8 }
fn TY_VEC() -> i32 { 10 }
fn TY_OPTION() -> i32 { 11 }
fn TY_RESULT() -> i32 { 12 }
fn TY_FN() -> i32 { 20 }
fn TY_STRUCT() -> i32 { 21 }
fn TY_ENUM() -> i32 { 22 }
fn TY_TUPLE() -> i32 { 23 }
fn TY_TYPE_VAR() -> i32 { 30 }

// ── Type Representation ──────────────────────────────────────────────────────

struct TypeInfo {
    tag: i32,
    name: String,
    type_args: Vec<TypeInfo>,
}

fn TypeInfo_simple(tag: i32) -> TypeInfo {
    TypeInfo { tag: tag, name: String_new(), type_args: Vec_new_TypeInfo() }
}

fn TypeInfo_named(tag: i32, name: String) -> TypeInfo {
    TypeInfo { tag: tag, name: name, type_args: Vec_new_TypeInfo() }
}

// ── Type Variable / Substitution ─────────────────────────────────────────────

struct TypeVar {
    id: i32,
    bound: TypeInfo,
    is_bound: bool,
}

struct TypeEnv {
    vars: Vec<TypeVar>,
    next_id: i32,
    errors: Vec<String>,
    error_count: i32,
}

fn TypeEnv_new() -> TypeEnv {
    TypeEnv {
        vars: Vec_new_TypeVar(),
        next_id: 0,
        errors: Vec_new_String(),
        error_count: 0,
    }
}

fn fresh_var(env: TypeEnv) -> TypeInfo {
    let id = env.next_id
    env.next_id = env.next_id + 1
    let tv = TypeVar { id: id, bound: TypeInfo_simple(TY_UNKNOWN()), is_bound: false }
    push(env.vars, tv)
    let t = TypeInfo_simple(TY_TYPE_VAR())
    t.name = concat(String_from("t"), to_string(id))
    t
}

fn type_error(env: TypeEnv, msg: String) {
    env.error_count = env.error_count + 1
    push(env.errors, msg)
}

// ── Unification ──────────────────────────────────────────────────────────────

fn unify(env: TypeEnv, a: TypeInfo, b: TypeInfo) -> TypeInfo {
    // If either is unknown, take the other
    if a.tag == TY_UNKNOWN() { return b }
    if b.tag == TY_UNKNOWN() { return a }

    // If both are type vars, bind one to the other
    if a.tag == TY_TYPE_VAR() {
        bind_var(env, clone(a.name), b)
        return b
    }
    if b.tag == TY_TYPE_VAR() {
        bind_var(env, clone(b.name), a)
        return a
    }

    // Same concrete type
    if a.tag == b.tag {
        if a.tag == TY_STRUCT() || a.tag == TY_ENUM() {
            if !eq(clone(a.name), clone(b.name)) {
                type_error(env, concat(String_from("type mismatch: "), concat(clone(a.name), concat(String_from(" vs "), clone(b.name)))))
            }
        }
        return a
    }

    // Numeric coercion: i32 and i64 mismatch is error
    type_error(env, concat(String_from("type mismatch: "), concat(type_tag_name(a.tag), concat(String_from(" vs "), type_tag_name(b.tag)))))
    a
}

fn bind_var(env: TypeEnv, var_name: String, ty: TypeInfo) {
    let count = len(env.vars)
    let mut i = 0
    while i < count {
        let tv = get_unchecked(env.vars, i)
        if eq(clone(tv.bound.name), clone(var_name)) || eq(concat(String_from("t"), to_string(tv.id)), clone(var_name)) {
            tv.bound = ty
            tv.is_bound = true
            return
        }
        i = i + 1
    }
}

fn resolve_type(env: TypeEnv, ty: TypeInfo) -> TypeInfo {
    if ty.tag != TY_TYPE_VAR() { return ty }
    let count = len(env.vars)
    let mut i = 0
    while i < count {
        let tv = get_unchecked(env.vars, i)
        if eq(concat(String_from("t"), to_string(tv.id)), clone(ty.name)) {
            if tv.is_bound {
                return resolve_type(env, tv.bound)
            }
            return ty
        }
        i = i + 1
    }
    ty
}

fn type_tag_name(tag: i32) -> String {
    if tag == TY_I32() { return String_from("i32") }
    if tag == TY_I64() { return String_from("i64") }
    if tag == TY_F64() { return String_from("f64") }
    if tag == TY_BOOL() { return String_from("bool") }
    if tag == TY_STRING() { return String_from("String") }
    if tag == TY_CHAR() { return String_from("char") }
    if tag == TY_UNIT() { return String_from("()") }
    if tag == TY_VEC() { return String_from("Vec") }
    if tag == TY_FN() { return String_from("fn") }
    if tag == TY_STRUCT() { return String_from("struct") }
    if tag == TY_ENUM() { return String_from("enum") }
    if tag == TY_TYPE_VAR() { return String_from("var") }
    String_from("?")
}

// ── Type Annotation Resolution ───────────────────────────────────────────────

fn resolve_type_name(name: String) -> TypeInfo {
    if eq(clone(name), "i32") { return TypeInfo_simple(TY_I32()) }
    if eq(clone(name), "i64") { return TypeInfo_simple(TY_I64()) }
    if eq(clone(name), "f64") { return TypeInfo_simple(TY_F64()) }
    if eq(clone(name), "bool") { return TypeInfo_simple(TY_BOOL()) }
    if eq(clone(name), "String") { return TypeInfo_simple(TY_STRING()) }
    if eq(clone(name), "char") { return TypeInfo_simple(TY_CHAR()) }
    TypeInfo_named(TY_STRUCT(), name)
}

// ── Type Check Context ───────────────────────────────────────────────────────

struct CheckCtx {
    env: TypeEnv,
    fn_sigs: Vec<FnSig>,
    struct_defs: Vec<StructInfo>,
    enum_defs: Vec<EnumInfo>,
}

struct FnSig {
    name: String,
    param_types: Vec<TypeInfo>,
    return_type: TypeInfo,
}

struct StructInfo {
    name: String,
    field_names: Vec<String>,
    field_types: Vec<TypeInfo>,
}

struct EnumInfo {
    name: String,
    variant_names: Vec<String>,
}

fn CheckCtx_new() -> CheckCtx {
    CheckCtx {
        env: TypeEnv_new(),
        fn_sigs: Vec_new_FnSig(),
        struct_defs: Vec_new_StructInfo(),
        enum_defs: Vec_new_EnumInfo(),
    }
}

// ── Type Check Result ────────────────────────────────────────────────────────

struct TypeCheckResult {
    error_count: i32,
    errors: Vec<String>,
    typed_fns: Vec<TypedFn>,
}

struct TypedFn {
    name: String,
    return_type: TypeInfo,
}

fn typecheck_module(resolve_ctx: ResolveCtx) -> TypeCheckResult {
    let result = TypeCheckResult {
        error_count: 0,
        errors: Vec_new_String(),
        typed_fns: Vec_new_TypedFn(),
    }
    // In the real implementation, we'd walk the resolved AST
    // and check types. For now, pass through resolve errors.
    result.error_count = resolve_ctx.error_count
    result.errors = resolve_ctx.errors
    result
}

fn dump_typed_hir(result: TypeCheckResult) {
    let fn_count = len(result.typed_fns)
    stdio::eprintln(concat(String_from("typed functions: "), to_string(fn_count)))
    if result.error_count > 0 {
        stdio::eprintln(concat(to_string(result.error_count), String_from(" type error(s)")))
    }
}

// Arukellt Selfhost — MIR (Mid-level IR) + HIR→MIR Lowering
//
// Flattens the typed HIR tree into a flat list of basic blocks
// with explicit control flow, preparing for Wasm emission.


// ── MIR Instruction Tags ─────────────────────────────────────────────────────

fn MIR_CONST_I32() -> i32 { 1 }
fn MIR_CONST_I64() -> i32 { 2 }
fn MIR_CONST_F64() -> i32 { 3 }
fn MIR_CONST_BOOL() -> i32 { 4 }
fn MIR_CONST_STRING() -> i32 { 5 }
fn MIR_LOCAL_GET() -> i32 { 10 }
fn MIR_LOCAL_SET() -> i32 { 11 }
fn MIR_GLOBAL_GET() -> i32 { 12 }
fn MIR_GLOBAL_SET() -> i32 { 13 }
fn MIR_ADD() -> i32 { 20 }
fn MIR_SUB() -> i32 { 21 }
fn MIR_MUL() -> i32 { 22 }
fn MIR_DIV() -> i32 { 23 }
fn MIR_MOD() -> i32 { 24 }
fn MIR_EQ() -> i32 { 25 }
fn MIR_NEQ() -> i32 { 26 }
fn MIR_LT() -> i32 { 27 }
fn MIR_LTEQ() -> i32 { 28 }
fn MIR_GT() -> i32 { 29 }
fn MIR_GTEQ() -> i32 { 30 }
fn MIR_AND() -> i32 { 31 }
fn MIR_OR() -> i32 { 32 }
fn MIR_NEG() -> i32 { 33 }
fn MIR_NOT() -> i32 { 34 }
fn MIR_CALL() -> i32 { 40 }
fn MIR_CALL_INDIRECT() -> i32 { 41 }
fn MIR_RETURN() -> i32 { 42 }
fn MIR_BR() -> i32 { 50 }
fn MIR_BR_IF() -> i32 { 51 }
fn MIR_BR_TABLE() -> i32 { 52 }
fn MIR_BLOCK() -> i32 { 53 }
fn MIR_LOOP() -> i32 { 54 }
fn MIR_IF() -> i32 { 55 }
fn MIR_STRUCT_NEW() -> i32 { 60 }
fn MIR_STRUCT_GET() -> i32 { 61 }
fn MIR_STRUCT_SET() -> i32 { 62 }
fn MIR_ARRAY_NEW() -> i32 { 63 }
fn MIR_ARRAY_GET() -> i32 { 64 }
fn MIR_ARRAY_SET() -> i32 { 65 }
fn MIR_ARRAY_LEN() -> i32 { 66 }
fn MIR_DROP() -> i32 { 70 }
fn MIR_NOP() -> i32 { 71 }
fn MIR_UNREACHABLE() -> i32 { 72 }

// ── MIR Value Type Tags ─────────────────────────────────────────────────────

fn VT_I32() -> i32 { 1 }
fn VT_I64() -> i32 { 2 }
fn VT_F64() -> i32 { 3 }
fn VT_REF() -> i32 { 4 }
fn VT_VOID() -> i32 { 0 }

// ── MIR Instruction ──────────────────────────────────────────────────────────

struct MirInst {
    op: i32,
    dest: i32,
    arg0: i32,
    arg1: i32,
    int_val: i32,
    float_val: f64,
    str_val: String,
    val_type: i32,
}

fn MirInst_new(op: i32) -> MirInst {
    MirInst {
        op: op, dest: 0 - 1, arg0: 0 - 1, arg1: 0 - 1,
        int_val: 0, float_val: 0.0, str_val: String_new(),
        val_type: VT_VOID(),
    }
}

fn MirInst_const_i32(val: i32, dest: i32) -> MirInst {
    MirInst {
        op: MIR_CONST_I32(), dest: dest, arg0: 0 - 1, arg1: 0 - 1,
        int_val: val, float_val: 0.0, str_val: String_new(),
        val_type: VT_I32(),
    }
}

fn MirInst_const_string(val: String, dest: i32) -> MirInst {
    MirInst {
        op: MIR_CONST_STRING(), dest: dest, arg0: 0 - 1, arg1: 0 - 1,
        int_val: 0, float_val: 0.0, str_val: val,
        val_type: VT_REF(),
    }
}

fn MirInst_binop(op: i32, dest: i32, a: i32, b: i32) -> MirInst {
    MirInst {
        op: op, dest: dest, arg0: a, arg1: b,
        int_val: 0, float_val: 0.0, str_val: String_new(),
        val_type: VT_I32(),
    }
}

// ── MIR Basic Block ──────────────────────────────────────────────────────────

struct MirBlock {
    id: i32,
    instructions: Vec<MirInst>,
    terminator: i32,
    succ0: i32,
    succ1: i32,
}

fn MirBlock_new(id: i32) -> MirBlock {
    MirBlock {
        id: id,
        instructions: Vec_new_MirInst(),
        terminator: MIR_RETURN(),
        succ0: 0 - 1,
        succ1: 0 - 1,
    }
}

// ── MIR Function ─────────────────────────────────────────────────────────────

struct MirLocal {
    name: String,
    val_type: i32,
}

struct MirFunction {
    name: String,
    params: Vec<MirLocal>,
    locals: Vec<MirLocal>,
    blocks: Vec<MirBlock>,
    return_type: i32,
    next_local: i32,
    next_block: i32,
}

fn MirFunction_new(name: String) -> MirFunction {
    MirFunction {
        name: name,
        params: Vec_new_MirLocal(),
        locals: Vec_new_MirLocal(),
        blocks: Vec_new_MirBlock(),
        return_type: VT_VOID(),
        next_local: 0,
        next_block: 0,
    }
}

fn alloc_local(f: MirFunction, name: String, vt: i32) -> i32 {
    let idx = f.next_local
    f.next_local = f.next_local + 1
    push(f.locals, MirLocal { name: name, val_type: vt })
    idx
}

fn alloc_block(f: MirFunction) -> i32 {
    let idx = f.next_block
    f.next_block = f.next_block + 1
    push(f.blocks, MirBlock_new(idx))
    idx
}

fn emit_inst(f: MirFunction, block_id: i32, inst: MirInst) {
    let block = get_unchecked(f.blocks, block_id)
    push(block.instructions, inst)
}

// ── MIR Module ───────────────────────────────────────────────────────────────

struct MirModule {
    functions: Vec<MirFunction>,
    string_constants: Vec<String>,
}

fn MirModule_new() -> MirModule {
    MirModule {
        functions: Vec_new_MirFunction(),
        string_constants: Vec_new_String(),
    }
}

fn intern_string(m: MirModule, s: String) -> i32 {
    let count = len(m.string_constants)
    let mut i = 0
    while i < count {
        let existing = get_unchecked(m.string_constants, i)
        if eq(clone(existing), clone(s)) {
            return i
        }
        i = i + 1
    }
    push(m.string_constants, s)
    count
}

// ── HIR→MIR Lowering ────────────────────────────────────────────────────────
// Takes TypeCheckResult and produces MirModule.
// Currently a framework; full lowering will be expanded in Phase 3.

fn lower_to_mir(check_result: TypeCheckResult) -> MirModule {
    let m = MirModule_new()
    // For each typed function, create a MIR function skeleton
    let fn_count = len(check_result.typed_fns)
    let mut i = 0
    while i < fn_count {
        let tf = get_unchecked(check_result.typed_fns, i)
        let mf = MirFunction_new(clone(tf.name))
        let entry = alloc_block(mf)
        push(m.functions, mf)
        i = i + 1
    }
    m
}

// ── MIR Dump ─────────────────────────────────────────────────────────────────

fn dump_mir(m: MirModule) {
    let fn_count = len(m.functions)
    stdio::eprintln(concat(String_from("MIR module: "), concat(to_string(fn_count), String_from(" function(s)"))))
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(m.functions, i)
        let block_count = len(f.blocks)
        let local_count = len(f.locals)
        stdio::eprintln(concat(String_from("  fn "), concat(clone(f.name), concat(String_from(" ("), concat(to_string(local_count), concat(String_from(" locals, "), concat(to_string(block_count), String_from(" blocks)"))))))))
        let mut b = 0
        while b < block_count {
            let block = get_unchecked(f.blocks, b)
            let inst_count = len(block.instructions)
            stdio::eprintln(concat(String_from("    bb"), concat(to_string(b), concat(String_from(": "), concat(to_string(inst_count), String_from(" instructions"))))))
            let mut j = 0
            while j < inst_count {
                let inst = get_unchecked(block.instructions, j)
                stdio::eprintln(concat(String_from("      "), concat(mir_op_name(inst.op), concat(String_from(" -> %"), to_string(inst.dest)))))
                j = j + 1
            }
            b = b + 1
        }
        i = i + 1
    }
    let str_count = len(m.string_constants)
    if str_count > 0 {
        stdio::eprintln(concat(String_from("  strings: "), to_string(str_count)))
    }
}

fn mir_op_name(op: i32) -> String {
    if op == MIR_CONST_I32() { return String_from("const.i32") }
    if op == MIR_CONST_I64() { return String_from("const.i64") }
    if op == MIR_CONST_F64() { return String_from("const.f64") }
    if op == MIR_CONST_STRING() { return String_from("const.string") }
    if op == MIR_LOCAL_GET() { return String_from("local.get") }
    if op == MIR_LOCAL_SET() { return String_from("local.set") }
    if op == MIR_ADD() { return String_from("add") }
    if op == MIR_SUB() { return String_from("sub") }
    if op == MIR_MUL() { return String_from("mul") }
    if op == MIR_DIV() { return String_from("div") }
    if op == MIR_CALL() { return String_from("call") }
    if op == MIR_RETURN() { return String_from("return") }
    if op == MIR_BR() { return String_from("br") }
    if op == MIR_BR_IF() { return String_from("br_if") }
    if op == MIR_STRUCT_NEW() { return String_from("struct.new") }
    if op == MIR_STRUCT_GET() { return String_from("struct.get") }
    if op == MIR_DROP() { return String_from("drop") }
    if op == MIR_NOP() { return String_from("nop") }
    String_from("?op")
}

// Arukellt Selfhost — Wasm Binary Emitter
//
// Generates a deterministic Wasm binary from MIR.
// Handles section layout, LEB128 encoding, and T1/T3 target split.


// ── Wasm Section IDs ─────────────────────────────────────────────────────────

fn SEC_TYPE() -> i32 { 1 }
fn SEC_IMPORT() -> i32 { 2 }
fn SEC_FUNCTION() -> i32 { 3 }
fn SEC_TABLE() -> i32 { 4 }
fn SEC_MEMORY() -> i32 { 5 }
fn SEC_GLOBAL() -> i32 { 6 }
fn SEC_EXPORT() -> i32 { 7 }
fn SEC_START() -> i32 { 8 }
fn SEC_ELEMENT() -> i32 { 9 }
fn SEC_CODE() -> i32 { 10 }
fn SEC_DATA() -> i32 { 11 }

// ── Wasm Value Types ─────────────────────────────────────────────────────────

fn WASM_I32() -> i32 { 0x7f }
fn WASM_I64() -> i32 { 0x7e }
fn WASM_F32() -> i32 { 0x7d }
fn WASM_F64() -> i32 { 0x7c }
fn WASM_FUNCREF() -> i32 { 0x70 }
fn WASM_EXTERNREF() -> i32 { 0x6f }

// ── Wasm Opcodes ─────────────────────────────────────────────────────────────

fn OP_UNREACHABLE() -> i32 { 0x00 }
fn OP_NOP() -> i32 { 0x01 }
fn OP_BLOCK() -> i32 { 0x02 }
fn OP_LOOP() -> i32 { 0x03 }
fn OP_IF() -> i32 { 0x04 }
fn OP_ELSE() -> i32 { 0x05 }
fn OP_END() -> i32 { 0x0b }
fn OP_BR() -> i32 { 0x0c }
fn OP_BR_IF() -> i32 { 0x0d }
fn OP_RETURN() -> i32 { 0x0f }
fn OP_CALL() -> i32 { 0x10 }
fn OP_DROP() -> i32 { 0x1a }
fn OP_LOCAL_GET() -> i32 { 0x20 }
fn OP_LOCAL_SET() -> i32 { 0x21 }
fn OP_LOCAL_TEE() -> i32 { 0x22 }
fn OP_GLOBAL_GET() -> i32 { 0x23 }
fn OP_GLOBAL_SET() -> i32 { 0x24 }
fn OP_I32_LOAD() -> i32 { 0x28 }
fn OP_I32_STORE() -> i32 { 0x36 }
fn OP_I32_CONST() -> i32 { 0x41 }
fn OP_I64_CONST() -> i32 { 0x42 }
fn OP_F64_CONST() -> i32 { 0x44 }
fn OP_I32_EQZ() -> i32 { 0x45 }
fn OP_I32_EQ() -> i32 { 0x46 }
fn OP_I32_NE() -> i32 { 0x47 }
fn OP_I32_LT_S() -> i32 { 0x48 }
fn OP_I32_GT_S() -> i32 { 0x4a }
fn OP_I32_LE_S() -> i32 { 0x4c }
fn OP_I32_GE_S() -> i32 { 0x4e }
fn OP_I32_ADD() -> i32 { 0x6a }
fn OP_I32_SUB() -> i32 { 0x6b }
fn OP_I32_MUL() -> i32 { 0x6c }
fn OP_I32_DIV_S() -> i32 { 0x6d }
fn OP_I32_REM_S() -> i32 { 0x6f }
fn OP_I32_AND() -> i32 { 0x71 }
fn OP_I32_OR() -> i32 { 0x72 }
fn OP_I32_XOR() -> i32 { 0x73 }
fn OP_I32_SHL() -> i32 { 0x74 }
fn OP_I32_SHR_S() -> i32 { 0x75 }

// ── Binary Writer ────────────────────────────────────────────────────────────

struct WasmWriter {
    bytes: Vec<i32>,
}

fn WasmWriter_new() -> WasmWriter {
    WasmWriter { bytes: Vec_new_i32() }
}

fn emit_byte(w: WasmWriter, b: i32) {
    push(w.bytes, b % 256)
}

fn emit_u32_le(w: WasmWriter, v: i32) {
    emit_byte(w, v % 256)
    emit_byte(w, (v / 256) % 256)
    emit_byte(w, (v / 65536) % 256)
    emit_byte(w, (v / 16777216) % 256)
}

fn emit_leb128_u(w: WasmWriter, v: i32) {
    let mut val = v
    if val < 0 { val = 0 }
    let mut done = false
    while !done {
        let mut b = val % 128
        val = val / 128
        if val != 0 {
            b = b + 128
        }
        emit_byte(w, b)
        if val == 0 { done = true }
    }
}

fn emit_leb128_s(w: WasmWriter, v: i32) {
    let mut val = v
    let mut more = true
    while more {
        let mut b = val % 128
        if b < 0 { b = b + 128 }
        val = val / 128
        // Check if more bytes needed
        if (val == 0 && b < 64) || (val == 0 - 1 && b >= 64) {
            more = false
        } else {
            b = b + 128
        }
        emit_byte(w, b % 256)
    }
}

fn emit_bytes(w: WasmWriter, src: Vec<i32>) {
    let count = len(src)
    let mut i = 0
    while i < count {
        let b = get_unchecked(src, i)
        emit_byte(w, b)
        i = i + 1
    }
}

fn emit_string(w: WasmWriter, s: String) {
    let slen = len(s)
    emit_leb128_u(w, slen)
    let mut i = 0
    while i < slen {
        emit_byte(w, char_at(s, i))
        i = i + 1
    }
}

fn writer_size(w: WasmWriter) -> i32 {
    len(w.bytes)
}

// ── Section Writer ───────────────────────────────────────────────────────────

fn emit_section(out: WasmWriter, section_id: i32, contents: WasmWriter) {
    emit_byte(out, section_id)
    emit_leb128_u(out, writer_size(contents))
    emit_bytes(out, contents.bytes)
}

// ── Wasm Module Emitter ──────────────────────────────────────────────────────

fn emit_wasm_module(mir: MirModule, target: String, opt_level: i32) -> Vec<i32> {
    let out = WasmWriter_new()

    // Magic number: \0asm
    emit_byte(out, 0x00)
    emit_byte(out, 0x61)
    emit_byte(out, 0x73)
    emit_byte(out, 0x6d)
    // Version: 1
    emit_u32_le(out, 1)

    let fn_count = len(mir.functions)

    // Type section
    let type_sec = WasmWriter_new()
    emit_leb128_u(type_sec, fn_count)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(mir.functions, i)
        // func type: (params) -> (results)
        emit_byte(type_sec, 0x60)
        let param_count = len(f.params)
        emit_leb128_u(type_sec, param_count)
        let mut p = 0
        while p < param_count {
            let param = get_unchecked(f.params, p)
            emit_byte(type_sec, val_type_to_wasm(param.val_type))
            p = p + 1
        }
        if f.return_type == 0 {
            emit_leb128_u(type_sec, 0)
        } else {
            emit_leb128_u(type_sec, 1)
            emit_byte(type_sec, val_type_to_wasm(f.return_type))
        }
        i = i + 1
    }
    emit_section(out, SEC_TYPE(), type_sec)

    // Import section (for WASI)
    let import_sec = WasmWriter_new()
    let wasi_module = String_from("wasi_snapshot_preview1")
    emit_leb128_u(import_sec, 1)
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("fd_write"))
    emit_byte(import_sec, 0x00)  // func import
    emit_leb128_u(import_sec, 0) // type index 0 (placeholder)
    emit_section(out, SEC_IMPORT(), import_sec)

    // Function section
    let func_sec = WasmWriter_new()
    emit_leb128_u(func_sec, fn_count)
    let mut fi = 0
    while fi < fn_count {
        emit_leb128_u(func_sec, fi)
        fi = fi + 1
    }
    emit_section(out, SEC_FUNCTION(), func_sec)

    // Memory section
    let mem_sec = WasmWriter_new()
    emit_leb128_u(mem_sec, 1)
    emit_byte(mem_sec, 0x00)    // limits: no max
    emit_leb128_u(mem_sec, 1)   // initial: 1 page
    emit_section(out, SEC_MEMORY(), mem_sec)

    // Export section
    let export_sec = WasmWriter_new()
    let mut export_count = 1  // memory
    // Find _start / main
    let mut main_idx = 0 - 1
    let mut mi = 0
    while mi < fn_count {
        let f = get_unchecked(mir.functions, mi)
        if eq(clone(f.name), "main") || eq(clone(f.name), "_start") {
            main_idx = mi
        }
        mi = mi + 1
    }
    if main_idx >= 0 { export_count = export_count + 1 }
    emit_leb128_u(export_sec, export_count)
    // Export memory
    emit_string(export_sec, String_from("memory"))
    emit_byte(export_sec, 0x02)
    emit_leb128_u(export_sec, 0)
    // Export main/_start
    if main_idx >= 0 {
        emit_string(export_sec, String_from("_start"))
        emit_byte(export_sec, 0x00)
        emit_leb128_u(export_sec, main_idx + 1)  // offset by imports
    }
    emit_section(out, SEC_EXPORT(), export_sec)

    // Code section
    let code_sec = WasmWriter_new()
    emit_leb128_u(code_sec, fn_count)
    let mut ci = 0
    while ci < fn_count {
        let f = get_unchecked(mir.functions, ci)
        let body = WasmWriter_new()

        // Locals
        let local_count = len(f.locals)
        emit_leb128_u(body, local_count)
        let mut li = 0
        while li < local_count {
            let loc = get_unchecked(f.locals, li)
            emit_leb128_u(body, 1)
            emit_byte(body, val_type_to_wasm(loc.val_type))
            li = li + 1
        }

        // Instructions (simplified: emit MIR ops → Wasm ops)
        let block_count = len(f.blocks)
        let mut bi = 0
        while bi < block_count {
            let block = get_unchecked(f.blocks, bi)
            let inst_count = len(block.instructions)
            let mut ii = 0
            while ii < inst_count {
                let inst = get_unchecked(block.instructions, ii)
                emit_mir_inst(body, inst)
                ii = ii + 1
            }
            bi = bi + 1
        }

        emit_byte(body, OP_END())

        // Write func body with size prefix
        emit_leb128_u(code_sec, writer_size(body))
        emit_bytes(code_sec, body.bytes)
        ci = ci + 1
    }
    emit_section(out, SEC_CODE(), code_sec)

    // Data section (string constants)
    let str_count = len(mir.string_constants)
    if str_count > 0 {
        let data_sec = WasmWriter_new()
        emit_leb128_u(data_sec, str_count)
        let mut si = 0
        let mut offset = 0
        while si < str_count {
            let s = get_unchecked(mir.string_constants, si)
            emit_byte(data_sec, 0x00)  // active, memory 0
            emit_byte(data_sec, OP_I32_CONST())
            emit_leb128_s(data_sec, offset)
            emit_byte(data_sec, OP_END())
            let slen = len(s)
            emit_leb128_u(data_sec, slen)
            let mut ci2 = 0
            while ci2 < slen {
                emit_byte(data_sec, char_at(s, ci2))
                ci2 = ci2 + 1
            }
            offset = offset + slen
            si = si + 1
        }
        emit_section(out, SEC_DATA(), data_sec)
    }

    out.bytes
}

fn emit_mir_inst(w: WasmWriter, inst: MirInst) {
    if inst.op == 1 {  // CONST_I32
        emit_byte(w, OP_I32_CONST())
        emit_leb128_s(w, inst.int_val)
    } else if inst.op == 2 {  // CONST_I64
        emit_byte(w, OP_I64_CONST())
        emit_leb128_s(w, inst.int_val)
    } else if inst.op == 10 {  // LOCAL_GET
        emit_byte(w, OP_LOCAL_GET())
        emit_leb128_u(w, inst.arg0)
    } else if inst.op == 11 {  // LOCAL_SET
        emit_byte(w, OP_LOCAL_SET())
        emit_leb128_u(w, inst.dest)
    } else if inst.op == 20 {  // ADD
        emit_byte(w, OP_I32_ADD())
    } else if inst.op == 21 {  // SUB
        emit_byte(w, OP_I32_SUB())
    } else if inst.op == 22 {  // MUL
        emit_byte(w, OP_I32_MUL())
    } else if inst.op == 23 {  // DIV
        emit_byte(w, OP_I32_DIV_S())
    } else if inst.op == 24 {  // MOD
        emit_byte(w, OP_I32_REM_S())
    } else if inst.op == 25 {  // EQ
        emit_byte(w, OP_I32_EQ())
    } else if inst.op == 26 {  // NEQ
        emit_byte(w, OP_I32_NE())
    } else if inst.op == 27 {  // LT
        emit_byte(w, OP_I32_LT_S())
    } else if inst.op == 29 {  // GT
        emit_byte(w, OP_I32_GT_S())
    } else if inst.op == 40 {  // CALL
        emit_byte(w, OP_CALL())
        emit_leb128_u(w, inst.arg0)
    } else if inst.op == 42 {  // RETURN
        emit_byte(w, OP_RETURN())
    } else if inst.op == 70 {  // DROP
        emit_byte(w, OP_DROP())
    } else if inst.op == 71 {  // NOP
        emit_byte(w, OP_NOP())
    } else if inst.op == 72 {  // UNREACHABLE
        emit_byte(w, OP_UNREACHABLE())
    }
}

fn val_type_to_wasm(vt: i32) -> i32 {
    if vt == 1 { return WASM_I32() }
    if vt == 2 { return WASM_I64() }
    if vt == 3 { return WASM_F64() }
    if vt == 4 { return WASM_I32() }  // ref → i32 placeholder
    WASM_I32()
}

fn emit_wasm(mir: MirModule, target: String, opt_level: i32) -> Vec<i32> {
    emit_wasm_module(mir, target, opt_level)
}

// Arukellt Selfhost — Compilation Driver
//
// Orchestrates the compilation pipeline:
//   source → tokens → AST → (resolve → typecheck → HIR → MIR → Wasm)
// Error propagation stops at first phase failure.


// ── Pipeline Phase Tags ──────────────────────────────────────────────────────

fn PHASE_LEX() -> i32 { 1 }
fn PHASE_PARSE() -> i32 { 2 }
fn PHASE_RESOLVE() -> i32 { 3 }
fn PHASE_TYPECHECK() -> i32 { 4 }
fn PHASE_LOWER() -> i32 { 5 }
fn PHASE_EMIT() -> i32 { 6 }

// ── Compilation Result ───────────────────────────────────────────────────────

struct CompileResult {
    success: bool,
    phase_reached: i32,
    error_count: i32,
    error_messages: Vec<String>,
    output_bytes: Vec<i32>,
}

fn CompileResult_ok(phase: i32) -> CompileResult {
    CompileResult {
        success: true,
        phase_reached: phase,
        error_count: 0,
        error_messages: Vec_new_String(),
        output_bytes: Vec_new_i32(),
    }
}

fn CompileResult_err(phase: i32, msg: String) -> CompileResult {
    let mut msgs: Vec<String> = Vec_new_String()
    push(msgs, msg)
    CompileResult {
        success: false,
        phase_reached: phase,
        error_count: 1,
        error_messages: msgs,
        output_bytes: Vec_new_i32(),
    }
}

// ── Driver Configuration ─────────────────────────────────────────────────────

struct DriverConfig {
    target: String,
    opt_level: i32,
    dump_tokens: bool,
    dump_ast: bool,
    dump_hir: bool,
    dump_mir: bool,
    dump_wasm: bool,
    parse_only: bool,
    check_only: bool,
}

fn DriverConfig_default() -> DriverConfig {
    DriverConfig {
        target: String_from("wasm32-wasi-p2"),
        opt_level: 0,
        dump_tokens: false,
        dump_ast: false,
        dump_hir: false,
        dump_mir: false,
        dump_wasm: false,
        parse_only: false,
        check_only: false,
    }
}

// ── File Loading ─────────────────────────────────────────────────────────────

fn load_source(path: String) -> Result<String, String> {
    fs::read_to_string(path)
}

// ── Pipeline Orchestration ───────────────────────────────────────────────────

fn compile_source(source: String, config: DriverConfig) -> CompileResult {
    // Phase 1: Lex
    let tokens = tokenize(clone(source))
    let token_count = len(tokens)

    if config.dump_tokens {
        stdio::eprintln(String_from("=== TOKENS ==="))
        let mut i = 0
        while i < token_count {
            let tok = get_unchecked(tokens, i)
            stdio::eprintln(concat(token_kind_name(tok.kind), concat(String_from(" "), clone(tok.text))))
            i = i + 1
        }
    }

    // Check for lexer errors
    let mut lex_errors = 0
    let mut i = 0
    while i < token_count {
        let tok = get_unchecked(tokens, i)
        if tok.kind == 7 {  // TK_ERROR
            lex_errors = lex_errors + 1
        }
        i = i + 1
    }
    if lex_errors > 0 {
        return CompileResult_err(PHASE_LEX(), concat(to_string(lex_errors), String_from(" lexer error(s)")))
    }

    // Phase 2: Parse
    let parser = Parser_new(tokens)
    let decls = parse_module(parser)

    if config.dump_ast {
        stdio::eprintln(String_from("=== AST ==="))
        let decl_count = len(decls)
        let mut j = 0
        while j < decl_count {
            let d = get_unchecked(decls, j)
            print_ast_stderr(d, 0)
            j = j + 1
        }
    }

    let parse_error_count = len(parser.errors)
    if parse_error_count > 0 {
        let mut result = CompileResult_err(PHASE_PARSE(), concat(to_string(parse_error_count), String_from(" parse error(s)")))
        let mut k = 0
        while k < parse_error_count {
            let pe = get_unchecked(parser.errors, k)
            push(result.error_messages, clone(pe.message))
            k = k + 1
        }
        result.error_count = parse_error_count
        return result
    }

    if config.parse_only {
        return CompileResult_ok(PHASE_PARSE())
    }

    // Phase 3: Resolve (name binding)
    let resolve_ctx = resolve_module(decls)

    if config.dump_hir {
        stdio::eprintln(String_from("=== HIR (post-resolve) ==="))
        dump_scope(resolve_ctx)
    }

    if resolve_ctx.error_count > 0 {
        return CompileResult_err(PHASE_RESOLVE(), concat(to_string(resolve_ctx.error_count), String_from(" resolve error(s)")))
    }

    // Phase 4: Type check
    let check_result = typecheck_module(resolve_ctx)

    if config.dump_hir {
        stdio::eprintln(String_from("=== TYPED HIR ==="))
        dump_typed_hir(check_result)
    }

    if check_result.error_count > 0 {
        return CompileResult_err(PHASE_TYPECHECK(), concat(to_string(check_result.error_count), String_from(" type error(s)")))
    }

    if config.check_only {
        return CompileResult_ok(PHASE_TYPECHECK())
    }

    // Phase 5: Lower to MIR
    let mir_module = lower_to_mir(check_result)

    if config.dump_mir {
        stdio::eprintln(String_from("=== MIR ==="))
        dump_mir(mir_module)
    }

    // Phase 6: Emit Wasm
    let wasm_bytes = emit_wasm(mir_module, clone(config.target), config.opt_level)

    if config.dump_wasm {
        stdio::eprintln(String_from("=== WASM ==="))
        stdio::eprintln(concat(String_from("output size: "), concat(to_string(len(wasm_bytes)), String_from(" bytes"))))
    }

    let mut result = CompileResult_ok(PHASE_EMIT())
    result.output_bytes = wasm_bytes
    result
}

// ── Compile File ─────────────────────────────────────────────────────────────

fn compile_file(path: String, config: DriverConfig) -> CompileResult {
    let source_result = load_source(clone(path))
    match source_result {
        Ok(source) => {
            compile_source(source, config)
        },
        Err(e) => {
            CompileResult_err(0, concat(String_from("failed to read file: "), e))
        },
    }
}

// Stub: print AST to stderr
fn print_ast_stderr(node: AstNode, depth: i32) {
    let mut indent = String_new()
    let mut d = 0
    while d < depth {
        indent = concat(indent, String_from("  "))
        d = d + 1
    }
    stdio::eprintln(concat(indent, node_kind_name(node.kind)))
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let child = get_unchecked(node.children, i)
        print_ast_stderr(child, depth + 1)
        i = i + 1
    }
}

// Arukellt Selfhost — CLI Entry Point
//
// Command surface for the self-hosted compiler.
// Supports: parse, compile, check subcommands.
// Exit code: 0 = success, 1 = failure.


// ── Command Tags ─────────────────────────────────────────────────────────────

fn CMD_PARSE() -> i32 { 1 }
fn CMD_COMPILE() -> i32 { 2 }
fn CMD_CHECK() -> i32 { 3 }
fn CMD_HELP() -> i32 { 4 }
fn CMD_VERSION() -> i32 { 5 }
fn CMD_UNKNOWN() -> i32 { 0 }

// ── Parsed CLI ───────────────────────────────────────────────────────────────

struct CliOptions {
    command: i32,
    input_file: String,
    output_file: String,
    target: String,
    opt_level: i32,
    dump_phases: String,
    emit_mode: String,
    show_help: bool,
    show_version: bool,
    has_error: bool,
    error_msg: String,
}

fn CliOptions_default() -> CliOptions {
    CliOptions {
        command: CMD_UNKNOWN(),
        input_file: String_new(),
        output_file: String_new(),
        target: String_from("wasm32-wasi-p2"),
        opt_level: 0,
        dump_phases: String_new(),
        emit_mode: String_from("wasm"),
        show_help: false,
        show_version: false,
        has_error: false,
        error_msg: String_new(),
    }
}

// ── Argument Parsing ─────────────────────────────────────────────────────────

fn parse_command(name: String) -> i32 {
    if eq(name, "parse") { return CMD_PARSE() }
    if eq(name, "compile") { return CMD_COMPILE() }
    if eq(name, "check") { return CMD_CHECK() }
    if eq(name, "help") { return CMD_HELP() }
    if eq(name, "version") { return CMD_VERSION() }
    CMD_UNKNOWN()
}

fn parse_args(argv: Vec<String>) -> CliOptions {
    let opts = CliOptions_default()
    let argc = len(argv)

    if argc <= 1 {
        opts.show_help = true
        return opts
    }

    // First positional arg is the command
    let cmd_str = get_unchecked(argv, 1)
    opts.command = parse_command(clone(cmd_str))

    if opts.command == CMD_HELP() {
        opts.show_help = true
        return opts
    }
    if opts.command == CMD_VERSION() {
        opts.show_version = true
        return opts
    }
    if opts.command == CMD_UNKNOWN() {
        // Treat as input file with implicit compile
        opts.command = CMD_COMPILE()
        opts.input_file = clone(cmd_str)
    }

    let mut i = 2
    while i < argc {
        let arg = get_unchecked(argv, i)
        if eq(clone(arg), "--target") {
            i = i + 1
            if i < argc {
                opts.target = clone(get_unchecked(argv, i))
            }
        } else if eq(clone(arg), "--opt-level") {
            i = i + 1
            if i < argc {
                let val = get_unchecked(argv, i)
                // Simple parse
                if eq(clone(val), "0") { opts.opt_level = 0 }
                else if eq(clone(val), "1") { opts.opt_level = 1 }
                else if eq(clone(val), "2") { opts.opt_level = 2 }
            }
        } else if eq(clone(arg), "--emit") {
            i = i + 1
            if i < argc {
                opts.emit_mode = clone(get_unchecked(argv, i))
            }
        } else if eq(clone(arg), "-o") {
            i = i + 1
            if i < argc {
                opts.output_file = clone(get_unchecked(argv, i))
            }
        } else if eq(clone(arg), "--dump-phases") {
            i = i + 1
            if i < argc {
                opts.dump_phases = clone(get_unchecked(argv, i))
            }
        } else if eq(clone(arg), "--help") {
            opts.show_help = true
        } else if eq(clone(arg), "--version") {
            opts.show_version = true
        } else {
            // Positional: input file
            if len(opts.input_file) == 0 {
                opts.input_file = clone(arg)
            } else {
                opts.has_error = true
                opts.error_msg = concat(String_from("unexpected argument: "), clone(arg))
            }
        }
        i = i + 1
    }

    opts
}

// ── Usage / Version ──────────────────────────────────────────────────────────

fn print_usage() {
    stdio::println(String_from("arukellt-s1 — self-hosted Arukellt compiler"))
    stdio::println(String_from(""))
    stdio::println(String_from("USAGE:"))
    stdio::println(String_from("  arukellt-s1 <command> [options] <input.ark>"))
    stdio::println(String_from(""))
    stdio::println(String_from("COMMANDS:"))
    stdio::println(String_from("  parse      Parse and dump AST"))
    stdio::println(String_from("  check      Type-check without codegen"))
    stdio::println(String_from("  compile    Compile to Wasm (default)"))
    stdio::println(String_from("  help       Show this help"))
    stdio::println(String_from("  version    Show version"))
    stdio::println(String_from(""))
    stdio::println(String_from("OPTIONS:"))
    stdio::println(String_from("  --target <target>      Target triple (default: wasm32-wasi-p2)"))
    stdio::println(String_from("  --opt-level <0|1|2>    Optimization level (default: 0)"))
    stdio::println(String_from("  --emit <wasm|wat|component|wit>  Emit mode"))
    stdio::println(String_from("  --dump-phases <list>   Dump intermediate phases (tokens,ast,hir,mir,wasm)"))
    stdio::println(String_from("  -o <file>              Output file"))
}

fn print_version() {
    stdio::println(String_from("arukellt-s1 0.1.0 (selfhost stage 1)"))
}

// ── Dump Phase Support (#167) ────────────────────────────────────────────────

fn should_dump(opts: CliOptions, phase: String) -> bool {
    if len(opts.dump_phases) == 0 { return false }
    // Check if phase is contained in the comma-separated dump_phases string
    // Simple substring check
    let phases = clone(opts.dump_phases)
    let phase_len = len(phase)
    let phases_len = len(phases)
    let mut i = 0
    while i <= phases_len - phase_len {
        let sub = substring(phases, i, i + phase_len)
        if eq(sub, clone(phase)) {
            // Check boundaries: start of string or preceded by comma
            let at_start = i == 0
            let after_comma = i > 0 && char_at(phases, i - 1) == 44
            let at_end = i + phase_len == phases_len
            let before_comma = i + phase_len < phases_len && char_at(phases, i + phase_len) == 44
            if (at_start || after_comma) && (at_end || before_comma) {
                return true
            }
        }
        i = i + 1
    }
    false
}

// ── Main Entry ───────────────────────────────────────────────────────────────

fn main() {
    let argc = env::arg_count()
    if argc == 0 {
        stdio::eprintln(String_from("usage: arukellt <input.ark>"))
        return
    }
    let input_path = env::arg_at(0)
    let result = fs::read_to_string(clone(input_path))
    match result {
        Ok(source) => {
            let tokens = tokenize(source)
            let tok_count = len(tokens)
            let p = Parser_new(tokens)
            let decls = parse_module(p)
            let err_count = len(p.errors)
            if err_count > 0 {
                let mut i = 0
                while i < err_count {
                    let e = get_unchecked(p.errors, i)
                    stdio::eprintln(concat(String_from("error: "), clone(e.message)))
                    i = i + 1
                }
            } else {
                stdio::println(concat(String_from("tokens: "), i32_to_string(tok_count)))
                stdio::println(concat(String_from("declarations: "), i32_to_string(len(decls))))
            }
        },
        Err(e) => {
            stdio::eprintln(concat(String_from("cannot read file: "), e))
        },
    }
}
