// Arukellt Selfhost - TypeInfo to TypeId intern bridge (depth-limited recursion PR-3).

use corehir::type_contracts
use corehir::type_info_kind
use corehir::type_kind
use corehir::type_table

fn TYPE_INFO_TO_TYPE_ID_MAX_DEPTH() -> i32 {
    4
}

fn type_info_to_type_id(table: TypeTable, ty: TypeInfo) -> TypeId {
    type_info_to_type_id_depth(table, ty, 0)
}

fn type_info_to_type_id_depth(table: TypeTable, ty: TypeInfo, depth: i32) -> TypeId {
    let tag = type_contracts::TypeInfo_tag(ty)
    if tag == 0 {
        return type_table::TypeTable_intern(table, type_kind::TYPE_KIND_PRIMITIVE(), String_from("void"), Vec_new_TypeId())
    }
    if depth > TYPE_INFO_TO_TYPE_ID_MAX_DEPTH() {
        let kind = type_info_kind::type_info_tag_to_kind(tag)
        let name = type_info_kind::type_info_display_name(ty)
        return type_table::TypeTable_intern(table, kind, name, Vec_new_TypeId())
    }
    let kind = type_info_kind::type_info_tag_to_kind(tag)
    let name = type_info_kind::type_info_display_name(ty)
    let arg_count = type_contracts::TypeInfo_type_arg_count(ty)
    let arg_ids = Vec_new_TypeId()
    let mut ai = 0
    while ai < arg_count {
        push(arg_ids, type_info_to_type_id_depth(table, type_contracts::TypeInfo_type_arg_at(ty, ai), depth + 1))
        ai = ai + 1
    }
    type_table::TypeTable_intern(table, kind, name, arg_ids)
}
