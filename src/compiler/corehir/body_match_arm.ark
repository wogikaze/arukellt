use corehir::expr_factory
use corehir::expr_access_types
// Arukellt Selfhost - CoreHIR body builder for match arms.

use corehir::body_patterns
use corehir::expr_predicates
use corehir::expr_builder_calls
use corehir::match_arm_node

fn corehir_build_match_arm_expr(table: CoreHirBodyTable, arm: AstNode) -> i32 {
    let child_count = match_arm_node::match_arm_child_count(arm)
    if child_count < 2 {
        return corehir_push_expr(table, expr_factory::CoreHirExpr_unsupported(match_arm_node::match_arm_span_start(arm)))
    }
    let children = Vec_new_i32()
    let pat_index = body_patterns::corehir_build_pattern_expr(table, match_arm_node::match_arm_child_at(arm, 0))
    push(children, pat_index)
    let pat_expr = corehir_body_expr_at(table, pat_index)
    if expr_predicates::expr_is_unsupported(pat_expr) {
        return corehir_push_expr(table, expr_factory::CoreHirExpr_unsupported(match_arm_node::match_arm_span_start(arm)))
    }
    if child_count == 3 {
        let guard_index = corehir_build_expr(table, match_arm_node::match_arm_child_at(arm, 1))
        push(children, guard_index)
        let guard_expr = corehir_body_expr_at(table, guard_index)
        if expr_predicates::expr_is_unsupported(guard_expr) {
            return corehir_push_expr(table, expr_factory::CoreHirExpr_unsupported(match_arm_node::match_arm_span_start(arm)))
        }
    }
    let body_index = corehir_build_expr(table, match_arm_node::match_arm_child_at(arm, child_count - 1))
    push(children, body_index)
    let body_expr = corehir_body_expr_at(table, body_index)
    if expr_predicates::expr_is_unsupported(body_expr) {
        return corehir_push_expr(table, expr_factory::CoreHirExpr_unsupported(match_arm_node::match_arm_span_start(arm)))
    }
    corehir_push_expr(table, expr_builder_calls::corehir_expr_match_arm(expr_access_types::expr_val_type(body_expr), expr_access_types::expr_type_name(body_expr), match_arm_node::match_arm_span_start(arm), children))
}
