use corehir::core_op_binding_generated
use corehir::core_op_id
use corehir::core_op_registry

fn core_op_binding_lookup_for_callee(callee: String) -> CoreOpId {
    let canonical = core_op_binding_generated::core_op_binding_core_op_id_for_callee(clone(callee))
    if len(canonical) == 0 {
        return core_op_id::CORE_OP_ID_NONE()
    }
    return core_op_registry::CoreOpRegistry_lookup_by_canonical(canonical)
}

fn core_op_binding_lookup_for_mangled(mangled: String) -> CoreOpId {
    core_op_binding_lookup_for_callee(clone(mangled))
}
