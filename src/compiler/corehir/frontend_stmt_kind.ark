use corehir::frontend_kind_map

fn corehir_kind_is_stmt_while(kind: i32) -> bool { kind == frontend_kind_map::nk_while() }
fn corehir_kind_is_stmt_loop(kind: i32) -> bool { kind == frontend_kind_map::nk_loop() }
fn corehir_kind_is_stmt_for(kind: i32) -> bool { kind == frontend_kind_map::nk_for() }
fn corehir_kind_is_stmt_break(kind: i32) -> bool { kind == frontend_kind_map::nk_break() }
fn corehir_kind_is_stmt_continue(kind: i32) -> bool { kind == frontend_kind_map::nk_continue() }
fn corehir_kind_is_stmt_return(kind: i32) -> bool { kind == frontend_kind_map::nk_return() }
fn corehir_kind_is_stmt_let(kind: i32) -> bool { kind == frontend_kind_map::nk_let() }
fn corehir_kind_is_stmt_expr_stmt(kind: i32) -> bool { kind == frontend_kind_map::nk_expr_stmt() }
