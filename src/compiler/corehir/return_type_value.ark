// Arukellt Selfhost - CoreHIR return annotation value type mapping.

use corehir::decl_ann_name
use corehir::return_ann_shape
use corehir::value_types

fn return_value_type_tag(node: AstNode) -> i32 {
    let child_count = return_ann_shape::return_ann_child_count(node)
    if child_count <= 0 {
        return value_types::VT_VOID()
    }
    let ret = return_ann_shape::return_ann_child(node)
    let name = decl_ann_name::decl_ann_name(ret)
    if eq(clone(name), String_from("f64")) {
        return value_types::VT_F64()
    if eq(clone(name), String_from("f32")) {
        return value_types::VT_F32()
    }
    if eq(clone(name), String_from("v128")) {
        return value_types::VT_V128()
    }
    }
    if eq(clone(name), String_from("i64")) || eq(clone(name), String_from("u64")) {
        return value_types::VT_I64()
    }
    if eq(clone(name), String_from("void")) || eq(clone(name), String_from("()")) {
        return value_types::VT_VOID()
    }
    if eq(clone(name), String_from("String")) || eq(clone(name), String_from("string")) {
        return value_types::VT_REF()
    }
    value_types::VT_I32()
}
