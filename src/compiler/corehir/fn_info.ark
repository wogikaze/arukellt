struct CoreHirFnInfo {
    decl_index: i32,
    typed_fn_index: i32,
    name: String,
    param_count: i32,
    params: Vec<CoreHirParam>,
    body_index: i32,
    is_entry_main: bool,
}

fn CoreHirFnInfo_new(decl_index: i32, typed_fn_index: i32, name: String, param_count: i32, params: Vec<CoreHirParam>, body_index: i32, is_entry_main: bool) -> CoreHirFnInfo {
    CoreHirFnInfo { decl_index: decl_index, typed_fn_index: typed_fn_index, name: name, param_count: param_count, params: params, body_index: body_index, is_entry_main: is_entry_main }
}

fn fn_info_index_for_decl(fn_infos: Vec<CoreHirFnInfo>, decl_index: i32) -> i32 {
    let count = len(fn_infos)
    let mut i = 0
    while i < count {
        let info = get_unchecked(fn_infos, i)
        if info.decl_index == decl_index {
            return i
        }
        i = i + 1
    }
    0 - 1
}

fn fn_info_typed_index_at(fn_infos: Vec<CoreHirFnInfo>, info_index: i32, fallback: i32) -> i32 {
    if info_index >= 0 && info_index < len(fn_infos) {
        let info = get_unchecked(fn_infos, info_index)
        return info.typed_fn_index
    }
    fallback
}

fn fn_info_body_index_at(fn_infos: Vec<CoreHirFnInfo>, info_index: i32, fallback: i32) -> i32 {
    if info_index >= 0 && info_index < len(fn_infos) {
        let info = get_unchecked(fn_infos, info_index)
        return info.body_index
    }
    fallback
}

fn fn_info_param_count_at(fn_infos: Vec<CoreHirFnInfo>, info_index: i32, fallback: i32) -> i32 {
    if info_index >= 0 && info_index < len(fn_infos) {
        let info = get_unchecked(fn_infos, info_index)
        return info.param_count
    }
    fallback
}

fn fn_info_param_at(fn_infos: Vec<CoreHirFnInfo>, info_index: i32, param_index: i32) -> CoreHirParam {
    let info = get_unchecked(fn_infos, info_index)
    get_unchecked(info.params, param_index)
}

fn fn_info_is_entry_main_at(fn_infos: Vec<CoreHirFnInfo>, info_index: i32, fallback: bool) -> bool {
    if info_index >= 0 && info_index < len(fn_infos) {
        let info = get_unchecked(fn_infos, info_index)
        return info.is_entry_main
    }
    fallback
}

fn fn_info_entry_main_decl_index(fn_infos: Vec<CoreHirFnInfo>) -> i32 {
    let count = len(fn_infos)
    let mut i = 0
    while i < count {
        let info = get_unchecked(fn_infos, i)
        if info.is_entry_main {
            return info.decl_index
        }
        i = i + 1
    }
    0 - 1
}
