use corehir::expr_node_access
use corehir::expr_predicates

fn corehir_build_children(table: CoreHirBodyTable, nodes: Vec<AstNode>, children: Vec<i32>) -> bool {
    let child_count = len(nodes)
    let mut i = 0
    let mut unsupported = false
    while i < child_count {
        let child_index = corehir_build_expr(table, get_unchecked(nodes, i))
        push(children, child_index)
        let child_expr = corehir_body_expr_at(table, child_index)
        if expr_predicates::expr_is_unsupported(child_expr) {
            unsupported = true
        }
        i = i + 1
    }
    unsupported
}

fn corehir_build_node_children(table: CoreHirBodyTable, node: AstNode, children: Vec<i32>) -> bool {
    let child_count = expr_node_access::expr_child_count(node)
    let mut i = 0
    let mut unsupported = false
    while i < child_count {
        let child_index = corehir_build_expr(table, expr_node_access::expr_child_at(node, i))
        push(children, child_index)
        let child_expr = corehir_body_expr_at(table, child_index)
        if expr_predicates::expr_is_unsupported(child_expr) {
            unsupported = true
        }
        i = i + 1
    }
    unsupported
}
