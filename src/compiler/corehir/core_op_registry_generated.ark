fn core_op_registry_lookup_index(canonical_id: String) -> i32 {
    let count = core_op_registry_entry_count()
    let mut i = 0
    while i < count {
        if eq(clone(canonical_id), core_op_registry_canonical_id_at(i)) {
            return i
        }
        i = i + 1
    }
    return 0 - 1
}
