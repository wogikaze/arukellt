// Arukellt Selfhost - CoreHIR integer literal suffix classification.

fn corehir_int_lit_has_small_suffix(text: String, n: i32) -> bool {
    if n >= 2 {
        let last = char_at(text, n - 1)
        let prev = char_at(text, n - 2)
        if last == 56 && (prev == 105 || prev == 117) {
            return true
        }
        if n >= 3 {
            let a = char_at(text, n - 3)
            let b = char_at(text, n - 2)
            let c = char_at(text, n - 1)
            if (a == 105 || a == 117) && b == 49 && c == 54 {
                return true
            }
            if (a == 105 || a == 117) && b == 51 && c == 50 {
                return true
            }
        }
    }
    false
}

fn corehir_int_lit_small_type_name(text: String, n: i32) -> String {
    if n >= 2 && char_at(text, n - 1) == 56 {
        if char_at(text, n - 2) == 117 {
            return String_from("u8")
        }
        return String_from("i8")
    }
    if n >= 3 && char_at(text, n - 2) == 49 && char_at(text, n - 1) == 54 {
        if char_at(text, n - 3) == 117 {
            return String_from("u16")
        }
        return String_from("i16")
    }
    if n >= 3 && char_at(text, n - 2) == 51 && char_at(text, n - 1) == 50 {
        if char_at(text, n - 3) == 117 {
            return String_from("u32")
        }
        return String_from("i32")
    }
    String_new()
}

fn corehir_int_lit_has_64_suffix(text: String, n: i32) -> bool {
    if n >= 3 {
        let a = char_at(text, n - 3)
        let b = char_at(text, n - 2)
        let c = char_at(text, n - 1)
        if (a == 105 || a == 117) && b == 54 && c == 52 {
            return true
        }
    }
    false
}

fn corehir_int_lit_64_type_name(text: String, n: i32) -> String {
    if n >= 3 && char_at(text, n - 3) == 117 {
        return String_from("u64")
    }
    String_from("i64")
}
