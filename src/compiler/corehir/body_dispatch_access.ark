// Arukellt Selfhost - CoreHIR access expression dispatch.

use corehir::body_access
use corehir::expr_node_predicates

fn corehir_dispatch_access_expr(table: CoreHirBodyTable, node: AstNode) -> i32 {
    if expr_node_predicates::expr_is_field_access(node) {
        return body_access::corehir_build_field_access_expr(table, node)
    }
    if expr_node_predicates::expr_is_index(node) {
        return body_access::corehir_build_index_expr(table, node)
    }
    0 - 2
}
