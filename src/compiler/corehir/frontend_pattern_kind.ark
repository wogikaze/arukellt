// Arukellt Selfhost - CoreHIR pattern kind adapter.

use corehir::frontend_kind_map

fn corehir_kind_is_pattern_ident(kind: i32) -> bool { kind == frontend_kind_map::nk_pat_ident() }
fn corehir_kind_is_pattern_wildcard(kind: i32) -> bool { kind == frontend_kind_map::nk_pat_wildcard() }
fn corehir_kind_is_pattern_literal(kind: i32) -> bool { kind == frontend_kind_map::nk_pat_literal() }
fn corehir_kind_is_pattern_variant(kind: i32) -> bool { kind == frontend_kind_map::nk_pat_variant() }
fn corehir_kind_is_pattern_or(kind: i32) -> bool { kind == frontend_kind_map::nk_pat_or() }
