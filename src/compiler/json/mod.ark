// Arukellt Selfhost - shared JSON parsing utilities for DAP and LSP.
//
// All functions are now thin delegations to `std::json` (issue #704).
// This module remains as a compatibility facade so existing `use json`
// imports in the compiler continue to work without per-file changes.

use std::json

pub fn skip_ws(s: String, pos: i32) -> i32 {
    json::skip_ws(s, pos)
}

pub fn parse_int_at(s: String, pos: i32) -> i32 {
    json::parse_int_at(s, pos)
}

pub fn parse_content_length(header_block: String) -> i32 {
    json::parse_content_length(header_block)
}
