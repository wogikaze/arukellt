// Arukellt Selfhost - formatter program pipeline.

use fmt::comments
use fmt::indent
use fmt::parse_gate
use fmt::sort_imports
use fmt::whitespace

fn fmt_format_source_impl(input: String) -> Option<String> {
    let gate = parse_gate::fmt_parse_gate(clone(input))
    if parse_gate::fmt_parse_gate_error_count(gate) > 0 {
        return Option::None
    }
    match sort_imports::fmt_sort_imports_text(clone(input)) {
        Option::None => {
            return Option::None
        },
        Option::Some(sorted_text) => {
            let lines = whitespace::fmt_split_lines(clone(sorted_text))
            let with_comments = comments::fmt_preserve_comment_lines(lines)
            let indented = indent::fmt_indent_apply(with_comments)
            let collapsed = whitespace::fmt_collapse_blank_lines(indented)
            Option::Some(whitespace::fmt_join_lines(collapsed))
        },
    }
}

fn fmt_format_source(input: String) -> Option<String> {
    fmt_format_source_impl(input)
}

fn fmt_sort_imports(input: String) -> Option<String> {
    sort_imports::fmt_sort_imports_text(input)
}
