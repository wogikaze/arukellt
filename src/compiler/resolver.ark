// Arukellt Selfhost — Resolver (Name Binding and Imports)
//
// Walks the AST and builds a scope chain, binding each identifier
// to its declaration. Reports undefined and duplicate names.

use std::host::stdio

// ── Symbol Tags ──────────────────────────────────────────────────────────────

fn SYM_LOCAL() -> i32 { 1 }
fn SYM_PARAM() -> i32 { 2 }
fn SYM_FN() -> i32 { 3 }
fn SYM_STRUCT() -> i32 { 4 }
fn SYM_ENUM() -> i32 { 5 }
fn SYM_VARIANT() -> i32 { 6 }
fn SYM_IMPORT() -> i32 { 7 }
fn SYM_BUILTIN() -> i32 { 8 }
fn SYM_MODULE() -> i32 { 9 }

// ── Symbol ───────────────────────────────────────────────────────────────────

struct Symbol {
    name: String,
    kind: i32,
    scope_depth: i32,
    decl_index: i32,
    is_mut: bool,
    is_pub: bool,
}

fn Symbol_new(name: String, kind: i32, depth: i32, index: i32) -> Symbol {
    Symbol { name: name, kind: kind, scope_depth: depth, decl_index: index, is_mut: false, is_pub: false }
}

fn Symbol_new_pub(name: String, kind: i32, depth: i32, index: i32) -> Symbol {
    Symbol { name: name, kind: kind, scope_depth: depth, decl_index: index, is_mut: false, is_pub: true }
}

// ── Scope ────────────────────────────────────────────────────────────────────

struct Scope {
    symbols: Vec<Symbol>,
    parent_depth: i32,
}

fn Scope_new(parent: i32) -> Scope {
    Scope { symbols: Vec_new_Symbol(), parent_depth: parent }
}

// ── Resolve Context ──────────────────────────────────────────────────────────

struct ResolveCtx {
    scopes: Vec<Scope>,
    current_depth: i32,
    error_count: i32,
    errors: Vec<String>,
    next_decl_index: i32,
}

fn ResolveCtx_new() -> ResolveCtx {
    let mut ctx = ResolveCtx {
        scopes: Vec_new_Scope(),
        current_depth: 0,
        error_count: 0,
        errors: Vec_new_String(),
        next_decl_index: 0,
    }
    // Push global scope
    push(ctx.scopes, Scope_new(0 - 1))
    // Register builtins
    register_builtins(ctx)
    ctx
}

fn push_scope(ctx: ResolveCtx) {
    ctx.current_depth = ctx.current_depth + 1
    if ctx.current_depth < len(ctx.scopes) {
        // Reuse existing scope at this depth — clear old symbols
        let scope = get_unchecked(ctx.scopes, ctx.current_depth)
        scope.symbols = Vec_new_Symbol()
    } else {
        push(ctx.scopes, Scope_new(ctx.current_depth - 1))
    }
}

fn pop_scope(ctx: ResolveCtx) {
    ctx.current_depth = ctx.current_depth - 1
}

fn define_impl(ctx: ResolveCtx, name: String, kind: i32, is_pub: bool) {
    let idx = ctx.next_decl_index
    ctx.next_decl_index = ctx.next_decl_index + 1
    // Add to current scope
    let scope = get_unchecked(ctx.scopes, ctx.current_depth)
    // Check for duplicates at current depth.
    // Shadowing is allowed for:
    //   - Local variable re-binding (let x = ...; let x = ...;)
    //   - User-defined functions/structs/enums shadowing builtin modules
    let sym_count = len(scope.symbols)
    let mut i = 0
    while i < sym_count {
        let existing = get_unchecked(scope.symbols, i)
        if eq(clone(existing.name), clone(name)) && existing.scope_depth == ctx.current_depth {
            // Allow shadowing of local variables and parameters
            if kind == SYM_LOCAL() || kind == SYM_PARAM() {
                // Overwrite in-place to shadow the existing binding
                existing.kind = kind
                existing.decl_index = idx
                existing.is_pub = is_pub
                return
            }
            // Allow user-defined fn/struct/enum to shadow a builtin module
            if (kind == SYM_FN() || kind == SYM_STRUCT() || kind == SYM_ENUM()) && existing.kind == SYM_MODULE() {
                existing.kind = kind
                existing.decl_index = idx
                existing.is_pub = is_pub
                return
            }
            resolve_error(ctx, concat(String_from("duplicate definition: "), clone(name)))
            return
        }
        i = i + 1
    }
    let sym = Symbol { name: clone(name), kind: kind, scope_depth: ctx.current_depth, decl_index: idx, is_mut: false, is_pub: is_pub }
    push(scope.symbols, sym)
}

fn define(ctx: ResolveCtx, name: String, kind: i32) {
    define_impl(ctx, name, kind, false)
}

fn define_pub(ctx: ResolveCtx, name: String, kind: i32) {
    define_impl(ctx, name, kind, true)
}

fn define_with_vis(ctx: ResolveCtx, name: String, kind: i32, is_pub: bool) {
    define_impl(ctx, name, kind, is_pub)
}

fn lookup(ctx: ResolveCtx, name: String) -> i32 {
    // Search from current scope to global
    let mut depth = ctx.current_depth
    while depth >= 0 {
        let scope = get_unchecked(ctx.scopes, depth)
        let sym_count = len(scope.symbols)
        let mut i = sym_count - 1
        while i >= 0 {
            let sym = get_unchecked(scope.symbols, i)
            if eq(clone(sym.name), clone(name)) {
                return sym.decl_index
            }
            i = i - 1
        }
        depth = depth - 1
    }
    0 - 1  // not found
}

// Return the symbol kind for a name, or -1 if not found.
fn lookup_kind(ctx: ResolveCtx, name: String) -> i32 {
    let mut depth = ctx.current_depth
    while depth >= 0 {
        let scope = get_unchecked(ctx.scopes, depth)
        let sym_count = len(scope.symbols)
        let mut i = sym_count - 1
        while i >= 0 {
            let sym = get_unchecked(scope.symbols, i)
            if eq(clone(sym.name), clone(name)) {
                return sym.kind
            }
            i = i - 1
        }
        depth = depth - 1
    }
    0 - 1
}

// Return whether a symbol is marked pub; returns false if not found.
fn lookup_is_pub(ctx: ResolveCtx, name: String) -> bool {
    let mut depth = ctx.current_depth
    while depth >= 0 {
        let scope = get_unchecked(ctx.scopes, depth)
        let sym_count = len(scope.symbols)
        let mut i = sym_count - 1
        while i >= 0 {
            let sym = get_unchecked(scope.symbols, i)
            if eq(clone(sym.name), clone(name)) {
                return sym.is_pub
            }
            i = i - 1
        }
        depth = depth - 1
    }
    false
}

fn resolve_error(ctx: ResolveCtx, msg: String) {
    ctx.error_count = ctx.error_count + 1
    push(ctx.errors, msg)
}

// ── Path Helpers ─────────────────────────────────────────────────────────────
// These helpers extract the module and symbol components of a qualified path
// like "mymod::fn_name".

// Returns the module part of "module::symbol", or the full path if no "::" is found.
fn path_module_part(path: String) -> String {
    let pos = index_of(clone(path), String_from("::"))
    if pos < 0 {
        return clone(path)
    }
    substring(path, 0, pos)
}

// Returns the symbol part of "module::symbol", or an empty string if no "::" is found.
fn path_symbol_part(path: String) -> String {
    let pos = index_of(clone(path), String_from("::"))
    if pos < 0 {
        return String_new()
    }
    substring(path, pos + 2, len(path))
}

// Returns the last segment of a "::" separated path.
// e.g. "std::host::stdio" → "stdio", "std::bytes" → "bytes", "foo" → "foo"
pub fn use_module_short_name(path: String) -> String {
    let n = len(path)
    let mut last_sep = 0 - 1
    let mut i = n - 2  // need at least 2 chars for "::"
    while i >= 0 {
        if eq(substring(path, i, i + 2), String_from("::")) {
            last_sep = i
            i = 0 - 1  // break
        } else {
            i = i - 1
        }
    }
    if last_sep < 0 {
        clone(path)
    } else {
        substring(path, last_sep + 2, n)
    }
}

// Register a single exported symbol from an imported module.
//
// Call this for each pub/private symbol in an imported module before resolving
// the importing module. The qualified name "module_name::symbol_name" is registered
// in the global scope with its visibility.
//
//   is_pub = true  → accessible cross-module (pub fn/struct/enum)
//   is_pub = false → private; resolver will emit a visibility error on access
pub fn register_module_export(ctx: ResolveCtx, module_name: String, symbol_name: String, kind: i32, is_pub: bool) {
    let qualified = concat(clone(module_name), concat(String_from("::"), clone(symbol_name)))
    define_impl(ctx, qualified, kind, is_pub)
}

