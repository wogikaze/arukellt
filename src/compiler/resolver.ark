// Arukellt Selfhost — Resolver (Name Binding and Imports)
//
// Walks the AST and builds a scope chain, binding each identifier
// to its declaration. Reports undefined and duplicate names.

use std::host::stdio

// ── Symbol Tags ──────────────────────────────────────────────────────────────

fn SYM_LOCAL() -> i32 { 1 }
fn SYM_PARAM() -> i32 { 2 }
fn SYM_FN() -> i32 { 3 }
fn SYM_STRUCT() -> i32 { 4 }
fn SYM_ENUM() -> i32 { 5 }
fn SYM_VARIANT() -> i32 { 6 }
fn SYM_IMPORT() -> i32 { 7 }
fn SYM_BUILTIN() -> i32 { 8 }
fn SYM_MODULE() -> i32 { 9 }

// ── Symbol ───────────────────────────────────────────────────────────────────

struct Symbol {
    name: String,
    kind: i32,
    scope_depth: i32,
    decl_index: i32,
    is_mut: bool,
}

fn Symbol_new(name: String, kind: i32, depth: i32, index: i32) -> Symbol {
    Symbol { name: name, kind: kind, scope_depth: depth, decl_index: index, is_mut: false }
}

// ── Scope ────────────────────────────────────────────────────────────────────

struct Scope {
    symbols: Vec<Symbol>,
    parent_depth: i32,
}

fn Scope_new(parent: i32) -> Scope {
    Scope { symbols: Vec_new_Symbol(), parent_depth: parent }
}

// ── Resolve Context ──────────────────────────────────────────────────────────

struct ResolveCtx {
    scopes: Vec<Scope>,
    current_depth: i32,
    error_count: i32,
    errors: Vec<String>,
    next_decl_index: i32,
}

fn ResolveCtx_new() -> ResolveCtx {
    let mut ctx = ResolveCtx {
        scopes: Vec_new_Scope(),
        current_depth: 0,
        error_count: 0,
        errors: Vec_new_String(),
        next_decl_index: 0,
    }
    // Push global scope
    push(ctx.scopes, Scope_new(0 - 1))
    // Register builtins
    register_builtins(ctx)
    ctx
}

fn push_scope(ctx: ResolveCtx) {
    ctx.current_depth = ctx.current_depth + 1
    if ctx.current_depth < len(ctx.scopes) {
        // Reuse existing scope at this depth — clear old symbols
        let scope = get_unchecked(ctx.scopes, ctx.current_depth)
        scope.symbols = Vec_new_Symbol()
    } else {
        push(ctx.scopes, Scope_new(ctx.current_depth - 1))
    }
}

fn pop_scope(ctx: ResolveCtx) {
    ctx.current_depth = ctx.current_depth - 1
}

fn define(ctx: ResolveCtx, name: String, kind: i32) {
    let idx = ctx.next_decl_index
    ctx.next_decl_index = ctx.next_decl_index + 1
    let sym = Symbol_new(clone(name), kind, ctx.current_depth, idx)
    // Add to current scope
    let scope = get_unchecked(ctx.scopes, ctx.current_depth)
    // Check for duplicates at current depth
    let sym_count = len(scope.symbols)
    let mut i = 0
    while i < sym_count {
        let existing = get_unchecked(scope.symbols, i)
        if eq(clone(existing.name), clone(name)) && existing.scope_depth == ctx.current_depth {
            resolve_error(ctx, concat(String_from("duplicate definition: "), clone(name)))
            return
        }
        i = i + 1
    }
    push(scope.symbols, sym)
}

fn lookup(ctx: ResolveCtx, name: String) -> i32 {
    // Search from current scope to global
    let mut depth = ctx.current_depth
    while depth >= 0 {
        let scope = get_unchecked(ctx.scopes, depth)
        let sym_count = len(scope.symbols)
        let mut i = sym_count - 1
        while i >= 0 {
            let sym = get_unchecked(scope.symbols, i)
            if eq(clone(sym.name), clone(name)) {
                return sym.decl_index
            }
            i = i - 1
        }
        depth = depth - 1
    }
    0 - 1  // not found
}

fn resolve_error(ctx: ResolveCtx, msg: String) {
    ctx.error_count = ctx.error_count + 1
    push(ctx.errors, msg)
}

// ── Builtin Registration ─────────────────────────────────────────────────────

fn register_builtins(ctx: ResolveCtx) {
    define(ctx, String_from("println"), SYM_BUILTIN())
    define(ctx, String_from("print"), SYM_BUILTIN())
    define(ctx, String_from("to_string"), SYM_BUILTIN())
    define(ctx, String_from("len"), SYM_BUILTIN())
    define(ctx, String_from("push"), SYM_BUILTIN())
    define(ctx, String_from("get"), SYM_BUILTIN())
    define(ctx, String_from("get_unchecked"), SYM_BUILTIN())
    define(ctx, String_from("concat"), SYM_BUILTIN())
    define(ctx, String_from("substring"), SYM_BUILTIN())
    define(ctx, String_from("clone"), SYM_BUILTIN())
    define(ctx, String_from("eq"), SYM_BUILTIN())
    define(ctx, String_from("char_at"), SYM_BUILTIN())
    define(ctx, String_from("String_from"), SYM_BUILTIN())
    define(ctx, String_from("String_new"), SYM_BUILTIN())
    define(ctx, String_from("Vec_new_i32"), SYM_BUILTIN())
    define(ctx, String_from("Vec_new_String"), SYM_BUILTIN())
    define(ctx, String_from("parse_f64"), SYM_BUILTIN())
    define(ctx, String_from("parse_i32"), SYM_BUILTIN())
    define(ctx, String_from("i32_to_string"), SYM_BUILTIN())
    define(ctx, String_from("i64_to_string"), SYM_BUILTIN())
    define(ctx, String_from("f64_to_string"), SYM_BUILTIN())
    define(ctx, String_from("bool_to_string"), SYM_BUILTIN())
    define(ctx, String_from("char_to_string"), SYM_BUILTIN())
    define(ctx, String_from("push_char"), SYM_BUILTIN())
    define(ctx, String_from("starts_with"), SYM_BUILTIN())
    define(ctx, String_from("args"), SYM_BUILTIN())
    define(ctx, String_from("exit"), SYM_BUILTIN())
    define(ctx, String_from("values"), SYM_BUILTIN())
    define(ctx, String_from("pop"), SYM_BUILTIN())
    define(ctx, String_from("set"), SYM_BUILTIN())
    define(ctx, String_from("is_empty"), SYM_BUILTIN())
    define(ctx, String_from("unwrap"), SYM_BUILTIN())
    define(ctx, String_from("unwrap_or"), SYM_BUILTIN())
    define(ctx, String_from("slice"), SYM_BUILTIN())
    define(ctx, String_from("split"), SYM_BUILTIN())
    define(ctx, String_from("join"), SYM_BUILTIN())
    define(ctx, String_from("reverse_i32"), SYM_BUILTIN())
    define(ctx, String_from("remove_i32"), SYM_BUILTIN())
    define(ctx, String_from("contains"), SYM_BUILTIN())
    define(ctx, String_from("contains_i32"), SYM_BUILTIN())
    define(ctx, String_from("contains_string"), SYM_BUILTIN())
    // Built-in enum variant constructors
    define(ctx, String_from("Some"), SYM_BUILTIN())
    define(ctx, String_from("None"), SYM_BUILTIN())
    define(ctx, String_from("Ok"), SYM_BUILTIN())
    define(ctx, String_from("Err"), SYM_BUILTIN())
    // Modules
    define(ctx, String_from("stdio"), SYM_MODULE())
    define(ctx, String_from("fs"), SYM_MODULE())
    define(ctx, String_from("process"), SYM_MODULE())
    define(ctx, String_from("env"), SYM_MODULE())
}

// ── AST Node Kind Constants (from parser) ────────────────────────────────────

fn NK_INT_LIT() -> i32 { 1 }
fn NK_IDENT() -> i32 { 5 }
fn NK_BINARY() -> i32 { 6 }
fn NK_UNARY() -> i32 { 7 }
fn NK_CALL() -> i32 { 8 }
fn NK_FIELD_ACCESS() -> i32 { 9 }
fn NK_STRUCT_LIT() -> i32 { 11 }
fn NK_IF_EXPR() -> i32 { 13 }
fn NK_MATCH_EXPR() -> i32 { 14 }
fn NK_BLOCK() -> i32 { 20 }
fn NK_ASSIGN() -> i32 { 18 }
fn NK_METHOD_CALL() -> i32 { 21 }
fn NK_LET() -> i32 { 30 }
fn NK_RETURN() -> i32 { 31 }
fn NK_WHILE() -> i32 { 34 }
fn NK_LOOP() -> i32 { 35 }
fn NK_FOR() -> i32 { 36 }
fn NK_EXPR_STMT() -> i32 { 37 }
fn NK_FN_DECL() -> i32 { 50 }
fn NK_STRUCT_DECL() -> i32 { 51 }
fn NK_ENUM_DECL() -> i32 { 52 }
fn NK_USE() -> i32 { 54 }
fn NK_TRAIT_DECL() -> i32 { 55 }
fn NK_IMPL_DECL() -> i32 { 56 }
fn NK_TUPLE() -> i32 { 17 }
fn NK_PAT_IDENT() -> i32 { 70 }
fn NK_PAT_WILDCARD() -> i32 { 71 }
fn NK_PAT_VARIANT() -> i32 { 73 }

// ── AST Node (duplicated from parser for standalone compilation) ─────────────

struct Span {
    start: i32,
    end: i32,
}

struct AstNode {
    kind: i32,
    span: Span,
    text: String,
    int_val: i32,
    float_val: f64,
    op: i32,
    children: Vec<AstNode>,
    type_ann: Vec<AstNode>,
    is_mut: bool,
    is_pub: bool,
}

// ── Resolve Module ───────────────────────────────────────────────────────────

pub fn resolve_module(decls: Vec<AstNode>) -> ResolveCtx {
    let ctx = ResolveCtx_new()
    let count = len(decls)

    // First pass: register all top-level names
    let mut i = 0
    while i < count {
        let d = get_unchecked(decls, i)
        if d.kind == NK_FN_DECL() {
            define(ctx, clone(d.text), SYM_FN())
        } else if d.kind == NK_STRUCT_DECL() {
            define(ctx, clone(d.text), SYM_STRUCT())
        } else if d.kind == NK_ENUM_DECL() {
            define(ctx, clone(d.text), SYM_ENUM())
        } else if d.kind == NK_USE() {
            define(ctx, clone(d.text), SYM_IMPORT())
        }
        i = i + 1
    }

    // Second pass: resolve bodies
    let mut j = 0
    while j < count {
        let d = get_unchecked(decls, j)
        if d.kind == NK_FN_DECL() {
            resolve_fn(ctx, d)
        } else if d.kind == NK_ENUM_DECL() {
            resolve_enum(ctx, d)
        }
        j = j + 1
    }

    ctx
}

fn resolve_fn(ctx: ResolveCtx, node: AstNode) {
    push_scope(ctx)

    // Register parameters
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count - 1 {
        let param = get_unchecked(node.children, i)
        if param.kind == NK_IDENT() {
            define(ctx, clone(param.text), SYM_PARAM())
        }
        i = i + 1
    }

    // Resolve body (last child is block)
    if child_count > 0 {
        let body = get_unchecked(node.children, child_count - 1)
        resolve_node(ctx, body)
    }

    pop_scope(ctx)
}

fn resolve_enum(ctx: ResolveCtx, node: AstNode) {
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let variant = get_unchecked(node.children, i)
        let full_name = concat(clone(node.text), concat(String_from("::"), clone(variant.text)))
        define(ctx, full_name, SYM_VARIANT())
        i = i + 1
    }
}

fn collect_pattern_bindings(ctx: ResolveCtx, pat: AstNode) {
    if pat.kind == NK_PAT_IDENT() {
        define(ctx, clone(pat.text), SYM_LOCAL())
        return
    }
    if pat.kind == NK_PAT_VARIANT() {
        // Recurse into sub-patterns (e.g. Ok(x) has x as a child)
        let child_count = len(pat.children)
        let mut i = 0
        while i < child_count {
            let sub = get_unchecked(pat.children, i)
            collect_pattern_bindings(ctx, sub)
            i = i + 1
        }
        return
    }
    // NK_PAT_WILDCARD, NK_PAT_LITERAL: no bindings
}

fn resolve_node(ctx: ResolveCtx, node: AstNode) {
    if node.kind == NK_IDENT() {
        let idx = lookup(ctx, clone(node.text))
        if idx < 0 {
            // Allow Vec_new_* as implicit builtins
            let name = clone(node.text)
            let name_len = len(name)
            let mut is_builtin = false
            if name_len >= 8 {
                if eq(substring(name, 0, 8), String_from("Vec_new_")) {
                    is_builtin = true
                }
            }
            if !is_builtin {
                resolve_error(ctx, concat(String_from("undefined name: "), clone(node.text)))
            }
        }
        return
    }

    if node.kind == NK_FIELD_ACCESS() {
        // Resolve the receiver (children[0]) but NOT the field name (node.text)
        if len(node.children) > 0 {
            let receiver = get_unchecked(node.children, 0)
            resolve_node(ctx, receiver)
        }
        return
    }

    if node.kind == NK_STRUCT_LIT() {
        // Verify struct name exists, resolve field values but not field names
        let idx = lookup(ctx, clone(node.text))
        if idx < 0 {
            resolve_error(ctx, concat(String_from("undefined struct: "), clone(node.text)))
        }
        let field_count = len(node.children)
        let mut i = 0
        while i < field_count {
            let field = get_unchecked(node.children, i)
            // field.text = field name (don't resolve)
            // field.children[0] = field value (resolve)
            if len(field.children) > 0 {
                let val = get_unchecked(field.children, 0)
                resolve_node(ctx, val)
            }
            i = i + 1
        }
        return
    }

    if node.kind == NK_METHOD_CALL() {
        // Resolve receiver (children[0]) and arguments, but not method name (node.text)
        let child_count = len(node.children)
        if child_count > 0 {
            let receiver = get_unchecked(node.children, 0)
            resolve_node(ctx, receiver)
        }
        let mut i = 1
        while i < child_count {
            let arg = get_unchecked(node.children, i)
            resolve_node(ctx, arg)
            i = i + 1
        }
        return
    }

    if node.kind == NK_LET() {
        // Resolve initializer before defining the binding
        let child_count = len(node.children)
        if child_count > 0 {
            let init = get_unchecked(node.children, 0)
            resolve_node(ctx, init)
        }
        // Skip defining wildcard `_` bindings (they are intentionally unused)
        if !eq(clone(node.text), "_") {
            define(ctx, clone(node.text), SYM_LOCAL())
        }
        return
    }

    if node.kind == NK_BLOCK() {
        push_scope(ctx)
        let child_count = len(node.children)
        let mut i = 0
        while i < child_count {
            let child = get_unchecked(node.children, i)
            resolve_node(ctx, child)
            i = i + 1
        }
        pop_scope(ctx)
        return
    }

    if node.kind == NK_FOR() {
        push_scope(ctx)
        // Resolve iterator
        if len(node.children) > 0 {
            let iter = get_unchecked(node.children, 0)
            resolve_node(ctx, iter)
        }
        // Define loop variable
        define(ctx, clone(node.text), SYM_LOCAL())
        // Resolve body
        if len(node.children) > 1 {
            let body = get_unchecked(node.children, 1)
            resolve_node(ctx, body)
        }
        pop_scope(ctx)
        return
    }

    if node.kind == NK_MATCH_EXPR() {
        // children[0] = scrutinee, rest are arms
        let child_count = len(node.children)
        if child_count > 0 {
            let scrutinee = get_unchecked(node.children, 0)
            resolve_node(ctx, scrutinee)
        }
        let mut arm_idx = 1
        while arm_idx < child_count {
            let arm = get_unchecked(node.children, arm_idx)
            // arm is NK_TUPLE with children[0]=pattern, children[1]=body
            push_scope(ctx)
            if len(arm.children) > 0 {
                let pat = get_unchecked(arm.children, 0)
                collect_pattern_bindings(ctx, pat)
            }
            if len(arm.children) > 1 {
                let body = get_unchecked(arm.children, 1)
                resolve_node(ctx, body)
            }
            pop_scope(ctx)
            arm_idx = arm_idx + 1
        }
        return
    }

    // Default: recurse into children
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let child = get_unchecked(node.children, i)
        resolve_node(ctx, child)
        i = i + 1
    }
}

// ── Dump ─────────────────────────────────────────────────────────────────────

pub fn dump_scope(ctx: ResolveCtx) {
    let scope_count = len(ctx.scopes)
    let mut i = 0
    while i < scope_count {
        let scope = get_unchecked(ctx.scopes, i)
        let sym_count = len(scope.symbols)
        stdio::eprintln(concat(String_from("scope["), concat(to_string(i), concat(String_from("] ("), concat(to_string(sym_count), String_from(" symbols)"))))))
        let mut j = 0
        while j < sym_count {
            let sym = get_unchecked(scope.symbols, j)
            let kind_str = sym_kind_name(sym.kind)
            stdio::eprintln(concat(String_from("  "), concat(kind_str, concat(String_from(" "), clone(sym.name)))))
            j = j + 1
        }
        i = i + 1
    }
    if ctx.error_count > 0 {
        let mut ei = 0
        while ei < len(ctx.errors) {
            stdio::eprintln(concat(String_from("error: "), clone(get_unchecked(ctx.errors, ei))))
            ei = ei + 1
        }
        stdio::eprintln(concat(to_string(ctx.error_count), String_from(" resolve error(s)")))
    }
}

fn sym_kind_name(kind: i32) -> String {
    if kind == SYM_LOCAL() { return String_from("local") }
    if kind == SYM_PARAM() { return String_from("param") }
    if kind == SYM_FN() { return String_from("fn") }
    if kind == SYM_STRUCT() { return String_from("struct") }
    if kind == SYM_ENUM() { return String_from("enum") }
    if kind == SYM_VARIANT() { return String_from("variant") }
    if kind == SYM_IMPORT() { return String_from("import") }
    if kind == SYM_BUILTIN() { return String_from("builtin") }
    if kind == SYM_MODULE() { return String_from("module") }
    String_from("unknown")
}

// ── Entry Point ──────────────────────────────────────────────────────────────

fn main() {
    let ctx = ResolveCtx_new()
    // Test: define and lookup
    define(ctx, String_from("x"), SYM_LOCAL())
    define(ctx, String_from("add"), SYM_FN())

    let idx_x = lookup(ctx, String_from("x"))
    let idx_add = lookup(ctx, String_from("add"))
    let idx_missing = lookup(ctx, String_from("missing"))

    stdio::println(concat(String_from("x found: "), to_string(idx_x >= 0)))
    stdio::println(concat(String_from("add found: "), to_string(idx_add >= 0)))
    stdio::println(concat(String_from("missing found: "), to_string(idx_missing >= 0)))

    // Test scoping
    push_scope(ctx)
    define(ctx, String_from("y"), SYM_LOCAL())
    let idx_y = lookup(ctx, String_from("y"))
    stdio::println(concat(String_from("y found (inner): "), to_string(idx_y >= 0)))
    pop_scope(ctx)

    let idx_y2 = lookup(ctx, String_from("y"))
    stdio::println(concat(String_from("y found (outer): "), to_string(idx_y2 >= 0)))

    stdio::println(String_from("Resolver OK."))
}
