// ── AST Node Kind Constants (from parser) ────────────────────────────────────

fn NK_INT_LIT() -> i32 { 1 }
fn NK_IDENT() -> i32 { 5 }
fn NK_BINARY() -> i32 { 6 }
fn NK_UNARY() -> i32 { 7 }
fn NK_CALL() -> i32 { 8 }
fn NK_FIELD_ACCESS() -> i32 { 9 }
fn NK_PATH() -> i32 { 16 }
fn NK_STRUCT_LIT() -> i32 { 11 }
fn NK_IF_EXPR() -> i32 { 13 }
fn NK_MATCH_EXPR() -> i32 { 14 }
fn NK_BLOCK() -> i32 { 20 }
fn NK_ASSIGN() -> i32 { 18 }
fn NK_METHOD_CALL() -> i32 { 21 }
fn NK_LET() -> i32 { 30 }
fn NK_RETURN() -> i32 { 31 }
fn NK_WHILE() -> i32 { 34 }
fn NK_LOOP() -> i32 { 35 }
fn NK_FOR() -> i32 { 36 }
fn NK_EXPR_STMT() -> i32 { 37 }
fn NK_FN_DECL() -> i32 { 50 }
fn NK_STRUCT_DECL() -> i32 { 51 }
fn NK_ENUM_DECL() -> i32 { 52 }
fn NK_USE() -> i32 { 54 }
fn NK_TRAIT_DECL() -> i32 { 55 }
fn NK_IMPL_DECL() -> i32 { 56 }
fn NK_TUPLE() -> i32 { 17 }
fn NK_PAT_IDENT() -> i32 { 70 }
fn NK_PAT_WILDCARD() -> i32 { 71 }
fn NK_PAT_VARIANT() -> i32 { 73 }

// ── AST Node (duplicated from parser for standalone compilation) ─────────────

struct Span {
    start: i32,
    end: i32,
}

struct AstNode {
    kind: i32,
    span: Span,
    text: String,
    int_val: i32,
    float_val: f64,
    op: i32,
    children: Vec<AstNode>,
    type_ann: Vec<AstNode>,
    is_mut: bool,
    is_pub: bool,
}

// ── Module Declarations (for multi-file resolution) ──────────────────────────

pub struct ModuleDecls {
    name: String,
    decls: Vec<AstNode>,
}

pub fn ModuleDecls_new(name: String, decls: Vec<AstNode>) -> ModuleDecls {
    ModuleDecls { name: name, decls: decls }
}

// ── Resolve Module ───────────────────────────────────────────────────────────

/// Resolve a single module without any imported module declarations.
/// Backward-compatible wrapper; prefer resolve_program for multi-file compilation.
pub fn resolve_module(decls: Vec<AstNode>) -> ResolveCtx {
    resolve_program(decls, Vec_new_ModuleDecls())
}

/// Resolve a program consisting of a main module and zero or more imported modules.
/// Each imported module's pub symbols are registered under "module_name::symbol_name"
/// so that qualified name resolution (e.g. mymath::add) works.
pub fn resolve_program(decls: Vec<AstNode>, modules: Vec<ModuleDecls>) -> ResolveCtx {
    let ctx = ResolveCtx_new()

    // Register symbols from imported modules.
    let mod_count = len(modules)
    let mut mi = 0
    while mi < mod_count {
        let m = get_unchecked(modules, mi)
        // Define the module name in global scope (override the hardcoded builtin if present)
        let existing = lookup(ctx, clone(m.name))
        if existing < 0 {
            define(ctx, clone(m.name), SYM_MODULE())
        }
        // Scan module decls for fn/struct/enum and register them as module exports
        let mdecl_count = len(m.decls)
        let mut di = 0
        while di < mdecl_count {
            let d = get_unchecked(m.decls, di)
            if d.kind == NK_FN_DECL() {
                register_module_export(ctx, clone(m.name), clone(d.text), SYM_FN(), d.is_pub)
            } else if d.kind == NK_STRUCT_DECL() {
                register_module_export(ctx, clone(m.name), clone(d.text), SYM_STRUCT(), d.is_pub)
            } else if d.kind == NK_ENUM_DECL() {
                register_module_export(ctx, clone(m.name), clone(d.text), SYM_ENUM(), d.is_pub)
            }
            di = di + 1
        }
        mi = mi + 1
    }

    let count = len(decls)

    // First pass: register all top-level names, preserving pub/private visibility.
    let mut i = 0
    while i < count {
        let d = get_unchecked(decls, i)
        if d.kind == NK_FN_DECL() {
            define_with_vis(ctx, clone(d.text), SYM_FN(), d.is_pub)
        } else if d.kind == NK_STRUCT_DECL() {
            define_with_vis(ctx, clone(d.text), SYM_STRUCT(), d.is_pub)
        } else if d.kind == NK_ENUM_DECL() {
            define_with_vis(ctx, clone(d.text), SYM_ENUM(), d.is_pub)
        } else if d.kind == NK_IMPL_DECL() {
            // Register each method as StructName::method_name
            let struct_name = clone(d.text)
            let mcount = len(d.children)
            let mut mi = 0
            while mi < mcount {
                let method = get_unchecked(d.children, mi)
                let mangled = concat(clone(struct_name), concat(String_from("::"), clone(method.text)))
                define_with_vis(ctx, mangled, SYM_FN(), d.is_pub)
                mi = mi + 1
            }
        } else if d.kind == NK_USE() {
            let existing_use = lookup(ctx, clone(d.text))
            if existing_use < 0 {
                define(ctx, clone(d.text), SYM_IMPORT())
            }
            // Also register the short name (last path segment) as SYM_MODULE so
            // that qualified paths like `bytes::foo` resolve the module part.
            // If an alias is present (stored in type_ann[0]), use it instead.
            let short_name = if len(d.type_ann) > 0 {
                let alias_node = get_unchecked(d.type_ann, 0)
                clone(alias_node.text)
            } else {
                use_module_short_name(clone(d.text))
            }
            let existing_mod = lookup(ctx, clone(short_name))
            if existing_mod < 0 {
                define(ctx, clone(short_name), SYM_MODULE())
            }
            // Handle destructure children: use base::{a, b, ...}
            let num_children = len(d.children)
            let mut ci = 0
            while ci < num_children {
                let child = get_unchecked(d.children, ci)
                if child.kind == NK_USE() {
                    let existing_child = lookup(ctx, clone(child.text))
                    if existing_child < 0 {
                        define(ctx, clone(child.text), SYM_IMPORT())
                    }
                    let child_short = use_module_short_name(clone(child.text))
                    let existing_child_mod = lookup(ctx, clone(child_short))
                    if existing_child_mod < 0 {
                        define(ctx, clone(child_short), SYM_MODULE())
                    }
                }
                ci = ci + 1
            }
        }
        i = i + 1
    }

    // Second pass: resolve bodies
    let mut j = 0
    while j < count {
        let d = get_unchecked(decls, j)
        if d.kind == NK_FN_DECL() {
            resolve_fn(ctx, d)
        } else if d.kind == NK_ENUM_DECL() {
            resolve_enum(ctx, d)
        } else if d.kind == NK_IMPL_DECL() {
            // Resolve each method body, registering self as a param
            let struct_name = clone(d.text)
            let mcount = len(d.children)
            let mut mi = 0
            while mi < mcount {
                let method = get_unchecked(d.children, mi)
                push_scope(ctx)
                let m_child_count = len(method.children)
                let mut pi = 0
                while pi < m_child_count - 1 {
                    let param = get_unchecked(method.children, pi)
                    if param.kind == NK_IDENT() {
                        define(ctx, clone(param.text), SYM_PARAM())
                    }
                    pi = pi + 1
                }
                if m_child_count > 0 {
                    let m_body = get_unchecked(method.children, m_child_count - 1)
                    resolve_node(ctx, m_body)
                }
                pop_scope(ctx)
                mi = mi + 1
            }
        }
        j = j + 1
    }

    ctx
}

fn resolve_fn(ctx: ResolveCtx, node: AstNode) {
    push_scope(ctx)

    // Register parameters
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count - 1 {
        let param = get_unchecked(node.children, i)
        if param.kind == NK_IDENT() {
            define(ctx, clone(param.text), SYM_PARAM())
        }
        i = i + 1
    }

    // Resolve body (last child is block)
    if child_count > 0 {
        let body = get_unchecked(node.children, child_count - 1)
        resolve_node(ctx, body)
    }

    pop_scope(ctx)
}

fn resolve_enum(ctx: ResolveCtx, node: AstNode) {
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let variant = get_unchecked(node.children, i)
        let full_name = concat(clone(node.text), concat(String_from("::"), clone(variant.text)))
        // Variants inherit the visibility of their parent enum.
        define_with_vis(ctx, full_name, SYM_VARIANT(), node.is_pub)
        i = i + 1
    }
}

fn collect_pattern_bindings(ctx: ResolveCtx, pat: AstNode) {
    if pat.kind == NK_PAT_IDENT() {
        define(ctx, clone(pat.text), SYM_LOCAL())
        return
    }
    if pat.kind == NK_PAT_VARIANT() {
        // Recurse into sub-patterns (e.g. Ok(x) has x as a child)
        let child_count = len(pat.children)
        let mut i = 0
        while i < child_count {
            let sub = get_unchecked(pat.children, i)
            collect_pattern_bindings(ctx, sub)
            i = i + 1
        }
        return
    }
    // NK_PAT_WILDCARD, NK_PAT_LITERAL: no bindings
}

fn resolve_node(ctx: ResolveCtx, node: AstNode) {
    if node.kind == NK_IDENT() {
        let idx = lookup(ctx, clone(node.text))
        if idx < 0 {
            // Allow Vec_new_* as implicit builtins
            let name = clone(node.text)
            let name_len = len(name)
            let mut is_builtin = false
            if name_len >= 8 {
                if eq(substring(name, 0, 8), String_from("Vec_new_")) {
                    is_builtin = true
                }
            }
            if !is_builtin {
                resolve_error(ctx, concat(String_from("undefined name: "), clone(node.text)))
            }
        }
        return
    }

    if node.kind == NK_FIELD_ACCESS() {
        // Resolve the receiver (children[0]) but NOT the field name (node.text)
        if len(node.children) > 0 {
            let receiver = get_unchecked(node.children, 0)
            resolve_node(ctx, receiver)
        }
        return
    }

    if node.kind == NK_PATH() {
        // Cross-module path expression: "module::symbol"
        // 1. Verify the module is in scope.
        // 2. If the qualified name "module::symbol" is pre-registered (via
        //    register_module_export), enforce its visibility: private symbols
        //    from other modules must not be accessed.
        let path = clone(node.text)
        let module_part = path_module_part(clone(path))
        let symbol_part = path_symbol_part(clone(path))

        // Verify the module name is defined.
        let mod_idx = lookup(ctx, clone(module_part))
        if mod_idx < 0 {
            resolve_error(ctx, concat(String_from("undefined module: "), clone(module_part)))
            return
        }

        // Check visibility when the qualified symbol is pre-registered.
        let sym_idx = lookup(ctx, clone(path))
        if sym_idx >= 0 {
            // Enum variants are always accessible when the enum is in scope;
            // skip the visibility check if the left-hand side is an enum type.
            let mod_kind = lookup_kind(ctx, clone(module_part))
            if mod_kind != SYM_ENUM() {
                if !lookup_is_pub(ctx, clone(path)) {
                    resolve_error(ctx, concat(
                        String_from("visibility error: `"),
                        concat(clone(symbol_part),
                        concat(String_from("` is private and cannot be accessed from module `"),
                        concat(clone(module_part), String_from("`"))))
                    ))
                }
            }
        }
        // If sym_idx < 0 the qualified name is not pre-registered (e.g. std:: modules,
        // or the driver did not call register_module_export for this import yet).
        // In that case, access is allowed — graceful degradation until the driver
        // populates the module export table.
        return
    }

    if node.kind == NK_STRUCT_LIT() {
        // Verify struct name exists, resolve field values but not field names
        let idx = lookup(ctx, clone(node.text))
        if idx < 0 {
            resolve_error(ctx, concat(String_from("undefined struct: "), clone(node.text)))
        }
        let field_count = len(node.children)
        let mut i = 0
        while i < field_count {
            let field = get_unchecked(node.children, i)
            // field.text = field name (don't resolve)
            // field.children[0] = field value (resolve)
            if len(field.children) > 0 {
                let val = get_unchecked(field.children, 0)
                resolve_node(ctx, val)
            }
            i = i + 1
        }
        return
    }

    if node.kind == NK_METHOD_CALL() {
        // Resolve receiver (children[0]) and arguments, but not method name (node.text)
        let child_count = len(node.children)
        if child_count > 0 {
            let receiver = get_unchecked(node.children, 0)
            resolve_node(ctx, receiver)
        }
        let mut i = 1
        while i < child_count {
            let arg = get_unchecked(node.children, i)
            resolve_node(ctx, arg)
            i = i + 1
        }
        return
    }

    if node.kind == NK_LET() {
        // Resolve initializer before defining the binding
        let child_count = len(node.children)
        if child_count > 0 {
            let init = get_unchecked(node.children, 0)
            resolve_node(ctx, init)
        }
        // Skip defining wildcard `_` bindings (they are intentionally unused)
        if !eq(clone(node.text), "_") {
            define(ctx, clone(node.text), SYM_LOCAL())
        }
        return
    }

    if node.kind == NK_BLOCK() {
        push_scope(ctx)
        let child_count = len(node.children)
        let mut i = 0
        while i < child_count {
            let child = get_unchecked(node.children, i)
            resolve_node(ctx, child)
            i = i + 1
        }
        pop_scope(ctx)
        return
    }

    if node.kind == NK_FOR() {
        push_scope(ctx)
        // Resolve iterator
        if len(node.children) > 0 {
            let iter = get_unchecked(node.children, 0)
            resolve_node(ctx, iter)
        }
        // Define loop variable
        define(ctx, clone(node.text), SYM_LOCAL())
        // Resolve body
        if len(node.children) > 1 {
            let body = get_unchecked(node.children, 1)
            resolve_node(ctx, body)
        }
        pop_scope(ctx)
        return
    }

    if node.kind == NK_MATCH_EXPR() {
        // children[0] = scrutinee, rest are arms
        let child_count = len(node.children)
        if child_count > 0 {
            let scrutinee = get_unchecked(node.children, 0)
            resolve_node(ctx, scrutinee)
        }
        let mut arm_idx = 1
        while arm_idx < child_count {
            let arm = get_unchecked(node.children, arm_idx)
            // arm is NK_TUPLE with children[0]=pattern, children[1]=body
            push_scope(ctx)
            if len(arm.children) > 0 {
                let pat = get_unchecked(arm.children, 0)
                collect_pattern_bindings(ctx, pat)
            }
            if len(arm.children) > 1 {
                let body = get_unchecked(arm.children, 1)
                resolve_node(ctx, body)
            }
            pop_scope(ctx)
            arm_idx = arm_idx + 1
        }
        return
    }

    // Default: recurse into children
    let child_count = len(node.children)
    let mut i = 0
    while i < child_count {
        let child = get_unchecked(node.children, i)
        resolve_node(ctx, child)
        i = i + 1
    }
}

// ── Dump ─────────────────────────────────────────────────────────────────────

pub fn dump_scope(ctx: ResolveCtx) {
    let scope_count = len(ctx.scopes)
    let mut i = 0
    while i < scope_count {
        let scope = get_unchecked(ctx.scopes, i)
        let sym_count = len(scope.symbols)
        stdio::eprintln(concat(String_from("scope["), concat(to_string(i), concat(String_from("] ("), concat(to_string(sym_count), String_from(" symbols)"))))))
        let mut j = 0
        while j < sym_count {
            let sym = get_unchecked(scope.symbols, j)
            let kind_str = sym_kind_name(sym.kind)
            stdio::eprintln(concat(String_from("  "), concat(kind_str, concat(String_from(" "), clone(sym.name)))))
            j = j + 1
        }
        i = i + 1
    }
    if ctx.error_count > 0 {
        let mut ei = 0
        while ei < len(ctx.errors) {
            stdio::eprintln(concat(String_from("error: "), clone(get_unchecked(ctx.errors, ei))))
            ei = ei + 1
        }
        stdio::eprintln(concat(to_string(ctx.error_count), String_from(" resolve error(s)")))
    }
}

fn sym_kind_name(kind: i32) -> String {
    if kind == SYM_LOCAL() { return String_from("local") }
    if kind == SYM_PARAM() { return String_from("param") }
    if kind == SYM_FN() { return String_from("fn") }
    if kind == SYM_STRUCT() { return String_from("struct") }
    if kind == SYM_ENUM() { return String_from("enum") }
    if kind == SYM_VARIANT() { return String_from("variant") }
    if kind == SYM_IMPORT() { return String_from("import") }
    if kind == SYM_BUILTIN() { return String_from("builtin") }
    if kind == SYM_MODULE() { return String_from("module") }
    String_from("unknown")
}

// ── Entry Point ──────────────────────────────────────────────────────────────

fn main() {
    let ctx = ResolveCtx_new()
    // Test: define and lookup
    define(ctx, String_from("x"), SYM_LOCAL())
    define(ctx, String_from("add"), SYM_FN())

    let idx_x = lookup(ctx, String_from("x"))
    let idx_add = lookup(ctx, String_from("add"))
    let idx_missing = lookup(ctx, String_from("missing"))

    stdio::println(concat(String_from("x found: "), to_string(idx_x >= 0)))
    stdio::println(concat(String_from("add found: "), to_string(idx_add >= 0)))
    stdio::println(concat(String_from("missing found: "), to_string(idx_missing >= 0)))

    // Test scoping
    push_scope(ctx)
    define(ctx, String_from("y"), SYM_LOCAL())
    let idx_y = lookup(ctx, String_from("y"))
    stdio::println(concat(String_from("y found (inner): "), to_string(idx_y >= 0)))
    pop_scope(ctx)

    let idx_y2 = lookup(ctx, String_from("y"))
    stdio::println(concat(String_from("y found (outer): "), to_string(idx_y2 >= 0)))

    stdio::println(String_from("Resolver OK."))

    // ── Visibility Enforcement Tests ─────────────────────────────────────────
    // Test that cross-module visibility is enforced:
    //   - pub symbols are accessible (no error)
    //   - private symbols produce a visibility error

    let vctx = ResolveCtx_new()
    // Register "mymod" as an imported module
    define(vctx, String_from("mymod"), SYM_IMPORT())
    // Register exports: one pub, one private
    register_module_export(vctx, String_from("mymod"), String_from("pub_fn"), SYM_FN(), true)
    register_module_export(vctx, String_from("mymod"), String_from("priv_fn"), SYM_FN(), false)

    // Build a NK_PATH node for "mymod::pub_fn" and resolve it — should not add an error.
    let pub_node = AstNode {
        kind: NK_PATH(),
        span: Span { start: 0, end: 0 },
        text: String_from("mymod::pub_fn"),
        int_val: 0,
        float_val: 0.0,
        op: 0,
        children: Vec_new_AstNode(),
        type_ann: Vec_new_AstNode(),
        is_mut: false,
        is_pub: false,
    }
    let errors_before_pub = vctx.error_count
    resolve_node(vctx, pub_node)
    let pub_ok = vctx.error_count == errors_before_pub
    stdio::println(concat(String_from("pub access OK: "), bool_to_string(pub_ok)))

    // Build a NK_PATH node for "mymod::priv_fn" and resolve it — should add one error.
    let priv_node = AstNode {
        kind: NK_PATH(),
        span: Span { start: 0, end: 0 },
        text: String_from("mymod::priv_fn"),
        int_val: 0,
        float_val: 0.0,
        op: 0,
        children: Vec_new_AstNode(),
        type_ann: Vec_new_AstNode(),
        is_mut: false,
        is_pub: false,
    }
    let errors_before_priv = vctx.error_count
    resolve_node(vctx, priv_node)
    let priv_blocked = vctx.error_count > errors_before_priv
    stdio::println(concat(String_from("private access blocked: "), bool_to_string(priv_blocked)))

    // Build a NK_PATH for an unregistered path — should succeed (graceful degradation).
    let unknown_node = AstNode {
        kind: NK_PATH(),
        span: Span { start: 0, end: 0 },
        text: String_from("mymod::unknown_fn"),
        int_val: 0,
        float_val: 0.0,
        op: 0,
        children: Vec_new_AstNode(),
        type_ann: Vec_new_AstNode(),
        is_mut: false,
        is_pub: false,
    }
    let errors_before_unknown = vctx.error_count
    resolve_node(vctx, unknown_node)
    let unknown_ok = vctx.error_count == errors_before_unknown
    stdio::println(concat(String_from("unregistered access OK (graceful): "), bool_to_string(unknown_ok)))

    stdio::println(String_from("Visibility OK."))

    // ── Module Import Resolution Tests ───────────────────────────────────────
    // Test resolve_program: register imported module declarations and verify
    // qualified name resolution works.

    let mut mod_decls: Vec<AstNode> = Vec_new_AstNode()
    // Simulate a pub fn "add" in module "mymath"
    let add_fn = AstNode {
        kind: NK_FN_DECL(),
        span: Span { start: 0, end: 0 },
        text: String_from("add"),
        int_val: 0,
        float_val: 0.0,
        op: 0,
        children: Vec_new_AstNode(),
        type_ann: Vec_new_AstNode(),
        is_mut: false,
        is_pub: true,
    }
    push(mod_decls, add_fn)
    // Simulate a private fn "internal" in module "mymath"
    let priv_fn_decl = AstNode {
        kind: NK_FN_DECL(),
        span: Span { start: 0, end: 0 },
        text: String_from("internal"),
        int_val: 0,
        float_val: 0.0,
        op: 0,
        children: Vec_new_AstNode(),
        type_ann: Vec_new_AstNode(),
        is_mut: false,
        is_pub: false,
    }
    push(mod_decls, priv_fn_decl)

    let mut modules: Vec<ModuleDecls> = Vec_new_ModuleDecls()
    push(modules, ModuleDecls_new(String_from("mymath"), mod_decls))

    // Main module: use mymath, call mymath::add
    let mut main_decls: Vec<AstNode> = Vec_new_AstNode()
    let use_node = AstNode {
        kind: NK_USE(),
        span: Span { start: 0, end: 0 },
        text: String_from("mymath"),
        int_val: 0,
        float_val: 0.0,
        op: 0,
        children: Vec_new_AstNode(),
        type_ann: Vec_new_AstNode(),
        is_mut: false,
        is_pub: false,
    }
    push(main_decls, use_node)

    let mctx = resolve_program(main_decls, modules)

    // mymath::add should be resolvable
    let add_idx = lookup(mctx, String_from("mymath::add"))
    let add_found = add_idx >= 0
    stdio::println(concat(String_from("mymath::add resolved: "), bool_to_string(add_found)))

    // mymath::add should be pub
    let add_pub = lookup_is_pub(mctx, String_from("mymath::add"))
    stdio::println(concat(String_from("mymath::add is pub: "), bool_to_string(add_pub)))

    // mymath::internal should be registered but private
    let internal_idx = lookup(mctx, String_from("mymath::internal"))
    let internal_found = internal_idx >= 0
    stdio::println(concat(String_from("mymath::internal registered: "), bool_to_string(internal_found)))
    let internal_pub = lookup_is_pub(mctx, String_from("mymath::internal"))
    let internal_private = !internal_pub
    stdio::println(concat(String_from("mymath::internal is private: "), bool_to_string(internal_private)))

    // Module "mymath" itself should be in scope
    let mod_kind = lookup_kind(mctx, String_from("mymath"))
    let mod_is_module = mod_kind == SYM_MODULE()
    stdio::println(concat(String_from("mymath is SYM_MODULE: "), bool_to_string(mod_is_module)))

    stdio::println(String_from("Module Import OK."))
}
