// Arukellt Selfhost — Wasm Binary Emitter: Writer Utilities
//
// Extracted from emitter.ark for module-level organization.
// Contains WasmWriter struct, LEB128 encoding, and basic binary emission.
//
// All functions are pub for cross-module access.

// ── Binary Writer ────────────────────────────────────────────────────────────
pub struct WasmWriter {
    bytes: Vec<i32>,
}

pub fn WasmWriter_new() -> WasmWriter {
    WasmWriter { bytes: Vec_new_i32() }
}

pub fn emit_byte(w: WasmWriter, b: i32) {
    push(w.bytes, b % 256)
}

pub fn emit_u32_le(w: WasmWriter, v: i32) {
    emit_byte(w, v % 256)
    emit_byte(w, v / 256 % 256)
    emit_byte(w, v / 65536 % 256)
    emit_byte(w, v / 16777216 % 256)
}

pub fn emit_leb128_u(w: WasmWriter, v: i32) {
    let mut val = v
    if val < 0 {
        val = 0
    }
    let mut done = false
    while !done {
        let mut b = val % 128
        val = val / 128
        if val != 0 {
            b = b + 128
        }
        emit_byte(w, b)
        if val == 0 {
            done = true
        }
    }
}

pub fn emit_leb128_s(w: WasmWriter, v: i32) {
    let mut val = v
    let mut more = true
    while more {
        let raw_mod = val % 128
        let mut b = raw_mod
        if b < 0 {
            b = b + 128
        }
        val = val / 128
        if raw_mod < 0 {
            val = val - 1
        }
        if val == 0 && b < 64 || val == 0 - 1 && b >= 64 {
            more = false
        } else {
            b = b + 128
        }
        emit_byte(w, b % 256)
    }
}

pub fn emit_leb128_s_i64(w: WasmWriter, v: i64) {
    let mut val = v
    let mut more = true
    while more {
        let raw_mod = i64_to_i32(val % 128)
        let mut b = raw_mod
        if b < 0 {
            b = b + 128
        }
        val = val / 128
        if raw_mod < 0 {
            val = val - 1
        }
        if val == 0 && b < 64 || val == 0 - 1 && b >= 64 {
            more = false
        } else {
            b = b + 128
        }
        emit_byte(w, b % 256)
    }
}

// Parse a decimal integer string as i64 (mirrors parse_decimal_as_i64 in mir.ark).
pub fn parse_decimal_as_i64_emitter(text: String) -> i64 {
    let n = len(text)
    let mut result: i64 = 0
    let mut i = 0
    let mut neg = false
    if i < n && char_at(text, i) == 45 {
        neg = true
        i = i + 1
    }
    let mut stop = false
    while i < n && !stop {
        let d = char_at(text, i)
        if d >= 48 && d <= 57 {
            result = result * 10 + i32_to_i64(d - 48)
        } else {
            if d == 95 {
            } else {
                stop = true
            }
        }
        i = i + 1
    }
    if neg {
        result = 0 - result
    }
    result
}

pub fn emit_bytes(w: WasmWriter, src: Vec<i32>) {
    let count = len(src)
    let mut i = 0
    while i < count {
        let b = get_unchecked(src, i)
        emit_byte(w, b)
        i = i + 1
    }
}

pub fn emit_f64(w: WasmWriter, val: f64) {
    let lo: i32 = f64_bits_lo(val)
    let hi: i32 = f64_bits_hi(val)
    emit_u32_le(w, lo)
    emit_u32_le(w, hi)
}

pub fn emit_string(w: WasmWriter, s: String) {
    let slen = len(s)
    emit_leb128_u(w, slen)
    let mut i = 0
    while i < slen {
        emit_byte(w, char_at(s, i))
        i = i + 1
    }
}

pub fn writer_size(w: WasmWriter) -> i32 {
    len(w.bytes)
}

// ── Section Writer ───────────────────────────────────────────────────────────
pub fn emit_section(out: WasmWriter, section_id: i32, contents: WasmWriter) {
    emit_byte(out, section_id)
    emit_leb128_u(out, writer_size(contents))
    emit_bytes(out, contents.bytes)
}
