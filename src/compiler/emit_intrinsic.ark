// Handler for: bool_to_string, text::format_bool, convert::bool_to_string
pub fn emit_bool_to_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                let s_tmp = ctx.scratch_base + 2
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                emit_writer::emit_leb128_u(w, s_tmp)
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                emit_writer::emit_leb128_u(w, s_tmp)
                                                                                                                                emit_writer::emit_byte(w, 4)
                                                                                                                                emit_writer::emit_byte(w, 127)
                                                                                                                                let true_offset = get_unchecked(ctx.string_offsets, ctx.true_str_idx)
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                emit_writer::emit_leb128_s(w, true_offset)
                                                                                                                                emit_writer::emit_byte(w, 5)
                                                                                                                                let false_offset = get_unchecked(ctx.string_offsets, ctx.false_str_idx)
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                emit_writer::emit_leb128_s(w, false_offset)
                                                                                                                                emit_writer::emit_byte(w, 11)
    true
}

