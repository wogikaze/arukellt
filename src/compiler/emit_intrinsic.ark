// Handler for: product_i32
pub fn emit_product_i32(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                    let s0 = ctx.scratch_base + 0
