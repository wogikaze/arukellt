// Handler for: char_to_string
pub fn emit_char_to_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                    let s_tmp = ctx.scratch_base + 2
                                                                                                                                                                                                                                                    let s_alloc = ctx.scratch_base + 3
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_tmp)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_alloc)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 5)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_alloc)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_alloc)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_tmp)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 58)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_alloc)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
    true
}

// Handler for: push_char
pub fn emit_push_char(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                        let s_char = ctx.scratch_base
                                                                                                                                                                                                                                                        let s_str = ctx.scratch_base + 1
                                                                                                                                                                                                                                                        let s_len = ctx.scratch_base + 2
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_char)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_len)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_len)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_char)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 58)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_len)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
    true
}

