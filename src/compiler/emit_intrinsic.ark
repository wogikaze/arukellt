pub fn emit_f64_bits_hi(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                let f_tmp2 = ctx.scratch_base + 12
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, f_tmp2)
                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_I32BUF())
