// Handler for: env::arg_count
pub fn emit_env_arg_count(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_ARGC())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_ARGV_SIZE())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_CALL())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 1)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_DROP())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_ARGC())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
    true
}

// Handler for: env::args
pub fn emit_env_args(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_ARGC())
