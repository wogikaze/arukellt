                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_PF_RESULT())
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_F64_LOAD())
                                                                                                                                                                                                            emit_writer::emit_byte(w, 3)
                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_F64_STORE())
                                                                                                                                                                                                            emit_writer::emit_byte(w, 3)
                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 12)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_END())
    true
}

// Handler for: fs::exists
pub fn emit_fs_exists(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                let s_ex = ctx.scratch_base + 2
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ex)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 3)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ex)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ex)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I64_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 2)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I64_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_FS_FD())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_CALL())
                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 3)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_EQ())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::WASM_I32())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_FS_FD())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_CALL())
                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 5)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_DROP())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_ELSE())
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_END())
    true
}

// Handler for: fs::read_to_string
pub fn emit_fs_read_to_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                    let s_path = ctx.scratch_base + 2
                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_path)
                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_FS_PATHPTR())
