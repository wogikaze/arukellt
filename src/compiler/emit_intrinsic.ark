                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 255)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_AND())
    true
}

// Handler for: u32_to_u64
pub fn emit_u32_to_u64(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I64_EXTEND_I32_U())
