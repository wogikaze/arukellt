pub fn emit_range_len(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                let s_range = ctx.scratch_base + 0
