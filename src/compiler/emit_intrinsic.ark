                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_END())
