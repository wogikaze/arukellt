    true
}

// Handler for: vec_get_unchecked, get_unchecked
pub fn emit_get_unchecked(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                            let s_idx = ctx.scratch_base
                                                                                                                                                                                                                                                                            let s_vec2 = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_idx)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_vec2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_vec2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_idx)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
    true
}

