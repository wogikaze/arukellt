// Handler for: fs::write_string
pub fn emit_fs_write_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                        let s_path_w = ctx.scratch_base + 2
                                                                                                                                                                                                                        let s_content = ctx.scratch_base + 3
                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
