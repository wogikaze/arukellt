                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOOP())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_i)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_len)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_BR_IF())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 1)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_data)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_i)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_data)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_i)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_i)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_i)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_BR())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 11)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 11)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_vec)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_len)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_rm_vec)
    true
}

// Handler for: String_new
pub fn emit_String_new(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                    let s_str_base = ctx.scratch_base
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str_base)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str_base)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str_base)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str_base)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
    true
}

// Handler for: slice, substring, text::slice_bytes
pub fn emit_slice(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                        let s_sl_end = ctx.scratch_base
                                                                                                                                                                                                                                                                                                                                                        let s_sl_start = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                        let s_sl_src = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                                        let s_sl_base = ctx.scratch_base + 3
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_end)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_start)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_src)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_base)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_base)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_end)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_start)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_base)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_src)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_start)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_end)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_start)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 252)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 10)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_base)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_end)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_start)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 3)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, -4)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_AND())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_sl_base)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
    true
}

// Handler for: join, text::join
pub fn emit_join(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                            let s_sep = ctx.scratch_base
                                                                                                                                                                                                                                                                                                                                                            let s_jvec = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                            let s_jlen = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                                            let s_jdata = ctx.scratch_base + 3
                                                                                                                                                                                                                                                                                                                                                            let s_ji = ctx.scratch_base + 4
                                                                                                                                                                                                                                                                                                                                                            let s_jbase = ctx.scratch_base + 5
                                                                                                                                                                                                                                                                                                                                                            let s_jdst = ctx.scratch_base + 6
                                                                                                                                                                                                                                                                                                                                                            let s_sep_len = ctx.scratch_base + 7
                                                                                                                                                                                                                                                                                                                                                            let s_str_p = ctx.scratch_base + 8
                                                                                                                                                                                                                                                                                                                                                            let s_str_l = ctx.scratch_base + 9
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_sep)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jvec)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jvec)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jlen)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jvec)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jdata)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_sep)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_sep_len)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jbase)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jbase)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jdst)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_ji)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_BLOCK())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOOP())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_ji)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_jlen)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_BR_IF())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 1)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_ji)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_GT_S())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 64)
