// Handler for: fs::write_bytes
pub fn emit_fs_write_bytes(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                            let s_bvec = ctx.scratch_base + 0
                                                                                                                                                                                                                            let s_path3 = ctx.scratch_base + 1
                                                                                                                                                                                                                            let s_bdata = ctx.scratch_base + 2
                                                                                                                                                                                                                            let s_bcount = ctx.scratch_base + 3
                                                                                                                                                                                                                            let s_bbuf = ctx.scratch_base + 4
                                                                                                                                                                                                                            let s_bi = ctx.scratch_base + 5
                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_bvec)
                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
