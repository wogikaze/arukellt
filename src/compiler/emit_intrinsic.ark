                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_DIV_S())
