pub fn emit_i64_to_i32(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_WRAP_I64())
    true
}

