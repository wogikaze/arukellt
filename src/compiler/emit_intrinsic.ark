                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 28)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                            let err_msg64 = "parse error: invalid integer"
                                                                                                                                                                                                                                                                                                                                                                            let err_len64 = len(err_msg64)
                                                                                                                                                                                                                                                                                                                                                                            let mut ei64 = 0
                                                                                                                                                                                                                                                                                                                                                                            while ei64 < err_len64 {
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s64_base)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4 + ei64)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                                let ch64 = char_at(err_msg64, ei64)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, ch64)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 58)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                ei64 = ei64 + 1
                                                                                                                                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                                                                                                                                            let s64_str_ptr = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s64_base)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s64_str_ptr)
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s64_base)
