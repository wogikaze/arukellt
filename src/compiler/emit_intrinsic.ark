// Handler for: reverse_String
pub fn emit_reverse_String(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                let s0 = ctx.scratch_base + 0
