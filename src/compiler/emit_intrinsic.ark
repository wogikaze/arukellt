pub fn emit_ends_with(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let s0 = ctx.scratch_base + 0
