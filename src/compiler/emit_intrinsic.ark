// Handler for: clamp_i32, math::clamp, clamp
pub fn emit_clamp(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    let s0 = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    let s1 = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    let s2 = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_LT_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s1)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_GT_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s0)
    true
}

// Handler for: core::range_new, range_new
pub fn emit_range_new(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let s_start = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        let s_end = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_end)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_start)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_start)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_end)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
    true
}

// Handler for: core::range_contains, range_contains
pub fn emit_range_contains(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            let s_range = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            let s_val = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_range)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LT_S())
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_AND())
    true
}

