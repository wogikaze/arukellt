                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s1)
    true
}

// Handler for: seq::count_eq
