                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, emit_scratch::SCRATCH_IOV() + 4)
                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, emit_scratch::FS_BUF_SIZE())
