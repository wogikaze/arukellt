// Arukellt Selfhost — Type Checker
//
// Performs type inference, unification, and generates typed HIR.
// Uses a substitution-based unification approach.
use std::host::stdio

fn TY_UNKNOWN() -> i32 {
    0
}

// ── Node Kind Tags (from parser.ark) ─────────────────────────────────────────
fn NK_INT_LIT() -> i32 {
    1
}

fn NK_FLOAT_LIT() -> i32 {
    2
}

fn NK_STRING_LIT() -> i32 {
    3
}

fn NK_BOOL_LIT() -> i32 {
    4
}

fn NK_IDENT() -> i32 {
    5
}

fn NK_BINARY() -> i32 {
    6
}

fn NK_UNARY() -> i32 {
    7
}

fn NK_CALL() -> i32 {
    8
}

fn NK_METHOD_CALL() -> i32 {
    21
}

fn NK_CLOSURE() -> i32 {
    15
}

fn NK_BLOCK() -> i32 {
    20
}

fn NK_LET() -> i32 {
    30
}

fn NK_RETURN() -> i32 {
    31
}

fn NK_WHILE() -> i32 {
    34
}

fn NK_FOR() -> i32 {
    36
}

fn NK_EXPR_STMT() -> i32 {
    37
}

fn NK_COMPREHENSION() -> i32 {
    38
}

fn NK_FN_DECL() -> i32 {
    50
}

fn NK_IMPL_DECL() -> i32 {
    56
}

fn NK_IF_EXPR() -> i32 {
    13
}

fn NK_ASSIGN() -> i32 {
    18
}

fn NK_MATCH_EXPR() -> i32 {
    14
}

fn NK_MATCH_ARM() -> i32 {
    26
}

// ── Pattern Kind Tags (from parser.ark) ──────────────────────────────────────
fn NK_PAT_WILDCARD() -> i32 {
    71
}

fn NK_PAT_IDENT() -> i32 {
    70
}

fn NK_PAT_LITERAL() -> i32 {
    72
}

// ── Operator Tags (from parser.ark) ──────────────────────────────────────────
fn OP_ADD() -> i32 {
    1
}

