use compiler::phases
use driver::errors_phase
use driver::result_record

pub fn parse_errors_result(source: String, source_file: String, errors: Vec<Diagnostic>) -> CompileResult {
    let parse_error_count = len(errors)
    let mut result = result_record::CompileResult_new(false, phases::PHASE_PARSE(), parse_error_count, Vec_new_String(), Vec_new_Diagnostic(), Vec_new_i32())
    let mut k = 0
    while k < parse_error_count {
        let diag = get_unchecked(errors, k)
        result_record::compile_result_push_diagnostic(result, diag)
        result_record::compile_result_push_error_message(result, errors_phase::enrich_diagnostic(clone(source), clone(source_file), diag))
        k = k + 1
    }
    result_record::compile_result_set_error_count(result, parse_error_count)
    result
}
