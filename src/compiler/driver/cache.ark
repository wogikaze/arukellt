// Arukellt Selfhost - whole-program compilation cache (fingerprint computation).

use driver::config_record
use loader::module_state_modules
use std::core::hash

// Compute a fingerprint combining main source, all module source hashes,
// and compilation config (target, opt_level, emit_mode, wasi_version).
// Returns a non-negative i32 hash that uniquely identifies the compilation
// input.  Two compilations with the same fingerprint will produce identical
// output, so the external driver can safely cache the result.
pub fn compute_program_fingerprint(source: String, modules: Vec<ModuleDecls>, config: DriverConfig) -> i32 {
    let mut h = hash::hash_string(clone(source))
    let module_count = len(modules)
    let mut i = 0
    while i < module_count {
        let mod_decls = get_unchecked(modules, i)
        h = hash::combine(h, module_state_modules::ModuleDecls_source_hash(mod_decls))
        i = i + 1
    }
    h = hash::combine(h, hash::hash_string(config_record::config_target(config)))
    h = hash::combine(h, config_record::config_opt_level(config))
    h = hash::combine(h, hash::hash_string(config_record::config_emit_mode(config)))
    h = hash::combine(h, hash::hash_string(config_record::config_wasi_version(config)))
    h
}
