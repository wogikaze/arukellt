// Arukellt Selfhost - driver configuration data contract.

struct DriverConfig {
    target: String,
    wasi_version: String,
    opt_level: i32,
    emit_mode: String,
    wit_paths: Vec<String>,
    dump_tokens: bool,
    dump_ast: bool,
    dump_hir: bool,
    dump_mir: bool,
    dump_wasm: bool,
    parse_only: bool,
    check_only: bool,
    source_dir: String,
    source_file: String,
    show_timing: bool,
}

fn DriverConfig_new(target: String, wasi_version: String, opt_level: i32, emit_mode: String, wit_paths: Vec<String>, dump_tokens: bool, dump_ast: bool, dump_hir: bool, dump_mir: bool, dump_wasm: bool, parse_only: bool, check_only: bool, source_dir: String, source_file: String, show_timing: bool) -> DriverConfig {
    DriverConfig { target: target, wasi_version: wasi_version, opt_level: opt_level, emit_mode: emit_mode, wit_paths: wit_paths, dump_tokens: dump_tokens, dump_ast: dump_ast, dump_hir: dump_hir, dump_mir: dump_mir, dump_wasm: dump_wasm, parse_only: parse_only, check_only: check_only, source_dir: source_dir, source_file: source_file, show_timing: show_timing }
}

fn DriverConfig_default() -> DriverConfig {
    DriverConfig_new(String_from("wasm32-wasi-p2"), String_from("p2"), 0, String_from("wasm"), Vec_new_String(), false, false, false, false, false, false, false, String_from("."), String_new(), false)
}

fn config_target(config: DriverConfig) -> String { clone(config.target) }
fn config_wasi_version(config: DriverConfig) -> String { clone(config.wasi_version) }
fn config_opt_level(config: DriverConfig) -> i32 { config.opt_level }
fn config_emit_mode(config: DriverConfig) -> String { clone(config.emit_mode) }
fn config_wit_paths(config: DriverConfig) -> Vec<String> { clone(config.wit_paths) }
fn config_dump_tokens(config: DriverConfig) -> bool { config.dump_tokens }
fn config_dump_ast(config: DriverConfig) -> bool { config.dump_ast }
fn config_dump_hir(config: DriverConfig) -> bool { config.dump_hir }
fn config_dump_mir(config: DriverConfig) -> bool { config.dump_mir }
fn config_dump_wasm(config: DriverConfig) -> bool { config.dump_wasm }
fn config_show_timing(config: DriverConfig) -> bool { config.show_timing }
fn config_parse_only(config: DriverConfig) -> bool { config.parse_only }
fn config_check_only(config: DriverConfig) -> bool { config.check_only }
fn config_source_dir(config: DriverConfig) -> String { clone(config.source_dir) }
fn config_source_file(config: DriverConfig) -> String { clone(config.source_file) }
fn config_set_wasi_version(config: DriverConfig, wasi_version: String) { config.wasi_version = wasi_version }
fn config_set_target(config: DriverConfig, target: String) { config.target = target }
fn config_set_opt_level(config: DriverConfig, opt_level: i32) { config.opt_level = opt_level }
fn config_set_emit_mode(config: DriverConfig, emit_mode: String) { config.emit_mode = emit_mode }
fn config_set_wit_paths(config: DriverConfig, wit_paths: Vec<String>) { config.wit_paths = wit_paths }
fn config_set_dump_tokens(config: DriverConfig, dump_tokens: bool) { config.dump_tokens = dump_tokens }
fn config_set_dump_ast(config: DriverConfig, dump_ast: bool) { config.dump_ast = dump_ast }
fn config_set_dump_hir(config: DriverConfig, dump_hir: bool) { config.dump_hir = dump_hir }
fn config_set_dump_mir(config: DriverConfig, dump_mir: bool) { config.dump_mir = dump_mir }
fn config_set_dump_wasm(config: DriverConfig, dump_wasm: bool) { config.dump_wasm = dump_wasm }
fn config_set_show_timing(config: DriverConfig, show_timing: bool) { config.show_timing = show_timing }
fn config_set_parse_only(config: DriverConfig, parse_only: bool) { config.parse_only = parse_only }
fn config_set_check_only(config: DriverConfig, check_only: bool) { config.check_only = check_only }
fn config_set_source_dir(config: DriverConfig, source_dir: String) { config.source_dir = source_dir }
fn config_set_source_file(config: DriverConfig, source_file: String) { config.source_file = source_file }
