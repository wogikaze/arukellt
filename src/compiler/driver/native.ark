fn string_to_bytes(text: String) -> Vec<i32> {
    let out = Vec_new_i32()
    let text_len = len(text)
    let mut i = 0
    while i < text_len {
        push(out, char_at(text, i))
        i = i + 1
    }
    out
}

pub fn emit_native_scaffold(_mir: MirModule, _target: String) -> Vec<i32> {
    let asm = String_from("; Arukellt T4 native scaffold (#641)\n")
    let asm = concat(asm, String_from(".text\n"))
    let asm = concat(asm, String_from(".globl main\n"))
    let asm = concat(asm, String_from("main:\n"))
    let asm = concat(asm, String_from("    xor %eax, %eax\n"))
    let asm = concat(asm, String_from("    ret\n"))
    string_to_bytes(asm)
}
