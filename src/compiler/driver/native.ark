pub fn native_output_bytes_from_string(text: String) -> Vec<i32> {
    let out = Vec_new_i32()
    let text_len = len(text)
    let mut i = 0
    while i < text_len {
        push(out, char_at(text, i))
        i = i + 1
    }
    out
}

pub fn emit_native_llvm_scaffold(_mir: MirModule) -> Vec<i32> {
    let asm = String_from("; Arukellt native-llvm scaffold (#641)\n")
    let asm = concat(asm, String_from(".text\n"))
    let asm = concat(asm, String_from(".globl main\n"))
    let asm = concat(asm, String_from("main:\n"))
    let asm = concat(asm, String_from("    xor %eax, %eax\n"))
    let asm = concat(asm, String_from("    ret\n"))
    native_output_bytes_from_string(asm)
}
