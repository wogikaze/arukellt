// Arukellt Selfhost - phase error result builders.

use compiler::phases
use driver::result_record
use std::host::stdio

pub fn module_loading_errors_result(errors: Vec<String>) -> CompileResult {
    let mut result = result_record::CompileResult_err(phases::PHASE_RESOLVE(), String_from("module loading error(s)"))
    let mut le = 0
    while le < len(errors) {
        result_record::compile_result_push_error_message(result, clone(get_unchecked(errors, le)))
        le = le + 1
    }
    result_record::compile_result_set_error_count(result, len(errors))
    result
}

pub fn resolve_errors_result(error_count: i32, errors: Vec<String>) -> CompileResult {
    let mut result = result_record::CompileResult_err(phases::PHASE_RESOLVE(), concat(to_string(error_count), String_from(" resolve error(s)")))
    let mut ei = 0
    while ei < len(errors) {
        result_record::compile_result_push_error_message(result, clone(get_unchecked(errors, ei)))
        ei = ei + 1
    }
    result_record::compile_result_set_error_count(result, error_count)
    result
}

pub fn type_errors_result(error_count: i32, errors: Vec<String>) -> CompileResult {
    let mut result = result_record::CompileResult_err(phases::PHASE_TYPECHECK(), concat(to_string(error_count), String_from(" type error(s)")))
    stdio::eprintln(concat(String_from("DBG errvec len="), to_string(len(errors))))
    let mut ei = 0
    while ei < len(errors) {
        stdio::eprintln(concat(String_from("DBG type err: "), clone(get_unchecked(errors, ei))))
        result_record::compile_result_push_error_message(result, clone(get_unchecked(errors, ei)))
        ei = ei + 1
    }
    result_record::compile_result_set_error_count(result, error_count)
    result
}
