// Handler for: trim_end, text::trim_end
pub fn emit_trim_end(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                let s0 = ctx.scratch_base + 0
