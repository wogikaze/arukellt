// Handler for: text::is_empty
pub fn emit_text_is_empty(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                        let s0 = ctx.scratch_base + 0
                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                        emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                        emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_EQZ())
    true
}


// Handler for: text::len_bytes
pub fn emit_text_len_bytes(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                            let s0 = ctx.scratch_base + 0
                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                            emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                            emit_writer::emit_leb128_u(w, s0)
                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                            emit_writer::emit_byte(w, 0)
    true
}


// Handler for: char_at
pub fn emit_char_at(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                let s_ca_str = ctx.scratch_base + 0
                                                                                                                                                                                let s_ca_i = ctx.scratch_base + 1
                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ca_i)
                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ca_str)
                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ca_str)
                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_ca_i)
                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD8_U())
                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                emit_writer::emit_byte(w, 0)
    true
}


// Handler for: pad_left, text::pad_left
pub fn emit_pad_left(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                    let s_str = ctx.scratch_base + 0
                                                                                                                                                                                    let s_width = ctx.scratch_base + 1
                                                                                                                                                                                    let s_fill = ctx.scratch_base + 2
                                                                                                                                                                                    let s_slen = ctx.scratch_base + 3
                                                                                                                                                                                    let s_alloc = ctx.scratch_base + 4
                                                                                                                                                                                    let s_pad = ctx.scratch_base + 5
                                                                                                                                                                                    let s_i = ctx.scratch_base + 6
                                                                                                                                                                                    let s_fb = ctx.scratch_base + 7
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_fill)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_width)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                    emit_writer::emit_byte(w, 2)
                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_slen)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_slen)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_width)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                    emit_writer::emit_byte(w, 127)
                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                    emit_writer::emit_leb128_u(w, s_str)
