// Handler for: to_string, i32_to_string, text::format_i32, convert::i32_to_string, __intrinsic_i32_to_string
pub fn emit_to_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                            let s_val = ctx.scratch_base + 2
                                                                                                                                                                                            let s_wpos = ctx.scratch_base
                                                                                                                                                                                            let s_neg = ctx.scratch_base + 1
                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                            let buf_end = emit_scratch::SCRATCH_I32BUF() + 20
                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                            emit_writer::emit_leb128_s(w, buf_end)
                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_wpos)
                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_neg)
                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_val)
