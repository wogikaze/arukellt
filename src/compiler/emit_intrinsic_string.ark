// Handler for: repeat, text::repeat, string::repeat
pub fn emit_repeat(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                let s0 = ctx.scratch_base + 0
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                let s1 = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                let s2 = ctx.scratch_base + 2
