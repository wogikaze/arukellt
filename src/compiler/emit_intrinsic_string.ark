// Arukellt Selfhost — Wasm Binary Emitter: String Intrinsic Handlers
// Extracted from emit_intrinsic.ark

use emit_inst_ctx


// Handler for: String_from, clone
pub fn emit_clone(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                        let _nop = 0
    true
}


// Handler for: bool_to_string, text::format_bool, convert::bool_to_string
pub fn emit_bool_to_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                let s_tmp = ctx.scratch_base + 2
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                emit_writer::emit_leb128_u(w, s_tmp)
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                emit_writer::emit_leb128_u(w, s_tmp)
                                                                                                                                emit_writer::emit_byte(w, 4)
                                                                                                                                emit_writer::emit_byte(w, 127)
                                                                                                                                let true_offset = get_unchecked(ctx.string_offsets, ctx.true_str_idx)
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                emit_writer::emit_leb128_s(w, true_offset)
                                                                                                                                emit_writer::emit_byte(w, 5)
                                                                                                                                let false_offset = get_unchecked(ctx.string_offsets, ctx.false_str_idx)
                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                emit_writer::emit_leb128_s(w, false_offset)
                                                                                                                                emit_writer::emit_byte(w, 11)
    true
}


// Handler for: len
pub fn emit_len(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                    emit_writer::emit_byte(w, 2)
                                                                                                                                    emit_writer::emit_byte(w, 0)
    true
}


// Handler for: concat, text::concat
pub fn emit_concat(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                            let s_a = ctx.scratch_base
                                                                                                                                            let s_b = ctx.scratch_base + 1
                                                                                                                                            let s_la = ctx.scratch_base + 2
                                                                                                                                            let s_rp = ctx.scratch_base + 3
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                            emit_writer::emit_leb128_u(w, inst.dest)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, inst.dest)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_rp)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, inst.dest)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_rp)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_a)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                            emit_writer::emit_byte(w, 252)
                                                                                                                                            emit_writer::emit_leb128_u(w, 10)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_rp)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_b)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, inst.dest)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_la)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                            emit_writer::emit_byte(w, 252)
                                                                                                                                            emit_writer::emit_leb128_u(w, 10)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                            emit_writer::emit_leb128_u(w, s_rp)
    true
}


