pub fn emit_f64_to_string(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                    let s_wpos = ctx.scratch_base + 0
                                                                                                                                                                                                    let s_neg = ctx.scratch_base + 1
                                                                                                                                                                                                    let s_int = ctx.scratch_base + 2
                                                                                                                                                                                                    let s_len = ctx.scratch_base + 3
                                                                                                                                                                                                    let s_alloc = ctx.scratch_base + 4
                                                                                                                                                                                                    let s_fdig = ctx.scratch_base + 5
                                                                                                                                                                                                    let s_fpos = ctx.scratch_base + 6
                                                                                                                                                                                                    let f_val = ctx.scratch_base + 12
                                                                                                                                                                                                    let f_frac = ctx.scratch_base + 13
                                                                                                                                                                                                    let buf_start = emit_scratch::SCRATCH_I32BUF()
                                                                                                                                                                                                    let buf_end = buf_start + 40
                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                    emit_writer::emit_leb128_u(w, f_val)
                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 0)
