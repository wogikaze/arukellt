pub fn emit_vec_get_unchecked_i64(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                        let s_idx_i64 = ctx.scratch_base
