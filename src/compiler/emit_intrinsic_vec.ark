// Arukellt Selfhost — Wasm Binary Emitter: Vec Intrinsic Handlers
// Extracted from emit_intrinsic.ark

use emit_inst_ctx


// Handler for: Vec_new_i64, Vec_new_f64
pub fn emit_Vec_new_i64(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 12)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 36)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 12)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 64)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 36)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 35)
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 76)
                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                            emit_inst_ctx::ctx_mark_vec_local(ctx, inst.dest)
    true
}


// Handler for: vec_len
pub fn emit_vec_len(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
    true
}


// Handler for: vec_push, push
pub fn emit_push(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                        let is_void_push = eq(clone(callee), "push")
                                                                                                                                                                                                                                                                        let s_val = ctx.scratch_base
                                                                                                                                                                                                                                                                        let s_vec = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                        let s_data = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                        let s_cap = ctx.scratch_base + 3
                                                                                                                                                                                                                                                                        let s_newdata = ctx.scratch_base + 4
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_cap)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_newdata)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_newdata)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_cap)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_SET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_data)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_newdata)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_data)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 252)
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 10)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_newdata)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_cap)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_END())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_val)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec)
                                                                                                                                                                                                                                                                        if is_void_push {
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_DROP())
                                                                                                                                                                                                                                                                        }
    true
}


// Handler for: vec_get_unchecked, get_unchecked
pub fn emit_get_unchecked(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                            let s_idx = ctx.scratch_base
                                                                                                                                                                                                                                                                            let s_vec2 = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_idx)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_vec2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_vec2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_u(w, s_idx)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                            emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                            emit_writer::emit_byte(w, 0)
    true
}


// Handler for: vec_push_i64, push_i64
pub fn emit_push_i64(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                let is_void_push_i64 = eq(clone(callee), "push_i64")
                                                                                                                                                                                                                                                                                let s_val_i64 = ctx.scratch_base + 14
                                                                                                                                                                                                                                                                                let s_vec_i64 = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                let s_data_i64 = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                let s_cap_i64 = ctx.scratch_base + 3
                                                                                                                                                                                                                                                                                let s_newdata_i64 = ctx.scratch_base + 4
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_val_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_vec_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_vec_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_vec_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_cap_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_GLOBAL_GET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_newdata_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_newdata_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_u(w, s_cap_i64)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                emit_writer::emit_leb128_s(w, 2)
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                                emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
