                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_val_set)
                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_STORE())
                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec_set)
    true
}


// Handler for: is_empty
pub fn emit_is_empty(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_SUB())
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                    emit_writer::emit_byte(w, emit_opcodes::OP_I32_EQZ())
    true
}


// Handler for: contains_i32, seq::seq_contains
pub fn emit_contains_i32(w: WasmWriter, inst: MirInst, ctx: emit_inst_ctx::SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                                                                                        let s_needle = ctx.scratch_base
                                                                                                                                                                                                                                                                                                                                        let s_vec_ci = ctx.scratch_base + 1
                                                                                                                                                                                                                                                                                                                                        let s_ci_i = ctx.scratch_base + 2
                                                                                                                                                                                                                                                                                                                                        let s_ci_len = ctx.scratch_base + 3
                                                                                                                                                                                                                                                                                                                                        let s_ci_data = ctx.scratch_base + 4
                                                                                                                                                                                                                                                                                                                                        let s_ci_found = ctx.scratch_base + 5
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_needle)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec_ci)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_found)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec_ci)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_len)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_vec_ci)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 8)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_data)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 0)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_i)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BLOCK())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOOP())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_i)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_len)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_GE_S())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BR_IF())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 1)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_data)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_i)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 4)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_MUL())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 2)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_needle)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_EQ())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_IF())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 64)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_found)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BR())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 2)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 11)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_i)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_s(w, 1)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_i)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_BR())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, 0)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 11)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, 11)
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                        emit_writer::emit_leb128_u(w, s_ci_found)
    true
}


