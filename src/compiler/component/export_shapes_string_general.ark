// Arukellt Selfhost - general multi-export string canonical ABI plan.

use component::export_function_view
use component::export_shapes_string_predicates
use component::naming
use mir::module_functions

struct StringGeneralExport {
	name: String,
}

fn StringGeneralExport_new(name: String) -> StringGeneralExport {
	StringGeneralExport { name: name }
}

fn StringGeneralExport_name(entry: StringGeneralExport) -> String {
	entry.name
}

struct StringGeneralPlan {
	entries: Vec<StringGeneralExport>,
}

fn StringGeneralPlan_new(entries: Vec<StringGeneralExport>) -> StringGeneralPlan {
	StringGeneralPlan { entries: entries }
}

fn StringGeneralPlan_count(plan: StringGeneralPlan) -> i32 {
	len(plan.entries)
}

fn StringGeneralPlan_entry_at(plan: StringGeneralPlan, idx: i32) -> StringGeneralExport {
	get_unchecked(plan.entries, idx)
}

fn comp_string_general_plan(mir: MirModule) -> StringGeneralPlan {
	let entries: Vec<StringGeneralExport> = Vec_new()
	let mut export_count = 0
	let n = module_functions::MirModule_function_count(mir)
	let mut i = 0
	while i < n {
		let f = module_functions::MirModule_function_at(mir, i)
		let export_name = export_function_view::export_function_name(f)
		if naming::comp_should_export_func(clone(export_name)) {
			export_count = export_count + 1
			if !export_shapes_string_predicates::comp_function_is_string_unary_export(f) {
				return StringGeneralPlan_new(Vec_new())
			}
			push(entries, StringGeneralExport_new(export_name))
		}
		i = i + 1
	}
	if export_count < 2 {
		return StringGeneralPlan_new(Vec_new())
	}
	StringGeneralPlan_new(entries)
}

fn comp_string_general_plan_is_valid(plan: StringGeneralPlan) -> bool {
	StringGeneralPlan_count(plan) >= 2
}
