    writer_core::comp_emit_byte(body, 0x3a)
    writer_core::comp_emit_leb128_u(body, 0)
    writer_core::comp_emit_leb128_u(body, 0)
    comp_emit_option_construct_return_ptr(body)
}

fn comp_emit_option_i64_construct_output_layout(body: writer_core::ComponentWriter) {
    comp_emit_option_construct_tag_i32(body)
    writer_core::comp_emit_byte(body, 0x41)
    writer_core::comp_emit_leb128_u(body, 65004)
    writer_core::comp_emit_byte(body, 0x41)
    writer_core::comp_emit_leb128_u(body, 0)
    writer_core::comp_emit_byte(body, 0x36)
    writer_core::comp_emit_leb128_u(body, 2)
    writer_core::comp_emit_leb128_u(body, 0)
    writer_core::comp_emit_byte(body, 0x41)
    writer_core::comp_emit_leb128_u(body, 65008)
    writer_core::comp_emit_byte(body, 0x20)
    writer_core::comp_emit_leb128_u(body, 1)
    writer_core::comp_emit_byte(body, 0x41)
    writer_core::comp_emit_leb128_u(body, 4)
    writer_core::comp_emit_byte(body, 0x6a)
    writer_core::comp_emit_byte(body, 0x29)
    writer_core::comp_emit_leb128_u(body, 2)
    writer_core::comp_emit_leb128_u(body, 0)
    writer_core::comp_emit_byte(body, 0x37)
    writer_core::comp_emit_leb128_u(body, 3)
    writer_core::comp_emit_leb128_u(body, 0)
    comp_emit_option_construct_return_ptr(body)
}
