    }
    String_new()
}

fn component_tuple_i32_i32_param_signature_error(f: AstNode, allows: ComponentContractAllows) -> String {
    if contract_allows_numeric_tuple_query::ComponentContractAllows_allow_tuple_param(allows) &&
    !contract_tuple_functions::component_fn_is_tuple_i32_i32_to_i32(contract_helpers::component_func_from_decl(f)) {
        return contract_helpers::component_error_for_fn(f)
    }
    String_new()
}

fn component_tuple_mixed_signature_error(f: AstNode, allows: ComponentContractAllows) -> String {
    if contract_allows_numeric_tuple_query::ComponentContractAllows_allow_tuple_mixed_param(allows) &&
    !contract_tuple_functions::component_fn_is_tuple_i32_bool_to_i32(contract_helpers::component_func_from_decl(f)) {
        return contract_helpers::component_error_for_fn(f)
    }
    String_new()
}

fn component_tuple_bool_bool_signature_error(f: AstNode, allows: ComponentContractAllows) -> String {
    if contract_allows_numeric_tuple_query::ComponentContractAllows_allow_tuple_bool_param(allows) &&
    !contract_tuple_functions::component_fn_is_tuple_bool_bool_to_i32(contract_helpers::component_func_from_decl(f)) {
        return contract_helpers::component_error_for_fn(f)
    }
    String_new()
}

fn component_tuple_i32_i32_roundtrip_signature_error(f: AstNode, allows: ComponentContractAllows) -> String {
    if contract_allows_numeric_tuple_query::ComponentContractAllows_allow_tuple_roundtrip(allows) &&
    !contract_tuple_functions::component_fn_is_tuple_i32_i32_to_tuple_i32_i32(contract_helpers::component_func_from_decl(f)) {
        return contract_helpers::component_error_for_fn(f)
    }
    String_new()
}

fn component_specialized_signature_error(f: AstNode, allows: ComponentContractAllows) -> String {
    let string_collection_error = component_string_collection_signature_error(f, allows)
    if len(string_collection_error) > 0 {
        return string_collection_error
    }
    let numeric_tuple_error = component_numeric_tuple_signature_error(f, allows)
    if len(numeric_tuple_error) > 0 {
        return numeric_tuple_error
    }
    let record_shape_error = contract_special_record_shape::component_record_shape_signature_error(f, allows)
    if len(record_shape_error) > 0 {
        return record_shape_error
    }
    if !contract_special_support::component_special_signature_supported(f) {
        return contract_helpers::component_error_for_fn(f)
    }
    String_new()
}
