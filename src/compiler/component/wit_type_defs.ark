// Arukellt Selfhost - WIT type definitions from declarations

use component::wit_decl
use component::wit_names
use component::wit_types

fn emit_wit_type_defs(decls: Vec<AstNode>) -> String {
	let mut out = String_from("")
	let mut i = 0
	while i < len(decls) {
		let d = wit_decl::wit_decl_from_node(get_unchecked(decls, i))
		if wit_decl::wit_decl_is_record(d) {
			out = concat(out, emit_wit_record_type_def(d))
		}
		if wit_decl::wit_decl_is_enum(d) {
			out = concat(out, emit_wit_enum_type_def(d))
		}
		i = i + 1
	}
	out
}

fn emit_wit_record_type_def(d: ComponentWitDecl) -> String {
	let mut out = String_from("  record ")
	out = concat(out, wit_names::wit_type_name(wit_decl::wit_decl_name(d)))
	out = concat(out, String_from(" {\n"))
	let mut fi = 0
	while fi < wit_decl::wit_decl_member_count(d) {
		let field = wit_decl::wit_decl_member_at(d, fi)
		out = concat(out, String_from("    "))
		out = concat(out, wit_names::wit_export_name(wit_decl::wit_decl_member_name(field)))
		out = concat(out, String_from(": "))
		if wit_decl::wit_decl_member_has_type(field) {
			out = concat(out, wit_types::wit_type_from_ast(wit_decl::wit_decl_member_type_view(field)))
		} else {
			out = concat(out, String_from("s32"))
		}
		out = concat(out, String_from(",\n"))
		fi = fi + 1
	}
	concat(out, String_from("  }\n\n"))
}

fn emit_wit_enum_type_def(d: ComponentWitDecl) -> String {
	let mut out = String_from("")
	if wit_decl::wit_decl_enum_has_payloads(d) {
		out = concat(out, String_from("  variant "))
	} else {
		out = concat(out, String_from("  enum "))
	}
	out = concat(out, wit_names::wit_type_name(wit_decl::wit_decl_name(d)))
	out = concat(out, String_from(" {\n"))
	let mut vi = 0
	while vi < wit_decl::wit_decl_member_count(d) {
		let variant = wit_decl::wit_decl_member_at(d, vi)
		out = concat(out, String_from("    "))
		out = concat(out, wit_names::wit_type_name(wit_decl::wit_decl_member_name(variant)))
		if wit_decl::wit_decl_member_has_type(variant) {
			out = concat(out, String_from("("))
			out = concat(out, wit_types::wit_type_from_ast(wit_decl::wit_decl_member_type_view(variant)))
			out = concat(out, String_from(")"))
		}
		out = concat(out, String_from(",\n"))
		vi = vi + 1
	}
	concat(out, String_from("  }\n\n"))
}
