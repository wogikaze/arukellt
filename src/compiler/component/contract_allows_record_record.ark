// Arukellt Selfhost - component record and variant contract allow data.

pub struct ComponentRecordAllows {
    allow_record_point: bool,
    allow_record_distance: bool,
    allow_record_roundtrip: bool,
    allow_record_add: bool,
    allow_color_enum: bool,
    allow_color_code: bool,
    allow_color_roundtrip: bool,
    allow_shape_area: bool,
    allow_shape_roundtrip: bool,
}

fn ComponentRecordAllows_new(
    allow_record_point: bool,
    allow_record_distance: bool,
    allow_record_roundtrip: bool,
    allow_record_add: bool,
    allow_color_enum: bool,
    allow_color_code: bool,
    allow_color_roundtrip: bool,
    allow_shape_area: bool,
    allow_shape_roundtrip: bool
) -> ComponentRecordAllows {
    ComponentRecordAllows {
        allow_record_point: allow_record_point,
        allow_record_distance: allow_record_distance,
        allow_record_roundtrip: allow_record_roundtrip,
        allow_record_add: allow_record_add,
        allow_color_enum: allow_color_enum,
        allow_color_code: allow_color_code,
        allow_color_roundtrip: allow_color_roundtrip,
        allow_shape_area: allow_shape_area,
        allow_shape_roundtrip: allow_shape_roundtrip,
    }
}
