}

fn ComponentRecordAllows_allow_color_roundtrip(allows: ComponentRecordAllows) -> bool {
    allows.allow_color_roundtrip
}

fn ComponentRecordAllows_allow_shape_area(allows: ComponentRecordAllows) -> bool {
    allows.allow_shape_area
}

