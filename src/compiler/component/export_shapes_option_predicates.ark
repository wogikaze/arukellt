	if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
		return false
	}
	if export_function_view::export_function_param_count(f) != 1 {
		return false
	}
	if !eq(export_function_view::export_function_return_type_name(f), String_from("i64")) {
		return false
	}
	naming::comp_type_name_is_option_i64(export_function_view::export_function_param_type_name(f, 0))
}

fn comp_function_is_option_i32_to_option_i32_export(f: MirFunction) -> bool {
	if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
		return false
	}
	if export_function_view::export_function_param_count(f) != 1 {
		return false
	}
	if !naming::comp_type_name_is_option_i32(export_function_view::export_function_return_type_name(f)) {
		return false
	}
	naming::comp_type_name_is_option_i32(export_function_view::export_function_param_type_name(f, 0))
}
