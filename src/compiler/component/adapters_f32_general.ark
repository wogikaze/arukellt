use component::adapter_body
use component::export_shapes_f32_general
use component::export_shapes_kinds
use component::sections
use component::writer_core

fn comp_f32_general_adapter_core_module(plan: export_shapes_f32_general::F32GeneralPlan) -> Vec<i32> {
    let out = sections::comp_new_core_module_writer()
    comp_emit_f32_general_adapter_sections(out, plan)
    writer_core::comp_writer_bytes(out)
}

fn comp_f32_general_kind_param_count(kind: i32) -> i32 {
    if kind == export_shapes_kinds::F32_BINARY() {
        return 2
    }
    1
}

fn comp_f32_general_kind_convert_params_to_f32(kind: i32) -> bool {
    kind != export_shapes_kinds::I32_TO_F32()
}

fn comp_f32_general_kind_convert_result_to_i32(kind: i32) -> bool {
    kind == export_shapes_kinds::F32_UNARY() || kind == export_shapes_kinds::F32_BINARY() || kind == export_shapes_kinds::I32_TO_F32()
}

fn comp_f32_general_kind_abi_param0_type(kind: i32) -> i32 {
    if kind == export_shapes_kinds::I32_TO_F32() {
        return 0x7f
    }
    0x7d
}

fn comp_f32_general_kind_abi_param1_type(kind: i32) -> i32 {
    0x7d
}

fn comp_f32_general_kind_abi_result_type(kind: i32) -> i32 {
    if kind == export_shapes_kinds::F32_TO_I32() {
        return 0x7f
    }
    if kind == export_shapes_kinds::I32_TO_F32() {
        return 0x7d
    }
    0x7d
}

fn comp_emit_f32_general_adapter_sections(out: writer_core::ComponentWriter, plan: export_shapes_f32_general::F32GeneralPlan) {
    comp_emit_f32_general_type_section(out, plan)
    comp_emit_f32_general_import_section(out, plan)
    comp_emit_f32_general_func_section(out, plan)
    comp_emit_f32_general_export_section(out, plan)
    comp_emit_f32_general_code_section(out, plan)
}

fn comp_emit_f32_general_type_section(out: writer_core::ComponentWriter, plan: export_shapes_f32_general::F32GeneralPlan) {
    let type_sec = writer_core::ComponentWriter_new()
    let count = export_shapes_f32_general::F32GeneralPlan_count(plan)
    writer_core::comp_emit_leb128_u(type_sec, count * 2)
    let mut i = 0
    while i < count {
        let entry = export_shapes_f32_general::F32GeneralPlan_entry_at(plan, i)
        let kind = export_shapes_f32_general::F32GeneralExport_kind(entry)
        let param_count = comp_f32_general_kind_param_count(kind)
        let user_params = Vec_new_i32()
        let mut pi = 0
        while pi < param_count {
            push(user_params, 0x7f)
            pi = pi + 1
        }
        let user_results = Vec_new_i32()
        push(user_results, 0x7f)
        sections::comp_emit_core_func_type(type_sec, user_params, user_results)
        let abi_params = Vec_new_i32()
        if param_count > 0 {
            push(abi_params, comp_f32_general_kind_abi_param0_type(kind))
        }
        if param_count > 1 {
            push(abi_params, comp_f32_general_kind_abi_param1_type(kind))
        }
        let abi_results = Vec_new_i32()
        push(abi_results, comp_f32_general_kind_abi_result_type(kind))
        sections::comp_emit_core_func_type(type_sec, abi_params, abi_results)
        i = i + 1
    }
    sections::comp_emit_wasm_section(out, 1, type_sec)
}

fn comp_emit_f32_general_import_section(out: writer_core::ComponentWriter, plan: export_shapes_f32_general::F32GeneralPlan) {
    let import_sec = writer_core::ComponentWriter_new()
    let count = export_shapes_f32_general::F32GeneralPlan_count(plan)
    writer_core::comp_emit_leb128_u(import_sec, count)
    let mut i = 0
    while i < count {
        let entry = export_shapes_f32_general::F32GeneralPlan_entry_at(plan, i)
        let name = export_shapes_f32_general::F32GeneralExport_name(entry)
        writer_core::comp_emit_string(import_sec, String_from("user"))
        writer_core::comp_emit_string(import_sec, clone(name))
        writer_core::comp_emit_byte(import_sec, 0x00)
        writer_core::comp_emit_leb128_u(import_sec, i * 2 + 1)
        i = i + 1
    }
    sections::comp_emit_wasm_section(out, 2, import_sec)
}

fn comp_emit_f32_general_func_section(out: writer_core::ComponentWriter, plan: export_shapes_f32_general::F32GeneralPlan) {
    let func_sec = writer_core::ComponentWriter_new()
    let count = export_shapes_f32_general::F32GeneralPlan_count(plan)
    writer_core::comp_emit_leb128_u(func_sec, count)
    let mut i = 0
    while i < count {
        writer_core::comp_emit_leb128_u(func_sec, i * 2)
        i = i + 1
    }
    sections::comp_emit_wasm_section(out, 3, func_sec)
}

fn comp_emit_f32_general_export_section(out: writer_core::ComponentWriter, plan: export_shapes_f32_general::F32GeneralPlan) {
    let export_sec = writer_core::ComponentWriter_new()
    let count = export_shapes_f32_general::F32GeneralPlan_count(plan)
    writer_core::comp_emit_leb128_u(export_sec, count)
    let mut i = 0
    while i < count {
        let entry = export_shapes_f32_general::F32GeneralPlan_entry_at(plan, i)
        let name = export_shapes_f32_general::F32GeneralExport_name(entry)
        writer_core::comp_emit_string(export_sec, clone(name))
        writer_core::comp_emit_byte(export_sec, 0x00)
        writer_core::comp_emit_leb128_u(export_sec, i)
        i = i + 1
    }
    sections::comp_emit_wasm_section(out, 7, export_sec)
}

fn comp_emit_f32_general_code_section(out: writer_core::ComponentWriter, plan: export_shapes_f32_general::F32GeneralPlan) {
    let code_sec = writer_core::ComponentWriter_new()
    let count = export_shapes_f32_general::F32GeneralPlan_count(plan)
    writer_core::comp_emit_leb128_u(code_sec, count)
    let mut i = 0
    while i < count {
        let entry = export_shapes_f32_general::F32GeneralPlan_entry_at(plan, i)
        let kind = export_shapes_f32_general::F32GeneralExport_kind(entry)
        comp_emit_f32_general_wrapper_body(code_sec, kind, i)
        i = i + 1
    }
    sections::comp_emit_wasm_section(out, 10, code_sec)
}

fn comp_emit_f32_general_wrapper_body(code_sec: writer_core::ComponentWriter, kind: i32, import_idx: i32) {
    let param_count = comp_f32_general_kind_param_count(kind)
    let convert_params = comp_f32_general_kind_convert_params_to_f32(kind)
    let convert_result = comp_f32_general_kind_convert_result_to_i32(kind)
    let body = writer_core::ComponentWriter_new()
    writer_core::comp_emit_leb128_u(body, 0)
    writer_core::comp_emit_byte(body, 0x20)
    writer_core::comp_emit_leb128_u(body, 0)
    if convert_params {
        writer_core::comp_emit_byte(body, 0xbc)
    }
    if param_count > 1 {
        writer_core::comp_emit_byte(body, 0x20)
        writer_core::comp_emit_leb128_u(body, 1)
        if convert_params {
            writer_core::comp_emit_byte(body, 0xbc)
        }
    }
    writer_core::comp_emit_byte(body, 0x10)
    writer_core::comp_emit_leb128_u(body, import_idx)
    if convert_result {
        writer_core::comp_emit_byte(body, 0xbe)
    }
    writer_core::comp_emit_byte(body, 0x0b)
    adapter_body::comp_emit_func_body(code_sec, body)
}
