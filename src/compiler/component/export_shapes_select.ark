use component::export_function_view
use component::export_shapes_match
use component::naming
use mir::module_functions

fn comp_single_list_export_name(mir: MirModule, kind: i32) -> String {
    let mut candidate = String_new()
    let mut count = 0
    let n = module_functions::MirModule_function_count(mir)
    let mut i = 0
    while i < n {
        let f = module_functions::MirModule_function_at(mir, i)
        let export_name = export_function_view::export_function_name(f)
        if naming::comp_should_export_func(clone(export_name)) {
            if export_shapes_match::comp_function_matches_list_export(f, kind) {
                count = count + 1
                candidate = export_name
            } else {
                return String_new()
            }
        }
        i = i + 1
    }
    if count == 1 {
        return candidate
    }
    String_new()
}

