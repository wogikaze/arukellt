// Arukellt Selfhost - component record/variant function predicates.

use component::contract_helpers

fn component_fn_is_point_to_i32(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 1) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Point")) && eq(contract_helpers::component_export_return_type_name(f), String_from("i32"))
}

fn component_fn_is_point_point_to_point(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 2) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Point")) && eq(contract_helpers::component_export_param_type_name_at(f, 1), String_from("Point")) && eq(contract_helpers::component_export_return_type_name(f), String_from("Point"))
}

fn component_fn_is_point_to_point(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 1) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Point")) && eq(contract_helpers::component_export_return_type_name(f), String_from("Point"))
}

fn component_fn_is_color_to_i32(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 1) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Color")) && eq(contract_helpers::component_export_return_type_name(f), String_from("i32"))
}

fn component_fn_is_color_to_color(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 1) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Color")) && eq(contract_helpers::component_export_return_type_name(f), String_from("Color"))
}

fn component_fn_is_shape_to_f64(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 1) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Shape")) && eq(contract_helpers::component_export_return_type_name(f), String_from("f64"))
}

fn component_fn_is_shape_to_shape(f: ComponentExportFunc) -> bool {
    contract_helpers::component_export_param_count_is(f, 1) && eq(contract_helpers::component_export_param_type_name_at(f, 0), String_from("Shape")) && eq(contract_helpers::component_export_return_type_name(f), String_from("Shape"))
}
