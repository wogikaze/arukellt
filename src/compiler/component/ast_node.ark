use parser::ast
use parser::kinds

fn node_kind(node: AstNode) -> i32 {
    ast::ast_node_kind(node)
}

fn node_kind_is(node: AstNode, kind: i32) -> bool {
    node_kind(node) == kind
}

fn node_text(node: AstNode) -> String {
    ast::ast_node_text(node)
}

fn node_is_pub(node: AstNode) -> bool {
    ast::ast_node_is_pub(node)
}

fn node_is_async(node: AstNode) -> bool {
    ast::ast_node_is_async(node)
}

fn node_child_count(node: AstNode) -> i32 {
    ast::ast_node_child_count(node)
}

fn node_child_at(node: AstNode, index: i32) -> AstNode {
    ast::ast_node_child_at(node, index)
}

fn node_is_fn_decl(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_FN_DECL())
}

fn node_is_struct_decl(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_STRUCT_DECL())
}

fn node_is_resource_decl(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_RESOURCE_DECL())
}

fn node_is_enum_decl(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_ENUM_DECL())
}

fn node_type_ann_count(node: AstNode) -> i32 {
    ast::ast_node_type_ann_count(node)
}

fn node_type_ann_at(node: AstNode, index: i32) -> AstNode {
    ast::ast_node_type_ann_at(node, index)
}

fn node_has_type_ann(node: AstNode) -> bool {
    node_type_ann_count(node) > 0
}

fn node_first_type_ann(node: AstNode) -> AstNode {
    node_type_ann_at(node, 0)
}

fn node_is_return_ann(node: AstNode) -> bool {
    eq(node_text(node), String_from("__return"))
}

fn node_is_type_named(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_TYPE_NAMED())
}

fn node_is_type_generic(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_TYPE_GENERIC())
}

fn node_is_type_tuple(node: AstNode) -> bool {
    node_kind_is(node, kinds::NK_TYPE_TUPLE())
}
