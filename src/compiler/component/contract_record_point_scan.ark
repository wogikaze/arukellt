use component::contract_helpers
use component::contract_record_fn
use component::contract_record_decl

pub struct ComponentRecordPointScan {
    has_point_shape: bool,
    has_distance: bool,
    has_add: bool,
    has_roundtrip: bool,
    export_count: i32,
}

fn ComponentRecordPointScan_new(has_point_shape: bool, has_distance: bool, has_add: bool, has_roundtrip: bool, export_count: i32) -> ComponentRecordPointScan {
    ComponentRecordPointScan {
        has_point_shape: has_point_shape,
        has_distance: has_distance,
        has_add: has_add,
        has_roundtrip: has_roundtrip,
        export_count: export_count,
    }
}

fn ComponentRecordPointScan_empty() -> ComponentRecordPointScan {
    ComponentRecordPointScan_new(false, false, false, false, 0)
}

fn ComponentRecordPointScan_export_count_is(scan: ComponentRecordPointScan, expected: i32) -> bool {
    scan.export_count == expected
}

fn ComponentRecordPointScan_increment_export_count(scan: ComponentRecordPointScan) {
    scan.export_count = scan.export_count + 1
}

fn component_record_point_scan_apply_export(scan: ComponentRecordPointScan, d: AstNode) {
    ComponentRecordPointScan_increment_export_count(scan)
    let f = contract_helpers::component_func_from_decl(d)
    if contract_record_fn::component_fn_is_point_to_i32(f) {
        scan.has_distance = true
    }
    if contract_record_fn::component_fn_is_point_point_to_point(f) {
        scan.has_add = true
    }
    if contract_record_fn::component_fn_is_point_to_point(f) {
        scan.has_roundtrip = true
    }
}

fn component_record_point_scan_apply_decl(scan: ComponentRecordPointScan, d: AstNode) {
    if contract_record_decl::component_decl_is_point_shape(d) {
        scan.has_point_shape = true
    }
    if contract_helpers::is_export_func_decl(d) {
        component_record_point_scan_apply_export(scan, d)
    }
}

fn ComponentRecordPointScan_allows_point(scan: ComponentRecordPointScan) -> bool {
    scan.has_point_shape && scan.has_distance && scan.has_add && ComponentRecordPointScan_export_count_is(scan, 2)
}

fn ComponentRecordPointScan_allows_distance(scan: ComponentRecordPointScan) -> bool {
    scan.has_point_shape && scan.has_distance && ComponentRecordPointScan_export_count_is(scan, 1)
}

fn ComponentRecordPointScan_allows_roundtrip(scan: ComponentRecordPointScan) -> bool {
    scan.has_point_shape && scan.has_roundtrip && ComponentRecordPointScan_export_count_is(scan, 1)
}

fn ComponentRecordPointScan_allows_add(scan: ComponentRecordPointScan) -> bool {
    scan.has_point_shape && scan.has_add && ComponentRecordPointScan_export_count_is(scan, 1)
}

fn component_record_point_scan(decls: Vec<AstNode>) -> ComponentRecordPointScan {
    let scan = ComponentRecordPointScan_empty()
    for i in 0..len(decls) {
        let d = get_unchecked(decls, i)
        component_record_point_scan_apply_decl(scan, d)
    }
    scan
}
