// Arukellt Selfhost - Component tuple export shape predicates
use component::export_function_view
use component::naming
use mir::value_types

fn comp_function_is_tuple_i32_i32_to_i32_export(f: MirFunction) -> bool {
    comp_function_is_tuple_param_to_named_export(f, String_from("Tuple:i32:i32"), String_from("i32"), true)
}

fn comp_function_is_tuple_i32_bool_to_i32_export(f: MirFunction) -> bool {
    comp_function_is_tuple_param_to_named_export(f, String_from("Tuple:i32:bool"), String_from("i32"), false)
}

fn comp_function_is_tuple_bool_bool_to_i32_export(f: MirFunction) -> bool {
    comp_function_is_tuple_param_to_named_export(f, String_from("Tuple:bool:bool"), String_from("i32"), false)
}

fn comp_function_is_tuple_i32_i32_to_tuple_i32_i32_export(f: MirFunction) -> bool {
    comp_function_is_tuple_param_to_abi_tuple_export(f, String_from("Tuple:i32:i32"), true)
}

fn comp_function_is_tuple_param_to_named_export(f: MirFunction, param_type_name: String, return_type_name: String, allow_abi_tuple_param: bool) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 1 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), return_type_name) {
        return false
    }
    let actual_param_type_name = export_function_view::export_function_param_type_name(f, 0)
    if allow_abi_tuple_param && eq(clone(actual_param_type_name), String_from("")) {
        return true
    }
    eq(actual_param_type_name, param_type_name)
}

fn comp_function_is_tuple_param_to_abi_tuple_export(f: MirFunction, param_type_name: String, allow_abi_tuple_param: bool) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 1 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), String_from("")) {
        return false
    }
    if export_function_view::export_function_return_type(f) != value_types::VT_I32() {
        return false
    }
    let actual_param_type_name = export_function_view::export_function_param_type_name(f, 0)
    if allow_abi_tuple_param && eq(clone(actual_param_type_name), String_from("")) {
        return true
    }
    eq(actual_param_type_name, param_type_name)
}

fn comp_function_is_i32_i32_to_tuple_i32_i32_export(f: MirFunction) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 2 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), String_from("")) {
        return false
    }
    export_function_view::export_function_param_val_type(f, 0) == value_types::VT_I32() && export_function_view::export_function_param_val_type(f, 1) == value_types::VT_I32() && export_function_view::export_function_return_type(f) == value_types::VT_I32()
}

fn comp_function_is_i64_i64_to_tuple_i64_i64_export(f: MirFunction) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 2 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), String_from("")) {
        return false
    }
    export_function_view::export_function_param_val_type(f, 0) == value_types::VT_I64() && export_function_view::export_function_param_val_type(f, 1) == value_types::VT_I64() && export_function_view::export_function_return_type(f) == value_types::VT_I32()
}
