    if !contract_helpers::component_export_param_has_type_at(f, idx) {
        return false
    }
    component_type_is_option_i64(contract_helpers::component_export_param_type_view_at(f, idx))
}

fn component_type_is_result_i32_string(ty: ComponentTypeNode) -> bool {
    component_type_is_generic_named_pair(ty, String_from("Result"), String_from("i32"), String_from("String"))
}

fn component_type_is_result_i32_i32(ty: ComponentTypeNode) -> bool {
    component_type_is_generic_named_pair(ty, String_from("Result"), String_from("i32"), String_from("i32"))
}

