}

fn ComponentContractAllows_allow_color_code(allows: ComponentContractAllows) -> bool {
    contract_allows_record_record::ComponentRecordAllows_allow_color_code(component_record_allows(allows))
}

fn ComponentContractAllows_allow_color_roundtrip(allows: ComponentContractAllows) -> bool {
