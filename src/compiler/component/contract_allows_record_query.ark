// Arukellt Selfhost - component record/color/shape allow queries.

use component::contract_allows_record_record
use component::contract_allows_root_record

fn component_record_allows(allows: ComponentContractAllows) -> ComponentRecordAllows {
    contract_allows_root_record::ComponentContractAllows_record(allows)
}

fn ComponentContractAllows_allow_record_point(allows: ComponentContractAllows) -> bool {
    contract_allows_record_record::ComponentRecordAllows_allow_record_point(component_record_allows(allows))
}

