// Arukellt Selfhost - Component color export shape scan.

use component::export_function_view
use component::naming
use mir::module_functions

pub struct ComponentColorExportScan {
	color_to_color_name: String,
	color_to_i32_name: String,
	export_count: i32,
}

fn ComponentColorExportScan_new(color_to_color_name: String, color_to_i32_name: String, export_count: i32) -> ComponentColorExportScan {
	ComponentColorExportScan {
		color_to_color_name: color_to_color_name,
		color_to_i32_name: color_to_i32_name,
		export_count: export_count,
	}
}

fn ComponentColorExportScan_empty() -> ComponentColorExportScan {
	ComponentColorExportScan_new(String_new(), String_new(), 0)
}

fn comp_color_export_count_is(scan: ComponentColorExportScan, expected: i32) -> bool {
	scan.export_count == expected
}

fn comp_color_has_color_to_color(scan: ComponentColorExportScan) -> bool {
	len(scan.color_to_color_name) > 0
}

fn comp_color_has_color_to_i32(scan: ComponentColorExportScan) -> bool {
	len(scan.color_to_i32_name) > 0
}

fn comp_color_to_color_name(scan: ComponentColorExportScan) -> String {
	scan.color_to_color_name
}

fn comp_color_to_i32_name(scan: ComponentColorExportScan) -> String {
	scan.color_to_i32_name
}

fn comp_color_increment_export_count(scan: ComponentColorExportScan) {
	scan.export_count = scan.export_count + 1
}

fn comp_color_set_color_to_color_name(scan: ComponentColorExportScan, name: String) {
	scan.color_to_color_name = name
}

fn comp_color_set_color_to_i32_name(scan: ComponentColorExportScan, name: String) {
	scan.color_to_i32_name = name
}

fn comp_function_is_color_to_color_export(f: MirFunction) -> bool {
	if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
		return false
	}
	if export_function_view::export_function_param_count(f) != 1 {
		return false
	}
	if !eq(export_function_view::export_function_return_type_name(f), String_from("Color")) {
		return false
	}
	eq(export_function_view::export_function_param_type_name(f, 0), String_from("Color"))
}

fn comp_function_is_color_to_i32_export(f: MirFunction) -> bool {
	if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
		return false
	}
	if export_function_view::export_function_param_count(f) != 1 {
		return false
	}
	if !eq(export_function_view::export_function_return_type_name(f), String_from("i32")) {
		return false
	}
	eq(export_function_view::export_function_param_type_name(f, 0), String_from("Color"))
}

fn comp_color_pair_color_to_color_name(scan: ComponentColorExportScan) -> String {
	if comp_color_export_count_is(scan, 2) && comp_color_has_color_to_color(scan) && comp_color_has_color_to_i32(scan) {
		return comp_color_to_color_name(scan)
	}
	String_new()
}

fn comp_color_single_color_to_color_name(scan: ComponentColorExportScan) -> String {
	if comp_color_export_count_is(scan, 1) && comp_color_has_color_to_color(scan) {
		return comp_color_to_color_name(scan)
	}
	String_new()
}

fn comp_color_pair_color_to_i32_name(scan: ComponentColorExportScan) -> String {
	if comp_color_export_count_is(scan, 2) && comp_color_has_color_to_i32(scan) && comp_color_has_color_to_color(scan) {
		return comp_color_to_i32_name(scan)
	}
	String_new()
}

fn comp_color_single_color_to_i32_name(scan: ComponentColorExportScan) -> String {
	if comp_color_export_count_is(scan, 1) && comp_color_has_color_to_i32(scan) {
		return comp_color_to_i32_name(scan)
	}
	String_new()
}

fn comp_color_export_scan_apply(scan: ComponentColorExportScan, f: MirFunction, export_name: String) {
	comp_color_increment_export_count(scan)
	if comp_function_is_color_to_color_export(f) {
		comp_color_set_color_to_color_name(scan, clone(export_name))
	}
	if comp_function_is_color_to_i32_export(f) {
		comp_color_set_color_to_i32_name(scan, export_name)
	}
}

fn comp_color_export_scan(mir: MirModule) -> ComponentColorExportScan {
	let scan = ComponentColorExportScan_empty()
	let n = module_functions::MirModule_function_count(mir)
	let mut i = 0
	while i < n {
		let f = module_functions::MirModule_function_at(mir, i)
		let export_name = export_function_view::export_function_name(f)
		if naming::comp_should_export_func(clone(export_name)) {
			comp_color_export_scan_apply(scan, f, export_name)
		}
		i = i + 1
	}
	scan
}
