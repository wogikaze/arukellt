	if contract_allows_collection_query::ComponentContractAllows_allow_option_roundtrip(allows) && !contract_collection_fn::component_fn_is_option_i32_to_option_i32(contract_helpers::component_func_from_decl(f)) {
		return contract_helpers::component_error_for_fn(f)
