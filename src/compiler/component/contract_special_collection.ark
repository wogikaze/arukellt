fn component_collection_result_signature_error(f: AstNode, allows: ComponentContractAllows) -> String {
	let safe_div_error = component_result_safe_div_signature_error(f, allows)
	if len(safe_div_error) > 0 {
		return safe_div_error
	}
	let param_error = component_result_param_signature_error(f, allows)
	if len(param_error) > 0 {
		return param_error
	}
	let string_param_error = component_result_string_param_signature_error(f, allows)
	if len(string_param_error) > 0 {
		return string_param_error
	}
	let roundtrip_error = component_result_roundtrip_signature_error(f, allows)
	if len(roundtrip_error) > 0 {
		return roundtrip_error
	}
	let bool_error = component_result_bool_signature_error(f, allows)
	if len(bool_error) > 0 {
		return bool_error
	}
	String_new()
}

