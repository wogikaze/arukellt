use component::component_base
use component::export_plan
use component::export_sections
use component::export_types
use component::writer_core
use component::world_spec

fn emit_component(core_wasm: Vec<i32>, mir: MirModule, target: String, wasi_version: String, world: String) -> Vec<i32> {
    let _target = target
    if world_spec::world_spec_uses_p2_command_component(clone(world), clone(wasi_version)) {
        return wasm::emit_p2_command_component(core_wasm)
    }
    // Specialized emit lowered to drop+unreachable with an i64 return temp and
    // failed validate (#730). Generic export path is enough for selfhost fixpoint.
    let out = component_base::comp_new_component_writer()
    let plan = export_plan::collect_component_exports(mir)
    emit_component_generic_exports(out, core_wasm, plan, mir)
}

fn emit_library_component(core_wasm: Vec<i32>, mir: MirModule, target: String, wasi_version: String, world: String) -> Vec<i32> {
    let _target = target
    let _wasi_version = wasi_version
    let _world = world
    let out = component_base::comp_new_component_writer()
    let plan = export_plan::collect_component_exports(mir)
    emit_component_generic_exports(out, core_wasm, plan, mir)
}

fn emit_component_generic_exports(out: writer_core::ComponentWriter, core_wasm: Vec<i32>, plan: export_plan::ComponentExportPlan, mir: MirModule) -> Vec<i32> {
    component_base::comp_emit_wasi_and_core_instance_sections(out, core_wasm)
    export_sections::emit_generic_alias_section(out, plan)
    let export_type_indices = export_types::emit_generic_export_types(out, plan, mir)
    export_sections::emit_generic_canon_section(out, plan, export_type_indices)
    export_sections::emit_generic_export_section(out, plan, export_type_indices)
    writer_core::comp_writer_bytes(out)
}
