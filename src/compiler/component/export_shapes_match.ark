// Arukellt Selfhost - Component export shape matching
use component::export_function_view
use component::export_shapes_kinds
use component::export_shapes_option_predicates
use component::export_shapes_result_predicates
use component::export_shapes_string_predicates
use component::export_shapes_tuple_predicates
use component::naming
use mir::value_types

fn comp_function_matches_list_export(f: MirFunction, kind: i32) -> bool {
    if kind == export_shapes_kinds::LIST_I32_TO_I32() {
        return comp_function_is_list_i32_to_i32_export(f)
    }
    if kind == export_shapes_kinds::I32_TO_LIST_I32() {
        return comp_function_is_i32_to_list_i32_export(f)
    }
    if kind == export_shapes_kinds::LIST_I32_TO_LIST_I32() {
        return comp_function_is_list_i32_to_list_i32_export(f)
    }
    false
}

fn comp_function_matches_numeric_export(f: MirFunction, kind: i32) -> bool {
    if kind == export_shapes_kinds::F32_UNARY() {
        return comp_function_is_f32_unary_export(f)
    }
    if kind == export_shapes_kinds::F32_BINARY() {
        return comp_function_is_f32_binary_export(f)
    }
    if kind == export_shapes_kinds::F32_TO_I32() {
        return comp_function_is_f32_to_i32_export(f)
    }
    if kind == export_shapes_kinds::I32_TO_F32() {
        return comp_function_is_i32_to_f32_export(f)
    }
    false
}

fn comp_function_is_list_i32_to_i32_export(f: MirFunction) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 1 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), String_from("i32")) {
        return false
    }
    eq(export_function_view::export_function_param_type_name(f, 0), String_from("Vec"))
}

fn comp_function_is_i32_to_list_i32_export(f: MirFunction) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 1 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), String_from("Vec")) {
        return false
    }
    export_function_view::export_function_param_val_type(f, 0) == value_types::VT_I32() && !eq(export_function_view::export_function_param_type_name(f, 0), String_from("Vec"))
}

fn comp_function_is_list_i32_to_list_i32_export(f: MirFunction) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 1 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), String_from("Vec")) {
        return false
    }
    eq(export_function_view::export_function_param_type_name(f, 0), String_from("Vec"))
}

fn comp_function_is_f32_unary_export(f: MirFunction) -> bool {
    comp_function_is_unary_numeric_export(f, String_from("f32"), String_from("f32"))
}

fn comp_function_is_f32_binary_export(f: MirFunction) -> bool {
    comp_function_is_binary_numeric_export(f, String_from("f32"), String_from("f32"), String_from("f32"))
}

fn comp_function_is_f32_to_i32_export(f: MirFunction) -> bool {
    comp_function_is_unary_numeric_export(f, String_from("f32"), String_from("i32"))
}

fn comp_function_is_i32_to_f32_export(f: MirFunction) -> bool {
    comp_function_is_unary_numeric_export(f, String_from("i32"), String_from("f32"))
}

fn comp_function_is_unary_numeric_export(f: MirFunction, param_type: String, return_type: String) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 1 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), return_type) {
        return false
    }
    eq(export_function_view::export_function_param_type_name(f, 0), param_type)
}

fn comp_function_is_binary_numeric_export(f: MirFunction, left_type: String, right_type: String, return_type: String) -> bool {
    if !naming::comp_should_export_func(export_function_view::export_function_name(f)) {
        return false
    }
    if export_function_view::export_function_param_count(f) != 2 {
        return false
    }
    if !eq(export_function_view::export_function_return_type_name(f), return_type) {
        return false
    }
    eq(export_function_view::export_function_param_type_name(f, 0), left_type) && eq(export_function_view::export_function_param_type_name(f, 1), right_type)
}

fn comp_function_matches_option_export(f: MirFunction, kind: i32) -> bool {
    if kind == export_shapes_kinds::I32_TO_OPTION_I32() {
        return export_shapes_option_predicates::comp_function_is_i32_to_option_i32_export(f)
    }
    if kind == export_shapes_kinds::BOOL_TO_OPTION_BOOL() {
        return export_shapes_option_predicates::comp_function_is_bool_to_option_bool_export(f)
    }
    if kind == export_shapes_kinds::BOOL_TO_OPTION_I64() {
        return export_shapes_option_predicates::comp_function_is_bool_to_option_i64_export(f)
    }
    if kind == export_shapes_kinds::OPTION_I32_TO_I32() {
        return export_shapes_option_predicates::comp_function_is_option_i32_to_i32_export(f)
    }
    if kind == export_shapes_kinds::OPTION_I64_TO_I64() {
        return export_shapes_option_predicates::comp_function_is_option_i64_to_i64_export(f)
    }
    if kind == export_shapes_kinds::OPTION_I32_TO_OPTION_I32() {
        return export_shapes_option_predicates::comp_function_is_option_i32_to_option_i32_export(f)
    }
    false
}

fn comp_function_matches_result_export(f: MirFunction, kind: i32) -> bool {
    if kind == export_shapes_kinds::RESULT_I32_I32_TO_I32() {
        return export_shapes_result_predicates::comp_function_is_result_i32_i32_to_i32_export(f)
    }
    if kind == export_shapes_kinds::RESULT_I32_STRING_TO_I32() {
        return export_shapes_result_predicates::comp_function_is_result_i32_string_to_i32_export(f)
    }
    if kind == export_shapes_kinds::RESULT_I32_I32_TO_RESULT_I32_I32() {
        return export_shapes_result_predicates::comp_function_is_result_i32_i32_to_result_i32_i32_export(f)
    }
    if kind == export_shapes_kinds::BOOL_TO_RESULT_BOOL_BOOL() {
        return export_shapes_result_predicates::comp_function_is_bool_to_result_bool_bool_export(f)
    }
    if kind == export_shapes_kinds::I32_I32_TO_RESULT_I32_STRING() {
        return export_shapes_result_predicates::comp_function_is_i32_i32_to_result_i32_string_export(f)
    }
    false
}

fn comp_function_matches_string_export(f: MirFunction, kind: i32, return_name: String) -> bool {
    if kind == export_shapes_kinds::STRING_UNARY() {
        return export_shapes_string_predicates::comp_function_is_string_unary_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_I32() {
        return export_shapes_string_predicates::comp_function_is_string_to_i32_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_NAMED_I32() {
        return export_shapes_string_predicates::comp_function_is_string_to_named_i32_export(f, return_name)
    }
    if kind == export_shapes_kinds::STRING_TO_BOOL() {
        return export_shapes_string_predicates::comp_function_is_string_to_bool_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_CHAR() {
        return export_shapes_string_predicates::comp_function_is_string_to_char_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_F64() {
        return export_shapes_string_predicates::comp_function_is_string_to_f64_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_I64() {
        return export_shapes_string_predicates::comp_function_is_string_to_i64_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_U64() {
        return export_shapes_string_predicates::comp_function_is_string_to_u64_export(f)
    }
    if kind == export_shapes_kinds::STRING_TO_F32() {
        return export_shapes_string_predicates::comp_function_is_string_to_f32_export(f)
    }
    if kind == export_shapes_kinds::I32_TO_STRING() {
        return export_shapes_string_predicates::comp_function_is_i32_to_string_export(f)
    }
    false
}

fn comp_function_matches_tuple_export(f: MirFunction, kind: i32) -> bool {
    if kind == export_shapes_kinds::I32_I32_TO_TUPLE_I32_I32() {
        return export_shapes_tuple_predicates::comp_function_is_i32_i32_to_tuple_i32_i32_export(f)
    }
    if kind == export_shapes_kinds::I64_I64_TO_TUPLE_I64_I64() {
        return export_shapes_tuple_predicates::comp_function_is_i64_i64_to_tuple_i64_i64_export(f)
    }
    if kind == export_shapes_kinds::TUPLE_I32_I32_TO_I32() {
        return export_shapes_tuple_predicates::comp_function_is_tuple_i32_i32_to_i32_export(f)
    }
    if kind == export_shapes_kinds::TUPLE_I32_I32_TO_TUPLE_I32_I32() {
        return export_shapes_tuple_predicates::comp_function_is_tuple_i32_i32_to_tuple_i32_i32_export(f)
    }
    if kind == export_shapes_kinds::TUPLE_I32_BOOL_TO_I32() {
        return export_shapes_tuple_predicates::comp_function_is_tuple_i32_bool_to_i32_export(f)
    }
    if kind == export_shapes_kinds::TUPLE_BOOL_BOOL_TO_I32() {
        return export_shapes_tuple_predicates::comp_function_is_tuple_bool_bool_to_i32_export(f)
    }
    false
}
