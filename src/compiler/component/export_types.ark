// Arukellt Selfhost - generic component export type plan

use collections::vec_extend
use component::constants_sections_linkage
use component::export_function_view
use component::export_plan
use component::naming
use component::types_wit_compound
use component::types_wit_func
use component::writer_core
use mir::module_functions

struct TypeInterner {
	type_data: Vec<i32>,
	type_starts: Vec<i32>,
	type_ends: Vec<i32>,
}

fn TypeInterner_new() -> TypeInterner {
	TypeInterner { type_data: Vec_new_i32(), type_starts: Vec_new_i32(), type_ends: Vec_new_i32() }
}

fn type_interner_add(interner: TypeInterner, type_bytes: Vec<i32>) -> i32 {
	let idx = len(interner.type_starts)
	let start = len(interner.type_data)
	let n = len(type_bytes)
	vec_extend::Vec_extend_i32(interner.type_data, type_bytes)
	push(interner.type_starts, start)
	push(interner.type_ends, start + n)
	idx
}

fn type_interner_emit_entries(tw: writer_core::ComponentWriter, type_data: Vec<i32>, type_starts: Vec<i32>, type_ends: Vec<i32>) {
	let count = len(type_starts)
	let mut i = 0
	while i < count {
		let s = get_unchecked(type_starts, i)
		let e = get_unchecked(type_ends, i)
		let mut j = s
		while j < e {
			writer_core::comp_emit_byte(tw, get_unchecked(type_data, j))
			j = j + 1
		}
		i = i + 1
	}
}

fn type_interner_emit_section(out: writer_core::ComponentWriter, interner: TypeInterner) {
	let tw = writer_core::ComponentWriter_new()
	let count = len(interner.type_starts)
	writer_core::comp_emit_leb128_u(tw, count)
	type_interner_emit_entries(tw, interner.type_data, interner.type_starts, interner.type_ends)
	writer_core::comp_emit_section(out, constants_sections_linkage::COMP_SEC_TYPE(), tw)
}

fn comp_ensure_color_export_type(interner: TypeInterner, export_name: String, color_type_idx: i32) -> i32 {
	if naming::comp_export_uses_color(export_name) && color_type_idx < 0 {
		let color_names = Vec_new_String()
		push(color_names, String_from("red"))
		push(color_names, String_from("green"))
		push(color_names, String_from("blue"))
		return type_interner_add(interner, types_wit_compound::comp_wit_enum_type(color_names))
	}
	color_type_idx
}

fn emit_generic_export_types(out: writer_core::ComponentWriter, plan: export_plan::ComponentExportPlan, mir: MirModule) -> Vec<i32> {
	let mut export_type_indices: Vec<i32> = Vec_new_i32()
	let interner = TypeInterner_new()
	let mut color_type_idx = 0 - 1

	let mut ei = 0
	let export_count = export_plan::export_plan_count(plan)
	while ei < export_count {
		let idx = export_plan::export_plan_index_at(plan, ei)
		let f = module_functions::MirModule_function_at(mir, idx)
		let export_name = export_function_view::export_function_name(f)
		color_type_idx = comp_ensure_color_export_type(interner, clone(export_name), color_type_idx)

		let mut param_vts: Vec<i32> = Vec_new_i32()
		let mut pi = 0
		let param_count = export_function_view::export_function_param_count(f)
		while pi < param_count {
			let param = export_function_view::export_function_param_at(f, pi)
			if naming::comp_export_uses_color(clone(export_name)) {
				push(param_vts, color_type_idx)
			} else {
				push(param_vts, naming::comp_param_wit_type(clone(export_name), param))
			}
			pi = pi + 1
		}

		let mut result_vts: Vec<i32> = Vec_new_i32()
		if export_function_view::export_function_return_type(f) != 0 {
			if naming::comp_export_result_uses_color(export_name) {
				push(result_vts, color_type_idx)
			} else {
				push(result_vts, naming::comp_result_wit_type(f))
			}
		}

		let type_bytes = types_wit_func::comp_component_func_type(param_vts, result_vts)
		let type_idx = type_interner_add(interner, type_bytes)
		push(export_type_indices, type_idx)

		ei = ei + 1
	}

	type_interner_emit_section(out, interner)
	export_type_indices
}
