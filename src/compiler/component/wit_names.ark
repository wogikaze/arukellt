// Arukellt Selfhost - WIT naming helpers

fn wit_export_name(name: String) -> String {
	let mut out = String_from("")
	let n = len(name)
	let mut i = 0
	while i < n {
		let ch = char_at(name, i)
		if ch == 95 {
			out = concat(out, String_from("-"))
		} else {
			out = concat(out, substring(name, i, i + 1))
		}
		i = i + 1
	}
	out
}

fn wit_type_name(name: String) -> String {
	let mut out = String_from("")
	let n = len(name)
	let mut i = 0
	while i < n {
		let ch = char_at(name, i)
		if ch == 95 {
			out = concat(out, String_from("-"))
		} else {
			if ch >= 65 && ch <= 90 {
				out = concat(out, char_to_string(ch + 32))
			} else {
				out = concat(out, substring(name, i, i + 1))
			}
		}
		i = i + 1
	}
	out
}
