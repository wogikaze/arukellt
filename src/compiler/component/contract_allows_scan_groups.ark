use component::contract_allows_collection_record
use component::contract_allows_numeric
use component::contract_allows_string_record
use component::contract_allows_tuple
use component::contract_collection_list_scan
use component::contract_collection_option_scan
use component::contract_collection_result_scan
use component::contract_numeric_scan
use component::contract_string_scan
use component::contract_string_scan_queries
use component::contract_tuple_scan

fn component_collection_allows(list_scan: ComponentCollectionListScan, option_scan: ComponentCollectionOptionScan, result_scan: ComponentCollectionResultScan) -> ComponentCollectionAllows {
    contract_allows_collection_record::ComponentCollectionAllows_from_scans(list_scan, option_scan, result_scan)
}

fn component_string_allows(string_scan: ComponentStringScan) -> ComponentStringAllows {
    contract_allows_string_record::ComponentStringAllows_new(
        contract_string_scan_queries::ComponentStringScan_allows_string_unary(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_general_multi(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_i32_to_string(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_i32(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_narrow_i32(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_bool(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_char(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_f32(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_f64(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_i64(string_scan),
        contract_string_scan_queries::ComponentStringScan_allows_string_to_u64(string_scan)
    )
}

fn component_collection_allows_from_decls(decls: Vec<AstNode>) -> ComponentContractAllowsCollection {
    let list_scan = contract_collection_list_scan::component_collection_list_scan(decls)
    let option_scan = contract_collection_option_scan::component_collection_option_scan(decls)
    let result_scan = contract_collection_result_scan::component_collection_result_scan(decls)
    component_collection_allows(list_scan, option_scan, result_scan)
}

fn component_numeric_allows_from_decls(decls: Vec<AstNode>) -> ComponentContractAllowsNumeric {
    let numeric_scan = contract_numeric_scan::component_numeric_scan(decls)
    contract_allows_numeric::component_numeric_allows(numeric_scan)
}

fn component_string_allows_from_decls(decls: Vec<AstNode>) -> ComponentContractAllowsString {
    let string_scan = contract_string_scan::component_string_scan(decls)
    component_string_allows(string_scan)
}

fn component_tuple_allows_from_decls(decls: Vec<AstNode>) -> ComponentContractAllowsTuple {
    let tuple_scan = contract_tuple_scan::component_tuple_scan(decls)
    contract_allows_tuple::component_tuple_allows(tuple_scan)
}
