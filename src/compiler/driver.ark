        let b = get_unchecked(ty.children, 1)
        if a.kind != parser_kinds::NK_TYPE_NAMED() {
            return false
        }
        if b.kind != parser_kinds::NK_TYPE_NAMED() {
            return false
        }
        if !eq(clone(a.text), String_from("i32")) {
            return false
        }
        return eq(clone(b.text), String_from("bool"))
    }
    false
}

