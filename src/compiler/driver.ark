fn component_fn_is_string_unary(f: AstNode) -> bool {
    len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("String")) && eq(component_return_type_name(f), String_from("String"))
}

fn component_fn_is_i32_to_string(f: AstNode) -> bool {
    len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("i32")) && eq(component_return_type_name(f), String_from("String"))
}

fn component_fn_is_string_to_i32(f: AstNode) -> bool {
    len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("String")) && eq(component_return_type_name(f), String_from("i32"))
}

fn component_fn_is_string_to_named_i32(f: AstNode, ret_name: String) -> bool {
