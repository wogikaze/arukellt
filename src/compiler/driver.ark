// Arukellt Selfhost — Compilation Driver
//
// Orchestrates the compilation pipeline:
//   source → tokens → AST → (resolve → typecheck → HIR → MIR → Wasm)
// Error propagation stops at first phase failure.
use std::host::env
use std::host::fs
use std::host::process
use std::host::stdio

use component_emitter
use diagnostics
use emitter
use emit_wat
use lexer
use mir_dump
use mir_lower
use parser
use parser_kinds
use resolver
use typechecker

fn PHASE_LEX() -> i32 {
    1
}

fn PHASE_PARSE() -> i32 {
    2
}

fn PHASE_RESOLVE() -> i32 {
    3
}

fn PHASE_TYPECHECK() -> i32 {
    4
}

fn PHASE_LOWER() -> i32 {
    5
}

fn PHASE_EMIT() -> i32 {
    6
}

// ── Compilation Result ───────────────────────────────────────────────────────
struct CompileResult {
    success: bool,
    phase_reached: i32,
    error_count: i32,
    error_messages: Vec<String>,
    diagnostics: Vec<Diagnostic>,
    output_bytes: Vec<i32>,
}

fn CompileResult_ok(phase: i32) -> CompileResult {
    CompileResult { success: true, phase_reached: phase, error_count: 0, error_messages: Vec_new_String(), diagnostics: Vec_new_Diagnostic(), output_bytes: Vec_new_i32() }
}

fn CompileResult_err(phase: i32, msg: String) -> CompileResult {
    let mut msgs: Vec<String> = Vec_new_String()
    push(msgs, msg)
    CompileResult { success: false, phase_reached: phase, error_count: 1, error_messages: msgs, diagnostics: Vec_new_Diagnostic(), output_bytes: Vec_new_i32() }
}

// ── Byte Offset to Line/Column ───────────────────────────────────────────────
fn offset_to_line(source: String, offset: i32) -> i32 {
    let n = len(source)
    let mut line: i32 = 1
    let mut i: i32 = 0
    while i < offset && i < n {
        let c = char_at(source, i)
        if c == 10 {
            line = line + 1
        }
        i = i + 1
    }
    line
}

fn offset_to_column(source: String, offset: i32) -> i32 {
    let n = len(source)
    let mut col: i32 = 1
    let mut i: i32 = 0
    while i < offset && i < n {
        let c = char_at(source, i)
        if c == 10 {
            col = 1
        } else {
            col = col + 1
        }
        i = i + 1
    }
    col
}

// ── Driver Configuration ─────────────────────────────────────────────────────
struct DriverConfig {
    target: String,
    wasi_version: String,
    opt_level: i32,
    emit_mode: String,
    wit_paths: Vec<String>,
    dump_tokens: bool,
    dump_ast: bool,
    dump_hir: bool,
    dump_mir: bool,
    dump_wasm: bool,
    parse_only: bool,
    check_only: bool,
    source_dir: String,
}

pub fn DriverConfig_default() -> DriverConfig {
    DriverConfig { target: String_from("wasm32-wasi-p2"), wasi_version: String_from("p2"), opt_level: 0, emit_mode: String_from("wasm"), wit_paths: Vec_new_String(), dump_tokens: false, dump_ast: false, dump_hir: false, dump_mir: false, dump_wasm: false, parse_only: false, check_only: false, source_dir: String_from(".") }
}

fn driver_export_name(name: String) -> String {
    let mut out = String_from("")
    let n = len(name)
    let mut i = 0
    while i < n {
        let ch = char_at(name, i)
        if ch == 95 {
            out = concat(out, String_from("-"))
        } else {
            out = concat(out, substring(name, i, i + 1))
        }
        i = i + 1
    }
    out
}

fn driver_wit_type_name(name: String) -> String {
    let mut out = String_from("")
    let n = len(name)
    let mut i = 0
    while i < n {
        let ch = char_at(name, i)
        if ch == 95 {
            out = concat(out, String_from("-"))
        } else {
            if ch >= 65 && ch <= 90 {
                out = concat(out, char_to_string(ch + 32))
            } else {
                out = concat(out, substring(name, i, i + 1))
            }
        }
        i = i + 1
    }
    out
}

fn driver_should_export_func(name: String) -> bool {
    if eq(clone(name), String_from("main")) || eq(clone(name), String_from("_start")) {
        return false
    }
    if eq(clone(name), String_from("print")) || eq(clone(name), String_from("println")) || eq(clone(name), String_from("eprintln")) {
        return false
    }
    if contains(clone(name), String_from("::")) {
        return false
    }
    true
}

fn wit_type_from_ast(ty: AstNode) -> String {
    if ty.kind == parser_kinds::NK_TYPE_NAMED() {
        let name = clone(ty.text)
        if eq(clone(name), String_from("i32")) {
            return String_from("s32")
        }
        if eq(clone(name), String_from("i64")) {
            return String_from("s64")
        }
        if eq(clone(name), String_from("f32")) {
            return String_from("f32")
        }
        if eq(clone(name), String_from("f64")) {
            return String_from("f64")
        }
        if eq(clone(name), String_from("bool")) {
            return String_from("bool")
        }
        if eq(clone(name), String_from("char")) {
            return String_from("char")
        }
        if eq(clone(name), String_from("u8")) {
            return String_from("u8")
        }
        if eq(clone(name), String_from("u16")) {
            return String_from("u16")
        }
        if eq(clone(name), String_from("u32")) {
            return String_from("u32")
        }
        if eq(clone(name), String_from("u64")) {
            return String_from("u64")
        }
        if eq(clone(name), String_from("i8")) {
            return String_from("s8")
        }
        if eq(clone(name), String_from("i16")) {
            return String_from("s16")
        }
        if eq(clone(name), String_from("String")) || eq(clone(name), String_from("string")) {
            return String_from("string")
        }
        return driver_wit_type_name(name)
    }
    if ty.kind == parser_kinds::NK_TYPE_GENERIC() {
        let name = clone(ty.text)
        if eq(clone(name), String_from("Vec")) && len(ty.children) > 1 {
            return concat(String_from("list<"), concat(wit_type_from_ast(get_unchecked(ty.children, 1)), String_from(">")))
        }
        if eq(clone(name), String_from("Option")) && len(ty.children) > 1 {
            return concat(String_from("option<"), concat(wit_type_from_ast(get_unchecked(ty.children, 1)), String_from(">")))
        }
        if eq(clone(name), String_from("Result")) && len(ty.children) > 2 {
            return concat(String_from("result<"), concat(wit_type_from_ast(get_unchecked(ty.children, 1)), concat(String_from(", "), concat(wit_type_from_ast(get_unchecked(ty.children, 2)), String_from(">")))))
        }
        return driver_wit_type_name(name)
    }
    if ty.kind == parser_kinds::NK_TYPE_TUPLE() {
        let mut out = String_from("tuple<")
        let mut i = 0
        while i < len(ty.children) {
            if i > 0 {
                out = concat(out, String_from(", "))
            }
            out = concat(out, wit_type_from_ast(get_unchecked(ty.children, i)))
            i = i + 1
        }
        return concat(out, String_from(">"))
    }
    String_from("s32")
}

fn wit_type_for_vt(vt: i32) -> String {
    if vt == 1 {
        return String_from("s32")
    }
    if vt == 2 {
        return String_from("s64")
    }
    if vt == 3 {
        return String_from("f64")
    }
    if vt == 4 {
        return String_from("string")
    }
    String_from("s32")
}

fn emit_wit_type_defs(decls: Vec<AstNode>) -> String {
    let mut out = String_from("")
    let mut i = 0
    while i < len(decls) {
        let d = get_unchecked(decls, i)
        if d.kind == parser_kinds::NK_STRUCT_DECL() {
            out = concat(out, String_from("  record "))
            out = concat(out, driver_wit_type_name(clone(d.text)))
            out = concat(out, String_from(" {\n"))
            let mut fi = 0
            while fi < len(d.children) {
                let field = get_unchecked(d.children, fi)
                out = concat(out, String_from("    "))
                out = concat(out, driver_export_name(clone(field.text)))
                out = concat(out, String_from(": "))
                if len(field.type_ann) > 0 {
                    out = concat(out, wit_type_from_ast(get_unchecked(field.type_ann, 0)))
                } else {
                    out = concat(out, String_from("s32"))
                }
                out = concat(out, String_from(",\n"))
                fi = fi + 1
            }
            out = concat(out, String_from("  }\n\n"))
        }
        if d.kind == parser_kinds::NK_ENUM_DECL() {
            let mut payload_count = 0
            let mut vi0 = 0
            while vi0 < len(d.children) {
                let v0 = get_unchecked(d.children, vi0)
                if len(v0.type_ann) > 0 || len(v0.children) > 0 {
                    payload_count = payload_count + 1
                }
                vi0 = vi0 + 1
            }
            if payload_count == 0 {
                out = concat(out, String_from("  enum "))
            } else {
                out = concat(out, String_from("  variant "))
            }
            out = concat(out, driver_wit_type_name(clone(d.text)))
            out = concat(out, String_from(" {\n"))
            let mut vi = 0
            while vi < len(d.children) {
                let variant = get_unchecked(d.children, vi)
                out = concat(out, String_from("    "))
                out = concat(out, driver_wit_type_name(clone(variant.text)))
                if len(variant.type_ann) > 0 {
                    out = concat(out, String_from("("))
                    out = concat(out, wit_type_from_ast(get_unchecked(variant.type_ann, 0)))
                    out = concat(out, String_from(")"))
                }
                out = concat(out, String_from(",\n"))
                vi = vi + 1
            }
            out = concat(out, String_from("  }\n\n"))
        }
        i = i + 1
    }
    out
}

fn fn_return_wit_type(f: AstNode) -> String {
    let mut i = 0
    while i < len(f.type_ann) {
        let ann = get_unchecked(f.type_ann, i)
        if eq(clone(ann.text), String_from("__return")) && len(ann.children) > 0 {
            return wit_type_from_ast(get_unchecked(ann.children, 0))
        }
        i = i + 1
    }
    String_new()
}

fn component_has_record_point_decls(decls: Vec<AstNode>) -> bool {
    let mut has_point_shape = false
    let mut has_distance = false
    let mut has_add = false
    let mut export_count = 0
    let mut i = 0
    while i < len(decls) {
        let d = get_unchecked(decls, i)
        if d.kind == parser_kinds::NK_STRUCT_DECL() && eq(clone(d.text), String_from("Point")) {
            if len(d.children) == 2 {
                let f0 = get_unchecked(d.children, 0)
                let f1 = get_unchecked(d.children, 1)
                if eq(clone(f0.text), String_from("x")) && eq(clone(f1.text), String_from("y")) && len(f0.type_ann) > 0 && len(f1.type_ann) > 0 {
                    let t0 = get_unchecked(f0.type_ann, 0)
                    let t1 = get_unchecked(f1.type_ann, 0)
                    if eq(clone(t0.text), String_from("i32")) && eq(clone(t1.text), String_from("i32")) {
                        has_point_shape = true
                    }
                }
            }
        }
        if d.kind == parser_kinds::NK_FN_DECL() && d.is_pub && driver_should_export_func(clone(d.text)) {
            export_count = export_count + 1
            if component_fn_is_point_to_i32(d) {
                has_distance = true
            }
            if component_fn_is_point_point_to_point(d) {
                has_add = true
            }
        }
        i = i + 1
    }
    has_point_shape && has_distance && has_add && export_count == 2
}

