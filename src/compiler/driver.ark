fn component_has_string_unary_decls(decls: Vec<AstNode>) -> bool {
    let mut has_string = false
    let mut export_count = 0
    let mut i = 0
    while i < len(decls) {
        let d = get_unchecked(decls, i)
        if d.kind == parser_kinds::NK_FN_DECL() && d.is_pub && driver_should_export_func(clone(d.text)) {
            export_count = export_count + 1
            if component_fn_is_string_unary(d) {
                has_string = true
            }
        }
        i = i + 1
    }
    has_string && export_count == 1
}

