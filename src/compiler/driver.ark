fn component_special_type_supported(fn_name: String, type_name: String) -> bool {
    if eq(clone(type_name), String_from("Point")) {
        return eq(clone(fn_name), String_from("distance_sq")) || eq(clone(fn_name), String_from("add_points"))
    }
    if eq(clone(type_name), String_from("Color")) {
        return eq(clone(fn_name), String_from("next_color")) || eq(clone(fn_name), String_from("color_to_value")) || eq(clone(fn_name), String_from("color_code"))
    }
    if eq(clone(type_name), String_from("Shape")) {
        return eq(clone(fn_name), String_from("area"))
    }
    if eq(clone(type_name), String_from("String")) {
        return true
    }
    false
}

fn component_param_type_name_at(f: AstNode, idx: i32) -> String {
    if idx < 0 || idx >= len(f.children) - 1 {
        return String_new()
    }
    let p = get_unchecked(f.children, idx)
    if len(p.type_ann) == 0 {
        return String_new()
    }
    let ty = get_unchecked(p.type_ann, 0)
    clone(ty.text)
}

fn component_return_type_name(f: AstNode) -> String {
    let mut i = 0
    while i < len(f.type_ann) {
        let ann = get_unchecked(f.type_ann, i)
        if eq(clone(ann.text), String_from("__return")) {
            if len(ann.children) > 0 {
                let ret = get_unchecked(ann.children, 0)
                return clone(ret.text)
            }
            return String_from("()")
        }
        i = i + 1
    }
    String_from("()")
}

fn component_special_signature_supported(f: AstNode) -> bool {
    let name = clone(f.text)
    if eq(clone(name), String_from("distance_sq")) {
        return len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("Point")) && eq(component_return_type_name(f), String_from("i32"))
    }
    if eq(clone(name), String_from("add_points")) {
        return len(f.children) == 3 && eq(component_param_type_name_at(f, 0), String_from("Point")) && eq(component_param_type_name_at(f, 1), String_from("Point")) && eq(component_return_type_name(f), String_from("Point"))
    }
    if eq(clone(name), String_from("next_color")) {
        return len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("Color")) && eq(component_return_type_name(f), String_from("Color"))
    }
    if eq(clone(name), String_from("color_to_value")) {
        return len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("Color")) && eq(component_return_type_name(f), String_from("i32"))
    }
    if eq(clone(name), String_from("color_code")) {
        return len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("Color")) && eq(component_return_type_name(f), String_from("i32"))
    }
    if eq(clone(name), String_from("area")) {
        return len(f.children) == 2 && eq(component_param_type_name_at(f, 0), String_from("Shape")) && eq(component_return_type_name(f), String_from("f64"))
    }
    if eq(clone(name), String_from("greet")) {
        return component_fn_is_string_unary(f) || component_fn_is_string_to_i32(f) || component_fn_is_string_to_narrow_i32(f) || component_fn_is_string_to_bool(f) || component_fn_is_string_to_char(f) || component_fn_is_string_to_f32(f) || component_fn_is_string_to_f64(f) || component_fn_is_string_to_i64(f) || component_fn_is_string_to_u64(f)
    }
    if eq(clone(name), String_from("first_or_zero")) {
        return component_fn_is_vec_i32_to_i32(f)
    }
    if eq(clone(name), String_from("maybe_double")) {
        return component_fn_is_i32_to_option_i32(f)
    }
    if eq(clone(name), String_from("safe_div")) {
        return component_fn_is_i32_i32_to_result_i32_string(f)
    }
    if eq(clone(name), String_from("square32")) {
        return component_fn_is_f32_unary(f)
    }
    if eq(clone(name), String_from("swap")) {
        return component_fn_is_i32_i32_to_tuple_i32_i32(f)
    }
    true
}

fn component_type_supported_for_func(ty: AstNode, fn_name: String, allow_record_point: bool, allow_record_distance: bool, allow_record_roundtrip: bool, allow_record_add: bool, allow_color_enum: bool, allow_color_code: bool, allow_color_roundtrip: bool, allow_shape_area: bool, allow_shape_roundtrip: bool, allow_string_greet: bool, allow_string_result: bool, allow_string_param: bool, allow_string_narrow: bool, allow_string_bool: bool, allow_string_char: bool, allow_string_f32: bool, allow_string_f64: bool, allow_string_i64: bool, allow_string_u64: bool, allow_list_first: bool, allow_list_result: bool, allow_list_roundtrip: bool, allow_option_maybe: bool, allow_option_param: bool, allow_option_roundtrip: bool, allow_option_bool: bool, allow_option_i64: bool, allow_option_i64_param: bool, allow_result_safe_div: bool, allow_result_param: bool, allow_result_string_param: bool, allow_result_roundtrip: bool, allow_result_bool: bool, allow_f32_square: bool, allow_f32_binary: bool, allow_f32_to_i32: bool, allow_i32_to_f32: bool, allow_tuple_swap: bool, allow_tuple_i64_swap: bool, allow_tuple_param: bool, allow_tuple_mixed_param: bool, allow_tuple_bool_param: bool, allow_tuple_roundtrip: bool) -> bool {
    if (allow_list_first || allow_list_result || allow_list_roundtrip) && component_type_is_vec_i32(ty) {
        return true
    }
    if (allow_option_maybe || allow_option_param || allow_option_roundtrip) && component_type_is_option_i32(ty) {
        return true
    }
    if allow_option_bool && component_type_is_option_bool(ty) {
        return true
    }
    if (allow_option_i64 || allow_option_i64_param) && component_type_is_option_i64(ty) {
        return true
    }
    if allow_result_safe_div && component_type_is_result_i32_string(ty) {
        return true
    }
    if allow_result_string_param && component_type_is_result_i32_string(ty) {
        return true
    }
    if (allow_result_param || allow_result_roundtrip) && component_type_is_result_i32_i32(ty) {
        return true
    }
    if allow_result_bool && component_type_is_result_bool_bool(ty) {
        return true
    }
    if (allow_tuple_swap || allow_tuple_param || allow_tuple_roundtrip) && component_type_is_tuple_i32_i32(ty) {
        return true
    }
    if allow_tuple_i64_swap && component_type_is_tuple_i64_i64(ty) {
        return true
    }
    if allow_tuple_mixed_param && component_type_is_tuple_i32_bool(ty) {
        return true
    }
    if allow_tuple_bool_param && component_type_is_tuple_bool_bool(ty) {
        return true
    }
    if ty.kind == parser_kinds::NK_TYPE_NAMED() {
        let name = clone(ty.text)
        if eq(clone(name), String_from("i32")) || eq(clone(name), String_from("i64")) || eq(clone(name), String_from("f64")) || eq(clone(name), String_from("bool")) || eq(clone(name), String_from("char")) || eq(clone(name), String_from("u8")) || eq(clone(name), String_from("u16")) || eq(clone(name), String_from("u32")) || eq(clone(name), String_from("u64")) || eq(clone(name), String_from("i8")) || eq(clone(name), String_from("i16")) {
            return true
        }
        if (allow_f32_square || allow_f32_binary || allow_f32_to_i32 || allow_i32_to_f32 || allow_string_f32) && eq(clone(name), String_from("f32")) {
            return true
        }
        if (allow_string_greet || allow_string_result || allow_string_param || allow_string_narrow || allow_string_bool || allow_string_char || allow_string_f32 || allow_string_f64 || allow_string_i64 || allow_string_u64) && eq(clone(name), String_from("String")) {
            return true
        }
        if allow_record_distance && eq(clone(name), String_from("Point")) {
            return true
        }
        if allow_record_point && eq(clone(name), String_from("Point")) {
            return true
        }
        if (allow_record_roundtrip || allow_record_add) && eq(clone(name), String_from("Point")) {
            return true
        }
        if allow_color_code && eq(clone(name), String_from("Color")) {
            return true
        }
        if (allow_color_enum || allow_color_roundtrip) && eq(clone(name), String_from("Color")) {
            return true
        }
        if (allow_shape_area || allow_shape_roundtrip) && eq(clone(name), String_from("Shape")) {
            return true
        }
        return false
    }
    false
}

fn validate_component_export_surface(decls: Vec<AstNode>) -> String {
    let allow_record_point = component_has_record_point_decls(decls)
    let allow_record_distance = component_has_record_distance_decls(decls)
    let allow_record_add = component_has_record_add_decls(decls)
    let allow_color_enum = component_has_color_enum_decls(decls)
    let allow_color_code = component_has_color_code_decls(decls)
    let allow_color_roundtrip = component_has_color_roundtrip_decls(decls)
    let allow_shape_area = component_has_shape_area_decls(decls)
    let allow_shape_roundtrip = component_has_shape_roundtrip_decls(decls)
    let allow_string_greet = component_has_string_unary_decls(decls)
    let allow_string_result = component_has_string_result_decls(decls)
    let allow_string_param = component_has_string_param_decls(decls)
    let allow_string_narrow = component_has_string_narrow_i32_decls(decls)
    let allow_string_bool = component_has_string_bool_decls(decls)
    let allow_string_char = component_has_string_char_decls(decls)
    let allow_string_f64 = component_has_string_f64_decls(decls)
    let allow_string_i64 = component_has_string_i64_decls(decls)
    let allow_string_u64 = component_has_string_u64_decls(decls)
    let allow_string_f32 = component_has_string_f32_decls(decls)
    let allow_list_first = component_has_list_unary_decls(decls)
    let allow_list_result = component_has_list_result_decls(decls)
    let allow_list_roundtrip = component_has_list_roundtrip_decls(decls)
    let allow_option_maybe = component_has_option_unary_decls(decls)
    let allow_option_param = component_has_option_param_decls(decls)
    let allow_option_roundtrip = component_has_option_roundtrip_decls(decls)
    let allow_option_bool = component_has_option_bool_decls(decls)
    let allow_option_i64 = component_has_option_i64_decls(decls)
    let allow_option_i64_param = component_has_option_i64_param_decls(decls)
    let allow_result_safe_div = component_has_result_binary_decls(decls)
    let allow_result_param = component_has_result_param_decls(decls)
    let allow_result_string_param = component_has_result_string_param_decls(decls)
    let allow_result_roundtrip = component_has_result_roundtrip_decls(decls)
    let allow_result_bool = component_has_result_bool_decls(decls)
    let allow_f32_square = component_has_f32_unary_decls(decls)
    let allow_f32_binary = component_has_f32_binary_decls(decls)
    let allow_f32_to_i32 = component_has_f32_to_i32_decls(decls)
    let allow_i32_to_f32 = component_has_i32_to_f32_decls(decls)
    let allow_tuple_swap = component_has_tuple_binary_decls(decls)
    let allow_tuple_i64_swap = component_has_tuple_i64_binary_decls(decls)
    let allow_tuple_param = component_has_tuple_param_decls(decls)
    let allow_tuple_mixed_param = component_has_tuple_mixed_param_decls(decls)
    let allow_tuple_bool_param = component_has_tuple_bool_param_decls(decls)
    let allow_tuple_roundtrip = component_has_tuple_roundtrip_decls(decls)
    let allow_record_roundtrip = component_has_record_roundtrip_decls(decls)
    let mut i = 0
    while i < len(decls) {
        let f = get_unchecked(decls, i)
        if f.kind == parser_kinds::NK_FN_DECL() && f.is_pub && driver_should_export_func(clone(f.text)) {
            if allow_string_greet && !component_fn_is_string_unary(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_result && !component_fn_is_i32_to_string(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_param && !component_fn_is_string_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_narrow && !component_fn_is_string_to_narrow_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_bool && !component_fn_is_string_to_bool(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_char && !component_fn_is_string_to_char(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_f64 && !component_fn_is_string_to_f64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_i64 && !component_fn_is_string_to_i64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_u64 && !component_fn_is_string_to_u64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_string_f32 && !component_fn_is_string_to_f32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_list_first && !component_fn_is_vec_i32_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_list_result && !component_fn_is_i32_to_vec_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_list_roundtrip && !component_fn_is_vec_i32_to_vec_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_option_maybe && !component_fn_is_i32_to_option_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_option_param && !component_fn_is_option_i32_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_option_roundtrip && !component_fn_is_option_i32_to_option_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_option_bool && !component_fn_is_bool_to_option_bool(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_option_i64 && !component_fn_is_bool_to_option_i64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_option_i64_param && !component_fn_is_option_i64_to_i64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_result_safe_div && !component_fn_is_i32_i32_to_result_i32_string(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_result_param && !component_fn_is_result_i32_i32_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_result_string_param && !component_fn_is_result_i32_string_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_result_roundtrip && !component_fn_is_result_i32_i32_to_result_i32_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_result_bool && !component_fn_is_bool_to_result_bool_bool(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_f32_square && !component_fn_is_f32_unary(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_f32_binary && !component_fn_is_f32_binary(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_f32_to_i32 && !component_fn_is_f32_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_i32_to_f32 && !component_fn_is_i32_to_f32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_tuple_swap && !component_fn_is_i32_i32_to_tuple_i32_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_tuple_i64_swap && !component_fn_is_i64_i64_to_tuple_i64_i64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_tuple_param && !component_fn_is_tuple_i32_i32_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_tuple_mixed_param && !component_fn_is_tuple_i32_bool_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_tuple_bool_param && !component_fn_is_tuple_bool_bool_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_tuple_roundtrip && !component_fn_is_tuple_i32_i32_to_tuple_i32_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_record_distance && !component_fn_is_point_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_record_point && !(component_fn_is_point_to_i32(f) || component_fn_is_point_point_to_point(f)) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_record_roundtrip && !component_fn_is_point_to_point(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_record_add && !component_fn_is_point_point_to_point(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_color_code && !component_fn_is_color_to_i32(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_color_enum && !(component_fn_is_color_to_color(f) || component_fn_is_color_to_i32(f)) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_color_roundtrip && !component_fn_is_color_to_color(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_shape_area && !component_fn_is_shape_to_f64(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if allow_shape_roundtrip && !component_fn_is_shape_to_shape(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            if !component_special_signature_supported(f) {
                return concat(String_from("E0401: component export uses a special adapter signature not supported by canonical ABI: "), clone(f.text))
            }
            let mut pi = 0
            while pi < len(f.children) - 1 {
                let p = get_unchecked(f.children, pi)
                if len(p.type_ann) == 0 {
                    return concat(String_from("E0401: component export requires explicit parameter type annotations: "), clone(f.text))
                }
                let pty = get_unchecked(p.type_ann, 0)
                if !component_type_supported_for_func(pty, clone(f.text), allow_record_point, allow_record_distance, allow_record_roundtrip, allow_record_add, allow_color_enum, allow_color_code, allow_color_roundtrip, allow_shape_area, allow_shape_roundtrip, allow_string_greet, allow_string_result, allow_string_param, allow_string_narrow, allow_string_bool, allow_string_char, allow_string_f32, allow_string_f64, allow_string_i64, allow_string_u64, allow_list_first, allow_list_result, allow_list_roundtrip, allow_option_maybe, allow_option_param, allow_option_roundtrip, allow_option_bool, allow_option_i64, allow_option_i64_param, allow_result_safe_div, allow_result_param, allow_result_string_param, allow_result_roundtrip, allow_result_bool, allow_f32_square, allow_f32_binary, allow_f32_to_i32, allow_i32_to_f32, allow_tuple_swap, allow_tuple_i64_swap, allow_tuple_param, allow_tuple_mixed_param, allow_tuple_bool_param, allow_tuple_roundtrip) {
                    return concat(String_from("E0401: component export uses a type not yet supported by canonical ABI: "), clone(f.text))
                }
                pi = pi + 1
            }
            let mut ai = 0
            while ai < len(f.type_ann) {
                let ann = get_unchecked(f.type_ann, ai)
                if eq(clone(ann.text), String_from("__return")) && len(ann.children) > 0 {
                    let rty = get_unchecked(ann.children, 0)
                    if !component_type_supported_for_func(rty, clone(f.text), allow_record_point, allow_record_distance, allow_record_roundtrip, allow_record_add, allow_color_enum, allow_color_code, allow_color_roundtrip, allow_shape_area, allow_shape_roundtrip, allow_string_greet, allow_string_result, allow_string_param, allow_string_narrow, allow_string_bool, allow_string_char, allow_string_f32, allow_string_f64, allow_string_i64, allow_string_u64, allow_list_first, allow_list_result, allow_list_roundtrip, allow_option_maybe, allow_option_param, allow_option_roundtrip, allow_option_bool, allow_option_i64, allow_option_i64_param, allow_result_safe_div, allow_result_param, allow_result_string_param, allow_result_roundtrip, allow_result_bool, allow_f32_square, allow_f32_binary, allow_f32_to_i32, allow_i32_to_f32, allow_tuple_swap, allow_tuple_i64_swap, allow_tuple_param, allow_tuple_mixed_param, allow_tuple_bool_param, allow_tuple_roundtrip) {
                        return concat(String_from("E0401: component export uses a type not yet supported by canonical ABI: "), clone(f.text))
                    }
                }
                ai = ai + 1
            }
        }
        i = i + 1
    }
    String_new()
}

fn emit_wit_text_from_decls(decls: Vec<AstNode>) -> String {
    let mut out = String_from("package arukellt:generated;\n\nworld arukellt {\n")
    out = concat(out, emit_wit_type_defs(decls))
    let mut i = 0
    while i < len(decls) {
        let f = get_unchecked(decls, i)
        if f.kind == parser_kinds::NK_FN_DECL() {
        if driver_should_export_func(clone(f.text)) {
            out = concat(out, String_from("  export "))
            out = concat(out, driver_export_name(clone(f.text)))
            out = concat(out, String_from(": func("))
            let mut pi = 0
            while pi < len(f.children) - 1 {
                if pi > 0 {
                    out = concat(out, String_from(", "))
                }
                let p = get_unchecked(f.children, pi)
                let pname = clone(p.text)
                if len(clone(pname)) > 0 {
                    out = concat(out, pname)
                } else {
                    out = concat(out, concat(String_from("arg"), to_string(pi)))
                }
                out = concat(out, String_from(": "))
                if len(p.type_ann) > 0 {
                    out = concat(out, wit_type_from_ast(get_unchecked(p.type_ann, 0)))
                } else {
                    out = concat(out, String_from("s32"))
                }
                pi = pi + 1
            }
            out = concat(out, String_from(")"))
            let ret = fn_return_wit_type(f)
            if len(ret) > 0 {
                out = concat(out, String_from(" -> "))
                out = concat(out, ret)
            }
            out = concat(out, String_from(";\n"))
        }
        }
        i = i + 1
    }
    concat(out, String_from("}\n"))
}

fn string_to_bytes(text: String) -> Vec<i32> {
    let mut bytes = Vec_new_i32()
    let mut i = 0
    while i < len(text) {
        push(bytes, char_at(text, i))
        i = i + 1
    }
    bytes
}

fn validate_wit_import_surface(paths: Vec<String>) -> String {
    let mut i = 0
    while i < len(paths) {
        let path = get_unchecked(paths, i)
        let read_result = fs::read_to_string(clone(path))
        match read_result {
            Result::Ok(text) => {
                if contains(clone(text), String_from("flags")) {
                    return concat(String_from("E0090: unsupported WIT flags type in "), clone(path))
                }
                if contains(clone(text), String_from("resource ")) {
                    return concat(String_from("E0402: unsupported WIT resource type in "), clone(path))
                }
                if contains(clone(text), String_from("own<")) || contains(clone(text), String_from("borrow<")) {
                    return concat(String_from("E0402: unsupported WIT resource handle type in "), clone(path))
                }
                if contains(clone(text), String_from("stream<")) || contains(clone(text), String_from("future<")) {
                    return concat(String_from("E0402: unsupported WIT async resource type in "), clone(path))
                }
                if contains(clone(text), String_from("import ")) && contains(clone(text), String_from(": func(")) {
                    return concat(String_from("E0401: WIT function imports are not yet bound to resolver/MIR: "), clone(path))
                }
            },
            Result::Err(e) => {
                return concat(String_from("unable to read WIT file "), concat(clone(path), concat(String_from(": "), e)))
            },
        }
        i = i + 1
    }
    String_new()
}

// ── File Loading ─────────────────────────────────────────────────────────────
fn load_source(path: String) -> Result<String, String> {
    fs::read_to_string(path)
}

// ── Module Loading ───────────────────────────────────────────────────────────
// Loads imported modules referenced by `use` declarations.
// Handles local .ark files, circular import detection, and stdlib recognition.
/// Returns true if the use path is a stdlib import (starts with "std::").
fn is_stdlib_path(path: String) -> bool {
    let n = len(path)
    if n < 5 {
        return false
    }
    eq(substring(path, 0, 5), String_from("std::"))
}

/// Returns the parent directory of a file path (everything before the last '/').
fn parent_dir(path: String) -> String {
    let n = len(path)
    let mut last_slash = 0 - 1
    let mut i = n - 1
    while i >= 0 {
        if eq(substring(path, i, i + 1), String_from("/")) {
            last_slash = i
            i = 0 - 1
        } else {
            i = i - 1
        }
    }
    if last_slash < 0 {
        String_from(".")
    } else {
        if last_slash == 0 {
            String_from("/")
        } else {
            substring(path, 0, last_slash)
        }
    }
}

// Module loading state: tracks loaded and in-progress modules for cycle detection.
// ModuleDecls is defined here (structurally identical to resolver::ModuleDecls)
// because the Ark parser does not support qualified type names in generic params.
struct ModuleDecls {
    name: String,
    decls: Vec<AstNode>,
}

struct LoadState {
    loaded_names: Vec<String>,
    loading_stack: Vec<String>,
    modules: Vec<ModuleDecls>,
    errors: Vec<String>,
}

fn LoadState_new() -> LoadState {
    LoadState { loaded_names: Vec_new_String(), loading_stack: Vec_new_String(), modules: Vec_new_ModuleDecls(), errors: Vec_new_String() }
}

/// Check if a name is in a string vector.
fn vec_has(v: Vec<String>, name: String) -> bool {
    let count = len(v)
    let mut i = 0
    while i < count {
        if eq(clone(get_unchecked(v, i)), clone(name)) {
            return true
        }
        i = i + 1
    }
    false
}

/// Convert a stdlib import path to a relative file path.
/// "std::core::cmp" → "std/core/cmp.ark"
fn stdlib_path_to_file(path: String) -> String {
    let n = len(path)
    let mut result = String_from("")
    let mut i = 0
    let mut seg_start = 0
    while i < n {
        if char_at(path, i) == 58 && i + 1 < n && char_at(path, i + 1) == 58 {
            result = concat(clone(result), concat(substring(clone(path), seg_start, i), String_from("/")))
            i = i + 2
            seg_start = i
        } else {
            i = i + 1
        }
    }
    concat(clone(result), concat(substring(clone(path), seg_start, n), String_from(".ark")))
}

/// Try to load a stdlib module from the std/ directory.
/// Silently skips if no file is found (host-only intrinsic modules).
fn load_stdlib_module(stdlib_path: String, state: LoadState) {
    if vec_has(state.loaded_names, clone(stdlib_path)) {
        return
    }
    if vec_has(state.loading_stack, clone(stdlib_path)) {
        return
    }
    let short_name = use_module_short_name(clone(stdlib_path))
    let primary = stdlib_path_to_file(clone(stdlib_path))
    let source_res = fs::read_to_string(clone(primary))
    match source_res {
        Result::Ok(src) => {
            load_stdlib_source(clone(stdlib_path), clone(short_name), src, state)
        },
        Result::Err(_) => {
            let n = len(primary)
            let mod_path = concat(substring(clone(primary), 0, n - 4), String_from("/mod.ark"))
            let mod_res = fs::read_to_string(clone(mod_path))
            match mod_res {
                Result::Ok(src) => {
                    load_stdlib_source(clone(stdlib_path), clone(short_name), src, state)
                },
                Result::Err(_) => {
                },
            }
        },
    }
}

fn load_stdlib_source(stdlib_path: String, short_name: String, source: String, state: LoadState) {
    push(state.loading_stack, clone(stdlib_path))
    let tokens: Vec<Token> = lexer::tokenize(clone(source))
    let p = parser::Parser_new(tokens)
    let mod_decls: Vec<AstNode> = parser::parse_module(p)
    push(state.loaded_names, clone(stdlib_path))
    push(state.modules, ModuleDecls { name: clone(short_name), decls: mod_decls })
    load_imported_modules(mod_decls, String_from("."), state)
}

/// Scan declarations for use statements and load referenced local modules.
/// Recursively loads transitive imports. Detects circular imports.
fn load_imported_modules(decls: Vec<AstNode>, base_dir: String, state: LoadState) {
    let count = len(decls)
    let mut i = 0
    while i < count {
        let d = get_unchecked(decls, i)
        if d.kind == 54 {
            let use_path = clone(d.text)
            if is_stdlib_path(clone(use_path)) {
                load_stdlib_module(clone(use_path), state)
            } else {
                load_single_module(clone(use_path), clone(base_dir), state)
            }
            let num_children = len(d.children)
            let mut ci = 0
            while ci < num_children {
                let child = get_unchecked(d.children, ci)
                if child.kind == 54 {
                    let child_path = clone(child.text)
                    if is_stdlib_path(clone(child_path)) {
                        load_stdlib_module(clone(child_path), state)
                    } else {
                        load_single_module(clone(child_path), clone(base_dir), state)
                    }
                }
                ci = ci + 1
            }
        }
        i = i + 1
    }
}

/// Load a single module by name from the given directory.
fn load_single_module(module_name: String, base_dir: String, state: LoadState) {
    if vec_has(state.loaded_names, clone(module_name)) {
        return
    }
    if vec_has(state.loading_stack, clone(module_name)) {
        push(state.errors, concat(String_from("circular import detected: "), clone(module_name)))
        return
    }
    push(state.loading_stack, clone(module_name))
    let file_path = concat(clone(base_dir), concat(String_from("/"), concat(clone(module_name), String_from(".ark"))))
    let source_result = fs::read_to_string(file_path)
    match source_result {
        Result::Ok(source) => {
            let tokens: Vec<Token> = lexer::tokenize(clone(source))
            let p = parser::Parser_new(tokens)
            let mod_decls: Vec<AstNode> = parser::parse_module(p)
            push(state.loaded_names, clone(module_name))
            push(state.modules, ModuleDecls { name: clone(module_name), decls: mod_decls })
            load_imported_modules(mod_decls, clone(base_dir), state)
        },
        Result::Err(e) => {
            push(state.errors, concat(String_from("failed to load module `"), concat(clone(module_name), concat(String_from("`: "), e))))
        },
    }
    let stack_len = len(state.loading_stack)
    if stack_len > 0 {
        pop(state.loading_stack)
    }
}

// ── Pipeline Orchestration ───────────────────────────────────────────────────
pub fn compile_source(source: String, config: DriverConfig) -> CompileResult {
    let wit_error = validate_wit_import_surface(config.wit_paths)
    if len(wit_error) > 0 {
        return CompileResult_err(PHASE_RESOLVE(), wit_error)
    }
    let tokens: Vec<Token> = lexer::tokenize(clone(source))
    let token_count = len(tokens)
    if config.dump_tokens {
        stdio::eprintln(String_from("=== TOKENS ==="))
        let mut i = 0
        while i < token_count {
            let tok = get_unchecked(tokens, i)
            stdio::eprintln(concat(lexer::token_kind_name(tok.kind), concat(String_from(" "), clone(tok.text))))
            i = i + 1
        }
    }
    let mut lex_errors = 0
    let mut i = 0
    while i < token_count {
        let tok = get_unchecked(tokens, i)
        if tok.kind == 7 {
            lex_errors = lex_errors + 1
        }
        i = i + 1
    }
    if lex_errors > 0 {
        return CompileResult_err(PHASE_LEX(), concat(to_string(lex_errors), String_from(" lexer error(s)")))
    }
    let parser = parser::Parser_new(tokens)
    let decls: Vec<AstNode> = parser::parse_module(parser)
    if config.dump_ast {
        stdio::eprintln(String_from("=== AST ==="))
        let decl_count = len(decls)
        let mut j = 0
        while j < decl_count {
            let d = get_unchecked(decls, j)
            parser::print_ast(d, 0)
            j = j + 1
        }
    }
    let parse_error_count = len(parser.errors)
    if parse_error_count > 0 {
        let mut result = CompileResult_err(PHASE_PARSE(), concat(to_string(parse_error_count), String_from(" parse error(s)")))
        let mut k = 0
        while k < parse_error_count {
            let pe = get_unchecked(parser.errors, k)
            push(result.error_messages, clone(pe.message))
            let line = offset_to_line(clone(source), pe.span.start)
            let col = offset_to_column(clone(source), pe.span.start)
            let file_name = clone(config.source_dir)
            let span = DiagnosticSpan_new_full(clone(file_name), line, col, pe.span.start, pe.span.end)
            let d = Diagnostic_new(clone(pe.code), pe.severity, span, clone(pe.message))
            push(result.diagnostics, d)
            k = k + 1
        }
        result.error_count = parse_error_count
        return result
    }
    if config.parse_only {
        return CompileResult_ok(PHASE_PARSE())
    }
    if eq(clone(config.emit_mode), String_from("component")) {
        let component_error = validate_component_export_surface(decls)
        if len(component_error) > 0 {
            return CompileResult_err(PHASE_EMIT(), component_error)
        }
    }
    let load_state = LoadState_new()
    load_imported_modules(decls, clone(config.source_dir), load_state)
    if contains(clone(source), String_from("HashMap_")) || contains(clone(source), String_from("HashSet_")) {
        load_stdlib_module(String_from("std::collections::hash"), load_state)
    }
    if len(load_state.errors) > 0 {
        let mut result = CompileResult_err(PHASE_RESOLVE(), String_from("module loading error(s)"))
        let mut le = 0
        while le < len(load_state.errors) {
            push(result.error_messages, clone(get_unchecked(load_state.errors, le)))
            le = le + 1
        }
        result.error_count = len(load_state.errors)
        return result
    }
    let resolve_ctx = resolver::resolve_program(decls, load_state.modules)
    if config.dump_hir {
        stdio::eprintln(String_from("=== HIR (post-resolve) ==="))
        resolver::dump_scope(resolve_ctx)
    }
    if resolve_ctx.error_count > 0 {
        let mut result = CompileResult_err(PHASE_RESOLVE(), concat(to_string(resolve_ctx.error_count), String_from(" resolve error(s)")))
        let mut ei = 0
        while ei < len(resolve_ctx.errors) {
            push(result.error_messages, clone(get_unchecked(resolve_ctx.errors, ei)))
            ei = ei + 1
        }
        result.error_count = resolve_ctx.error_count
        return result
    }
    let all_decls = Vec_new_AstNode()
    let combined_mc = len(load_state.modules)
    let mut combined_mi = 0
    while combined_mi < combined_mc {
        let combined_md = get_unchecked(load_state.modules, combined_mi)
        let combined_dc = len(combined_md.decls)
        let mut combined_dk = 0
        while combined_dk < combined_dc {
            push(all_decls, get_unchecked(combined_md.decls, combined_dk))
            combined_dk = combined_dk + 1
        }
        combined_mi = combined_mi + 1
    }
    let main_dc = len(decls)
    let mut main_dk = 0
    while main_dk < main_dc {
        push(all_decls, get_unchecked(decls, main_dk))
        main_dk = main_dk + 1
    }
    let check_result = typechecker::typecheck_module(all_decls, resolve_ctx)
    if config.dump_hir {
        stdio::eprintln(String_from("=== TYPED HIR ==="))
        typechecker::dump_typed_hir(check_result)
    }
    if check_result.error_count > 0 {
        let mut result = CompileResult_err(PHASE_TYPECHECK(), concat(to_string(check_result.error_count), String_from(" type error(s)")))
        let mut ei = 0
        while ei < len(check_result.errors) {
            push(result.error_messages, clone(get_unchecked(check_result.errors, ei)))
            ei = ei + 1
        }
        result.error_count = check_result.error_count
        return result
    }
    if config.check_only {
        return CompileResult_ok(PHASE_TYPECHECK())
    }
        let mut mir_module = mir_lower::lower_to_mir(all_decls, check_result)
    if eq(clone(config.emit_mode), "component") || eq(clone(config.emit_mode), "wit") {
        mir_module = mir_lower::lower_to_mir_no_prune(all_decls, check_result)
    }
    if config.dump_mir {
        mir_dump::dump_mir(mir_module)
    }
    // Derive wasi_version from the target string
    let tgt = clone(config.target)
    let is_p2 = contains(clone(tgt), String_from("-p2"))
    if is_p2 {
        config.wasi_version = String_from("p2")
    } else {
        config.wasi_version = String_from("p1")
    }
    let emit_mode = clone(config.emit_mode)
    if eq(clone(emit_mode), "component") && !contains(clone(config.target), String_from("-p2")) {
        return CompileResult_err(PHASE_EMIT(), String_from("component model requires --target wasm32-wasi-p2"))
    }
    if eq(clone(emit_mode), "wit") {
        let wit_text = emit_wit_text_from_decls(all_decls)
        let mut result = CompileResult_ok(PHASE_EMIT())
        result.output_bytes = string_to_bytes(wit_text)
        result
    } else {
    if eq(clone(emit_mode), "wat") {
        let wat_text = emit_wat::emit_wat(mir_module, clone(config.target), config.opt_level)
        let mut result = CompileResult_ok(PHASE_EMIT())
        let wat_len = len(wat_text)
        let mut wat_bytes: Vec<i32> = Vec_new_i32()
        let mut wi = 0
        while wi < wat_len {
            push(wat_bytes, char_at(wat_text, wi))
            wi = wi + 1
        }
        result.output_bytes = wat_bytes
        result
    } else {
        if eq(clone(emit_mode), "wasm") {
            let wasm_bytes = emitter::emit_wasm(mir_module, clone(config.target), config.opt_level)
            if config.dump_wasm {
                stdio::eprintln(String_from("=== WASM ==="))
                stdio::eprintln(concat(String_from("output size: "), concat(to_string(len(wasm_bytes)), String_from(" bytes"))))
            }
            let mut result = CompileResult_ok(PHASE_EMIT())
            result.output_bytes = wasm_bytes
            result
        } else {
            if eq(clone(emit_mode), "component") {
                // Emit core module first, then wrap in component binary
                let core_wasm = emitter::emit_wasm(mir_module, clone(config.target), config.opt_level)
                if config.dump_wasm {
                    stdio::eprintln(concat(String_from("core wasm size: "), concat(to_string(len(core_wasm)), String_from(" bytes"))))
                }
                let comp_bytes = component_emitter::emit_component(core_wasm, mir_module, clone(config.target), clone(config.wasi_version))
                let mut result = CompileResult_ok(PHASE_EMIT())
                result.output_bytes = comp_bytes
                result
            } else {
                CompileResult_err(PHASE_EMIT(), concat(String_from("unsupported emit mode: "), clone(emit_mode)))
            }
        }
    }
    }
}

// ── Compile File ─────────────────────────────────────────────────────────────
pub fn compile_file(path: String, config: DriverConfig) -> CompileResult {
    let cloned_path = clone(path)
    config.source_dir = parent_dir(clone(cloned_path))
    let source_result = load_source(cloned_path)
    match source_result {
        Result::Ok(source) => {
            compile_source(source, config)
        },
        Result::Err(e) => {
            CompileResult_err(0, concat(String_from("failed to read file: "), e))
        },
    }
}

// ── Entry Point ──────────────────────────────────────────────────────────────
fn main() {
    let args = env::args()
    let argc = env::arg_count()
    let mut arg_start = 0
    if argc > 0 {
        let first = get_unchecked(args, 0)
        if eq(clone(first), String_from("--")) {
            arg_start = 1
        }
    }
    if argc - arg_start < 4 {
        stdio::eprintln(String_from("usage: arukellt compile <input> --target <target> -o <output>"))
        process::exit(1)
    }
    let subcommand = get_unchecked(args, arg_start)
    if !eq(clone(subcommand), String_from("compile")) {
        stdio::eprintln(concat(String_from("unknown subcommand: "), clone(subcommand)))
        process::exit(1)
    }
    let input_path = get_unchecked(args, arg_start + 1)
    let config = DriverConfig_default()
    let mut output_path = String_from("")
    let mut has_output = false
    let mut i = arg_start + 2
    while i < argc {
        let flag = get_unchecked(args, i)
        if eq(clone(flag), String_from("-o")) {
            if i + 1 < argc {
                output_path = get_unchecked(args, i + 1)
                has_output = true
                i = i + 2
            } else {
                i = i + 1
            }
        } else {
            if eq(clone(flag), String_from("--target")) {
                if i + 1 < argc {
                    config.target = get_unchecked(args, i + 1)
                    i = i + 2
                } else {
                    i = i + 1
                }
            } else {
                if eq(clone(flag), String_from("--emit")) {
                    if i + 1 < argc {
                        config.emit_mode = get_unchecked(args, i + 1)
                        i = i + 2
                    } else {
                        i = i + 1
                    }
                } else {
                    i = i + 1
                }
            }
        }
    }
    if !has_output {
        stdio::eprintln(String_from("error: missing -o <output> flag"))
        process::exit(1)
    }
    let result = compile_file(clone(input_path), config)
    if result.success {
        match fs::write_bytes(clone(output_path), result.output_bytes) {
            Result::Ok(_) => {
            },
            Result::Err(e) => {
                stdio::eprintln(concat(String_from("error writing output: "), e))
                process::exit(1)
            },
        }
    } else {
        let err_count = result.error_count
        let mut j = 0
        while j < err_count {
            let msg = get_unchecked(result.error_messages, j)
            stdio::eprintln(concat(String_from("error: "), clone(msg)))
            j = j + 1
        }
        process::exit(1)
    }
}
// ── Pipeline Phase Tags ──────────────────────────────────────────────────────
// break
// NK_USE
// Handle destructure children: use base::{a, b, ...}
// NK_USE
// Already loaded — skip
// Circular import detection
// Push onto loading stack
// Construct file path: base_dir/module_name.ark
// Lex
// Parse
// Record as loaded
// Recursively load imports from this module
// Pop from loading stack
// Phase 1: Lex
// Check for lexer errors
// TK_ERROR
// Phase 2: Parse
// Phase 3: Resolve (name binding)
// Load imported modules from use declarations
// Auto-import std::collections::hash when HashMap_* or HashSet_* builtins are used
// without an explicit import. These monomorphic builtins delegate to the hash module.
// Report module loading errors
// Build combined declaration list: imported modules first, then main module.
// This allows MIR lowering to include all functions needed for cross-module calls.
// Phase 4: Type check (using combined declarations for cross-module type info)
// Phase 5: Lower to MIR (using combined declarations)
// Phase 6: Emit Wasm
// WAT text output
// Convert WAT string to byte vector
// Set source_dir from the file's parent directory for module resolution
// Expect: compile <input> [--target <target>] [--emit <mode>] -o <output>
// Skip any leading `--` separator that wasmtime passes as argv
