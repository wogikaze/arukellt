use wasm::inst_store
use wasm::intrinsic_parse_f64
use wasm::intrinsic_parse_i32
use wasm::intrinsic_parse_i64

fn try_emit_parse_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_parse_float_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_parse_int_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_parse_float_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_parse_parse_f64(){
        let _result_on_stack = intrinsic_parse_f64::emit_parse_f64(w, inst, ctx)
        if !_result_on_stack {
            return false
        }
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_parse_int_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_parse_parse_i32(){
        let _result_on_stack = intrinsic_parse_i32::emit_parse_i32(w, inst, ctx)
        if !_result_on_stack {
            return false
        }
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_parse_parse_i64(){
        let _result_on_stack = intrinsic_parse_i64::emit_parse_i64(w, inst, ctx)
        if !_result_on_stack {
            return false
        }
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}
