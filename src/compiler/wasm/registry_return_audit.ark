// Arukellt Selfhost - PR-4a-pre emit-unchanged old/new return VT audit.

use mir::value_types
use wasm::ctx_record
use wasm::registry_return_guard
use wasm::registry_return_resolve

struct RegistryReturnAuditCounters {
    candidates: i32,
    matched: i32,
    mismatched: i32,
    mismatch_log_budget: i32,
}

fn RegistryReturnAuditCounters_new() -> RegistryReturnAuditCounters {
    RegistryReturnAuditCounters { candidates: 0, matched: 0, mismatched: 0, mismatch_log_budget: 32 }
}

fn registry_audit_on_call(ctx: SelfEmitCtx, inst: MirInst, callee: String, fn_legacy_vt: i32) {
    if !registry_return_guard::registry_guard_is_normal_call(ctx, inst, callee) {
        return
    }
    ctx_record::SelfEmitCtx_registry_audit_inc_candidates(ctx)
    let reg_vt = registry_return_resolve::registry_resolve_legacy_return_vt(ctx, inst)
    if legacy_vt_values_equal(reg_vt, fn_legacy_vt) {
        ctx_record::SelfEmitCtx_registry_audit_inc_matched(ctx)
        return
    }
    ctx_record::SelfEmitCtx_registry_audit_inc_mismatched(ctx)
    registry_audit_log_mismatch(ctx, callee, fn_legacy_vt, reg_vt)
}

fn legacy_vt_values_equal(a: i32, b: i32) -> bool {
    a == b
}

fn registry_audit_log_mismatch(ctx: SelfEmitCtx, callee: String, old_vt: i32, new_vt: i32) {
    if ctx_record::SelfEmitCtx_registry_audit_mismatch_budget(ctx) <= 0 {
        return
    }
    ctx_record::SelfEmitCtx_registry_audit_dec_mismatch_budget(ctx)
    let line = concat(String_from("reg-vt-audit: mismatch callee="), concat(callee, concat(String_from(" old="), concat(i32_to_string(old_vt), concat(String_from(" new="), i32_to_string(new_vt))))))
    stdio::eprintln(line)
}

fn registry_audit_print_summary(ctx: SelfEmitCtx) {
    let c = ctx_record::SelfEmitCtx_registry_audit_candidates(ctx)
    if c <= 0 {
        return
    }
    let line = concat(String_from("reg-vt-audit: summary candidates="), concat(i32_to_string(c), concat(String_from(" matched="), concat(i32_to_string(ctx_record::SelfEmitCtx_registry_audit_matched(ctx)), concat(String_from(" mismatched="), i32_to_string(ctx_record::SelfEmitCtx_registry_audit_mismatched(ctx)))))))
    stdio::eprintln(line)
}

fn registry_emit_call_has_void_return(ctx: SelfEmitCtx, inst: MirInst, callee: String, fn_legacy_vt: i32) -> bool {
    registry_audit_on_call(ctx, inst, callee, fn_legacy_vt)
    if registry_return_resolve::registry_should_use_matched_path(ctx, inst, callee, fn_legacy_vt) {
        return registry_return_resolve::registry_resolve_call_has_void_return(ctx, inst)
    }
    fn_legacy_vt == value_types::VT_VOID()
}
