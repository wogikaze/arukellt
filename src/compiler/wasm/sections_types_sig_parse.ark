// Arukellt Selfhost - Wasm type signature parsing helpers.

fn parse_sub_super_offset(sig: String) -> i32 {
    let plus = find_type_sig_char(sig, 43)
    if plus < 0 {
        return 0
    }
    let mut val = 0
    let mut i = plus + 1
    let n = len(sig)
    while i < n {
        let c = char_at(clone(sig), i)
        if c >= 48 && c <= 57 {
            val = val * 10 + (c - 48)
            i = i + 1
        } else {
            break
        }
    }
    val
}

fn parse_sub_struct_sig(sig: String) -> String {
    let marker = String_from("_GS_")
    let start = find_type_sig_str(sig, marker)
    if start >= 0 {
        let body_start = start + 1
        let at = find_type_sig_char(sig, 64)
        if at >= body_start {
            return substring(clone(sig), body_start, at)
        }
        return substring(clone(sig), body_start, len(sig))
    }
    // Enum variant sigs use _S_ instead of _GS_ (e.g. SubF+14_S_f0_i32_f1_i32)
    let s_marker = String_from("_S_")
    let s_start = find_type_sig_str(sig, s_marker)
    if s_start >= 0 {
        let body_start = s_start + 3
        let at = find_type_sig_char(sig, 64)
        if at >= body_start {
            return concat(String_from("GS_"), substring(clone(sig), body_start, at))
        }
        return concat(String_from("GS_"), substring(clone(sig), body_start, len(sig)))
    }
    String_from("GS_f0_i32")
}

fn find_type_sig_char(s: String, c: i32) -> i32 {
    let n = len(s)
    let mut i = 0
    while i < n {
        if char_at(clone(s), i) == c {
            return i
        }
        i = i + 1
    }
    0 - 1
}

fn find_type_sig_str(s: String, needle: String) -> i32 {
    let n = len(s)
    let nn = len(needle)
    if nn <= 0 || nn > n {
        return 0 - 1
    }
    let mut i = 0
    while i + nn <= n {
        let mut matched = 1
        let mut j = 0
        while j < nn {
            if char_at(clone(s), i + j) != char_at(clone(needle), j) {
                matched = 0
            }
            j = j + 1
        }
        if matched == 1 {
            return i
        }
        i = i + 1
    }
    0 - 1
}

fn parse_type_sig_int(s: String) -> i32 {
    let n = len(s)
    let mut val = 0
    let mut i = 0
    while i < n {
        let c = char_at(clone(s), i)
        if c >= 48 && c <= 57 {
            val = val * 10 + (c - 48)
        }
        i = i + 1
    }
    val
}

fn parse_gcref_offset(sig: String) -> i32 {
    if eq(clone(sig), String_from("gcref")) {
        return 2
    }
    if starts_with(clone(sig), String_from("gcref")) {
        return parse_type_sig_int(substring(sig, 5, len(sig)))
    }
    2
}
