use mir::inst_accessors_operands
use wasm::ctx_scratch
use wasm::inst_ctx
use wasm::opcodes
use wasm::intrinsics::helpers_core

// Handler for: seq::take_i32
fn emit_seq_take_i32(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s0 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s1 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s2 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s3 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s4 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s5 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    emit_seq_take_prepare(w, s0, s1, s2, s4)
    emit_seq_slice_alloc_result(w, s2, s3, s5)
    emit_seq_slice_copy_payload(w, s2, s4, s5)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s3)
    inst_ctx::ctx_mark_vec_local(ctx, inst_accessors_operands::MirInst_dest(inst))
    return true
}

// Handler for: seq::skip_i32
fn emit_seq_skip_i32(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s0 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s1 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s2 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s3 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s4 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s5 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s6 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s7 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    emit_seq_skip_prepare(w, s0, s1, s2, s3, s5, s7)
    emit_seq_slice_alloc_result(w, s3, s4, s6)
    emit_seq_slice_copy_payload(w, s3, s5, s6)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s4)
    inst_ctx::ctx_mark_vec_local(ctx, inst_accessors_operands::MirInst_dest(inst))
    return true
}

fn emit_seq_take_prepare(w: WasmWriter, count_local: i32, src_local: i32, result_len_local: i32, src_data_local: i32) {
    emit_seq_take_source(w, count_local, src_local, result_len_local)
    emit_seq_take_range(w, count_local, src_local, result_len_local, src_data_local)
}

fn emit_seq_take_source(w: WasmWriter, count_local: i32, src_local: i32, result_len_local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, count_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, src_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_local)
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_TEE())
    writer_core::emit_leb128_u(w, result_len_local)
}

fn emit_seq_take_range(w: WasmWriter, count_local: i32, src_local: i32, result_len_local: i32, src_data_local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, count_local)
    writer_core::emit_byte(w, opcodes::OP_I32_GT_S())
    writer_core::emit_byte(w, opcodes::OP_IF())
    writer_core::emit_byte(w, 64)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, count_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, result_len_local)
    writer_core::emit_byte(w, opcodes::OP_END())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_local)
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 8)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, src_data_local)
}

fn emit_seq_skip_prepare(w: WasmWriter, count_local: i32, src_local: i32, start_local: i32, result_len_local: i32, src_data_start_local: i32, src_len_local: i32) {
    emit_seq_skip_source(w, count_local, src_local, src_len_local)
    emit_seq_skip_range(w, count_local, src_local, start_local, result_len_local, src_data_start_local, src_len_local)
}

fn emit_seq_skip_source(w: WasmWriter, count_local: i32, src_local: i32, src_len_local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, count_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, src_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_local)
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, src_len_local)
}

fn emit_seq_skip_range(w: WasmWriter, count_local: i32, src_local: i32, start_local: i32, result_len_local: i32, src_data_start_local: i32, src_len_local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_len_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_TEE())
    writer_core::emit_leb128_u(w, start_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, count_local)
    writer_core::emit_byte(w, opcodes::OP_I32_GT_S())
    writer_core::emit_byte(w, opcodes::OP_IF())
    writer_core::emit_byte(w, 64)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, count_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, start_local)
    writer_core::emit_byte(w, opcodes::OP_END())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_len_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, start_local)
    writer_core::emit_byte(w, opcodes::OP_I32_SUB())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, result_len_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_local)
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 8)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, start_local)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 4)
    writer_core::emit_byte(w, opcodes::OP_I32_MUL())
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, src_data_start_local)
}

fn emit_seq_slice_alloc_result(w: WasmWriter, result_len_local: i32, result_vec_local: i32, result_data_local: i32) {
    emit_seq_slice_alloc_header(w, result_len_local, result_vec_local)
    emit_seq_slice_alloc_data(w, result_vec_local, result_data_local)
}

fn emit_seq_slice_alloc_header(w: WasmWriter, result_len_local: i32, result_vec_local: i32) {
    writer_core::emit_byte(w, 35)
    writer_core::emit_leb128_u(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_TEE())
    writer_core::emit_leb128_u(w, result_vec_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_len_local)
    writer_core::emit_byte(w, opcodes::OP_I32_STORE())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_vec_local)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 4)
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_len_local)
    writer_core::emit_byte(w, opcodes::OP_I32_STORE())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_vec_local)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 12)
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    helpers_core::emit_heap_set(w)
}

fn emit_seq_slice_alloc_data(w: WasmWriter, result_vec_local: i32, result_data_local: i32) {
    writer_core::emit_byte(w, 35)
    writer_core::emit_leb128_u(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_TEE())
    writer_core::emit_leb128_u(w, result_data_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_vec_local)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 8)
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_data_local)
    writer_core::emit_byte(w, opcodes::OP_I32_STORE())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
}

fn emit_seq_slice_copy_payload(w: WasmWriter, result_len_local: i32, src_data_start_local: i32, result_data_local: i32) {
    emit_seq_slice_reserve_payload(w, result_len_local, result_data_local)
    emit_seq_slice_copy_memory(w, result_len_local, src_data_start_local, result_data_local)
}

fn emit_seq_slice_reserve_payload(w: WasmWriter, result_len_local: i32, result_data_local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_data_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_len_local)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 4)
    writer_core::emit_byte(w, opcodes::OP_I32_MUL())
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    helpers_core::emit_heap_set(w)
}

fn emit_seq_slice_copy_memory(w: WasmWriter, result_len_local: i32, src_data_start_local: i32, result_data_local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_data_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, src_data_start_local)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, result_len_local)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 4)
    writer_core::emit_byte(w, opcodes::OP_I32_MUL())
    writer_core::emit_byte(w, 252)
    writer_core::emit_leb128_u(w, 10)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, 0)
}
