    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_abs() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_ABS(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_splat() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_SPLAT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_extract_lane(){
        call_simd_emit::emit_simd_extract_lane(w, inst, opcodes::SIMD_F64X2_EXTRACT_LANE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_replace_lane(){
        call_simd_emit::emit_simd_replace_lane(w, inst, opcodes::SIMD_F64X2_REPLACE_LANE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_eq() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F64X2_EQ(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_ne() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F64X2_NE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_lt() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F64X2_LT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_gt() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F64X2_GT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_le() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F64X2_LE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_ge() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F64X2_GE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_ceil() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_CEIL(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_floor() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_FLOOR(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_trunc() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_TRUNC(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_nearest() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_NEAREST(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_promote_low_f32x4(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_PROMOTE_LOW_F32X4(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_convert_low_i32x4_s(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_CONVERT_LOW_I32X4_S(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_convert_low_i32x4_u(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F64X2_CONVERT_LOW_I32X4_U(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    false
}

