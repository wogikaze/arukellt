fn try_emit_simd_native_alltrue_bitmask(w: WasmWriter, callee: String, inst: MirInst, dest: i32, arg0: i32, arg1: i32) -> bool {
    if eq(clone(callee), String_from("__simd_i8x16_all_true")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I8X16_ALL_TRUE()); return true }
    if eq(clone(callee), String_from("__simd_i8x16_bitmask")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I8X16_BITMASK()); return true }
    if eq(clone(callee), String_from("__simd_i16x8_bitmask")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_BITMASK()); return true }
    if eq(clone(callee), String_from("__simd_i32x4_all_true")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I32X4_ALL_TRUE()); return true }
    if eq(clone(callee), String_from("__simd_i32x4_bitmask")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I32X4_BITMASK()); return true }
    if eq(clone(callee), String_from("__simd_i64x2_all_true")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I64X2_ALL_TRUE()); return true }
    if eq(clone(callee), String_from("__simd_i64x2_bitmask")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I64X2_BITMASK()); return true }
    false
}
