        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_I16X8_NARROW_I32X4_U(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extadd_pairwise_i8x16_s(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_EXTADD_PAIRWISE_I8X16_S(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extadd_pairwise_i8x16_u(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_EXTADD_PAIRWISE_I8X16_U(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extend_low_i8x16_s(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_EXTEND_LOW_I8X16_S(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extend_high_i8x16_s(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_EXTEND_HIGH_I8X16_S(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extend_high_i8x16_u(){
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_EXTEND_HIGH_I8X16_U(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    false
}

fn try_emit_simd_native_alltrue_bitmask(w: WasmWriter, handler_id: i32, inst: MirInst, dest: i32, arg0: i32, arg1: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_all_true() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I8X16_ALL_TRUE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_bitmask() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I8X16_BITMASK(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_bitmask() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I16X8_BITMASK(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i32x4_all_true() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I32X4_ALL_TRUE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i32x4_bitmask() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I32X4_BITMASK(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i64x2_all_true() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I64X2_ALL_TRUE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i64x2_bitmask() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_I64X2_BITMASK(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    false
}
