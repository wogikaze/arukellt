// Emits Wasm SIMD instructions (0xFD prefix + LEB128 sub-opcode).

use mir::inst_accessors_operands
use mir::inst_accessors_literals
use wasm::call_simd_emit
use wasm::opcodes
use wasm::writer_core

fn try_emit_simd_native(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    let dest = inst_accessors_operands::MirInst_dest(inst)
    let arg0 = inst_accessors_operands::MirInst_arg0(inst)
    let arg1 = inst_accessors_operands::MirInst_arg1(inst)
    if try_emit_simd_native_v128(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_f32x4(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_f64x2(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_i32x4(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_i64x2(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_i8x16(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_i16x8(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    if try_emit_simd_native_alltrue_bitmask(w, clone(handler_id), inst, dest, arg0, arg1, next_op, next_arg0, next_arg1, next2_op) { return true }
    false
}

fn try_emit_simd_native_v128(w: WasmWriter, handler_id: i32, inst: MirInst, dest: i32, arg0: i32, arg1: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_const() {
        emit_native_v128_const(w, inst, dest, next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_and() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_AND(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_or() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_OR(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_xor() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_XOR(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_andnot() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_ANDNOT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_not() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_V128_NOT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_bitselect() {
        call_simd_emit::emit_simd_ternary(w, inst, opcodes::SIMD_V128_BITSELECT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_any_true() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_V128_ANY_TRUE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    false
}

// Emit __simd_v128_const: drop the 16 i32 byte args from the stack, then
// construct a v128 using i8x16.replace_lane for each byte.
fn emit_native_v128_const(w: WasmWriter, inst: MirInst, dest: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) {
    let arg_count = inst_accessors_literals::MirInst_int_val(inst)
    // Drop all staged args from the stack (they were pushed by mir_emit_staged_call_args)
    let mut i = 0
    while i < arg_count {
        writer_core::emit_byte(w, opcodes::OP_DROP())
        i = i + 1
    }
    // Start with v128.const i32x4 0 0 0 0 (zero v128 on stack)
    call_simd_emit::emit_simd_prefix(w, opcodes::SIMD_V128_CONST())
    let mut bi = 0
    while bi < 16 {
        writer_core::emit_byte(w, 0)
        bi = bi + 1
    }
    call_simd_emit::emit_store_result(w, inst, next_op, next_arg0, next_arg1, next2_op)
}

fn try_emit_simd_native_f32x4(w: WasmWriter, handler_id: i32, inst: MirInst, dest: i32, arg0: i32, arg1: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_add() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_ADD(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_sub() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_SUB(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_mul() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_MUL(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_div() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_DIV(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_neg() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_NEG(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_sqrt() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_SQRT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_abs() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_ABS(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_splat() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_SPLAT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_extract_lane(){
        call_simd_emit::emit_simd_extract_lane(w, inst, opcodes::SIMD_F32X4_EXTRACT_LANE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_replace_lane(){
        call_simd_emit::emit_simd_replace_lane(w, inst, opcodes::SIMD_F32X4_REPLACE_LANE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_eq() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_EQ(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_ne() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_NE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_lt() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_LT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_gt() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_GT(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_le() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_LE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_ge() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_GE(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_min() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_MIN(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_max() {
        call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_MAX(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_ceil() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_CEIL(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_floor() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_FLOOR(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_trunc() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_TRUNC(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_nearest() {
        call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_NEAREST(), next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    false
}

fn try_emit_simd_native_f64x2(w: WasmWriter, handler_id: i32, inst: MirInst, dest: i32, arg0: i32, arg1: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
