// Arukellt Selfhost - Native SIMD emission (T2/T3/T5).
// Emits Wasm SIMD instructions (0xFD prefix + LEB128 sub-opcode).

use mir::inst_accessors_operands
use wasm::call_simd_emit
use wasm::opcodes

fn try_emit_simd_native(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    let dest = inst_accessors_operands::MirInst_dest(inst)
    let arg0 = inst_accessors_operands::MirInst_arg0(inst)
    let arg1 = inst_accessors_operands::MirInst_arg1(inst)
    if try_emit_simd_native_v128(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_f32x4(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_f64x2(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_i32x4(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_i64x2(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_i8x16(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_i16x8(w, clone(callee), inst, dest, arg0, arg1) { return true }
    if try_emit_simd_native_alltrue_bitmask(w, clone(callee), inst, dest, arg0, arg1) { return true }
    false
}

fn try_emit_simd_native_v128(w: WasmWriter, callee: String, inst: MirInst, dest: i32, arg0: i32, arg1: i32) -> bool {
    if eq(clone(callee), String_from("__simd_v128_and")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_AND()); return true }
    if eq(clone(callee), String_from("__simd_v128_or")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_OR()); return true }
    if eq(clone(callee), String_from("__simd_v128_xor")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_XOR()); return true }
    if eq(clone(callee), String_from("__simd_v128_andnot")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_V128_ANDNOT()); return true }
    if eq(clone(callee), String_from("__simd_v128_not")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_V128_NOT()); return true }
    if eq(clone(callee), String_from("__simd_v128_bitselect")) { call_simd_emit::emit_simd_ternary(w, inst, opcodes::SIMD_V128_BITSELECT()); return true }
    if eq(clone(callee), String_from("__simd_v128_any_true")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_V128_ANY_TRUE()); return true }
    false
}

fn try_emit_simd_native_f32x4(w: WasmWriter, callee: String, inst: MirInst, dest: i32, arg0: i32, arg1: i32) -> bool {
    if eq(clone(callee), String_from("__simd_f32x4_add")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_ADD()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_sub")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_SUB()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_mul")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_MUL()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_div")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_DIV()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_neg")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_NEG()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_sqrt")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_SQRT()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_abs")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_ABS()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_splat")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_SPLAT()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_extract_lane")) { call_simd_emit::emit_simd_extract_lane(w, inst, opcodes::SIMD_F32X4_EXTRACT_LANE()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_replace_lane")) { call_simd_emit::emit_simd_replace_lane(w, inst, opcodes::SIMD_F32X4_REPLACE_LANE()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_eq")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_EQ()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_ne")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_NE()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_lt")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_LT()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_gt")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_GT()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_le")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_LE()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_ge")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_GE()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_min")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_MIN()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_max")) { call_simd_emit::emit_simd_binary(w, inst, opcodes::SIMD_F32X4_MAX()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_ceil")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_CEIL()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_floor")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_FLOOR()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_trunc")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_TRUNC()); return true }
    if eq(clone(callee), String_from("__simd_f32x4_nearest")) { call_simd_emit::emit_simd_unary(w, inst, opcodes::SIMD_F32X4_NEAREST()); return true }
    false
}

