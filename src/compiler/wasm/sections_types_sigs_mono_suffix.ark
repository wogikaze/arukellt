// Mono type suffix parsing and type-key helpers.

use wasm::sections_types_gc

fn extract_mono_suffix(fn_name: String) -> String {
    let name_len = len(fn_name)
    // Collect all "__" positions
    let sep_positions = Vec_new_i32()
    let mut i = 0
    while i < name_len - 1 {
        if char_at(fn_name, i) == 95 && char_at(fn_name, i + 1) == 95 {
            push(sep_positions, i)
        }
        i = i + 1
    }
    let sep_count = len(sep_positions)
    if sep_count == 0 {
        return String_new()
    }
    // Try positions from left to right: the first position where all suffix
    // parts are valid type keys is the correct separator. This handles both
    // method names (e.g. "Picker__echo__i32" → "echo" is invalid, "i32" is valid)
    // and multi-param generics (e.g. "pair_first__i32__String" → "i32__String" all valid).
    let mut si = 0
    while si < sep_count {
        let sep_pos = get_unchecked(sep_positions, si)
        let suffix = substring(fn_name, sep_pos + 2, name_len)
        let type_keys = split_by_double_underscore(suffix)
        let key_count = len(type_keys)
        if key_count > 0 && all_valid_type_keys(type_keys, key_count) {
            return suffix
        }
        si = si + 1
    }
    // Fallback: use the first "__" separator (original behavior)
    let first_sep = get_unchecked(sep_positions, 0)
    substring(fn_name, first_sep + 2, name_len)
}

// Check if all type keys in a list are valid mono type keys.
// Valid keys: known primitives (i32, i64, f64, f32, bool, char),
// "String", or identifiers starting with an uppercase letter (struct/enum names).
fn all_valid_type_keys(type_keys: Vec<String>, key_count: i32) -> bool {
    let mut ki = 0
    while ki < key_count {
        let key = get_unchecked(type_keys, ki)
        if !is_valid_type_key(key) {
            return false
        }
        ki = ki + 1
    }
    true
}

fn is_valid_type_key(key: String) -> bool {
    if eq(clone(key), String_from("i32")) || eq(clone(key), String_from("i64")) || eq(clone(key), String_from("f64")) || eq(clone(key), String_from("f32")) || eq(clone(key), String_from("bool")) || eq(clone(key), String_from("char")) || eq(clone(key), String_from("String")) || eq(clone(key), String_from("string")) {
        return true
    }
    // User-defined type names start with uppercase letter (A-Z = 65-90)
    if len(key) > 0 {
        let first = char_at(key, 0)
        if first >= 65 && first <= 90 {
            return true
        }
    }
    false
}

// Split a string by "__" separator into a Vec<String>.
fn split_by_double_underscore(s: String) -> Vec<String> {
    let result = Vec_new_String()
    let slen = len(s)
    let mut start = 0
    let mut i = 0
    while i < slen - 1 {
        if char_at(s, i) == 95 && char_at(s, i + 1) == 95 {
            push(result, substring(s, start, i))
            start = i + 2
            i = i + 2
        } else {
            i = i + 1
        }
    }
    if start <= slen {
        push(result, substring(s, start, slen))
    }
    result
}

// Map a type variable name (e.g. "T", "E") to a type parameter index.
// Uses common naming conventions for generic type parameters.
fn type_var_name_to_index(type_var_name: String, max_count: i32) -> i32 {
    // Strip leading "?" if present.
    let name = if starts_with(clone(type_var_name), String_from("?")) {
        substring(clone(type_var_name), 1, len(type_var_name))
    } else {
        clone(type_var_name)
    }
    // Common single-letter type variable conventions:
    // T→0, E→1, U→2, V→3, W→4, K→0, A→0, B→1, C→2, D→3
    // Ordinal fresh vars (t0, t1, …) map by suffix number.
    if starts_with(clone(name), String_from("t")) {
        let slen = len(name)
        if slen >= 2 {
            let mut num = 0
            let mut i = 1
            let mut all_digits = true
            while i < slen {
                let ch = char_at(name, i)
                if ch < 48 || ch > 57 {
                    all_digits = false
                } else {
                    num = num * 10 + (ch - 48)
                }
                i = i + 1
            }
            if all_digits {
                return num
            }
        }
    }
    if eq(clone(name), String_from("T")) { return 0 }
    if eq(clone(name), String_from("E")) { return 1 }
    if eq(clone(name), String_from("U")) { return 2 }
    if eq(clone(name), String_from("V")) { return 3 }
    if eq(clone(name), String_from("W")) { return 4 }
    if eq(clone(name), String_from("K")) { return 0 }
    if eq(clone(name), String_from("A")) { return 0 }
    if eq(clone(name), String_from("B")) { return 1 }
    if eq(clone(name), String_from("C")) { return 2 }
    if eq(clone(name), String_from("D")) { return 3 }
    0
}

// Map a mono type key string to a wasm type signature.
fn mono_type_key_to_sig(key: String) -> String {
    if eq(clone(key), String_from("i32")) {
        return String_from("i32")
    }
    if eq(clone(key), String_from("i64")) {
        return String_from("i64")
    }
    if eq(clone(key), String_from("f64")) {
        return String_from("f64")
    }
    if eq(clone(key), String_from("f32")) {
        return String_from("f32")
    }
    if eq(clone(key), String_from("bool")) {
        return String_from("i32")
    }
    if eq(clone(key), String_from("String")) {
        return sections_types_gc::gc_string_type_sig()
    }
    if eq(clone(key), String_from("char")) {
        return String_from("i32")
    }
    String_new()
}
