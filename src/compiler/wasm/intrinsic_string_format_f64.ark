use wasm::ctx_scratch
use wasm::string_gc_helpers
use wasm::intrinsics::helpers_control_branch
use wasm::intrinsics::helpers_control_loop
use wasm::intrinsics::helpers_control_structured
use wasm::intrinsics::helpers_core_heap
use wasm::intrinsics::helpers_core_locals
use wasm::intrinsics::helpers_memory_access
use wasm::intrinsics::helpers_numeric_f64
use wasm::intrinsics::helpers_numeric_i32_arith
use wasm::intrinsics::helpers_numeric_i32_compare
use wasm::intrinsics::helpers_numeric_i32_const
use wasm::intrinsics::helpers_numeric_i32_convert
// Handler for: f64_to_string, text::format_f64, convert::f64_to_string, __intrinsic_f64_to_string
//
// Emits a *shortest round-trip* decimal representation of the f64 argument
// (replacing the previous naive digit-extraction loop that printed
// `1.199999999999999` for `1.2`).  For each fractional precision k = 1..17 we
// test whether `round(value * 10^k) / 10^k` re-parses to the same f64; the
// first k that round-trips is the shortest printable form.  Digits are then
// extracted from the integer-valued `scaled = round(value * 10^k)` via f64
// div/mod (exact for scaled < 2^53) and assembled with the decimal point k
// digits from the right.  At least one fractional digit is always emitted so
// integer-valued f64 render as `5.0` (matches the `.expected` golden).
fn emit_f64_to_string(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s_wpos = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_neg = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_k = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_j = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_di = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_pos = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_zero = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    let f_val = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 12)
    let f_scale = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 13)
    let f_work = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 14)
    let digit_buf = 16
    let out_buf = 72
    helpers_core_locals::emit_local_set(w, f_val)
    emit_f64_prepare_value(w, s_neg, f_val)
    emit_f64_find_shortest_k(w, s_k, f_val, f_scale, f_work)
    emit_f64_compute_scaled(w, f_val, f_scale, f_work)
    emit_f64_extract_digits(w, f_work, f_scale, s_di, s_j, digit_buf)
    // s_zero = 0 — used as the inclusive lower bound for fraction digit runs
    // where the bound is the literal 0 (not a local index).
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_zero)
    emit_f64_assemble(w, s_pos, s_neg, s_k, s_di, s_j, s_wpos, s_zero, digit_buf, out_buf)
    if contains(clone(ctx.target), String_from("freestanding")) || contains(clone(ctx.target), String_from("-p2")) || contains(clone(ctx.target), String_from("-p3")) {
        emit_f64_alloc_string_gc(w, s_wpos, s_len, s_pos, ctx.gc_type_base, ctx)
    } else {
        let s_alloc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
        emit_f64_alloc_string(w, s_wpos, s_len, s_alloc, s_pos)
    }
    return true
}
fn emit_f64_prepare_value(w: WasmWriter, s_neg: i32, f_val: i32) {
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_neg)
    helpers_core_locals::emit_local_get(w, f_val)
    helpers_numeric_f64::emit_f64_const_words(w, 0, 0)
    helpers_numeric_f64::emit_f64_lt(w)
    helpers_control_structured::emit_if_empty(w)
    helpers_core_locals::emit_local_get(w, f_val)
    helpers_numeric_f64::emit_f64_neg(w)
    helpers_core_locals::emit_local_set(w, f_val)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_core_locals::emit_local_set(w, s_neg)
    helpers_control_structured::emit_end(w)
}
// Find the smallest k in [1, 17] such that round(f_val * 10^k) / 10^k == f_val.
// Leaves s_k = k and f_scale = 10^k.  f_work is used as a scratch candidate.
fn emit_f64_find_shortest_k(w: WasmWriter, s_k: i32, f_val: i32, f_scale: i32, f_work: i32) {
    helpers_numeric_f64::emit_f64_const_words(w, 0, 1076101120)
    helpers_core_locals::emit_local_set(w, f_scale)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_core_locals::emit_local_set(w, s_k)
    helpers_control_loop::emit_block_loop_header(w)
    // candidate = round(f_val * f_scale) / f_scale
    helpers_core_locals::emit_local_get(w, f_val)
    helpers_core_locals::emit_local_get(w, f_scale)
    helpers_numeric_f64::emit_f64_mul(w)
    helpers_numeric_f64::emit_f64_nearest(w)
    helpers_core_locals::emit_local_get(w, f_scale)
    helpers_numeric_f64::emit_f64_div(w)
    helpers_core_locals::emit_local_set(w, f_work)
    // if candidate == f_val: break (found shortest k)
    helpers_core_locals::emit_local_get(w, f_work)
    helpers_core_locals::emit_local_get(w, f_val)
    helpers_numeric_f64::emit_f64_eq(w)
    helpers_control_branch::emit_br_if(w, 1)
    // if s_k >= 17: break (fallback to max precision)
    helpers_core_locals::emit_local_get(w, s_k)
    helpers_numeric_i32_const::emit_i32_const(w, 17)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    // k++, f_scale *= 10
    helpers_core_locals::emit_local_get(w, s_k)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_k)
    helpers_core_locals::emit_local_get(w, f_scale)
    helpers_numeric_f64::emit_f64_const_words(w, 0, 1076101120)
    helpers_numeric_f64::emit_f64_mul(w)
    helpers_core_locals::emit_local_set(w, f_scale)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
}
// f_work = round(f_val * f_scale)  (integer-valued f64, the scaled mantissa).
fn emit_f64_compute_scaled(w: WasmWriter, f_val: i32, f_scale: i32, f_work: i32) {
    helpers_core_locals::emit_local_get(w, f_val)
    helpers_core_locals::emit_local_get(w, f_scale)
    helpers_numeric_f64::emit_f64_mul(w)
    helpers_numeric_f64::emit_f64_nearest(w)
    helpers_core_locals::emit_local_set(w, f_work)
}
// Extract decimal digits of the integer-valued f64 in f_work, least-significant
// first, into memory at digit_buf.  s_di receives the digit count.  f_temp
// (passed as f_scale's slot, no longer needed after scaling) holds the next
// quotient.  s_j holds the current digit value transiently.
fn emit_f64_extract_digits(w: WasmWriter, f_work: i32, f_temp: i32, s_di: i32, s_j: i32, digit_buf: i32) {
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_di)
    // if f_work == 0.0: emit a single '0' digit and return.
    helpers_core_locals::emit_local_get(w, f_work)
    helpers_numeric_f64::emit_f64_const_words(w, 0, 0)
    helpers_numeric_f64::emit_f64_eq(w)
    helpers_control_structured::emit_if_empty(w)
    helpers_numeric_i32_const::emit_i32_const(w, digit_buf)
    helpers_numeric_i32_const::emit_i32_const(w, 48)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_core_locals::emit_local_set(w, s_di)
    helpers_control_structured::emit_else(w)
    helpers_control_loop::emit_block_loop_header(w)
    // while f_work >= 1.0
    helpers_core_locals::emit_local_get(w, f_work)
    helpers_numeric_f64::emit_f64_const_words(w, 0, 1072693248)
    helpers_numeric_f64::emit_f64_lt(w)
    helpers_control_branch::emit_br_if(w, 1)
    // f_temp = trunc(f_work / 10)
    helpers_core_locals::emit_local_get(w, f_work)
    helpers_numeric_f64::emit_f64_const_words(w, 0, 1076101120)
    helpers_numeric_f64::emit_f64_div(w)
    helpers_numeric_f64::emit_f64_trunc(w)
    helpers_core_locals::emit_local_set(w, f_temp)
    // digit = f_work - 10 * f_temp  (in [0, 9])
    helpers_core_locals::emit_local_get(w, f_work)
    helpers_core_locals::emit_local_get(w, f_temp)
    helpers_numeric_f64::emit_f64_const_words(w, 0, 1076101120)
    helpers_numeric_f64::emit_f64_mul(w)
    helpers_numeric_f64::emit_f64_sub(w)
    helpers_numeric_i32_convert::emit_i32_trunc_f64_s(w)
    helpers_core_locals::emit_local_set(w, s_j)
    // buf[digit_buf + s_di] = '0' + digit
    helpers_numeric_i32_const::emit_i32_const(w, digit_buf)
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_const::emit_i32_const(w, 48)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_store8_default(w)
    // s_di++, f_work = f_temp
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_di)
    helpers_core_locals::emit_local_get(w, f_temp)
    helpers_core_locals::emit_local_set(w, f_work)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
}
// Copy digit_buf[s_j down to s_bound] (inclusive) to the output at s_pos,
// advancing s_pos and decrementing s_j.  Used for both integer and fraction
// digit runs.  s_bound is a *local index* holding the lower bound (inclusive);
// callers must store the bound into that local before calling.
fn emit_f64_emit_digit_run(w: WasmWriter, s_pos: i32, s_j: i32, s_bound: i32, digit_buf: i32) {
    helpers_control_loop::emit_block_loop_header(w)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_core_locals::emit_local_get(w, s_bound)
    helpers_numeric_i32_compare::emit_i32_lt_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, digit_buf)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load8_u_default(w)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_pos)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_j)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
}
// Build the final decimal string at out_buf.  s_pos is the running cursor and
// ends at the one-past-last byte; s_wpos is set to out_buf for the allocator.
fn emit_f64_assemble(w: WasmWriter, s_pos: i32, s_neg: i32, s_k: i32, s_di: i32, s_j: i32, s_wpos: i32, s_zero: i32, digit_buf: i32, out_buf: i32) {
    helpers_numeric_i32_const::emit_i32_const(w, out_buf)
    helpers_core_locals::emit_local_tee(w, s_pos)
    helpers_core_locals::emit_local_set(w, s_wpos)
    // sign
    helpers_core_locals::emit_local_get(w, s_neg)
    helpers_control_structured::emit_if_empty(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 45)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_pos)
    helpers_control_structured::emit_end(w)
    // integer part: digits[s_di-1 .. s_k], or "0" when s_di <= s_k
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_core_locals::emit_local_get(w, s_k)
    helpers_numeric_i32_compare::emit_i32_le_s(w)
    helpers_control_structured::emit_if_empty(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 48)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_pos)
    helpers_control_structured::emit_else(w)
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_j)
    emit_f64_emit_digit_run(w, s_pos, s_j, s_k, digit_buf)
    helpers_control_structured::emit_end(w)
    // decimal point
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 46)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_pos)
    // fraction part
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_core_locals::emit_local_get(w, s_k)
    helpers_numeric_i32_compare::emit_i32_lt_s(w)
    helpers_control_structured::emit_if_empty(w)
    // s_di < s_k: emit (s_k - s_di) leading zeros, then all s_di digits.
    helpers_core_locals::emit_local_get(w, s_k)
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_j)
    helpers_control_loop::emit_block_loop_header(w)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_numeric_i32_compare::emit_i32_le_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 48)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_pos)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_pos)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_j)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
    helpers_core_locals::emit_local_get(w, s_di)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_j)
    emit_f64_emit_digit_run(w, s_pos, s_j, s_zero, digit_buf)
    helpers_control_structured::emit_else(w)
    // s_di >= s_k: emit digits[s_k-1 .. 0]
    helpers_core_locals::emit_local_get(w, s_k)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_j)
    emit_f64_emit_digit_run(w, s_pos, s_j, s_zero, digit_buf)
    helpers_control_structured::emit_end(w)
}
fn emit_f64_alloc_string_gc(w: WasmWriter, s_wpos: i32, s_len: i32, s_fpos: i32, string_type: i32, ctx: SelfEmitCtx) {
    let s_gc = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    // s_len = s_fpos - s_wpos  (total digit count including sign, decimal point)
    helpers_core_locals::emit_local_get(w, s_fpos)
    helpers_core_locals::emit_local_get(w, s_wpos)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_len)
    // Allocate GC array
    helpers_core_locals::emit_local_get(w, s_len)
    string_gc_helpers::emit_gc_array_new(w, string_type)
    helpers_core_locals::emit_local_set(w, s_gc)
    // Copy loop
    emit_gc_f64_digit_copy_loop(w, s_gc, s_wpos, s_len, s_i, string_type)
    // Push GC ref on stack
    helpers_core_locals::emit_local_get(w, s_gc)
}
fn emit_gc_f64_digit_copy_loop(w: WasmWriter, s_gc: i32, s_wpos: i32, s_len: i32, s_i: i32, string_type: i32) {
    string_gc_helpers::emit_gc_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_block_loop(w)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_core_locals::emit_local_get(w, s_len)
    string_gc_helpers::emit_gc_i32_ge_s(w)
    string_gc_helpers::emit_gc_br_if(w, 1)
    // gc_arr[i] = scratch_buf[s_wpos + i]
    helpers_core_locals::emit_local_get(w, s_gc)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_core_locals::emit_local_get(w, s_wpos)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load8_u_default(w)
    string_gc_helpers::emit_gc_array_set(w, string_type)
    // i++
    helpers_core_locals::emit_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_br(w, 0)
    string_gc_helpers::emit_gc_block_loop_end(w)
}
fn emit_f64_alloc_string(w: WasmWriter, s_wpos: i32, s_len: i32, s_alloc: i32, s_fpos: i32) {
    helpers_core_locals::emit_local_get(w, s_fpos)
    helpers_core_locals::emit_local_get(w, s_wpos)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_len)
    helpers_core_heap::emit_heap_get(w)
    helpers_core_locals::emit_local_tee(w, s_alloc)
    helpers_core_locals::emit_local_get(w, s_len)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_heap::emit_heap_set(w)
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_core_locals::emit_local_get(w, s_len)
    helpers_memory_access::emit_i32_store_default(w)
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, s_wpos)
    helpers_core_locals::emit_local_get(w, s_len)
    helpers_memory_access::emit_memory_copy(w)
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
}
