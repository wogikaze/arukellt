// Arukellt Selfhost - pre-encoded inner wasi:cli/run component for P2 command wrappers.

fn p2_run_inner_component_bytes() -> Vec<i32> {
    p2_run_bytes_from_hex(String_from("0061736d0d000100070501400001000a1401000f696d706f72742d66756e632d72756e0100070501400001000b0b01000372756e0100010101"))
}

fn p2_run_bytes_from_hex(hex: String) -> Vec<i32> {
    let out = Vec_new_i32()
    let n = len(hex)
    let mut i = 0
    while i + 1 < n {
        let hi = p2_run_hex_val(char_at(hex, i))
        let lo = p2_run_hex_val(char_at(hex, i + 1))
        push(out, hi * 16 + lo)
        i = i + 2
    }
    out
}

fn p2_run_hex_val(c: i32) -> i32 {
    if c >= 48 && c <= 57 {
        return c - 48
    }
    if c >= 97 && c <= 102 {
        return c - 87
    }
    0
}
