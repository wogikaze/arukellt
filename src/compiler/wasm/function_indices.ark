// Arukellt Selfhost - Wasm function index translation.

use wasm::emit_target

fn defined_function_index(function_idx: i32, target: String) -> i32 {
    function_idx + emit_target::host_import_count(clone(target))
}

fn wrapper_function_index(fn_count: i32, target: String) -> i32 {
    fn_count + emit_target::host_import_count(clone(target))
}
