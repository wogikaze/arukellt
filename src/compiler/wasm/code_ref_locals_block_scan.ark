// inference for ref locals (replaces the instruction tracer).
//
// This file contains the depth-aware recursive inference function and
// the block-scanning producer inspection.  It replaces the tracer
// (infer_ref_local_gc_type_depth) with a structured approach:
//
// 1. variant_slot → GcLayoutTable lookup (structured type ID)
// 2. type_name → GcLayoutTable lookup, then string-prefix fallback
// 3. function parameter type_name lookup
// 4. Block scan for direct dest assignments (ARRAY_NEW, GC_STRUCT_NEW,
//    STRUCT_NEW, CALL, CONST_STRING) and LOCAL_SET source tracing
//
// LOCAL_SET chain propagation is handled by post_pass_type_propagate.ark
// at MIR lowering time, but this scan still traces LOCAL_SET sources
// recursively (up to depth 3) for cases the post-pass didn't cover.

use mir::block_inst_access
use mir::function_locals_view
use mir::function_param_view
use mir::inst_accessors_operands
use mir::inst_accessors_shape
use mir::local_access
use mir::opcodes
use wasm::ctx_gc_type
use wasm::ctx_gc_layout_lookup
use wasm::code_ref_locals_types
use wasm::code_ref_locals_typename
use wasm::code_ref_locals_infer_dest
use wasm::code_ref_locals_stack_scan

// Public entry point: infer GC type for a local's storage.
fn infer_local_storage_gc_type(f: MirFunction, local_idx: i32, ctx: SelfEmitCtx) -> i32 {
    infer_local_storage_gc_type_depth(f, local_idx, ctx, 0)
}

// Depth-aware recursive inference.  Depth limit prevents infinite
// recursion in cyclic LOCAL_SET chains.
fn infer_local_storage_gc_type_depth(f: MirFunction, local_idx: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    if depth > 3 {
        return 0 - 1
    }
    if local_idx < 0 || local_idx >= function_locals_view::MirFunction_local_count(f) {
        return 0 - 1
    }
    let loc = function_locals_view::MirFunction_local_at(f, local_idx)
    let type_name = clone(loc.type_name)
    // 1. type_name → GcLayoutTable lookup, then string-prefix fallback.
    // Prefer the declared container type over a stray variant_slot so
    // payload locals (string, vec, etc.) are not declared as enum variants.
    if len(type_name) > 0 {
        let tn_gc = ctx_gc_layout_lookup::SelfEmitCtx_wasm_ref_type_idx_for_type_name(ctx, clone(type_name))
        if tn_gc >= 0 {
            return tn_gc
        }
        let tn_fallback = code_ref_locals_typename::infer_gc_type_from_type_name(clone(type_name), ctx)
        if tn_fallback >= 0 {
            return tn_fallback
        }
    }
    if code_ref_locals_types::is_option_type_name(clone(type_name)) {
        return ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
    }
    // 2. variant_slot direct lookup (structured type ID) only when the
    // local lacks an explicit container type_name.
    let variant_slot = local_access::MirLocal_variant_slot(loc)
    if variant_slot >= 0 && len(type_name) == 0 {
        let variant_gc = ctx_gc_layout_lookup::SelfEmitCtx_wasm_ref_type_idx_for_variant_slot(ctx, variant_slot)
        if variant_gc >= 0 {
            return variant_gc
        }
    }
    // 3. function parameter type_name lookup
    let param_count = function_param_view::MirFunction_param_count(f)
    if local_idx >= 0 && local_idx < param_count {
        let param_type_name = function_param_view::MirFunction_param_type_name(f, local_idx)
        if len(param_type_name) > 0 {
            let param_gc = ctx_gc_layout_lookup::SelfEmitCtx_wasm_ref_type_idx_for_type_name(ctx, clone(param_type_name))
            if param_gc >= 0 {
                return param_gc
            }
            let param_fallback = code_ref_locals_typename::infer_gc_type_from_type_name(param_type_name, ctx)
            if param_fallback >= 0 {
                return param_fallback
            }
        }
    }
    // 4. Block scan for producer inspection
    infer_gc_type_from_block_scan(f, local_idx, ctx, depth)
}

// Scan all blocks for instructions that assign to local_idx and infer
// the GC type from the producer instruction.
fn infer_gc_type_from_block_scan(f: MirFunction, local_idx: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    let block_count = len(f.blocks)
    let mut bi = 0
    while bi < block_count {
        let block = get_unchecked(f.blocks, bi)
        let inst_count = block_inst_access::MirBlock_inst_count(block)
        let mut ii = 0
        let mut prev_op = 0 - 1
        let mut prev_arg0 = 0 - 1
        let mut prev_dest = 0 - 1
        while ii < inst_count {
            let inst = block_inst_access::MirBlock_inst_at(block, ii)
            let op = inst_accessors_shape::MirInst_op(inst)
            let dest = inst_accessors_operands::MirInst_dest(inst)
            if dest == local_idx {
                let matched = infer_from_dest_match(f, inst, op, ctx, depth)
                if matched >= 0 {
                    return matched
                }
            }
            if op == opcodes::MIR_LOCAL_SET() && inst_accessors_operands::MirInst_arg0(inst) == local_idx {
                let source = inst_accessors_operands::MirInst_arg1(inst)
                if source >= 0 {
                    let inferred = infer_local_storage_gc_type_depth(f, source, ctx, depth + 1)
                    if inferred >= 0 {
                        return inferred
                    }
                } else {
                    let stacked = infer_from_stack_set(f, block, inst_count, ii, prev_op, prev_arg0, prev_dest, ctx, depth)
                    if stacked >= 0 {
                        return stacked
                    }
                }
            }
            prev_op = op
            prev_arg0 = inst_accessors_operands::MirInst_arg0(inst)
            prev_dest = dest
            ii = ii + 1
        }
        bi = bi + 1
    }
    0 - 1
}

// For direct dest match: if LOCAL_GET, trace the source local;
// otherwise, inspect the producer instruction.
fn infer_from_dest_match(f: MirFunction, inst: MirInst, op: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    if op == opcodes::MIR_LOCAL_GET() {
        let src = inst_accessors_operands::MirInst_arg0(inst)
        if src >= 0 {
            return infer_local_storage_gc_type_depth(f, src, ctx, depth + 1)
        }
        return 0 - 1
    }
    code_ref_locals_infer_dest::infer_ref_local_from_producer(f, inst, op, ctx)
}

// Stack-based LOCAL_SET (arg1 < 0): find the stack value producer.
fn infer_from_stack_set(f: MirFunction, block: MirBlock, inst_count: i32, ii: i32, prev_op: i32, prev_arg0: i32, prev_dest: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    if prev_op == opcodes::MIR_LOCAL_GET() && prev_arg0 >= 0 {
        let inferred = infer_local_storage_gc_type_depth(f, prev_arg0, ctx, depth + 1)
        if inferred >= 0 {
            return inferred
        }
    }
    if prev_dest >= 0 {
        let inferred = infer_local_storage_gc_type_depth(f, prev_dest, ctx, depth + 1)
        if inferred >= 0 {
            return inferred
        }
    }
    let src_ii = code_ref_locals_stack_scan::find_stack_value_source(block, inst_count, ii)
    if src_ii >= 0 {
        let src_inst = block_inst_access::MirBlock_inst_at(block, src_ii)
        let src_op = inst_accessors_shape::MirInst_op(src_inst)
        let src_arg0 = inst_accessors_operands::MirInst_arg0(src_inst)
        let src_dest = inst_accessors_operands::MirInst_dest(src_inst)
        if src_op == opcodes::MIR_LOCAL_GET() && src_arg0 >= 0 {
            let inferred = infer_local_storage_gc_type_depth(f, src_arg0, ctx, depth + 1)
            if inferred >= 0 {
                return inferred
            }
        }
        if src_dest >= 0 {
            let inferred = infer_local_storage_gc_type_depth(f, src_dest, ctx, depth + 1)
            if inferred >= 0 {
                return inferred
            }
        }
        let inferred = infer_from_dest_match(f, src_inst, src_op, ctx, depth)
        if inferred >= 0 {
            return inferred
        }
    }
    0 - 1
}
