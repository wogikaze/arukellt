use wasm::constants
use wasm::ctx_scratch
use wasm::intrinsic_env_var_result
use wasm::intrinsic_env_var_scan
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32

fn emit_env_var_lookup(w: WasmWriter, ctx: SelfEmitCtx, name_ptr: i32) {
    intrinsic_env_var_result::emit_env_var_clear_result(w)
    let name_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    emit_env_var_read_name_len(w, name_ptr, name_len)
    emit_env_var_fetch_environ(w, ctx)
    intrinsic_env_var_scan::emit_env_var_scan_entries(w, ctx, name_ptr, name_len)
    intrinsic_env_var_result::emit_env_var_load_or_none(w, ctx)
}

fn emit_env_var_read_name_len(w: WasmWriter, name_ptr: i32, name_len: i32) {
    helpers_core::emit_local_get(w, name_ptr)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_sub(w)
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_local_set(w, name_len)
}

fn emit_env_var_fetch_environ(w: WasmWriter, ctx: SelfEmitCtx) {
    emit_env_var_align_heap(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_ARGC())
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_ARGV_SIZE())
    helpers_core::emit_call(w, constants::WASI_IMPORT_ENVIRON_SIZES_GET())
    helpers_core::emit_drop(w)
    let env_count = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let buf_size = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_ARGC())
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_local_set(w, env_count)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_ARGV_SIZE())
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_local_set(w, buf_size)
    let ptrs_base = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let buf_base = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    emit_env_var_alloc_table(w, env_count, ptrs_base)
    emit_env_var_alloc_buffer(w, buf_size, buf_base)
    helpers_core::emit_local_get(w, ptrs_base)
    helpers_core::emit_local_get(w, buf_base)
    helpers_core::emit_call(w, constants::WASI_IMPORT_ENVIRON_GET())
    helpers_core::emit_drop(w)
}

fn emit_env_var_align_heap(w: WasmWriter) {
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 3)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_div_u(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_mul(w)
    helpers_core::emit_heap_set(w)
}

fn emit_env_var_alloc_table(w: WasmWriter, env_count: i32, ptrs_base: i32) {
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_set(w, ptrs_base)
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_get(w, env_count)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_mul(w)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
}

fn emit_env_var_alloc_buffer(w: WasmWriter, buf_size: i32, buf_base: i32) {
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_set(w, buf_base)
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_get(w, buf_size)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
}
