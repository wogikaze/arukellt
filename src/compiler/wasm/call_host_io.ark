    false
}

fn try_emit_fs_write_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_write_string(){
        let _result_on_stack = intrinsic_fs::emit_fs_write_string(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_write_bytes(){
        let _result_on_stack = intrinsic_fs::emit_fs_write_bytes(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_process_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_process_exit(){
        let _result_on_stack = intrinsic_process::emit_process_exit(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_process_abort(){
        let _result_on_stack = intrinsic_process::emit_process_abort(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_stdio_call(
    w: WasmWriter,
    handler_id: i32,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    prev_handler_id: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32
) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_read_stdin(){
        let _result_on_stack = intrinsic_stdio::emit_read_stdin_to_string(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_println(){
        let drop_stray_text_ref = gc_println_should_drop_stray_text_ref(prev_op, prev_handler_id)
        let _result_on_stack = intrinsic_stdio::emit_println(w, inst, ctx, drop_stray_text_ref, next_op, prev_op)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_print(){
        let _result_on_stack = intrinsic_stdio::emit_print(w, inst, ctx, prev_op)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_eprintln(){
        let _result_on_stack = intrinsic_stdio::emit_eprintln(w, inst, ctx, prev_op)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_panic(){
        let _exited = intrinsic_assert::emit_panic_message_exit(w, inst, ctx, prev_op, prev_arg0)
        return true
    }
    false
}

fn gc_println_should_drop_stray_text_ref(prev_op: i32, prev_handler_id: i32) -> bool {
    if prev_op != mir::opcodes::MIR_CALL() {
        return false
    }
    if prev_handler_id == corehir::core_op_registry_generated::core_op_handler_text_to_string() {
        return true
    }
    if prev_handler_id == corehir::core_op_registry_generated::core_op_handler_text_format_i64() {
        return true
    }
    if prev_handler_id == corehir::core_op_registry_generated::core_op_handler_text_format_f64() {
        return true
    }
    if prev_handler_id == corehir::core_op_registry_generated::core_op_handler_text_format_bool() {
        return true
    }
    if prev_handler_id == corehir::core_op_registry_generated::core_op_handler_text_char_to_string() {
        return true
    }
    false
}
