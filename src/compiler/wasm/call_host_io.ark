use wasm::inst_store
use wasm::intrinsic_env_args
use wasm::intrinsic_assert
use wasm::intrinsic_fs
use wasm::intrinsic_process
use wasm::intrinsic_stdio

fn try_emit_env_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_env_var_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_env_arg_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_env_arg_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_arg_count(){
        let _result_on_stack = intrinsic_env_args::emit_env_arg_count(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_args(){
        let _result_on_stack = intrinsic_env_args::emit_env_args(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_has_flag(){
        let _result_on_stack = intrinsic_env_args::emit_env_has_flag(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_arg_at(){
        let _result_on_stack = intrinsic_env_args::emit_env_arg_at(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_env_var_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_var(){
        let _result_on_stack = intrinsic_env_args::emit_env_var(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_get_var(){
        let _result_on_stack = intrinsic_env_args::emit_env_get_var(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_var_or_default(){
        let _result_on_stack = intrinsic_env_args::emit_env_var_or_default(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_fs_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_fs_query_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_fs_read_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_fs_write_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_fs_query_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_exists(){
        let _result_on_stack = intrinsic_fs::emit_fs_exists(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_fs_read_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_fs_read_file(){
        let _result_on_stack = intrinsic_fs::emit_fs_read_to_string(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
