        return true
    }
    if eq(clone(callee), "hash_string::hashmap_i32_str_set_flag") {
        intrinsic_hashmap_str_slot::emit_hm_is_slot_set(w, inst, ctx, 2, next_op, next_arg0, next_arg1, next2_op)
