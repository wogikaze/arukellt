    if eq(clone(callee), "hash_string::hashmap_i32_str_get_key") {
        intrinsic_hashmap_str_slot::emit_hm_is_slot_get(w, inst, ctx, 0, next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if eq(clone(callee), "hash_string::hashmap_i32_str_set_key") {
        intrinsic_hashmap_str_slot::emit_hm_is_slot_set(w, inst, ctx, 0, next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if eq(clone(callee), "hash_string::hashmap_i32_str_get_val") {
        intrinsic_hashmap_str_slot::emit_hm_is_slot_get(w, inst, ctx, 1, next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if eq(clone(callee), "hash_string::hashmap_i32_str_set_val") {
