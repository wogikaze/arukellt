fn emit_hm_slot_get_gc(w: WasmWriter, hm_type: i32, field_idx: i32, array_type: i32, s_map: i32, s_idx: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, s_map)
    writer_gc::emit_gc_struct_get(w, hm_type, field_idx)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, s_idx)
    writer_gc::emit_gc_array_get(w, array_type)
}

fn emit_hm_slot_set_gc(w: WasmWriter, hm_type: i32, field_idx: i32, array_type: i32, s_map: i32, s_idx: i32, s_val: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, s_map)
    writer_gc::emit_gc_struct_get(w, hm_type, field_idx)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, s_idx)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, s_val)
    writer_gc::emit_gc_array_set(w, array_type)
}

fn gc_slot_field(region: i32) -> i32 {
    if region == 0 {
        return 2
    }
    if region == 1 {
        return 3
    }
    4
}

fn gc_slot_array_type_si(region: i32, i32_array_type: i32, string_ref_array_type: i32) -> i32 {
    if region == 0 {
        return string_ref_array_type
    }
    i32_array_type
}

fn gc_slot_array_type_is(region: i32, i32_array_type: i32, string_ref_array_type: i32) -> i32 {
    if region == 0 {
        return i32_array_type
    }
    if region == 1 {
        return string_ref_array_type
    }
    i32_array_type
}

fn gc_slot_array_type_ss(region: i32, i32_array_type: i32, string_ref_array_type: i32) -> i32 {
    if region == 0 || region == 1 {
        return string_ref_array_type
    }
    i32_array_type
}

