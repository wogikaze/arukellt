use corehir::kinds
use corehir::type_id
use corehir::type_table
use mir::module_gc_enum
use mir::module_gc_struct
use wasm::gc_layout_table

fn populate_gc_layout_table_for_emit(
    table: GcLayoutTable,
    tt: TypeTable,
    mir: MirModule,
    gc_type_base: i32,
    gc_enum_variant_type_map: Vec<i32>,
    gc_struct_type_map: Vec<i32>
) {
    // Use find_existing instead of intern to avoid mutating the TypeTable
    // during emit — interning new entries shifts type IDs and corrupts
    // downstream emit phases.
    register_builtin(table, tt, kinds::TYPE_KIND_STRING(), String_from("String"), gc_type_base + 0)
    register_builtin(table, tt, kinds::TYPE_KIND_VEC(), String_from("vec:i32"), gc_type_base + 10)
    register_builtin(table, tt, kinds::TYPE_KIND_VEC(), String_from("vec:String"), gc_type_base + 19)
    register_builtin(table, tt, kinds::TYPE_KIND_VEC(), String_from("vec:v128"), gc_type_base + 21)
    register_builtin(table, tt, kinds::TYPE_KIND_VEC(), String_from("vec:i64"), gc_type_base + 22)
    register_builtin(table, tt, kinds::TYPE_KIND_VEC(), String_from("vec:f64"), gc_type_base + 23)
    register_builtin(table, tt, kinds::TYPE_KIND_HASHMAP(), String_from("hashmap:String:i32"), gc_type_base + 16)
    register_builtin(table, tt, kinds::TYPE_KIND_HASHMAP(), String_from("hashmap:i32:String"), gc_type_base + 17)
    register_builtin(table, tt, kinds::TYPE_KIND_HASHMAP(), String_from("hashmap:String:String"), gc_type_base + 18)
    gc_layout_table::gc_layout_table_populate_from_type_table(table, tt, gc_type_base)
    gc_layout_table::gc_layout_table_register_enum_variant_names(table, tt, module_gc_enum::MirModule_gc_enum_variant_names(mir), gc_enum_variant_type_map)
    gc_layout_table::gc_layout_table_register_struct_names(table, tt, module_gc_struct::MirModule_gc_struct_names(mir), gc_struct_type_map)
}

fn register_builtin(table: GcLayoutTable, tt: TypeTable, kind: i32, name: String, type_idx: i32) {
    let tid = type_table::type_table_find_existing(tt, kind, clone(name), Vec_new_TypeId())
    if !type_id::type_id_is_valid(tid) {
        return
    }
    gc_layout_table::gc_layout_table_register(table, tid, gc_layout_table::WasmRefType_new(type_idx, 1), 0 - 1)
}
