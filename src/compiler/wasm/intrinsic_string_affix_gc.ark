use wasm::ctx_record
use wasm::ctx_scratch
use wasm::string_gc_helpers

fn emit_starts_with_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let s_gc0 = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_gc1 = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 1)
    let string_type = ctx_record::SelfEmitCtx_gc_type_base(ctx)
    let s_len_main = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_len_prefix = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_result = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)

    string_gc_helpers::emit_gc_local_set(w, s_gc1)
    string_gc_helpers::emit_gc_local_set(w, s_gc0)

    emit_gc_affix_lens(w, s_gc0, s_gc1, s_len_main, s_len_prefix)

    string_gc_helpers::emit_gc_local_get(w, s_len_prefix)
    string_gc_helpers::emit_gc_local_get(w, s_len_main)
    string_gc_helpers::emit_gc_i32_gt_s(w)
    string_gc_helpers::emit_gc_if_void(w)
    string_gc_helpers::emit_gc_i32_const(w, 0)
    string_gc_helpers::emit_gc_local_set(w, s_result)
    string_gc_helpers::emit_gc_else(w)

    string_gc_helpers::emit_gc_i32_const(w, 1)
    string_gc_helpers::emit_gc_local_set(w, s_result)
    emit_gc_affix_loop(w, s_i, s_len_prefix, s_gc0, s_gc1, s_result, string_type)
    string_gc_helpers::emit_gc_end(w)
    string_gc_helpers::emit_gc_local_get(w, s_result)
}

fn emit_ends_with_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let s_gc0 = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_gc1 = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 1)
    let string_type = ctx_record::SelfEmitCtx_gc_type_base(ctx)
    let s_len_main = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_len_suffix = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_result = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)

    string_gc_helpers::emit_gc_local_set(w, s_gc1)
    string_gc_helpers::emit_gc_local_set(w, s_gc0)

    emit_gc_affix_lens(w, s_gc0, s_gc1, s_len_main, s_len_suffix)

    string_gc_helpers::emit_gc_local_get(w, s_len_suffix)
    string_gc_helpers::emit_gc_local_get(w, s_len_main)
    string_gc_helpers::emit_gc_i32_gt_s(w)
    string_gc_helpers::emit_gc_if_void(w)
    string_gc_helpers::emit_gc_i32_const(w, 0)
    string_gc_helpers::emit_gc_local_set(w, s_result)
    string_gc_helpers::emit_gc_else(w)

    string_gc_helpers::emit_gc_i32_const(w, 1)
    string_gc_helpers::emit_gc_local_set(w, s_result)
    emit_gc_ends_with_loop(w, s_i, s_len_suffix, s_gc0, s_gc1, s_len_main, s_result, string_type)
    string_gc_helpers::emit_gc_end(w)
    string_gc_helpers::emit_gc_local_get(w, s_result)
}

fn emit_gc_affix_lens(w: WasmWriter, arg0: i32, arg1: i32, s_len_main: i32, s_len_sub: i32) {
    string_gc_helpers::emit_gc_local_get(w, arg0)
    string_gc_helpers::emit_gc_array_len(w)
    string_gc_helpers::emit_gc_local_set(w, s_len_main)
    string_gc_helpers::emit_gc_local_get(w, arg1)
    string_gc_helpers::emit_gc_array_len(w)
    string_gc_helpers::emit_gc_local_set(w, s_len_sub)
}

fn emit_gc_affix_loop(w: WasmWriter, s_i: i32, s_len: i32, arg0: i32, arg1: i32, s_result: i32, string_type: i32) {
    string_gc_helpers::emit_gc_i32_const(w, 0)
    string_gc_helpers::emit_gc_local_set(w, s_i)
    string_gc_helpers::emit_gc_block_loop(w)
    emit_gc_affix_loop_check(w, s_i, s_len)
    string_gc_helpers::emit_gc_br_if(w, 1)
    emit_gc_byte_cmp_body(w, arg0, arg1, s_i, s_result, string_type)
    emit_gc_affix_loop_inc(w, s_i)
    string_gc_helpers::emit_gc_br(w, 0)
    string_gc_helpers::emit_gc_block_loop_end(w)
}

fn emit_gc_ends_with_loop(w: WasmWriter, s_i: i32, s_len: i32, arg0: i32, arg1: i32, s_len_main: i32, s_result: i32, string_type: i32) {
    string_gc_helpers::emit_gc_i32_const(w, 0)
    string_gc_helpers::emit_gc_local_set(w, s_i)
    string_gc_helpers::emit_gc_block_loop(w)
    emit_gc_affix_loop_check(w, s_i, s_len)
    string_gc_helpers::emit_gc_br_if(w, 1)
    string_gc_helpers::emit_gc_local_get(w, arg0)
    string_gc_helpers::emit_gc_local_get(w, s_len_main)
    string_gc_helpers::emit_gc_local_get(w, s_len)
    string_gc_helpers::emit_gc_i32_sub(w)
    string_gc_helpers::emit_gc_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_add(w)
    string_gc_helpers::emit_gc_array_get_u(w, string_type)
    string_gc_helpers::emit_gc_local_get(w, arg1)
    string_gc_helpers::emit_gc_local_get(w, s_i)
    string_gc_helpers::emit_gc_array_get_u(w, string_type)
    emit_gc_byte_cmp_result(w, s_result)
    emit_gc_affix_loop_inc(w, s_i)
    string_gc_helpers::emit_gc_br(w, 0)
    string_gc_helpers::emit_gc_block_loop_end(w)
}

fn emit_gc_affix_loop_check(w: WasmWriter, s_i: i32, s_len: i32) {
    string_gc_helpers::emit_gc_local_get(w, s_i)
    string_gc_helpers::emit_gc_local_get(w, s_len)
    string_gc_helpers::emit_gc_i32_ge_s(w)
}

fn emit_gc_affix_loop_inc(w: WasmWriter, s_i: i32) {
    string_gc_helpers::emit_gc_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    string_gc_helpers::emit_gc_i32_add(w)
    string_gc_helpers::emit_gc_local_set(w, s_i)
}

fn emit_gc_byte_cmp_body(w: WasmWriter, arg0: i32, arg1: i32, s_i: i32, s_result: i32, string_type: i32) {
    string_gc_helpers::emit_gc_local_get(w, arg0)
    string_gc_helpers::emit_gc_local_get(w, s_i)
    string_gc_helpers::emit_gc_array_get_u(w, string_type)
    string_gc_helpers::emit_gc_local_get(w, arg1)
    string_gc_helpers::emit_gc_local_get(w, s_i)
    string_gc_helpers::emit_gc_array_get_u(w, string_type)
    string_gc_helpers::emit_gc_i32_ne(w)
    string_gc_helpers::emit_gc_if_void(w)
    string_gc_helpers::emit_gc_i32_const(w, 0)
    string_gc_helpers::emit_gc_local_set(w, s_result)
    string_gc_helpers::emit_gc_br(w, 2)
    string_gc_helpers::emit_gc_end(w)
}

fn emit_gc_byte_cmp_result(w: WasmWriter, s_result: i32) {
    string_gc_helpers::emit_gc_i32_ne(w)
    string_gc_helpers::emit_gc_if_void(w)
    string_gc_helpers::emit_gc_i32_const(w, 0)
    string_gc_helpers::emit_gc_local_set(w, s_result)
    string_gc_helpers::emit_gc_br(w, 2)
    string_gc_helpers::emit_gc_end(w)
}
