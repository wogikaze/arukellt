// Arukellt Selfhost - string pad non-GC helpers.
// Extracted from intrinsic_string_pad.ark

use wasm::intrinsics::helpers_control
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32

fn emit_pad_read_args_and_len(w: WasmWriter, s_str: i32, s_width: i32, s_fill: i32, s_slen: i32) {
    helpers_core::emit_local_set(w, s_fill)
    helpers_core::emit_local_set(w, s_width)
    helpers_core::emit_local_set(w, s_str)
    helpers_core::emit_local_get(w, s_str)
    helpers_memory::emit_string_len_from_stack(w)
    helpers_core::emit_local_set(w, s_slen)
}

fn emit_pad_delta_fill_and_alloc(w: WasmWriter, s_width: i32, s_slen: i32, s_pad: i32, s_fill: i32, s_fb: i32, s_alloc: i32) {
    helpers_core::emit_local_get(w, s_width)
    helpers_core::emit_local_get(w, s_slen)
    helpers_numeric_i32::emit_i32_sub(w)
    helpers_core::emit_local_set(w, s_pad)
    helpers_core::emit_local_get(w, s_fill)
    helpers_memory::emit_i32_load8_u_default(w)
    helpers_core::emit_local_set(w, s_fb)
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_tee(w, s_alloc)
    helpers_core::emit_local_get(w, s_width)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
    helpers_core::emit_local_get(w, s_alloc)
    helpers_core::emit_local_get(w, s_width)
    helpers_memory::emit_i32_store_default(w)
}

fn emit_pad_fill_loop(w: WasmWriter, s_alloc: i32, s_offset: i32, s_pad: i32, s_i: i32, s_fb: i32, has_offset: bool) {
    helpers_numeric_i32::emit_i32_const(w, 0)
    helpers_core::emit_local_set(w, s_i)
    helpers_control::emit_block_loop_header(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_core::emit_local_get(w, s_pad)
    helpers_numeric_i32::emit_i32_ge_s(w)
    helpers_control::emit_br_if(w, 1)
    helpers_core::emit_local_get(w, s_alloc)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    if has_offset {
        helpers_core::emit_local_get(w, s_offset)
        helpers_numeric_i32::emit_i32_add(w)
    }
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_get(w, s_fb)
    helpers_memory::emit_i32_store8_default(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32::emit_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_set(w, s_i)
    helpers_control::emit_br(w, 0)
    helpers_control::emit_end(w)
    helpers_control::emit_end(w)
}

fn emit_pad_copy_source(w: WasmWriter, s_alloc: i32, s_str: i32, s_slen: i32, s_offset: i32, has_offset: bool) {
    helpers_core::emit_local_get(w, s_alloc)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    if has_offset {
        helpers_core::emit_local_get(w, s_offset)
        helpers_numeric_i32::emit_i32_add(w)
    }
    helpers_core::emit_local_get(w, s_str)
    helpers_core::emit_local_get(w, s_slen)
    helpers_memory::emit_memory_copy(w)
}

fn emit_pad_result_ptr(w: WasmWriter, s_alloc: i32) {
    helpers_core::emit_local_get(w, s_alloc)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
}
