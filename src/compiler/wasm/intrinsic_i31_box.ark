// Arukellt Selfhost - i31ref boxing demo intrinsic for GC verification.

use mir::inst_accessors_operands
use wasm::opcodes
use wasm::ctx_scratch
use wasm::ctx_record
use wasm::emit_target
use wasm::writer_core
use wasm::writer_gc

fn try_emit_i31_box_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if !eq(clone(callee), String_from("__intrinsic_i31_box")) && !eq(clone(callee), String_from("i31_box")) {
        return false
    }
    if !emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let s_val = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_core::emit_leb128_u(w, s_val)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
        writer_core::emit_leb128_u(w, s_val)
    } else {
        let s_val = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_core::emit_leb128_u(w, s_val)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
        writer_core::emit_leb128_u(w, s_val)
        writer_gc::emit_gc_ref_i31(w)
        writer_gc::emit_gc_i31_get_s(w)
    }
    return true
}
