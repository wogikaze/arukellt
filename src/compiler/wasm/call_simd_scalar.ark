// On T1, v128 is emulated as 4 consecutive i32 locals.
// arg0 = source v128 local base, arg1 = second arg (scalar or v128 base), dest = result v128 local base.
// For binary ops: arg0 and arg1 are v128 bases (4 i32 each).
// For splat: arg0 is the scalar value.
// For extract_lane: arg0 is the v128 base, lane is an immediate.
// For replace_lane: arg0 is the v128 base, arg1 is the scalar value, lane is an immediate.

use mir::inst_accessors_operands
use wasm::call_simd_scalar_cmp
use wasm::call_simd_scalar_ops
use wasm::opcodes

fn try_emit_simd_scalar(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    let dest = inst_accessors_operands::MirInst_dest(inst)
    let arg0 = inst_accessors_operands::MirInst_arg0(inst)
    let arg1 = inst_accessors_operands::MirInst_arg1(inst)
    if try_emit_simd_scalar_splat_zero(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_extract(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_replace(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_binary(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_unary(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_comparison(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_minmax(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_rounding(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_shift(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_alltrue_bitmask(w, clone(handler_id), dest, arg0, arg1) { return true }
    if try_emit_simd_scalar_saturating(w, clone(handler_id), dest, arg0, arg1) { return true }
    false
}

fn try_emit_simd_scalar_splat_zero(w: WasmWriter, handler_id: i32, dest: i32, arg0: i32, arg1: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_splat() {
        call_simd_scalar_ops::emit_scalar_splat_f32(w, arg0, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i32x4_splat() {
        call_simd_scalar_ops::emit_scalar_splat_i32(w, arg0, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_splat() {
        call_simd_scalar_ops::emit_scalar_splat_i32(w, arg0, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_splat() {
        call_simd_scalar_ops::emit_scalar_splat_i32(w, arg0, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_splat() {
        call_simd_scalar_ops::emit_scalar_splat_f64(w, arg0, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i64x2_splat() {
        call_simd_scalar_ops::emit_scalar_splat_i64(w, arg0, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_v128_const() {
        call_simd_scalar_ops::emit_scalar_zero(w, dest)
        return true
    }
    false
}

fn try_emit_simd_scalar_extract(w: WasmWriter, handler_id: i32, dest: i32, arg0: i32, arg1: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_extract_lane() {
        call_simd_scalar_ops::emit_scalar_extract_f32(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i32x4_extract_lane() {
        call_simd_scalar_ops::emit_scalar_extract_i32(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_extract_lane_s() {
        call_simd_scalar_ops::emit_scalar_extract_i32(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_extract_lane_u() {
        call_simd_scalar_ops::emit_scalar_extract_i32(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extract_lane_s() {
        call_simd_scalar_ops::emit_scalar_extract_i32(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_extract_lane_u() {
        call_simd_scalar_ops::emit_scalar_extract_i32(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_extract_lane() {
        call_simd_scalar_ops::emit_scalar_extract_f64(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i64x2_extract_lane() {
        call_simd_scalar_ops::emit_scalar_extract_i64(w, arg0, arg1, dest)
        return true
    }
    false
}

