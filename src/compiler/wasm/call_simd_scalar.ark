fn try_emit_simd_scalar_minmax(w: WasmWriter, handler_id: i32, dest: i32, arg0: i32, arg1: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i32x4_min_s() {
