    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f64x2_trunc() {
        call_simd_scalar_cmp::emit_scalar_f64x2_unary(w, arg0, dest, opcodes::OP_F64_TRUNC())
