fn try_emit_simd_scalar_saturating(w: WasmWriter, handler_id: i32, dest: i32, arg0: i32, arg1: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_add_sat_s() {
        call_simd_scalar_cmp::emit_scalar_i32x4_add_sat(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_add_sat_u() {
        call_simd_scalar_cmp::emit_scalar_i32x4_add_sat(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_sub_sat_s() {
        call_simd_scalar_cmp::emit_scalar_i32x4_sub_sat(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_sub_sat_u() {
        call_simd_scalar_cmp::emit_scalar_i32x4_sub_sat(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_add_sat_s() {
        call_simd_scalar_cmp::emit_scalar_i32x4_add_sat(w, arg0, arg1, dest)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_add_sat_u() {
        call_simd_scalar_cmp::emit_scalar_i32x4_add_sat(w, arg0, arg1, dest)
        return true
