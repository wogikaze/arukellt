        call_simd_scalar_cmp::emit_scalar_i32x4_minmax(w, arg0, arg1, dest, opcodes::OP_I32_LT_U())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_max_s() {
        call_simd_scalar_cmp::emit_scalar_i32x4_maxmax(w, arg0, arg1, dest, opcodes::OP_I32_GT_S())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i8x16_max_u() {
        call_simd_scalar_cmp::emit_scalar_i32x4_maxmax(w, arg0, arg1, dest, opcodes::OP_I32_GT_U())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_min_s() {
        call_simd_scalar_cmp::emit_scalar_i32x4_minmax(w, arg0, arg1, dest, opcodes::OP_I32_LT_S())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_min_u() {
        call_simd_scalar_cmp::emit_scalar_i32x4_minmax(w, arg0, arg1, dest, opcodes::OP_I32_LT_U())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_max_s() {
        call_simd_scalar_cmp::emit_scalar_i32x4_maxmax(w, arg0, arg1, dest, opcodes::OP_I32_GT_S())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_i16x8_max_u() {
        call_simd_scalar_cmp::emit_scalar_i32x4_maxmax(w, arg0, arg1, dest, opcodes::OP_I32_GT_U())
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_simd_f32x4_min() {
        call_simd_scalar_cmp::emit_scalar_f32x4_minmax(w, arg0, arg1, dest, opcodes::OP_F32_LT())
        return true
