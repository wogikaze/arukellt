use wasm::ctx_gc_type
use wasm::ctx_gc_type_vec_ref
use wasm::ctx_scratch

fn vec_set_array_type(ctx: SelfEmitCtx, is_vec_string: bool, is_vec_i64: bool, is_vec_f64: bool, is_vec_sref: bool) -> i32 {
    if is_vec_sref {
        return ctx_gc_type_vec_ref::SelfEmitCtx_struct_ref_array_type(ctx)
    }
    if is_vec_string {
        return ctx_gc_type::SelfEmitCtx_string_array_type(ctx)
    }
    if is_vec_i64 {
        return ctx_gc_type::SelfEmitCtx_i64_array_type(ctx)
    }
    if is_vec_f64 {
        return ctx_gc_type::SelfEmitCtx_f64_array_type(ctx)
    }
    ctx_gc_type::SelfEmitCtx_i32_array_type(ctx)
}

fn vec_set_val_scratch(ctx: SelfEmitCtx, is_vec_string: bool, is_vec_i64: bool, is_vec_f64: bool, is_vec_sref: bool) -> i32 {
    // Distinct from scratch_gc_vec_local (holds the Vec handle during set).
    if is_vec_sref {
        return ctx_scratch::SelfEmitCtx_scratch_gc_struct_ref_val_local(ctx, 0)
    }
    if is_vec_string {
        return ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    }
    if is_vec_i64 {
        return ctx_scratch::SelfEmitCtx_scratch_local(ctx, 15)
    }
    if is_vec_f64 {
        return ctx_scratch::SelfEmitCtx_scratch_local(ctx, 12)
    }
    ctx_scratch::SelfEmitCtx_scratch_base(ctx)
}

fn vec_set_vec_flags(vec_type: i32, ctx: SelfEmitCtx) -> (bool, bool, bool, bool) {
    let is_vec_string = vec_type == ctx_gc_type::SelfEmitCtx_vec_string_type(ctx)
    let is_vec_i64 = vec_type == ctx_gc_type::SelfEmitCtx_vec_i64_type(ctx)
    let is_vec_f64 = vec_type == ctx_gc_type::SelfEmitCtx_vec_f64_type(ctx)
    let is_vec_sref = vec_type == ctx_gc_type_vec_ref::SelfEmitCtx_vec_struct_ref_type(ctx)
    (is_vec_string, is_vec_i64, is_vec_f64, is_vec_sref)
}
