// Call dispatch owner: routes MIR call instructions to target handlers.

use mir::inst_accessors_literals
use mir::inst_accessors_shape
use mir::opcodes
use wasm::call_fallback
use wasm::call_indirect
use wasm::call_wit
use wasm::core_op_dispatch
use wasm::core_op_shadow

fn try_emit_call_inst(
    w: WasmWriter,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    prev_callee: String,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32,
    bindings: Vec<resolver::wit_import_bind::WitImportBinding>
) -> bool {
    if call_wit::try_emit_wit_call(w, inst, ctx, bindings, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if inst_accessors_shape::MirInst_op(inst) == opcodes::MIR_CALL_INDIRECT() {
        call_indirect::emit_call_indirect_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if inst_accessors_shape::MirInst_op(inst) == opcodes::MIR_CALL() {
        let callee = callee_name_for_diagnostics(clone(inst_accessors_literals::MirInst_str_val(inst)))
        core_op_shadow::core_op_shadow_observe_call(ctx, inst, clone(callee))
        if core_op_dispatch::try_emit_call_via_core_op_registry(
            w,
            inst,
            ctx,
            prev_op,
            prev_arg0,
            prev_arg1,
            prev_callee,
            next_op,
            next_arg0,
            next_arg1,
            next2_op,
            len(bindings)
        ) {
            return true
        }
        call_fallback::emit_fallback_call(w, callee, inst, ctx, prev_op, prev_arg0, prev_arg1, prev_callee, next_op, next_arg0, next_arg1, next2_op, len(bindings))
        return true
    }
    false
}

fn callee_name_for_diagnostics(raw_callee: String) -> String {
    let callee_n = len(raw_callee)
    if callee_n > 12 && starts_with(clone(raw_callee), String_from("__intrinsic_")) {
        return substring(clone(raw_callee), 12, callee_n)
    }
    raw_callee
}
