}

fn hashmap_string_string_builtin_alias(name: String) -> String {
    if eq(clone(name), String_from("HashMap_new_String_String")) || eq(clone(name), String_from("HashMap_String_String_new")) {
        return String_from("hash_string::hashmap_str_str_new")
    }
    if eq(clone(name), String_from("HashMap_String_String_insert")) {
        return String_from("hash_string::hashmap_str_str_set")
    }
    if eq(clone(name), String_from("HashMap_String_String_get")) {
        return String_from("hash_string::hashmap_str_str_get")
    }
    if eq(clone(name), String_from("HashMap_String_String_contains_key")) {
