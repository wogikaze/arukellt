//
// GC target: emit_struct_new uses GC struct.new only when dest is VT_GC_REF.
//            emit_struct_get/set always use linear-memory path (struct type
//            cannot be determined from MIR instruction alone; GC-typed structs
//            like Vec use explicit writer_gc calls in intrinsic files).

use mir::inst_accessors_shape
use mir::inst_accessors_operands
use mir::inst_accessors_literals
use wasm::opcodes
use wasm::writer_core
use wasm::writer_gc
use wasm::ctx_gc_type
use wasm::ctx_record
use wasm::ctx_gc_layout_lookup
use wasm::emit_target
use wasm::code_ref_locals
use wasm::intrinsics::helpers_core
use mir::value_types

fn emit_struct_new(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx, prev_op: i32) {
    let dest = inst_accessors_operands::MirInst_dest(inst)
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let struct_name = inst_accessors_literals::MirInst_str_val(inst)
        let gc_type_idx = if len(struct_name) > 0 && ctx_gc_type::SelfEmitCtx_has_struct_type(ctx, clone(struct_name)) {
            ctx_gc_type::SelfEmitCtx_struct_type_by_name(ctx, clone(struct_name))
        } else {
            ctx_gc_type::SelfEmitCtx_struct_type(ctx, inst_accessors_literals::MirInst_int_val(inst))
        }
        writer_gc::emit_gc_struct_new_default(w, gc_type_idx)
        writer_gc::emit_gc_ref_cast(w, gc_type_idx)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_core::emit_leb128_u(w, dest)
        return
    }
    writer_core::emit_byte(w, opcodes::OP_GLOBAL_GET())
    writer_core::emit_leb128_u(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, dest)
    writer_core::emit_byte(w, opcodes::OP_GLOBAL_GET())
    writer_core::emit_leb128_u(w, 0)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, inst_accessors_literals::MirInst_int_val(inst))
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    helpers_core::emit_heap_set(w)
}

fn emit_struct_get(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx, prev_op: i32, prev_arg0: i32) {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let byte_offset = inst_accessors_literals::MirInst_int_val(inst)
        let gc_type_idx = resolve_gc_struct_type_idx(inst, ctx, prev_op, prev_arg0, byte_offset, inst_accessors_operands::MirInst_arg1(inst))
        let field_idx = compute_field_idx_get(inst, byte_offset)
        if prev_op == mir::opcodes::MIR_STRUCT_SET() {
            writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
            writer_core::emit_leb128_u(w, prev_arg0)
        } else if prev_op != mir::opcodes::MIR_LOCAL_GET() {
            let base_local = inst_accessors_operands::MirInst_arg0(inst)
            if base_local >= 0 {
                writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
                writer_core::emit_leb128_u(w, base_local)
            }
        }
        writer_gc::emit_gc_ref_cast(w, gc_type_idx)
        writer_gc::emit_gc_struct_get(w, gc_type_idx, field_idx)
        return
    }
    if inst_accessors_literals::MirInst_int_val(inst) > 0 {
        writer_core::emit_byte(w, opcodes::OP_I32_CONST())
        writer_core::emit_leb128_s(w, inst_accessors_literals::MirInst_int_val(inst))
        writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    }
    let val_type = inst_accessors_shape::MirInst_val_type(inst)
    if val_type == value_types::VT_F64() {
        writer_core::emit_byte(w, opcodes::OP_F64_LOAD())
        writer_core::emit_byte(w, 3)
        writer_core::emit_byte(w, 0)
    } else {
        if val_type == value_types::VT_F32() {
            writer_core::emit_byte(w, opcodes::OP_F32_LOAD())
            writer_core::emit_byte(w, 2)
            writer_core::emit_byte(w, 0)
        } else {
            if val_type == value_types::VT_I64() {
                writer_core::emit_byte(w, opcodes::OP_I64_LOAD())
                writer_core::emit_byte(w, 2)
                writer_core::emit_byte(w, 0)
            } else {
                writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
                writer_core::emit_byte(w, 2)
                writer_core::emit_byte(w, 0)
            }
        }
    }
}

fn emit_struct_set(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let byte_offset = inst_accessors_literals::MirInst_int_val(inst)
        let gc_type_idx = resolve_gc_struct_type_idx(inst, ctx, 0 - 1, 0 - 1, byte_offset, inst_accessors_operands::MirInst_dest(inst))
        let field_idx = compute_field_idx_set(inst, byte_offset)
        let base_local = inst_accessors_operands::MirInst_arg0(inst)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
        writer_core::emit_leb128_u(w, base_local)
        writer_gc::emit_gc_ref_cast(w, gc_type_idx)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_TEE())
        writer_core::emit_leb128_u(w, base_local)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
        writer_core::emit_leb128_u(w, inst_accessors_operands::MirInst_arg1(inst))
        writer_gc::emit_gc_struct_set(w, gc_type_idx, field_idx)
        return
    }
    let val_type = inst_accessors_shape::MirInst_val_type(inst)
    if val_type == value_types::VT_F64() {
        emit_struct_store_value(w, inst, inst_accessors_operands::MirInst_arg1(inst), opcodes::OP_F64_STORE(), 3)
    } else {
        if val_type == value_types::VT_F32() {
            emit_struct_store_value(w, inst, inst_accessors_operands::MirInst_arg1(inst), opcodes::OP_F32_STORE(), 2)
        } else {
            if val_type == value_types::VT_I64() {
                emit_struct_store_value(w, inst, inst_accessors_operands::MirInst_arg1(inst), opcodes::OP_I64_STORE(), 2)
            } else {
                emit_struct_store_value(w, inst, inst_accessors_operands::MirInst_arg1(inst), opcodes::OP_I32_STORE(), 2)
            }
        }
    }
}

fn emit_struct_store_value(w: WasmWriter, inst: MirInst, value_local: i32, store_opcode: i32, align: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, inst_accessors_operands::MirInst_arg0(inst))
    if inst_accessors_literals::MirInst_int_val(inst) > 0 {
        writer_core::emit_byte(w, opcodes::OP_I32_CONST())
        writer_core::emit_leb128_s(w, inst_accessors_literals::MirInst_int_val(inst))
        writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    }
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, value_local)
    writer_core::emit_byte(w, store_opcode)
    writer_core::emit_byte(w, align)
    writer_core::emit_byte(w, 0)
}

fn compute_field_idx_set(inst: MirInst, byte_offset: i32) -> i32 {
    let dest = inst_accessors_operands::MirInst_dest(inst)
    if dest >= 100000 {
        return dest / 100000
    }
    byte_offset / 4
}

fn compute_field_idx_get(inst: MirInst, byte_offset: i32) -> i32 {
    let arg1 = inst_accessors_operands::MirInst_arg1(inst)
    if arg1 >= 100000 {
        return arg1 / 100000
    }
    byte_offset / 4
}

fn resolve_gc_struct_type_idx(inst: MirInst, ctx: SelfEmitCtx, prev_op: i32, prev_arg0: i32, byte_offset: i32, size_hint: i32) -> i32 {
    let struct_name = inst_accessors_literals::MirInst_str_val(inst)
    if len(struct_name) > 0 && ctx_gc_type::SelfEmitCtx_has_struct_type(ctx, clone(struct_name)) {
        return ctx_gc_type::SelfEmitCtx_struct_type_by_name(ctx, clone(struct_name))
    }
    let mut base_local = inst_accessors_operands::MirInst_arg0(inst)
    if base_local < 0 && prev_arg0 >= 0 && (prev_op == mir::opcodes::MIR_LOCAL_GET() || prev_op == mir::opcodes::MIR_STRUCT_SET()) {
        base_local = prev_arg0
    }
    if base_local >= 0 {
        let spine_gc = ctx_gc_layout_lookup::SelfEmitCtx_wasm_ref_type_idx_for_local(ctx, base_local)
        if spine_gc >= 0 {
            return spine_gc
        }
        let func_idx = ctx_record::SelfEmitCtx_current_func_idx(ctx)
        let f = ctx_record::SelfEmitCtx_function_at(ctx, func_idx)
        let inferred = code_ref_locals::infer_ref_local_gc_type(f, base_local, ctx)
        if inferred >= 0 {
            return inferred
        }
    }
    let size_hint_val = size_hint
    let struct_size_est = if size_hint_val >= 100000 {
        size_hint_val % 100000
    } else if size_hint_val > 0 {
        size_hint_val
    } else {
        byte_offset + 4
    }
    ctx_gc_type::SelfEmitCtx_struct_type(ctx, struct_size_est)
}
