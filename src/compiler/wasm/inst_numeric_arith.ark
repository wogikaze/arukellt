// Arukellt Selfhost - Wasm Binary Emitter: numeric arithmetic instruction handlers.

use mir::inst_accessors_shape
use mir::value_types
use wasm::ctx_record
use wasm::emit_target
use wasm::intrinsic_string_basic
use wasm::opcodes
use wasm::writer_core

fn emit_add(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let val_type = inst_accessors_shape::MirInst_val_type(inst)
    if val_type == value_types::VT_F64() {
        writer_core::emit_byte(w, opcodes::OP_F64_ADD())
    } else {
        if val_type == value_types::VT_F32() {
            writer_core::emit_byte(w, opcodes::OP_F32_ADD())
        } else {
            if val_type == value_types::VT_I64() {
                writer_core::emit_byte(w, opcodes::OP_I64_ADD())
            } else {
                if val_type == value_types::VT_REF() && emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
                    intrinsic_string_basic::emit_concat(w, inst, ctx)
                } else {
                    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
                }
            }
        }
    }
}

fn emit_sub(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let val_type = inst_accessors_shape::MirInst_val_type(inst)
    if val_type == value_types::VT_F64() {
        writer_core::emit_byte(w, opcodes::OP_F64_SUB())
    } else {
        if val_type == value_types::VT_F32() {
            writer_core::emit_byte(w, opcodes::OP_F32_SUB())
        } else {
            if val_type == value_types::VT_I64() {
                writer_core::emit_byte(w, opcodes::OP_I64_SUB())
            } else {
                writer_core::emit_byte(w, opcodes::OP_I32_SUB())
            }
        }
    }
}

fn emit_mul(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let val_type = inst_accessors_shape::MirInst_val_type(inst)
    if val_type == value_types::VT_F64() {
        writer_core::emit_byte(w, opcodes::OP_F64_MUL())
    } else {
        if val_type == value_types::VT_F32() {
            writer_core::emit_byte(w, opcodes::OP_F32_MUL())
        } else {
            if val_type == value_types::VT_I64() {
                writer_core::emit_byte(w, opcodes::OP_I64_MUL())
            } else {
                writer_core::emit_byte(w, opcodes::OP_I32_MUL())
            }
        }
    }
}

fn emit_div(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let val_type = inst_accessors_shape::MirInst_val_type(inst)
    if val_type == value_types::VT_F64() {
        writer_core::emit_byte(w, opcodes::OP_F64_DIV())
    } else {
        if val_type == value_types::VT_F32() {
            writer_core::emit_byte(w, opcodes::OP_F32_DIV())
        } else {
            if val_type == value_types::VT_I64() {
                writer_core::emit_byte(w, opcodes::OP_I64_DIV_S())
            } else {
                writer_core::emit_byte(w, opcodes::OP_I32_DIV_S())
            }
        }
    }
}

fn emit_mod(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    if inst_accessors_shape::MirInst_val_type(inst) == value_types::VT_I64() {
        writer_core::emit_byte(w, opcodes::OP_I64_REM_S())
    } else {
        writer_core::emit_byte(w, opcodes::OP_I32_REM_S())
    }
}
