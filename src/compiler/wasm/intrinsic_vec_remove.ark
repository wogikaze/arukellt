use wasm::ctx_scratch
use wasm::ctx_record
use wasm::ctx_gc_type
use wasm::emit_target
use wasm::opcodes
use wasm::writer_core
use wasm::writer_gc
use wasm::string_gc_helpers
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_numeric_i32
use wasm::intrinsics::helpers_numeric_i32_convert

// Handler for: remove_i32
fn emit_remove_i32(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        return emit_remove_gc(w, ctx)
    }
    let s_rm_idx = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let s_rm_vec = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_rm_data = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_rm_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_rm_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, s_rm_idx)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, s_rm_vec)
    emit_remove_setup(w, s_rm_idx, s_rm_vec, s_rm_data, s_rm_len, s_rm_i)
    emit_remove_shift_loop(w, s_rm_data, s_rm_len, s_rm_i)
    emit_remove_finish(w, s_rm_vec, s_rm_len)
    return true
}

// GC target: shift elements down from idx to len-1, then decrement len.
fn emit_remove_gc(w: WasmWriter, ctx: SelfEmitCtx) -> bool {
    let s_idx = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let s_vec = ctx_scratch::SelfEmitCtx_scratch_gc_vec_local(ctx, 0)
    let s_arr = ctx_scratch::SelfEmitCtx_scratch_gc_i32_array_local(ctx, 0)
    let s_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let vec_type = ctx_gc_type::SelfEmitCtx_vec_type(ctx)
    let arr_type = ctx_gc_type::SelfEmitCtx_i32_array_type(ctx)
    emit_remove_gc_setup(w, s_idx, s_vec, s_arr, s_len, s_i, vec_type)
    emit_remove_gc_shift_loop(w, s_arr, s_len, s_i, arr_type)
    emit_remove_gc_finish(w, s_vec, s_len, vec_type)
    return true
}

fn emit_remove_gc_setup(w: WasmWriter, s_idx: i32, s_vec: i32, s_arr: i32, s_len: i32, s_i: i32, vec_type: i32) {
    // Stack: [vec_ref, idx] — pop idx, then vec
    helpers_core::emit_local_set(w, s_idx)
    helpers_core::emit_local_set(w, s_vec)
    // arr = vec.data, len = vec.len
    helpers_core::emit_local_get(w, s_vec)
    writer_gc::emit_gc_ref_cast(w, vec_type)
    writer_gc::emit_gc_struct_get(w, vec_type, 0)
    helpers_core::emit_local_set(w, s_arr)
    helpers_core::emit_local_get(w, s_vec)
    writer_gc::emit_gc_ref_cast(w, vec_type)
    writer_gc::emit_gc_struct_get_i32(w, vec_type, 1)
    helpers_core::emit_local_set(w, s_len)
    // i = idx
    helpers_core::emit_local_get(w, s_idx)
    helpers_core::emit_local_set(w, s_i)
}

fn emit_remove_gc_shift_loop(w: WasmWriter, s_arr: i32, s_len: i32, s_i: i32, arr_type: i32) {
    // loop: while i < len-1: arr[i] = arr[i+1]; i++
    string_gc_helpers::emit_gc_block_loop(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_core::emit_local_get(w, s_len)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_sub(w)
    string_gc_helpers::emit_gc_i32_ge_s(w)
    string_gc_helpers::emit_gc_br_if(w, 1)
    // arr[i] = arr[i+1]
    helpers_core::emit_local_get(w, s_arr)
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32_convert::emit_narrow_i64_operand(w)
    helpers_core::emit_local_get(w, s_arr)
    helpers_core::emit_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    writer_gc::emit_gc_array_get(w, arr_type)
    writer_gc::emit_gc_array_set(w, arr_type)
    // i = i + 1
    helpers_core::emit_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_br(w, 0)
    string_gc_helpers::emit_gc_block_loop_end(w)
}

fn emit_remove_gc_finish(w: WasmWriter, s_vec: i32, s_len: i32, vec_type: i32) {
    // vec.len = len - 1
    helpers_core::emit_local_get(w, s_vec)
    writer_gc::emit_gc_ref_cast(w, vec_type)
    helpers_core::emit_local_get(w, s_len)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_sub(w)
    writer_gc::emit_gc_struct_set_i32(w, vec_type, 1)
    // push vec ref back
    helpers_core::emit_local_get(w, s_vec)
}

fn emit_remove_setup(w: WasmWriter, s_rm_idx: i32, s_rm_vec: i32, s_rm_data: i32, s_rm_len: i32, s_rm_i: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_vec)
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, s_rm_len)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_vec)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 8)
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, s_rm_data)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_idx)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, s_rm_i)
}

fn emit_remove_shift_loop(w: WasmWriter, s_rm_data: i32, s_rm_len: i32, s_rm_i: i32) {
    writer_core::emit_byte(w, opcodes::OP_BLOCK())
    writer_core::emit_byte(w, 64)
    writer_core::emit_byte(w, opcodes::OP_LOOP())
    writer_core::emit_byte(w, 64)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_i)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_len)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 1)
    writer_core::emit_byte(w, opcodes::OP_I32_SUB())
    writer_core::emit_byte(w, opcodes::OP_I32_GE_S())
    writer_core::emit_byte(w, opcodes::OP_BR_IF())
    writer_core::emit_leb128_u(w, 1)
    emit_remove_shift_one(w, s_rm_data, s_rm_i)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_i)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 1)
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, s_rm_i)
    writer_core::emit_byte(w, opcodes::OP_BR())
    writer_core::emit_leb128_u(w, 0)
    writer_core::emit_byte(w, 11)
    writer_core::emit_byte(w, 11)
}

fn emit_remove_shift_one(w: WasmWriter, s_rm_data: i32, s_rm_i: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_data)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_i)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 4)
    writer_core::emit_byte(w, opcodes::OP_I32_MUL())
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_data)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_i)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 1)
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 4)
    writer_core::emit_byte(w, opcodes::OP_I32_MUL())
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_I32_STORE())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
}

fn emit_remove_finish(w: WasmWriter, s_rm_vec: i32, s_rm_len: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_vec)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_len)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 1)
    writer_core::emit_byte(w, opcodes::OP_I32_SUB())
    writer_core::emit_byte(w, opcodes::OP_I32_STORE())
    writer_core::emit_byte(w, 2)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, s_rm_vec)
}
