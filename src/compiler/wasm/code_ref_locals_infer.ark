// Arukellt Selfhost - GC reference local type inference helpers.

use mir::block_inst_access
use mir::inst_record
use mir::inst_accessors_operands
use mir::inst_accessors_shape
use mir::function_param_view
use mir::function_locals_view
use mir::local_access
use mir::opcodes
use wasm::code_ref_locals_scan
use wasm::code_ref_locals_typename
use wasm::code_ref_locals_infer_dest

fn infer_ref_local_gc_type_depth(f: MirFunction, local_idx: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    if depth > 3 {
        return 0 - 1
    }
    // Check the local's own type_name first — if it maps to a known GC ref
    // type, use that directly. This handles cases where a local is traced
    // from another local's inference and has a type_name like "string",
    // "vec:i32", "hashmap:...", "Option_...", "Result_...", etc.
    if local_idx >= 0 && local_idx < function_locals_view::MirFunction_local_count(f) {
        let loc = function_locals_view::MirFunction_local_at(f, local_idx)
        let type_name = local_access::MirLocal_type_name(loc)
        if len(type_name) > 0 {
            let gc_type = code_ref_locals_typename::infer_gc_type_from_type_name(clone(type_name), ctx)
            if gc_type >= 0 {
                // Only use type_name if the local is actually assigned a ref
                // value. Locals can be reused for i32 in other code paths, and
                // the type_name may be sticky from a prior usage. At depth 0
                // (the initial inference call), verify there is evidence of a
                // ref assignment before trusting the type_name.
                if depth == 0 && !code_ref_locals_scan::local_has_any_ref_assignment(f, local_idx) {
                    // Skip type_name — try assignment tracing instead
                } else {
                    return gc_type
                }
            }
        }
    }
    // If the local is a function parameter, infer GC type from its type name.
    let param_count = function_param_view::MirFunction_param_count(f)
    if local_idx >= 0 && local_idx < param_count {
        let param_type_name = function_param_view::MirFunction_param_type_name(f, local_idx)
        let param_gc_type = code_ref_locals_typename::infer_gc_type_from_type_name(param_type_name, ctx)
        if param_gc_type >= 0 {
            return param_gc_type
        }
    }
    let block_count = len(f.blocks)
    let mut bi = 0
    while bi < block_count {
        let block = get_unchecked(f.blocks, bi)
        let inst_count = block_inst_access::MirBlock_inst_count(block)
        let found = infer_ref_local_from_block(f, block, inst_count, local_idx, ctx, depth)
        if found >= 0 {
            return found
        }
        bi = bi + 1
    }
    0 - 1
}

// Infer the GC type of an instruction that assigns to a destination local.
// Traces LOCAL_GET sources recursively, then delegates producer inspection.
fn infer_ref_local_from_dest_match(f: MirFunction, inst: MirInst, op: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    if op == opcodes::MIR_LOCAL_GET() {
        let src = inst_accessors_operands::MirInst_arg0(inst)
        if src >= 0 {
            return infer_ref_local_gc_type_depth(f, src, ctx, depth + 1)
        }
    }
    code_ref_locals_infer_dest::infer_ref_local_from_producer(f, inst, op, ctx)
}

fn infer_ref_local_from_block(f: MirFunction, block: MirBlock, inst_count: i32, local_idx: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    let mut ii = 0
    let mut prev_op = 0 - 1
    let mut prev_arg0 = 0 - 1
    let mut prev_dest = 0 - 1
    while ii < inst_count {
        let inst = block_inst_access::MirBlock_inst_at(block, ii)
        let op = inst_accessors_shape::MirInst_op(inst)
        let dest = inst_accessors_operands::MirInst_dest(inst)
        let arg0 = inst_accessors_operands::MirInst_arg0(inst)
        if dest == local_idx {
            let matched = infer_ref_local_from_dest_match(f, inst, op, ctx, depth)
            if matched >= 0 {
                return matched
            }
        }
        if op == opcodes::MIR_LOCAL_SET() && inst_accessors_operands::MirInst_arg0(inst) == local_idx {
            let source = inst_accessors_operands::MirInst_arg1(inst)
            if source >= 0 {
                let inferred = infer_ref_local_gc_type_depth(f, source, ctx, depth + 1)
                if inferred >= 0 {
                    return inferred
                }
            }
            let stacked = infer_ref_local_from_stack_set(f, block, inst_count, ii, prev_op, prev_arg0, prev_dest, ctx, depth)
            if stacked >= 0 {
                return stacked
            }
        }
        prev_op = op
        prev_arg0 = arg0
        prev_dest = dest
        ii = ii + 1
    }
    0 - 1
}

// Stack-based LOCAL_SET (arg1 < 0): the value was pushed by a previous
// instruction.  First check the immediately preceding instruction (fast path
// for the common LOCAL_GET + LOCAL_SET and producer + LOCAL_SET patterns),
// then scan backwards for the actual stack value producer.
fn infer_ref_local_from_stack_set(f: MirFunction, block: MirBlock, inst_count: i32, ii: i32, prev_op: i32, prev_arg0: i32, prev_dest: i32, ctx: SelfEmitCtx, depth: i32) -> i32 {
    if prev_op == opcodes::MIR_LOCAL_GET() && prev_arg0 >= 0 {
        let inferred = infer_ref_local_gc_type_depth(f, prev_arg0, ctx, depth + 1)
        if inferred >= 0 {
            return inferred
        }
    }
    if prev_dest >= 0 {
        let inferred = infer_ref_local_gc_type_depth(f, prev_dest, ctx, depth + 1)
        if inferred >= 0 {
            return inferred
        }
    }
    // If the fast path failed (e.g. the previous instruction was
    // another stack-based LOCAL_SET), scan backwards to find the
    // instruction that actually produced the value on top of the
    // stack.  This handles consecutive stack-based LOCAL_SETs:
    //   local.get 2   (push ref)
    //   local.get 4   (push i32)
    //   local.set 16  (pop i32)
    //   local.set 17  (pop ref)  ← needs to skip local.set 16
    let src_ii = find_stack_value_source(block, inst_count, ii)
    if src_ii >= 0 {
        let src_inst = block_inst_access::MirBlock_inst_at(block, src_ii)
        let src_op = inst_accessors_shape::MirInst_op(src_inst)
        let src_arg0 = inst_accessors_operands::MirInst_arg0(src_inst)
        let src_dest = inst_accessors_operands::MirInst_dest(src_inst)
        if src_op == opcodes::MIR_LOCAL_GET() && src_arg0 >= 0 {
            let inferred = infer_ref_local_gc_type_depth(f, src_arg0, ctx, depth + 1)
            if inferred >= 0 {
                return inferred
            }
        }
        if src_dest >= 0 {
            let inferred = infer_ref_local_gc_type_depth(f, src_dest, ctx, depth + 1)
            if inferred >= 0 {
                return inferred
            }
        }
        let inferred = infer_ref_local_from_dest_match(f, src_inst, src_op, ctx, depth)
        if inferred >= 0 {
            return inferred
        }
    }
    0 - 1
}

// Scan backwards from set_ii-1 to find the instruction that produced the
// value consumed by a stack-based LOCAL_SET at position set_ii.
// Tracks a "needed" counter: each stack-based LOCAL_SET or DROP increments
// it (they consume a value), each value-producing instruction decrements it.
// When "needed" reaches 0, we found the producer.
// Returns the instruction index, or -1 if not found.
fn find_stack_value_source(block: MirBlock, inst_count: i32, set_ii: i32) -> i32 {
    let mut needed = 1
    let mut ii = set_ii - 1
    let mut steps = 0
    let max_steps = 128
    while ii >= 0 && steps < max_steps {
        let inst = block_inst_access::MirBlock_inst_at(block, ii)
        let op = inst_accessors_shape::MirInst_op(inst)
        let arg1 = inst_accessors_operands::MirInst_arg1(inst)
        if op == opcodes::MIR_LOCAL_SET() && arg1 < 0 {
            needed = needed + 1
        } else if op == opcodes::MIR_DROP() {
            needed = needed + 1
        } else if is_stack_value_producing_op(op) {
            needed = needed - 1
            if needed == 0 {
                return ii
            }
        }
        ii = ii - 1
        steps = steps + 1
    }
    0 - 1
}

// Check if an opcode produces a value on the stack (or via TEE).
// Excludes LOCAL_SET and DROP (which consume rather than produce).
fn is_stack_value_producing_op(op: i32) -> bool {
    if op == opcodes::MIR_CONST_I32() || op == opcodes::MIR_CONST_I64() || op == opcodes::MIR_CONST_F64() || op == opcodes::MIR_CONST_STRING() || op == opcodes::MIR_CONST_BOOL() {
        return true
    }
    if op == opcodes::MIR_LOCAL_GET() {
        return true
    }
    if op == opcodes::MIR_CALL() || op == opcodes::MIR_WIT_CALL() {
        return true
    }
    if op == opcodes::MIR_STRUCT_NEW() || op == opcodes::MIR_STRUCT_GET() || op == opcodes::MIR_ARRAY_NEW() || op == opcodes::MIR_ARRAY_GET() || op == opcodes::MIR_ARRAY_LEN() {
        return true
    }
    if op == opcodes::MIR_GC_STRUCT_NEW() || op == opcodes::MIR_GC_STRUCT_GET() {
        return true
    }
    if op == opcodes::MIR_REF_CAST() || op == opcodes::MIR_REF_TEST() || op == opcodes::MIR_REF_FUNC() {
        return true
    }
    if op == opcodes::MIR_NEG() || op == opcodes::MIR_NOT() || op == opcodes::MIR_EQZ() {
        return true
    }
    if op == opcodes::MIR_EXTEND_I32_TO_I64() || op == opcodes::MIR_TRUNC_I64_TO_I32() {
        return true
    }
    if opcodes::is_arith_opcode(op) {
        return true
    }
    false
}
