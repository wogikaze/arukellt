use wasm::intrinsic_string_access
use wasm::inst_store
use wasm::intrinsic_string_contains_bytes
use wasm::intrinsic_string_trim
use wasm::intrinsic_string_basic
use wasm::intrinsic_string_from_bytes
use wasm::intrinsic_string_format
use wasm::intrinsic_math
use wasm::intrinsic_string_pad
fn try_emit_text_core_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_basic_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_pad_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_access_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_access_trim_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_search_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_measure_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_chars_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_access_chars_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_char_at(){
        let _result_on_stack = intrinsic_string_access::emit_char_at(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_access_measure_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_is_empty(){
        let _result_on_stack = intrinsic_string_access::emit_text_is_empty(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_len_bytes(){
        let _result_on_stack = intrinsic_string_access::emit_text_len_bytes(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_access_search_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_contains(){
        let _result_on_stack = intrinsic_string_contains_bytes::emit_contains(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_access_trim_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_trim_start(){
        let _result_on_stack = intrinsic_string_trim::emit_trim_start(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_trim_end(){
        let _result_on_stack = intrinsic_string_trim::emit_trim_end(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_basic_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_construct_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_measure_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_compare_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_compare_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_string_eq() {
        let _result_on_stack = intrinsic_math::emit_string_eq_intrinsic(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_concat(){
        let _result_on_stack = intrinsic_string_basic::emit_concat(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_construct_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_raw_string_new(){
        let _result_on_stack = intrinsic_string_format::emit_String_new(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_raw_string_clone(){
        let _result_on_stack = intrinsic_string_basic::emit_clone(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_raw_string_from_bytes(){
        let _result_on_stack = intrinsic_string_from_bytes::emit_string_from_bytes(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_clone(){
        let _result_on_stack = intrinsic_string_basic::emit_clone(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }

    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_format_bool(){
        let _result_on_stack = intrinsic_string_basic::emit_bool_to_string(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_string_from_bytes(){
        let _result_on_stack = intrinsic_string_from_bytes::emit_string_from_bytes(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_measure_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_raw_string_byte_at_unchecked(){
        let _result_on_stack = intrinsic_string_access::emit_char_at(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_raw_string_len_bytes(){
        let _result_on_stack = intrinsic_string_basic::emit_len(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_len(){
        let _result_on_stack = intrinsic_string_basic::emit_len(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_pad_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_pad_left(){
        let _result_on_stack = intrinsic_string_pad::emit_pad_left(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_pad_right(){
        let _result_on_stack = intrinsic_string_pad::emit_pad_right(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn finish_text_call(w: WasmWriter, inst: MirInst, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, result_on_stack: bool) -> bool {
    inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, result_on_stack)
    true
}
