use mir::inst_accessors_operands
use wasm::intrinsic_string_access
use wasm::inst_store
use wasm::intrinsic_string_contains_bytes
use wasm::intrinsic_string_trim
use wasm::intrinsic_string_basic
use wasm::intrinsic_string_from_bytes
use wasm::intrinsic_math
use wasm::intrinsic_string_pad
use wasm::writer_core
use wasm::opcodes
use mir::opcodes as mir_opcodes

fn try_emit_text_core_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_basic_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_pad_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_access_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_access_trim_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_search_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_measure_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_access_chars_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_access_chars_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "char_at") {
        let _result_on_stack = intrinsic_string_access::emit_char_at(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_access_measure_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "text::is_empty") {
        let _result_on_stack = intrinsic_string_access::emit_text_is_empty(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if eq(clone(callee), "text::len_bytes") {
        let _result_on_stack = intrinsic_string_access::emit_text_len_bytes(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_access_search_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "text::contains") || eq(clone(callee), "contains") {
        let _result_on_stack = intrinsic_string_contains_bytes::emit_contains(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_access_trim_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "trim_start") || eq(clone(callee), "text::trim_start") {
        let _result_on_stack = intrinsic_string_trim::emit_trim_start(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if eq(clone(callee), "trim_end") || eq(clone(callee), "text::trim_end") {
        let _result_on_stack = intrinsic_string_trim::emit_trim_end(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_basic_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_construct_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_measure_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_compare_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn is_eq_callee_name(callee: String) -> bool {
    if len(callee) != 2 {
        return false
    }
    char_at(clone(callee), 0) == 101 && char_at(clone(callee), 1) == 113
}

// normalize_callee_name maps __intrinsic_string_eq -> string_eq; route both to the inline emitter.
fn is_string_eq_callee_name(callee: String) -> bool {
    if is_eq_callee_name(clone(callee)) {
        return true
    }
    eq(clone(callee), String_from("string_eq"))
}

fn try_emit_text_compare_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if is_string_eq_callee_name(clone(callee)) {
        let _result_on_stack = intrinsic_math::emit_string_eq_intrinsic(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if eq(clone(callee), "concat") || eq(clone(callee), "text::concat") || eq(clone(callee), "text::builder_append") || eq(clone(callee), "std::text::builder_append") {
        let _result_on_stack = intrinsic_string_basic::emit_concat(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_construct_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "String_from") || eq(clone(callee), "clone") {
        let _result_on_stack = intrinsic_string_basic::emit_clone(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }

    if eq(clone(callee), "bool_to_string") || eq(clone(callee), "text::format_bool") || eq(clone(callee), "convert::bool_to_string") || eq(clone(callee), "__intrinsic_bool_to_string") {
        let _result_on_stack = intrinsic_string_basic::emit_bool_to_string(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if eq(clone(callee), "string_from_bytes") || eq(clone(callee), "__intrinsic_string_from_bytes") {
        let _result_on_stack = intrinsic_string_from_bytes::emit_string_from_bytes(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_measure_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "len") {
        let _result_on_stack = intrinsic_string_basic::emit_len(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_pad_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "pad_left") || eq(clone(callee), "text::pad_left") {
        let _result_on_stack = intrinsic_string_pad::emit_pad_left(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if eq(clone(callee), "pad_right") || eq(clone(callee), "text::pad_right") {
        let _result_on_stack = intrinsic_string_pad::emit_pad_right(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn finish_text_call(w: WasmWriter, inst: MirInst, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, result_on_stack: bool) -> bool {
    if result_on_stack && inst_accessors_operands::MirInst_dest(inst) >= 0 && should_force_text_call_dest_store(next_op, next_arg0) {
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_core::emit_leb128_u(w, inst_accessors_operands::MirInst_dest(inst))
    } else {
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, result_on_stack)
    }
    true
}

fn should_force_text_call_dest_store(next_op: i32, next_arg0: i32) -> bool {
    if next_op == mir_opcodes::MIR_CALL() && next_arg0 >= 0 {
        return true
    }
    if next_op == mir_opcodes::MIR_WIT_CALL() && next_arg0 >= 0 {
        return true
    }
    false
}
