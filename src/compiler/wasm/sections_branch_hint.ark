// Arukellt Selfhost - metadata.code.branch_hint custom section (#064).

use wasm::opcodes
use wasm::writer_core
use wasm::writer_sections
use wasm::writer_string

fn emit_branch_hint_custom_section(out: WasmWriter) {
    let payload = writer_core::WasmWriter_new()
    writer_string::emit_string(payload, String_from("metadata.code.branch_hint"))
    writer_core::emit_leb128_u(payload, 0)
    writer_sections::emit_section(out, opcodes::SEC_CUSTOM(), payload)
}
