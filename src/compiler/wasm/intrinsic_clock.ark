use wasm::constants
use wasm::ctx_record
use wasm::emit_target
use wasm::intrinsics::helpers_clock_p2
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_numeric_i32
use wasm::intrinsics::helpers_numeric_i64_arith
use wasm::opcodes
use wasm::writer_core

fn emit_clock_now(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_p2_wasi(ctx_record::SelfEmitCtx_wasi_version(ctx)) {
        helpers_core::emit_call(w, constants::P2_IMPORT_MONOTONIC_NOW())
        return true
    }
    emit_clock_time_get(w, 1)
    emit_clock_load_i64_result(w)
    return true
}

fn emit_clock_now_ms(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_p2_wasi(ctx_record::SelfEmitCtx_wasi_version(ctx)) {
        helpers_core::emit_call(w, constants::P2_IMPORT_WALL_NOW())
        helpers_clock_p2::emit_wall_datetime_to_ms(w, ctx)
        return true
    }
    emit_clock_time_get(w, 0)
    emit_clock_load_i64_result(w)
    let million: i64 = 1000000
    emit_i64_const_value(w, million)
    helpers_numeric_i64_arith::emit_i64_div_u(w)
    return true
}

fn emit_clock_time_get(w: WasmWriter, clock_id: i32) {
    helpers_numeric_i32::emit_i32_const(w, clock_id)
    let zero: i64 = 0
    emit_i64_const_value(w, zero)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_CLOCK_RESULT())
    helpers_core::emit_call(w, constants::WASI_IMPORT_CLOCK_TIME_GET())
    helpers_core::emit_drop(w)
}

fn emit_clock_load_i64_result(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_CLOCK_RESULT())
    writer_core::emit_byte(w, opcodes::OP_I64_LOAD())
    writer_core::emit_byte(w, 2)
    writer_core::emit_leb128_u(w, 0)
}

fn emit_i64_const_value(w: WasmWriter, value: i64) {
    writer_core::emit_byte(w, opcodes::OP_I64_CONST())
    writer_core::emit_leb128_s_i64(w, value)
}
