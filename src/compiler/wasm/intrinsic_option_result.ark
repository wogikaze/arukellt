// Arukellt Selfhost - Option and Result intrinsic facade.

use mir::inst_accessors_operands
use wasm::ctx_record
use wasm::ctx_scratch
use wasm::ctx_gc_type
use wasm::emit_target
use wasm::intrinsics::helpers_control
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32
use wasm::writer_gc

// Find an enum variant type that has a payload field (field 1) with i32 type.
// The enum open type only has field 0 (discriminant), so accessing field 1
// requires casting to a variant type that has the payload field.
// We search the variant names for "Some" or "Ok" (the payload variants).
fn find_payload_variant_type(ctx: SelfEmitCtx) -> i32 {
    let names = ctx_record::SelfEmitCtx_gc_enum_variant_names(ctx)
    let type_map = ctx_record::SelfEmitCtx_gc_enum_variant_type_map(ctx)
    let count = len(names)
    let mut i = 0
    while i < count {
        let name = clone(get_unchecked(names, i))
        // Look for "Some" or "Ok" variants (payload variants with i32 field 1)
        if contains(name, String_from("Some")) || contains(name, String_from("Ok")) {
            if i < len(type_map) {
                let variant_type = get_unchecked(type_map, i)
                let enum_open = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
                if variant_type != enum_open {
                    return variant_type
                }
            }
        }
        i = i + 1
    }
    0 - 1
}

// Handler for: unwrap
fn emit_unwrap_l4771(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    emit_unwrap_payload(w, inst, ctx)
}

// Handler for: unwrap_or
fn emit_unwrap_or_l4779(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    emit_unwrap_or_result(w, inst, ctx)
}

// Handler for: is_some, is_ok
fn emit_is_ok(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let enum_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
        writer_gc::emit_gc_struct_get(w, enum_type, 0)
        helpers_numeric_i32::emit_i32_eqz(w)
        return true
    }
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_eqz(w)
    return true
}

// Handler for: is_none, is_err
fn emit_is_err(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let enum_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
        writer_gc::emit_gc_struct_get(w, enum_type, 0)
        return true
    }
    helpers_memory::emit_i32_load_default(w)
    return true
}

// Handler for: unwrap
fn emit_unwrap_l4827(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    emit_unwrap_payload(w, inst, ctx)
}

// Handler for: unwrap_or
fn emit_unwrap_or_l4835(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    emit_unwrap_or_option(w, inst, ctx)
}

// Handler for: is_some
fn emit_is_some(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let enum_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
        writer_gc::emit_gc_struct_get(w, enum_type, 0)
        helpers_numeric_i32::emit_i32_eqz(w)
        return true
    }
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_eqz(w)
    return true
}

// Handler for: is_none
fn emit_is_none(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let enum_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
        writer_gc::emit_gc_struct_get(w, enum_type, 0)
        helpers_numeric_i32::emit_i32_const(w, 0)
        helpers_numeric_i32::emit_i32_ne(w)
        return true
    }
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_const(w, 0)
    helpers_numeric_i32::emit_i32_ne(w)
    return true
}

fn emit_unwrap_payload(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let variant_type = find_payload_variant_type(ctx)
        if variant_type >= 0 {
            writer_gc::emit_gc_ref_cast(w, variant_type)
            writer_gc::emit_gc_struct_get(w, variant_type, 1)
        } else {
            let enum_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
            writer_gc::emit_gc_struct_get(w, enum_type, 1)
        }
        return true
    }
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_load_default(w)
    return true
}

fn emit_unwrap_or_result(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s_def = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let mut s_opt = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        s_opt = ctx_scratch::SelfEmitCtx_scratch_gc_enum_local(ctx, 0)
    }
    emit_unwrap_or_with_locals(w, s_opt, s_def, ctx)
    return true
}

fn emit_unwrap_or_option(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let mut s_opt = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let s_def = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        s_opt = ctx_scratch::SelfEmitCtx_scratch_gc_enum_local(ctx, 0)
    }
    emit_unwrap_or_with_locals(w, s_opt, s_def, ctx)
    return true
}

fn emit_unwrap_or_with_locals(w: WasmWriter, s_opt: i32, s_def: i32, ctx: SelfEmitCtx) {
    helpers_core::emit_local_set(w, s_def)
    helpers_core::emit_local_set(w, s_opt)
    helpers_core::emit_local_get(w, s_opt)
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let enum_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
        writer_gc::emit_gc_struct_get(w, enum_type, 0)
        helpers_numeric_i32::emit_i32_eqz(w)
        helpers_control::emit_if_i32(w)
        helpers_core::emit_local_get(w, s_opt)
        let variant_type = find_payload_variant_type(ctx)
        if variant_type >= 0 {
            writer_gc::emit_gc_ref_cast(w, variant_type)
            writer_gc::emit_gc_struct_get(w, variant_type, 1)
        } else {
            writer_gc::emit_gc_struct_get(w, enum_type, 1)
        }
        helpers_control::emit_else(w)
        helpers_core::emit_local_get(w, s_def)
        helpers_control::emit_end(w)
        return
    }
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_eqz(w)
    helpers_control::emit_if_i32(w)
    helpers_core::emit_local_get(w, s_opt)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_load_default(w)
    helpers_control::emit_else(w)
    helpers_core::emit_local_get(w, s_def)
    helpers_control::emit_end(w)
}
