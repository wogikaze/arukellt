// Arukellt Wasm - SIMD extended opcode constants (comparison, min/max, rounding, shift, all_true, narrow, extadd, extend, conversion).

// SIMD comparison - i8x16 (le_s/le_u/ge_s/ge_u conflict with v128 eq/ne/lt/le, skipped)
pub fn SIMD_I8X16_EQ() -> i32 { 0x23 }
pub fn SIMD_I8X16_NE() -> i32 { 0x24 }
pub fn SIMD_I8X16_LT_S() -> i32 { 0x25 }
pub fn SIMD_I8X16_LT_U() -> i32 { 0x26 }
pub fn SIMD_I8X16_GT_S() -> i32 { 0x27 }
pub fn SIMD_I8X16_GT_U() -> i32 { 0x28 }

// SIMD comparison - i16x8 (eq through ge_s conflict with v128 gt/ge/not/and/andnot/or/xor/bitselect/any_true, skipped)
pub fn SIMD_I16X8_GE_U() -> i32 { 0x36 }

// SIMD comparison - i32x4
pub fn SIMD_I32X4_EQ() -> i32 { 0x37 }
pub fn SIMD_I32X4_NE() -> i32 { 0x38 }
pub fn SIMD_I32X4_LT_S() -> i32 { 0x39 }
pub fn SIMD_I32X4_LT_U() -> i32 { 0x3a }
pub fn SIMD_I32X4_GT_S() -> i32 { 0x3b }
pub fn SIMD_I32X4_GT_U() -> i32 { 0x3c }
pub fn SIMD_I32X4_LE_S() -> i32 { 0x3d }
pub fn SIMD_I32X4_LE_U() -> i32 { 0x3e }
pub fn SIMD_I32X4_GE_S() -> i32 { 0x3f }
pub fn SIMD_I32X4_GE_U() -> i32 { 0x40 }

// SIMD comparison - f32x4
pub fn SIMD_F32X4_EQ() -> i32 { 0x41 }
pub fn SIMD_F32X4_NE() -> i32 { 0x42 }
pub fn SIMD_F32X4_LT() -> i32 { 0x43 }
pub fn SIMD_F32X4_GT() -> i32 { 0x44 }
pub fn SIMD_F32X4_LE() -> i32 { 0x45 }
pub fn SIMD_F32X4_GE() -> i32 { 0x46 }

// SIMD comparison - f64x2
pub fn SIMD_F64X2_EQ() -> i32 { 0x47 }
pub fn SIMD_F64X2_NE() -> i32 { 0x48 }
pub fn SIMD_F64X2_LT() -> i32 { 0x49 }
pub fn SIMD_F64X2_GT() -> i32 { 0x4a }
pub fn SIMD_F64X2_LE() -> i32 { 0x4b }
pub fn SIMD_F64X2_GE() -> i32 { 0x4c }

// SIMD comparison - i64x2 (gt_s=0xd9 conflicts with i32x4.mul, skipped)
pub fn SIMD_I64X2_EQ() -> i32 { 0xd6 }
pub fn SIMD_I64X2_NE() -> i32 { 0xd7 }
pub fn SIMD_I64X2_LT_S() -> i32 { 0xd8 }
pub fn SIMD_I64X2_LE_S() -> i32 { 0xda }
pub fn SIMD_I64X2_GE_S() -> i32 { 0xdb }

// SIMD min/max - i8x16
pub fn SIMD_I8X16_MIN_S() -> i32 { 0x76 }
pub fn SIMD_I8X16_MIN_U() -> i32 { 0x77 }
pub fn SIMD_I8X16_MAX_S() -> i32 { 0x78 }
pub fn SIMD_I8X16_MAX_U() -> i32 { 0x79 }

// SIMD min/max - i16x8
pub fn SIMD_I16X8_MIN_S() -> i32 { 0x96 }
pub fn SIMD_I16X8_MIN_U() -> i32 { 0x97 }
pub fn SIMD_I16X8_MAX_S() -> i32 { 0x98 }
pub fn SIMD_I16X8_MAX_U() -> i32 { 0x99 }

// SIMD min/max - i32x4 (max_u=0xb9 conflicts with i16x8.mul, skipped)
pub fn SIMD_I32X4_MIN_S() -> i32 { 0xb6 }
pub fn SIMD_I32X4_MIN_U() -> i32 { 0xb7 }
pub fn SIMD_I32X4_MAX_S() -> i32 { 0xb8 }

// SIMD min/max - f32x4
pub fn SIMD_F32X4_MIN() -> i32 { 0xe8 }
pub fn SIMD_F32X4_MAX() -> i32 { 0xe9 }

// SIMD min/max - f64x2 (min=0xf4/max=0xf5 conflict with f64x2.add/sub, skipped)

// SIMD rounding - f32x4
pub fn SIMD_F32X4_CEIL() -> i32 { 0x67 }
pub fn SIMD_F32X4_FLOOR() -> i32 { 0x68 }
pub fn SIMD_F32X4_TRUNC() -> i32 { 0x69 }
pub fn SIMD_F32X4_NEAREST() -> i32 { 0x6a }

// SIMD rounding - f64x2
pub fn SIMD_F64X2_CEIL() -> i32 { 0x74 }
pub fn SIMD_F64X2_FLOOR() -> i32 { 0x75 }
pub fn SIMD_F64X2_TRUNC() -> i32 { 0x7a }
pub fn SIMD_F64X2_NEAREST() -> i32 { 0x94 }

// SIMD shift - i8x16
pub fn SIMD_I8X16_SHL() -> i32 { 0x6b }
pub fn SIMD_I8X16_SHR_S() -> i32 { 0x6c }
pub fn SIMD_I8X16_SHR_U() -> i32 { 0x6d }

// SIMD shift - i16x8
pub fn SIMD_I16X8_SHL() -> i32 { 0x8b }
pub fn SIMD_I16X8_SHR_S() -> i32 { 0x8c }
pub fn SIMD_I16X8_SHR_U() -> i32 { 0x8d }

// SIMD shift - i32x4
pub fn SIMD_I32X4_SHL() -> i32 { 0xab }
pub fn SIMD_I32X4_SHR_S() -> i32 { 0xac }
pub fn SIMD_I32X4_SHR_U() -> i32 { 0xad }

// SIMD shift - i64x2
pub fn SIMD_I64X2_SHL() -> i32 { 0xcb }
pub fn SIMD_I64X2_SHR_S() -> i32 { 0xcc }
pub fn SIMD_I64X2_SHR_U() -> i32 { 0xcd }

// SIMD all_true / bitmask
pub fn SIMD_I8X16_ALL_TRUE() -> i32 { 0x63 }
pub fn SIMD_I8X16_BITMASK() -> i32 { 0x64 }
// i16x8 all_true (0x83) skipped — conflicts with i8x16.sub_sat_u
pub fn SIMD_I16X8_BITMASK() -> i32 { 0x84 }
pub fn SIMD_I32X4_ALL_TRUE() -> i32 { 0xa3 }
pub fn SIMD_I32X4_BITMASK() -> i32 { 0xa4 }
pub fn SIMD_I64X2_ALL_TRUE() -> i32 { 0xc3 }
pub fn SIMD_I64X2_BITMASK() -> i32 { 0xc4 }

// SIMD narrow
pub fn SIMD_I8X16_NARROW_I16X8_S() -> i32 { 0x65 }
pub fn SIMD_I8X16_NARROW_I16X8_U() -> i32 { 0x66 }
pub fn SIMD_I16X8_NARROW_I32X4_S() -> i32 { 0x85 }
pub fn SIMD_I16X8_NARROW_I32X4_U() -> i32 { 0x86 }

// SIMD extadd pairwise
pub fn SIMD_I16X8_EXTADD_PAIRWISE_I8X16_S() -> i32 { 0x7c }
pub fn SIMD_I16X8_EXTADD_PAIRWISE_I8X16_U() -> i32 { 0x7d }

// SIMD extend
pub fn SIMD_I16X8_EXTEND_LOW_I8X16_S() -> i32 { 0x87 }
pub fn SIMD_I16X8_EXTEND_HIGH_I8X16_S() -> i32 { 0x88 }
// i16x8 extend_low_i8x16_u (0x89) skipped — conflicts with i8x16.mul
pub fn SIMD_I16X8_EXTEND_HIGH_I8X16_U() -> i32 { 0x8a }

// SIMD conversion
pub fn SIMD_F64X2_PROMOTE_LOW_F32X4() -> i32 { 0x5f }
pub fn SIMD_F64X2_CONVERT_LOW_I32X4_S() -> i32 { 0xfe }
pub fn SIMD_F64X2_CONVERT_LOW_I32X4_U() -> i32 { 0xff }
