use mir::opcodes
use wasm::call_host_io
use wasm::inst_store
use wasm::intrinsic_assert
use wasm::intrinsic_option_result
use wasm::intrinsics::helpers_core

fn try_emit_option_assert_call(
    w: WasmWriter,
    handler_id: i32,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32
) -> bool {
    if try_emit_option_result_call(w, clone(handler_id), inst, ctx, prev_op, prev_arg0, prev_arg1, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_assert_call(w, clone(handler_id), inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    call_host_io::try_emit_process_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op)
}

fn try_emit_option_result_call(
    w: WasmWriter,
    handler_id: i32,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32
) -> bool {
    if try_emit_option_unwrap_call(w, handler_id, inst, ctx, prev_op, prev_arg0, prev_arg1, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_option_status_call(w, handler_id, inst, ctx, prev_op, prev_arg0, prev_arg1, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

// When Option/Result was just built via GC_STRUCT_SET, the receiver is only
// in a local — not on the stack. Unary calls do not stage args, so reload it
// (same pattern as call_fallback_resolved for user calls) (#726 option_is_*).
fn emit_option_receiver_if_needed(w: WasmWriter, prev_op: i32, prev_arg0: i32, prev_arg1: i32) {
    if prev_op == opcodes::MIR_GC_STRUCT_SET() {
        if prev_arg1 >= 0 {
            helpers_core::emit_local_get(w, prev_arg1)
        }
        return
    }
    if prev_op == opcodes::MIR_STRUCT_SET() {
        if prev_arg0 >= 0 {
            helpers_core::emit_local_get(w, prev_arg0)
        }
    }
}

fn try_emit_option_status_call(
    w: WasmWriter,
    handler_id: i32,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32
) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_is_ok(){
        emit_option_receiver_if_needed(w, prev_op, prev_arg0, prev_arg1)
        let _result_on_stack = intrinsic_option_result::emit_is_ok(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_is_err(){
        emit_option_receiver_if_needed(w, prev_op, prev_arg0, prev_arg1)
        let _result_on_stack = intrinsic_option_result::emit_is_err(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_option_unwrap_call(
    w: WasmWriter,
    handler_id: i32,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32
) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_unwrap(){
        emit_option_receiver_if_needed(w, prev_op, prev_arg0, prev_arg1)
        let _result_on_stack = intrinsic_option_result::emit_unwrap_l4771(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_unwrap_or(){
        emit_option_receiver_if_needed(w, prev_op, prev_arg0, prev_arg1)
        let _result_on_stack = intrinsic_option_result::emit_unwrap_or_l4779(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_assert_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_assert(){
        let _result_on_stack = intrinsic_assert::emit_assert(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_assert_eq(){
        let _result_on_stack = intrinsic_assert::emit_assert_eq(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_assert_eq_i64(){
        let _result_on_stack = intrinsic_assert::emit_assert_eq_i64(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_assert_ne(){
        let _result_on_stack = intrinsic_assert::emit_assert_ne(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_runtime_assert_eq_str(){
        let _result_on_stack = intrinsic_assert::emit_assert_eq_str(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}
