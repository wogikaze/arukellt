// Arukellt Selfhost - Wasm call namespace: call_host_assert

use wasm::call_host_io
use wasm::inst_store
use wasm::intrinsic_assert
use wasm::intrinsic_option_result

// Arukellt Selfhost - Wasm option/result/assert/process host call dispatch facade.

fn try_emit_option_assert_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_option_result_call(w, clone(callee), inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_assert_call(w, clone(callee), inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    call_host_io::try_emit_process_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op)
}

// Arukellt Selfhost - option/result host call dispatch.

fn try_emit_option_result_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_option_unwrap_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_option_status_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

// Arukellt Selfhost - option/result status host call dispatch.

fn try_emit_option_status_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "is_some") || eq(clone(callee), "is_ok") {
        let _result_on_stack = intrinsic_option_result::emit_is_ok(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if eq(clone(callee), "is_none") || eq(clone(callee), "is_err") {
        let _result_on_stack = intrinsic_option_result::emit_is_err(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

// Arukellt Selfhost - option/result unwrap host call dispatch.

fn try_emit_option_unwrap_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "unwrap") {
        let _result_on_stack = intrinsic_option_result::emit_unwrap_l4771(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if eq(clone(callee), "unwrap_or") {
        let _result_on_stack = intrinsic_option_result::emit_unwrap_or_l4779(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_assert_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if eq(clone(callee), "assert") {
        let _result_on_stack = intrinsic_assert::emit_assert(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if eq(clone(callee), "assert_eq") {
        let _result_on_stack = intrinsic_assert::emit_assert_eq(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if eq(clone(callee), "assert_eq_i64") {
        let _result_on_stack = intrinsic_assert::emit_assert_eq_i64(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if eq(clone(callee), "assert_ne") {
        let _result_on_stack = intrinsic_assert::emit_assert_ne(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if eq(clone(callee), "assert_eq_str") {
        let _result_on_stack = intrinsic_assert::emit_assert_eq_str(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}
