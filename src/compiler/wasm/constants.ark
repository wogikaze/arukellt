// Scratch offsets for f64 parsing.
fn SCRATCH_PF_RESULT() -> i32 { 112 }
fn SCRATCH_PF_DIVISOR() -> i32 { 120 }
fn SCRATCH_PF_SAWDOT() -> i32 { 48 }
fn SCRATCH_PF_DECCOUNT() -> i32 { 52 }

// Local result store actions.
fn STORE_ACTION_SKIP() -> i32 { 0 }
fn STORE_ACTION_TEE() -> i32 { 1 }
fn STORE_ACTION_SET() -> i32 { 2 }
