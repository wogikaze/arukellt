    if try_emit_scalar_float_math_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_scalar_i32_math_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_scalar_loop_math_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
