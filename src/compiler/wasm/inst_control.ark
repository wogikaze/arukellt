// Arukellt Selfhost - Wasm Binary Emitter control instruction facade.
//
// Extracted from emitter.ark for module-level organization.

use mir::inst_accessors_literals
use mir::inst_accessors_operands
use wasm::opcodes
use wasm::writer_core
use wasm::writer_leb

fn emit_br(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_BR())
    writer_leb::emit_leb128_u(w, inst_accessors_literals::MirInst_int_val(inst))
}

fn emit_br_if(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_BR_IF())
    writer_leb::emit_leb128_u(w, inst_accessors_literals::MirInst_int_val(inst))
}

fn emit_block(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_BLOCK())
    writer_core::emit_byte(w, 64)
}

fn emit_loop(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_LOOP())
    writer_core::emit_byte(w, 64)
}

fn emit_if(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_IF())
    writer_core::emit_byte(w, 64)
}

fn emit_else(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_ELSE())
}

fn emit_end(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    writer_core::emit_byte(w, opcodes::OP_END())
}

use wasm::opcodes
use wasm::writer_core
use wasm::writer_leb
use wasm::ctx_gc_type

fn emit_br_on_cast(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let type_slot = inst_accessors_operands::MirInst_arg0(inst)
    let to_type_idx = ctx_gc_type::SelfEmitCtx_enum_variant_type(ctx, type_slot)
    let from_type_idx = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
    writer_core::emit_byte(w, opcodes::GC_PREFIX())
    writer_leb::emit_leb128_u(w, opcodes::GC_BR_ON_CAST())
    writer_core::emit_byte(w, 3)
    writer_leb::emit_leb128_u(w, inst_accessors_literals::MirInst_int_val(inst))
    writer_leb::emit_leb128_s(w, from_type_idx)
    writer_leb::emit_leb128_s(w, to_type_idx)
}

fn emit_br_on_cast_fail(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let type_slot = inst_accessors_operands::MirInst_arg0(inst)
    let to_type_idx = ctx_gc_type::SelfEmitCtx_enum_variant_type(ctx, type_slot)
    let from_type_idx = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
    writer_core::emit_byte(w, opcodes::GC_PREFIX())
    writer_leb::emit_leb128_u(w, opcodes::GC_BR_ON_CAST_FAIL())
    writer_core::emit_byte(w, 3)
    writer_leb::emit_leb128_u(w, inst_accessors_literals::MirInst_int_val(inst))
    writer_leb::emit_leb128_s(w, from_type_idx)
    writer_leb::emit_leb128_s(w, to_type_idx)
}
