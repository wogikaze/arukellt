// Arukellt Selfhost - vec allocation/length intrinsic handlers

use mir::inst_accessors_operands
use wasm::inst_ctx
use wasm::intrinsic_vec_new_layout

// Handler for: Vec_new_i64, Vec_new_f64
fn emit_Vec_new_i64(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    intrinsic_vec_new_layout::emit_vec_new_layout(w, 64, 76)
    inst_ctx::ctx_mark_vec_local(ctx, inst_accessors_operands::MirInst_dest(inst))
    return true
}


// Handler for: vec_len
fn emit_vec_len(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
                                                                                                                                                                                                                                                                    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
                                                                                                                                                                                                                                                                    writer_core::emit_byte(w, 2)
                                                                                                                                                                                                                                                                    writer_core::emit_byte(w, 0)
    return true
}
