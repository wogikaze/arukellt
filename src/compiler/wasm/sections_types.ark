use wasm::opcodes
use wasm::constants
// Arukellt Selfhost - Wasm type section builder.

use wasm::writer_core
use wasm::writer_leb
use wasm::writer_sections
use mir::types
use mir::function_return_view
use mir::function_param_view
use mir::local_access
use wasm::sections_type_plan
use wasm::emit_target
use mir::module_wit_imports

struct TypeCanonPlan {
    canon_types: Vec<String>,
    type_map: Vec<i32>,
}

fn emit_type_section(out: WasmWriter, functions: Vec<MirFunction>, fn_count: i32, needs_wrapper: i32, target: String, bindings: Vec<resolver::wit_import_bind::WitImportBinding>) -> TypeSectionPlan {
    let num_host_types = emit_target::host_type_count(clone(target))
    let wit_import_count = module_wit_imports::wit_import_count(bindings)
    let type_sigs = build_type_sigs(functions, fn_count, needs_wrapper, clone(target), bindings)
    let canon_plan = canonicalize_type_sigs(type_sigs)
    let canon_types = TypeCanonPlan_canon_types(canon_plan)
    let type_map = TypeCanonPlan_type_map(canon_plan)
    let type_sec = writer_core::WasmWriter_new()
    writer_leb::emit_leb128_u(type_sec, len(canon_types))
    emit_canon_type_entries(type_sec, canon_types)
    writer_sections::emit_section(out, opcodes::SEC_TYPE(), type_sec)
    sections_type_plan::build_type_section_plan(type_map, num_host_types, wit_import_count, fn_count, needs_wrapper)
}

fn TypeCanonPlan_new(canon_types: Vec<String>, type_map: Vec<i32>) -> TypeCanonPlan {
    TypeCanonPlan { canon_types: canon_types, type_map: type_map }
}

fn TypeCanonPlan_canon_types(plan: TypeCanonPlan) -> Vec<String> {
    plan.canon_types
}

fn TypeCanonPlan_type_map(plan: TypeCanonPlan) -> Vec<i32> {
    plan.type_map
}

fn build_type_sigs(functions: Vec<MirFunction>, fn_count: i32, needs_wrapper: i32, target: String, bindings: Vec<resolver::wit_import_bind::WitImportBinding>) -> Vec<String> {
    let type_sigs = Vec_new_String()
    if emit_target::is_freestanding_target(clone(target)) {
        append_t2_type_sigs(type_sigs)
    } else {
        append_wasi_type_sigs(type_sigs)
    }
    append_wit_type_sigs(type_sigs, bindings)
    append_function_type_sigs(type_sigs, functions, fn_count)
    append_wrapper_type_sig(type_sigs, needs_wrapper)
    type_sigs
}

fn append_wit_type_sigs(type_sigs: Vec<String>, bindings: Vec<resolver::wit_import_bind::WitImportBinding>) {
    let mut i = 0
    while i < module_wit_imports::wit_import_count(bindings) {
        push(type_sigs, module_wit_imports::wit_import_type_sig(bindings, i))
        i = i + 1
    }
}

fn append_wasi_type_sigs(type_sigs: Vec<String>) {
    push(type_sigs, String_from("i32_i32_i32_i32_1i32"))
    push(type_sigs, String_from("i32_i32_1i32"))
    push(type_sigs, String_from("i32_i32_i32_i32_i32_i64_i64_i32_i32_1i32"))
    push(type_sigs, String_from("i32_1i32"))
    push(type_sigs, String_from("i32_0"))
    push(type_sigs, String_from("i32_i64_i32_1i32"))
}

fn append_t2_type_sigs(type_sigs: Vec<String>) {
    push(type_sigs, String_from("i32_i32_0"))
    push(type_sigs, String_from("0"))
    push(type_sigs, String_from("i32_i32_1i32"))
}

fn append_function_type_sigs(type_sigs: Vec<String>, functions: Vec<MirFunction>, fn_count: i32) {
    let mut ui = 0
    while ui < fn_count {
        let uf = get_unchecked(functions, ui)
        push(type_sigs, build_function_type_sig(uf))
        ui = ui + 1
    }
}

fn build_function_type_sig(uf: MirFunction) -> String {
    let mut sig = String_new()
    let pc = function_param_view::MirFunction_param_count(uf)
    let mut pi = 0
    while pi < pc {
        let p = function_param_view::MirFunction_param_at(uf, pi)
        sig = concat(sig, val_type_to_sig(local_access::MirLocal_val_type(p)))
        sig = concat(sig, String_from("_"))
        pi = pi + 1
    }
    let return_type = function_return_view::MirFunction_return_type(uf)
    if return_type == 0 {
        sig = concat(sig, String_from("0"))
    } else {
        sig = concat(sig, String_from("1"))
        sig = concat(sig, val_type_to_sig(return_type))
    }
    sig
}

fn append_wrapper_type_sig(type_sigs: Vec<String>, needs_wrapper: i32) {
    if needs_wrapper == 1 {
        push(type_sigs, String_from("0"))
    }
}

fn canonicalize_type_sigs(type_sigs: Vec<String>) -> TypeCanonPlan {
    let canon_types = Vec_new_String()
    let mut type_map = Vec_new_i32()
    let ts_count = len(type_sigs)
    let mut tsi = 0
    while tsi < ts_count {
        let sig = get_unchecked(type_sigs, tsi)
        let found = find_canon_type_index(canon_types, sig)
        if found >= 0 {
            push(type_map, found)
        } else {
            push(type_map, len(canon_types))
            push(canon_types, sig)
        }
        tsi = tsi + 1
    }
    TypeCanonPlan_new(canon_types, type_map)
}

fn find_canon_type_index(canon_types: Vec<String>, sig: String) -> i32 {
    let mut found = 0 - 1
    let mut cti = 0
    while cti < len(canon_types) {
        if eq(clone(get_unchecked(canon_types, cti)), clone(sig)) {
            found = cti
        }
        cti = cti + 1
    }
    found
}

fn emit_canon_type_entries(type_sec: WasmWriter, canon_types: Vec<String>) {
    let mut cti2 = 0
    while cti2 < len(canon_types) {
        let csig = get_unchecked(canon_types, cti2)
        writer_core::emit_byte(type_sec, 96)
        let param_segments = type_sig_param_segments(csig)
        let result_seg = type_sig_result_segment(csig)
        emit_type_param_entries(type_sec, param_segments)
        emit_type_result_entry(type_sec, result_seg)
        cti2 = cti2 + 1
    }
}

fn emit_type_param_entries(type_sec: WasmWriter, param_segments: Vec<String>) {
    let param_count = len(param_segments)
    writer_leb::emit_leb128_u(type_sec, param_count)
    let mut pi = 0
    while pi < param_count {
        let seg = get_unchecked(param_segments, pi)
        writer_core::emit_byte(type_sec, sig_to_wasm_type(seg))
        pi = pi + 1
    }
}

fn emit_type_result_entry(type_sec: WasmWriter, result_seg: String) {
    if eq(clone(result_seg), "0") {
        writer_leb::emit_leb128_u(type_sec, 0)
    } else {
        // Slice within the result segment itself; the full-signature length
        // overruns substring and collapses the result type to the fallback.
        let rt = substring(result_seg, 1, len(result_seg))
        writer_leb::emit_leb128_u(type_sec, 1)
        writer_core::emit_byte(type_sec, sig_to_wasm_type(rt))
    }
}

fn type_sig_param_segments(csig: String) -> Vec<String> {
    let sig_len = len(csig)
    let mut param_segments = Vec_new_String()
    let mut seg_start = 0
    let mut si = 0
    while si < sig_len {
        if char_at(csig, si) == 95 {
            let seg = substring(csig, seg_start, si)
            push(param_segments, seg)
            seg_start = si + 1
        }
        si = si + 1
    }
    param_segments
}

fn type_sig_result_segment(csig: String) -> String {
    let sig_len = len(csig)
    let mut seg_start = 0
    let mut si = 0
    while si < sig_len {
        if char_at(csig, si) == 95 {
            seg_start = si + 1
        }
        si = si + 1
    }
    substring(csig, seg_start, sig_len)
}

fn val_type_to_sig(vt: i32) -> String {
    if vt == 1 {
        String_from("i32")
    } else {
        if vt == 2 {
            String_from("i64")
        } else {
            if vt == 3 {
                String_from("f64")
            } else {
                String_from("ref")
            }
        }
    }
}

fn sig_to_wasm_type(sig: String) -> i32 {
    if eq(clone(sig), "i32") {
        constants::WASM_I32()
    } else {
        if eq(clone(sig), "i64") {
            constants::WASM_I64()
        } else {
            if eq(clone(sig), "f64") {
                constants::WASM_F64()
            } else {
                constants::WASM_I32()
            }
        }
    }
}
