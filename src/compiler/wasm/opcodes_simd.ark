pub fn SIMD_I16X8_ADD() -> i32 { 0xae }
pub fn SIMD_I16X8_ADD_SAT_S() -> i32 { 0xaf }
pub fn SIMD_I16X8_ADD_SAT_U() -> i32 { 0xb0 }
pub fn SIMD_I16X8_SUB() -> i32 { 0xb1 }
pub fn SIMD_I16X8_SUB_SAT_S() -> i32 { 0xb2 }
pub fn SIMD_I16X8_SUB_SAT_U() -> i32 { 0xb3 }
pub fn SIMD_I16X8_MUL() -> i32 { 0xb9 }
pub fn SIMD_I16X8_NEG() -> i32 { 0x9f }
pub fn SIMD_I16X8_ABS() -> i32 { 0x90 }

// Arithmetic - i32x4
pub fn SIMD_I32X4_ADD() -> i32 { 0xae }
pub fn SIMD_I32X4_SUB() -> i32 { 0xb1 }
pub fn SIMD_I32X4_MUL() -> i32 { 0xb5 }
pub fn SIMD_I32X4_NEG() -> i32 { 0xa1 }
pub fn SIMD_I32X4_ABS() -> i32 { 0xa0 }

