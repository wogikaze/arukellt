// Arithmetic - f64x2
pub fn SIMD_F64X2_ADD() -> i32 { 0xf4 }
pub fn SIMD_F64X2_SUB() -> i32 { 0xf5 }
pub fn SIMD_F64X2_MUL() -> i32 { 0xf6 }
pub fn SIMD_F64X2_DIV() -> i32 { 0xf7 }
