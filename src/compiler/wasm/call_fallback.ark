use wasm::opcodes
use wasm::writer_core
use wasm::call_fallback_resolved
use wasm::call_fallback_intrinsics
use mir::inst_accessors_literals

fn emit_fallback_call(
    w: WasmWriter,
    callee: String,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32,
    wit_import_count: i32
) {
    if call_fallback_resolved::try_emit_resolved_fallback_call(
        w,
        callee,
        inst,
        ctx,
        prev_op,
        prev_arg0,
        prev_arg1,
        next_op,
        next_arg0,
        next_arg1,
        next2_op,
        wit_import_count
    ) {
        return
    }
    if call_fallback_intrinsics::try_emit_name_intrinsic_fallback(
        w,
        callee,
        inst,
        ctx,
        next_op,
        next_arg0,
        next_arg1,
        next2_op
    ) {
        return
    }
    emit_unresolved_fallback_call(w, inst)
}

fn emit_unresolved_fallback_call(w: WasmWriter, inst: MirInst) {
    let arg_count = inst_accessors_literals::MirInst_int_val(inst)
    let mut drop_i = 0
    while drop_i < arg_count {
        writer_core::emit_byte(w, opcodes::OP_DROP())
        drop_i = drop_i + 1
    }
    writer_core::emit_byte(w, opcodes::OP_UNREACHABLE())
}
