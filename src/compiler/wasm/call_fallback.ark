// Arukellt Selfhost - Wasm call namespace: call_fallback

use mir::types
use wasm::opcodes
use mir::function_return_view
use wasm::ctx_record
use wasm::inst_ctx
use wasm::inst_store
use wasm::writer_core
use wasm::writer_leb
use mir::value_types
use wasm::function_indices
use mir::inst_accessors_literals
use mir::inst_accessors_operands
use wasm::intrinsic_vec_new_layout

fn emit_fallback_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, wit_import_count: i32) {
    if starts_with(clone(callee), String_from("Vec_new_")) {
        emit_vec_new_fallback_call(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op)
        return
    }
    if try_emit_resolved_fallback_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op, wit_import_count) {
        return
    }
    emit_unresolved_fallback_call(w, inst)
}

fn try_emit_resolved_fallback_call(w: WasmWriter, callee: String, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, wit_import_count: i32) -> bool {
    let fn_idx = inst_ctx::resolve_fn_index(ctx, clone(callee))
    if fn_idx < 0 {
        return false
    }
    writer_core::emit_byte(w, opcodes::OP_CALL())
    writer_leb::emit_leb128_u(w, function_indices::defined_function_index(fn_idx, ctx_record::SelfEmitCtx_target(ctx), ctx_record::SelfEmitCtx_wasi_version(ctx), ctx_record::SelfEmitCtx_needs_arukellt_host(ctx), ctx_record::SelfEmitCtx_needs_wasi_http_outgoing(ctx), wit_import_count))
    let called = ctx_record::SelfEmitCtx_function_at(ctx, fn_idx)
    if function_return_view::MirFunction_return_type(called) != value_types::VT_VOID() {
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
    }
    true
}

fn emit_unresolved_fallback_call(w: WasmWriter, inst: MirInst) {
    let arg_count = inst_accessors_literals::MirInst_int_val(inst)
    let mut drop_i = 0
    while drop_i < arg_count {
        writer_core::emit_byte(w, opcodes::OP_DROP())
        drop_i = drop_i + 1
    }
    writer_core::emit_byte(w, opcodes::OP_UNREACHABLE())
}

fn emit_vec_new_fallback_call(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) {
    intrinsic_vec_new_layout::emit_vec_new_layout(w, 32, 44)
    inst_ctx::ctx_mark_vec_local(ctx, inst_accessors_operands::MirInst_dest(inst))
    inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
}
