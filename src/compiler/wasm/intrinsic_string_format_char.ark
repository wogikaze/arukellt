use mir::inst_accessors_operands
use wasm::ctx_record
use wasm::ctx_scratch
use wasm::ctx_gc_type
use wasm::emit_target
use wasm::opcodes
use wasm::writer_core
use wasm::writer_gc
use wasm::string_gc_helpers
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32

// Handler for: char_to_string
fn emit_char_to_string(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        emit_char_to_string_gc(w, inst, ctx)
        return true
    }
    let s_tmp = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_alloc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    emit_char_to_string_setup(w, s_tmp)
    emit_char_to_string_alloc(w, s_alloc)
    emit_char_to_string_payload(w, s_alloc, s_tmp)
    helpers_core::emit_local_get(w, s_alloc)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    return true
}

fn emit_char_to_string_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let s_char = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_gc = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let string_type = ctx_record::SelfEmitCtx_gc_type_base(ctx)
    helpers_core::emit_local_set(w, s_char)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    string_gc_helpers::emit_gc_array_new(w, string_type)
    string_gc_helpers::emit_gc_local_set(w, s_gc)
    string_gc_helpers::emit_gc_local_get(w, s_gc)
    string_gc_helpers::emit_gc_i32_const(w, 0)
    helpers_numeric_i32::emit_narrow_i64_operand(w)
    helpers_core::emit_local_get(w, s_char)
    string_gc_helpers::emit_gc_array_set(w, string_type)
    // Leave the gc array ref on the stack; finish_text_call handles dest store.
    string_gc_helpers::emit_gc_local_get(w, s_gc)
}

// Handler for: push_char
fn emit_push_char(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        return emit_push_char_gc(w, inst, ctx)
    }
    let s_char = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let s_str = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    emit_push_char_setup(w, s_char, s_str, s_len)
    emit_push_char_store(w, s_char, s_str, s_len)
    emit_push_char_len_update(w, s_str, s_len)
    return true
}

// GC target push_char: string is a GC array ref (array of mut i8).
// Since GC arrays can't be resized, we create a new array with len+1,
// copy old elements, set the new char, and drop the result (void fn).
fn emit_push_char_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s_char = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let s_gc = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_new = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 1)
    let s_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let string_type = ctx_record::SelfEmitCtx_gc_type_base(ctx)

    // Stack: [string_ref, char]  (char on top)
    // Pop char into i32 scratch
    helpers_core::emit_local_set(w, s_char)
    // Pop string ref into GC ref scratch
    helpers_core::emit_local_set(w, s_gc)

    // Get string length: array.len
    helpers_core::emit_local_get(w, s_gc)
    string_gc_helpers::emit_gc_array_len(w)
    helpers_core::emit_local_set(w, s_len)

    // Create new array with len+1 elements
    helpers_core::emit_local_get(w, s_len)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    string_gc_helpers::emit_gc_array_new(w, string_type)
    helpers_core::emit_local_set(w, s_new)

    // Copy old elements: array.copy(s_new, 0, s_gc, 0, s_len)
    helpers_core::emit_local_get(w, s_new)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 0)
    helpers_core::emit_local_get(w, s_gc)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 0)
    helpers_core::emit_local_get(w, s_len)
    writer_gc::emit_gc_array_copy(w, string_type, string_type)

    // Set new char at index s_len
    helpers_core::emit_local_get(w, s_new)
    helpers_core::emit_local_get(w, s_len)
    helpers_numeric_i32::emit_narrow_i64_operand(w)
    helpers_core::emit_local_get(w, s_char)
    string_gc_helpers::emit_gc_array_set(w, string_type)

    // Void function — drop the new array ref (not stored back to caller's local)
    // The new array is lost; this is a known limitation of void push_char on GC targets.
    return true
}

// Handler for: String_new
fn emit_String_new(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        let string_type = ctx_record::SelfEmitCtx_gc_type_base(ctx)
        string_gc_helpers::emit_gc_i32_const(w, 0)
        string_gc_helpers::emit_gc_array_new(w, string_type)
        return true
    }
    let s_str_base = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    emit_String_new_alloc(w, s_str_base)
    emit_String_new_header(w, s_str_base)
    helpers_core::emit_local_get(w, s_str_base)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    return true
}

fn emit_char_to_string_setup(w: WasmWriter, char_local: i32) {
    helpers_core::emit_local_set(w, char_local)
}

fn emit_char_to_string_alloc(w: WasmWriter, alloc_local: i32) {
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_tee(w, alloc_local)
    helpers_numeric_i32::emit_i32_const(w, 5)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
    helpers_core::emit_local_get(w, alloc_local)
    helpers_numeric_i32::emit_i32_const(w, 1)
    helpers_memory::emit_i32_store_default(w)
}

fn emit_char_to_string_payload(w: WasmWriter, alloc_local: i32, char_local: i32) {
    helpers_core::emit_local_get(w, alloc_local)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_get(w, char_local)
    helpers_memory::emit_i32_store8_default(w)
}

fn emit_push_char_setup(w: WasmWriter, char_local: i32, str_local: i32, len_local: i32) {
    helpers_core::emit_local_set(w, char_local)
    helpers_core::emit_local_set(w, str_local)
    helpers_core::emit_local_get(w, str_local)
    helpers_memory::emit_string_len_from_stack(w)
    helpers_core::emit_local_set(w, len_local)
}

fn emit_push_char_store(w: WasmWriter, char_local: i32, str_local: i32, len_local: i32) {
    helpers_core::emit_local_get(w, str_local)
    helpers_core::emit_local_get(w, len_local)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_get(w, char_local)
    helpers_memory::emit_i32_store8_default(w)
}

fn emit_push_char_len_update(w: WasmWriter, str_local: i32, len_local: i32) {
    helpers_core::emit_local_get(w, str_local)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_sub(w)
    helpers_core::emit_local_get(w, len_local)
    helpers_numeric_i32::emit_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_store_default(w)
}

fn emit_String_new_alloc(w: WasmWriter, str_base_local: i32) {
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_set(w, str_base_local)
}

fn emit_String_new_header(w: WasmWriter, str_base_local: i32) {
    helpers_core::emit_local_get(w, str_base_local)
    helpers_numeric_i32::emit_i32_const(w, 0)
    helpers_memory::emit_i32_store_default(w)
    helpers_core::emit_local_get(w, str_base_local)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
}
