use wasm::ctx_record
use wasm::ctx_gc_type_locals
use wasm::ctx_gc_type_vec_ref
use wasm::sections_types_gc
use mir::function_identity
use mir::function_locals_view
use mir::local_access

fn SelfEmitCtx_i32_array_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 1
}

fn SelfEmitCtx_string_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx)
}

fn SelfEmitCtx_struct_type(ctx: SelfEmitCtx, byte_size: i32) -> i32 {
    // Map byte_size to the matching GC struct type index.
    // Available: S_f0_i32 (idx 2) through S_f0_i32_..._f7_i32 (idx 9)
    // Each i32 field is 4 bytes; struct type count = ceil(byte_size / 4) fields.
    let field_count = (byte_size + 3) / 4
    if field_count <= 1 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 2
    } else if field_count == 2 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 3
    } else if field_count == 3 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 4
    } else if field_count == 4 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 5
    } else if field_count == 5 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 6
    } else if field_count == 6 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 7
    } else if field_count == 7 {
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 8
    } else {
        // 8+ fields → use S_f0_i32_..._f7_i32 (idx 9)
        ctx_record::SelfEmitCtx_gc_type_base(ctx) + 9
    }
}

fn SelfEmitCtx_vec_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 10
}

fn SelfEmitCtx_vec_string_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 19
}

fn SelfEmitCtx_vec_v128_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 21
}

fn SelfEmitCtx_vec_i64_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 22
}

fn SelfEmitCtx_vec_f64_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 23
}

fn SelfEmitCtx_string_array_type(ctx: SelfEmitCtx) -> i32 {
    // Vec<String> uses the same element type as String (i8 array = type 0).
    // The String ref array type is at offset 15 (A_ref0).
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 15
}

fn SelfEmitCtx_v128_array_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 20
}

fn SelfEmitCtx_vec_type_for_ctx(ctx: SelfEmitCtx) -> i32 {
    if ctx_gc_type_locals::SelfEmitCtx_is_vec_string_context(ctx) || ctx_gc_type_locals::ctx_has_vec_string_local(ctx) {
        return SelfEmitCtx_vec_string_type(ctx)
    }
    if ctx_gc_type_locals::ctx_has_vec_v128_local(ctx) {
        return SelfEmitCtx_vec_v128_type(ctx)
    }
    if ctx_gc_type_locals::ctx_has_vec_i64_local(ctx) {
        return SelfEmitCtx_vec_i64_type(ctx)
    }
    if ctx_gc_type_locals::ctx_has_vec_f64_local(ctx) {
        return SelfEmitCtx_vec_f64_type(ctx)
    }
    SelfEmitCtx_vec_type(ctx)
}

// Determine the vec GC type index from a specific local index.
// Returns -1 if the local index is invalid or the local type is unknown,
// in which case the caller should fall back to vec_type_for_ctx.

fn SelfEmitCtx_vec_type_for_local(ctx: SelfEmitCtx, local_idx: i32) -> i32 {
    if local_idx < 0 {
        return 0 - 1
    }
    let func_idx = ctx_record::SelfEmitCtx_current_func_idx(ctx)
    let f = ctx_record::SelfEmitCtx_function_at(ctx, func_idx)
    if local_idx >= function_locals_view::MirFunction_local_count(f) {
        return 0 - 1
    }
    let loc = function_locals_view::MirFunction_local_at(f, local_idx)
    let tname = local_access::MirLocal_type_name(loc)
    if eq(clone(tname), String_from("vec:String")) || eq(clone(tname), String_from("vec:string")) {
        return SelfEmitCtx_vec_string_type(ctx)
    }
    if eq(clone(tname), String_from("vec:v128")) || eq(clone(tname), String_from("vec:V128")) {
        return SelfEmitCtx_vec_v128_type(ctx)
    }
    if eq(clone(tname), String_from("vec:i64")) || eq(clone(tname), String_from("vec:I64")) {
        return SelfEmitCtx_vec_i64_type(ctx)
    }
    if eq(clone(tname), String_from("vec:f64")) || eq(clone(tname), String_from("vec:F64")) {
        return SelfEmitCtx_vec_f64_type(ctx)
    }
    if starts_with(clone(tname), String_from("vec:")) {
        let elem = substring(clone(tname), 4, len(tname))
        if ctx_gc_type_vec_ref::gc_vec_elem_is_struct_ref(clone(elem)) || eq(clone(elem), String_from("Vec")) || starts_with(clone(elem), String_from("vec:")) {
            return ctx_gc_type_vec_ref::SelfEmitCtx_vec_struct_ref_type(ctx)
        }
        return SelfEmitCtx_vec_type(ctx)
    }
    0 - 1
}

fn SelfEmitCtx_array_type_for_vec(ctx: SelfEmitCtx) -> i32 {
    if ctx_gc_type_locals::SelfEmitCtx_is_vec_string_context(ctx) || ctx_gc_type_locals::ctx_has_vec_string_local(ctx) {
        return SelfEmitCtx_string_array_type(ctx)
    }
    if ctx_gc_type_locals::ctx_has_vec_v128_local(ctx) {
        return SelfEmitCtx_v128_array_type(ctx)
    }
    if ctx_gc_type_locals::ctx_has_vec_i64_local(ctx) {
        return SelfEmitCtx_i64_array_type(ctx)
    }
    if ctx_gc_type_locals::ctx_has_vec_f64_local(ctx) {
        return SelfEmitCtx_f64_array_type(ctx)
    }
    SelfEmitCtx_i32_array_type(ctx)
}

fn SelfEmitCtx_i64_array_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 11
}

fn SelfEmitCtx_f64_array_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 12
}

fn SelfEmitCtx_i64_struct_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 13
}

fn SelfEmitCtx_enum_open_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + sections_types_gc::gc_enum_open_type_offset()
}

fn SelfEmitCtx_string_ref_array_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 15
}

fn SelfEmitCtx_hashmap_str_i32_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 16
}

fn SelfEmitCtx_hashmap_i32_str_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 17
}

fn SelfEmitCtx_hashmap_str_str_type(ctx: SelfEmitCtx) -> i32 {
    ctx_record::SelfEmitCtx_gc_type_base(ctx) + 18
}

fn SelfEmitCtx_enum_variant_type(ctx: SelfEmitCtx, type_slot: i32) -> i32 {
    if type_slot < 0 {
        return SelfEmitCtx_enum_open_type(ctx)
    }
    let map = ctx_record::SelfEmitCtx_gc_enum_variant_type_map(ctx)
    if type_slot >= 0 && type_slot < len(map) {
        return get_unchecked(map, type_slot)
    }
    let base = ctx_record::SelfEmitCtx_gc_enum_variant_base(ctx)
    if base < 0 {
        return ctx_record::SelfEmitCtx_gc_type_base(ctx) + 2
    }
    base + type_slot
}

fn SelfEmitCtx_struct_type_by_name(ctx: SelfEmitCtx, struct_name: String) -> i32 {
    let names = ctx_record::SelfEmitCtx_gc_struct_names(ctx)
    let count = len(names)
    let mut i = 0
    while i < count {
        if eq(clone(get_unchecked(names, i)), clone(struct_name)) {
            let map = ctx_record::SelfEmitCtx_gc_struct_type_map(ctx)
            if i < len(map) {
                return get_unchecked(map, i)
            }
        }
        i = i + 1
    }
    // Check enum variant names: map slot to the enum variant type map.
    let ev_names = ctx_record::SelfEmitCtx_gc_enum_variant_names(ctx)
    let ev_count = len(ev_names)
    let mut ei = 0
    while ei < ev_count {
        if eq(clone(get_unchecked(ev_names, ei)), clone(struct_name)) {
            let ev_map = ctx_record::SelfEmitCtx_gc_enum_variant_type_map(ctx)
            if ei < len(ev_map) {
                return get_unchecked(ev_map, ei)
            }
        }
        ei = ei + 1
    }
    0 - 1
}

fn SelfEmitCtx_has_struct_type(ctx: SelfEmitCtx, struct_name: String) -> bool {
    let names = ctx_record::SelfEmitCtx_gc_struct_names(ctx)
    let count = len(names)
    let mut i = 0
    while i < count {
        if eq(clone(get_unchecked(names, i)), clone(struct_name)) {
            return true
        }
        i = i + 1
    }
    // Check enum variant names.
    let ev_names = ctx_record::SelfEmitCtx_gc_enum_variant_names(ctx)
    let ev_count = len(ev_names)
    let mut ei = 0
    while ei < ev_count {
        if eq(clone(get_unchecked(ev_names, ei)), clone(struct_name)) {
            return true
        }
        ei = ei + 1
    }
    false
}
