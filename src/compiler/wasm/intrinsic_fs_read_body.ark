use wasm::constants
use wasm::ctx_gc_type
use wasm::ctx_record
use wasm::ctx_scratch
use wasm::emit_target
use wasm::intrinsics::helpers_control
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32
use wasm::opcodes
use wasm::writer_core
use wasm::writer_gc

fn emit_fs_read_open_error(w: WasmWriter, ctx: SelfEmitCtx) {
    emit_fs_read_open_error_message(w)
    emit_fs_read_result_pair(w, 1, ctx)
}

fn emit_fs_read_open_error_message(w: WasmWriter) {
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 15)
    helpers_memory::emit_i32_store_default(w)
    let err_msg_fo = "file open error"
    let mut ebi = 0
    while ebi < 15 {
        helpers_core::emit_heap_get(w)
        helpers_numeric_i32::emit_i32_const(w, 4 + ebi)
        helpers_numeric_i32::emit_i32_add(w)
        helpers_numeric_i32::emit_i32_const(w, char_at(err_msg_fo, ebi))
        helpers_memory::emit_i32_store8_default(w)
        ebi = ebi + 1
    }
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_STRPTR())
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_store_default(w)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 19)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
}

fn emit_fs_read_loop(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_BUFSTART())
    helpers_core::emit_heap_get(w)
    helpers_memory::emit_i32_store_default(w)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
    helpers_control::emit_block_loop_header(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_IOV())
    helpers_core::emit_heap_get(w)
    helpers_memory::emit_i32_store_default(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_IOV() + 4)
    helpers_numeric_i32::emit_i32_const(w, constants::FS_BUF_SIZE())
    helpers_memory::emit_i32_store_default(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_FD())
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_IOV())
    helpers_numeric_i32::emit_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_NREAD())
    helpers_core::emit_call(w, 4)
    helpers_core::emit_drop(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_NREAD())
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_eqz(w)
    helpers_control::emit_br_if(w, 1)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_NREAD())
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
    helpers_control::emit_br(w, 0)
    helpers_control::emit_end(w)
    helpers_control::emit_end(w)
}

fn emit_fs_read_success(w: WasmWriter, ctx: SelfEmitCtx) {
    emit_fs_read_success_len_header(w)
    emit_fs_read_success_close_fd(w)
    emit_fs_read_success_strptr(w)
    emit_fs_read_result_pair(w, 0, ctx)
}

fn emit_fs_read_success_len_header(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_BUFSTART())
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_BUFSTART())
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_numeric_i32::emit_i32_sub(w)
    helpers_memory::emit_i32_store_default(w)
}

fn emit_fs_read_success_close_fd(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_FD())
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_call(w, 5)
    helpers_core::emit_drop(w)
}

fn emit_fs_read_success_strptr(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_STRPTR())
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_BUFSTART())
    helpers_memory::emit_i32_load_default(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_store_default(w)
}

fn emit_fs_read_result_pair(w: WasmWriter, tag: i32, ctx: SelfEmitCtx) {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        emit_fs_read_result_pair_gc(w, tag, ctx)
        return
    }
    helpers_core::emit_heap_get(w)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, tag)
    helpers_memory::emit_i32_store_default(w)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 4)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_STRPTR())
    helpers_memory::emit_i32_load_default(w)
    helpers_memory::emit_i32_store_default(w)
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, 8)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_heap_set(w)
}

fn emit_fs_read_result_pair_gc(w: WasmWriter, tag: i32, ctx: SelfEmitCtx) {
    let s_str = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_len = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let string_type = ctx_record::SelfEmitCtx_gc_type_base(ctx)
    emit_fs_read_gc_string_from_scratch(w, s_str, s_i, s_len, string_type)
    let variant_name = if tag == 0 { String_from("Result::Ok") } else { String_from("Result::Err") }
    let variant_type = find_result_string_variant_type(ctx, clone(variant_name))
    let open_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
    let type_idx = if variant_type >= 0 { variant_type } else { open_type }
    helpers_numeric_i32::emit_i32_const(w, tag)
    helpers_core::emit_local_get(w, s_str)
    writer_gc::emit_gc_struct_new(w, type_idx)
    writer_gc::emit_gc_ref_cast(w, open_type)
}

fn find_result_string_variant_type(ctx: SelfEmitCtx, variant_name: String) -> i32 {
    // Prefer `_f1_ref0` (String payload) over the first name-only match
    // which is usually `_f1_i32` from builtin registration order.
    let names = ctx_record::SelfEmitCtx_gc_enum_variant_names(ctx)
    let sigs = ctx_record::SelfEmitCtx_gc_enum_variant_sigs(ctx)
    let type_map = ctx_record::SelfEmitCtx_gc_enum_variant_type_map(ctx)
    let open_type = ctx_gc_type::SelfEmitCtx_enum_open_type(ctx)
    let count = len(names)
    let mut fallback = 0 - 1
    let mut i = 0
    while i < count {
        if eq(clone(get_unchecked(names, i)), clone(variant_name)) {
            if i < len(type_map) {
                let variant_type = get_unchecked(type_map, i)
                if variant_type != open_type {
                    if i < len(sigs) && ends_with(clone(get_unchecked(sigs, i)), String_from("_f1_ref0")) {
                        return variant_type
                    }
                    if fallback < 0 {
                        fallback = variant_type
                    }
                }
            }
        }
        i = i + 1
    }
    if fallback >= 0 {
        return fallback
    }
    ctx_gc_type::SelfEmitCtx_struct_type_by_name(ctx, clone(variant_name))
}

fn emit_fs_read_gc_string_from_scratch(w: WasmWriter, s_str: i32, s_i: i32, s_len: i32, string_type: i32) {
    helpers_core::emit_heap_get(w)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_BUFSTART())
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_local_set(w, s_len)
    helpers_core::emit_local_get(w, s_len)
    writer_gc::emit_gc_array_new(w, string_type)
    writer_gc::emit_gc_ref_cast(w, string_type)
    helpers_core::emit_local_set(w, s_str)
    helpers_numeric_i32::emit_i32_const(w, 0)
    helpers_core::emit_local_set(w, s_i)
    helpers_control::emit_block_loop_header(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_core::emit_local_get(w, s_len)
    writer_core::emit_byte(w, opcodes::OP_I32_GE_S())
    helpers_control::emit_br_if(w, 1)
    helpers_core::emit_local_get(w, s_str)
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32::emit_i32_const(w, constants::SCRATCH_FS_STRPTR())
    helpers_memory::emit_i32_load_default(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32::emit_i32_add(w)
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD8_U())
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, 0)
    writer_gc::emit_gc_array_set(w, string_type)
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32::emit_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_set(w, s_i)
    helpers_control::emit_br(w, 0)
    helpers_control::emit_end(w)
    helpers_control::emit_end(w)
}
