// Arukellt Selfhost - string ASCII case intrinsic facade.

use wasm::ctx_scratch
use wasm::intrinsics::helpers_control_branch
use wasm::intrinsics::helpers_control_loop
use wasm::intrinsics::helpers_control_structured
use wasm::intrinsics::helpers_core_heap
use wasm::intrinsics::helpers_core_locals
use wasm::intrinsics::helpers_memory_access
use wasm::intrinsics::helpers_memory_stack
use wasm::intrinsics::helpers_numeric_i32_arith
use wasm::intrinsics::helpers_numeric_i32_bitwise
use wasm::intrinsics::helpers_numeric_i32_compare
use wasm::intrinsics::helpers_numeric_i32_const

// Handler for: to_uppercase, to_upper, text::to_upper, text::to_uppercase
fn emit_to_upper(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s0 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s1 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s2 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s3 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s4 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    emit_case_read_source_and_alloc(w, s0, s1, s2)
    emit_ascii_case_loop(w, s0, s1, s2, s3, s4, 97, 122, true)
    emit_case_finish_heap_and_result(w, s1, s2)
    return true
}

// Handler for: to_lowercase, to_lower, text::to_lower, text::to_lowercase
fn emit_to_lower(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s0 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s1 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s2 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s3 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s4 = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    emit_case_read_source_and_alloc(w, s0, s1, s2)
    emit_ascii_case_loop(w, s0, s1, s2, s3, s4, 65, 90, false)
    emit_case_finish_heap_and_result(w, s1, s2)
    return true
}

fn emit_case_read_source_and_alloc(w: WasmWriter, s_src: i32, s_len: i32, s_dst: i32) {
    helpers_core_locals::emit_local_set(w, s_src)
    helpers_core_locals::emit_local_get(w, s_src)
    helpers_memory_stack::emit_string_len_from_stack(w)
    helpers_core_locals::emit_local_set(w, s_len)
    helpers_core_heap::emit_heap_get(w)
    helpers_core_locals::emit_local_get(w, s_len)
    helpers_memory_access::emit_i32_store_default(w)
    helpers_core_heap::emit_heap_get(w)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_dst)
}

fn emit_ascii_case_loop(w: WasmWriter, s_src: i32, s_len: i32, s_dst: i32, s_i: i32, s_ch: i32, range_start: i32, range_end: i32, to_upper: bool) {
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_i)
    helpers_control_loop::emit_block_loop_header(w)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_core_locals::emit_local_get(w, s_len)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    emit_ascii_case_load_char(w, s_src, s_i, s_ch)
    emit_ascii_case_convert_if_needed(w, s_ch, range_start, range_end, to_upper)
    helpers_core_locals::emit_local_get(w, s_dst)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, s_ch)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_i)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
}

fn emit_ascii_case_load_char(w: WasmWriter, s_src: i32, s_i: i32, s_ch: i32) {
    helpers_core_locals::emit_local_get(w, s_src)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load8_u_default(w)
    helpers_core_locals::emit_local_set(w, s_ch)
}

fn emit_ascii_case_convert_if_needed(w: WasmWriter, s_ch: i32, range_start: i32, range_end: i32, to_upper: bool) {
    helpers_core_locals::emit_local_get(w, s_ch)
    helpers_numeric_i32_const::emit_i32_const(w, range_start)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_core_locals::emit_local_get(w, s_ch)
    helpers_numeric_i32_const::emit_i32_const(w, range_end)
    helpers_numeric_i32_compare::emit_i32_le_s(w)
    helpers_numeric_i32_bitwise::emit_i32_and(w)
    helpers_control_structured::emit_if_empty(w)
    helpers_core_locals::emit_local_get(w, s_ch)
    helpers_numeric_i32_const::emit_i32_const(w, 32)
    if to_upper {
        helpers_numeric_i32_arith::emit_i32_sub(w)
    } else {
        helpers_numeric_i32_arith::emit_i32_add(w)
    }
    helpers_core_locals::emit_local_set(w, s_ch)
    helpers_control_structured::emit_end(w)
}

fn emit_case_finish_heap_and_result(w: WasmWriter, s_len: i32, s_dst: i32) {
    helpers_core_heap::emit_heap_get(w)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, s_len)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_numeric_i32_const::emit_i32_const(w, 3)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_numeric_i32_const::emit_i32_const(w, -4)
    helpers_numeric_i32_bitwise::emit_i32_and(w)
    helpers_core_heap::emit_heap_set(w)
    helpers_core_locals::emit_local_get(w, s_dst)
}
