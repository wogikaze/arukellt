// Arukellt Selfhost - Wasm emitter context data record.

pub struct SelfEmitCtx {
    functions: Vec<MirFunction>,
    string_offsets: Vec<i32>,
    string_lengths: Vec<i32>,
    string_values: Vec<String>,
    scratch_base: i32,
    true_str_idx: i32,
    false_str_idx: i32,
    vec_locals: Vec<i32>,
    target: String,
    wasi_version: String,
    needs_arukellt_host: i32,
    gc_hint_offsets: Vec<i32>,
    needs_wasi_http_outgoing: i32,
}

fn SelfEmitCtx_new(functions: Vec<MirFunction>, string_offsets: Vec<i32>, string_lengths: Vec<i32>, string_values: Vec<String>, true_str_idx: i32, false_str_idx: i32, target: String, wasi_version: String, needs_arukellt_host: i32, needs_wasi_http_outgoing: i32) -> SelfEmitCtx {
    SelfEmitCtx { functions: functions, string_offsets: string_offsets, string_lengths: string_lengths, string_values: string_values, scratch_base: 0, true_str_idx: true_str_idx, false_str_idx: false_str_idx, vec_locals: Vec_new_i32(), target: target, wasi_version: wasi_version, needs_arukellt_host: needs_arukellt_host, gc_hint_offsets: Vec_new_i32(), needs_wasi_http_outgoing: needs_wasi_http_outgoing }
}

fn SelfEmitCtx_needs_arukellt_host(ctx: SelfEmitCtx) -> i32 {
    ctx.needs_arukellt_host
}

fn SelfEmitCtx_needs_wasi_http_outgoing(ctx: SelfEmitCtx) -> i32 {
    ctx.needs_wasi_http_outgoing
}

fn SelfEmitCtx_target(ctx: SelfEmitCtx) -> String {
    ctx.target
}

fn SelfEmitCtx_wasi_version(ctx: SelfEmitCtx) -> String {
    ctx.wasi_version
}

fn SelfEmitCtx_function_count(ctx: SelfEmitCtx) -> i32 {
    len(ctx.functions)
}

fn SelfEmitCtx_function_at(ctx: SelfEmitCtx, idx: i32) -> MirFunction {
    get_unchecked(ctx.functions, idx)
}

fn SelfEmitCtx_functions(ctx: SelfEmitCtx) -> Vec<MirFunction> {
    ctx.functions
}
