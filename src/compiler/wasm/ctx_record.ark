fn SelfEmitCtx_set_gc_enum_variant_names(ctx: SelfEmitCtx, gc_enum_variant_names: Vec<String>) {
    ctx.gc_enum_variant_names = gc_enum_variant_names
}

fn SelfEmitCtx_gc_struct_base(ctx: SelfEmitCtx) -> i32 {
    ctx.gc_struct_base
}

fn SelfEmitCtx_set_gc_struct_base(ctx: SelfEmitCtx, gc_struct_base: i32) {
    ctx.gc_struct_base = gc_struct_base
}

fn SelfEmitCtx_gc_struct_type_map(ctx: SelfEmitCtx) -> Vec<i32> {
    ctx.gc_struct_type_map
}

fn SelfEmitCtx_set_gc_struct_type_map(ctx: SelfEmitCtx, gc_struct_type_map: Vec<i32>) {
    ctx.gc_struct_type_map = gc_struct_type_map
}

fn SelfEmitCtx_gc_struct_names(ctx: SelfEmitCtx) -> Vec<String> {
    ctx.gc_struct_names
}

fn SelfEmitCtx_set_gc_struct_names(ctx: SelfEmitCtx, gc_struct_names: Vec<String>) {
    ctx.gc_struct_names = gc_struct_names
}

fn SelfEmitCtx_set_current_func_idx(ctx: SelfEmitCtx, current_func_idx: i32) {
    ctx.current_func_idx = current_func_idx
