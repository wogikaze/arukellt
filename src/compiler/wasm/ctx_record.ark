    ctx.registry_audit_candidates
}

fn SelfEmitCtx_registry_audit_matched(ctx: SelfEmitCtx) -> i32 {
    ctx.registry_audit_matched
}

fn SelfEmitCtx_registry_audit_mismatched(ctx: SelfEmitCtx) -> i32 {
    ctx.registry_audit_mismatched
}

fn SelfEmitCtx_registry_audit_mismatch_budget(ctx: SelfEmitCtx) -> i32 {
    ctx.registry_audit_mismatch_budget
}

fn SelfEmitCtx_registry_audit_inc_candidates(ctx: SelfEmitCtx) {
    ctx.registry_audit_candidates = ctx.registry_audit_candidates + 1
}

fn SelfEmitCtx_registry_audit_inc_matched(ctx: SelfEmitCtx) {
    ctx.registry_audit_matched = ctx.registry_audit_matched + 1
}

fn SelfEmitCtx_registry_audit_inc_mismatched(ctx: SelfEmitCtx) {
    ctx.registry_audit_mismatched = ctx.registry_audit_mismatched + 1
}

fn SelfEmitCtx_registry_audit_dec_mismatch_budget(ctx: SelfEmitCtx) {
    ctx.registry_audit_mismatch_budget = ctx.registry_audit_mismatch_budget - 1
}
