// Wasm emitter context data record.
use corehir::signature_registry
use corehir::type_table
use mir::function_identity
use mir::lower::mono_instance_table
use wasm::gc_layout_table
use collections::name_index

pub struct SelfEmitCtx {
    functions: Vec<MirFunction>,
    function_name_lengths: Vec<i32>,
    function_name_index: NameIndex,
    function_name_counts: NameIndex,
    string_offsets: Vec<i32>,
    string_lengths: Vec<i32>,
    string_values: Vec<String>,
    scratch_base: i32,
    true_str_idx: i32,
    false_str_idx: i32,
    vec_locals: Vec<i32>,
    target: String,
    wasi_version: String,
    needs_arukellt_host: i32,
    gc_hint_offsets: Vec<i32>,
    needs_wasi_http_outgoing: i32,
    gc_type_base: i32,
    gc_enum_variant_base: i32,
    gc_enum_variant_type_map: Vec<i32>,
    gc_enum_variant_names: Vec<String>,
    gc_enum_variant_sigs: Vec<String>,
    gc_struct_base: i32,
    gc_struct_type_map: Vec<i32>,
    gc_struct_names: Vec<String>,
    gc_struct_sigs: Vec<String>,
    current_func_idx: i32,
    fn_type_map: Vec<i32>,
    signature_registry: SignatureRegistry,
    type_table: TypeTable,
    mono_instance_table: MonoInstanceTable,
    spine_populated: bool,
    registry_audit_candidates: i32,
    registry_audit_matched: i32,
    registry_audit_mismatched: i32,
    registry_audit_mismatch_budget: i32,
    core_op_shadow_candidates: i32,
    core_op_shadow_matched: i32,
    core_op_shadow_mismatched: i32,
    core_op_shadow_unresolved: i32,
    core_op_shadow_mismatch_budget: i32,
    gc_layout_table: GcLayoutTable,
    // Per-function emit caches (#829). Empty = inactive.
    local_gc_infer_cache: Vec<i32>,
    local_struct_new_cache: Vec<i32>,
    // [functions, struct_new_hits, infer_hits, infer_fills] — debug counters.
    local_gc_cache_stats: Vec<i32>,
}

fn SelfEmitCtx_new(
    functions: Vec<MirFunction>,
    string_offsets: Vec<i32>,
    string_lengths: Vec<i32>,
    string_values: Vec<String>,
    true_str_idx: i32,
    false_str_idx: i32,
    target: String,
    wasi_version: String,
    needs_arukellt_host: i32,
    needs_wasi_http_outgoing: i32
) -> SelfEmitCtx {
    let fn_count = len(functions)
    let mut name_lengths = Vec_new_i32()
    let function_name_index = name_index::NameIndex_new(fn_count)
    let function_name_counts = name_index::NameIndex_new(fn_count)
    let mut fi = 0
    while fi < fn_count {
        let fname = function_identity::MirFunction_name(get_unchecked(functions, fi))
        push(name_lengths, len(clone(fname)))
        name_index::name_index_insert_first(function_name_index, clone(fname), fi)
        name_index::name_index_increment(function_name_counts, fname)
        fi = fi + 1
    }
    let empty_i32 = Vec_new_i32()
    let empty_string = Vec_new_String()
    let empty_i32_b = Vec_new_i32()
    let empty_i32_c = Vec_new_i32()
    let empty_string_b = Vec_new_String()
    let empty_string_c = Vec_new_String()
    let empty_i32_d = Vec_new_i32()
    let empty_string_d = Vec_new_String()
    let empty_string_e = Vec_new_String()
    let empty_i32_e = Vec_new_i32()
    let sig = signature_registry::SignatureRegistry_new()
    let types = type_table::TypeTable_new()
    let mono = mono_instance_table::MonoInstanceTable_new()
    let layout = gc_layout_table::GcLayoutTable_new()
    SelfEmitCtx {
        functions: functions,
        function_name_lengths: name_lengths,
        function_name_index: function_name_index,
        function_name_counts: function_name_counts,
        string_offsets: string_offsets,
        string_lengths: string_lengths,
        string_values: string_values,
        scratch_base: 0,
        true_str_idx: true_str_idx,
        false_str_idx: false_str_idx,
        vec_locals: empty_i32,
        target: target,
        wasi_version: wasi_version,
        needs_arukellt_host: needs_arukellt_host,
        gc_hint_offsets: empty_i32_b,
        needs_wasi_http_outgoing: needs_wasi_http_outgoing,
        gc_type_base: 0,
        gc_enum_variant_base: 0 - 1,
        gc_enum_variant_type_map: empty_i32_c,
        gc_enum_variant_names: empty_string_b,
        gc_enum_variant_sigs: empty_string_c,
        gc_struct_base: 0 - 1,
        gc_struct_type_map: empty_i32_d,
        gc_struct_names: empty_string_d,
        gc_struct_sigs: empty_string_e,
        current_func_idx: 0,
        fn_type_map: empty_i32_e,
        signature_registry: sig,
        type_table: types,
        mono_instance_table: mono,
        spine_populated: false,
        registry_audit_candidates: 0,
        registry_audit_matched: 0,
        registry_audit_mismatched: 0,
        registry_audit_mismatch_budget: 128,
        core_op_shadow_candidates: 0,
        core_op_shadow_matched: 0,
        core_op_shadow_mismatched: 0,
        core_op_shadow_unresolved: 0,
        core_op_shadow_mismatch_budget: 128,
        gc_layout_table: layout,
        local_gc_infer_cache: Vec_new_i32(),
        local_struct_new_cache: Vec_new_i32(),
        local_gc_cache_stats: SelfEmitCtx_new_local_gc_cache_stats(),
    }
}

fn SelfEmitCtx_new_local_gc_cache_stats() -> Vec<i32> {
    let stats = Vec_new_i32()
    push(stats, 0)
    push(stats, 0)
    push(stats, 0)
    push(stats, 0)
    stats
}

fn SelfEmitCtx_local_gc_infer_cache(ctx: SelfEmitCtx) -> Vec<i32> {
    ctx.local_gc_infer_cache
}

fn SelfEmitCtx_set_local_gc_infer_cache(ctx: SelfEmitCtx, cache: Vec<i32>) {
    ctx.local_gc_infer_cache = cache
}

