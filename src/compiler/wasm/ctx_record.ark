// Arukellt Selfhost - Wasm emitter context data record.

pub struct SelfEmitCtx {
    functions: Vec<MirFunction>,
    string_offsets: Vec<i32>,
    string_lengths: Vec<i32>,
    string_values: Vec<String>,
    scratch_base: i32,
    true_str_idx: i32,
    false_str_idx: i32,
    vec_locals: Vec<i32>,
}

fn SelfEmitCtx_new(functions: Vec<MirFunction>, string_offsets: Vec<i32>, string_lengths: Vec<i32>, string_values: Vec<String>, true_str_idx: i32, false_str_idx: i32) -> SelfEmitCtx {
    SelfEmitCtx { functions: functions, string_offsets: string_offsets, string_lengths: string_lengths, string_values: string_values, scratch_base: 0, true_str_idx: true_str_idx, false_str_idx: false_str_idx, vec_locals: Vec_new_i32() }
}

fn SelfEmitCtx_function_count(ctx: SelfEmitCtx) -> i32 {
    len(ctx.functions)
}

fn SelfEmitCtx_function_at(ctx: SelfEmitCtx, idx: i32) -> MirFunction {
    get_unchecked(ctx.functions, idx)
}

fn SelfEmitCtx_functions(ctx: SelfEmitCtx) -> Vec<MirFunction> {
    ctx.functions
}
