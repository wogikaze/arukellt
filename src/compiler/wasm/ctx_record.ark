// Arukellt Selfhost - Wasm emitter context data record.

use corehir::signature_registry
use corehir::type_table
use mir::function_identity

pub struct SelfEmitCtx {
    functions: Vec<MirFunction>,
    function_name_lengths: Vec<i32>,
    string_offsets: Vec<i32>,
    string_lengths: Vec<i32>,
    string_values: Vec<String>,
    scratch_base: i32,
    true_str_idx: i32,
    false_str_idx: i32,
    vec_locals: Vec<i32>,
    target: String,
    wasi_version: String,
    needs_arukellt_host: i32,
    gc_hint_offsets: Vec<i32>,
    needs_wasi_http_outgoing: i32,
    gc_type_base: i32,
    gc_enum_variant_base: i32,
    gc_enum_variant_type_map: Vec<i32>,
    gc_enum_variant_names: Vec<String>,
    gc_struct_base: i32,
    gc_struct_type_map: Vec<i32>,
    gc_struct_names: Vec<String>,
    current_func_idx: i32,
    fn_type_map: Vec<i32>,
    signature_registry: SignatureRegistry,
    type_table: TypeTable,
    spine_populated: bool,
    registry_audit_candidates: i32,
    registry_audit_matched: i32,
    registry_audit_mismatched: i32,
    registry_audit_mismatch_budget: i32,
}

fn SelfEmitCtx_new(functions: Vec<MirFunction>, string_offsets: Vec<i32>, string_lengths: Vec<i32>, string_values: Vec<String>, true_str_idx: i32, false_str_idx: i32, target: String, wasi_version: String, needs_arukellt_host: i32, needs_wasi_http_outgoing: i32) -> SelfEmitCtx {
    let fn_count = len(functions)
    let mut name_lengths = Vec_new_i32()
    let mut fi = 0
    while fi < fn_count {
        push(name_lengths, len(function_identity::MirFunction_name(get_unchecked(functions, fi))))
        fi = fi + 1
    }
    SelfEmitCtx { functions: functions, function_name_lengths: name_lengths, string_offsets: string_offsets, string_lengths: string_lengths, string_values: string_values, scratch_base: 0, true_str_idx: true_str_idx, false_str_idx: false_str_idx, vec_locals: Vec_new_i32(), target: target, wasi_version: wasi_version, needs_arukellt_host: needs_arukellt_host, gc_hint_offsets: Vec_new_i32(), needs_wasi_http_outgoing: needs_wasi_http_outgoing, gc_type_base: 0, gc_enum_variant_base: 0 - 1, gc_enum_variant_type_map: Vec_new_i32(), gc_enum_variant_names: Vec_new_String(), gc_struct_base: 0 - 1, gc_struct_type_map: Vec_new_i32(), gc_struct_names: Vec_new_String(), current_func_idx: 0, fn_type_map: Vec_new_i32(), signature_registry: signature_registry::SignatureRegistry_new(), type_table: type_table::TypeTable_new(), spine_populated: false, registry_audit_candidates: 0, registry_audit_matched: 0, registry_audit_mismatched: 0, registry_audit_mismatch_budget: 128 }
}

fn SelfEmitCtx_needs_arukellt_host(ctx: SelfEmitCtx) -> i32 {
    ctx.needs_arukellt_host
}

fn SelfEmitCtx_needs_wasi_http_outgoing(ctx: SelfEmitCtx) -> i32 {
    ctx.needs_wasi_http_outgoing
}

fn SelfEmitCtx_target(ctx: SelfEmitCtx) -> String {
    ctx.target
}

fn SelfEmitCtx_wasi_version(ctx: SelfEmitCtx) -> String {
    ctx.wasi_version
}

fn SelfEmitCtx_function_count(ctx: SelfEmitCtx) -> i32 {
    len(ctx.functions)
}

fn SelfEmitCtx_function_at(ctx: SelfEmitCtx, idx: i32) -> MirFunction {
    get_unchecked(ctx.functions, idx)
}

fn SelfEmitCtx_function_name_length_at(ctx: SelfEmitCtx, idx: i32) -> i32 {
    get_unchecked(ctx.function_name_lengths, idx)
}

fn SelfEmitCtx_functions(ctx: SelfEmitCtx) -> Vec<MirFunction> {
    ctx.functions
}

fn SelfEmitCtx_gc_type_base(ctx: SelfEmitCtx) -> i32 {
    ctx.gc_type_base
}

fn SelfEmitCtx_set_gc_type_base(ctx: SelfEmitCtx, gc_type_base: i32) {
    ctx.gc_type_base = gc_type_base
}

