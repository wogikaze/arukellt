use wasm::ctx_scratch
use wasm::intrinsic_env_var_lookup
use wasm::intrinsics::helpers_core_locals

fn emit_env_var(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let name_local = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    helpers_core_locals::emit_local_set(w, name_local)
    intrinsic_env_var_lookup::emit_env_var_lookup(w, ctx, name_local)
    return true
}

fn emit_env_get_var(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    emit_env_var(w, inst, ctx)
}
