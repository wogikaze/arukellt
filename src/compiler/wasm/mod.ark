// Arukellt Selfhost - Wasm public boundary.

use wasm::wasm
use wasm::wat

pub fn emit_wasm(mir: MirModule, target: String, opt_level: i32, bindings: Vec<resolver::wit_import_bind::WitImportBinding>) -> Vec<i32> {
    wasm::emit_wasm_module(mir, target, opt_level, bindings)
}

pub fn emit_wat(mir: MirModule, target: String, opt_level: i32) -> String {
    wat::emit_wat_module(mir, target, opt_level)
}
