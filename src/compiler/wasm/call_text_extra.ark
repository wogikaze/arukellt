use wasm::call_text_core
use wasm::inst_store
use wasm::intrinsic_string_extra
use wasm::intrinsic_string_format
use wasm::intrinsic_string_index_of
use wasm::intrinsic_string_replace_all
use wasm::intrinsic_string_transform

fn try_emit_text_extra_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_extra_affix_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_extra_transform_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_extra_search_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_extra_format_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_extra_affix_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_extra_affix_misc_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_extra_affix_edge_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_extra_affix_edge_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_starts_with(){
        let _result_on_stack = intrinsic_string_extra::emit_starts_with(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_ends_with(){
        let _result_on_stack = intrinsic_string_extra::emit_ends_with(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_trim(){
        let _result_on_stack = intrinsic_string_extra::emit_trim(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_extra_affix_misc_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_contains(){
        let _result_on_stack = intrinsic_string_extra::emit_contains_String(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_reverse(){
        let _result_on_stack = intrinsic_string_extra::emit_reverse_String(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_extra_format_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_f32_to_string(){
        let _result_on_stack = intrinsic_string_format::emit_f32_to_string(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_extra_search_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_index_of(){
        let _result_on_stack = intrinsic_string_index_of::emit_index_of(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_replace(){
        let _result_on_stack = intrinsic_string_replace_all::emit_replace(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn try_emit_text_extra_transform_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_repeat(){
        let _result_on_stack = intrinsic_string_transform::emit_repeat(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_to_uppercase(){
        let _result_on_stack = intrinsic_string_transform::emit_to_upper(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_to_lowercase(){
        let _result_on_stack = intrinsic_string_transform::emit_to_lower(w, inst, ctx)
        return finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
    }
    false
}

fn finish_text_call(w: WasmWriter, inst: MirInst, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, result_on_stack: bool) -> bool {
    // Delegate to call_text_core so string VT_REF store forcing stays in sync.
    call_text_core::finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, result_on_stack)
}
