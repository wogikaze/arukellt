use wasm::opcodes
use wasm::writer_core
use wasm::writer_leb

fn emit_i32_const(w: WasmWriter, value: i32) {
    if writer_core::writer_memory64(w) {
        writer_core::emit_byte(w, opcodes::OP_I64_CONST())
        writer_leb::emit_leb128_s(w, value)
        return
    }
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_leb::emit_leb128_s(w, value)
}
