// Arukellt Selfhost - Wasm i32 arithmetic helper recipes.

use wasm::opcodes
use wasm::writer_core

fn emit_i32_add(w: WasmWriter) { writer_core::emit_byte(w, opcodes::OP_I32_ADD()) }
fn emit_i32_sub(w: WasmWriter) { writer_core::emit_byte(w, opcodes::OP_I32_SUB()) }
fn emit_i32_mul(w: WasmWriter) { writer_core::emit_byte(w, opcodes::OP_I32_MUL()) }
fn emit_i32_div_u(w: WasmWriter) { writer_core::emit_byte(w, opcodes::OP_I32_DIV_U()) }
fn emit_i32_rem_u(w: WasmWriter) { writer_core::emit_byte(w, opcodes::OP_I32_REM_U()) }
