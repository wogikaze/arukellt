// Arukellt Selfhost - Wasm memory access helper recipes.

use wasm::opcodes
use wasm::writer_core
use wasm::writer_leb

fn emit_i32_load(w: WasmWriter, offset: i32) {
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD())
    writer_core::emit_byte(w, 2)
    writer_leb::emit_leb128_u(w, offset)
}

fn emit_i32_store(w: WasmWriter, offset: i32) {
    writer_core::emit_byte(w, opcodes::OP_I32_STORE())
    writer_core::emit_byte(w, 2)
    writer_leb::emit_leb128_u(w, offset)
}

fn emit_i32_load_default(w: WasmWriter) {
    emit_i32_load(w, 0)
}

fn emit_i32_store_default(w: WasmWriter) {
    emit_i32_store(w, 0)
}

fn emit_i32_load8_u_default(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_LOAD8_U())
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, 0)
}

fn emit_i32_store8_default(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_STORE8())
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, 0)
}

fn emit_memory_copy(w: WasmWriter) {
    writer_core::emit_byte(w, 252)
    writer_leb::emit_leb128_u(w, 10)
    writer_core::emit_byte(w, 0)
    writer_core::emit_byte(w, 0)
}
