use wasm::intrinsics::helpers_io_const
use wasm::intrinsics::helpers_io_memory

fn emit_scratch_addr(w: WasmWriter, offset: i32) {
    helpers_io_const::emit_i32_const(w, offset)
}

fn emit_string_len_from_stack(w: WasmWriter) {
    helpers_io_const::emit_i32_const(w, 4)
    helpers_io_memory::emit_i32_sub(w)
    helpers_io_memory::emit_i32_load_default(w)
}
