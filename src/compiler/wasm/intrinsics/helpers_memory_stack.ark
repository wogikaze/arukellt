use wasm::opcodes
use wasm::writer_core
use wasm::writer_leb
use wasm::intrinsics::helpers_memory_access

fn emit_i32_const(w: WasmWriter, value: i32) {
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_leb::emit_leb128_s(w, value)
}

fn emit_i32_sub(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_SUB())
}

fn emit_local_get(w: WasmWriter, local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, local)
}

fn emit_local_set(w: WasmWriter, local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_leb::emit_leb128_u(w, local)
}

fn emit_scratch_addr(w: WasmWriter, offset: i32) {
    emit_i32_const(w, offset)
}

fn emit_string_len_from_stack(w: WasmWriter) {
    emit_i32_const(w, 4)
    emit_i32_sub(w)
    helpers_memory_access::emit_i32_load_default(w)
}

fn emit_load_string_len_to_local(w: WasmWriter, string_local: i32, len_local: i32) {
    emit_local_get(w, string_local)
    emit_string_len_from_stack(w)
    emit_local_set(w, len_local)
}
