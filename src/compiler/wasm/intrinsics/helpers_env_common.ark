// Arukellt Selfhost - Common env intrinsic helpers facade.

use wasm::intrinsics::helpers_control
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32

fn env_emit_br_if(w: WasmWriter, depth: i32) {
    helpers_control::emit_br_if(w, depth)
}

fn env_emit_br(w: WasmWriter, depth: i32) {
    helpers_control::emit_br(w, depth)
}

fn env_emit_block_loop_header(w: WasmWriter) {
    helpers_control::emit_block_loop_header(w)
}

fn env_emit_if_empty(w: WasmWriter) {
    helpers_control::emit_if_empty(w)
}

fn env_emit_else(w: WasmWriter) {
    helpers_control::emit_else(w)
}

fn env_emit_end(w: WasmWriter) {
    helpers_control::emit_end(w)
}

fn env_emit_call(w: WasmWriter, idx: i32) {
    helpers_core::emit_call(w, idx)
}

fn env_emit_heap_get(w: WasmWriter) {
    helpers_core::emit_heap_get(w)
}

fn env_emit_heap_set(w: WasmWriter) {
    helpers_core::emit_heap_set(w)
}

fn env_emit_local_get(w: WasmWriter, idx: i32) {
    helpers_core::emit_local_get(w, idx)
}

fn env_emit_local_set(w: WasmWriter, idx: i32) {
    helpers_core::emit_local_set(w, idx)
}

fn env_emit_local_tee(w: WasmWriter, idx: i32) {
    helpers_core::emit_local_tee(w, idx)
}

fn env_emit_stack_drop(w: WasmWriter) {
    helpers_core::emit_stack_drop(w)
}

fn env_emit_i32_load8_u_default(w: WasmWriter) {
    helpers_memory::emit_i32_load8_u_default(w)
}

fn env_emit_i32_store8_default(w: WasmWriter) {
    helpers_memory::emit_i32_store8_default(w)
}

fn env_emit_i32_load_default(w: WasmWriter) {
    helpers_memory::emit_i32_load_default(w)
}

fn env_emit_i32_store_default(w: WasmWriter) {
    helpers_memory::emit_i32_store_default(w)
}

fn env_emit_i32_add(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_add(w)
}

fn env_emit_i32_sub(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_sub(w)
}

fn env_emit_i32_eq(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_eq(w)
}

fn env_emit_i32_ge_s(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_ge_s(w)
}

fn env_emit_i32_lt_s(w: WasmWriter) {
    helpers_numeric_i32::emit_i32_lt_s(w)
}

fn env_emit_i32_const(w: WasmWriter, val: i32) {
    helpers_numeric_i32::emit_i32_const(w, val)
}
