// Arukellt Selfhost - GC string emission helper utilities.
//
// Provides compact GC loop/compare primitives to reduce per-file import fan-out.

use wasm::opcodes
use wasm::writer_core

fn emit_gc_block_loop(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_BLOCK())
    writer_core::emit_byte(w, 64)
    writer_core::emit_byte(w, opcodes::OP_LOOP())
    writer_core::emit_byte(w, 64)
}

fn emit_gc_block_loop_end(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_END())
    writer_core::emit_byte(w, opcodes::OP_END())
}

fn emit_gc_br_if(w: WasmWriter, depth: i32) {
    writer_core::emit_byte(w, opcodes::OP_BR_IF())
    writer_core::emit_leb128_u(w, depth)
}

fn emit_gc_br(w: WasmWriter, depth: i32) {
    writer_core::emit_byte(w, opcodes::OP_BR())
    writer_core::emit_leb128_u(w, depth)
}

fn emit_gc_i32_ge_s(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_GE_S())
}

fn emit_gc_i32_eq(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_EQ())
}

fn emit_gc_i32_ne(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_NE())
}

fn emit_gc_i32_gt_s(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_GT_S())
}

fn emit_gc_i32_add(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_ADD())
}

fn emit_gc_i32_sub(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_I32_SUB())
}

fn emit_gc_i32_const(w: WasmWriter, value: i32) {
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, value)
}

fn emit_gc_local_set(w: WasmWriter, local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, local)
}

fn emit_gc_local_get(w: WasmWriter, local: i32) {
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, local)
}

fn emit_gc_array_len(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::GC_PREFIX())
    writer_core::emit_leb128_u(w, opcodes::GC_ARRAY_LEN())
}

fn emit_gc_array_new(w: WasmWriter, type_idx: i32) {
    writer_core::emit_byte(w, opcodes::GC_PREFIX())
    writer_core::emit_leb128_u(w, opcodes::GC_ARRAY_NEW_DEFAULT())
    writer_core::emit_leb128_u(w, type_idx)
}

fn emit_gc_array_get_u(w: WasmWriter, type_idx: i32) {
    writer_core::emit_byte(w, opcodes::GC_PREFIX())
    writer_core::emit_leb128_u(w, opcodes::GC_ARRAY_GET_U())
    writer_core::emit_leb128_u(w, type_idx)
}

fn emit_gc_array_set(w: WasmWriter, type_idx: i32) {
    writer_core::emit_byte(w, opcodes::GC_PREFIX())
    writer_core::emit_leb128_u(w, opcodes::GC_ARRAY_SET())
    writer_core::emit_leb128_u(w, type_idx)
}

fn emit_gc_ref_null(w: WasmWriter, type_idx: i32) {
    writer_core::emit_byte(w, opcodes::OP_REF_NULL())
    writer_core::emit_leb128_u(w, type_idx)
}

fn emit_gc_if_void(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_IF())
    writer_core::emit_byte(w, 64)
}

fn emit_gc_else(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_ELSE())
}

fn emit_gc_end(w: WasmWriter) {
    writer_core::emit_byte(w, opcodes::OP_END())
}

fn emit_gc_ref_cast(w: WasmWriter, type_idx: i32) {
    writer_core::emit_byte(w, opcodes::OP_GC_PREFIX())
    writer_core::emit_leb128_u(w, opcodes::GC_REF_CAST())
    writer_core::emit_leb128_u(w, type_idx)
}

fn emit_gc_struct_get(w: WasmWriter, type_idx: i32, field_idx: i32) {
    writer_core::emit_byte(w, opcodes::OP_GC_PREFIX())
    writer_core::emit_leb128_u(w, opcodes::GC_STRUCT_GET())
    writer_core::emit_leb128_u(w, type_idx)
    writer_core::emit_leb128_u(w, field_idx)
}
