// Arukellt Selfhost - GC string chars intrinsic handler.
//
// GC target: text::chars creates Vec<char> as a GC Vec.
//   Vec<char> = (struct (field (mut (ref null (array (mut i32))))
//                       (field (mut i32)))
//
//   Creates: array.new_default A_i32 1 → array.set 0 char → struct.new vec_type

use wasm::opcodes
use wasm::ctx_scratch
use wasm::ctx_record
use wasm::emit_target
use wasm::writer_core
use wasm::writer_leb
use wasm::writer_gc
use wasm::ctx_gc_type

fn emit_text_chars_gc(w: WasmWriter, ctx: SelfEmitCtx) -> bool {
    // Stack: [src_char]  (i32 char value)
    // After: [vec_ref]   (GC Vec<char> containing the char)
    //
    // 1. Pop and save src_char
    // 2. array.new_default A_i32 1
    // 3. array.set 0 = src_char
    // 4. struct.new vec_type(data_array, 1)

    let s_src = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let arr_tmp = ctx_scratch::SelfEmitCtx_scratch_gc_i32_array_local(ctx, 0)
    let vec_type = ctx_gc_type::SelfEmitCtx_vec_type(ctx)
    let i32_array_type = ctx_gc_type::SelfEmitCtx_i32_array_type(ctx)

    // Step 1: Save source char
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_leb::emit_leb128_u(w, s_src)

    // Step 2: Create backing array of size 1
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_leb::emit_leb128_s(w, 1)
    writer_gc::emit_gc_array_new(w, i32_array_type)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_TEE())
    writer_leb::emit_leb128_u(w, arr_tmp)

    // Step 3: Store char at data[0]
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_leb::emit_leb128_s(w, 0)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, s_src)
    writer_gc::emit_gc_array_set(w, i32_array_type)

    // Step 4: Create Vec struct (data_array, len=1)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_leb::emit_leb128_u(w, arr_tmp)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_leb::emit_leb128_s(w, 1)
    writer_gc::emit_gc_struct_new(w, vec_type)

    return true
}
