use wasm::writer_core

fn parse_decimal_as_i64_emitter(text: String) -> i64 {
    let n = len(text)
    let mut result: i64 = 0
    let mut i = 0
    let mut neg = false
    if i < n && char_at(text, i) == 45 {
        neg = true
        i = i + 1
    }
    let mut stop = false
    while i < n && !stop {
        let d = char_at(text, i)
        if d >= 48 && d <= 57 {
            result = result * 10 + i32_to_i64(d - 48)
        } else {
            if d == 95 {
            } else {
                stop = true
            }
        }
        i = i + 1
    }
    if neg {
        result = 0 - result
    }
    result
}

fn emit_f64(w: writer_core::WasmWriter, val: f64) {
    let lo: i32 = f64_bits_lo(val)
    let hi: i32 = f64_bits_hi(val)
    writer_core::emit_u32_le(w, lo)
    writer_core::emit_u32_le(w, hi)
}
