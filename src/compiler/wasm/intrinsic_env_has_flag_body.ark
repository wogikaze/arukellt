// Arukellt Selfhost - env::has_flag implementation body.

use wasm::constants
use wasm::ctx_scratch
use wasm::opcodes
use wasm::writer_core
use wasm::intrinsics::helpers_control_branch
use wasm::intrinsics::helpers_control_loop
use wasm::intrinsics::helpers_control_structured
use wasm::intrinsics::helpers_core_misc
use wasm::intrinsics::helpers_core_locals
use wasm::intrinsics::helpers_memory_access
use wasm::intrinsics::helpers_numeric_i32_arith
use wasm::intrinsics::helpers_numeric_i32_compare
use wasm::intrinsics::helpers_numeric_i32_const

fn emit_has_flag(w: WasmWriter, ctx: SelfEmitCtx) -> bool {
    let s_flag = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_flen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_argc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_argv = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_cstr = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_clen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    let s_j = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 8)
    let s_found = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 9)
    emit_has_flag_setup(w, ctx)
    helpers_control_loop::emit_block_loop_header(w)
    emit_has_flag_loop_body(w, s_flag, s_flen, s_argc, s_i, s_argv, s_cstr, s_clen, s_j, s_found)
    helpers_control_loop::emit_block_loop_footer(w)
    helpers_core_locals::emit_local_get(w, s_found)
    return true
}

fn emit_has_flag_setup(w: WasmWriter, ctx: SelfEmitCtx) {
    let s_flag = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_flen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_argc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_argv = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_argv_buf = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_found = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 9)
    let s_bufsize = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 10)
    helpers_core_locals::emit_local_set(w, s_flag)
    helpers_core_locals::emit_local_get(w, s_flag)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_memory_access::emit_i32_load_default(w)
    helpers_core_locals::emit_local_set(w, s_flen)
    helpers_numeric_i32_const::emit_i32_const(w, constants::SCRATCH_ARGC())
    helpers_numeric_i32_const::emit_i32_const(w, constants::SCRATCH_ARGV_SIZE())
    helpers_core_misc::emit_call(w, 1)
    helpers_core_misc::emit_drop(w)
    helpers_numeric_i32_const::emit_i32_const(w, constants::SCRATCH_ARGC())
    helpers_memory_access::emit_i32_load_default(w)
    helpers_core_locals::emit_local_set(w, s_argc)
    emit_has_flag_alloc_argv(w, s_argc, s_argv, s_argv_buf, s_bufsize)
    helpers_core_locals::emit_local_get(w, s_argv)
    helpers_core_locals::emit_local_get(w, s_argv_buf)
    helpers_core_misc::emit_call(w, 2)
    helpers_core_misc::emit_drop(w)
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_found)
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_i)
}

fn emit_has_flag_alloc_argv(w: WasmWriter, s_argc: i32, s_argv: i32, s_argv_buf: i32, s_bufsize: i32) {
    helpers_core_misc::emit_heap_get(w)
    helpers_core_locals::emit_local_set(w, s_argv)
    helpers_core_misc::emit_heap_get(w)
    helpers_core_locals::emit_local_get(w, s_argc)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_mul(w)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_misc::emit_heap_set(w)
    helpers_numeric_i32_const::emit_i32_const(w, constants::SCRATCH_ARGV_SIZE())
    helpers_memory_access::emit_i32_load_default(w)
    helpers_core_locals::emit_local_set(w, s_bufsize)
    helpers_core_misc::emit_heap_get(w)
    helpers_core_locals::emit_local_set(w, s_argv_buf)
    helpers_core_misc::emit_heap_get(w)
    helpers_core_locals::emit_local_get(w, s_bufsize)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_numeric_i32_const::emit_i32_const(w, 3)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_numeric_i32_const::emit_i32_const(w, -4)
    writer_core::emit_byte(w, opcodes::OP_I32_AND())
    helpers_core_misc::emit_heap_set(w)
}

fn emit_has_flag_loop_body(w: WasmWriter, s_flag: i32, s_flen: i32, s_argc: i32, s_i: i32, s_argv: i32, s_cstr: i32, s_clen: i32, s_j: i32, s_found: i32) {
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_core_locals::emit_local_get(w, s_argc)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_found)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_argv)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_mul(w)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load_default(w)
    helpers_core_locals::emit_local_set(w, s_cstr)
    emit_has_flag_strlen(w, s_cstr, s_clen)
    emit_has_flag_compare(w, s_flag, s_flen, s_cstr, s_clen, s_j, s_found)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_i)
    helpers_control_branch::emit_br(w, 0)
}

fn emit_has_flag_strlen(w: WasmWriter, s_cstr: i32, s_clen: i32) {
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_clen)
    helpers_control_loop::emit_block_loop_header(w)
    helpers_core_locals::emit_local_get(w, s_cstr)
    helpers_core_locals::emit_local_get(w, s_clen)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load8_u_default(w)
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_numeric_i32_compare::emit_i32_eq(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_clen)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_clen)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_loop::emit_block_loop_footer(w)
}

fn emit_has_flag_compare(w: WasmWriter, s_flag: i32, s_flen: i32, s_cstr: i32, s_clen: i32, s_j: i32, s_found: i32) {
    helpers_control_loop::emit_void_block(w)
    helpers_core_locals::emit_local_get(w, s_clen)
    helpers_core_locals::emit_local_get(w, s_flen)
    helpers_numeric_i32_compare::emit_i32_ne(w)
    helpers_control_branch::emit_br_if(w, 0)
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_j)
    emit_has_flag_byte_loop(w, s_flag, s_flen, s_cstr, s_j)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_core_locals::emit_local_get(w, s_flen)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_structured::emit_if_empty(w)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_core_locals::emit_local_set(w, s_found)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
}

fn emit_has_flag_byte_loop(w: WasmWriter, s_flag: i32, s_flen: i32, s_cstr: i32, s_j: i32) {
    helpers_control_loop::emit_block_loop_header(w)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_core_locals::emit_local_get(w, s_flen)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_cstr)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load8_u_default(w)
    helpers_core_locals::emit_local_get(w, s_flag)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_memory_access::emit_i32_load8_u_default(w)
    helpers_numeric_i32_compare::emit_i32_ne(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_j)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_j)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_loop::emit_block_loop_footer(w)
}
