use mir::inst_accessors_literals
use mir::inst_accessors_shape
use mir::opcodes
use wasm::call_fallback
use wasm::call_hash
use wasm::call_indirect
use wasm::call_wit
use wasm::core_op_dispatch
use wasm::core_op_shadow
use wasm::inst_dispatch_arith
use wasm::inst_dispatch_const
use wasm::inst_dispatch_control
use wasm::inst_dispatch_convert
use wasm::inst_dispatch_local
use wasm::inst_dispatch_gc_hint
use wasm::inst_dispatch_gc_cast
use wasm::inst_dispatch_struct
use wasm::inst_future

fn emit_mir_inst_ctx(
    w: WasmWriter,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    prev_func_id_raw: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32,
    bindings: Vec<resolver::wit_import_bind::WitImportBinding>
) {
    if inst_dispatch_gc_cast::try_emit_gc_cast_inst(w, inst, ctx) {
        return
    }
    if inst_dispatch_const::try_emit_const_or_get_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op, bindings) {
        return
    }
    if inst_dispatch_local::try_emit_local_set_inst(w, inst, ctx, prev_op, prev_arg0, prev_arg1, next_op, next_arg1) {
        return
    }
    if inst_dispatch_arith::try_emit_arith_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if try_emit_call_inst(w, inst, ctx, prev_op, prev_arg0, prev_arg1, prev_func_id_raw, next_op, next_arg0, next_arg1, next2_op, bindings) {
        return
    }
    if inst_dispatch_convert::try_emit_convert_inst_with_prev(w, inst, ctx, prev_op, prev_arg0, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if inst_dispatch_control::try_emit_control_inst(w, inst, ctx) {
        return
    }
    if inst_dispatch_gc_hint::try_emit_gc_hint_inst(w, inst, ctx) {
        return
    }
    if inst_dispatch_struct::try_emit_struct_inst(w, inst, ctx, prev_op, prev_arg0, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if inst_future::try_emit_future_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
}

fn try_emit_call_inst(
    w: WasmWriter,
    inst: MirInst,
    ctx: SelfEmitCtx,
    prev_op: i32,
    prev_arg0: i32,
    prev_arg1: i32,
    prev_func_id_raw: i32,
    next_op: i32,
    next_arg0: i32,
    next_arg1: i32,
    next2_op: i32,
    bindings: Vec<resolver::wit_import_bind::WitImportBinding>
) -> bool {
    if call_wit::try_emit_wit_call(w, inst, ctx, bindings, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if inst_accessors_shape::MirInst_op(inst) == opcodes::MIR_CALL_INDIRECT() {
        call_indirect::emit_call_indirect_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op)
        return true
    }
    if inst_accessors_shape::MirInst_op(inst) != opcodes::MIR_CALL() {
        return false
    }
    let callee = clone(inst_accessors_literals::MirInst_str_val(inst))
    core_op_shadow::core_op_shadow_observe_call(ctx, inst, clone(callee))
    if core_op_dispatch::try_emit_call_via_core_op_registry(
        w,
        inst,
        ctx,
        prev_op,
        prev_arg0,
        prev_arg1,
        prev_func_id_raw,
        next_op,
        next_arg0,
        next_arg1,
        next2_op,
        len(bindings)
    ) {
        return true
    }
    if call_hash::try_emit_hash_call(w, callee, inst, ctx, next_op, next_arg0, next_arg1, next2_op, len(bindings)) {
        return true
    }
    call_fallback::emit_fallback_call(
        w,
        callee,
        inst,
        ctx,
        prev_op,
        prev_arg0,
        prev_arg1,
        next_op,
        next_arg0,
        next_arg1,
        next2_op,
        len(bindings)
    )
    true
}
