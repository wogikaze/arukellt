// Arukellt Selfhost - MIR instruction to Wasm dispatch

use wasm::inst_dispatch_arith
use wasm::inst_dispatch_call
use wasm::inst_dispatch_const
use wasm::inst_dispatch_control
use wasm::inst_dispatch_convert
use wasm::inst_dispatch_local
use wasm::inst_dispatch_gc_hint
use wasm::inst_dispatch_struct
use wasm::inst_future
use mir::inst_accessors_shape
use mir::inst_accessors_literals
use mir::inst_accessors_operands
use mir::opcodes
use wasm::writer_core
use wasm::writer_leb
use wasm::writer_gc
use wasm::ctx_gc_type

fn emit_mir_inst_ctx(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx, prev_op: i32, prev_arg0: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, bindings: Vec<resolver::wit_import_bind::WitImportBinding>) {
    if try_emit_gc_cast_inst(w, inst, ctx) {
        return
    }
    if inst_dispatch_const::try_emit_const_or_get_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if inst_dispatch_local::try_emit_local_set_inst(w, inst, ctx, prev_op, prev_arg0, next_op, next_arg1) {
        return
    }
    if inst_dispatch_arith::try_emit_arith_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if inst_dispatch_call::try_emit_call_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op, bindings) {
        return
    }
    if inst_dispatch_convert::try_emit_convert_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if inst_dispatch_control::try_emit_control_inst(w, inst, ctx) {
        return
    }
    if inst_dispatch_gc_hint::try_emit_gc_hint_inst(w, inst, ctx) {
        return
    }
    if inst_dispatch_struct::try_emit_struct_inst(w, inst, ctx, prev_op, prev_arg0, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
    if inst_future::try_emit_future_inst(w, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return
    }
}

fn try_emit_gc_cast_inst(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let op = inst_accessors_shape::MirInst_op(inst)
    if op == opcodes::MIR_REF_TEST() {
        let type_slot = inst_accessors_operands::MirInst_arg0(inst)
        let gc_type_idx = ctx_gc_type::SelfEmitCtx_enum_variant_type(ctx, type_slot)
        let scrut_local = inst_accessors_operands::MirInst_arg1(inst)
        let dest = inst_accessors_shape::MirInst_dest(inst)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
        writer_leb::emit_leb128_u(w, scrut_local)
        writer_gc::emit_gc_ref_test(w, gc_type_idx)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_leb::emit_leb128_u(w, dest)
        return true
    }
    if op == opcodes::MIR_REF_CAST() {
        let type_slot = inst_accessors_operands::MirInst_arg0(inst)
        let gc_type_idx = ctx_gc_type::SelfEmitCtx_enum_variant_type(ctx, type_slot)
        let scrut_local = inst_accessors_operands::MirInst_arg1(inst)
        let dest = inst_accessors_shape::MirInst_dest(inst)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
        writer_leb::emit_leb128_u(w, scrut_local)
        writer_gc::emit_gc_ref_cast(w, gc_type_idx)
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_leb::emit_leb128_u(w, dest)
        return true
    }
    false
}
