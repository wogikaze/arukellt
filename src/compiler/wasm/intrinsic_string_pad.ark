use wasm::ctx_scratch
use wasm::intrinsics::helpers_control_branch
use wasm::intrinsics::helpers_control_loop
use wasm::intrinsics::helpers_control_structured
use wasm::intrinsics::helpers_core_heap
use wasm::intrinsics::helpers_core_locals
use wasm::intrinsics::helpers_memory_access
use wasm::intrinsics::helpers_memory_stack
use wasm::intrinsics::helpers_numeric_i32_arith
use wasm::intrinsics::helpers_numeric_i32_compare
use wasm::intrinsics::helpers_numeric_i32_const

// Handler for: pad_left, text::pad_left
fn emit_pad_left(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s_str = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_width = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_fill = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_slen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_alloc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_pad = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_fb = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    emit_pad_read_args_and_len(w, s_str, s_width, s_fill, s_slen)
    helpers_core_locals::emit_local_get(w, s_slen)
    helpers_core_locals::emit_local_get(w, s_width)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_structured::emit_if_i32(w)
    helpers_core_locals::emit_local_get(w, s_str)
    helpers_control_structured::emit_else(w)
    emit_pad_delta_fill_and_alloc(w, s_width, s_slen, s_pad, s_fill, s_fb, s_alloc)
    emit_pad_fill_loop(w, s_alloc, s_slen, s_pad, s_i, s_fb, false)
    emit_pad_copy_source(w, s_alloc, s_str, s_slen, s_pad, true)
    emit_pad_result_ptr(w, s_alloc)
    helpers_control_structured::emit_end(w)
    return true
}

// Handler for: pad_right, text::pad_right
fn emit_pad_right(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s_str = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_width = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_fill = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_slen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_alloc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_pad = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_fb = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    emit_pad_read_args_and_len(w, s_str, s_width, s_fill, s_slen)
    helpers_core_locals::emit_local_get(w, s_slen)
    helpers_core_locals::emit_local_get(w, s_width)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_structured::emit_if_i32(w)
    helpers_core_locals::emit_local_get(w, s_str)
    helpers_control_structured::emit_else(w)
    emit_pad_delta_fill_and_alloc(w, s_width, s_slen, s_pad, s_fill, s_fb, s_alloc)
    emit_pad_copy_source(w, s_alloc, s_str, s_slen, s_pad, false)
    emit_pad_fill_loop(w, s_alloc, s_slen, s_pad, s_i, s_fb, true)
    emit_pad_result_ptr(w, s_alloc)
    helpers_control_structured::emit_end(w)
    return true
}

fn emit_pad_read_args_and_len(w: WasmWriter, s_str: i32, s_width: i32, s_fill: i32, s_slen: i32) {
    helpers_core_locals::emit_local_set(w, s_fill)
    helpers_core_locals::emit_local_set(w, s_width)
    helpers_core_locals::emit_local_set(w, s_str)
    helpers_core_locals::emit_local_get(w, s_str)
    helpers_memory_stack::emit_string_len_from_stack(w)
    helpers_core_locals::emit_local_set(w, s_slen)
}

fn emit_pad_delta_fill_and_alloc(w: WasmWriter, s_width: i32, s_slen: i32, s_pad: i32, s_fill: i32, s_fb: i32, s_alloc: i32) {
    helpers_core_locals::emit_local_get(w, s_width)
    helpers_core_locals::emit_local_get(w, s_slen)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_core_locals::emit_local_set(w, s_pad)
    helpers_core_locals::emit_local_get(w, s_fill)
    helpers_memory_access::emit_i32_load8_u_default(w)
    helpers_core_locals::emit_local_set(w, s_fb)
    helpers_core_heap::emit_heap_get(w)
    helpers_core_locals::emit_local_tee(w, s_alloc)
    helpers_core_locals::emit_local_get(w, s_width)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_heap::emit_heap_set(w)
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_core_locals::emit_local_get(w, s_width)
    helpers_memory_access::emit_i32_store_default(w)
}

fn emit_pad_fill_loop(w: WasmWriter, s_alloc: i32, s_offset: i32, s_pad: i32, s_i: i32, s_fb: i32, has_offset: bool) {
    helpers_numeric_i32_const::emit_i32_const(w, 0)
    helpers_core_locals::emit_local_set(w, s_i)
    helpers_control_loop::emit_block_loop_header(w)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_core_locals::emit_local_get(w, s_pad)
    helpers_numeric_i32_compare::emit_i32_ge_s(w)
    helpers_control_branch::emit_br_if(w, 1)
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    if has_offset {
        helpers_core_locals::emit_local_get(w, s_offset)
        helpers_numeric_i32_arith::emit_i32_add(w)
    }
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, s_fb)
    helpers_memory_access::emit_i32_store8_default(w)
    helpers_core_locals::emit_local_get(w, s_i)
    helpers_numeric_i32_const::emit_i32_const(w, 1)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, s_i)
    helpers_control_branch::emit_br(w, 0)
    helpers_control_structured::emit_end(w)
    helpers_control_structured::emit_end(w)
}

fn emit_pad_copy_source(w: WasmWriter, s_alloc: i32, s_str: i32, s_slen: i32, s_offset: i32, has_offset: bool) {
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    if has_offset {
        helpers_core_locals::emit_local_get(w, s_offset)
        helpers_numeric_i32_arith::emit_i32_add(w)
    }
    helpers_core_locals::emit_local_get(w, s_str)
    helpers_core_locals::emit_local_get(w, s_slen)
    helpers_memory_access::emit_memory_copy(w)
}

fn emit_pad_result_ptr(w: WasmWriter, s_alloc: i32) {
    helpers_core_locals::emit_local_get(w, s_alloc)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
}
