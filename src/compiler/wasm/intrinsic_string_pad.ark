use wasm::ctx_scratch
use wasm::ctx_record
use wasm::ctx_gc_type
use wasm::emit_target
use wasm::writer_gc
use wasm::string_gc_helpers
use wasm::intrinsic_string_pad_helpers
use wasm::intrinsics::helpers_control
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_numeric_i32

// Handler for: pad_left, text::pad_left
fn emit_pad_left(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        emit_pad_left_gc(w, inst, ctx)
        return true
    }
    let s_str = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_width = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_fill = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_slen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_alloc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_pad = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_fb = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    intrinsic_string_pad_helpers::emit_pad_read_args_and_len(w, s_str, s_width, s_fill, s_slen)
    helpers_core::emit_local_get(w, s_slen)
    helpers_core::emit_local_get(w, s_width)
    helpers_numeric_i32::emit_i32_ge_s(w)
    helpers_control::emit_if_i32(w)
    helpers_core::emit_local_get(w, s_str)
    helpers_control::emit_else(w)
    intrinsic_string_pad_helpers::emit_pad_delta_fill_and_alloc(w, s_width, s_slen, s_pad, s_fill, s_fb, s_alloc)
    intrinsic_string_pad_helpers::emit_pad_fill_loop(w, s_alloc, s_slen, s_pad, s_i, s_fb, false)
    intrinsic_string_pad_helpers::emit_pad_copy_source(w, s_alloc, s_str, s_slen, s_pad, true)
    intrinsic_string_pad_helpers::emit_pad_result_ptr(w, s_alloc)
    helpers_control::emit_end(w)
    return true
}

// Handler for: pad_right, text::pad_right
fn emit_pad_right(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        emit_pad_right_gc(w, inst, ctx)
        return true
    }
    let s_str = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 0)
    let s_width = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_fill = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_slen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let s_alloc = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 4)
    let s_pad = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_fb = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    intrinsic_string_pad_helpers::emit_pad_read_args_and_len(w, s_str, s_width, s_fill, s_slen)
    helpers_core::emit_local_get(w, s_slen)
    helpers_core::emit_local_get(w, s_width)
    helpers_numeric_i32::emit_i32_ge_s(w)
    helpers_control::emit_if_i32(w)
    helpers_core::emit_local_get(w, s_str)
    helpers_control::emit_else(w)
    intrinsic_string_pad_helpers::emit_pad_delta_fill_and_alloc(w, s_width, s_slen, s_pad, s_fill, s_fb, s_alloc)
    intrinsic_string_pad_helpers::emit_pad_copy_source(w, s_alloc, s_str, s_slen, s_pad, false)
    intrinsic_string_pad_helpers::emit_pad_fill_loop(w, s_alloc, s_slen, s_pad, s_i, s_fb, true)
    intrinsic_string_pad_helpers::emit_pad_result_ptr(w, s_alloc)
    helpers_control::emit_end(w)
    return true
}

// GC-target pad_left: string/fill are (ref null array_i8), result is new GC array.
fn emit_pad_left_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let g_str = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_width = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let g_fill = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 2)
    let s_slen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let g_result = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 3)
    let s_pad = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_fb = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    let string_type = ctx_gc_type::SelfEmitCtx_string_type(ctx)

    // Stack: [string_ref, width_i32, fill_ref]
    helpers_core::emit_local_set(w, g_fill)
    helpers_core::emit_local_set(w, s_width)
    helpers_core::emit_local_set(w, g_str)

    // s_slen = len(string)
    helpers_core::emit_local_get(w, g_str)
    writer_gc::emit_gc_array_len(w)
    helpers_core::emit_local_set(w, s_slen)

    // if s_slen >= s_width: result = g_str
    // else: allocate, fill, copy
    helpers_core::emit_local_get(w, s_slen)
    helpers_core::emit_local_get(w, s_width)
    helpers_numeric_i32::emit_i32_ge_s(w)
    string_gc_helpers::emit_gc_if_void(w)
    helpers_core::emit_local_get(w, g_str)
    helpers_core::emit_local_set(w, g_result)
    string_gc_helpers::emit_gc_else(w)
    // s_pad = s_width - s_slen
    helpers_core::emit_local_get(w, s_width)
    helpers_core::emit_local_get(w, s_slen)
    helpers_numeric_i32::emit_i32_sub(w)
    helpers_core::emit_local_set(w, s_pad)
    // s_fb = fill[0]
    helpers_core::emit_local_get(w, g_fill)
    helpers_numeric_i32::emit_i32_const(w, 0)
    writer_gc::emit_gc_array_get_u(w, string_type)
    helpers_core::emit_local_set(w, s_fb)
    // Allocate new array of size s_width
    helpers_core::emit_local_get(w, s_width)
    string_gc_helpers::emit_gc_array_new(w, string_type)
    helpers_core::emit_local_set(w, g_result)
    // Fill first s_pad bytes with s_fb
    emit_pad_gc_fill_loop(w, g_result, s_pad, s_i, s_fb, string_type)
    // Copy original string to dest at offset s_pad
    emit_pad_gc_copy_source(w, g_result, g_str, s_slen, s_pad, string_type)
    string_gc_helpers::emit_gc_end(w)

    // Result on stack
    helpers_core::emit_local_get(w, g_result)
}

// GC-target pad_right: string/fill are (ref null array_i8), result is new GC array.
fn emit_pad_right_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let g_str = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 0)
    let s_width = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let g_fill = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 2)
    let s_slen = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let g_result = ctx_scratch::SelfEmitCtx_scratch_gc_local(ctx, 3)
    let s_pad = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 5)
    let s_i = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 6)
    let s_fb = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 7)
    let string_type = ctx_gc_type::SelfEmitCtx_string_type(ctx)

    // Stack: [string_ref, width_i32, fill_ref]
    helpers_core::emit_local_set(w, g_fill)
    helpers_core::emit_local_set(w, s_width)
    helpers_core::emit_local_set(w, g_str)

    // s_slen = len(string)
    helpers_core::emit_local_get(w, g_str)
    writer_gc::emit_gc_array_len(w)
    helpers_core::emit_local_set(w, s_slen)

    // if s_slen >= s_width: result = g_str
    // else: allocate, copy, fill
    helpers_core::emit_local_get(w, s_slen)
    helpers_core::emit_local_get(w, s_width)
    helpers_numeric_i32::emit_i32_ge_s(w)
    string_gc_helpers::emit_gc_if_void(w)
    helpers_core::emit_local_get(w, g_str)
    helpers_core::emit_local_set(w, g_result)
    string_gc_helpers::emit_gc_else(w)
    // s_pad = s_width - s_slen
    helpers_core::emit_local_get(w, s_width)
    helpers_core::emit_local_get(w, s_slen)
    helpers_numeric_i32::emit_i32_sub(w)
    helpers_core::emit_local_set(w, s_pad)
    // s_fb = fill[0]
    helpers_core::emit_local_get(w, g_fill)
    helpers_numeric_i32::emit_i32_const(w, 0)
    writer_gc::emit_gc_array_get_u(w, string_type)
    helpers_core::emit_local_set(w, s_fb)
    // Allocate new array of size s_width
    helpers_core::emit_local_get(w, s_width)
    string_gc_helpers::emit_gc_array_new(w, string_type)
    helpers_core::emit_local_set(w, g_result)
    // Copy original string to dest at offset 0
    emit_pad_gc_copy_source(w, g_result, g_str, s_slen, s_pad, string_type)
    // Fill from s_slen to s_width with s_fb
    emit_pad_gc_fill_loop_offset(w, g_result, s_slen, s_pad, s_i, s_fb, string_type)
    string_gc_helpers::emit_gc_end(w)

    // Result on stack
    helpers_core::emit_local_get(w, g_result)
}

fn emit_pad_gc_fill_loop(w: WasmWriter, g_result: i32, s_pad: i32, s_i: i32, s_fb: i32, string_type: i32) {
    string_gc_helpers::emit_gc_i32_const(w, 0)
    helpers_core::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_block_loop(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_core::emit_local_get(w, s_pad)
    string_gc_helpers::emit_gc_i32_ge_s(w)
    string_gc_helpers::emit_gc_br_if(w, 1)
    // dest[i] = fill_byte
    helpers_core::emit_local_get(w, g_result)
    helpers_core::emit_local_get(w, s_i)
    helpers_core::emit_local_get(w, s_fb)
    string_gc_helpers::emit_gc_array_set(w, string_type)
    helpers_core::emit_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_br(w, 0)
    string_gc_helpers::emit_gc_block_loop_end(w)
}

fn emit_pad_gc_fill_loop_offset(w: WasmWriter, g_result: i32, s_offset: i32, s_pad: i32, s_i: i32, s_fb: i32, string_type: i32) {
    string_gc_helpers::emit_gc_i32_const(w, 0)
    helpers_core::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_block_loop(w)
    helpers_core::emit_local_get(w, s_i)
    helpers_core::emit_local_get(w, s_pad)
    string_gc_helpers::emit_gc_i32_ge_s(w)
    string_gc_helpers::emit_gc_br_if(w, 1)
    // dest[s_offset + i] = fill_byte
    helpers_core::emit_local_get(w, g_result)
    helpers_core::emit_local_get(w, s_offset)
    helpers_core::emit_local_get(w, s_i)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_get(w, s_fb)
    string_gc_helpers::emit_gc_array_set(w, string_type)
    helpers_core::emit_local_get(w, s_i)
    string_gc_helpers::emit_gc_i32_const(w, 1)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_set(w, s_i)
    string_gc_helpers::emit_gc_br(w, 0)
    string_gc_helpers::emit_gc_block_loop_end(w)
}

fn emit_pad_gc_copy_source(w: WasmWriter, g_result: i32, g_str: i32, s_slen: i32, s_offset: i32, string_type: i32) {
    // array.copy: [dst_ref, dst_offset, src_ref, src_offset, n]
    helpers_core::emit_local_get(w, g_result)
    helpers_core::emit_local_get(w, s_offset)
    helpers_core::emit_local_get(w, g_str)
    helpers_numeric_i32::emit_i32_const(w, 0)
    helpers_core::emit_local_get(w, s_slen)
    writer_gc::emit_gc_array_copy(w, string_type, string_type)
}

