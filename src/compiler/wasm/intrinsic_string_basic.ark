use mir::inst_accessors_operands
use wasm::ctx_scratch
use wasm::ctx_string_view
use wasm::ctx_record
use wasm::emit_target
use wasm::writer_gc
use wasm::intrinsics::helpers_control_structured
use wasm::intrinsics::helpers_core_heap
use wasm::intrinsics::helpers_core_locals
use wasm::intrinsics::helpers_memory_access
use wasm::intrinsics::helpers_memory_stack
use wasm::intrinsics::helpers_numeric_i32_arith
use wasm::intrinsics::helpers_numeric_i32_const

// Handler for: String_from, clone
fn emit_clone(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
                                                                                                                        let _nop = 0
    return true
    }

// Handler for: len
fn emit_len(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        writer_gc::emit_gc_array_len(w)
    } else {
        helpers_memory_stack::emit_string_len_from_stack(w)
    }
    return true
    }

// Handler for: bool_to_string, text::format_bool, convert::bool_to_string
fn emit_bool_to_string(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
                                                                                                                                let s_tmp = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
                                                                                                                                helpers_core_locals::emit_local_set(w, s_tmp)
                                                                                                                                helpers_core_locals::emit_local_get(w, s_tmp)
                                                                                                                                helpers_control_structured::emit_if_i32(w)
                                                                                                                                let true_offset = ctx_string_view::SelfEmitCtx_true_string_offset(ctx)
                                                                                                                                helpers_numeric_i32_const::emit_i32_const(w, true_offset)
                                                                                                                                helpers_control_structured::emit_else(w)
                                                                                                                                let false_offset = ctx_string_view::SelfEmitCtx_false_string_offset(ctx)
                                                                                                                                helpers_numeric_i32_const::emit_i32_const(w, false_offset)
                                                                                                                                helpers_control_structured::emit_end(w)
    return true
    }

// Handler for: concat, text::concat
fn emit_concat(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let s_a = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let s_b = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let s_la = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)
    let s_rp = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 3)
    let total_len = inst_accessors_operands::MirInst_dest(inst)
    emit_concat_setup(w, s_a, s_b, s_la, total_len)
    emit_concat_alloc(w, s_rp, total_len)
    emit_concat_copy(w, s_a, s_b, s_la, s_rp, total_len)
    helpers_core_locals::emit_local_get(w, s_rp)
    return true
}

fn emit_concat_setup(w: WasmWriter, a_local: i32, b_local: i32, len_a_local: i32, total_len_local: i32) {
    helpers_core_locals::emit_local_set(w, b_local)
    helpers_core_locals::emit_local_set(w, a_local)
    helpers_memory_stack::emit_load_string_len_to_local(w, a_local, len_a_local)
    helpers_core_locals::emit_local_get(w, b_local)
    helpers_memory_stack::emit_string_len_from_stack(w)
    helpers_core_locals::emit_local_get(w, len_a_local)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, total_len_local)
}

fn emit_concat_alloc(w: WasmWriter, result_ptr_local: i32, total_len_local: i32) {
    helpers_core_heap::emit_heap_get(w)
    helpers_core_locals::emit_local_get(w, total_len_local)
    helpers_memory_access::emit_i32_store_default(w)
    helpers_core_heap::emit_heap_get(w)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_set(w, result_ptr_local)
    helpers_core_heap::emit_heap_get(w)
    helpers_numeric_i32_const::emit_i32_const(w, 4)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, total_len_local)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_heap::emit_heap_set(w)
}

fn emit_concat_copy(w: WasmWriter, a_local: i32, b_local: i32, len_a_local: i32, result_ptr_local: i32, total_len_local: i32) {
    helpers_core_locals::emit_local_get(w, result_ptr_local)
    helpers_core_locals::emit_local_get(w, a_local)
    helpers_core_locals::emit_local_get(w, len_a_local)
    helpers_memory_access::emit_memory_copy(w)

    helpers_core_locals::emit_local_get(w, result_ptr_local)
    helpers_core_locals::emit_local_get(w, len_a_local)
    helpers_numeric_i32_arith::emit_i32_add(w)
    helpers_core_locals::emit_local_get(w, b_local)
    helpers_core_locals::emit_local_get(w, total_len_local)
    helpers_core_locals::emit_local_get(w, len_a_local)
    helpers_numeric_i32_arith::emit_i32_sub(w)
    helpers_memory_access::emit_memory_copy(w)
}
