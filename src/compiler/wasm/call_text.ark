use wasm::call_text_core
use wasm::call_text_extra
use wasm::inst_store
use wasm::intrinsic_string_collection
use wasm::intrinsic_string_format
use wasm::call_text_mir_view
use mir::inst_accessors_operands
use mir::inst_record
use mir::opcodes as mir_opcodes
use wasm::ctx_record
use wasm::emit_target
use wasm::opcodes
use wasm::writer_core

fn try_emit_text_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if call_text_core::try_emit_text_core_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_format_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_collection_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if call_text_extra::try_emit_text_extra_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_collection_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_text_collection_view_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_text_collection_join_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_text_collection_join_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_join(){
        let _result_on_stack = intrinsic_string_collection::emit_join(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_split(){
        let _result_on_stack = intrinsic_string_collection::emit_split(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_text_collection_view_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_string_slice(){
        let _result_on_stack = intrinsic_string_collection::emit_slice(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_chars(){
        let _result_on_stack = intrinsic_string_collection::emit_text_chars(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_text_format_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if try_emit_numeric_text_format_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_char_text_format_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    if try_emit_string_text_format_call(w, handler_id, inst, ctx, next_op, next_arg0, next_arg1, next2_op) {
        return true
    }
    false
}

fn try_emit_char_text_format_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_char_to_string(){
        let _result_on_stack = intrinsic_string_format::emit_char_to_string(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_push_char(){
        let _result_on_stack = intrinsic_string_format::emit_push_char(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn try_emit_numeric_text_format_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_to_string(){
        let arg_vt = to_string_arg_vt(inst, ctx)
        if arg_vt == call_text_mir_view::VT_I64() {
            let _result_on_stack = intrinsic_string_format::emit_i64_to_string(w, inst, ctx)
            finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, text_call_result_on_stack(inst, _result_on_stack))
            return true
        }
        if arg_vt == call_text_mir_view::VT_F64() {
            let _result_on_stack = intrinsic_string_format::emit_f64_to_string(w, inst, ctx)
            finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, text_call_result_on_stack(inst, _result_on_stack))
            return true
        }
        if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) && to_string_arg_is_ref(inst, ctx) {
            finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
            return true
        }
        let _result_on_stack = intrinsic_string_format::emit_to_string(w, inst, ctx)
        finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, text_call_result_on_stack(inst, _result_on_stack))
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_format_i64(){
        let _result_on_stack = intrinsic_string_format::emit_i64_to_string(w, inst, ctx)
        finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, text_call_result_on_stack(inst, _result_on_stack))
        return true
    }
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_format_f64(){
        let _result_on_stack = intrinsic_string_format::emit_f64_to_string(w, inst, ctx)
        finish_text_call(w, inst, next_op, next_arg0, next_arg1, next2_op, text_call_result_on_stack(inst, _result_on_stack))
        return true
    }
    false
}

fn try_emit_string_text_format_call(w: WasmWriter, handler_id: i32, inst: MirInst, ctx: SelfEmitCtx, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) -> bool {
    if handler_id == corehir::core_op_registry_generated::core_op_handler_text_String_new(){
        let _result_on_stack = intrinsic_string_format::emit_String_new(w, inst, ctx)
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, _result_on_stack)
        return true
    }
    false
}

fn finish_text_call(w: WasmWriter, inst: MirInst, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, result_on_stack: bool) -> bool {
    // String format results must land in dest before a following CALL that
    // reads the local (dump_mir print path). Skipping the store leaves the
    // ptr on the stack and validates as "values remaining on stack".
    if result_on_stack &&
    inst_accessors_operands::MirInst_dest(inst) >= 0 &&
    should_force_text_call_dest_store(next_op, next_arg0) {
        writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
        writer_core::emit_leb128_u(w, inst_accessors_operands::MirInst_dest(inst))
    } else {
        inst_store::emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, result_on_stack)
    }
    true
}

fn should_force_text_call_dest_store(next_op: i32, next_arg0: i32) -> bool {
    if next_op == mir_opcodes::MIR_CALL() && next_arg0 >= 0 {
        return true
    }
    if next_op == mir_opcodes::MIR_WIT_CALL() && next_arg0 >= 0 {
        return true
    }
    false
}

fn text_call_result_on_stack(inst: MirInst, default_on_stack: bool) -> bool {
    default_on_stack
}

// Check if the argument to to_string is a reference type (String) on GC targets.
// When the argument is already a String ref, the i32 to_string intrinsic must be
// skipped and the String ref passed through unchanged.
fn to_string_arg_is_ref(inst: MirInst, ctx: SelfEmitCtx) -> bool {
    let arg0 = inst_accessors_operands::MirInst_arg0(inst)
    if arg0 < 0 {
        // Value is on the stack (not from a local). Check the dest local type
        // or infer from the call context. For stack values, we assume it's
        // not a ref unless we can prove otherwise.
        return false
    }
    let f = ctx_record::SelfEmitCtx_function_at(ctx, ctx_record::SelfEmitCtx_current_func_idx(ctx))
    if arg0 >= call_text_mir_view::local_count(f) {
        return false
    }
    let loc = call_text_mir_view::local_at(f, arg0)
    let type_name = call_text_mir_view::local_type_name(loc)
    if eq(clone(type_name), String_from("String")) || eq(clone(type_name), String_from("string")) {
        return true
    }
    false
}

fn to_string_arg_vt(inst: MirInst, ctx: SelfEmitCtx) -> i32 {
    let arg0 = inst_accessors_operands::MirInst_arg0(inst)
    if arg0 < 0 {
        // Value is a constant on the stack. Use the instruction's val_type
        // to determine the correct to_string variant (i32 vs i64 vs f64).
        let vt = inst_record::mir_inst_val_type(inst)
        if vt == call_text_mir_view::VT_I64() {
            return call_text_mir_view::VT_I64()
        }
        if vt == call_text_mir_view::VT_F64() {
            return call_text_mir_view::VT_F64()
        }
        return call_text_mir_view::VT_I32()
    }
    let f = ctx_record::SelfEmitCtx_function_at(ctx, ctx_record::SelfEmitCtx_current_func_idx(ctx))
    if arg0 >= call_text_mir_view::local_count(f) {
        return call_text_mir_view::VT_I32()
    }
    let loc = call_text_mir_view::local_at(f, arg0)
    let type_name = call_text_mir_view::local_type_name(loc)
    if eq(clone(type_name), String_from("i64")) || eq(clone(type_name), String_from("I64")) {
        return call_text_mir_view::VT_I64()
    }
    if eq(clone(type_name), String_from("f64")) || eq(clone(type_name), String_from("F64")) {
        return call_text_mir_view::VT_F64()
    }
    // Fallback: check the local's val_type for i64/f64.
    let vt = call_text_mir_view::local_val_type(loc)
    if vt == call_text_mir_view::VT_I64() {
        return call_text_mir_view::VT_I64()
    }
    if vt == call_text_mir_view::VT_F64() {
        return call_text_mir_view::VT_F64()
    }
    call_text_mir_view::VT_I32()
}
