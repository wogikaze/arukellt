//
// GC target: emits struct.new + array.new_default for Vec<T> GC representation.
//   Vec<T> = (struct (field (mut (ref null (array (mut i32))))  ;; data array
//                     (field (mut i32)))                         ;; len
// Linear-memory target: bump-allocated vec header + data with u32
// wraparound detection on the total allocation size.

use wasm::opcodes
use wasm::writer_core
use wasm::writer_gc
use wasm::ctx_gc_type
use wasm::ctx_gc_type_locals
use wasm::ctx_gc_type_vec_ref
use wasm::emit_target
use wasm::ctx_record
use wasm::ctx_scratch
use wasm::intrinsics::helpers_core
use wasm::intrinsics::helpers_memory
use wasm::intrinsics::helpers_numeric_i32
use mir::inst_accessors_operands
use mir::inst_accessors_literals
use wasm::intrinsic_vec_type

fn emit_vec_new_layout(w: WasmWriter, heap_bump: i32, _result_back_delta: i32, inst: MirInst, ctx: SelfEmitCtx) {
    if emit_target::is_gc_target(ctx_record::SelfEmitCtx_target(ctx)) {
        emit_vec_new_layout_gc(w, inst, ctx)
    } else {
        emit_vec_new_layout_lm(w, heap_bump, inst, ctx)
    }
}

fn emit_vec_new_layout_gc(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    let dest_local = inst_accessors_operands::MirInst_dest(inst)
    let vec_type = intrinsic_vec_type::resolve_vec_type_for_new_dest(ctx, dest_local)
    let array_type = intrinsic_vec_type::resolve_array_type_for_new_dest(ctx, dest_local)
    let is_vec_string = vec_type == ctx_gc_type::SelfEmitCtx_vec_string_type(ctx)
    let is_vec_v128 = vec_type == ctx_gc_type::SelfEmitCtx_vec_v128_type(ctx)
    let is_vec_i64 = vec_type == ctx_gc_type::SelfEmitCtx_vec_i64_type(ctx)
    let is_vec_f64 = vec_type == ctx_gc_type::SelfEmitCtx_vec_f64_type(ctx)
    let is_vec_sref = vec_type == ctx_gc_type_vec_ref::SelfEmitCtx_vec_struct_ref_type(ctx)
    let arr_tmp = if is_vec_string {
        ctx_scratch::SelfEmitCtx_scratch_gc_string_ref_array_local(ctx, 0)
    } else if is_vec_v128 {
        ctx_scratch::SelfEmitCtx_scratch_gc_v128_array_local(ctx, 0)
    } else if is_vec_i64 {
        ctx_scratch::SelfEmitCtx_scratch_gc_i64_array_local(ctx, 0)
    } else if is_vec_f64 {
        ctx_scratch::SelfEmitCtx_scratch_gc_f64_array_local(ctx, 0)
    } else if is_vec_sref {
        ctx_scratch::SelfEmitCtx_scratch_gc_struct_ref_array_local(ctx, 0)
    } else {
        ctx_scratch::SelfEmitCtx_scratch_gc_i32_array_local(ctx, 0)
    }

    // Step 1-2: Create backing array with the requested capacity. Constructors
    // without a capacity argument retain the established default of eight.
    if inst_accessors_literals::MirInst_int_val(inst) > 0 {
        let capacity = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
        helpers_core::emit_local_set(w, capacity)
        helpers_core::emit_local_get(w, capacity)
        writer_gc::emit_gc_array_new_from_widened(w, array_type)
    } else {
        writer_core::emit_byte(w, opcodes::OP_I32_CONST())
        writer_core::emit_leb128_s(w, 8)
        writer_gc::emit_gc_array_new(w, array_type)
    }
    writer_gc::emit_gc_ref_cast(w, array_type)
    writer_core::emit_byte(w, opcodes::OP_LOCAL_SET())
    writer_core::emit_leb128_u(w, arr_tmp)

    // Step 3: Create Vec struct with field 0 = array, field 1 = 0 (len)
    // struct.new takes all field values on the stack in order.
    writer_core::emit_byte(w, opcodes::OP_LOCAL_GET())
    writer_core::emit_leb128_u(w, arr_tmp)
    writer_gc::emit_gc_ref_cast(w, array_type)
    writer_core::emit_byte(w, opcodes::OP_I32_CONST())
    writer_core::emit_leb128_s(w, 0)
    writer_gc::emit_gc_struct_new(w, vec_type)
    writer_gc::emit_gc_ref_cast(w, vec_type)
}

fn ctx_has_vec_string_local(ctx: SelfEmitCtx) -> bool {
    if ctx_gc_type_locals::SelfEmitCtx_is_vec_string_context(ctx) {
        return true
    }
    ctx_gc_type_locals::ctx_has_vec_string_local(ctx)
}

fn emit_vec_new_layout_lm(w: WasmWriter, heap_bump: i32, inst: MirInst, ctx: SelfEmitCtx) {
    // Constructors with a capacity argument pass that value on the stack.
    // The linear-memory path currently reserves a fixed default-capacity buffer
    // (heap_bump bytes) and consumes the argument only to keep the stack clean.
    if inst_accessors_literals::MirInst_int_val(inst) > 0 {
        helpers_core::emit_drop(w)
    }
    let total_size = heap_bump + 12

    let old_result = ctx_scratch::SelfEmitCtx_scratch_base(ctx)
    let new_end = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 1)
    let result = ctx_scratch::SelfEmitCtx_scratch_local(ctx, 2)

    // old_result = current heap pointer
    helpers_core::emit_heap_get(w)
    helpers_core::emit_local_set(w, old_result)

    // new_end = old_result + total_size (may wrap around 2^32)
    helpers_core::emit_local_get(w, old_result)
    helpers_numeric_i32::emit_i32_const(w, total_size)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_set(w, new_end)

    // result = (new_end < old_result) ? 0 : old_result
    helpers_numeric_i32::emit_i32_const(w, 0)
    helpers_core::emit_local_get(w, old_result)
    helpers_core::emit_local_get(w, new_end)
    helpers_core::emit_local_get(w, old_result)
    helpers_numeric_i32::emit_i32_lt_u(w)
    writer_core::emit_byte(w, opcodes::OP_SELECT())
    helpers_core::emit_local_set(w, result)

    // new_end = (new_end < old_result) ? total_size : new_end
    helpers_numeric_i32::emit_i32_const(w, total_size)
    helpers_core::emit_local_get(w, new_end)
    helpers_core::emit_local_get(w, new_end)
    helpers_core::emit_local_get(w, old_result)
    helpers_numeric_i32::emit_i32_lt_u(w)
    writer_core::emit_byte(w, opcodes::OP_SELECT())
    helpers_core::emit_local_set(w, new_end)

    // Advance the heap to new_end and ensure memory is grown if needed.
    helpers_core::emit_local_get(w, new_end)
    helpers_core::emit_heap_set(w)

    // Write the Vec header at the result pointer.
    emit_vec_new_store_i32(w, result, 0, 0)
    emit_vec_new_store_i32(w, result, 4, 8)
    emit_vec_new_store_data_pointer(w, result)

    // Leave the result pointer on the stack for the caller.
    helpers_core::emit_local_get(w, result)
}

fn emit_vec_new_store_i32(w: WasmWriter, base_local: i32, offset: i32, value: i32) {
    helpers_core::emit_local_get(w, base_local)
    if offset != 0 {
        helpers_numeric_i32::emit_i32_const(w, offset)
        helpers_numeric_i32::emit_i32_add(w)
    }
    helpers_numeric_i32::emit_i32_const(w, value)
    helpers_memory::emit_i32_store(w, 0)
}

fn emit_vec_new_store_data_pointer(w: WasmWriter, base_local: i32) {
    helpers_core::emit_local_get(w, base_local)
    helpers_numeric_i32::emit_i32_const(w, 8)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_core::emit_local_get(w, base_local)
    helpers_numeric_i32::emit_i32_const(w, 12)
    helpers_numeric_i32::emit_i32_add(w)
    helpers_memory::emit_i32_store(w, 0)
}
