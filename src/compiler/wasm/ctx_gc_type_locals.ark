use wasm::ctx_record
use mir::function_identity
use mir::function_locals_view
use mir::local_access

fn SelfEmitCtx_is_vec_string_context(ctx: SelfEmitCtx) -> bool {
    let func_idx = ctx_record::SelfEmitCtx_current_func_idx(ctx)
    let f = ctx_record::SelfEmitCtx_function_at(ctx, func_idx)
    let name = function_identity::MirFunction_name(f)
    // Functions that operate on Vec<String> rather than Vec<i32>.
    if starts_with(clone(name), String_from("hashset_str_")) ||
    starts_with(clone(name), String_from("hash_vec_string_")) ||
    starts_with(clone(name), String_from("vec_string_")) ||
    starts_with(clone(name), String_from("hash_map_vec_string_")) {
        return true
    }
    false
}

fn ctx_has_vec_string_local(ctx: SelfEmitCtx) -> bool {
    let func_idx = ctx_record::SelfEmitCtx_current_func_idx(ctx)
    let f = ctx_record::SelfEmitCtx_function_at(ctx, func_idx)
    let name = function_identity::MirFunction_name(f)
    if ends_with(clone(name), String_from("__String")) {
        return true
    }
    let nlocals = function_locals_view::MirFunction_local_count(f)
    let mut li = 0
    while li < nlocals {
        let loc = function_locals_view::MirFunction_local_at(f, li)
        let tname = local_access::MirLocal_type_name(loc)
        if eq(clone(tname), String_from("vec:String")) || eq(clone(tname), String_from("vec:string")) {
            return true
        }
        li = li + 1
    }
    false
}

