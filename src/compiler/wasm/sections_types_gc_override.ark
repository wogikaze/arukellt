// Arukellt Selfhost - Wasm type section GC type sig override helpers.

use wasm::emit_target
use wasm::sections_types_gc

fn gc_param_type_sig_override(fn_name: String, param_idx: i32, type_name: String, target: String) -> String {
    if !emit_target::is_gc_target(clone(target)) {
        return String_new()
    }
    // Generic monomorphizations: function names ending with __String have
    // String-typed params that the MIR may still represent as i32.
    if ends_with(clone(fn_name), String_from("__String")) {
        return sections_types_gc::gc_string_type_sig()
    }
    if param_idx != 0 {
        return String_new()
    }
    // Check function name before type_name: hashmap functions may have "vec:..."
    // type names (from their linear-memory representation) but need their proper
    // GC struct type assigned on GC targets.
    if starts_with(clone(fn_name), String_from("hash_string::hashmap_str_str_")) || starts_with(clone(fn_name), String_from("hashmap_str_str_")) {
        return sections_types_gc::gc_hashmap_str_str_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hash_string::hashmap_i32_str_")) || starts_with(clone(fn_name), String_from("hashmap_i32_str_")) {
        return sections_types_gc::gc_hashmap_i32_str_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hashmap_str_val_")) {
        return sections_types_gc::gc_hashmap_i32_str_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hashmap_str_")) || eq(clone(fn_name), String_from("hashmap_str_i32_new")) || starts_with(clone(fn_name), String_from("hash_string::hashmap_str_")) {
        return sections_types_gc::gc_hashmap_str_i32_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hashmap_")) || starts_with(clone(fn_name), String_from("hashset_")) || starts_with(clone(fn_name), String_from("hash::hashmap_")) || starts_with(clone(fn_name), String_from("hash::hashset_")) {
        // Exclude helper functions whose first parameter is i32, not Vec.
        if eq(clone(fn_name), String_from("hashmap_key_index")) || eq(clone(fn_name), String_from("hashmap_value_index")) || eq(clone(fn_name), String_from("hashmap_flag_index")) || eq(clone(fn_name), String_from("hashmap_required_vec_len")) || eq(clone(fn_name), String_from("hashmap_min_capacity_for_entries")) || eq(clone(fn_name), String_from("hashmap_with_capacity")) {
            return String_new()
        }
        // hashset_str_* and hash_vec_string_* functions take Vec<String>, not Vec<i32>.
        if starts_with(clone(fn_name), String_from("hashset_str_")) || starts_with(clone(fn_name), String_from("hash_vec_string_")) {
            return sections_types_gc::gc_vec_string_type_sig()
        }
        return sections_types_gc::gc_vec_type_sig()
    }
    if len(type_name) > 0 {
        return String_new()
    }
    String_new()
}

fn gc_enum_return_type_sig(type_name: String, target: String) -> String {
    if !emit_target::is_gc_target(clone(target)) {
        return String_new()
    }
    if starts_with(clone(type_name), String_from("enum:")) {
        return sections_types_gc::gc_enum_open_type_sig()
    }
    if starts_with(clone(type_name), String_from("option:")) || starts_with(clone(type_name), String_from("Option:")) {
        return sections_types_gc::gc_enum_open_type_sig()
    }
    if starts_with(clone(type_name), String_from("Option_")) {
        return sections_types_gc::gc_enum_open_type_sig()
    }
    if eq(clone(type_name), String_from("Option")) {
        return sections_types_gc::gc_enum_open_type_sig()
    }
    String_new()
}

fn gc_return_type_sig_override(fn_name: String, type_name: String, target: String) -> String {
    if !emit_target::is_gc_target(clone(target)) {
        return String_new()
    }
    let enum_sig = gc_enum_return_type_sig(clone(type_name), clone(target))
    if len(enum_sig) > 0 {
        return enum_sig
    }
    if gc_fn_returns_option(clone(fn_name)) {
        return sections_types_gc::gc_enum_open_type_sig()
    }
    if len(type_name) > 0 {
        return String_new()
    }
    if starts_with(clone(fn_name), String_from("hashmap_str_i32_new")) || eq(clone(fn_name), String_from("hashmap_str_i32_new")) {
        return sections_types_gc::gc_hashmap_str_i32_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hash_string::hashmap_i32_str_new")) {
        return sections_types_gc::gc_hashmap_i32_str_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hash_string::hashmap_str_str_new")) {
        return sections_types_gc::gc_hashmap_str_str_type_sig()
    }
    if starts_with(clone(fn_name), String_from("hashmap_new")) || starts_with(clone(fn_name), String_from("hashmap_with_capacity")) {
        return sections_types_gc::gc_vec_type_sig()
    }
    String_new()
}

fn gc_fn_returns_option(fn_name: String) -> bool {
    if eq(clone(fn_name), String_from("hashmap_get_option")) || eq(clone(fn_name), String_from("hash::hashmap_get_option")) || eq(clone(fn_name), String_from("HashMap_i32_i32_get")) {
        return true
    }
    if eq(clone(fn_name), String_from("hashmap_remove")) || eq(clone(fn_name), String_from("hash::hashmap_remove")) || eq(clone(fn_name), String_from("HashMap_i32_i32_remove")) {
        return true
    }
    if eq(clone(fn_name), String_from("hash_string::hashmap_str_get")) || eq(clone(fn_name), String_from("hashmap_str_get")) || eq(clone(fn_name), String_from("hash::hashmap_str_get")) || eq(clone(fn_name), String_from("HashMap_String_i32_get")) {
        return true
    }
    if eq(clone(fn_name), String_from("hash_string::hashmap_str_remove")) || eq(clone(fn_name), String_from("hashmap_str_remove")) || eq(clone(fn_name), String_from("hash::hashmap_str_remove")) || eq(clone(fn_name), String_from("HashMap_String_i32_remove")) {
        return true
    }
    if eq(clone(fn_name), String_from("hashmap_str_val_get")) || eq(clone(fn_name), String_from("HashMap_i32_String_get")) || eq(clone(fn_name), String_from("hash_string::hashmap_i32_str_get")) {
        return true
    }
    if eq(clone(fn_name), String_from("hashmap_str_str_get")) || eq(clone(fn_name), String_from("HashMap_String_String_get")) || eq(clone(fn_name), String_from("hash_string::hashmap_str_str_get")) {
        return true
    }
    if eq(clone(fn_name), String_from("hashmap_str_str_remove")) || eq(clone(fn_name), String_from("HashMap_String_String_remove")) || eq(clone(fn_name), String_from("hash_string::hashmap_str_str_remove")) {
        return true
    }
    false
}
