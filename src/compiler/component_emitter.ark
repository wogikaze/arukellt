// Arukellt Selfhost — Wasm Component Binary Emitter
//
// Generates deterministic Wasm Component binaries from MIR.
// Handles component sections, type interning, and core module wrapping.
use std::host::stdio

// ── Component Section IDs ─────────────────────────────────────────────────────
fn COMP_SEC_CORE_MODULE() -> i32 {
    1
}

fn COMP_SEC_CORE_INSTANCE() -> i32 {
    2
}

fn COMP_SEC_CORE_TYPE() -> i32 {
	3
}

fn COMP_SEC_COMPONENT() -> i32 {
    4
}

fn COMP_SEC_INSTANCE() -> i32 {
	5
}

fn COMP_SEC_ALIAS() -> i32 {
	6
}

fn COMP_SEC_TYPE() -> i32 {
	7
}

fn COMP_SEC_CANON() -> i32 {
	8
}

fn COMP_SEC_START() -> i32 {
	9
}

fn COMP_SEC_IMPORT() -> i32 {
	10
}

fn COMP_SEC_EXPORT() -> i32 {
	11
}

// ── Component Model Sort Bytes ─────────────────────────────────────────────────
// Used in type/import/export sections to distinguish core vs component entities.
fn COMP_SORT_CORE_FUNC() -> i32 {
	0x00
}

fn COMP_SORT_CORE_MODULE() -> i32 {
	0x01
}

fn COMP_SORT_FUNC() -> i32 {
	0x40
}

fn COMP_SORT_INSTANCE() -> i32 {
	0x42
}

// ── Component Export/Import Sort Bytes ─────────────────────────────────────────
fn COMP_EXI_SORT_FUNC() -> i32 {
	0x01
}

fn COMP_EXI_SORT_MODULE() -> i32 {
	0x01
}

fn COMP_EXI_SORT_INSTANCE() -> i32 {
	0x02
}

fn COMP_EXI_SORT_COMPONENT() -> i32 {
	0x03
}

fn COMP_EXI_SORT_FUNC_COMP() -> i32 {
	0x10
}

// ── Canonical ABI Option Encodings ─────────────────────────────────────────────
fn COMP_CANON_LIFT() -> i32 {
	0x00
}

fn COMP_CANON_LOWER() -> i32 {
	0x01
}

fn COMP_CANON_OPTION_UTF8() -> i32 {
	0x00
}

fn COMP_CANON_OPTION_UTF16() -> i32 {
	0x01
}

fn COMP_CANON_OPTION_LATIN1() -> i32 {
	0x02
}

fn COMP_CANON_OPTION_STRING_ENCODING() -> i32 {
	0x00
}

fn COMP_CANON_OPTION_MEMORY() -> i32 {
	0x03
}

fn COMP_CANON_OPTION_REALLOC() -> i32 {
	0x04
}

fn COMP_CANON_OPTION_POST_RETURN() -> i32 {
	0x05
}

// ── WIT Primitive Value Types ───────────────────────────────────────────────────
// These are the component-model-level value type encodings (not core wasm types).
fn WIT_VAL_BOOL() -> i32 {
	0x7f
}

fn WIT_VAL_U8() -> i32 {
	0x7d
}

fn WIT_VAL_U16() -> i32 {
	0x7b
}

fn WIT_VAL_U32() -> i32 {
	0x79
}

fn WIT_VAL_U64() -> i32 {
	0x77
}

fn WIT_VAL_S8() -> i32 {
	0x7e
}

fn WIT_VAL_S16() -> i32 {
	0x7c
}

fn WIT_VAL_S32() -> i32 {
	0x7a
}

fn WIT_VAL_S64() -> i32 {
	0x78
}

fn WIT_VAL_FLOAT32() -> i32 {
	0x76
}

fn WIT_VAL_FLOAT64() -> i32 {
	0x75
}

fn WIT_VAL_CHAR() -> i32 {
	0x74
}

fn WIT_VAL_STRING() -> i32 {
	0x73
}

// ── WIT Composite Type Tags ─────────────────────────────────────────────────────
fn WIT_TAG_LIST() -> i32 {
	0x70
}

fn WIT_TAG_RECORD() -> i32 {
	0x72
}

fn WIT_TAG_VARIANT() -> i32 {
	0x71
}

fn WIT_TAG_FLAGS() -> i32 {
	0x6e
}

fn WIT_TAG_TUPLE() -> i32 {
	0x6f
}

fn WIT_TAG_OPTION() -> i32 {
	0x6b
}

fn WIT_TAG_RESULT() -> i32 {
	0x6a
}

fn WIT_TAG_OWN() -> i32 {
	0x69
}

fn WIT_TAG_BORROW() -> i32 {
	0x68
}

fn WIT_TAG_ENUM() -> i32 {
	0x6d
}

// ── Component Value Types ─────────────────────────────────────────────────────
// Component model value type encodings
fn COMP_VAL_TYPE_I32() -> i32 {
    0x7f  // i32
}

fn COMP_VAL_TYPE_I64() -> i32 {
    0x7e  // i64
}

fn COMP_VAL_TYPE_F32() -> i32 {
    0x7d  // f32
}

fn COMP_VAL_TYPE_F64() -> i32 {
    0x7c  // f64
}

fn COMP_VAL_TYPE_BOOL() -> i32 {
    0x7b  // bool
}

fn COMP_VAL_TYPE_CHAR() -> i32 {
    0x7a  // char
}

// ── Component Writer ──────────────────────────────────────────────────────────
struct ComponentWriter {
    bytes: Vec<i32>,
}

fn ComponentWriter_new() -> ComponentWriter {
    ComponentWriter { bytes: Vec_new_i32() }
}

fn comp_emit_byte(w: ComponentWriter, b: i32) {
    push(w.bytes, b % 256)
}

fn comp_emit_u32_le(w: ComponentWriter, v: i32) {
    comp_emit_byte(w, v % 256)
    comp_emit_byte(w, v / 256 % 256)
    comp_emit_byte(w, v / 65536 % 256)
    comp_emit_byte(w, v / 16777216 % 256)
}

fn comp_emit_leb128_u(w: ComponentWriter, v: i32) {
    let mut val = v
    if val < 0 {
        val = 0
    }
    let mut done = false
    while !done {
        let mut b = val % 128
        val = val / 128
        if val != 0 {
            b = b + 128
        }
        comp_emit_byte(w, b)
        if val == 0 {
            done = true
        }
    }
}

fn comp_emit_bytes(w: ComponentWriter, src: Vec<i32>) {
    let count = len(src)
    let mut i = 0
    while i < count {
        let b = get_unchecked(src, i)
        comp_emit_byte(w, b)
        i = i + 1
    }
}

fn comp_emit_string(w: ComponentWriter, s: String) {
    let slen = len(s)
    comp_emit_leb128_u(w, slen)
    let mut i = 0
    while i < slen {
        comp_emit_byte(w, char_at(s, i))
        i = i + 1
    }
}

fn comp_writer_size(w: ComponentWriter) -> i32 {
    len(w.bytes)
}

// ── Component Section Writer ──────────────────────────────────────────────────
fn comp_emit_section(out: ComponentWriter, section_id: i32, contents: ComponentWriter) {
    comp_emit_byte(out, section_id)
    comp_emit_leb128_u(out, comp_writer_size(contents))
    comp_emit_bytes(out, contents.bytes)
}

// ── Type Interner ──────────────────────────────────────────────────────────────
// Deduplicates type definitions emitted into the component type section.
// Uses a flat byte buffer paired with start/end offset arrays to avoid Vec<Vec<i32>>.
struct TypeInterner {
	type_data: Vec<i32>,
	type_starts: Vec<i32>,
	type_ends: Vec<i32>,
}

fn TypeInterner_new() -> TypeInterner {
	TypeInterner { type_data: Vec_new_i32(), type_starts: Vec_new_i32(), type_ends: Vec_new_i32() }
}

fn type_interner_count(interner: TypeInterner) -> i32 {
	len(interner.type_starts)
}

fn type_interner_add(interner: TypeInterner, type_bytes: Vec<i32>) -> i32 {
	let idx = len(interner.type_starts)
	let start = len(interner.type_data)
	let n = len(type_bytes)
	let mut i = 0
	while i < n {
		push(interner.type_data, get_unchecked(type_bytes, i))
		i = i + 1
	}
	push(interner.type_starts, start)
	push(interner.type_ends, start + n)
	idx
}

fn type_interner_emit_section(out: ComponentWriter, interner: TypeInterner) {
	let tw = ComponentWriter_new()
	let count = len(interner.type_starts)
	comp_emit_leb128_u(tw, count)
	let mut i = 0
	while i < count {
		let s = get_unchecked(interner.type_starts, i)
		let e = get_unchecked(interner.type_ends, i)
		let mut j = s
		while j < e {
			comp_emit_byte(tw, get_unchecked(interner.type_data, j))
			j = j + 1
		}
		i = i + 1
	}
	comp_emit_section(out, COMP_SEC_TYPE(), tw)
}

// ── WIT Type Encoding Helpers ──────────────────────────────────────────────────
// These emit a single WIT type definition into a temporary ComponentWriter.
fn comp_core_func_type(param_vts: Vec<i32>, result_vts: Vec<i32>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, COMP_SORT_CORE_FUNC())
	comp_emit_byte(w, 0x60)
	comp_emit_leb128_u(w, len(param_vts))
	let mut i = 0
	while i < len(param_vts) {
		comp_emit_byte(w, get_unchecked(param_vts, i))
		i = i + 1
	}
	comp_emit_leb128_u(w, len(result_vts))
	i = 0
	while i < len(result_vts) {
		comp_emit_byte(w, get_unchecked(result_vts, i))
		i = i + 1
	}
	w.bytes
}

fn comp_component_func_type(param_wit_types: Vec<i32>, result_wit_types: Vec<i32>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, COMP_SORT_FUNC())
	comp_emit_leb128_u(w, len(param_wit_types))
	let mut i = 0
	while i < len(param_wit_types) {
		comp_emit_string(w, concat(String_from("arg"), to_string(i)))
		comp_emit_byte(w, get_unchecked(param_wit_types, i))
		i = i + 1
	}
	if len(result_wit_types) > 0 {
		comp_emit_byte(w, 0x00)
		comp_emit_byte(w, get_unchecked(result_wit_types, 0))
	} else {
		comp_emit_byte(w, 0x01)
		comp_emit_leb128_u(w, 0)
	}
	w.bytes
}

fn comp_wit_string_type() -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_VAL_STRING())
	w.bytes
}

fn comp_wit_list_type(elem_type_idx: i32) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_LIST())
	comp_emit_leb128_u(w, elem_type_idx)
	w.bytes
}

fn comp_wit_option_type(elem_type_idx: i32) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_OPTION())
	comp_emit_leb128_u(w, elem_type_idx)
	w.bytes
}

fn comp_wit_result_type(ok_type_idx: i32, err_type_idx: i32) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_RESULT())
	comp_emit_byte(w, 0x01)
	comp_emit_leb128_u(w, ok_type_idx)
	comp_emit_byte(w, 0x01)
	comp_emit_leb128_u(w, err_type_idx)
	w.bytes
}

fn comp_wit_record_type(names: Vec<String>, type_indices: Vec<i32>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_RECORD())
	let count = len(names)
	comp_emit_leb128_u(w, count)
	let mut i = 0
	while i < count {
		comp_emit_string(w, get_unchecked(names, i))
		comp_emit_leb128_u(w, get_unchecked(type_indices, i))
		i = i + 1
	}
	w.bytes
}

fn comp_wit_variant_type(names: Vec<String>, type_indices: Vec<i32>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_VARIANT())
	let count = len(names)
	comp_emit_leb128_u(w, count)
	let mut i = 0
	while i < count {
		comp_emit_string(w, get_unchecked(names, i))
		let ti = get_unchecked(type_indices, i)
		if ti < 0 {
			comp_emit_leb128_u(w, 0)
		} else {
			comp_emit_leb128_u(w, 1)
			comp_emit_leb128_u(w, ti)
		}
		comp_emit_byte(w, 0x00)
		i = i + 1
	}
	w.bytes
}

fn comp_wit_enum_type(names: Vec<String>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_ENUM())
	let count = len(names)
	comp_emit_leb128_u(w, count)
	let mut i = 0
	while i < count {
		comp_emit_string(w, get_unchecked(names, i))
		i = i + 1
	}
	w.bytes
}

fn comp_wit_flags_type(names: Vec<String>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_FLAGS())
	let count = len(names)
	comp_emit_leb128_u(w, count)
	let mut i = 0
	while i < count {
		comp_emit_string(w, get_unchecked(names, i))
		i = i + 1
	}
	w.bytes
}

fn comp_wit_tuple_type(elem_type_indices: Vec<i32>) -> Vec<i32> {
	let w = ComponentWriter_new()
	comp_emit_byte(w, WIT_TAG_TUPLE())
	let count = len(elem_type_indices)
	comp_emit_leb128_u(w, count)
	let mut i = 0
	while i < count {
		comp_emit_leb128_u(w, get_unchecked(elem_type_indices, i))
		i = i + 1
	}
	w.bytes
}

// ── Import Section Builder ─────────────────────────────────────────────────────
struct CompImport {
	name: String,
	sort: i32,
	type_idx: i32,
}

fn CompImport_new(name: String, sort: i32, type_idx: i32) -> CompImport {
	CompImport { name: name, sort: sort, type_idx: type_idx }
}

fn comp_emit_import_section(out: ComponentWriter, imports: Vec<CompImport>) {
	if len(imports) == 0 {
		return
	}
	let w = ComponentWriter_new()
	comp_emit_leb128_u(w, len(imports))
	let mut i = 0
	while i < len(imports) {
		let imp = get_unchecked(imports, i)
		comp_emit_string(w, imp.name)
		comp_emit_byte(w, imp.sort)
		comp_emit_leb128_u(w, imp.type_idx)
		i = i + 1
	}
	comp_emit_section(out, COMP_SEC_IMPORT(), w)
}

// ── Export Section Builder ─────────────────────────────────────────────────────
fn comp_emit_export(out: ComponentWriter, name: String, sort: i32, type_idx: i32) {
	comp_emit_byte(out, 0x00)
	comp_emit_string(out, name)
	comp_emit_byte(out, sort)
	comp_emit_leb128_u(out, type_idx)
	comp_emit_byte(out, 0x00)
}

fn comp_emit_core_func_type(w: ComponentWriter, params: Vec<i32>, results: Vec<i32>) {
	comp_emit_byte(w, 0x60)
	comp_emit_leb128_u(w, len(params))
	let mut i = 0
	while i < len(params) {
		comp_emit_byte(w, get_unchecked(params, i))
		i = i + 1
	}
	comp_emit_leb128_u(w, len(results))
	i = 0
	while i < len(results) {
		comp_emit_byte(w, get_unchecked(results, i))
		i = i + 1
	}
}

fn comp_emit_wasm_section(out: ComponentWriter, section_id: i32, contents: ComponentWriter) {
	comp_emit_section(out, section_id, contents)
}

fn comp_wasi_stub_core_module() -> Vec<i32> {
	let out = ComponentWriter_new()
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x61)
	comp_emit_byte(out, 0x73)
	comp_emit_byte(out, 0x6d)
	comp_emit_byte(out, 0x01)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x00)

	let type_sec = ComponentWriter_new()
	comp_emit_leb128_u(type_sec, 5)
	let p4 = Vec_new_i32()
	push(p4, 0x7f)
	push(p4, 0x7f)
	push(p4, 0x7f)
	push(p4, 0x7f)
	let r_i32 = Vec_new_i32()
	push(r_i32, 0x7f)
	comp_emit_core_func_type(type_sec, p4, r_i32)
	let p2 = Vec_new_i32()
	push(p2, 0x7f)
	push(p2, 0x7f)
	comp_emit_core_func_type(type_sec, p2, r_i32)
	let p_path = Vec_new_i32()
	push(p_path, 0x7f)
	push(p_path, 0x7f)
	push(p_path, 0x7f)
	push(p_path, 0x7f)
	push(p_path, 0x7f)
	push(p_path, 0x7e)
	push(p_path, 0x7e)
	push(p_path, 0x7f)
	push(p_path, 0x7f)
	comp_emit_core_func_type(type_sec, p_path, r_i32)
	let p1 = Vec_new_i32()
	push(p1, 0x7f)
	comp_emit_core_func_type(type_sec, p1, r_i32)
	let r_void = Vec_new_i32()
	comp_emit_core_func_type(type_sec, p1, r_void)
	comp_emit_wasm_section(out, 1, type_sec)

	let func_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_sec, 7)
	comp_emit_leb128_u(func_sec, 0)
	comp_emit_leb128_u(func_sec, 1)
	comp_emit_leb128_u(func_sec, 1)
	comp_emit_leb128_u(func_sec, 2)
	comp_emit_leb128_u(func_sec, 0)
	comp_emit_leb128_u(func_sec, 3)
	comp_emit_leb128_u(func_sec, 4)
	comp_emit_wasm_section(out, 3, func_sec)

	let export_sec = ComponentWriter_new()
	comp_emit_leb128_u(export_sec, 7)
	comp_emit_string(export_sec, String_from("fd_write"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 0)
	comp_emit_string(export_sec, String_from("args_sizes_get"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 1)
	comp_emit_string(export_sec, String_from("args_get"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 2)
	comp_emit_string(export_sec, String_from("path_open"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 3)
	comp_emit_string(export_sec, String_from("fd_read"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 4)
	comp_emit_string(export_sec, String_from("fd_close"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 5)
	comp_emit_string(export_sec, String_from("proc_exit"))
	comp_emit_byte(export_sec, 0x00)
	comp_emit_leb128_u(export_sec, 6)
	comp_emit_wasm_section(out, 7, export_sec)

	let code_sec = ComponentWriter_new()
	comp_emit_leb128_u(code_sec, 7)
	let mut ci = 0
	while ci < 6 {
		comp_emit_leb128_u(code_sec, 4)
		comp_emit_leb128_u(code_sec, 0)
		comp_emit_byte(code_sec, 0x41)
		comp_emit_leb128_u(code_sec, 0)
		comp_emit_byte(code_sec, 0x0b)
		ci = ci + 1
	}
	comp_emit_leb128_u(code_sec, 2)
	comp_emit_leb128_u(code_sec, 0)
	comp_emit_byte(code_sec, 0x0b)
	comp_emit_wasm_section(out, 10, code_sec)

	out.bytes
}

fn comp_emit_store_const_local(body: ComponentWriter, addr: i32, local_idx: i32) {
	comp_emit_byte(body, 0x41)
	comp_emit_leb128_u(body, addr)
	comp_emit_byte(body, 0x20)
	comp_emit_leb128_u(body, local_idx)
	comp_emit_byte(body, 0x36)
	comp_emit_leb128_u(body, 2)
	comp_emit_leb128_u(body, 0)
}

fn comp_emit_func_body(code_sec: ComponentWriter, body: ComponentWriter) {
	comp_emit_leb128_u(code_sec, comp_writer_size(body))
	comp_emit_bytes(code_sec, body.bytes)
}

fn comp_point_adapter_core_module(distance_name: String, add_name: String) -> Vec<i32> {
	let out = ComponentWriter_new()
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x61)
	comp_emit_byte(out, 0x73)
	comp_emit_byte(out, 0x6d)
	comp_emit_byte(out, 0x01)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x00)

	let type_sec = ComponentWriter_new()
	comp_emit_leb128_u(type_sec, 4)
	let dist_params = Vec_new_i32()
	push(dist_params, 0x7f)
	push(dist_params, 0x7f)
	let i32_result = Vec_new_i32()
	push(i32_result, 0x7f)
	comp_emit_core_func_type(type_sec, dist_params, i32_result)
	let add_params = Vec_new_i32()
	push(add_params, 0x7f)
	push(add_params, 0x7f)
	push(add_params, 0x7f)
	push(add_params, 0x7f)
	comp_emit_core_func_type(type_sec, add_params, i32_result)
	let ptr_param = Vec_new_i32()
	push(ptr_param, 0x7f)
	comp_emit_core_func_type(type_sec, ptr_param, i32_result)
	let two_ptr_params = Vec_new_i32()
	push(two_ptr_params, 0x7f)
	push(two_ptr_params, 0x7f)
	comp_emit_core_func_type(type_sec, two_ptr_params, i32_result)
	comp_emit_wasm_section(out, 1, type_sec)

	let import_sec = ComponentWriter_new()
	comp_emit_leb128_u(import_sec, 3)
	comp_emit_string(import_sec, String_from("user"))
	comp_emit_string(import_sec, String_from("memory"))
	comp_emit_byte(import_sec, 0x02)
	comp_emit_leb128_u(import_sec, 0)
	comp_emit_leb128_u(import_sec, 1)
	comp_emit_string(import_sec, String_from("user"))
	comp_emit_string(import_sec, clone(distance_name))
	comp_emit_byte(import_sec, 0x00)
	comp_emit_leb128_u(import_sec, 2)
	comp_emit_string(import_sec, String_from("user"))
	comp_emit_string(import_sec, clone(add_name))
	comp_emit_byte(import_sec, 0x00)
	comp_emit_leb128_u(import_sec, 3)
	comp_emit_wasm_section(out, 2, import_sec)

	let func_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_sec, 2)
	comp_emit_leb128_u(func_sec, 0)
	comp_emit_leb128_u(func_sec, 1)
	comp_emit_wasm_section(out, 3, func_sec)

	let export_sec = ComponentWriter_new()
	comp_emit_leb128_u(export_sec, 2)
