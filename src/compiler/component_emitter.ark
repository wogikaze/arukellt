	comp_emit_section(out, COMP_SEC_CORE_MODULE(), wasi_stub_sec)
	let core_module_sec = ComponentWriter_new()
	comp_emit_bytes(core_module_sec, core_wasm)
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), core_module_sec)
	let adapter_sec = ComponentWriter_new()
	comp_emit_bytes(adapter_sec, comp_f32_to_i32_adapter_core_module(clone(export_name)))
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), adapter_sec)

	let core_instance_sec = ComponentWriter_new()
	comp_emit_leb128_u(core_instance_sec, 3)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("wasi_snapshot_preview1"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 2)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("user"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_section(out, COMP_SEC_CORE_INSTANCE(), core_instance_sec)

	let alias_sec = ComponentWriter_new()
	comp_emit_leb128_u(alias_sec, 1)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 2)
	comp_emit_string(alias_sec, clone(export_name))
	comp_emit_section(out, COMP_SEC_ALIAS(), alias_sec)

	let type_sec = ComponentWriter_new()
	comp_emit_leb128_u(type_sec, 1)
	let params = Vec_new_i32()
	push(params, WIT_VAL_FLOAT32())
	let results = Vec_new_i32()
	push(results, WIT_VAL_S32())
	comp_emit_bytes(type_sec, comp_component_func_type(params, results))
	comp_emit_section(out, COMP_SEC_TYPE(), type_sec)

	let canon_sec = ComponentWriter_new()
	comp_emit_leb128_u(canon_sec, 1)
	comp_emit_byte(canon_sec, COMP_CANON_LIFT())
	comp_emit_byte(canon_sec, 0x00)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_section(out, COMP_SEC_CANON(), canon_sec)

	let func_export_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_export_sec, 1)
	comp_emit_byte(func_export_sec, 0x00)
	comp_emit_string(func_export_sec, comp_export_name(clone(export_name)))
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 0)
	comp_emit_byte(func_export_sec, 0x01)
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 0)
	comp_emit_section(out, COMP_SEC_EXPORT(), func_export_sec)

	out.bytes
}

fn emit_i32_to_f32_component(core_wasm: Vec<i32>, export_name: String) -> Vec<i32> {
	let out = ComponentWriter_new()
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x61)
	comp_emit_byte(out, 0x73)
	comp_emit_byte(out, 0x6d)
	comp_emit_byte(out, 0x0d)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x01)
	comp_emit_byte(out, 0x00)

	let wasi_stub_sec = ComponentWriter_new()
	comp_emit_bytes(wasi_stub_sec, comp_wasi_stub_core_module())
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), wasi_stub_sec)
	let core_module_sec = ComponentWriter_new()
	comp_emit_bytes(core_module_sec, core_wasm)
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), core_module_sec)
	let adapter_sec = ComponentWriter_new()
	comp_emit_bytes(adapter_sec, comp_i32_to_f32_adapter_core_module(clone(export_name)))
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), adapter_sec)

	let core_instance_sec = ComponentWriter_new()
	comp_emit_leb128_u(core_instance_sec, 3)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("wasi_snapshot_preview1"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 2)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("user"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_section(out, COMP_SEC_CORE_INSTANCE(), core_instance_sec)

	let alias_sec = ComponentWriter_new()
	comp_emit_leb128_u(alias_sec, 1)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 2)
	comp_emit_string(alias_sec, clone(export_name))
	comp_emit_section(out, COMP_SEC_ALIAS(), alias_sec)

	let type_sec = ComponentWriter_new()
	comp_emit_leb128_u(type_sec, 1)
	let params = Vec_new_i32()
	push(params, WIT_VAL_S32())
	let results = Vec_new_i32()
	push(results, WIT_VAL_FLOAT32())
	comp_emit_bytes(type_sec, comp_component_func_type(params, results))
	comp_emit_section(out, COMP_SEC_TYPE(), type_sec)

	let canon_sec = ComponentWriter_new()
	comp_emit_leb128_u(canon_sec, 1)
	comp_emit_byte(canon_sec, COMP_CANON_LIFT())
	comp_emit_byte(canon_sec, 0x00)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_section(out, COMP_SEC_CANON(), canon_sec)

	let func_export_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_export_sec, 1)
	comp_emit_byte(func_export_sec, 0x00)
	comp_emit_string(func_export_sec, comp_export_name(clone(export_name)))
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 0)
	comp_emit_byte(func_export_sec, 0x01)
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 0)
	comp_emit_section(out, COMP_SEC_EXPORT(), func_export_sec)

	out.bytes
}

// ── Core Module to Component Wrapper ──────────────────────────────────────────
// Wraps a core Wasm module in a Component binary.
// This creates a minimal component that:
// 1. Contains the core module as a nested component
// 2. Exports the core module's functions as component exports
// 3. Handles WASI imports appropriately
pub fn emit_component(core_wasm: Vec<i32>, mir: MirModule, target: String, wasi_version: String) -> Vec<i32> {
	let out = ComponentWriter_new()

	// Write component magic header: \0asm + component version field.
	// Component binaries use version 0x0001000d, encoded little-endian.
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x61)  // 'a'
	comp_emit_byte(out, 0x73)  // 's'
	comp_emit_byte(out, 0x6d)  // 'm'
	comp_emit_byte(out, 0x0d)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x01)
	comp_emit_byte(out, 0x00)

	// Count exportable functions
	let fn_count = len(mir.functions)
	let mut export_count = 0
	let mut export_names: Vec<String> = Vec_new_String()
	let mut export_indices: Vec<i32> = Vec_new_i32()
	let mut export_type_indices: Vec<i32> = Vec_new_i32()

	let mut mi = 0
	while mi < fn_count {
		let f = get_unchecked(mir.functions, mi)
		// Export all functions except those that start with '__'
		let name = clone(f.name)
		let nlen = len(name)
		if nlen > 2 && char_at(name, 0) == 95 && char_at(name, 1) == 95 {
			// Skip internal functions
		} else {
			if comp_should_export_func(clone(name)) {
				push(export_names, name)
				push(export_indices, mi)
				export_count = export_count + 1
			}
		}
		mi = mi + 1
	}

	if comp_has_record_point_exports(export_names) {
		return emit_record_point_component(core_wasm, String_from("distance_sq"), String_from("add_points"))
	}
	let point_distance_name = comp_point_to_i32_pair_export_name(mir)
	let point_add_name = comp_point_point_to_point_pair_export_name(mir)
	if len(point_distance_name) > 0 && len(point_add_name) > 0 {
		return emit_record_point_component(core_wasm, point_distance_name, point_add_name)
	}
	if comp_has_record_distance_exports(export_names) {
		return emit_record_distance_component(core_wasm, String_from("distance_sq"))
	}
	let point_to_i32_name = comp_single_point_to_i32_export_name(mir)
	if len(point_to_i32_name) > 0 {
		return emit_record_distance_component(core_wasm, point_to_i32_name)
	}
	let point_to_point_name = comp_single_point_to_point_export_name(mir)
	if len(point_to_point_name) > 0 {
		return emit_record_point_roundtrip_component(core_wasm, point_to_point_name)
	}
	let point_point_to_point_name = comp_single_point_point_to_point_export_name(mir)
	if len(point_point_to_point_name) > 0 {
		return emit_record_point_add_component(core_wasm, point_point_to_point_name)
	}
	if comp_has_color_code_exports(export_names) {
		return emit_color_code_component(core_wasm, String_from("color_code"))
	}
	if comp_has_color_enum_exports(export_names) {
		return emit_color_enum_component(core_wasm, String_from("next_color"), String_from("color_to_value"))
	}
	let color_next_name = comp_color_to_color_export_name(mir)
	let color_value_name = comp_color_to_i32_pair_export_name(mir)
	if len(color_next_name) > 0 && len(color_value_name) > 0 {
		return emit_color_enum_component(core_wasm, color_next_name, color_value_name)
	}
	let color_to_i32_name = comp_single_color_to_i32_export_name(mir)
	if len(color_to_i32_name) > 0 {
		return emit_color_code_component(core_wasm, color_to_i32_name)
	}
	let color_to_color_name = comp_single_color_to_color_export_name(mir)
	if len(color_to_color_name) > 0 {
		return emit_color_roundtrip_component(core_wasm, color_to_color_name)
	}
	let string_unary_name = comp_single_string_unary_export_name(mir)
	if len(string_unary_name) > 0 {
		return emit_string_unary_component(core_wasm, string_unary_name)
	}
	let string_to_i32_name = comp_single_string_to_i32_export_name(mir)
	if len(string_to_i32_name) > 0 {
		return emit_string_to_i32_component(core_wasm, string_to_i32_name, WIT_VAL_S32())
	}
	let string_to_u8_name = comp_single_string_to_named_i32_export_name(mir, String_from("u8"))
	if len(string_to_u8_name) > 0 {
		return emit_string_to_u8_component(core_wasm, string_to_u8_name)
	}
	let string_to_u16_name = comp_single_string_to_named_i32_export_name(mir, String_from("u16"))
	if len(string_to_u16_name) > 0 {
		return emit_string_to_u16_component(core_wasm, string_to_u16_name)
	}
	let string_to_u32_name = comp_single_string_to_named_i32_export_name(mir, String_from("u32"))
	if len(string_to_u32_name) > 0 {
		return emit_string_to_u32_component(core_wasm, string_to_u32_name)
	}
	let string_to_i8_name = comp_single_string_to_named_i32_export_name(mir, String_from("i8"))
	if len(string_to_i8_name) > 0 {
		return emit_string_to_i8_component(core_wasm, string_to_i8_name)
	}
	let string_to_i16_name = comp_single_string_to_named_i32_export_name(mir, String_from("i16"))
	if len(string_to_i16_name) > 0 {
		return emit_string_to_i16_component(core_wasm, string_to_i16_name)
	}
	let string_to_bool_name = comp_single_string_to_bool_export_name(mir)
	if len(string_to_bool_name) > 0 {
		return emit_string_to_bool_component(core_wasm, string_to_bool_name)
	}
	let string_to_char_name = comp_single_string_to_char_export_name(mir)
	if len(string_to_char_name) > 0 {
		return emit_string_to_char_component(core_wasm, string_to_char_name)
	}
	let string_to_f32_name = comp_single_string_to_f32_export_name(mir)
	if len(string_to_f32_name) > 0 {
		return emit_string_to_f32_component(core_wasm, string_to_f32_name)
	}
	let string_to_f64_name = comp_single_string_to_f64_export_name(mir)
	if len(string_to_f64_name) > 0 {
		return emit_string_to_f64_component(core_wasm, string_to_f64_name)
	}
	let string_to_i64_name = comp_single_string_to_i64_export_name(mir)
	if len(string_to_i64_name) > 0 {
		return emit_string_to_i64_component(core_wasm, string_to_i64_name)
	}
	let string_to_u64_name = comp_single_string_to_u64_export_name(mir)
	if len(string_to_u64_name) > 0 {
		return emit_string_to_u64_component(core_wasm, string_to_u64_name)
	}
	let string_result_name = comp_single_i32_to_string_export_name(mir)
	if len(string_result_name) > 0 {
		return emit_i32_to_string_component(core_wasm, string_result_name)
	}
	let list_i32_name = comp_single_list_i32_to_i32_export_name(mir)
	if len(list_i32_name) > 0 {
		return emit_list_i32_to_i32_component(core_wasm, list_i32_name)
	}
	let list_i32_result_name = comp_single_i32_to_list_i32_export_name(mir)
	if len(list_i32_result_name) > 0 {
		return emit_i32_to_list_i32_component(core_wasm, list_i32_result_name)
	}
	let list_i32_roundtrip_name = comp_single_list_i32_to_list_i32_export_name(mir)
	if len(list_i32_roundtrip_name) > 0 {
		return emit_list_i32_to_list_i32_component(core_wasm, list_i32_roundtrip_name)
	}
	let option_i32_name = comp_single_i32_to_option_i32_export_name(mir)
	if len(option_i32_name) > 0 {
		return emit_i32_to_option_i32_component(core_wasm, option_i32_name)
	}
	let option_bool_name = comp_single_bool_to_option_bool_export_name(mir)
	if len(option_bool_name) > 0 {
		return emit_bool_to_option_bool_component(core_wasm, option_bool_name)
	}
	let option_i64_name = comp_single_bool_to_option_i64_export_name(mir)
	if len(option_i64_name) > 0 {
		return emit_bool_to_option_i64_component(core_wasm, option_i64_name)
	}
	let option_i32_param_name = comp_single_option_i32_to_i32_export_name(mir)
	if len(option_i32_param_name) > 0 {
		return emit_option_i32_to_i32_component(core_wasm, option_i32_param_name)
	}
	let option_i64_param_name = comp_single_option_i64_to_i64_export_name(mir)
	if len(option_i64_param_name) > 0 {
		return emit_option_i64_to_i64_component(core_wasm, option_i64_param_name)
	}
	let option_i32_roundtrip_name = comp_single_option_i32_to_option_i32_export_name(mir)
	if len(option_i32_roundtrip_name) > 0 {
		return emit_option_i32_to_option_i32_component(core_wasm, option_i32_roundtrip_name)
	}
	let result_i32_string_name = comp_single_i32_i32_to_result_i32_string_export_name(mir)
	if len(result_i32_string_name) > 0 {
		return emit_i32_i32_to_result_i32_string_component(core_wasm, result_i32_string_name)
	}
	let result_bool_name = comp_single_bool_to_result_bool_bool_export_name(mir)
	if len(result_bool_name) > 0 {
		return emit_bool_to_result_bool_bool_component(core_wasm, result_bool_name)
	}
	let result_i32_i32_param_name = comp_single_result_i32_i32_to_i32_export_name(mir)
	if len(result_i32_i32_param_name) > 0 {
		return emit_result_i32_i32_to_i32_component(core_wasm, result_i32_i32_param_name)
	}
	let result_i32_string_param_name = comp_single_result_i32_string_to_i32_export_name(mir)
	if len(result_i32_string_param_name) > 0 {
		return emit_result_i32_string_to_i32_component(core_wasm, result_i32_string_param_name)
	}
	let result_i32_i32_roundtrip_name = comp_single_result_i32_i32_to_result_i32_i32_export_name(mir)
	if len(result_i32_i32_roundtrip_name) > 0 {
		return emit_result_i32_i32_to_result_i32_i32_component(core_wasm, result_i32_i32_roundtrip_name)
	}
	if comp_has_shape_area_exports(export_names) {
		return emit_shape_area_component(core_wasm, String_from("area"))
	}
	let shape_to_f64_name = comp_single_shape_to_f64_export_name(mir)
	if len(shape_to_f64_name) > 0 {
		return emit_shape_area_component(core_wasm, shape_to_f64_name)
	}
	let shape_to_shape_name = comp_single_shape_to_shape_export_name(mir)
	if len(shape_to_shape_name) > 0 {
		return emit_shape_roundtrip_component(core_wasm, shape_to_shape_name)
	}
	let tuple_i32_name = comp_single_i32_i32_to_tuple_i32_i32_export_name(mir)
	if len(tuple_i32_name) > 0 {
		return emit_i32_i32_to_tuple_i32_i32_component(core_wasm, tuple_i32_name)
	}
	let tuple_i64_name = comp_single_i64_i64_to_tuple_i64_i64_export_name(mir)
	if len(tuple_i64_name) > 0 {
		return emit_i64_i64_to_tuple_i64_i64_component(core_wasm, tuple_i64_name)
	}
	let tuple_i32_param_name = comp_single_tuple_i32_i32_to_i32_export_name(mir)
	if len(tuple_i32_param_name) > 0 {
		return emit_tuple_i32_i32_to_i32_component(core_wasm, tuple_i32_param_name)
	}
	let tuple_i32_bool_param_name = comp_single_tuple_i32_bool_to_i32_export_name(mir)
	if len(tuple_i32_bool_param_name) > 0 {
		return emit_tuple_i32_bool_to_i32_component(core_wasm, tuple_i32_bool_param_name)
	}
	let tuple_bool_bool_param_name = comp_single_tuple_bool_bool_to_i32_export_name(mir)
	if len(tuple_bool_bool_param_name) > 0 {
		return emit_tuple_bool_bool_to_i32_component(core_wasm, tuple_bool_bool_param_name)
	}
	let tuple_i32_roundtrip_name = comp_single_tuple_i32_i32_to_tuple_i32_i32_export_name(mir)
	if len(tuple_i32_roundtrip_name) > 0 {
		return emit_tuple_i32_i32_to_tuple_i32_i32_component(core_wasm, tuple_i32_roundtrip_name)
	}
	let f32_binary_name = comp_single_f32_binary_export_name(mir)
	if len(f32_binary_name) > 0 {
		return emit_f32_binary_component(core_wasm, f32_binary_name)
	}
	let f32_to_i32_name = comp_single_f32_to_i32_export_name(mir)
	if len(f32_to_i32_name) > 0 {
		return emit_f32_to_i32_component(core_wasm, f32_to_i32_name)
	}
	let i32_to_f32_name = comp_single_i32_to_f32_export_name(mir)
	if len(i32_to_f32_name) > 0 {
		return emit_i32_to_f32_component(core_wasm, i32_to_f32_name)
	}
	let f32_unary_name = comp_single_f32_unary_export_name(mir)
	if len(f32_unary_name) > 0 {
		return emit_f32_unary_component(core_wasm, f32_unary_name)
	}

	// Build component function type definitions using the TypeInterner
	let interner = TypeInterner_new()
	let mut color_type_idx = 0 - 1

	let mut ei = 0
	while ei < export_count {
		let idx = get_unchecked(export_indices, ei)
		let f = get_unchecked(mir.functions, idx)
		if comp_export_uses_color(clone(f.name)) && color_type_idx < 0 {
			let color_names = Vec_new_String()
			push(color_names, String_from("red"))
			push(color_names, String_from("green"))
			push(color_names, String_from("blue"))
			color_type_idx = type_interner_add(interner, comp_wit_enum_type(color_names))
		}

		// Collect core wasm parameter types
		let mut param_vts: Vec<i32> = Vec_new_i32()
		let mut pi = 0
		while pi < len(f.params) {
			let param = get_unchecked(f.params, pi)
			if comp_export_uses_color(clone(f.name)) {
				push(param_vts, color_type_idx)
			} else {
				push(param_vts, comp_param_wit_type(clone(f.name), param))
			}
			pi = pi + 1
		}

		// Collect core wasm result types
		let mut result_vts: Vec<i32> = Vec_new_i32()
		if f.return_type != 0 {
			if comp_export_result_uses_color(clone(f.name)) {
				push(result_vts, color_type_idx)
			} else {
				push(result_vts, comp_result_wit_type(f))
			}
		}

		let type_bytes = comp_component_func_type(param_vts, result_vts)
		let type_idx = type_interner_add(interner, type_bytes)
		push(export_type_indices, type_idx)

		ei = ei + 1
	}

	// Core module 0: a minimal WASI Preview 1 instance stub used to satisfy the
	// unconditional imports emitted by the current core wasm emitter.
	let wasi_stub_sec = ComponentWriter_new()
	comp_emit_bytes(wasi_stub_sec, comp_wasi_stub_core_module())
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), wasi_stub_sec)

	// Core module 1: the compiled user module.
	let core_module_sec = ComponentWriter_new()
	comp_emit_bytes(core_module_sec, core_wasm)
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), core_module_sec)

	// Instantiate the WASI stub, then instantiate the user module with the stub
	// wired to the expected `wasi_snapshot_preview1` import namespace.
	let core_instance_sec = ComponentWriter_new()
	comp_emit_leb128_u(core_instance_sec, 2)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("wasi_snapshot_preview1"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_section(out, COMP_SEC_CORE_INSTANCE(), core_instance_sec)

	// Alias each core export from user instance 1 as a core function.
	let alias_sec = ComponentWriter_new()
	comp_emit_leb128_u(alias_sec, export_count)
	let mut ai = 0
	while ai < export_count {
		let core_name = get_unchecked(export_names, ai)
		comp_emit_byte(alias_sec, 0x00)
		comp_emit_byte(alias_sec, 0x00)
		comp_emit_byte(alias_sec, 0x01)
		comp_emit_leb128_u(alias_sec, 1)
		comp_emit_string(alias_sec, core_name)
		ai = ai + 1
	}
	comp_emit_section(out, COMP_SEC_ALIAS(), alias_sec)

	// Emit component type section from the interner.
	type_interner_emit_section(out, interner)

	// Canonically lift each aliased core function to a component function.
	let canon_sec = ComponentWriter_new()
	comp_emit_leb128_u(canon_sec, export_count)
	let mut ci = 0
	while ci < export_count {
		let type_idx_canon = get_unchecked(export_type_indices, ci)
		comp_emit_byte(canon_sec, COMP_CANON_LIFT())
		comp_emit_byte(canon_sec, 0x00)
		comp_emit_leb128_u(canon_sec, ci)
		comp_emit_leb128_u(canon_sec, 0)
		comp_emit_leb128_u(canon_sec, type_idx_canon)
		ci = ci + 1
	}
	comp_emit_section(out, COMP_SEC_CANON(), canon_sec)

	// Component export section for the lifted component functions.
	let export_sec = ComponentWriter_new()
	comp_emit_leb128_u(export_sec, export_count)
	let mut ei2 = 0
	while ei2 < export_count {
		let name = get_unchecked(export_names, ei2)
		let export_type_idx = get_unchecked(export_type_indices, ei2)

		// Export name
		comp_emit_byte(export_sec, 0x00)
		comp_emit_string(export_sec, comp_export_name(name))

		// Export sort: component function
		comp_emit_byte(export_sec, COMP_EXI_SORT_FUNC())

		// Function index in the component function index space.
		comp_emit_leb128_u(export_sec, ei2)
		comp_emit_byte(export_sec, 0x01)
		comp_emit_byte(export_sec, COMP_EXI_SORT_FUNC())
		comp_emit_leb128_u(export_sec, export_type_idx)

		ei2 = ei2 + 1
	}

	comp_emit_section(out, COMP_SEC_EXPORT(), export_sec)

	out.bytes
}

// ── Helper Functions ──────────────────────────────────────────────────────────
fn val_type_to_comp(val_type: i32) -> i32 {
    if val_type == 1 {
        return WIT_VAL_S32()
    }
    if val_type == 2 {
        return WIT_VAL_S64()
    }
    if val_type == 3 {
        return WIT_VAL_FLOAT64()
    }
    if val_type == 4 {
        return WIT_VAL_STRING()
    }
    WIT_VAL_S32()
}
