fn comp_export_name(name: String) -> String {
	let mut out = String_from("")
	let n = len(name)
	let mut i = 0
	while i < n {
		let ch = char_at(name, i)
		if ch == 95 {
			out = concat(out, String_from("-"))
		} else {
			out = concat(out, substring(name, i, i + 1))
		}
		i = i + 1
	}
	out
}

fn comp_wit_type_from_name(type_name: String, fallback_vt: i32) -> i32 {
	if eq(clone(type_name), String_from("bool")) {
		return WIT_VAL_BOOL()
	}
	if eq(clone(type_name), String_from("char")) {
		return WIT_VAL_CHAR()
	}
	if eq(clone(type_name), String_from("u8")) {
		return WIT_VAL_U8()
	}
	if eq(clone(type_name), String_from("u16")) {
		return WIT_VAL_U16()
	}
	if eq(clone(type_name), String_from("u32")) {
		return WIT_VAL_U32()
	}
	if eq(clone(type_name), String_from("u64")) {
		return WIT_VAL_U64()
	}
	if eq(clone(type_name), String_from("i8")) {
		return WIT_VAL_S8()
	}
	if eq(clone(type_name), String_from("i16")) {
		return WIT_VAL_S16()
	}
	if eq(clone(type_name), String_from("i32")) {
		return WIT_VAL_S32()
	}
	if eq(clone(type_name), String_from("i64")) {
		return WIT_VAL_S64()
	}
	if eq(clone(type_name), String_from("f32")) {
		return WIT_VAL_FLOAT32()
	}
	if eq(clone(type_name), String_from("f64")) {
		return WIT_VAL_FLOAT64()
	}
	if eq(clone(type_name), String_from("string")) {
		return WIT_VAL_STRING()
	}
	val_type_to_comp(fallback_vt)
}

fn comp_param_wit_type(fn_name: String, param: MirLocal) -> i32 {
	if len(param.type_name) > 0 {
		return comp_wit_type_from_name(clone(param.type_name), param.val_type)
	}
	val_type_to_comp(param.val_type)
}

fn comp_result_wit_type(f: MirFunction) -> i32 {
	if len(f.return_type_name) > 0 {
		return comp_wit_type_from_name(clone(f.return_type_name), f.return_type)
	}
	val_type_to_comp(f.return_type)
}

fn comp_export_uses_color(name: String) -> bool {
	false
}

fn comp_export_result_uses_color(name: String) -> bool {
	false
}

fn comp_should_export_func(name: String) -> bool {
	if eq(clone(name), String_from("main")) || eq(clone(name), String_from("_start")) {
		return false
	}
	if eq(clone(name), String_from("print")) || eq(clone(name), String_from("println")) || eq(clone(name), String_from("eprintln")) {
		return false
	}
	if contains(clone(name), String_from("::")) {
		return false
	}
	true
}

fn emit_color_enum_component(core_wasm: Vec<i32>, next_name: String, value_name: String) -> Vec<i32> {
	let out = ComponentWriter_new()
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x61)
	comp_emit_byte(out, 0x73)
	comp_emit_byte(out, 0x6d)
	comp_emit_byte(out, 0x0d)
	comp_emit_byte(out, 0x00)
	comp_emit_byte(out, 0x01)
	comp_emit_byte(out, 0x00)

	let wasi_stub_sec = ComponentWriter_new()
	comp_emit_bytes(wasi_stub_sec, comp_wasi_stub_core_module())
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), wasi_stub_sec)
	let core_module_sec = ComponentWriter_new()
	comp_emit_bytes(core_module_sec, core_wasm)
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), core_module_sec)
	let core_instance_sec = ComponentWriter_new()
	comp_emit_leb128_u(core_instance_sec, 2)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("wasi_snapshot_preview1"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_section(out, COMP_SEC_CORE_INSTANCE(), core_instance_sec)

	let alias_sec = ComponentWriter_new()
	comp_emit_leb128_u(alias_sec, 2)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 1)
	comp_emit_string(alias_sec, clone(next_name))
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 1)
	comp_emit_string(alias_sec, clone(value_name))
	comp_emit_section(out, COMP_SEC_ALIAS(), alias_sec)

	let enum_type_sec = ComponentWriter_new()
	comp_emit_leb128_u(enum_type_sec, 1)
	let color_names = Vec_new_String()
	push(color_names, String_from("red"))
	push(color_names, String_from("green"))
	push(color_names, String_from("blue"))
	comp_emit_bytes(enum_type_sec, comp_wit_enum_type(color_names))
	comp_emit_section(out, COMP_SEC_TYPE(), enum_type_sec)

	let type_export_sec = ComponentWriter_new()
	comp_emit_leb128_u(type_export_sec, 1)
	comp_emit_byte(type_export_sec, 0x00)
	comp_emit_string(type_export_sec, String_from("color"))
	comp_emit_byte(type_export_sec, 0x03)
	comp_emit_leb128_u(type_export_sec, 0)
	comp_emit_byte(type_export_sec, 0x00)
	comp_emit_section(out, COMP_SEC_EXPORT(), type_export_sec)

	let func_type_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_type_sec, 2)
	let next_params = Vec_new_i32()
	push(next_params, 1)
	let next_results = Vec_new_i32()
	push(next_results, 1)
	comp_emit_bytes(func_type_sec, comp_component_func_type(next_params, next_results))
	let value_params = Vec_new_i32()
	push(value_params, 1)
	let value_results = Vec_new_i32()
	push(value_results, WIT_VAL_S32())
	comp_emit_bytes(func_type_sec, comp_component_func_type(value_params, value_results))
	comp_emit_section(out, COMP_SEC_TYPE(), func_type_sec)

	let canon_sec = ComponentWriter_new()
	comp_emit_leb128_u(canon_sec, 2)
	comp_emit_byte(canon_sec, COMP_CANON_LIFT())
	comp_emit_byte(canon_sec, 0x00)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 2)
	comp_emit_byte(canon_sec, COMP_CANON_LIFT())
	comp_emit_byte(canon_sec, 0x00)
	comp_emit_leb128_u(canon_sec, 1)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 3)
	comp_emit_section(out, COMP_SEC_CANON(), canon_sec)

	let func_export_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_export_sec, 2)
	comp_emit_byte(func_export_sec, 0x00)
	comp_emit_string(func_export_sec, comp_export_name(clone(next_name)))
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 0)
	comp_emit_byte(func_export_sec, 0x01)
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 2)
	comp_emit_byte(func_export_sec, 0x00)
	comp_emit_string(func_export_sec, comp_export_name(clone(value_name)))
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 1)
	comp_emit_byte(func_export_sec, 0x01)
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 3)
	comp_emit_section(out, COMP_SEC_EXPORT(), func_export_sec)

	out.bytes
}

