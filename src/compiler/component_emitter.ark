fn comp_has_record_point_exports(names: Vec<String>) -> bool {
	let mut has_distance = false
	let mut has_add = false
	let n = len(names)
	let mut i = 0
	while i < n {
		let nm = get_unchecked(names, i)
		if eq(clone(nm), String_from("distance_sq")) {
			has_distance = true
		}
		if eq(clone(nm), String_from("add_points")) {
			has_add = true
		}
		i = i + 1
	}
	has_distance && has_add
}

fn comp_has_record_distance_exports(names: Vec<String>) -> bool {
	len(names) == 1 && eq(get_unchecked(names, 0), String_from("distance_sq"))
}

fn comp_function_is_point_to_i32_export(f: MirFunction) -> bool {
	if !comp_should_export_func(clone(f.name)) {
		return false
	}
	if len(f.params) != 1 {
		return false
	}
	if !eq(clone(f.return_type_name), String_from("i32")) {
		return false
	}
	let p = get_unchecked(f.params, 0)
	eq(clone(p.type_name), String_from("Point"))
}

fn comp_single_point_to_i32_export_name(mir: MirModule) -> String {
	let mut candidate = String_new()
	let mut count = 0
	let n = len(mir.functions)
	let mut i = 0
	while i < n {
		let f = get_unchecked(mir.functions, i)
		if comp_should_export_func(clone(f.name)) {
			count = count + 1
			if comp_function_is_point_to_i32_export(f) {
				candidate = clone(f.name)
			}
		}
		i = i + 1
	}
	if count == 1 && len(candidate) > 0 {
		return candidate
	}
	String_new()
}

fn comp_function_is_point_point_to_point_export(f: MirFunction) -> bool {
	if !comp_should_export_func(clone(f.name)) {
		return false
	}
	if len(f.params) != 2 {
		return false
	}
	if !eq(clone(f.return_type_name), String_from("Point")) {
		return false
	}
	let p0 = get_unchecked(f.params, 0)
	let p1 = get_unchecked(f.params, 1)
	eq(clone(p0.type_name), String_from("Point")) && eq(clone(p1.type_name), String_from("Point"))
}

fn comp_function_is_point_to_point_export(f: MirFunction) -> bool {
	if !comp_should_export_func(clone(f.name)) {
		return false
	}
	if len(f.params) != 1 {
		return false
	}
	if !eq(clone(f.return_type_name), String_from("Point")) {
		return false
	}
	let p = get_unchecked(f.params, 0)
	eq(clone(p.type_name), String_from("Point"))
}

