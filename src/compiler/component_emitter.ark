	comp_emit_section(out, COMP_SEC_CORE_MODULE(), wasi_stub_sec)
	let core_module_sec = ComponentWriter_new()
	comp_emit_bytes(core_module_sec, core_wasm)
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), core_module_sec)
	let adapter_sec = ComponentWriter_new()
	comp_emit_bytes(adapter_sec, comp_point_adapter_core_module(clone(distance_name), clone(add_name)))
	comp_emit_section(out, COMP_SEC_CORE_MODULE(), adapter_sec)

	let core_instance_sec = ComponentWriter_new()
	comp_emit_leb128_u(core_instance_sec, 3)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("wasi_snapshot_preview1"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 0)
	comp_emit_byte(core_instance_sec, 0x00)
	comp_emit_leb128_u(core_instance_sec, 2)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_string(core_instance_sec, String_from("user"))
	comp_emit_byte(core_instance_sec, 0x12)
	comp_emit_leb128_u(core_instance_sec, 1)
	comp_emit_section(out, COMP_SEC_CORE_INSTANCE(), core_instance_sec)

	let alias_sec = ComponentWriter_new()
	comp_emit_leb128_u(alias_sec, 3)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x02)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 1)
	comp_emit_string(alias_sec, String_from("memory"))
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 2)
	comp_emit_string(alias_sec, clone(distance_name))
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x00)
	comp_emit_byte(alias_sec, 0x01)
	comp_emit_leb128_u(alias_sec, 2)
	comp_emit_string(alias_sec, clone(add_name))
	comp_emit_section(out, COMP_SEC_ALIAS(), alias_sec)

	let record_type_sec = ComponentWriter_new()
	comp_emit_leb128_u(record_type_sec, 1)
	let field_names = Vec_new_String()
	push(field_names, String_from("x"))
	push(field_names, String_from("y"))
	let field_types = Vec_new_i32()
	push(field_types, WIT_VAL_S32())
	push(field_types, WIT_VAL_S32())
	comp_emit_bytes(record_type_sec, comp_wit_record_type(field_names, field_types))
	comp_emit_section(out, COMP_SEC_TYPE(), record_type_sec)

	let type_export_sec = ComponentWriter_new()
	comp_emit_leb128_u(type_export_sec, 1)
	comp_emit_byte(type_export_sec, 0x00)
	comp_emit_string(type_export_sec, String_from("point"))
	comp_emit_byte(type_export_sec, 0x03)
	comp_emit_leb128_u(type_export_sec, 0)
	comp_emit_byte(type_export_sec, 0x00)
	comp_emit_section(out, COMP_SEC_EXPORT(), type_export_sec)

	let func_type_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_type_sec, 2)
	let point_param = Vec_new_i32()
	push(point_param, 1)
	let s32_result = Vec_new_i32()
	push(s32_result, WIT_VAL_S32())
	comp_emit_bytes(func_type_sec, comp_component_func_type(point_param, s32_result))
	let two_point_params = Vec_new_i32()
	push(two_point_params, 1)
	push(two_point_params, 1)
	let point_result = Vec_new_i32()
	push(point_result, 1)
	comp_emit_bytes(func_type_sec, comp_component_func_type(two_point_params, point_result))
	comp_emit_section(out, COMP_SEC_TYPE(), func_type_sec)

	let canon_sec = ComponentWriter_new()
	comp_emit_leb128_u(canon_sec, 2)
	comp_emit_byte(canon_sec, COMP_CANON_LIFT())
	comp_emit_byte(canon_sec, 0x00)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 2)
	comp_emit_byte(canon_sec, COMP_CANON_LIFT())
	comp_emit_byte(canon_sec, 0x00)
	comp_emit_leb128_u(canon_sec, 1)
	comp_emit_leb128_u(canon_sec, 1)
	comp_emit_byte(canon_sec, COMP_CANON_OPTION_MEMORY())
	comp_emit_leb128_u(canon_sec, 0)
	comp_emit_leb128_u(canon_sec, 3)
	comp_emit_section(out, COMP_SEC_CANON(), canon_sec)

	let func_export_sec = ComponentWriter_new()
	comp_emit_leb128_u(func_export_sec, 2)
	comp_emit_byte(func_export_sec, 0x00)
	comp_emit_string(func_export_sec, comp_export_name(clone(distance_name)))
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 0)
	comp_emit_byte(func_export_sec, 0x01)
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 2)
	comp_emit_byte(func_export_sec, 0x00)
	comp_emit_string(func_export_sec, comp_export_name(clone(add_name)))
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 1)
	comp_emit_byte(func_export_sec, 0x01)
	comp_emit_byte(func_export_sec, COMP_EXI_SORT_FUNC())
	comp_emit_leb128_u(func_export_sec, 3)
	comp_emit_section(out, COMP_SEC_EXPORT(), func_export_sec)

	out.bytes
}

