use mir::inst_factory
use mir::opcodes
use mir::types
use mir::value_types

fn MirInst_local_get(local_idx: i32) -> MirInst {
    inst_factory::MirInst_full(opcodes::MIR_LOCAL_GET(), 0 - 1, local_idx, 0 - 1, 0, 0.0, String_new(), value_types::VT_VOID())
}

fn MirInst_local_get_to(local_idx: i32, dest: i32) -> MirInst {
    inst_factory::MirInst_full(opcodes::MIR_LOCAL_GET(), dest, local_idx, 0 - 1, 0, 0.0, String_new(), value_types::VT_VOID())
}
