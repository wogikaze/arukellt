use mir::lower::ctx_struct_lookup
use mir::lower::ctx_struct_layout
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower::ctx_gc_enum
use mir::lower::ctx_types
use mir::inst_struct_get
use mir::value_types

// Strip "struct:TypeName:byte_size" → "TypeName" so struct layout lookups
// (ctx_field_index, ctx_struct_byte_size, etc.) match the registered name.
// Passes through non-"struct:" type names unchanged.
fn strip_struct_type_prefix(type_name: String) -> String {
    if !starts_with(clone(type_name), String_from("struct:")) {
        return type_name
    }
    let n = len(type_name)
    let mut first_colon = 0 - 1
    let mut last_colon = 0 - 1
    let mut i = 0
    while i < n {
        if char_at(type_name, i) == ':' {
            if first_colon < 0 {
                first_colon = i
            }
            last_colon = i
        }
        i = i + 1
    }
    if first_colon < 0 || last_colon < 0 || first_colon == last_colon {
        return type_name
    }
    substring(type_name, first_colon + 1, last_colon)
}

// Layout tables register bare names. Call return locals may carry
// `module::Type` (or nested qualifiers); strip the last `::` segment only.
// Do not strip single `:` — that would break `struct:Name:size` encoding.
fn strip_module_qualifier(type_name: String) -> String {
    let n = len(type_name)
    if n < 2 {
        return type_name
    }
    let mut i = n - 2
    while i >= 0 {
        if char_at(type_name, i) == 58 && char_at(type_name, i + 1) == 58 {
            return substring(type_name, i + 2, n)
        }
        i = i - 1
    }
    type_name
}

fn canonicalize_struct_layout_name(type_name: String) -> String {
    strip_module_qualifier(strip_struct_type_prefix(type_name))
}

fn mir_field_access_dest_vt(ctx: LowerCtx, base_type: String, field_name: String, field_idx: i32, is_f64_field: bool) -> i32 {
    let mut dest_vt = value_types::VT_I32()
    if is_f64_field {
        dest_vt = value_types::VT_F64()
    }
    if len(base_type) > 0 {
        let ft_vt = ctx_struct_lookup::ctx_get_field_type(ctx, clone(base_type), clone(field_name))
        if eq(clone(ft_vt), "i64") {
            dest_vt = value_types::VT_I64()
        }
    }
    if len(base_type) > 0 && ctx_struct_layout::ctx_struct_field_is_gc_ref(ctx, clone(base_type), field_idx) {
        if ctx_gc_enum::ctx_is_gc_target(ctx) {
            dest_vt = value_types::VT_GC_REF()
        } else {
            dest_vt = value_types::VT_REF()
        }
    }
    if len(base_type) > 0 && ctx_struct_layout::ctx_struct_field_is_v128(ctx, clone(base_type), field_idx) {
        dest_vt = value_types::VT_V128()
    }
    dest_vt
}

fn mir_emit_field_access(ctx: LowerCtx, field_name: String, base_idx: i32) -> i32 {
    let raw_type = ctx_api_local_types::ctx_get_local_type(ctx, base_idx)
    let base_type = canonicalize_struct_layout_name(raw_type)
    let mut field_idx = 0
    let mut is_f64_field = false
    if len(base_type) > 0 {
        field_idx = ctx_struct_lookup::ctx_field_index(ctx, clone(base_type), clone(field_name))
        is_f64_field = ctx_struct_layout::ctx_struct_field_is_f64(ctx, clone(base_type), field_idx)
    } else {
        field_idx = ctx_struct_lookup::ctx_field_index_any(ctx, clone(field_name))
    }
    let dest_vt = mir_field_access_dest_vt(ctx, clone(base_type), clone(field_name), field_idx, is_f64_field)
    let dest = ctx_api_local_alloc::ctx_fresh_local(ctx, dest_vt)
    let mut field_off = field_idx * 4
    // Default to dest_vt so Memory64 struct.get widen/narrow sees REF vs i32.
    // Previously VOID left the emitter treating String/struct fields as i32.
    let mut field_vt = dest_vt
    if len(base_type) > 0 {
        field_off = ctx_struct_layout::ctx_struct_field_offset(ctx, clone(base_type), field_idx)
        if is_f64_field {
            field_vt = value_types::VT_F64()
        }
        if dest_vt == value_types::VT_I64() {
            field_vt = value_types::VT_I64()
        }
        if ctx_struct_layout::ctx_struct_field_is_v128(ctx, clone(base_type), field_idx) {
            field_vt = value_types::VT_V128()
        }
        let ft = ctx_struct_lookup::ctx_get_field_type(ctx, clone(base_type), clone(field_name))
        if len(ft) > 0 {
            ctx_api_local_types::ctx_set_local_type(ctx, dest, ctx_struct_layout::ctx_maybe_enum_return_type_name(ctx, ft))
        } else if dest_vt == value_types::VT_GC_REF() || dest_vt == value_types::VT_REF() {
            // Missing field type metadata must not fall through to string
            // inference (#726 json JsonParseStep.value).
            ctx_api_local_types::ctx_set_local_type(ctx, dest, String_from("enum:open"))
        }
    }
    let mut struct_byte_size = 0
    if len(base_type) > 0 {
        struct_byte_size = ctx_struct_layout::ctx_struct_byte_size(ctx, clone(base_type))
    }
    ctx_api_emit::ctx_emit(ctx, inst_struct_get::MirInst_struct_get_field_idx(base_idx, clone(base_type), field_off, field_idx, struct_byte_size, field_vt, dest))
    dest
}
