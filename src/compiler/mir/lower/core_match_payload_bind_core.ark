// Arukellt Selfhost - CoreHIR match payload variant field binding.

use mir::lower::ctx_gc_enum
use mir::lower::ctx_struct_layout
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::inst_struct_get
use mir::inst_gc_struct
use mir::inst_local_get
use mir::inst_local_set
use mir::lower::core_expr_shape_accessors
use mir::lower::core_match_payload_bind_types
use mir::value_types

fn core_emit_payload_variant_binds(ctx: LowerCtx, exprs: Vec<CoreHirExpr>, pat: CoreHirExpr, scrut_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool, scrut_ok_is_i32: bool, scrut_ok_is_ref: bool) {
    let variant_name = core_expr_shape_accessors::mir_core_expr_text(pat)
    let mut bi = 0
    while bi < core_expr_shape_accessors::mir_core_expr_child_count(pat) {
        let bind_pat = get_unchecked(exprs, core_expr_shape_accessors::mir_core_expr_child(pat, bi))
        let bind_vt = core_match_payload_bind_types::core_payload_field_vt(ctx, clone(variant_name), bi, scrut_ok_is_f64, scrut_ok_is_i64, scrut_ok_is_ref)
        let bind_local = ctx_api_local_alloc::ctx_alloc_local(ctx, core_expr_shape_accessors::mir_core_expr_text(bind_pat), bind_vt)
        core_match_payload_bind_types::set_gc_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, bind_vt, bi)
        if bind_vt == value_types::VT_GC_REF() || core_match_payload_bind_types::core_payload_gc_field_is_ref(ctx, clone(variant_name), bi) {
            if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            }
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
        if bind_vt == value_types::VT_I32() && scrut_ok_is_i32 && bi == 0 {
            if core_match_payload_bind_types::core_payload_i32_name_needs_type(clone(variant_name)) {
                ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("i32"))
            }
        }
        if bind_vt == value_types::VT_GC_REF() && scrut_ok_is_ref && bi == 0 {
            if core_match_payload_bind_types::core_match_variant_is_some_or_ok(clone(variant_name)) {
                if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                    ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("string"))
                }
            }
        }
        // Infer concrete payload type from scrutinee type for Option/Result.
        if bi == 0 {
            core_infer_payload_bind_type(ctx, clone(variant_name), bind_local, bind_vt, scrut_idx)
        }
        emit_payload_field_bind(ctx, variant_name, bi, scrut_idx, bind_vt, bind_local)
        bi = bi + 1
    }
}

// Extract the concrete payload element type from the scrutinee type name.
// When scrutinee has type "option:Token" or "Option_Token", bind local should get "Token".
// When scrutinee has type "Result_i32_String", Ok bind should get "i32", Err bind should get "String".
fn core_payload_elem_type_from_scrut(scrut_type: String, is_some_or_ok: bool) -> String {
    if is_some_or_ok {
        if starts_with(clone(scrut_type), String_from("option:")) {
            return substring(scrut_type, 7, len(scrut_type))
        }
        if starts_with(clone(scrut_type), String_from("Option_")) {
            return substring(scrut_type, 7, len(scrut_type))
        }
        if starts_with(clone(scrut_type), String_from("Result_")) || starts_with(clone(scrut_type), String_from("result:")) {
            return core_match_payload_bind_types::core_extract_first_result_type_param(scrut_type)
        }
        return String_new()
    }
    if starts_with(clone(scrut_type), String_from("Result_")) || starts_with(clone(scrut_type), String_from("result:")) {
        return core_match_payload_bind_types::core_extract_second_result_type_param(scrut_type)
    }
    String_new()
}

// Infer the concrete payload type for the first bind of Some/Ok/Err patterns
// from the scrutinee's type name, then fix up the local's type and vt.
fn core_infer_payload_bind_type(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, scrut_idx: i32) {
    let is_some_or_ok = core_match_payload_bind_types::core_match_variant_is_some_or_ok(clone(variant_name))
    let is_err = core_match_payload_bind_types::core_match_variant_is_err(clone(variant_name))
    if !is_some_or_ok && !is_err {
        return
    }
    // Override when type is empty, "enum:open", or contains an
    // unresolved type variable.  Also override the "string"
    // fallback set by set_gc_payload_bind_type_if_needed for Err
    // variants, so that non-String Err payloads (e.g. AppError)
    // get the correct type.
    let current_type = ctx_api_local_types::ctx_get_local_type(ctx, bind_local)
    if !(len(current_type) == 0 || eq(current_type, String_from("enum:open")) || starts_with(current_type, String_from("enum:")) || (is_err && eq(current_type, String_from("string")))) {
        return
    }
    let scrut_type = ctx_api_local_types::ctx_get_local_type(ctx, scrut_idx)
    let elem_ty = core_payload_elem_type_from_scrut(scrut_type, is_some_or_ok)
    if len(elem_ty) == 0 {
        return
    }
    // For non-scalar, non-String types (e.g. AppError),
    // prefix with "enum:" so the emitter's ref local type
    // inference maps it to the enum open type.
    // However, types that already have a recognised ref
    // prefix (vec:, hashmap:, Option_, Result_, option:,
    // result:) should NOT be prefixed with "enum:" because
    // the emitter has dedicated GC type mappings for them.
    let mut set_type = clone(elem_ty)
    if !core_match_payload_bind_types::core_payload_scalar_type_name(clone(elem_ty)) {
        if !eq(clone(elem_ty), "String") && !eq(clone(elem_ty), "string") {
            if !starts_with(clone(elem_ty), String_from("vec:")) && !starts_with(clone(elem_ty), String_from("hashmap:")) && !starts_with(clone(elem_ty), String_from("Option_")) && !starts_with(clone(elem_ty), String_from("option:")) && !starts_with(clone(elem_ty), String_from("Result_")) && !starts_with(clone(elem_ty), String_from("result:")) {
                set_type = concat(String_from("enum:"), clone(elem_ty))
            }
        }
    }
    ctx_api_local_types::ctx_set_local_type(ctx, bind_local, set_type)
    // Fix vt: if the element type is scalar, override
    // VT_GC_REF with VT_I32 to match the actual payload.
    if core_match_payload_bind_types::core_payload_scalar_type_name(clone(elem_ty)) {
        if bind_vt == value_types::VT_GC_REF() {
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_I32())
        }
    } else {
        // Non-scalar types (String, Vec, etc.) are GC refs
        // on GC targets.  Override VT_I32 to VT_GC_REF so
        // that the local is declared as a ref and the enum
        // variant is created with a ref field.  This is
        // critical when core_payload_gc_field_is_ref could
        // not detect the ref type because the variant was
        // previously registered with an i32 payload.
        if ctx_gc_enum::ctx_is_gc_target(ctx) {
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
    }
}

fn emit_payload_field_bind(ctx: LowerCtx, variant_name: String, bi: i32, scrut_idx: i32, bind_vt: i32, bind_local: i32) {
    // Use the current local vt, which may have been corrected by the
    // type inference block above (e.g. VT_GC_REF → VT_I32 for scalar
    // payloads from generic Option/Result types).
    let mut effective_vt = ctx_api_local_types::ctx_local_vt(ctx, bind_local)
    if effective_vt == value_types::VT_VOID() {
        effective_vt = bind_vt
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) && effective_vt != value_types::VT_GC_REF() {
        if core_match_payload_bind_types::core_payload_gc_field_is_ref(ctx, clone(variant_name), bi) {
            effective_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
            if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            }
        } else if core_match_payload_bind_types::core_payload_type_name_is_gc_ref(ctx, bind_local) {
            // The local type name indicates a GC ref type (String, Vec, etc.)
            // but core_payload_gc_field_is_ref could not detect it because
            // the variant was previously registered with an i32 payload.
            effective_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
    }
    let mut field_vt = value_types::VT_VOID()
    if effective_vt == value_types::VT_F64() {
        field_vt = value_types::VT_F64()
    } else {
        if effective_vt == value_types::VT_I64() {
            field_vt = value_types::VT_I64()
        }
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) {
        let mut type_slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
        // For all enum variants (Ok, Err, Some, None, etc.), try payload-specific
        // variant lookup to ensure the variant type matches the payload type.
        // This is critical when Ok and Err have different payload types (e.g.,
        // Ok<i32> vs Err<String>) — name-only lookup may return the wrong variant.
        if bi == 0 {
            let payload_vts = Vec_new_i32()
            push(payload_vts, effective_vt)
            // Pass the bind local's type name so that the correct GC ref
            // type offset is used (e.g. ref10 for Vec, ref0 for String).
            let bind_type_name = ctx_api_local_types::ctx_get_local_type(ctx, bind_local)
            let payload_slot = ctx_gc_enum::ctx_ensure_gc_enum_payload_variant_typed(ctx, clone(variant_name), payload_vts, clone(bind_type_name))
            if payload_slot >= 0 {
                type_slot = payload_slot
            }
        }
        ctx_api_emit::ctx_emit(ctx, inst_gc_struct::MirInst_gc_struct_get(bind_local, scrut_idx, type_slot, bi + 1, field_vt))
        return
    }
    ctx_api_emit::ctx_emit(ctx, inst_local_get::MirInst_local_get(scrut_idx))
    ctx_api_emit::ctx_emit(ctx, inst_struct_get::MirInst_struct_get_field_idx(scrut_idx, clone(variant_name), ctx_struct_layout::ctx_struct_field_offset(ctx, clone(variant_name), bi + 1), bi + 1, ctx_struct_layout::ctx_struct_byte_size(ctx, clone(variant_name)), field_vt, bind_local))
    ctx_api_emit::ctx_emit(ctx, inst_local_set::MirInst_local_set(bind_local))
}
