use mir::lower::ctx_gc_enum
use mir::lower::ctx_struct_layout
use mir::lower::ctx_struct_field_type
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower::ctx_types
// Arukellt Selfhost - CoreHIR match payload variant field binding.

use mir::inst_struct_get
use mir::inst_gc_struct
use mir::inst_local_get
use mir::inst_local_set
use mir::lower::core_expr_shape_accessors
use mir::value_types

fn core_emit_payload_variant_binds(ctx: LowerCtx, exprs: Vec<CoreHirExpr>, pat: CoreHirExpr, scrut_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool, scrut_ok_is_i32: bool, scrut_ok_is_ref: bool) {
    let variant_name = core_expr_shape_accessors::mir_core_expr_text(pat)
    let mut bi = 0
    while bi < core_expr_shape_accessors::mir_core_expr_child_count(pat) {
        let bind_pat = get_unchecked(exprs, core_expr_shape_accessors::mir_core_expr_child(pat, bi))
        let bind_vt = core_payload_field_vt(ctx, clone(variant_name), bi, scrut_ok_is_f64, scrut_ok_is_i64, scrut_ok_is_ref)
        let bind_local = ctx_api_local_alloc::ctx_alloc_local(ctx, core_expr_shape_accessors::mir_core_expr_text(bind_pat), bind_vt)
        set_gc_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, bind_vt, bi)
        if bind_vt == value_types::VT_GC_REF() || core_payload_gc_field_is_ref(ctx, clone(variant_name), bi) {
            if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            }
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
        if bind_vt == value_types::VT_I32() && scrut_ok_is_i32 && bi == 0 {
            if core_payload_i32_name_needs_type(clone(variant_name)) {
                ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("i32"))
            }
        }
        if bind_vt == value_types::VT_GC_REF() && scrut_ok_is_ref && bi == 0 {
            if core_match_variant_is_some_or_ok(clone(variant_name)) {
                if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                    ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("string"))
                }
            }
        }
        // Infer concrete payload type from scrutinee type for Option/Result.
        // When scrutinee has type "option:Token" or "Option_Token", bind local should get "Token".
        // When scrutinee has type "Result_i32_String", Ok bind should get "i32", Err bind should get "String".
        if bi == 0 {
            let is_some_or_ok = core_match_variant_is_some_or_ok(clone(variant_name))
            let is_err = core_match_variant_is_err(clone(variant_name))
            if is_some_or_ok || is_err {
                if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 || eq(ctx_api_local_types::ctx_get_local_type(ctx, bind_local), String_from("enum:open")) || starts_with(ctx_api_local_types::ctx_get_local_type(ctx, bind_local), String_from("enum:")) {
                    let scrut_type = ctx_api_local_types::ctx_get_local_type(ctx, scrut_idx)
                    let mut elem_ty = String_new()
                    if is_some_or_ok {
                        if starts_with(clone(scrut_type), String_from("option:")) {
                            elem_ty = substring(scrut_type, 7, len(scrut_type))
                        } else {
                            if starts_with(clone(scrut_type), String_from("Option_")) {
                                elem_ty = substring(scrut_type, 7, len(scrut_type))
                            } else {
                                if starts_with(clone(scrut_type), String_from("Result_")) {
                                    elem_ty = core_extract_first_result_type_param(scrut_type)
                                } else {
                                    if starts_with(clone(scrut_type), String_from("result:")) {
                                        elem_ty = core_extract_first_result_type_param(scrut_type)
                                    }
                                }
                            }
                        }
                    } else {
                        if starts_with(clone(scrut_type), String_from("Result_")) {
                            elem_ty = core_extract_second_result_type_param(scrut_type)
                        } else {
                            if starts_with(clone(scrut_type), String_from("result:")) {
                                elem_ty = core_extract_second_result_type_param(scrut_type)
                            }
                        }
                    }
                    if len(elem_ty) > 0 {
                        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, elem_ty)
                        // Fix vt: if the element type is scalar, override
                        // VT_GC_REF with VT_I32 to match the actual payload.
                        if core_payload_scalar_type_name(clone(elem_ty)) {
                            if bind_vt == value_types::VT_GC_REF() {
                                ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_I32())
                            }
                        }
                    }
                }
            }
        }
        emit_payload_field_bind(ctx, variant_name, bi, scrut_idx, bind_vt, bind_local)
        bi = bi + 1
    }
}

fn emit_payload_field_bind(ctx: LowerCtx, variant_name: String, bi: i32, scrut_idx: i32, bind_vt: i32, bind_local: i32) {
    // Use the current local vt, which may have been corrected by the
    // type inference block above (e.g. VT_GC_REF → VT_I32 for scalar
    // payloads from generic Option/Result types).
    let mut effective_vt = ctx_api_local_types::ctx_local_vt(ctx, bind_local)
    if effective_vt == value_types::VT_VOID() {
        effective_vt = bind_vt
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) && effective_vt != value_types::VT_GC_REF() {
        if core_payload_gc_field_is_ref(ctx, clone(variant_name), bi) {
            effective_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
            if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            }
        }
    }
    let mut field_vt = value_types::VT_VOID()
    if effective_vt == value_types::VT_F64() {
        field_vt = value_types::VT_F64()
    } else {
        if effective_vt == value_types::VT_I64() {
            field_vt = value_types::VT_I64()
        }
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) {
        let mut type_slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
        // For all enum variants (Ok, Err, Some, None, etc.), try payload-specific
        // variant lookup to ensure the variant type matches the payload type.
        // This is critical when Ok and Err have different payload types (e.g.,
        // Ok<i32> vs Err<String>) — name-only lookup may return the wrong variant.
        if bi == 0 {
            let payload_vts = Vec_new_i32()
            push(payload_vts, effective_vt)
            let payload_slot = ctx_gc_enum::ctx_ensure_gc_enum_payload_variant(ctx, clone(variant_name), payload_vts)
            if payload_slot >= 0 {
                type_slot = payload_slot
            }
        }
        ctx_api_emit::ctx_emit(ctx, inst_gc_struct::MirInst_gc_struct_get(bind_local, scrut_idx, type_slot, bi + 1, field_vt))
        return
    }
    ctx_api_emit::ctx_emit(ctx, inst_local_get::MirInst_local_get(scrut_idx))
    ctx_api_emit::ctx_emit(ctx, inst_struct_get::MirInst_struct_get(ctx_struct_layout::ctx_struct_field_offset(ctx, clone(variant_name), bi + 1), field_vt))
    ctx_api_emit::ctx_emit(ctx, inst_local_set::MirInst_local_set(bind_local))
}

fn core_match_variant_is_err(variant_name: String) -> bool {
    eq(clone(variant_name), "Err") || eq(clone(variant_name), "Result::Err")
}

fn core_match_variant_is_some_or_ok(variant_name: String) -> bool {
    if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") {
        return true
    }
    if eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
        return true
    }
    false
}

fn core_payload_field_vt(ctx: LowerCtx, variant_name: String, field_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool, scrut_ok_is_ref: bool) -> i32 {
    if ctx_struct_layout::ctx_struct_field_is_gc_ref(ctx, clone(variant_name), field_idx + 1) {
        return value_types::VT_GC_REF()
    }
    let field_type = ctx_struct_field_type::ctx_struct_field_type_name(ctx, clone(variant_name), field_idx + 1)
    if len(field_type) > 0 && !core_payload_scalar_type_name(clone(field_type)) {
        return value_types::VT_GC_REF()
    }
    if core_match_variant_is_err(clone(variant_name)) && field_idx == 0 {
        return value_types::VT_GC_REF()
    }
    if scrut_ok_is_ref && field_idx == 0 {
        if core_match_variant_is_some_or_ok(clone(variant_name)) {
            return value_types::VT_GC_REF()
        }
    }
    let mut field_is_f64 = ctx_struct_layout::ctx_struct_field_is_f64(ctx, clone(variant_name), field_idx + 1)
    if !field_is_f64 && scrut_ok_is_f64 && field_idx == 0 {
        if core_match_variant_is_some_or_ok(clone(variant_name)) {
            field_is_f64 = true
        }
    }
    if field_is_f64 {
        return value_types::VT_F64()
    }
    let field_is_i64 = ctx_struct_layout::ctx_struct_field_is_i64(ctx, clone(variant_name), field_idx + 1)
    if field_is_i64 {
        return value_types::VT_I64()
    }
    if scrut_ok_is_i64 && field_idx == 0 {
        if core_match_variant_is_some_or_ok(clone(variant_name)) {
            return value_types::VT_I64()
        }
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) && core_payload_gc_field_is_ref(ctx, clone(variant_name), field_idx) {
        return value_types::VT_GC_REF()
    }
    value_types::VT_I32()
}

fn core_payload_gc_field_is_ref(ctx: LowerCtx, variant_name: String, field_idx: i32) -> bool {
    let slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
    if slot < 0 {
        return false
    }
    let sig = clone(get_unchecked(ctx.gc_enum_variant_sigs, slot))
    if field_idx == 0 {
        if contains(clone(sig), String_from("_f1_ref")) {
            return true
        }
    }
    false
}

fn core_payload_i32_name_needs_type(variant_name: String) -> bool {
    core_match_variant_is_some_or_ok(variant_name)
}

fn set_gc_payload_bind_type_if_needed(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, field_idx: i32) {
    if bind_vt != value_types::VT_GC_REF() {
        return
    }
    let field_type = ctx_struct_field_type::ctx_struct_field_type_name(ctx, clone(variant_name), field_idx + 1)
    if eq(clone(field_type), "String") || eq(clone(field_type), "string") {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("string"))
        return
    }
    if len(field_type) > 0 && ctx_struct_layout::ctx_is_registered_enum_type(ctx, clone(field_type)) {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if len(field_type) > 0 && !core_payload_scalar_type_name(clone(field_type)) {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if core_match_variant_is_err(clone(variant_name)) && field_idx == 0 {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("string"))
    }
}

fn core_payload_scalar_type_name(type_name: String) -> bool {
    if eq(clone(type_name), "i32") || eq(clone(type_name), "I32") {
        return true
    }
    if eq(clone(type_name), "i64") || eq(clone(type_name), "I64") {
        return true
    }
    if eq(clone(type_name), "u64") || eq(clone(type_name), "U64") {
        return true
    }
    if eq(clone(type_name), "f64") || eq(clone(type_name), "F64") {
        return true
    }
    if eq(clone(type_name), "bool") || eq(clone(type_name), "Bool") {
        return true
    }
    if eq(clone(type_name), "char") {
        return true
    }
    false
}

// Extract the first type parameter from a Result type string like
// "Result_i32_String" or "result:i32:String".
fn core_extract_first_result_type_param(scrut_type: String) -> String {
    let prefix_len = 7
    let rest = substring(scrut_type, prefix_len, len(scrut_type))
    let mut sep = 0 - 1
    let mut i = 0
    let rlen = len(rest)
    while i < rlen {
        let ch = char_at(rest, i)
        if ch == 95 || ch == 58 {
            sep = i
            i = rlen
        }
        i = i + 1
    }
    if sep < 0 {
        return rest
    }
    substring(rest, 0, sep)
}

// Extract the second type parameter from a Result type string like
// "Result_i32_String" or "result:i32:String".
fn core_extract_second_result_type_param(scrut_type: String) -> String {
    let prefix_len = 7
    let rest = substring(scrut_type, prefix_len, len(scrut_type))
    let mut first_sep = 0 - 1
    let mut i = 0
    let rlen = len(rest)
    while i < rlen {
        let ch = char_at(rest, i)
        if ch == 95 || ch == 58 {
            first_sep = i
            i = rlen
        }
        i = i + 1
    }
    if first_sep < 0 {
        return String_new()
    }
    substring(rest, first_sep + 1, rlen)
}
