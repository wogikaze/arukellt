// Arukellt Selfhost - monomorphized parameter type substitution (#707).
//
// After mono type params are set up, re-substitute type-variable param
// locals with the concrete monomorphized type.

use mir::lower::ann_types
use mir::lower::ctx_api_function_frame
use mir::lower::ctx_api_local_types
use mir::lower::ctx_current_storage
use mir::lower::ctx_mono_type_params
use mir::function_identity
use mir::function_param_view
use mir::local_access
use mir::value_types

fn mir_substitute_mono_param_types(ctx: LowerCtx) {
    let func = ctx_current_storage::ctx_current_func_value(ctx)
    let fn_name = function_identity::MirFunction_name(func)
    // Extract the mono type suffix from the function name (e.g. "i32" from
    // "unwrap_or_default__i32"). If no "__" separator, this is not a
    // specialized mono function â€” skip substitution.
    let mono_suffix = extract_mono_suffix(clone(fn_name))
    if len(clone(mono_suffix)) == 0 {
        return
    }
    // Prefer the mono type parameter mapping (set up by
    // ctx_setup_mono_type_params_by_ordinal) which correctly maps
    // individual type variables to their concrete types even for
    // multi-parameter generics (e.g. Tâ†’i32, Eâ†’String).
    let has_mono_map = ctx_mono_type_params::ctx_has_mono_type_params(ctx)
    let param_count = function_param_view::MirFunction_param_count(func)
    let mut p = 0
    while p < param_count {
        let param = function_param_view::MirFunction_param_at(func, p)
        let ty_name = local_access::MirLocal_type_name(param)
        // Handle composite type names containing type variables, e.g.
        // "?Option:T" or "?Result:T" â€” substitute the inner type variable
        // with the concrete monomorphized type.
        if starts_with(clone(ty_name), String_from("?Option:")) {
            let type_var = substring(clone(ty_name), 8, len(ty_name))
            let concrete = resolve_concrete_type(ctx, clone(type_var), clone(mono_suffix), has_mono_map)
            if len(concrete) > 0 {
                let mono_type_name = concat(String_from("Option:"), concrete)
                ctx_api_local_types::ctx_set_local_vt(ctx, p, value_types::VT_GC_REF())
                ctx_api_local_types::ctx_set_local_type(ctx, p, clone(mono_type_name))
                ctx_api_function_frame::ctx_set_func_param_type(ctx, p, value_types::VT_GC_REF(), mono_type_name)
            }
        } else {
            if starts_with(clone(ty_name), String_from("?Result:")) {
                // Result<T, E> â€” extract the first type variable T and substitute.
                let rest = substring(clone(ty_name), 8, len(ty_name))
                let type_var = extract_first_type_var(rest)
                let concrete = resolve_concrete_type(ctx, clone(type_var), clone(mono_suffix), has_mono_map)
                if len(concrete) > 0 {
                    let mono_type_name = concat(String_from("enum:Result"), concat(String_from(":"), concrete))
                    ctx_api_local_types::ctx_set_local_vt(ctx, p, value_types::VT_GC_REF())
                    ctx_api_local_types::ctx_set_local_type(ctx, p, clone(mono_type_name))
                    ctx_api_function_frame::ctx_set_func_param_type(ctx, p, value_types::VT_GC_REF(), mono_type_name)
                }
            } else {
                if starts_with(clone(ty_name), String_from("?")) {
                    // Plain type variable (e.g. "?T") â€” substitute with the
                    // concrete type from the mono mapping or function name suffix.
                    let type_var = substring(clone(ty_name), 1, len(ty_name))
                    let concrete = resolve_concrete_type(ctx, clone(type_var), clone(mono_suffix), has_mono_map)
                    if len(concrete) > 0 {
                        let pvt = ann_types::mir_local_vt_from_type_name(clone(concrete))
                        ctx_api_local_types::ctx_set_local_vt(ctx, p, pvt)
                        ctx_api_local_types::ctx_set_local_type(ctx, p, clone(concrete))
                        ctx_api_function_frame::ctx_set_func_param_type(ctx, p, pvt, concrete)
                    }
                }
            }
        }
        p = p + 1
    }
}

// Resolve a type variable name to its concrete monomorphized type.
// Uses the mono type parameter mapping when available, falling back to
// the function name suffix.  For multi-parameter generics the suffix
// contains multiple type keys separated by "__" (e.g. "i32__String");
// the fallback uses the type variable name to pick the right one.
fn resolve_concrete_type(ctx: LowerCtx, type_var: String, mono_suffix: String, has_mono_map: bool) -> String {
    if has_mono_map {
        let resolved = ctx_mono_type_params::ctx_resolve_mono_type_param(ctx, clone(type_var))
        if len(resolved) > 0 {
            return resolved
        }
    }
    // Fallback: split the suffix by "__" and use the type variable name
    // to determine the correct type parameter index.
    let type_keys = split_mono_suffix(clone(mono_suffix))
    let key_count = len(type_keys)
    if key_count == 0 {
        return String_new()
    }
    if key_count == 1 {
        return get_unchecked(type_keys, 0)
    }
    let idx = mono_type_var_to_index(clone(type_var))
    if idx < 0 || idx >= key_count {
        return get_unchecked(type_keys, 0)
    }
    get_unchecked(type_keys, idx)
}

// Split a mono suffix string by "__" into individual type keys.
fn split_mono_suffix(suffix: String) -> Vec<String> {
    let result = Vec_new_String()
    let slen = len(suffix)
    let mut start = 0
    let mut i = 0
    while i < slen - 1 {
        if char_at(suffix, i) == 95 && char_at(suffix, i + 1) == 95 {
            push(result, substring(suffix, start, i))
            start = i + 2
            i = i + 2
        } else {
            i = i + 1
        }
    }
    if start <= slen {
        push(result, substring(suffix, start, slen))
    }
    result
}

// Map a type variable name to a type parameter index using common
// naming conventions (Tâ†’0, Eâ†’1, Uâ†’2, Vâ†’3, Kâ†’0, etc.).
fn mono_type_var_to_index(type_var: String) -> i32 {
    if eq(clone(type_var), String_from("T")) { return 0 }
    if eq(clone(type_var), String_from("E")) { return 1 }
    if eq(clone(type_var), String_from("U")) { return 2 }
    if eq(clone(type_var), String_from("V")) { return 3 }
    if eq(clone(type_var), String_from("W")) { return 4 }
    if eq(clone(type_var), String_from("K")) { return 0 }
    if eq(clone(type_var), String_from("A")) { return 0 }
    if eq(clone(type_var), String_from("B")) { return 1 }
    if eq(clone(type_var), String_from("C")) { return 2 }
    if eq(clone(type_var), String_from("D")) { return 3 }
    0
}

// Extract the first type variable from a composite type string like "T:U".
fn extract_first_type_var(rest: String) -> String {
    let rlen = len(rest)
    let mut ci = 0
    while ci < rlen {
        if char_at(rest, ci) == 58 {
            return substring(rest, 0, ci)
        }
        ci = ci + 1
    }
    rest
}

fn extract_mono_suffix(fn_name: String) -> String {
    // Extract the full suffix after the FIRST "__" separator.
    // This contains all type parameter keys joined by "__"
    // (e.g. "i32__String" for ok_or_default__i32__String).
    let name_len = len(fn_name)
    let mut i = 0
    while i < name_len - 1 {
        if char_at(fn_name, i) == 95 && char_at(fn_name, i + 1) == 95 {
            return substring(fn_name, i + 2, name_len)
        }
        i = i + 1
    }
    String_new()
}
