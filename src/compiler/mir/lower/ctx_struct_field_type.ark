// Arukellt MIR lowering context - struct field type queries.

use mir::lower::ctx_struct_storage

fn ctx_struct_field_is_f64(ctx: LowerCtx, struct_name: String, field_idx: i32) -> bool {
    let sc = ctx_struct_storage::ctx_struct_layout_count(ctx)
    let mut offset = 0
    let mut si = 0
    while si < sc {
        let sn = ctx_struct_storage::ctx_struct_layout_name_at(ctx, si)
        let fc = ctx_struct_storage::ctx_struct_layout_field_count_at(ctx, si)
        if eq(clone(sn), clone(struct_name)) {
            if field_idx < fc {
                let ft = ctx_struct_storage::ctx_struct_field_type_at_offset(ctx, offset + field_idx)
                return eq(clone(ft), "f64")
            }
            return false
        }
        offset = offset + fc
        si = si + 1
    }
    false
}
