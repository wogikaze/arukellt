use mir::lower::ast_node
use mir::lower::ctx_api_nesting
use mir::lower::ctx_api_local_alloc
use mir::lower_kinds
use mir::lower::ctx_types
use mir::inst_structured_control
use mir::inst_local_get
use mir::inst_op
use mir::opcodes
use mir::lower::match
use mir::value_types

fn lower_single_match_compare_prefix(ctx: LowerCtx, arm_node: AstNode, pat: AstNode, payload_info: MirMatchPayloadInfo, scrut_idx: i32, has_guard: bool, if_depth: i32) -> i32 {
    let mut depth = if_depth
    let compare_idx = match::mir_match_payload_compare_idx(payload_info)
    ctx_emit(ctx, inst_local_get::MirInst_local_get(compare_idx))
    let pat_idx = lower_expr(ctx, pat)
    let cmp_dest = ctx_fresh_local(ctx, value_types::VT_I32())
    ctx_emit(ctx, inst_op::MirInst_binop(opcodes::MIR_EQ(), cmp_dest, compare_idx, pat_idx))
    ctx_emit(ctx, inst_structured_control::MirInst_if())
    ctx_api_nesting::ctx_push_nesting(ctx)
    depth = depth + 1
    match::mir_emit_payload_variant_binds_if_needed(ctx, payload_info, pat, scrut_idx)
    if has_guard {
        let guard2 = ast_node::node_child_at(arm_node, 1)
        lower_expr(ctx, guard2)
        match::mir_emit_match_guard_begin(ctx)
        depth = depth + 1
    }
    depth
}
