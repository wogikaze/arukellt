use mir::lower::match_payload_bind
use mir::lower::match_payload_prepare

fn mir_prepare_match_payload(ctx: LowerCtx, node: AstNode, child_count: i32, scrut_idx: i32) -> MirMatchPayloadInfo {
    match_payload_prepare::mir_prepare_match_payload(ctx, node, child_count, scrut_idx)
}

fn mir_match_payload_compare_idx(info: MirMatchPayloadInfo) -> i32 {
    match_payload_prepare::mir_match_payload_info_compare_idx(info)
}

fn mir_emit_match_ident_bind(ctx: LowerCtx, pat: AstNode, scrut_idx: i32) {
    match_payload_bind::mir_emit_match_ident_bind(ctx, pat, scrut_idx)
}

fn mir_emit_payload_variant_binds_if_needed(ctx: LowerCtx, info: MirMatchPayloadInfo, pat: AstNode, scrut_idx: i32) {
    match_payload_bind::mir_emit_payload_variant_binds_if_needed(ctx, info, pat, scrut_idx)
}
