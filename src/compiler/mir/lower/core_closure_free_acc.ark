// Arukellt Selfhost - CoreHIR closure free-variable accumulator.

fn core_closure_push_unique_cap(acc: Vec<String>, name: String) {
    let mut j = len(acc) - 1
    let mut dup = false
    while j >= 0 && !dup {
        if eq(clone(get_unchecked(acc, j)), clone(name)) {
            dup = true
        }
        j = j - 1
    }
    if !dup {
        push(acc, name)
    }
}
