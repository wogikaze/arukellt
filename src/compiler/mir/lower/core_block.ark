use mir::lower::ctx_api_emit
use mir::lower::ctx_types
use mir::lower::core_expr_shape_accessors

fn lower_core_block(ctx: LowerCtx, exprs: Vec<CoreHirExpr>, expr: CoreHirExpr) -> i32 {
    let child_count = core_expr_shape_accessors::mir_core_expr_child_count(expr)
    let mut last_result = 0 - 1
    let mut i = 0
    while i < child_count {
        let child_result = lower_core_expr(ctx, exprs, core_expr_shape_accessors::mir_core_expr_child(expr, i))
        // Intermediate results live in locals; do not drop from an empty stack.
        if i < child_count - 1 {
            last_result = 0 - 1
        } else {
            last_result = child_result
        }
        i = i + 1
    }
    last_result
}
