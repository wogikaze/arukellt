use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower::ctx_types
use mir::inst_call
use mir::inst_local_get
use mir::inst_local_set
use mir::value_types

fn hof_result_local(ctx: LowerCtx) -> i32 {
    ctx_api_local_alloc::ctx_fresh_local(ctx, value_types::VT_I32())
}

fn emit_hof_result_vec_init(ctx: LowerCtx, result_local: i32, new_callee: String, local_type: String) {
    ctx_api_emit::ctx_emit(ctx, inst_call::MirInst_call(new_callee, 0, result_local))
    ctx_api_emit::ctx_emit(ctx, inst_local_set::MirInst_local_set(result_local))
    ctx_api_local_types::ctx_set_local_type(ctx, result_local, local_type)
}

fn emit_hof_result_value(ctx: LowerCtx, local_id: i32) -> i32 {
    ctx_api_emit::ctx_emit(ctx, inst_local_get::MirInst_local_get(local_id))
    local_id
}

fn emit_hof_result_select(ctx: LowerCtx, acc_local: i32, result_local: i32, use_acc: bool) -> i32 {
    if use_acc {
        return emit_hof_result_value(ctx, acc_local)
    }
    emit_hof_result_value(ctx, result_local)
}
