use mir::lower::ctx_api_variants
use mir::lower::ctx_types
// Arukellt Selfhost - MIR lowering enum and variant layout registration.

use corehir::layout_decl_name
use corehir::layout_decl_variants
use corehir::layout_variant
use mir::lower::registry_enum_payload

fn mir_enum_has_payload(decl: CoreHirLayoutDecl) -> bool {
    registry_enum_payload::mir_enum_has_payload(decl)
}

fn mir_register_payload_variant_layout(ctx: LowerCtx, full_name: String, variant: CoreHirLayoutVariant) {
    registry_enum_payload::mir_register_payload_variant_layout(ctx, full_name, variant)
}

fn mir_register_enum_layout(ctx: LowerCtx, decl: CoreHirLayoutDecl) {
    let vc = layout_decl_variants::layout_decl_variant_count(decl)
    let has_payload = mir_enum_has_payload(decl)
    let mut vi = 0
    while vi < vc {
        let variant = layout_decl_variants::layout_decl_variant_at(decl, vi)
        let full_name = concat(layout_decl_name::layout_decl_name(decl), concat(String_from("::"), layout_variant::layout_variant_name(variant)))
        ctx_api_variants::ctx_register_variant_tag(ctx, clone(full_name), vi)
        if has_payload {
            mir_register_payload_variant_layout(ctx, clone(full_name), variant)
        }
        vi = vi + 1
    }
}
