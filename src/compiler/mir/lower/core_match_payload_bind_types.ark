// CoreHIR match payload bind types.
use mir::lower::ctx_api_local_types
use mir::lower::ctx_gc_enum
use mir::lower::ctx_gc_struct
use mir::lower::ctx_struct_field_type
use mir::lower::ctx_struct_layout
use mir::value_types
fn core_match_variant_is_err(variant_name: String) -> bool {
    eq(clone(variant_name), "Err") || eq(clone(variant_name), "Result::Err")
}

fn core_match_variant_is_some_or_ok(variant_name: String) -> bool {
    if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") {
        return true
    }
    if eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
        return true
    }
    false
}

fn core_payload_field_vt(ctx: LowerCtx, variant_name: String, field_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool, scrut_ok_is_ref: bool) -> i32 {
    if ctx_struct_layout::ctx_struct_field_is_gc_ref(ctx, clone(variant_name), field_idx + 1) {
        return value_types::VT_GC_REF()
    }
    let field_type = ctx_struct_field_type::ctx_struct_field_type_name(ctx, clone(variant_name), field_idx + 1)
    if len(field_type) > 0 && !core_payload_scalar_type_name(clone(field_type)) {
        return value_types::VT_GC_REF()
    }
    if core_match_variant_is_err(clone(variant_name)) && field_idx == 0 {
        return value_types::VT_GC_REF()
    }
    if scrut_ok_is_ref && field_idx == 0 {
        if core_match_variant_is_some_or_ok(clone(variant_name)) {
            return value_types::VT_GC_REF()
        }
    }
    let mut field_is_f64 = ctx_struct_layout::ctx_struct_field_is_f64(ctx, clone(variant_name), field_idx + 1)
    if !field_is_f64 && scrut_ok_is_f64 && field_idx == 0 {
        if core_match_variant_is_some_or_ok(clone(variant_name)) {
            field_is_f64 = true
        }
    }
    if field_is_f64 {
        return value_types::VT_F64()
    }
    let field_is_i64 = ctx_struct_layout::ctx_struct_field_is_i64(ctx, clone(variant_name), field_idx + 1)
    if field_is_i64 {
        return value_types::VT_I64()
    }
    if scrut_ok_is_i64 && field_idx == 0 {
        if core_match_variant_is_some_or_ok(clone(variant_name)) {
            return value_types::VT_I64()
        }
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) && core_payload_gc_field_is_ref(ctx, clone(variant_name), field_idx) {
        return value_types::VT_GC_REF()
    }
    value_types::VT_I32()
}

fn core_payload_gc_field_is_ref(ctx: LowerCtx, variant_name: String, field_idx: i32) -> bool {
    let slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
    if slot < 0 {
        return false
    }
    let sig = clone(get_unchecked(ctx.gc_enum_variant_sigs, slot))
    if field_idx == 0 {
        if contains(clone(sig), String_from("_f1_ref")) {
            return true
        }
    }
    false
}

fn core_payload_i32_name_needs_type(variant_name: String) -> bool {
    core_match_variant_is_some_or_ok(variant_name)
}

fn set_gc_payload_bind_type_if_needed(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, field_idx: i32) {
    if bind_vt != value_types::VT_GC_REF() {
        return
    }
    let field_type = ctx_struct_field_type::ctx_struct_field_type_name(ctx, clone(variant_name), field_idx + 1)
    if eq(clone(field_type), "String") || eq(clone(field_type), "string") {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("string"))
        return
    }
    // Vec<T> must stay a container type — never enum:Vec<...> (#726 toml Table).
    let vec_type = normalize_core_payload_vec_type_name(clone(field_type))
    if len(vec_type) > 0 {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, vec_type)
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if len(field_type) > 0 && ctx_struct_layout::ctx_is_registered_enum_type(ctx, clone(field_type)) {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if len(field_type) > 0 && !core_payload_scalar_type_name(clone(field_type)) {
        // Named GC structs keep bare names for gcsref Option payloads (#726).
        if ctx_gc_struct::ctx_gc_struct_slot(ctx, clone(field_type)) >= 0 {
            ctx_api_local_types::ctx_set_local_type(ctx, bind_local, clone(field_type))
        } else {
            ctx_api_local_types::ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        }
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if core_match_variant_is_err(clone(variant_name)) && field_idx == 0 {
        ctx_api_local_types::ctx_set_local_type(ctx, bind_local, String_from("string"))
    }
}

fn normalize_core_payload_vec_type_name(field_type: String) -> String {
    if starts_with(clone(field_type), String_from("vec:")) {
        return field_type
    }
    if eq(clone(field_type), String_from("Vec")) {
        return String_from("vec:i32")
    }
    if starts_with(clone(field_type), String_from("Vec<")) && ends_with(clone(field_type), String_from(">")) {
        let inner = substring(clone(field_type), 4, len(field_type) - 1)
        return concat(String_from("vec:"), inner)
    }
    if starts_with(clone(field_type), String_from("Vec_")) {
        let inner = substring(clone(field_type), 4, len(field_type))
        return concat(String_from("vec:"), inner)
    }
    String_new()
}

fn core_payload_scalar_type_name(type_name: String) -> bool {
    if eq(clone(type_name), "i32") || eq(clone(type_name), "I32") {
        return true
    }
    if eq(clone(type_name), "i64") || eq(clone(type_name), "I64") {
        return true
    }
    if eq(clone(type_name), "u64") || eq(clone(type_name), "U64") {
        return true
    }
    if eq(clone(type_name), "f64") || eq(clone(type_name), "F64") {
        return true
    }
    if eq(clone(type_name), "bool") || eq(clone(type_name), "Bool") {
        return true
    }
    if eq(clone(type_name), "char") {
        return true
    }
    // Result<(), E> Ok payload is i32 0 (#726 toml_insert_key).
    if eq(clone(type_name), "unit") || eq(clone(type_name), "()") || eq(clone(type_name), "void") {
        return true
    }
    false
}

fn normalize_payload_elem_type_name(elem_ty: String) -> String {
    if eq(clone(elem_ty), String_from("Vec")) {
        return String_from("vec:i32")
    }
    if starts_with(clone(elem_ty), String_from("Vec<")) && ends_with(clone(elem_ty), String_from(">")) {
        let inner = substring(clone(elem_ty), 4, len(elem_ty) - 1)
        return concat(String_from("vec:"), inner)
    }
    if starts_with(clone(elem_ty), String_from("Vec_")) {
        return concat(String_from("vec:"), substring(clone(elem_ty), 4, len(elem_ty)))
    }
    elem_ty
}

fn payload_bind_needs_variant_slot(type_name: String, variant_name: String) -> bool {
    if core_match_variant_is_some_or_ok(clone(variant_name)) || core_match_variant_is_err(clone(variant_name)) {
        return false
    }
    if len(type_name) == 0 || eq(clone(type_name), String_from("enum:open")) {
        return false
    }
    // Nested enum payloads must stay enum-open (#726 nested_enum).
    if starts_with(clone(type_name), String_from("enum:")) {
        return false
    }
    false
}

fn core_extract_first_result_type_param(scrut_type: String) -> String {
    let prefix_len = 7
    let rest = substring(scrut_type, prefix_len, len(scrut_type))
    // Split Ok/Err on the LAST encoding separator (#726 toml/json).
    let sep_char = if starts_with(clone(scrut_type), String_from("result:")) { 58 } else { 95 }
    let last = find_last_sep_char(clone(rest), sep_char)
    if last > 0 {
        return normalize_payload_elem_type_name(substring(rest, 0, last))
    }
    normalize_payload_elem_type_name(rest)
}

fn core_extract_second_result_type_param(scrut_type: String) -> String {
    let prefix_len = 7
    let rest = substring(scrut_type, prefix_len, len(scrut_type))
    let sep_char = if starts_with(clone(scrut_type), String_from("result:")) { 58 } else { 95 }
    let last = find_last_sep_char(clone(rest), sep_char)
    if last >= 0 && last + 1 < len(rest) {
        return substring(rest, last + 1, len(rest))
    }
    String_new()
}

fn find_last_sep_char(s: String, sep_char: i32) -> i32 {
    let n = len(s)
    let mut i = n - 1
    while i >= 0 {
        if char_at(clone(s), i) == sep_char {
            return i
        }
        i = i - 1
    }
    0 - 1
}

fn core_payload_type_name_is_gc_ref(ctx: LowerCtx, bind_local: i32) -> bool {
    let type_name = ctx_api_local_types::ctx_get_local_type(ctx, bind_local)
    if len(type_name) == 0 {
        return false
    }
    if eq(clone(type_name), String_from("string")) || eq(clone(type_name), String_from("String")) {
        return true
    }
    if starts_with(clone(type_name), String_from("vec:")) {
        return true
    }
    if starts_with(clone(type_name), String_from("hashmap:")) {
        return true
    }
    if starts_with(clone(type_name), String_from("option:")) || starts_with(clone(type_name), String_from("Option_")) {
        return true
    }
    if starts_with(clone(type_name), String_from("Result_")) || starts_with(clone(type_name), String_from("result:")) || starts_with(clone(type_name), String_from("enum:")) || starts_with(clone(type_name), String_from("struct:")) {
        return true
    }
    false
}
