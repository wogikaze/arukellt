use mir::lower::entry_body_source

struct MirLowerInput {
    view: CoreHirMirView,
    body_source: MirLowerEntryBodySource,
    wit_paths: Vec<String>,
    decl_nodes: Vec<AstNode>,
    target: String,
    report_phase_timing: i32,
}

fn mir_lower_input_new(
    view: CoreHirMirView,
    fallback_source: MirLowerFallbackSource,
    wit_paths: Vec<String>,
    decl_nodes: Vec<AstNode>,
    target: String,
    report_phase_timing: i32
) -> MirLowerInput {
    let body_source = entry_body_source::mir_entry_body_source_new(entry_body_source::mir_entry_body_source_view_from_core(view), fallback_source)
    let mut effective_target = clone(target)
    if len(effective_target) == 0 {
        effective_target = String_from("wasm32-gc")
    }
    MirLowerInput {
        view: view,
        body_source: body_source,
        wit_paths: wit_paths,
        decl_nodes: decl_nodes,
        target: effective_target,
        report_phase_timing: report_phase_timing
    }
}

fn mir_lower_input_wit_paths(input: MirLowerInput) -> Vec<String> {
    input.wit_paths
}

fn mir_lower_input_decl_nodes(input: MirLowerInput) -> Vec<AstNode> {
    input.decl_nodes
}

fn mir_lower_input_view(input: MirLowerInput) -> CoreHirMirView {
    input.view
}

fn mir_lower_input_body_source(input: MirLowerInput) -> MirLowerEntryBodySource {
    input.body_source
}

fn mir_lower_input_target(input: MirLowerInput) -> String {
    clone(input.target)
}
