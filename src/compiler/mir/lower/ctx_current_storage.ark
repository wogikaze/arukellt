fn ctx_current_func_value(ctx: LowerCtx) -> MirFunction {
    ctx.func
}

fn ctx_set_current_func_value(ctx: LowerCtx, func: MirFunction) {
    ctx.func = func
}

fn ctx_current_block_value(ctx: LowerCtx) -> i32 {
    ctx.cur_block
}

fn ctx_set_current_block_value(ctx: LowerCtx, block_idx: i32) {
    ctx.cur_block = block_idx
}

fn ctx_current_module_value(ctx: LowerCtx) -> MirModule {
    ctx.module
}
