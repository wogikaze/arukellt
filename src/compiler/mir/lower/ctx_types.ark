// Arukellt Selfhost - MIR lowering context data contract.

use mir::types

pub struct LowerCtx {
    module: MirModule,
    func: MirFunction,
    cur_block: i32,
    local_names: Vec<String>,
    local_indices: Vec<i32>,
    fn_names: Vec<String>,
    fn_indices: Vec<i32>,
    fn_return_vts: Vec<i32>,
    fn_return_type_names: Vec<String>,
    loop_exit_block: i32,
    loop_cond_block: i32,
    nesting_depth: i32,
    loop_break_depth: i32,
    loop_continue_depth: i32,
    loop_break_local: i32,
    struct_names: Vec<String>,
    struct_field_counts: Vec<i32>,
    struct_all_fields: Vec<String>,
    struct_field_types: Vec<String>,
    local_types: Vec<String>,
    local_type_indices: Vec<i32>,
    variant_names: Vec<String>,
    variant_tags: Vec<i32>,
    payload_variants: Vec<String>,
    closure_counter: i32,
    closure_last_synth: String,
    closure_last_caps: String,
    closure_last_extra: i32,
    closure_bind_names: Vec<String>,
    closure_bind_synth: Vec<String>,
    closure_bind_caps: Vec<String>,
    closure_bind_extra: Vec<i32>,
    local_type_start: i32,
    mono_call_starts: Vec<i32>,
    mono_call_targets: Vec<String>,
    mono_call_sources: Vec<String>,
    mono_call_used: Vec<i32>,
}
