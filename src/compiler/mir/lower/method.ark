// Arukellt Selfhost - MIR lowering helpers for method calls.

use mir::lower::ctx_api_local_types
use mir::lower::ctx_fn_exists
use mir::lower::ctx_mono_type_params
use mir::lower::method_emit
use mir::lower::method_resolve

fn mir_initial_method_callee(ctx: LowerCtx, method_name: String, receiver_idx: i32) -> String {
    let mut struct_name = String_from("")
    if receiver_idx >= 0 {
        struct_name = ctx_get_local_type(ctx, receiver_idx)
    }
    // When the receiver type is a type variable (e.g. "?T"), try to
    // resolve it to a concrete type via the monomorphization type
    // parameter mapping. This enables `x.method()` inside generic
    // functions `<T: Trait>` to resolve to `ConcreteType::method`.
    if len(struct_name) > 0 && starts_with(clone(struct_name), String_from("?")) {
        let bare_name = substring(clone(struct_name), 1, len(struct_name))
        let resolved = ctx_mono_type_params::ctx_resolve_mono_type_param(ctx, bare_name)
        if len(resolved) > 0 {
            struct_name = resolved
        }
    }
    // Normalize builtin type names so method calls resolve correctly.
    // Vec locals carry type "vec:i32" / "vec:String" etc.; normalize to "Vec".
    // String locals carry type "string"; normalize to "String".
    if starts_with(clone(struct_name), String_from("vec:")) {
        struct_name = String_from("Vec")
    }
    if eq(clone(struct_name), String_from("string")) {
        struct_name = String_from("String")
    }
    // Strip aggregate classifiers, module path prefixes, and per-use instance
    // suffixes (e.g. "struct:VecIter:12" or "std::core::iter::VecIter:12")
    // so method calls resolve to the unqualified base type name.
    struct_name = method_resolve::mir_normalize_type_name(clone(struct_name))
    if len(struct_name) > 0 {
        return concat(clone(struct_name), concat(String_from("::"), clone(method_name)))
    }
    method_name
}

fn mir_method_mono_type_key(ctx: LowerCtx, first_method_arg_idx: i32) -> String {
    method_resolve::mir_method_mono_type_key(ctx, first_method_arg_idx)
}

fn mir_resolve_method_callee(ctx: LowerCtx, callee_name: String, first_method_arg_idx: i32, span_start: i32) -> String {
    method_resolve::mir_resolve_method_callee(ctx, callee_name, first_method_arg_idx, span_start)
}

fn mir_emit_method_call(ctx: LowerCtx, callee_name: String, arg_count: i32, first_arg_idx: i32) -> i32 {
    method_emit::mir_emit_method_call(ctx, callee_name, arg_count, first_arg_idx)
}
