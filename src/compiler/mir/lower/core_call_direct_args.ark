use mir::lower::call_emit
use mir::lower::call_indirect_emit
use mir::lower::core_call_args
use mir::lower::core_call_direct_arg
use mir::lower::core_expr_shape_accessors
use mir::lower::core_expr_shape_atoms
use mir::lower::core_literals
use mir::lower::core_names

fn lower_core_direct_call_args(ctx: LowerCtx, exprs: Vec<CoreHirExpr>, expr: CoreHirExpr, child_count: i32) -> i32 {
    let callee_name = core_expr_shape_accessors::mir_core_expr_text(expr)
    if eq(clone(callee_name), "String_from") && child_count == 2 {
        let arg_expr = get_unchecked(exprs, core_expr_shape_accessors::mir_core_expr_child(expr, 1))
        if core_expr_shape_atoms::mir_core_expr_is_string(arg_expr) {
            return core_literals::lower_core_literal_value(ctx, arg_expr)
        }
    }
    let callee_name = core_expr_shape_accessors::mir_core_expr_text(expr)
    let callee_node = get_unchecked(exprs, core_expr_shape_accessors::mir_core_expr_child(expr, 0))
    if core_expr_shape_atoms::mir_core_expr_is_ident(callee_node) {
        let callee_local = core_names::mir_core_lookup_local(ctx, callee_node)
        if callee_local >= 0 && call_indirect_emit::mir_is_funcref_local(ctx, callee_local) {
            return call_indirect_emit::mir_lower_indirect_call(ctx, exprs, expr, child_count, callee_local)
        }
    }
    let is_println = core_call_args::mir_core_is_printlike_callee(clone(callee_name))
    let stage_call_args = !is_println && child_count > 2
    let callee_expects_i64 = mir_core_callee_expects_i64(clone(callee_name))
    let staged_arg_locals = Vec_new_i32()
    let mut first_arg_idx = 0 - 1
    let mut second_arg_idx = 0 - 1
    let mut lane_immediate = 0 - 1
    let mut a = 1
    while a < child_count {
        let arg_expr = get_unchecked(exprs, core_expr_shape_accessors::mir_core_expr_child(expr, a))
        let mut arg_idx = 0 - 1
        let is_lane_immediate = a == 2 && call_emit::mir_is_simd_lane_immediate_callee(clone(callee_name)) && core_expr_shape_atoms::mir_core_expr_is_int(arg_expr)
        if is_lane_immediate {
            lane_immediate = core_expr_shape_accessors::mir_core_expr_int_val(arg_expr)
            a = a + 1
            continue
        }
        let needs_print_convert = is_println &&
        a == 1 &&
        core_expr_shape_atoms::mir_core_expr_is_ident(arg_expr) &&
        core_call_args::mir_core_print_arg_needs_string_conversion(ctx, arg_expr, core_names::mir_core_lookup_local(ctx, arg_expr))
        if needs_print_convert {
            arg_idx = core_names::mir_core_lookup_local(ctx, arg_expr)
        } else if callee_expects_i64 && core_expr_shape_atoms::mir_core_expr_is_int(arg_expr) {
            arg_idx = core_literals::lower_core_int_literal_forced_i64(ctx, arg_expr)
        } else {
            arg_idx = lower_core_expr(ctx, exprs, core_expr_shape_accessors::mir_core_expr_child(expr, a))
        }
        arg_idx = core_call_direct_arg::mir_lower_core_direct_print_arg(ctx, arg_expr, arg_idx, is_println, a)
        arg_idx = core_call_direct_arg::mir_lower_core_direct_stage_arg(ctx, staged_arg_locals, arg_idx, stage_call_args)
        if a == 1 {
            first_arg_idx = arg_idx
        }
        if a == 2 {
            second_arg_idx = arg_idx
        }
        a = a + 1
    }
    call_emit::mir_emit_direct_call(
        ctx,
        callee_name,
        child_count - 1,
        first_arg_idx,
        second_arg_idx,
        staged_arg_locals,
        stage_call_args,
        core_expr_shape_accessors::mir_core_expr_span_start(expr),
        lane_immediate
    )
}

fn mir_core_callee_expects_i64(callee_name: String) -> bool {
    // Conversion intrinsics that *produce* i64 from i32 must keep i32 args.
    // `contains("i64")` alone wrongly matches `__intrinsic_i32_to_i64` and
    // forces i64.const + extend (#726 hashmap i64::hash).
    if contains(clone(callee_name), String_from("i32_to_i64")) || contains(clone(callee_name), String_from("u32_to_u64")) {
        return false
    }
    if contains(clone(callee_name), String_from("i64")) {
        return true
    }
    if contains(clone(callee_name), String_from("get_unchecked")) {
        return true
    }
    if ends_with(clone(callee_name), String_from("seek_to")) {
        return true
    }
    if eq(clone(callee_name), String_from("seek")) {
        return true
    }
    if ends_with(clone(callee_name), String_from("::seek")) {
        return true
    }
    false
}
