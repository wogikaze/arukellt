use mir::lower::call_rewrite_vec_access
use mir::lower::call_rewrite_vec_push
use mir::lower::ctx_api_emit
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_local_types
use mir::lower::ctx_types
use mir::inst_call
use mir::inst_misc_control
use mir::value_types

struct MirVecCallRewrite {
    callee_name: String,
    push_i64_needs_extend: bool,
}

fn mir_vec_call_rewrite_new(callee_name: String, push_i64_needs_extend: bool) -> MirVecCallRewrite {
    MirVecCallRewrite { callee_name: callee_name, push_i64_needs_extend: push_i64_needs_extend }
}

fn mir_vec_call_rewrite_callee_name(rewrite: MirVecCallRewrite) -> String {
    clone(rewrite.callee_name)
}

fn mir_vec_call_rewrite_push_i64_needs_extend(rewrite: MirVecCallRewrite) -> bool {
    rewrite.push_i64_needs_extend
}

fn mir_vec_call_target_is_intrinsic(callee_name: String) -> bool {
    eq(clone(callee_name), String_from("vec_get")) ||
    eq(clone(callee_name), String_from("vec_get_unchecked")) ||
    eq(clone(callee_name), String_from("vec_get_unchecked_i64")) ||
    eq(clone(callee_name), String_from("vec_get_unchecked_f64")) ||
    eq(clone(callee_name), String_from("vec_len")) ||
    eq(clone(callee_name), String_from("vec_push")) ||
    eq(clone(callee_name), String_from("push_i64")) ||
    eq(clone(callee_name), String_from("push_f64")) ||
    eq(clone(callee_name), String_from("vec_push_i64")) ||
    eq(clone(callee_name), String_from("vec_push_f64")) ||
    eq(clone(callee_name), String_from("vec_set")) ||
    eq(clone(callee_name), String_from("vec_pop"))
}

fn mir_rewrite_vec_access_after_mono(ctx: LowerCtx, callee_name: String, first_arg_idx: i32) -> String {
    if is_vec_get_unchecked_callee(clone(callee_name)) {
        return call_rewrite_vec_access::mir_rewrite_vec_get_unchecked(ctx, callee_name, first_arg_idx)
    }
    if is_vec_get_callee(clone(callee_name)) {
        return call_rewrite_vec_access::mir_rewrite_vec_get(ctx, callee_name, first_arg_idx)
    }
    callee_name
}

fn mir_rewrite_vec_call(ctx: LowerCtx, callee_name: String, first_arg_idx: i32, second_arg_idx: i32, stage_call_args: bool) -> MirVecCallRewrite {
    let mut rewritten = callee_name
    let mut push_i64_needs_extend = false
    if eq(clone(rewritten), "len") {
        rewritten = mir_rewrite_vec_len(ctx, rewritten, first_arg_idx)
    }
    if eq(clone(rewritten), "push") {
        let push_rewrite = call_rewrite_vec_push::mir_rewrite_vec_push(ctx, rewritten, first_arg_idx, second_arg_idx, stage_call_args)
        rewritten = call_rewrite_vec_push::mir_vec_push_rewrite_callee_name(push_rewrite)
        push_i64_needs_extend = call_rewrite_vec_push::mir_vec_push_rewrite_push_i64_needs_extend(push_rewrite)
    }
    if is_vec_get_unchecked_callee(clone(rewritten)) {
        rewritten = call_rewrite_vec_access::mir_rewrite_vec_get_unchecked(ctx, rewritten, first_arg_idx)
    }
    if is_vec_get_callee(clone(rewritten)) {
        rewritten = call_rewrite_vec_access::mir_rewrite_vec_get(ctx, rewritten, first_arg_idx)
    }
    rewritten = mir_rewrite_vec_basic(rewritten)
    mir_vec_call_rewrite_new(rewritten, push_i64_needs_extend)
}

fn is_vec_get_unchecked_callee(name: String) -> bool {
    eq(clone(name), String_from("get_unchecked")) ||
    eq(clone(name), String_from("__intrinsic_get_unchecked")) ||
    ends_with(clone(name), String_from("::get_unchecked")) ||
    starts_with(clone(name), String_from("get_unchecked__")) ||
    contains(name, String_from("::get_unchecked__"))
}

fn is_vec_get_callee(name: String) -> bool {
    eq(clone(name), String_from("get")) ||
    eq(clone(name), String_from("__intrinsic_get")) ||
    ends_with(clone(name), String_from("::get")) ||
    starts_with(clone(name), String_from("get__")) ||
    contains(name, String_from("::get__"))
}

fn mir_rewrite_vec_is_empty_to_local(ctx: LowerCtx, first_arg_idx: i32) -> i32 {
    if first_arg_idx < 0 {
        return 0 - 1
    }
    let first_arg_type = ctx_api_local_types::ctx_get_local_type(ctx, first_arg_idx)
    if !eq(clone(first_arg_type), String_from("Vec")) && !starts_with(clone(first_arg_type), "vec:") {
        return 0 - 1
    }
    // The receiver value is already on the stack from lower_expr.
    // Emit: call vec_len 1; eqz dest
    let len_dest = ctx_api_local_alloc::ctx_fresh_local(ctx, value_types::VT_I32())
    ctx_api_emit::ctx_emit(ctx, inst_call::MirInst_call(String_from("vec_len"), 1, len_dest))
    ctx_api_local_types::ctx_set_local_type(ctx, len_dest, String_from("i32"))
    ctx_api_local_types::ctx_set_local_vt(ctx, len_dest, value_types::VT_I32())
    let eqz_dest = ctx_api_local_alloc::ctx_fresh_local(ctx, value_types::VT_I32())
    ctx_api_emit::ctx_emit(ctx, inst_misc_control::MirInst_eqz(eqz_dest, len_dest))
    ctx_api_local_types::ctx_set_local_type(ctx, eqz_dest, String_from("bool"))
    ctx_api_local_types::ctx_set_local_vt(ctx, eqz_dest, value_types::VT_I32())
    eqz_dest
}

fn mir_rewrite_vec_len(ctx: LowerCtx, callee_name: String, first_arg_idx: i32) -> String {
    if first_arg_idx >= 0 {
        let arg_type_len = ctx_api_local_types::ctx_get_local_type(ctx, first_arg_idx)
        if eq(clone(arg_type_len), String_from("Vec")) || starts_with(clone(arg_type_len), "vec:") {
            return String_from("vec_len")
        }
    }
    callee_name
}

fn mir_rewrite_vec_basic(callee_name: String) -> String {
    let mut rewritten = callee_name
    if eq(clone(rewritten), "pop") {
        rewritten = String_from("vec_pop")
    }
    if eq(clone(rewritten), "set") {
        rewritten = String_from("vec_set")
    }
    rewritten
}
