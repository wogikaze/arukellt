use mir::lower::ctx_api_local_types
use mir::lower::ctx_fn_exists
use mir::lower::ctx_fn_index
use mir::lower::ctx_types
use mir::mono
use mir::value_types

fn mir_method_name_last_segment(name: String) -> String {
    let n = len(name)
    let mut last_start = 0 - 1
    let mut i = 0
    while i < n - 1 {
        if char_at(name, i) == 58 && char_at(name, i + 1) == 58 {
            last_start = i + 2
            i = i + 2
        } else {
            i = i + 1
        }
    }
    if last_start >= 0 {
        return substring(name, last_start, n)
    }
    clone(name)
}

fn mir_method_name_last_two_segments(name: String) -> String {
    let n = len(name)
    let mut prev_start = 0 - 1
    let mut last_start = 0 - 1
    let mut i = 0
    while i < n - 1 {
        if char_at(name, i) == 58 && char_at(name, i + 1) == 58 {
            prev_start = last_start
            last_start = i + 2
            i = i + 2
        } else {
            i = i + 1
        }
    }
    if prev_start >= 0 {
        return substring(name, prev_start, n)
    }
    if last_start >= 0 {
        return substring(name, last_start, n)
    }
    clone(name)
}

fn mir_is_all_digits(s: String) -> bool {
    let n = len(s)
    if n == 0 {
        return false
    }
    let mut i = 0
    while i < n {
        let c = char_at(s, i)
        if c < 48 || c > 57 {
            return false
        }
        i = i + 1
    }
    true
}

fn mir_strip_type_instance_suffix(name: String) -> String {
    let n = len(name)
    if n == 0 {
        return name
    }
    let mut last_colon = 0 - 1
    let mut i = n - 1
    while i >= 0 {
        if char_at(name, i) == 58 {
            last_colon = i
            i = 0 - 1
        }
        i = i - 1
    }
    if last_colon >= 0 {
        let suffix = substring(name, last_colon + 1, n)
        if mir_is_all_digits(suffix) {
            return substring(name, 0, last_colon)
        }
    }
    clone(name)
}

fn mir_normalize_type_name(t: String) -> String {
    let mut n = clone(t)
    if starts_with(clone(n), String_from("struct:")) {
        n = substring(n, 7, len(n))
    }
    if starts_with(clone(n), String_from("enum:")) {
        n = substring(n, 5, len(n))
    }
    n = mir_strip_type_instance_suffix(clone(n))
    n = mir_method_name_last_segment(clone(n))
    n
}

fn mir_resolve_short_method_name(ctx: LowerCtx, name: String) -> String {
    let norm = mir_normalize_type_name(clone(name))
    let exact = ctx_fn_index::ctx_fn_index_find(ctx, clone(norm))
    if exact >= 0 {
        return clone(ctx_fn_index::ctx_fn_index_name_at(ctx, exact))
    }
    let last_two = mir_method_name_last_two_segments(clone(norm))
    if !eq(clone(last_two), clone(norm)) {
        let found = ctx_fn_index::ctx_fn_index_find(ctx, clone(last_two))
        if found >= 0 {
            return clone(ctx_fn_index::ctx_fn_index_name_at(ctx, found))
        }
    }
    let last = mir_method_name_last_segment(clone(norm))
    if !eq(clone(last), clone(norm)) {
        let found = ctx_fn_index::ctx_fn_index_find(ctx, clone(last))
        if found >= 0 {
            return clone(ctx_fn_index::ctx_fn_index_name_at(ctx, found))
        }
    }
    String_from("")
}

fn mir_method_mono_type_key(ctx: LowerCtx, first_method_arg_idx: i32) -> String {
    if first_method_arg_idx < 0 {
        return String_from("")
    }
    let mut method_mono_type_key = ctx_get_local_type(ctx, first_method_arg_idx)
    if len(method_mono_type_key) == 0 {
        let method_arg_vt = ctx_local_vt(ctx, first_method_arg_idx)
        if method_arg_vt == value_types::VT_I64() {
            method_mono_type_key = String_from("i64")
        } else {
            if method_arg_vt == value_types::VT_F64() {
                method_mono_type_key = String_from("f64")
            } else {
                method_mono_type_key = String_from("i32")
            }
        }
    }
    if eq(clone(method_mono_type_key), String_from("string")) {
        method_mono_type_key = String_from("String")
    }
    method_mono_type_key
}

fn mir_resolve_method_callee(ctx: LowerCtx, callee_name: String, first_method_arg_idx: i32, span_start: i32) -> String {
    let method_mono_type_key = mir_method_mono_type_key(ctx, first_method_arg_idx)
    if len(method_mono_type_key) > 0 {
        let method_mono_candidate = mono::mono_safe_name(concat(clone(callee_name), concat(String_from("__"), method_mono_type_key)))
        if ctx_has_fn_name(ctx, clone(method_mono_candidate)) {
            return method_mono_candidate
        }
    }
    let mono_target = ctx_mono_lookup_call(ctx, span_start)
    if len(mono_target) > 0 {
        return mono_target
    }
    let named_mono_target = ctx_resolve_unused_mono_by_name(ctx, callee_name)
    if len(named_mono_target) > 0 {
        return named_mono_target
    }
    if ctx_has_fn_name(ctx, clone(callee_name)) {
        return callee_name
    }
    // Fallback for builtin types: if the mangled callee (e.g. "Vec::push")
    // is not a MIR function, check if the type prefix is a builtin type.
    // If so, map to the corresponding compiler intrinsic name.
    let bare_name = mir_bare_method_name(callee_name)
    if len(bare_name) > 0 && mir_is_builtin_type_prefix(callee_name) {
        let intrinsic_name = mir_builtin_method_to_intrinsic(callee_name, bare_name)
        if len(intrinsic_name) > 0 {
            return intrinsic_name
        }
        return bare_name
    }
    let short_name = mir_resolve_short_method_name(ctx, clone(callee_name))
    if len(short_name) > 0 {
        return short_name
    }
    callee_name
}

fn mir_builtin_method_to_intrinsic(mangled: String, bare_name: String) -> String {
    let prefix = mir_type_prefix(mangled)
    // Vec methods: some intrinsics use bare name, others use vec_ prefix.
    if eq(clone(prefix), String_from("Vec")) {
        if eq(clone(bare_name), String_from("len")) { return String_from("vec_len") }
        if eq(clone(bare_name), String_from("get")) { return String_from("vec_get") }
        if eq(clone(bare_name), String_from("set")) { return String_from("vec_set") }
        if eq(clone(bare_name), String_from("pop")) { return String_from("vec_pop") }
        // push, get_unchecked, is_empty use bare name — no mapping needed.
        return String_from("")
    }
    // String methods: len, char_at, etc. use bare name — no mapping needed.
    // Scalar methods: map trait dispatch names to compare intrinsics so
    // prelude String `eq` is not used for i32/i64/f64/bool/char receivers.
    if eq(clone(bare_name), String_from("eq")) {
        if eq(clone(prefix), String_from("i32")) { return String_from("__intrinsic_i32_eq") }
        if eq(clone(prefix), String_from("i64")) { return String_from("__intrinsic_i64_eq") }
        if eq(clone(prefix), String_from("f64")) { return String_from("__intrinsic_f64_eq") }
        if eq(clone(prefix), String_from("bool")) { return String_from("__intrinsic_i32_eq") }
        if eq(clone(prefix), String_from("char")) { return String_from("__intrinsic_i32_eq") }
    }
    if eq(clone(bare_name), String_from("hash")) {
        if eq(clone(prefix), String_from("i32")) { return String_from("hash_i32") }
        if eq(clone(prefix), String_from("String")) { return String_from("hash_string") }
        if eq(clone(prefix), String_from("i64")) { return String_from("hash_i64") }
        if eq(clone(prefix), String_from("bool")) { return String_from("hash_i32") }
        if eq(clone(prefix), String_from("char")) { return String_from("hash_i32") }
        if eq(clone(prefix), String_from("f64")) { return String_from("hash_f64") }
    }
    String_from("")
}

fn mir_bare_method_name(mangled: String) -> String {
    let pos = index_of(clone(mangled), String_from("::"))
    if pos < 0 {
        return String_from("")
    }
    substring(mangled, pos + 2, len(mangled))
}

fn mir_is_builtin_type_prefix(mangled: String) -> bool {
    let prefix = mir_type_prefix(mangled)
    if eq(clone(prefix), String_from("Vec")) { return true }
    if eq(clone(prefix), String_from("String")) { return true }
    if eq(clone(prefix), String_from("i32")) { return true }
    if eq(clone(prefix), String_from("i64")) { return true }
    if eq(clone(prefix), String_from("f64")) { return true }
    if eq(clone(prefix), String_from("f32")) { return true }
    if eq(clone(prefix), String_from("bool")) { return true }
    if eq(clone(prefix), String_from("char")) { return true }
    false
}

fn mir_type_prefix(mangled: String) -> String {
    let pos = index_of(clone(mangled), String_from("::"))
    if pos < 0 {
        return String_from("")
    }
    substring(mangled, 0, pos)
}
