use mir::function_locals_view
use mir::local_access
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_function_frame
use mir::lower::ctx_current_storage
use mir::lower::ctx_struct_layout
use mir::lower::ctx_types
use mir::local_factory
// Arukellt Selfhost - CoreHIR closure capture parameter emission.

use mir::value_types

fn core_closure_lookup_capture_type(ctx: LowerCtx, cli: i32) -> String {
    let mut cap_type = String_new()
    if cli < 0 {
        return cap_type
    }
    let func = ctx_current_storage::ctx_current_func_value(ctx)
    if cli < function_locals_view::MirFunction_local_count(func) {
        let loc = function_locals_view::MirFunction_local_at(func, cli)
        cap_type = local_access::MirLocal_type_name(loc)
    }
    if len(cap_type) == 0 {
        cap_type = ctx_api_local_types::ctx_get_local_type(ctx, cli)
    }
    if len(cap_type) > 0 {
        cap_type = ctx_struct_layout::ctx_maybe_enum_return_type_name(ctx, clone(cap_type))
    } else {
        if ctx_api_local_types::ctx_local_vt(ctx, cli) == value_types::VT_GC_REF() {
            cap_type = String_from("String")
        }
    }
    cap_type
}

fn core_closure_capture_vts(ctx: LowerCtx, caps: Vec<String>) -> Vec<i32> {
    let cap_n = len(caps)
    let cap_vts = Vec_new_i32()
    let mut cvi = 0
    while cvi < cap_n {
        let cname = clone(get_unchecked(caps, cvi))
        let cli = ctx_api_local_alloc::ctx_lookup_local(ctx, clone(cname))
        let mut pvt = value_types::VT_I32()
        if cli >= 0 {
            pvt = ctx_api_local_types::ctx_local_vt(ctx, cli)
            let cap_type = core_closure_lookup_capture_type(ctx, cli)
            if starts_with(clone(cap_type), String_from("struct:")) || eq(clone(cap_type), String_from("String")) || eq(clone(cap_type), String_from("string")) || starts_with(clone(cap_type), String_from("enum:")) || starts_with(clone(cap_type), String_from("vec:")) || starts_with(clone(cap_type), String_from("Option_")) || starts_with(clone(cap_type), String_from("Result_")) {
                pvt = value_types::VT_GC_REF()
            }
        }
        push(cap_vts, pvt)
        cvi = cvi + 1
    }
    cap_vts
}

fn core_closure_capture_types(ctx: LowerCtx, caps: Vec<String>) -> Vec<String> {
    let cap_n = len(caps)
    let cap_types = Vec_new_String()
    let mut cvi = 0
    while cvi < cap_n {
        let cname = clone(get_unchecked(caps, cvi))
        let cli = ctx_api_local_alloc::ctx_lookup_local(ctx, clone(cname))
        let cap_type = core_closure_lookup_capture_type(ctx, cli)
        push(cap_types, cap_type)
        cvi = cvi + 1
    }
    cap_types
}

fn core_emit_closure_captures(ctx: LowerCtx, caps: Vec<String>, cap_vts: Vec<i32>, cap_types: Vec<String>) {
    let cap_n = len(caps)
    let mut ci = 0
    while ci < cap_n {
        let cname = clone(get_unchecked(caps, ci))
        let pvt = get_unchecked(cap_vts, ci)
        let cap_type = clone(get_unchecked(cap_types, ci))
        let _idx2 = ctx_api_local_alloc::ctx_alloc_local(ctx, clone(cname), pvt)
        if len(cap_type) > 0 {
            ctx_api_local_types::ctx_set_local_type(ctx, _idx2, clone(cap_type))
        }
        ctx_api_function_frame::ctx_push_func_param(ctx, local_factory::MirLocal_new(clone(cname), pvt, cap_type))
        ci = ci + 1
    }
}
