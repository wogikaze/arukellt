use corehir::function_id
use corehir::signature_registry
use corehir::core_op_binding
use corehir::core_op_id
use mir::inst_record
use mir::inst_accessors_literals
use mir::inst_accessors_shape
use mir::opcodes
use mir::lower::ctx_current_storage
use mir::module_spine

fn mir_call_inst_attach_func_id(ctx: LowerCtx, inst: MirInst, callee_name: String) -> MirInst {
    let m = ctx_current_storage::ctx_current_module_value(ctx)
    if !module_spine::MirModule_signature_spine_populated(m) {
        return inst
    }
    let registry = module_spine::MirModule_signature_registry(m)
    let mut fid = signature_registry::signature_registry_lookup_by_mangled(registry, clone(callee_name))
    if !function_id::function_id_is_valid(fid) {
        let coid = core_op_binding::core_op_binding_lookup_for_callee(clone(callee_name))
        if core_op_id::core_op_id_is_some(coid) {
            fid = signature_registry::signature_registry_register_core_op_alias(
                registry,
                clone(callee_name),
                coid
            )
        }
    }
    if function_id::function_id_is_valid(fid) {
        return inst_record::mir_inst_with_func_id_raw(inst, function_id::FunctionId_raw(fid))
    }
    inst
}

fn mir_inst_attach_func_id_if_call(ctx: LowerCtx, inst: MirInst) -> MirInst {
    if inst_accessors_shape::MirInst_op(inst) != opcodes::MIR_CALL() {
        return inst
    }
    mir_call_inst_attach_func_id(ctx, inst, inst_accessors_literals::MirInst_str_val(inst))
}
