use mir::lower::ast_node
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower::ctx_types
// Arukellt Selfhost - MIR match payload field binding emission.

use mir::inst_struct_get
use mir::inst_gc_struct
use mir::inst_local_get
use mir::inst_local_set
use mir::lower::ctx_gc_enum
use mir::lower::ctx_struct_field_type
use mir::lower::match_payload_field_type
use mir::value_types

fn mir_emit_payload_variant_binds(ctx: LowerCtx, pat: AstNode, scrut_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool, scrut_ok_is_i32: bool) {
    let variant_name = ast_node::node_text(pat)
    let mut bi = 0
    while bi < ast_node::node_child_count(pat) {
        let bind_pat = ast_node::node_child_at(pat, bi)
        let bind_vt = match_payload_field_type::mir_payload_field_vt(ctx, clone(variant_name), bi, scrut_ok_is_f64, scrut_ok_is_i64)
        let bind_local = ctx_alloc_local(ctx, ast_node::node_text(bind_pat), bind_vt)
        if bind_vt == value_types::VT_GC_REF() || match_payload_field_type::mir_payload_gc_field_is_ref(ctx, clone(variant_name), bi) {
            ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
        set_gc_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, bind_vt, bi)
        set_i32_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, bind_vt, bi, scrut_ok_is_i32)
        emit_payload_field_bind(ctx, clone(variant_name), scrut_idx, bind_local, bind_vt, bi)
        bi = bi + 1
    }
}

fn set_gc_payload_bind_type_if_needed(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, field_idx: i32) {
    if bind_vt != value_types::VT_GC_REF() {
        return
    }
    let field_type = ctx_struct_field_type::ctx_struct_field_type_name(ctx, clone(variant_name), field_idx + 1)
    if eq(clone(field_type), "String") || eq(clone(field_type), "string") {
        ctx_set_local_type(ctx, bind_local, String_from("string"))
        return
    }
    if len(field_type) > 0 && ctx_struct_field_type::field_type_is_registered_enum(ctx, clone(field_type)) {
        ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if len(field_type) > 0 && !match_payload_field_type::mir_payload_scalar_type_name(clone(field_type)) {
        ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if match_payload_field_type::mir_match_variant_is_err(clone(variant_name)) && field_idx == 0 {
        ctx_set_local_type(ctx, bind_local, String_from("string"))
    }
}

fn set_i32_payload_bind_type_if_needed(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, field_idx: i32, scrut_ok_is_i32: bool) {
    if bind_vt == value_types::VT_I32() && scrut_ok_is_i32 && field_idx == 0 {
        if match_payload_field_type::mir_match_variant_is_some_or_ok(clone(variant_name)) {
            ctx_set_local_type(ctx, bind_local, String_from("i32"))
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_I32())
        }
    }
}

fn emit_payload_field_bind(ctx: LowerCtx, variant_name: String, scrut_idx: i32, bind_local: i32, bind_vt: i32, field_idx: i32) {
    let mut effective_vt = bind_vt
    if ctx_gc_enum::ctx_is_gc_target(ctx) && effective_vt != value_types::VT_GC_REF() {
        if match_payload_field_type::mir_payload_gc_field_is_ref(ctx, clone(variant_name), field_idx) {
            effective_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
            set_gc_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, effective_vt, field_idx)
            if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            }
        }
    }
    let mut field_vt = value_types::VT_VOID()
    if effective_vt == value_types::VT_F64() {
        field_vt = value_types::VT_F64()
    } else {
        if effective_vt == value_types::VT_I64() {
            field_vt = value_types::VT_I64()
        }
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) {
        let type_slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
        ctx_emit(ctx, inst_gc_struct::MirInst_gc_struct_get(bind_local, scrut_idx, type_slot, field_idx + 1, field_vt))
        return
    }
    ctx_emit(ctx, inst_local_get::MirInst_local_get(scrut_idx))
    ctx_emit(ctx, inst_struct_get::MirInst_struct_get(ctx_struct_field_offset(ctx, clone(variant_name), field_idx + 1), field_vt))
    ctx_emit(ctx, inst_local_set::MirInst_local_set(bind_local))
}
