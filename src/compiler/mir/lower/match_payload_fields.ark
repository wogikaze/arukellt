// Arukellt Selfhost - MIR match payload field binding emission.
use mir::lower::ast_node
use mir::lower::ctx_api_local_types
use mir::inst_struct_get
use mir::inst_gc_struct
use mir::inst_local_get
use mir::inst_local_set
use mir::lower::ctx_gc_enum
use mir::lower::ctx_gc_enum_payload
use mir::lower::ctx_struct_field_type
use mir::lower::ctx_struct_layout
use mir::lower::match_payload_bind_types
use mir::lower::match_payload_bind_gc_resolve
use mir::lower::match_payload_field_type
use mir::value_types
fn mir_emit_payload_variant_binds(ctx: LowerCtx, pat: AstNode, scrut_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool, scrut_ok_is_i32: bool) {
    let variant_name = ast_node::node_text(pat)
    let mut bi = 0
    while bi < ast_node::node_child_count(pat) {
        let bind_pat = ast_node::node_child_at(pat, bi)
        let bind_vt = match_payload_field_type::mir_payload_field_vt(ctx, clone(variant_name), bi, scrut_ok_is_f64, scrut_ok_is_i64)
        let bind_local = ctx_alloc_local(ctx, ast_node::node_text(bind_pat), bind_vt)
        if bind_vt == value_types::VT_GC_REF() || match_payload_field_type::mir_payload_gc_field_is_ref(ctx, clone(variant_name), bi) {
            ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
        match_payload_bind_types::set_gc_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, bind_vt, bi)
        match_payload_bind_types::set_i32_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, bind_vt, bi, scrut_ok_is_i32)
        // Infer concrete payload type from scrutinee type for Option/Result.
        if bi == 0 {
            mir_infer_payload_bind_type(ctx, clone(variant_name), bind_local, bind_vt, scrut_idx)
        }
        emit_payload_field_bind(ctx, clone(variant_name), scrut_idx, bind_local, bind_vt, bi)
        bi = bi + 1
    }
}
// Extract the concrete payload element type from the scrutinee type name.
fn mir_payload_elem_type_from_scrut(scrut_type: String, is_some_or_ok: bool) -> String {
    if is_some_or_ok {
        // Ok/Some payload is the first type parameter.
        if starts_with(clone(scrut_type), String_from("option:")) {
            return substring(scrut_type, 7, len(scrut_type))
        }
        if starts_with(clone(scrut_type), String_from("Option_")) {
            return substring(scrut_type, 7, len(scrut_type))
        }
        if starts_with(clone(scrut_type), String_from("Result_")) || starts_with(clone(scrut_type), String_from("result:")) {
            return match_payload_bind_types::extract_first_result_type_param(scrut_type)
        }
        return String_new()
    }
    // Err payload is the second type parameter.
    if starts_with(clone(scrut_type), String_from("Result_")) || starts_with(clone(scrut_type), String_from("result:")) {
        return match_payload_bind_types::extract_second_result_type_param(scrut_type)
    }
    String_new()
}

fn mir_infer_payload_set_type(ctx: LowerCtx, elem_ty: String) -> String {
    // For non-scalar, non-String types (e.g. AppError),
    // prefix with "enum:" so the emitter's ref local type
    // inference maps it to the enum open type.
    // However, types that already have a recognised ref
    // prefix (vec:, hashmap:, Option_, Result_, option:,
    // result:) should NOT be prefixed with "enum:" because
    // the emitter has dedicated GC type mappings for them.
    // Named GC structs (Token, etc.) must keep their bare
    // name so Option::Some can use gcsref<slot> (#726 display).
    let mut set_type = clone(elem_ty)
    if !match_payload_field_type::mir_payload_scalar_type_name(clone(elem_ty)) {
        if !eq(clone(elem_ty), "String") && !eq(clone(elem_ty), "string") {
            if !starts_with(clone(elem_ty), String_from("vec:")) && !starts_with(clone(elem_ty), String_from("Vec<")) && !starts_with(clone(elem_ty), String_from("Vec_")) && !eq(clone(elem_ty), String_from("Vec")) && !starts_with(clone(elem_ty), String_from("hashmap:")) && !starts_with(clone(elem_ty), String_from("Option_")) && !starts_with(clone(elem_ty), String_from("option:")) && !starts_with(clone(elem_ty), String_from("Result_")) && !starts_with(clone(elem_ty), String_from("result:")) {
                if !ctx_struct_layout::ctx_is_registered_struct_type(ctx, clone(elem_ty)) {
                    set_type = concat(String_from("enum:"), clone(elem_ty))
                }
            }
        }
    }
    set_type
}

// Infer the concrete payload type for the first bind of Some/Ok/Err patterns
// from the scrutinee's type name, then fix up the local's type and vt.
fn mir_infer_payload_bind_type(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, scrut_idx: i32) {
    let is_some_or_ok = match_payload_field_type::mir_match_variant_is_some_or_ok(clone(variant_name))
    let is_err = match_payload_field_type::mir_match_variant_is_err(clone(variant_name))
    if !is_some_or_ok && !is_err {
        return
    }
    let current_type = ctx_get_local_type(ctx, bind_local)
    // Override when type is empty, "enum:open", or contains an
    // unresolved type variable (e.g. "enum:T" where T is a generic
    // type parameter name, not a concrete type).
    // Also override the "string" fallback set by
    // set_gc_payload_bind_type_if_needed for Err variants, so that
    // non-String Err payloads (e.g. AppError) get the correct type.
    if !(len(current_type) == 0 || eq(current_type, String_from("enum:open")) || starts_with(current_type, String_from("enum:")) || (is_err && eq(current_type, String_from("string")))) {
        return
    }
    let scrut_type = ctx_get_local_type(ctx, scrut_idx)
    let elem_ty = mir_payload_elem_type_from_scrut(scrut_type, is_some_or_ok)
    if len(elem_ty) == 0 {
        return
    }
    let mut set_type = mir_infer_payload_set_type(ctx, clone(elem_ty))
    // Normalize unit Ok payload to i32 (matches Ok(()) lowering).
    if eq(clone(elem_ty), "unit") || eq(clone(elem_ty), "()") || eq(clone(elem_ty), "void") {
        set_type = String_from("i32")
    }
    ctx_set_local_type(ctx, bind_local, set_type)
    // Fix vt for scalars: i64/f64 keep their width; other
    // scalars collapse to i32. Do not force i64 → i32 (#726 debug_vec).
    if match_payload_field_type::mir_payload_scalar_type_name(clone(elem_ty)) {
        if eq(clone(elem_ty), "i64") || eq(clone(elem_ty), "I64") {
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_I64())
        } else if eq(clone(elem_ty), "f64") || eq(clone(elem_ty), "F64") {
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_F64())
        } else {
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_I32())
        }
    } else {
        // Non-scalar types (String, Vec, etc.) are GC refs
        // on GC targets.  Override VT_I32 to VT_GC_REF so
        // that the local is declared as a ref and the enum
        // variant is created with a ref field.
        if ctx_gc_enum::ctx_is_gc_target(ctx) {
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
    }
}

fn emit_payload_field_bind(ctx: LowerCtx, variant_name: String, scrut_idx: i32, bind_local: i32, bind_vt: i32, field_idx: i32) {
    // Use the current local vt, which may have been corrected by the
    // type inference block above (e.g. VT_GC_REF → VT_I32 for scalar
    // payloads from generic Option/Result types).
    let mut effective_vt = ctx_api_local_types::ctx_local_vt(ctx, bind_local)
    if effective_vt == value_types::VT_VOID() {
        effective_vt = bind_vt
    }
    if ctx_gc_enum::ctx_is_gc_target(ctx) && effective_vt != value_types::VT_GC_REF() {
        // Do not re-promote scalar Ok payloads (unit/i32/i64/f64) to GC ref
        // just because a stale Result::Ok slot was registered with _f1_ref*
        // (#726 Result<(), E> match vs Ok(()) emit).
        let bind_ty = ctx_get_local_type(ctx, bind_local)
        let scalar_bind = match_payload_field_type::mir_payload_scalar_type_name(clone(bind_ty)) || eq(clone(bind_ty), "i32") || eq(clone(bind_ty), "i64") || eq(clone(bind_ty), "f64")
        if !scalar_bind && match_payload_field_type::mir_payload_gc_field_is_ref(ctx, clone(variant_name), field_idx) {
            effective_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
            match_payload_bind_types::set_gc_payload_bind_type_if_needed(ctx, clone(variant_name), bind_local, effective_vt, field_idx)
            if len(ctx_api_local_types::ctx_get_local_type(ctx, bind_local)) == 0 {
                ctx_set_local_type(ctx, bind_local, String_from("enum:open"))
            }
        } else if !scalar_bind && match_payload_bind_types::payload_type_name_is_gc_ref(ctx, bind_local) {
            // The local type name indicates a GC ref type (String, Vec, etc.)
            // but core_payload_gc_field_is_ref could not detect it because
            // the variant was previously registered with an i32 payload.
            // Override effective_vt to VT_GC_REF so the enum variant is
            // created/found with a ref field.
            effective_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
    }
    let mut field_vt = value_types::VT_VOID()
    if effective_vt == value_types::VT_F64() {
        field_vt = value_types::VT_F64()
    } else {
        if effective_vt == value_types::VT_I64() {
            field_vt = value_types::VT_I64()
        }
    }
    if emit_payload_field_bind_gc(ctx, clone(variant_name), field_idx, effective_vt, bind_local, scrut_idx, field_vt) {
        return
    }
    ctx_emit(ctx, inst_local_get::MirInst_local_get(scrut_idx))
    ctx_emit(ctx, inst_struct_get::MirInst_struct_get_field_idx(scrut_idx, clone(variant_name), ctx_struct_layout::ctx_struct_field_offset(ctx, clone(variant_name), field_idx + 1), field_idx + 1, ctx_struct_layout::ctx_struct_byte_size(ctx, clone(variant_name)), field_vt, bind_local))
    ctx_emit(ctx, inst_local_set::MirInst_local_set(bind_local))
}

fn emit_payload_field_bind_gc(ctx: LowerCtx, variant_name: String, field_idx: i32, effective_vt: i32, bind_local: i32, scrut_idx: i32, field_vt: i32) -> bool {
    if !ctx_gc_enum::ctx_is_gc_target(ctx) {
        return false
    }
    let mut type_slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
    let mut eff_vt = effective_vt
    if field_idx == 0 {
        // Resolve bind type first so vec:/enum: names force GC ref vt
        // before payload variant registration (#726 json Array / Result).
        let bind_type_name = match_payload_bind_gc_resolve::emit_payload_field_bind_gc_resolve_type(ctx, clone(variant_name), field_idx, bind_local)
        if starts_with(clone(bind_type_name), String_from("vec:")) || starts_with(clone(bind_type_name), String_from("Vec")) || starts_with(clone(bind_type_name), String_from("enum:")) || starts_with(clone(bind_type_name), String_from("result:")) || starts_with(clone(bind_type_name), String_from("option:")) || eq(clone(bind_type_name), String_from("string")) || eq(clone(bind_type_name), String_from("String")) {
            eff_vt = value_types::VT_GC_REF()
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        }
        let payload_vts = Vec_new_i32()
        push(payload_vts, eff_vt)
        let payload_slot = ctx_gc_enum_payload::ctx_ensure_gc_enum_payload_variant_typed(ctx, clone(variant_name), payload_vts, clone(bind_type_name))
        if payload_slot >= 0 {
            type_slot = payload_slot
        }
    }
    // Nested enum binds (enum:Inner) stay enum-open (#726 nested_enum).
    let bind_ty_for_slot = ctx_get_local_type(ctx, bind_local)
    if eff_vt == value_types::VT_GC_REF() && type_slot >= 0 && !starts_with(clone(bind_ty_for_slot), String_from("enum:")) && match_payload_bind_types::payload_bind_needs_variant_slot(clone(bind_ty_for_slot), clone(variant_name)) {
        ctx_api_local_types::ctx_set_local_variant_slot(ctx, bind_local, type_slot)
    }
    ctx_emit(ctx, inst_gc_struct::MirInst_gc_struct_get(bind_local, scrut_idx, type_slot, field_idx + 1, field_vt))
    true
}
