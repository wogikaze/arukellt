use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower::ctx_api_variants
use mir::lower::ctx_fn_index
use mir::lower::ctx_types
// Arukellt Selfhost - CoreHIR name/path value lowering.

use mir::inst_const_i32
use mir::inst_local_get
use mir::inst_ref_func
use mir::lower::core_expr_shape_accessors
use mir::lower::core_expr_shape_atoms
use mir::lower::variants
use mir::value_types

fn mir_core_lookup_local(ctx: LowerCtx, expr: CoreHirExpr) -> i32 {
    ctx_api_local_alloc::ctx_lookup_local(ctx, core_expr_shape_accessors::mir_core_expr_text(expr))
}

fn lower_core_name_value(ctx: LowerCtx, expr: CoreHirExpr) -> i32 {
    if core_expr_shape_atoms::mir_core_expr_is_ident(expr) {
        let idx = ctx_api_local_alloc::ctx_lookup_local(ctx, core_expr_shape_accessors::mir_core_expr_text(expr))
        if idx >= 0 {
            ctx_api_emit::ctx_emit(ctx, inst_local_get::MirInst_local_get_to(idx, idx))
            return idx
        }
        let ident_tag = ctx_api_variants::ctx_variant_tag(ctx, core_expr_shape_accessors::mir_core_expr_text(expr))
        if ident_tag >= 0 {
            return variants::lower_variant_value(ctx, core_expr_shape_accessors::mir_core_expr_text(expr), ident_tag)
        }
        let fn_idx = ctx_fn_index::ctx_fn_index_find(ctx, core_expr_shape_accessors::mir_core_expr_text(expr))
        if fn_idx >= 0 {
            let dest = ctx_api_local_alloc::ctx_fresh_local(ctx, value_types::VT_I32())
            ctx_api_emit::ctx_emit(ctx, inst_ref_func::MirInst_ref_func(core_expr_shape_accessors::mir_core_expr_text(expr), dest))
            return dest
        }
        return 0 - 1
    }
    if core_expr_shape_atoms::mir_core_expr_is_path(expr) {
        let tag = ctx_api_variants::ctx_variant_tag(ctx, core_expr_shape_accessors::mir_core_expr_text(expr))
        if tag >= 0 {
            return variants::lower_variant_value(ctx, core_expr_shape_accessors::mir_core_expr_text(expr), tag)
        }
        return 0 - 1
    }
    0 - 2
}
