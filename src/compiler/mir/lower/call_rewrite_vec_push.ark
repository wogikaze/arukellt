use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_emit
use mir::lower::ctx_types
// Arukellt Selfhost - MIR call rewrite rules for Vec push.

use mir::inst_convert
use mir::value_types

struct MirVecPushRewrite {
    callee_name: String,
    push_i64_needs_extend: bool,
}

fn mir_vec_push_rewrite_new(callee_name: String, push_i64_needs_extend: bool) -> MirVecPushRewrite {
    MirVecPushRewrite { callee_name: callee_name, push_i64_needs_extend: push_i64_needs_extend }
}

fn mir_vec_push_rewrite_callee_name(rewrite: MirVecPushRewrite) -> String {
    clone(rewrite.callee_name)
}

fn mir_vec_push_rewrite_push_i64_needs_extend(rewrite: MirVecPushRewrite) -> bool {
    rewrite.push_i64_needs_extend
}

fn mir_rewrite_vec_push(ctx: LowerCtx, callee_name: String, first_arg_idx: i32, second_arg_idx: i32, stage_call_args: bool) -> MirVecPushRewrite {
    let mut rewritten = callee_name
    let mut push_i64_needs_extend = false
    if first_arg_idx >= 0 {
        let arg_type_push = ctx_api_local_types::ctx_get_local_type(ctx, first_arg_idx)
        if eq(clone(arg_type_push), "vec:i64") {
            rewritten = String_from("push_i64")
            if second_arg_idx >= 0 && ctx_api_local_types::ctx_local_vt(ctx, second_arg_idx) == value_types::VT_I32() {
                if stage_call_args {
                    push_i64_needs_extend = true
                } else {
                    ctx_api_emit::ctx_emit(ctx, inst_convert::MirInst_extend_i32_to_i64_stack())
                }
            }
        } else {
            if eq(clone(arg_type_push), "vec:f64") {
                rewritten = String_from("push_f64")
            } else {
                if starts_with(clone(arg_type_push), "vec:") {
                    rewritten = String_from("vec_push")
                }
            }
        }
    }
    mir_vec_push_rewrite_new(rewritten, push_i64_needs_extend)
}
