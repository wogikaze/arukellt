use corehir::kinds
use corehir::expr_predicates

fn mir_core_expr_is_return(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_RETURN())
}

fn mir_core_expr_is_break(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_BREAK())
}

fn mir_core_expr_is_continue(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_CONTINUE())
}
