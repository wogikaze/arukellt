use corehir::kinds
use corehir::function_id
use corehir::mir_signature_method
use corehir::mir_signature_fn
use corehir::signature_entry
use corehir::signature_registry
use corehir::type_id
use corehir::mir_value_type
use corehir::type_info_to_mir_value
use corehir::core_op_id
use corehir::param
use mir::lower::fn_index_method_return_type
use mir::lower::fn_index_source
use mir::lower::mono_suffix_parse
use mir::value_types

fn sig_reg_register_fn(
    table: TypeTable,
    registry: SignatureRegistry,
    source: MirLowerFnIndexSource,
    sig_source: CoreHirMirSignatureSource,
    fn_info_index: i32,
    typed_index: i32,
    mangled: String,
    impl_id: i32,
    mono_id: i32,
    abi: i32
) {
    // CoreHir params/VT only — TypedFn.TypeInfo values are unsafe across the
    // duplicate TypeInfo/TypedFn structs in the flat selfhost overlay.
    let params = sig_reg_params_from_fn_info(sig_source, fn_info_index, table)
    let returns = Vec_new_MirValueType()
    push(
        returns,
        type_info_to_mir_value::vt_to_mir_value(
            table,
            fn_index_source::mir_fn_index_source_typed_return_vt(source, typed_index),
            fn_index_source::mir_fn_index_source_typed_return_type_name(source, typed_index)
        )
    )
    let receiver = mir_value_type::MirValueType_new(type_id::TYPE_ID_INVALID(), kinds::VALUE_REPR_SCALAR(), kinds::NULLABILITY_NOT_REF())
    let entry = signature_entry::SignatureEntry_new(
        function_id::FunctionId_new(0),
        clone(mangled),
        params,
        returns,
        false,
        receiver,
        0 - 1,
        impl_id,
        mono_id,
        abi,
        core_op_id::CORE_OP_ID_NONE()
    )
    signature_registry::signature_registry_register(registry, entry, mangled)
}

fn sig_reg_register_method(
    table: TypeTable,
    registry: SignatureRegistry,
    source: MirLowerFnIndexSource,
    sig_source: CoreHirMirSignatureSource,
    method_info_index: i32,
    mangled: String,
    impl_decl_index: i32
) {
    let params = sig_reg_params_from_method_info(sig_source, method_info_index, table)
    let returns = Vec_new_MirValueType()
    let mrvt_name = fn_index_source::mir_fn_index_source_method_return_type_name_at(source, method_info_index, String_from(""))
    push(returns, type_info_to_mir_value::vt_to_mir_value(table, fn_index_source::mir_fn_index_source_method_return_vt_at(source, method_info_index, 1), clone(mrvt_name)))
    let receiver = type_info_to_mir_value::vt_to_mir_value(table, 5, String_from("String"))
    let entry = signature_entry::SignatureEntry_new(
        function_id::FunctionId_new(0),
        clone(mangled),
        params,
        returns,
        true,
        receiver,
        0 - 1,
        impl_decl_index,
        0 - 1,
        kinds::ABI_KIND_TRAIT_DISPATCH(),
        core_op_id::CORE_OP_ID_NONE()
    )
    signature_registry::signature_registry_register(registry, entry, mangled)
}

fn sig_reg_params_from_fn_info(sig_source: CoreHirMirSignatureSource, fn_info_index: i32, table: TypeTable) -> Vec<MirValueType> {
    sig_reg_params_from_fn_info_mono(sig_source, fn_info_index, table, String_new())
}

fn sig_reg_params_from_fn_info_mono(
    sig_source: CoreHirMirSignatureSource,
    fn_info_index: i32,
    table: TypeTable,
    mangled: String
) -> Vec<MirValueType> {
    let result = Vec_new_MirValueType()
    if fn_info_index < 0 {
        return result
    }
    let pc = mir_signature_fn::mir_signature_fn_param_count_at(sig_source, fn_info_index, 0)
    let mut pi = 0
    while pi < pc {
        let p = mir_signature_fn::mir_signature_fn_param_at(sig_source, fn_info_index, pi)
        let mut type_name = param::param_type_name(p)
        let local_name = param::param_local_type_name(p)
        if len(local_name) > 0 {
            type_name = local_name
        }
        if len(mangled) > 0 {
            type_name = sig_reg_subst_mono_param_type_name(clone(type_name), clone(mangled))
        }
        let mut vt = param::param_value_type(p)
        if starts_with(clone(type_name), String_from("vec:")) ||
        starts_with(clone(type_name), String_from("option:")) ||
        starts_with(clone(type_name), String_from("struct:")) {
            vt = value_types::VT_GC_REF()
        } else if !fn_index_method_return_type::method_return_type_name_is_type_var(clone(type_name)) &&
            len(type_name) > 0 {
                vt = fn_index_method_return_type::method_return_vt_from_type_name(clone(type_name))
            }
            push(result, type_info_to_mir_value::vt_to_mir_value(table, vt, type_name))
            pi = pi + 1
        }
        result
    }

    fn sig_reg_subst_mono_param_type_name(type_name: String, mangled: String) -> String {
        let suffix = mono_suffix_parse::extract_mono_suffix(clone(mangled))
        if len(suffix) == 0 {
            return type_name
        }
        if starts_with(clone(type_name), String_from("vec:")) {
            let elem = substring(clone(type_name), 4, len(type_name))
            if !mono_suffix_parse::mono_elem_is_substitutable_type_var(clone(elem)) {
                return type_name
            }
            let concrete = sig_reg_resolve_mono_type_key(clone(elem), clone(suffix))
            if len(concrete) == 0 {
                return type_name
            }
            return concat(String_from("vec:"), concrete)
        }
        if starts_with(clone(type_name), String_from("option:")) {
            let elem = substring(clone(type_name), 7, len(type_name))
            if !mono_suffix_parse::mono_elem_is_substitutable_type_var(clone(elem)) {
                return type_name
            }
            let concrete = sig_reg_resolve_mono_type_key(clone(elem), clone(suffix))
            if len(concrete) == 0 {
                return type_name
            }
            return concat(String_from("option:"), concrete)
        }
        if fn_index_method_return_type::method_return_type_name_is_type_var(clone(type_name)) {
            let concrete = sig_reg_resolve_mono_type_key(clone(type_name), clone(suffix))
            if len(concrete) > 0 {
                return concrete
            }
        }
        type_name
    }

    fn sig_reg_resolve_mono_type_key(type_var: String, mono_suffix: String) -> String {
        if starts_with(clone(mono_suffix), String_from("Vec")) {
            return mono_suffix
        }
        let keys = mono_suffix_parse::split_mono_suffix(clone(mono_suffix))
        let key_count = len(keys)
        if key_count <= 0 {
            return String_new()
        }
        if key_count == 1 {
            return get_unchecked(keys, 0)
        }
        let idx = mono_suffix_parse::mono_type_var_to_index(clone(type_var))
        if idx >= 0 && idx < key_count {
            return get_unchecked(keys, idx)
        }
        get_unchecked(keys, 0)
    }

    fn sig_reg_params_from_method_info(sig_source: CoreHirMirSignatureSource, method_info_index: i32, table: TypeTable) -> Vec<MirValueType> {
        let result = Vec_new_MirValueType()
        if method_info_index < 0 {
            return result
        }
        let pc = mir_signature_method::mir_signature_method_param_count_at(sig_source, method_info_index, 0)
        let mut pi = 0
        while pi < pc {
            let p = mir_signature_method::mir_signature_method_param_at(sig_source, method_info_index, pi)
            push(result, type_info_to_mir_value::vt_to_mir_value(table, param::param_value_type(p), param::param_type_name(p)))
            pi = pi + 1
        }
        result
    }
