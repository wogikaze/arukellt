use std::text
use mir::lower::ctx_gc_enum
use mir::lower::ctx_gc_enum_sig
use mir::lower::ctx_struct_field_type

fn ctx_ensure_gc_enum_payload_variant(ctx: LowerCtx, variant_name: String, payload_vts: Vec<i32>) -> i32 {
    let payload_found = ctx_gc_enum::ctx_gc_enum_variant_slot_for_payload(ctx, clone(variant_name), payload_vts)
    if payload_found >= 0 {
        return payload_found
    }
    let name_slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
    if name_slot >= 0 {
        let layout_field_sigs = gc_enum_build_payload_field_sigs(ctx, clone(variant_name))
        if len(layout_field_sigs) > 0 {
            let existing_sig = clone(get_unchecked(ctx.gc_enum_variant_sigs, name_slot))
            let existing_payload = ctx_gc_enum_sig::gc_enum_payload_suffix_after_prefix(clone(existing_sig), String_from("SubF+14_S_f0_i32"))
            if eq(clone(existing_payload), clone(layout_field_sigs)) {
                return name_slot
            }
        }
        let existing_sig = clone(get_unchecked(ctx.gc_enum_variant_sigs, name_slot))
        let want_field_sigs = ctx_gc_enum_sig::ctx_gc_enum_payload_field_sigs_from_vts(payload_vts)
        if ctx_gc_enum_sig::gc_enum_payload_sigs_compatible(existing_sig, want_field_sigs) {
            return name_slot
        }
    }
    let normalized = ctx_gc_enum::ctx_gc_enum_normalize_variant_name(clone(variant_name))
    let field_sigs = ctx_gc_enum_sig::ctx_gc_enum_payload_field_sigs_from_vts(payload_vts)
    let sig = ctx_gc_enum_sig::gc_enum_payload_variant_sig(len(ctx.gc_enum_variant_names), field_sigs)
    ctx_gc_enum::ctx_register_gc_enum_variant(ctx, clone(normalized), sig)
}

fn ctx_ensure_gc_enum_payload_variant_typed(ctx: LowerCtx, variant_name: String, payload_vts: Vec<i32>, type_name: String) -> i32 {
    let layout_field_sigs = gc_enum_build_payload_field_sigs(ctx, clone(variant_name))
    let field_sigs = gc_enum_payload_typed_resolve_field_sigs(ctx, clone(variant_name), payload_vts, clone(type_name), clone(layout_field_sigs))
    let normalized = ctx_gc_enum::ctx_gc_enum_normalize_variant_name(clone(variant_name))
    let want_sig = ctx_gc_enum_sig::gc_enum_payload_variant_sig(0, clone(field_sigs))
    let slot = gc_enum_payload_typed_find_slot(ctx, clone(variant_name), clone(normalized), want_sig, clone(field_sigs), clone(layout_field_sigs), clone(type_name))
    if slot >= 0 {
        return slot
    }
    let sig = ctx_gc_enum_sig::gc_enum_payload_variant_sig(len(ctx.gc_enum_variant_names), clone(field_sigs))
    ctx_gc_enum::ctx_register_gc_enum_variant(ctx, clone(normalized), sig)
}

fn gc_enum_payload_typed_resolve_field_sigs(ctx: LowerCtx, variant_name: String, payload_vts: Vec<i32>, type_name: String, layout_field_sigs: String) -> String {
    let mut field_sigs = ctx_gc_enum_sig::ctx_gc_enum_payload_field_sigs_typed(ctx, payload_vts, clone(type_name))
    let normalized = ctx_gc_enum::ctx_gc_enum_normalize_variant_name(clone(variant_name))
    let is_vec_container = ctx_gc_enum::gc_enum_variant_is_vec_container(clone(normalized))
    if is_vec_container {
        if contains(clone(field_sigs), String_from("ref14")) || len(field_sigs) == 0 {
            if len(layout_field_sigs) > 0 && !contains(clone(layout_field_sigs), String_from("ref14")) {
                field_sigs = layout_field_sigs
            } else if starts_with(clone(type_name), String_from("vec:")) || starts_with(clone(type_name), String_from("Vec")) {
                field_sigs = ctx_gc_enum_sig::ctx_gc_enum_payload_field_sigs_typed(ctx, payload_vts, clone(type_name))
            } else {
                field_sigs = String_from("_f1_ref25")
            }
        }
    }
    if len(layout_field_sigs) > 0 {
        if len(type_name) == 0 || eq(clone(type_name), String_from("enum:open")) || contains(clone(field_sigs), String_from("ref14")) {
            if contains(clone(layout_field_sigs), String_from("ref")) || contains(clone(layout_field_sigs), String_from("gcsref")) {
                if !(is_vec_container && contains(clone(layout_field_sigs), String_from("ref14"))) {
                    field_sigs = layout_field_sigs
                }
            }
        }
    }
    if is_vec_container && len(layout_field_sigs) > 0 && !contains(clone(layout_field_sigs), String_from("ref14")) {
        field_sigs = layout_field_sigs
    }
    field_sigs
}

fn gc_enum_payload_typed_find_slot(ctx: LowerCtx, variant_name: String, normalized: String, want_sig: String, field_sigs: String, layout_field_sigs: String, type_name: String) -> i32 {
    let count = len(ctx.gc_enum_variant_sigs)
    let mut i = 0
    while i < count {
        if eq(get_unchecked(ctx.gc_enum_variant_sigs, i), clone(want_sig)) {
            if ctx_gc_enum::ctx_gc_enum_variant_names_match(clone(get_unchecked(ctx.gc_enum_variant_names, i)), clone(normalized)) {
                return i
            }
        }
        i = i + 1
    }
    i = 0
    while i < count {
        if ctx_gc_enum::ctx_gc_enum_variant_names_match(clone(get_unchecked(ctx.gc_enum_variant_names, i)), clone(normalized)) {
            let existing_sig = clone(get_unchecked(ctx.gc_enum_variant_sigs, i))
            let existing_payload = ctx_gc_enum_sig::gc_enum_payload_suffix_after_prefix(clone(existing_sig), String_from("SubF+14_S_f0_i32"))
            if eq(clone(existing_payload), clone(field_sigs)) {
                return i
            }
        }
        i = i + 1
    }
    let name_slot = ctx_gc_enum::ctx_gc_enum_variant_slot(ctx, clone(variant_name))
    if name_slot >= 0 {
        let existing_sig = clone(get_unchecked(ctx.gc_enum_variant_sigs, name_slot))
        let existing_payload = ctx_gc_enum_sig::gc_enum_payload_suffix_after_prefix(clone(existing_sig), String_from("SubF+14_S_f0_i32"))
        let is_vec_container = ctx_gc_enum::gc_enum_variant_is_vec_container(clone(normalized))
        if is_vec_container && contains(clone(existing_payload), String_from("ref14")) && contains(clone(field_sigs), String_from("ref25")) {
            // fall through to register a fresh typed slot
        } else {
            if len(layout_field_sigs) > 0 && eq(clone(existing_payload), clone(layout_field_sigs)) {
                if len(field_sigs) == 0 || eq(clone(existing_payload), clone(field_sigs)) {
                    return name_slot
                }
            }
            if (len(type_name) == 0 || eq(clone(type_name), String_from("enum:open"))) && len(existing_payload) > 0 {
                if len(layout_field_sigs) == 0 || eq(clone(existing_payload), clone(layout_field_sigs)) {
                    if len(field_sigs) == 0 || eq(clone(existing_payload), clone(field_sigs)) {
                        if contains(clone(existing_payload), String_from("ref")) || contains(clone(existing_payload), String_from("gcsref")) {
                            return name_slot
                        }
                    }
                }
            }
            // Never reuse a scalar builtin Some/Ok slot for a ref payload
            // (or the reverse). Compatible() alone is not enough when the
            // first name hit is Option::Some/_f1_i32 and want is _f1_ref14.
            if len(field_sigs) > 0 &&
            !ctx_gc_enum_sig::gc_enum_payload_is_scalar_sig(clone(field_sigs)) &&
            ctx_gc_enum_sig::gc_enum_payload_is_scalar_sig(clone(existing_payload)) {
                // fall through
            } else if ctx_gc_enum_sig::gc_enum_payload_sigs_compatible(existing_sig, clone(field_sigs)) {
                return name_slot
            }
        }
    }
    0 - 1
}

fn gc_enum_build_payload_field_sigs(ctx: LowerCtx, variant_name: String) -> String {
    let mut sig = String_new()
    let layout_name = ctx_struct_field_type::ctx_resolve_variant_layout_name(ctx, clone(variant_name))
    let layout_count = len(ctx.struct_names)
    let mut li = 0
    while li < layout_count {
        if eq(get_unchecked(ctx.struct_names, li), clone(layout_name)) || eq(get_unchecked(ctx.struct_names, li), clone(variant_name)) {
            let field_count = get_unchecked(ctx.struct_field_counts, li)
            let mut fi = 1
            while fi < field_count {
                let mut off = 0
                let mut si = 0
                while si < li {
                    off = off + get_unchecked(ctx.struct_field_counts, si)
                    si = si + 1
                }
                off = off + fi
                let ft = get_unchecked(ctx.struct_field_types, off)
                sig = text::builder_append(sig, ctx_gc_enum_sig::gc_enum_field_sig_for_type_ctx(ctx, clone(ft)))
                fi = fi + 1
            }
            return sig
        }
        li = li + 1
    }
    sig
}
