use mir::lower::fn_index
use mir::lower::fn_index_view

fn mir_build_fn_index_from_view(view: CoreHirMirView, midx: MonoIndex, m: MirModule) -> MirLowerFnIndex {
    fn_index_view::mir_build_fn_index_from_view(view, midx, m)
}

fn mir_fn_index_typed_fn_count(info: MirLowerFnIndex) -> i32 {
    fn_index::mir_fn_index_typed_fn_count(info)
}
