fn closure_storage_clear_pending_bind(ctx: LowerCtx) {
    ctx.closure_last_synth = String_new()
    ctx.closure_last_caps = String_new()
    ctx.closure_last_extra = 0
}

fn closure_storage_next_synth_name(ctx: LowerCtx) -> String {
    let synth = concat(String_from("__closure_"), to_string(ctx.closure_counter))
    ctx.closure_counter = ctx.closure_counter + 1
    synth
}

fn closure_storage_pending_synth(ctx: LowerCtx) -> String {
    clone(ctx.closure_last_synth)
}

fn closure_storage_set_pending_bind(ctx: LowerCtx, synth: String, packed: String, extra: i32) {
    ctx.closure_last_synth = synth
    ctx.closure_last_caps = packed
    ctx.closure_last_extra = extra
}

fn closure_storage_push_bind(ctx: LowerCtx, bind_name: String) {
    push(ctx.closure_bind_names, bind_name)
    push(ctx.closure_bind_synth, clone(ctx.closure_last_synth))
    push(ctx.closure_bind_caps, clone(ctx.closure_last_caps))
    push(ctx.closure_bind_extra, ctx.closure_last_extra)
}

fn closure_storage_bind_count(ctx: LowerCtx) -> i32 {
    len(ctx.closure_bind_names)
}

fn closure_storage_bind_name_at(ctx: LowerCtx, index: i32) -> String {
    clone(get_unchecked(ctx.closure_bind_names, index))
}

fn closure_storage_bind_synth_at(ctx: LowerCtx, index: i32) -> String {
    clone(get_unchecked(ctx.closure_bind_synth, index))
}

fn closure_storage_bind_caps_at(ctx: LowerCtx, index: i32) -> String {
    clone(get_unchecked(ctx.closure_bind_caps, index))
}

fn closure_storage_bind_extra_at(ctx: LowerCtx, index: i32) -> i32 {
    get_unchecked(ctx.closure_bind_extra, index)
}
