use mir::lower::ctx_api_local_types
use mir::lower::ctx_gc_enum
use mir::value_types

fn mark_hash_type_ref(ctx: LowerCtx, dest: i32, type_name: String) {
    ctx_api_local_types::ctx_set_local_type(ctx, dest, type_name)
    if ctx_gc_enum::ctx_is_gc_target(ctx) {
        ctx_api_local_types::ctx_set_local_vt(ctx, dest, value_types::VT_GC_REF())
    }
}

fn callee_eq(callee_name: String, expected: String) -> bool {
    eq(clone(callee_name), expected)
}

fn is_hashmap_si32_new(callee_name: String) -> bool {
    if callee_eq(clone(callee_name), String_from("__hm_si_new")) {
        return true
    }
    if callee_eq(clone(callee_name), String_from("hash_string::hashmap_str_i32_new")) {
        return true
    }
    if callee_eq(clone(callee_name), String_from("HashMap_new_String_i32")) {
        return true
    }
    callee_eq(callee_name, String_from("HashMap_String_i32_new"))
}

