fn mark_hash_call_result_type(ctx: LowerCtx, callee_name: String, dest: i32) {
    if is_hashmap_si32_new(clone(callee_name)) {
        mark_hash_type_ref(ctx, dest, String_from("hashmap:si32"))
    }
    if is_hashmap_i32str_new(clone(callee_name)) {
        mark_hash_type_ref(ctx, dest, String_from("hashmap:i32str"))
    }
    if is_hashmap_strstr_new(clone(callee_name)) {
        mark_hash_type_ref(ctx, dest, String_from("hashmap:strstr"))
    }
    if callee_eq(clone(callee_name), String_from("__hm_si_get_key")) {
        mark_hash_type_ref(ctx, dest, String_from("string"))
    }
    if callee_eq(clone(callee_name), String_from("__hm_is_get_key")) {
        ctx_api_local_types::ctx_set_local_type(ctx, dest, String_from("i32"))
    }
    if callee_eq(clone(callee_name), String_from("__hm_is_get_val")) ||
    callee_eq(clone(callee_name), String_from("__hm_ss_get_key")) ||
    callee_eq(clone(callee_name), String_from("__hm_ss_get_val")) {
        mark_hash_type_ref(ctx, dest, String_from("string"))
    }
    if is_hashmap_i32i32_new(clone(callee_name)) {
        mark_hash_type_ref(ctx, dest, String_from("hashmap:i32i32"))
    }
    if is_hashset_i32_new(clone(callee_name)) {
        mark_hash_type_ref(ctx, dest, String_from("vec:i32"))
    }
    if is_hash_vec_i32_result(clone(callee_name)) {
        mark_hash_type_ref(ctx, dest, String_from("vec:i32"))
    }
    if callee_eq(clone(callee_name), String_from("hashset_str_new")) || callee_eq(clone(callee_name), String_from("hash_map::hashset_str_new")) {
        mark_hash_type_ref(ctx, dest, String_from("vec:String"))
    }
    mark_hash_query_result_type(ctx, callee_name, dest)
}

fn mark_hash_query_result_type(ctx: LowerCtx, callee_name: String, dest: i32) {
    if is_option_i32_hash_query(clone(callee_name)) {
        ctx_api_local_types::ctx_set_local_type(ctx, dest, String_from("Option_i32"))
        if ctx_gc_enum::ctx_is_gc_target(ctx) {
            ctx_api_local_types::ctx_set_local_vt(ctx, dest, value_types::VT_GC_REF())
        }
    }
    if is_option_string_hash_query(clone(callee_name)) {
        ctx_api_local_types::ctx_set_local_type(ctx, dest, String_from("Option_String"))
        if ctx_gc_enum::ctx_is_gc_target(ctx) {
            ctx_api_local_types::ctx_set_local_vt(ctx, dest, value_types::VT_GC_REF())
        }
    }
    if is_hash_size_query(clone(callee_name)) {
        ctx_api_local_types::ctx_set_local_type(ctx, dest, String_from("i32"))
    }
    if is_hash_bool_query(clone(callee_name)) {
        ctx_api_local_types::ctx_set_local_type(ctx, dest, String_from("bool"))
    }
}
// MIR call result type propagation for hash collections.
