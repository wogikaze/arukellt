use mir::lower::ctx_fn_return_vt
use mir::lower::loop_struct_iter
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_types
// Arukellt Selfhost - CoreHIR iterator for-loop MIR lowering.

use mir::lower::core_expr_shape_accessors
use mir::lower::core_for_values

fn lower_core_for_iter(ctx: LowerCtx, exprs: Vec<CoreHirExpr>, expr: CoreHirExpr) -> i32 {
    if core_expr_shape_accessors::mir_core_expr_child_count(expr) < 2 {
        return 0 - 1
    }
    let iter_expr = get_unchecked(exprs, core_expr_shape_accessors::mir_core_expr_child(expr, 0))
    let range_local_si = ctx_api_local_alloc::ctx_lookup_local(ctx, core_expr_shape_accessors::mir_core_expr_text(iter_expr))
    if range_local_si < 0 {
        return 0 - 1
    }
    let si_struct_type = ctx_api_local_types::ctx_get_local_type(ctx, range_local_si)
    if starts_with(clone(si_struct_type), "Vec") || starts_with(clone(si_struct_type), "vec:") {
        return core_for_values::lower_core_for_values(ctx, exprs, expr)
    }
    let si_next_callee = concat(clone(si_struct_type), String_from("::next"))
    let si_next_vt = ctx_fn_return_vt::ctx_fn_return_vt(ctx, clone(si_next_callee))
    if si_next_vt == 0 {
        return 0 - 1
    }
    let _si_iter_idx = lower_core_expr(ctx, exprs, core_expr_shape_accessors::mir_core_expr_child(expr, 0))
    let si_scope = loop_struct_iter::mir_begin_struct_iterator_loop(ctx, core_expr_shape_accessors::mir_core_expr_text(expr), si_struct_type, si_next_callee)
    let _si_body = lower_core_expr(ctx, exprs, core_expr_shape_accessors::mir_core_expr_child(expr, 1))
    loop_struct_iter::mir_end_struct_iterator_loop(ctx, si_scope)
    0 - 1
}
