use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower::ctx_types
// Arukellt Selfhost - MIR struct literal base-field copy emission.

use mir::inst_struct_get
use mir::inst_struct_set
use mir::inst_local_get
use mir::value_types

fn mir_copy_struct_base_fields(ctx: LowerCtx, struct_name: String, dest: i32, base_idx: i32) {
    let total_fields = ctx_struct_field_count(ctx, clone(struct_name))
    let byte_size = ctx_struct_byte_size(ctx, clone(struct_name))
    let mut fi = 0
    while fi < total_fields {
        let fname = ctx_struct_field_name(ctx, clone(struct_name), fi)
        let is_f64_field = ctx_struct_field_is_f64(ctx, clone(struct_name), fi)
        let is_i64_field = ctx_struct_field_is_i64(ctx, clone(struct_name), fi)
        let mut field_vt = value_types::VT_I32()
        if is_f64_field {
            field_vt = value_types::VT_F64()
        }
        if field_vt == value_types::VT_I32() && is_i64_field {
            field_vt = value_types::VT_I64()
        }
        if ctx_struct_field_is_v128(ctx, clone(struct_name), fi) {
            field_vt = value_types::VT_V128()
        }
        let tmp = ctx_fresh_local(ctx, field_vt)
        emit_struct_base_field_get(ctx, clone(struct_name), base_idx, tmp, ctx_struct_field_offset(ctx, clone(struct_name), fi), fi, is_f64_field, is_i64_field, byte_size)
        emit_struct_base_field_set(ctx, clone(struct_name), dest, tmp, ctx_struct_field_offset(ctx, clone(struct_name), fi), fi, is_f64_field, is_i64_field, byte_size)
        fi = fi + 1
    }
}

fn emit_struct_base_field_get(ctx: LowerCtx, struct_name: String, base_idx: i32, tmp: i32, offset: i32, field_idx: i32, is_f64_field: bool, is_i64_field: bool, byte_size: i32) {
    ctx_emit(ctx, inst_local_get::MirInst_local_get_to(base_idx, base_idx))
    let mut field_vt = value_types::VT_VOID()
    if is_f64_field {
        field_vt = value_types::VT_F64()
    }
    if field_vt == value_types::VT_VOID() && is_i64_field {
        field_vt = value_types::VT_I64()
    }
    if field_vt == value_types::VT_VOID() && ctx_struct_field_is_v128(ctx, clone(struct_name), offset) {
        field_vt = value_types::VT_V128()
    }
    ctx_emit(ctx, inst_struct_get::MirInst_struct_get_field_idx(base_idx, clone(struct_name), offset, field_idx, byte_size, field_vt, tmp))
}

fn emit_struct_base_field_set(ctx: LowerCtx, struct_name: String, dest: i32, tmp: i32, offset: i32, field_idx: i32, is_f64_field: bool, is_i64_field: bool, byte_size: i32) {
    let mut field_vt = value_types::VT_VOID()
    if is_f64_field {
        field_vt = value_types::VT_F64()
    }
    if field_vt == value_types::VT_VOID() && is_i64_field {
        field_vt = value_types::VT_I64()
    }
    if field_vt == value_types::VT_VOID() && ctx_struct_field_is_v128(ctx, clone(struct_name), offset) {
        field_vt = value_types::VT_V128()
    }
    ctx_emit(ctx, inst_struct_set::MirInst_struct_set_named_idx(dest, tmp, clone(struct_name), offset, field_idx, byte_size, field_vt))
}
