use corehir::param
use mir::lower::binary_type_names
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_function_frame
use mir::lower::ctx_api_local_types
use mir::lower::ctx_struct_layout
use mir::lower::ctx_types
use mir::local_factory
use mir::types
use mir::value_types

fn mir_bind_fn_param(ctx: LowerCtx, param: CoreHirParam) {
    if !param::param_is_bindable(param) {
        return
    }
    let mut pvt = param::param_value_type(param)
    let p_type_name = param::param_type_name(param)
    let local_type_name = param::param_local_type_name(param)
    let mut mir_type_name = clone(p_type_name)
    let mut sig_type_name = clone(p_type_name)
    let mut is_type_var = false
    if len(local_type_name) > 0 {
        mir_type_name = clone(local_type_name)
        sig_type_name = clone(local_type_name)
        if starts_with(clone(local_type_name), String_from("vec:")) ||
        starts_with(clone(local_type_name), String_from("hashmap:")) ||
        starts_with(clone(local_type_name), String_from("Option_")) ||
        starts_with(clone(local_type_name), String_from("option:")) ||
        starts_with(clone(local_type_name), String_from("Result_")) ||
        starts_with(clone(local_type_name), String_from("result:")) {
            pvt = value_types::VT_GC_REF()
        } else {
            // Qualified names like "parser::TomlValue" need the bare enum
            // name for layout lookup; without this, export shells keep VT_I32.
            let bare = mir_param_strip_module_prefix(clone(local_type_name))
            if ctx_struct_layout::ctx_is_registered_enum_type(ctx, clone(bare)) || ctx_struct_layout::ctx_is_registered_enum_type(ctx, clone(local_type_name)) {
                pvt = value_types::VT_GC_REF()
                mir_type_name = ctx_struct_layout::ctx_maybe_enum_return_type_name(ctx, clone(bare))
                sig_type_name = clone(mir_type_name)
            } else {
                if ctx_struct_layout::ctx_is_registered_struct_type(ctx, clone(local_type_name)) || ctx_struct_layout::ctx_is_registered_struct_type(ctx, clone(bare)) {
                    pvt = value_types::VT_GC_REF()
                    sig_type_name = ctx_struct_layout::ctx_maybe_enum_return_type_name(ctx, clone(bare))
                } else {
                    let named = mir_param_resolve_named_user_type(ctx, clone(bare))
                    if len(named) > 0 {
                        pvt = value_types::VT_GC_REF()
                        sig_type_name = clone(named)
                        mir_type_name = named
                    }
                }
            }
        }
    } else {
        let resolved = mir_param_resolve_no_local_type(ctx, clone(p_type_name))
        if len(resolved) > 0 {
            pvt = value_types::VT_GC_REF()
            mir_type_name = get_unchecked(resolved, 0)
            sig_type_name = get_unchecked(resolved, 1)
            if starts_with(clone(mir_type_name), String_from("?")) {
                is_type_var = true
            }
        }
    }
    let param_name = param::param_name(param)
    let param_local = ctx_alloc_local(ctx, clone(param_name), pvt)
    ctx_push_func_param(ctx, local_factory::MirLocal_new(clone(param_name), pvt, sig_type_name))
    ctx_api_local_types::ctx_set_local_type(ctx, param_local, mir_type_name)
}

fn mir_param_resolve_no_local_type(ctx: LowerCtx, p_type_name: String) -> Vec<String> {
    let result = Vec_new_String()
    if ctx_struct_layout::ctx_is_registered_enum_type(ctx, clone(p_type_name)) {
        let mt = concat(String_from("enum:"), p_type_name)
        push(result, mt)
        push(result, clone(mt))
        return result
    }
    if ctx_struct_layout::ctx_is_registered_struct_type(ctx, clone(p_type_name)) {
        push(result, clone(p_type_name))
        push(result, ctx_struct_layout::ctx_maybe_enum_return_type_name(ctx, clone(p_type_name)))
        return result
    }
    if !binary_type_names::mir_is_builtin_type_name(clone(p_type_name)) && len(p_type_name) > 0 {
        let mt = concat(String_from("?"), clone(p_type_name))
        push(result, mt)
        push(result, clone(mt))
        return result
    }
    result
}

fn mir_param_resolve_named_user_type(ctx: LowerCtx, bare: String) -> String {
    // Named user type not yet in layout table (or all-i32
    // struct that previously skipped GC registration): still
    // use the GC ABI so range_iter(Range) is not i32.
    // Unsubstituted type params (T, U, ...) stay i32.
    if !binary_type_names::mir_is_builtin_type_name(clone(bare)) && len(bare) > 0 && !mir_param_name_is_type_param(clone(bare)) {
        return bare
    }
    String_new()
}

fn mir_param_strip_module_prefix(name: String) -> String {
    let n = len(name)
    let mut i = n - 1
    while i >= 0 {
        if char_at(name, i) == 58 {
            return substring(name, i + 1, n)
        }
        i = i - 1
    }
    clone(name)
}

fn mir_param_name_is_type_param(name: String) -> bool {
    if len(name) == 0 {
        return false
    }
    if starts_with(clone(name), String_from("?")) {
        return mir_param_name_is_type_param(substring(name, 1, len(name)))
    }
    if len(name) == 1 {
        let ch = char_at(name, 0)
        if ch >= 65 && ch <= 90 {
            return true
        }
    }
    false
}
