use corehir::kinds
// Arukellt Selfhost - MIR lowering CoreHIR operator and binding shape predicates.

use corehir::expr_predicates

fn mir_core_expr_is_let(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_LET())
}

fn mir_core_expr_is_assign(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_ASSIGN())
}

fn mir_core_expr_is_binary(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_BINARY())
}

fn mir_core_expr_is_unary(expr: CoreHirExpr) -> bool {
    expr_predicates::expr_kind_is(expr, commands::COREHIR_EXPR_UNARY())
}
