// Arukellt Selfhost - MIR lowering context initialization API.

use mir::lower::ctx_init
use mir::lower::ctx_types

fn LowerCtx_new(m: MirModule) -> ctx_types::LowerCtx {
    ctx_init::LowerCtx_new(m)
}

fn LowerCtx_new_for_target(m: MirModule, target: String) -> ctx_types::LowerCtx {
    ctx_init::LowerCtx_new_for_target(m, target)
}
