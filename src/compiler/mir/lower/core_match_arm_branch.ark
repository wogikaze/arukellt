use mir::lower::ctx_api_emit
use mir::lower::ctx_types
// Arukellt Selfhost - CoreHIR non-final match arm MIR lowering.

use mir::inst_structured_control
use mir::lower::core_expr_shape_accessors
use mir::lower::core_expr_shape_patterns
use mir::lower::core_match_conditions
use mir::lower::core_match_control
use mir::lower::core_match_patterns
use mir::lower::core_match_payload
use mir::lower::core_match_result

fn core_match_arm_has_guard(arm: CoreHirExpr) -> bool {
    core_expr_shape_accessors::mir_core_expr_child_count(arm) == 3
}

fn lower_core_match_branch_arm(
    ctx: LowerCtx,
    exprs: Vec<CoreHirExpr>,
    arm_node: CoreHirExpr,
    pat: CoreHirExpr,
    body: i32,
    scrut_idx: i32,
    result: i32,
    payload_info: CoreMatchPayloadInfo,
    if_depth: i32
) -> i32 {
    let mut next_if_depth = if_depth
    let is_catchall = core_match_patterns::core_match_is_catchall(pat)
    let has_guard = core_match_arm_has_guard(arm_node)
    if is_catchall {
        if core_expr_shape_patterns::mir_core_expr_is_pat_ident(pat) {
            core_match_patterns::core_emit_match_ident_bind(ctx, pat, scrut_idx)
        }
        if has_guard {
            let guard = core_expr_shape_accessors::mir_core_expr_child(arm_node, 1)
            lower_core_expr(ctx, exprs, guard)
            core_match_control::core_emit_match_guard_begin(ctx)
            next_if_depth = next_if_depth + 1
        }
    } else {
        if core_expr_shape_patterns::mir_core_expr_is_pat_or(pat) {
            core_match_conditions::core_emit_or_pattern_condition(ctx, exprs, pat, core_match_payload::core_match_payload_compare_idx(payload_info), scrut_idx)
            core_match_control::core_emit_if_begin(ctx)
            next_if_depth = next_if_depth + 1
        } else {
            core_match_conditions::core_emit_value_pattern_condition(ctx, pat, core_match_payload::core_match_payload_compare_idx(payload_info), scrut_idx)
            core_match_control::core_emit_if_begin(ctx)
            next_if_depth = next_if_depth + 1
            core_match_payload::core_emit_payload_variant_binds_if_needed(ctx, exprs, payload_info, pat, scrut_idx)
            if has_guard {
                let guard2 = core_expr_shape_accessors::mir_core_expr_child(arm_node, 1)
                lower_core_expr(ctx, exprs, guard2)
                core_match_control::core_emit_match_guard_begin(ctx)
                next_if_depth = next_if_depth + 1
            }
        }
    }
    let arm_result = lower_core_expr(ctx, exprs, body)
    core_match_result::core_store_match_arm_result(ctx, result, arm_result)
    ctx_api_emit::ctx_emit(ctx, inst_structured_control::MirInst_else())
    next_if_depth
}
