use mir::lower::ast_node
use mir::lower::call_rewrite_method
use mir::lower::ctx_api_local_types
use mir::lower::ctx_api_local_alloc
use mir::lower::ctx_api_emit
use mir::lower_kinds
use mir::lower::ctx_types
use mir::inst_call
use mir::inst_local_get
use mir::inst_local_set
use mir::lower::ctx_gc_enum
use mir::value_types

fn mir_convert_print_arg_to_string(ctx: LowerCtx, arg: AstNode, arg_idx: i32) -> i32 {
    let wrap_lt = ctx_api_local_types::ctx_get_local_type(ctx, arg_idx)
    let mut wrap_callee = String_from("to_string")
    if eq(clone(wrap_lt), "char") || ast_node::node_kind_is(arg, lower_kinds::NK_CHAR_LIT()) {
        wrap_callee = String_from("char_to_string")
    } else {
        if eq(clone(wrap_lt), "bool") || ast_node::node_kind_is(arg, lower_kinds::NK_BOOL_LIT()) {
            wrap_callee = String_from("bool_to_string")
        } else {
            if eq(clone(wrap_lt), "f64") || ast_node::node_kind_is(arg, lower_kinds::NK_FLOAT_LIT()) {
                wrap_callee = String_from("f64_to_string")
            } else {
                if eq(clone(wrap_lt), "i64") || eq(clone(wrap_lt), "u64") || ctx_api_local_types::ctx_local_vt(ctx, arg_idx) == value_types::VT_I64() {
                    wrap_callee = String_from("i64_to_string")
                } else {
                    wrap_callee = call_rewrite_method::mir_try_resolve_impl_method(ctx, clone(wrap_callee), arg_idx)
                }
            }
        }
    }
    let wrap_vt = if ctx_gc_enum::ctx_is_gc_target(ctx) {
        value_types::VT_GC_REF()
    } else {
        value_types::VT_REF()
    }
    let wrap_dest = ctx_api_local_alloc::ctx_fresh_local(ctx, wrap_vt)
    ctx_api_local_types::ctx_set_local_type(ctx, wrap_dest, String_from("String"))
    let arg_vt = ctx_api_local_types::ctx_local_vt(ctx, arg_idx)
    let arg_temp = ctx_api_local_alloc::ctx_fresh_local(ctx, arg_vt)
    if len(wrap_lt) > 0 {
        ctx_api_local_types::ctx_set_local_type(ctx, arg_temp, wrap_lt)
    }
    ctx_api_emit::ctx_emit(ctx, inst_local_set::MirInst_local_set_from(arg_temp, arg_idx))
    ctx_api_emit::ctx_emit(ctx, inst_local_get::MirInst_local_get(arg_temp))
    ctx_api_emit::ctx_emit(ctx, inst_call::MirInst_call(wrap_callee, 1, wrap_dest))
    wrap_dest
}
