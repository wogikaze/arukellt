// Arukellt Selfhost - closure capture name packing.
use std::text

fn closure_pack_caps(caps: Vec<String>) -> String {
    let mut s = text::builder_new()
    let c = len(caps)
    let mut i = 0
    while i < c {
        if i > 0 {
            s = text::builder_append(s, String_from(","))
        }
        s = text::builder_append(s, clone(get_unchecked(caps, i)))
        i = i + 1
    }
    text::builder_build(s)
}
