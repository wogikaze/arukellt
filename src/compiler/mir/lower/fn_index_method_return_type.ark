// Arukellt Selfhost - method return TypeInfo for mono index prepass.

use mir::lower_kinds
use mir::type_contracts

fn method_generic_return_type_from_name(type_name: String, has_mono_variants: bool) -> TypeInfo {
    if len(type_name) == 0 && has_mono_variants {
        return type_contracts::TypeInfo_new(lower_kinds::TY_TYPE_VAR(), String_from("T"), Vec_new_TypeInfo())
    }
    method_return_type_info_from_name(type_name)
}

fn method_return_type_info_from_name(type_name: String) -> TypeInfo {
    if len(type_name) == 0 {
        return type_contracts::TypeInfo_simple(0)
    }
    if eq(clone(type_name), String_from("i32")) || eq(clone(type_name), String_from("u32")) || eq(clone(type_name), String_from("u8")) || eq(clone(type_name), String_from("u16")) || eq(clone(type_name), String_from("i16")) || eq(clone(type_name), String_from("i8")) {
        return type_contracts::TypeInfo_simple(lower_kinds::TY_I32())
    }
    if eq(clone(type_name), String_from("i64")) || eq(clone(type_name), String_from("u64")) {
        return type_contracts::TypeInfo_simple(lower_kinds::TY_I64())
    }
    if eq(clone(type_name), String_from("f64")) {
        return type_contracts::TypeInfo_simple(lower_kinds::TY_F64())
    }
    if eq(clone(type_name), String_from("f32")) {
        return type_contracts::TypeInfo_simple(lower_kinds::TY_F32())
    }
    if eq(clone(type_name), String_from("bool")) {
        return type_contracts::TypeInfo_simple(lower_kinds::TY_BOOL())
    }
    if eq(clone(type_name), String_from("char")) {
        return type_contracts::TypeInfo_simple(lower_kinds::TY_CHAR())
    }
    if eq(clone(type_name), String_from("String")) || eq(clone(type_name), String_from("string")) {
        return type_contracts::TypeInfo_new(lower_kinds::TY_STRING(), String_from("String"), Vec_new_TypeInfo())
    }
    if starts_with(clone(type_name), String_from("vec:")) {
        return type_contracts::TypeInfo_new(lower_kinds::TY_VEC(), clone(type_name), Vec_new_TypeInfo())
    }
    if method_return_type_name_is_type_var(clone(type_name)) {
        return type_contracts::TypeInfo_new(lower_kinds::TY_TYPE_VAR(), clone(type_name), Vec_new_TypeInfo())
    }
    type_contracts::TypeInfo_new(lower_kinds::TY_STRUCT(), clone(type_name), Vec_new_TypeInfo())
}

fn method_return_type_name_is_type_var(type_name: String) -> bool {
    if eq(clone(type_name), String_from("T")) || eq(clone(type_name), String_from("A")) || eq(clone(type_name), String_from("B")) || eq(clone(type_name), String_from("C")) || eq(clone(type_name), String_from("D")) || eq(clone(type_name), String_from("E")) || eq(clone(type_name), String_from("K")) || eq(clone(type_name), String_from("U")) || eq(clone(type_name), String_from("V")) || eq(clone(type_name), String_from("W")) {
        return true
    }
    false
}
