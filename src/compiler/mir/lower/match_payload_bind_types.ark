// MIR match payload bind types.
use mir::lower::ctx_api_local_types
use mir::lower::ctx_gc_enum
use mir::lower::ctx_gc_struct
use mir::lower::ctx_struct_field_type
use mir::lower::match_payload_field_type
use mir::value_types

fn set_gc_payload_bind_type_if_needed(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, field_idx: i32) {
    if bind_vt != value_types::VT_GC_REF() {
        return
    }
    let field_type = ctx_struct_field_type::ctx_struct_field_type_name(ctx, clone(variant_name), field_idx + 1)
    if eq(clone(field_type), "String") || eq(clone(field_type), "string") {
        ctx_set_local_type(ctx, bind_local, String_from("string"))
        return
    }
    // Vec<T> / Vec_T must stay container types — never enum:Vec<...> which
    // collapses Table payloads to enum-open (#726 toml_full_*).
    let vec_type = normalize_payload_vec_type_name(clone(field_type))
    if len(vec_type) > 0 {
        ctx_set_local_type(ctx, bind_local, vec_type)
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if len(field_type) > 0 && ctx_struct_field_type::field_type_is_registered_enum(ctx, clone(field_type)) {
        ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if len(field_type) > 0 && !match_payload_field_type::mir_payload_scalar_type_name(clone(field_type)) {
        // Named GC structs keep bare names for gcsref Option payloads (#726).
        if ctx_gc_struct::ctx_gc_struct_slot(ctx, clone(field_type)) >= 0 {
            ctx_set_local_type(ctx, bind_local, clone(field_type))
        } else {
            ctx_set_local_type(ctx, bind_local, concat(String_from("enum:"), field_type))
        }
        ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_GC_REF())
        return
    }
    if match_payload_field_type::mir_match_variant_is_err(clone(variant_name)) && field_idx == 0 {
        ctx_set_local_type(ctx, bind_local, String_from("string"))
    }
}

fn normalize_payload_vec_type_name(field_type: String) -> String {
    if starts_with(clone(field_type), String_from("vec:")) {
        return field_type
    }
    if eq(clone(field_type), String_from("Vec")) {
        return String_from("vec:i32")
    }
    if starts_with(clone(field_type), String_from("Vec<")) && ends_with(clone(field_type), String_from(">")) {
        let inner = substring(clone(field_type), 4, len(field_type) - 1)
        return concat(String_from("vec:"), inner)
    }
    if starts_with(clone(field_type), String_from("Vec_")) {
        let inner = substring(clone(field_type), 4, len(field_type))
        return concat(String_from("vec:"), inner)
    }
    String_new()
}

fn set_i32_payload_bind_type_if_needed(ctx: LowerCtx, variant_name: String, bind_local: i32, bind_vt: i32, field_idx: i32, scrut_ok_is_i32: bool) {
    if bind_vt == value_types::VT_I32() && scrut_ok_is_i32 && field_idx == 0 {
        if match_payload_field_type::mir_match_variant_is_some_or_ok(clone(variant_name)) {
            ctx_set_local_type(ctx, bind_local, String_from("i32"))
            ctx_api_local_types::ctx_set_local_vt(ctx, bind_local, value_types::VT_I32())
        }
    }
}

fn normalize_payload_elem_type_name(elem_ty: String) -> String {
    if eq(clone(elem_ty), String_from("Vec")) {
        return String_from("vec:i32")
    }
    if starts_with(clone(elem_ty), String_from("Vec<")) && ends_with(clone(elem_ty), String_from(">")) {
        let inner = substring(clone(elem_ty), 4, len(elem_ty) - 1)
        return concat(String_from("vec:"), inner)
    }
    if starts_with(clone(elem_ty), String_from("Vec_")) {
        return concat(String_from("vec:"), substring(clone(elem_ty), 4, len(elem_ty)))
    }
    elem_ty
}

fn payload_bind_needs_variant_slot(type_name: String, variant_name: String) -> bool {
    if match_payload_field_type::mir_match_variant_is_some_or_ok(clone(variant_name)) || match_payload_field_type::mir_match_variant_is_err(clone(variant_name)) {
        return false
    }
    if len(type_name) == 0 || eq(clone(type_name), String_from("enum:open")) {
        return false
    }
    // Nested enum payloads (enum:Inner from Outer::Wrap) must stay
    // enum-open. The container's payload type_slot is Outer::Wrap, not
    // Inner — applying it types the bind as the wrong concrete variant
    // (#726 nested_enum).
    if starts_with(clone(type_name), String_from("enum:")) {
        return false
    }
    false
}

fn extract_first_result_type_param(scrut_type: String) -> String {
    let prefix_len = 7
    let rest = substring(scrut_type, prefix_len, len(scrut_type))
    // Split Ok/Err on the LAST encoding separator so nested vec:T /
    // Vec_T / option:T stay intact (#726 toml Result<Vec<T>, E>).
    // result:vec:T:E → last ':'; Result_vec:T_E / Result_Vec_T_E → last '_'.
    let sep_char = if starts_with(clone(scrut_type), String_from("result:")) { 58 } else { 95 }
    let last = find_last_sep_char(clone(rest), sep_char)
    if last > 0 {
        return normalize_payload_elem_type_name(substring(rest, 0, last))
    }
    normalize_payload_elem_type_name(rest)
}

fn extract_second_result_type_param(scrut_type: String) -> String {
    let prefix_len = 7
    let rest = substring(scrut_type, prefix_len, len(scrut_type))
    let sep_char = if starts_with(clone(scrut_type), String_from("result:")) { 58 } else { 95 }
    let last = find_last_sep_char(clone(rest), sep_char)
    if last >= 0 && last + 1 < len(rest) {
        return substring(rest, last + 1, len(rest))
    }
    String_new()
}

fn find_last_sep_char(s: String, sep_char: i32) -> i32 {
    let n = len(s)
    let mut i = n - 1
    while i >= 0 {
        if char_at(clone(s), i) == sep_char {
            return i
        }
        i = i - 1
    }
    0 - 1
}

fn payload_type_name_is_gc_ref(ctx: LowerCtx, bind_local: i32) -> bool {
    let type_name = ctx_api_local_types::ctx_get_local_type(ctx, bind_local)
    if len(type_name) == 0 {
        return false
    }
    if eq(clone(type_name), String_from("string")) || eq(clone(type_name), String_from("String")) {
        return true
    }
    if starts_with(clone(type_name), String_from("vec:")) || starts_with(clone(type_name), String_from("Vec<")) || starts_with(clone(type_name), String_from("Vec_")) || eq(clone(type_name), String_from("Vec")) {
        return true
    }
    if starts_with(clone(type_name), String_from("hashmap:")) {
        return true
    }
    if starts_with(clone(type_name), String_from("option:")) || starts_with(clone(type_name), String_from("Option_")) {
        return true
    }
    if starts_with(clone(type_name), String_from("Result_")) || starts_with(clone(type_name), String_from("result:")) {
        return true
    }
    if starts_with(clone(type_name), String_from("enum:")) {
        return true
    }
    if starts_with(clone(type_name), String_from("struct:")) {
        return true
    }
    false
}
