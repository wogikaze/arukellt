use mir::lower::ctx_api_local_types
use mir::lower::ctx_fn_return_type
use mir::lower::ctx_fn_return_vt
use mir::lower::ctx_types
// Arukellt Selfhost - CoreHIR print argument conversion decision.

use mir::lower::core_call_arg_names
use mir::lower::core_expr_shape_accessors
use mir::lower::core_expr_shape_atoms
use mir::lower::core_expr_shape_calls
use mir::lower::core_expr_shape_ops
use mir::value_types

fn mir_core_print_arg_needs_string_conversion(ctx: LowerCtx, arg: CoreHirExpr, arg_idx: i32) -> bool {
    if core_expr_shape_calls::mir_core_expr_is_call(arg) {
        let cn = core_expr_shape_accessors::mir_core_expr_text(arg)
        if core_call_arg_names::mir_core_call_string_result_name(clone(cn)) {
            return false
        }
        let return_type_name = ctx_fn_return_type::ctx_fn_return_type_name(ctx, clone(cn))
        if eq(clone(return_type_name), "String") || eq(clone(return_type_name), "str") || eq(clone(return_type_name), "string") {
            return false
        }
        let rv = ctx_fn_return_vt::ctx_fn_return_vt(ctx, clone(cn))
        if rv == value_types::VT_GC_REF() || rv == value_types::VT_REF() {
            return false
        }
        if len(return_type_name) > 0 {
            if rv == value_types::VT_I32() || rv == value_types::VT_I64() || rv == value_types::VT_F64() {
                return true
            }
        }
    }
    if arg_idx >= 0 {
        let lt = ctx_api_local_types::ctx_get_local_type(ctx, arg_idx)
        if eq(clone(lt), "String") || eq(clone(lt), "str") || eq(clone(lt), "string") {
            return false
        }
        let arg_vt = ctx_api_local_types::ctx_local_vt(ctx, arg_idx)
        if arg_vt == value_types::VT_I32() || arg_vt == value_types::VT_I64() || arg_vt == value_types::VT_F64() {
            return true
        }
    }
    let mut needs_convert = core_expr_shape_atoms::mir_core_expr_is_int(arg) || core_expr_shape_atoms::mir_core_expr_is_bool(arg) || core_expr_shape_atoms::mir_core_expr_is_char(arg) || core_expr_shape_atoms::mir_core_expr_is_float(arg) || core_expr_shape_ops::mir_core_expr_is_unary(arg)
    if !needs_convert {
        let lt = ctx_api_local_types::ctx_get_local_type(ctx, arg_idx)
        if eq(clone(lt), "char") || eq(clone(lt), "u8") || eq(clone(lt), "u16") || eq(clone(lt), "u32") || eq(clone(lt), "u64") || eq(clone(lt), "i16") || eq(clone(lt), "i32") || eq(clone(lt), "i64") || eq(clone(lt), "bool") || eq(clone(lt), "f64") {
            needs_convert = true
        }
    }
    needs_convert
}
