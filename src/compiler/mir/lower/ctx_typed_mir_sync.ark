use mir::function_locals_view
use mir::local_access
use mir::local_mutation
use mir::lower::ctx_current_storage
use mir::function_local_mutation
use mir::spine_lookup
use mir::typed_mir_compat

fn ctx_sync_local_value_type(ctx: LowerCtx, local_idx: i32) {
    let m = ctx_current_storage::ctx_current_module_value(ctx)
    let func = ctx_current_storage::ctx_current_func_value(ctx)
    if local_idx < 0 || local_idx >= function_locals_view::MirFunction_local_count(func) {
        return
    }
    let loc = function_locals_view::MirFunction_local_at(func, local_idx)
    let vt = local_access::MirLocal_val_type(loc)
    let tn = local_access::MirLocal_type_name(loc)
    let mvt = spine_lookup::legacy_vt_to_mvt(m, vt, clone(tn))
    let mut f = func
    let new_loc = local_mutation::MirLocal_copy_with_value_type(loc, mvt)
    function_local_mutation::MirFunction_set_local(f, local_idx, new_loc)
    ctx_current_storage::ctx_set_current_func_value(ctx, f)
}

fn ctx_set_local_mvt(ctx: LowerCtx, local_idx: i32, value_type: MirValueType) {
    let func = ctx_current_storage::ctx_current_func_value(ctx)
    if local_idx < 0 || local_idx >= function_locals_view::MirFunction_local_count(func) {
        return
    }
    let loc = function_locals_view::MirFunction_local_at(func, local_idx)
    let mut f = func
    let new_loc = local_mutation::MirLocal_copy_with_value_type(loc, value_type)
    function_local_mutation::MirFunction_set_local(f, local_idx, new_loc)
    ctx_current_storage::ctx_set_current_func_value(ctx, f)
}

fn ctx_local_mvt(ctx: LowerCtx, local_idx: i32) -> MirValueType {
    let func = ctx_current_storage::ctx_current_func_value(ctx)
    if local_idx < 0 || local_idx >= function_locals_view::MirFunction_local_count(func) {
        return typed_mir_compat::mvt_invalid()
    }
    let loc = function_locals_view::MirFunction_local_at(func, local_idx)
    local_access::MirLocal_value_type(loc)
}

fn ctx_enrich_inst_result_types(ctx: LowerCtx, inst: MirInst) -> MirInst {
    let m = ctx_current_storage::ctx_current_module_value(ctx)
    spine_lookup::enrich_inst_result_types(m, inst)
}
