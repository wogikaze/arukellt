use mir::lower::ctx_types
// Arukellt Selfhost - MIR match payload field value-type selection.

use mir::value_types

fn mir_payload_field_vt(ctx: LowerCtx, variant_name: String, field_idx: i32, scrut_ok_is_f64: bool, scrut_ok_is_i64: bool) -> i32 {
    let mut field_is_f64 = ctx_struct_field_is_f64(ctx, clone(variant_name), field_idx + 1)
    if !field_is_f64 && scrut_ok_is_f64 && field_idx == 0 {
        if mir_match_variant_is_some_or_ok(clone(variant_name)) {
            field_is_f64 = true
        }
    }
    if field_is_f64 {
        return value_types::VT_F64()
    }
    if scrut_ok_is_i64 && field_idx == 0 {
        if mir_match_variant_is_some_or_ok(clone(variant_name)) {
            return value_types::VT_I64()
        }
    }
    value_types::VT_I32()
}

fn mir_match_variant_is_some_or_ok(variant_name: String) -> bool {
    if eq(clone(variant_name), "Ok") || eq(clone(variant_name), "Result::Ok") {
        return true
    }
    if eq(clone(variant_name), "Some") || eq(clone(variant_name), "Option::Some") {
        return true
    }
    false
}
