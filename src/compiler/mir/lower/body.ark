use mir::lower::ast_node
use mir::lower::body_dispatch_expr
use mir::lower::body_dispatch_stmt
use mir::lower::values

fn lower_expr(ctx: LowerCtx, node: AstNode) -> i32 {
    let kind = ast_node::node_kind(node)
    let atomic = values::lower_atomic_expr(ctx, node)
    if atomic != 0 - 2 {
        return atomic
    }
    let non_stmt_result = body_dispatch_expr::lower_non_statement_expr(ctx, node, kind)
    if non_stmt_result != 0 - 2 {
        return non_stmt_result
    }
    body_dispatch_stmt::lower_statement_like_expr(ctx, node, kind)
}
