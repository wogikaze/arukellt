use mir::inst_accessors_shape
use mir::inst_accessors_literals
use mir::block_inst_access
use mir::opcodes
use mir::function_block_queries
use mir::reachability_names
use mir::types

fn mir_mark_reachable_calls(functions: Vec<MirFunction>, reachable: Vec<i32>) -> bool {
    let fn_count = len(functions)
    let mut changed = false
    let mut fi = 0
    while fi < fn_count {
        if get_unchecked(reachable, fi) != 0 {
            let f = get_unchecked(functions, fi)
            if mir_mark_function_call_targets(functions, reachable, f) {
                changed = true
            }
        }
        fi = fi + 1
    }
    changed
}

fn mir_mark_function_call_targets(functions: Vec<MirFunction>, reachable: Vec<i32>, f: MirFunction) -> bool {
    let mut changed = false
    let block_count = function_block_queries::MirFunction_block_count(f)
    let mut bi = 0
    while bi < block_count {
        let block = function_block_queries::MirFunction_block_at(f, bi)
        let inst_count = block_inst_access::MirBlock_inst_count(block)
        let mut ii = 0
        while ii < inst_count {
            let inst = block_inst_access::MirBlock_inst_at(block, ii)
            let op = inst_accessors_shape::MirInst_op(inst)
            if op == opcodes::MIR_CALL() {
                if reachability_names::mir_mark_reachable_name(functions, reachable, inst_accessors_literals::MirInst_str_val(inst)) {
                    changed = true
                }
            }
            if op == opcodes::MIR_REF_FUNC() {
                if reachability_names::mir_mark_reachable_name(functions, reachable, inst_accessors_literals::MirInst_str_val(inst)) {
                    changed = true
                }
            }
            ii = ii + 1
        }
        bi = bi + 1
    }
    changed
}
