use mir::reachability_index
use mir::types

fn mir_enqueue_reachable_name(
    index: MirReachabilityIndex,
    functions: Vec<MirFunction>,
    reachable: Vec<i32>,
    queue: Vec<i32>,
    name: String
) -> bool {
    reachability_index::mir_reachability_enqueue_by_name(index, functions, reachable, queue, name)
}
