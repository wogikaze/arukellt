use mir::ssa_state_factory
use mir::function_locals_view
// Arukellt Selfhost - MIR SSA function/module rename entrypoints.

use mir::function_block_queries
use mir::module_functions
use mir::ssa_rename_block
use mir::ssa_rename_init

fn mir_ssa_rename_function(f: MirFunction) {
    let original_local_count = function_locals_view::MirFunction_local_count(f)
    ssa_rename_init::mir_ssa_reset_local_slots(f)
    let state = ssa_state_factory::MirSsaRenameState_new(original_local_count, function_block_queries::MirFunction_block_count(f))
    ssa_rename_init::mir_ssa_tag_function_params(f, state)
    ssa_rename_block::mir_ssa_rename_blocks(f, state)
}

fn mir_ssa_rename_module(m: MirModule) {
    let fn_count = module_functions::MirModule_function_count(m)
    let mut i = 0
    while i < fn_count {
        mir_ssa_rename_function(module_functions::MirModule_function_at(m, i))
        i = i + 1
    }
}
