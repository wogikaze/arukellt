use std::host::process
use std::host::stdio
use std::text
use mir::dump_format_phi
use mir::phi_access

fn mir_expect_phi_args(f: MirFunction, block_id: i32, phi: MirPhi, expected_count: i32, expected_pred0: i32, expected_local0: i32, expected_pred1: i32, expected_local1: i32) {
    let arg_count = phi_access::MirPhi_arg_count(phi)
    if arg_count != expected_count {
        let mut msg = concat(String_from("phi arg count check failed for bb"), to_string(block_id))
        msg = text::builder_append(msg, String_from(": expected="))
        msg = text::builder_append(msg, to_string(expected_count))
        msg = text::builder_append(msg, String_from(" actual="))
        msg = text::builder_append(msg, to_string(arg_count))
        stdio::eprintln(msg)
        process::exit(1)
    }
    if expected_count > 0 {
        let arg0 = phi_access::MirPhi_arg_at(phi, 0)
        if phi_access::MirPhiArg_pred_block(arg0) != expected_pred0 || phi_access::MirPhiArg_local(arg0) != expected_local0 {
            let msg = concat(String_from("phi arg0 check failed for bb"), concat(to_string(block_id), concat(String_from(": actual="), dump_format_phi::mir_format_phi(f, phi))))
            stdio::eprintln(msg)
            process::exit(1)
        }
    }
    if expected_count > 1 {
        let arg1 = phi_access::MirPhi_arg_at(phi, 1)
        if phi_access::MirPhiArg_pred_block(arg1) != expected_pred1 || phi_access::MirPhiArg_local(arg1) != expected_local1 {
            let msg = concat(String_from("phi arg1 check failed for bb"), concat(to_string(block_id), concat(String_from(": actual="), dump_format_phi::mir_format_phi(f, phi))))
            stdio::eprintln(msg)
            process::exit(1)
        }
    }
}
