// Arukellt Selfhost - MIR block data record.

use mir::opcodes
use mir::phi_record
use mir::inst_record

pub struct MirBlock {
    id: i32,
    phis: Vec<MirPhi>,
    instructions: Vec<MirInst>,
    terminator: i32,
    succ0: i32,
    succ1: i32,
    preds: Vec<i32>,
    idom: i32,
    dom_set: Vec<i32>,
    dom_frontier: Vec<i32>,
}

fn MirBlock_new(id: i32) -> MirBlock {
    MirBlock {
        id: id,
        phis: Vec_new_MirPhi(),
        instructions: Vec_new_MirInst(),
        terminator: opcodes::MIR_RETURN(),
        succ0: 0 - 1,
        succ1: 0 - 1,
        preds: Vec_new_i32(),
        idom: 0 - 1,
        dom_set: Vec_new_i32(),
        dom_frontier: Vec_new_i32()
    }
}
