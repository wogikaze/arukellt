use mir::block_inst_mutation
// Arukellt Selfhost - MIR function instruction append API.

use mir::function_block_queries
use mir::types

fn emit_inst(f: MirFunction, block_id: i32, inst: MirInst) {
    let block = function_block_queries::MirFunction_block_at(f, block_id)
    block_inst_mutation::MirBlock_push_inst(block, inst)
}
