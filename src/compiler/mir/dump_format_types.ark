// Arukellt Selfhost - MIR dump value type formatting

use mir::value_types

fn mir_value_type_name(vt: i32) -> String {
    if vt == value_types::VT_I32() {
        return String_from("i32")
    }
    if vt == value_types::VT_I64() {
        return String_from("i64")
    }
    if vt == value_types::VT_F64() {
        return String_from("f64")
    }
    if vt == value_types::VT_REF() {
        return String_from("ref")
    }
    if vt == value_types::VT_GC_REF() {
        return String_from("gc_ref")
    }
    if vt == value_types::VT_VOID() {
        return String_from("void")
    }
    String_from("?")
}
