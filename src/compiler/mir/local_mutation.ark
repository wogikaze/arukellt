use mir::local_record

fn MirLocal_set_ssa(local: MirLocal, ssa_name: String, ssa_version: i32) {
    local_record::mir_local_set_ssa(local, ssa_name, ssa_version)
}

fn MirLocal_set_val_type(local: MirLocal, val_type: i32) {
    local_record::mir_local_set_val_type(local, val_type)
}

fn MirLocal_set_val_type_only(local: MirLocal, val_type: i32) {
    local_record::mir_local_set_val_type_only(local, val_type)
}

fn MirLocal_set_type_name(local: MirLocal, type_name: String) {
    local_record::mir_local_set_type_name(local, type_name)
}

fn MirLocal_copy_with_val_type(source: MirLocal, val_type: i32) -> MirLocal {
    local_record::mir_local_copy_with_val_type(source, val_type)
}

fn MirLocal_copy_with_type_name(source: MirLocal, type_name: String) -> MirLocal {
    local_record::mir_local_copy_with_type_name(source, type_name)
}

fn MirLocal_copy_with_value_type(source: MirLocal, value_type: MirValueType) -> MirLocal {
    local_record::mir_local_copy_with_value_type(source, value_type)
}

fn MirLocal_set_value_type(local: MirLocal, value_type: MirValueType) {
    local_record::mir_local_set_value_type(local, value_type)
}
