// Arukellt Selfhost - monomorphization name normalization

fn mono_safe_name(name: String) -> String {
    let mut out = String_from("")
    let n = len(name)
    let mut i = 0
    while i < n {
        let ch = char_at(name, i)
        if ch == 60 || ch == 62 || ch == 44 || ch == 58 || ch == 32 {
            out = concat(out, String_from("_"))
        } else {
            out = concat(out, substring(name, i, i + 1))
        }
        i = i + 1
    }
    out
}
