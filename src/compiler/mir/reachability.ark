use mir::reachability_entry
use mir::types

fn mir_prune_unreachable_with_roots(m: MirModule, extra_roots: Vec<String>) -> i32 {
    reachability_entry::mir_prune_unreachable_with_roots(m, extra_roots)
}

fn mir_prune_unreachable(m: MirModule) -> i32 {
    reachability_entry::mir_prune_unreachable_with_roots(m, Vec_new_String())
}

fn mir_prune_unreachable_for_t3(m: MirModule, export_names: Vec<String>) -> i32 {
    reachability_entry::mir_prune_unreachable_with_roots(m, export_names)
}
