use std::host::env
use std::host::env
use mir::inst_accessors_shape
use mir::inst_accessors_literals
use mir::block_inst_access
use mir::opcodes
use mir::function_block_queries
use mir::function_identity
use mir::core_op_call
use mir::module_functions
use mir::reachability_prune
use mir::types
use resolver
use mir::inst_accessors_shape
use mir::inst_accessors_literals
use mir::block_inst_access
use mir::opcodes
use mir::function_block_queries
use mir::function_identity
use mir::core_op_call
use mir::module_functions
use mir::reachability_prune
use mir::types
use resolver

// Pre-#823 fixpoint walk kept for A/B measurement only.
// Enable with MIR_REACHABILITY_LEGACY_FIXPOINT=1 on a clock-capable artifact.

fn mir_reachability_legacy_enabled() -> bool {
    match env::var(String_from("MIR_REACHABILITY_LEGACY_FIXPOINT")) {
        Some(v) => eq(clone(v), String_from("1")) || eq(clone(v), String_from("true")),
        None => false
    }
}

fn mir_legacy_mark_reachable_name(functions: Vec<MirFunction>, reachable: Vec<i32>, name: String) -> bool {
    let count = len(functions)
    let mut i = 0
    while i < count {
        let f = get_unchecked(functions, i)
        if eq(function_identity::MirFunction_name(f), clone(name)) {
            if get_unchecked(reachable, i) == 0 {
                set(reachable, i, 1)
                return true
            }
            return false
        }
        i = i + 1
    }
    let short = resolver::use_module_short_name(clone(name))
    if eq(clone(short), clone(name)) {
        return false
    }
    let mut changed = false
    let mut j = 0
    while j < count {
        let f = get_unchecked(functions, j)
        if eq(function_identity::MirFunction_name(f), clone(short)) {
            if get_unchecked(reachable, j) == 0 {
                set(reachable, j, 1)
                changed = true
            }
        }
        j = j + 1
    }
    changed
}

fn mir_legacy_mark_roots(functions: Vec<MirFunction>, reachable: Vec<i32>, extra_roots: Vec<String>) -> i32 {
    let mut root_count = 0
    if mir_legacy_mark_reachable_name(functions, reachable, String_from("main")) {
        root_count = root_count + 1
    }
    if mir_legacy_mark_reachable_name(functions, reachable, String_from("_start")) {
        root_count = root_count + 1
    }
    let extra_count = len(extra_roots)
    let mut ei = 0
    while ei < extra_count {
        if mir_legacy_mark_reachable_name(functions, reachable, clone(get_unchecked(extra_roots, ei))) {
            root_count = root_count + 1
        }
        ei = ei + 1
    }
    root_count
}

fn mir_legacy_mark_function_call_targets(
    m: MirModule,
    functions: Vec<MirFunction>,
    reachable: Vec<i32>,
    f: MirFunction
) -> bool {
    let mut changed = false
    let block_count = function_block_queries::MirFunction_block_count(f)
    let mut bi = 0
    while bi < block_count {
        let block = function_block_queries::MirFunction_block_at(f, bi)
        let inst_count = block_inst_access::MirBlock_inst_count(block)
        let mut ii = 0
        while ii < inst_count {
            let inst = block_inst_access::MirBlock_inst_at(block, ii)
            let op = inst_accessors_shape::MirInst_op(inst)
            if op == opcodes::MIR_CALL() {
                if mir_legacy_mark_reachable_name(
                    functions,
                    reachable,
                    inst_accessors_literals::MirInst_str_val(inst)
                ) {
                    changed = true
                }
                let fallback = core_op_call::mir_call_normal_fallback_symbol(m, inst)
                if len(fallback) > 0 && mir_legacy_mark_reachable_name(functions, reachable, fallback) {
                    changed = true
                }
            }
            if op == opcodes::MIR_REF_FUNC() {
                if mir_legacy_mark_reachable_name(
                    functions,
                    reachable,
                    inst_accessors_literals::MirInst_str_val(inst)
                ) {
                    changed = true
                }
            }
            ii = ii + 1
        }
        bi = bi + 1
    }
    changed
}

fn mir_legacy_mark_reachable_calls(m: MirModule, functions: Vec<MirFunction>, reachable: Vec<i32>) -> bool {
    let fn_count = len(functions)
    let mut changed = false
    let mut fi = 0
    while fi < fn_count {
        if get_unchecked(reachable, fi) != 0 {
            let f = get_unchecked(functions, fi)
            if mir_legacy_mark_function_call_targets(m, functions, reachable, f) {
                changed = true
            }
        }
        fi = fi + 1
    }
    changed
}

fn mir_prune_unreachable_legacy_fixpoint(m: MirModule, extra_roots: Vec<String>) -> i32 {
    let fn_count = module_functions::MirModule_function_count(m)
    if fn_count == 0 {
        return 0
    }
    let functions = module_functions::MirModule_functions(m)
    let reachable = Vec_new_i32()
    let mut i = 0
    while i < fn_count {
        push(reachable, 0)
        i = i + 1
    }
    let root_count = mir_legacy_mark_roots(functions, reachable, extra_roots)
    if root_count == 0 {
        return 0
    }
    let mut changed = true
    while changed {
        changed = mir_legacy_mark_reachable_calls(m, functions, reachable)
    }
    reachability_prune::mir_prune_unmarked_functions(m, reachable)
}
