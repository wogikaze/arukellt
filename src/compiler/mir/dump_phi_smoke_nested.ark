use std::host::process
use std::host::stdio
use mir::dominance
use mir::dump_core
use mir::dump_expect
use mir::dump_smoke_nested_phi_fixture
use mir::module_functions
use mir::ssa
use mir::value_types

fn run_phi_insertion_nested_join_smoke() {
    let fx = dump_smoke_nested_phi_fixture::mir_dump_nested_phi_fixture_new(String_from("phi_insert_nested_join_sample"))
    let m = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_module(fx)
    let f = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_function(fx)
    let inner_then_val = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_inner_then_val(fx)
    let inner_else_val = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_inner_else_val(fx)
    let inner_join_val = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_inner_join_val(fx)
    let outer_else_val = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_outer_else_val(fx)
    let outer_join_val = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_outer_join_val(fx)
    let inner_then_bb = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_inner_then_bb(fx)
    let inner_else_bb = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_inner_else_bb(fx)
    let inner_join_bb = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_inner_join_bb(fx)
    let outer_else_bb = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_outer_else_bb(fx)
    let outer_join_bb = dump_smoke_nested_phi_fixture::MirDumpNestedPhiFixture_outer_join_bb(fx)
    dominance::mir_compute_dominance_for_function(f)
    if !ssa::mir_try_insert_simple_join_phi(f, inner_join_bb, inner_join_val) {
        stdio::eprintln(String_from("nested join phi insertion failed at inner join"))
        process::exit(1)
    }
    if !ssa::mir_try_insert_simple_join_phi(f, outer_join_bb, outer_join_val) {
        stdio::eprintln(String_from("nested join phi insertion failed at outer join"))
        process::exit(1)
    }
    ssa::mir_ssa_rename_function(f)
    dump_expect::mir_expect_phi(f, inner_join_bb, inner_join_val, value_types::VT_I32(), 2, inner_then_bb, inner_then_val, inner_else_bb, inner_else_val)
    dump_expect::mir_expect_phi(f, outer_join_bb, outer_join_val, value_types::VT_I32(), 2, inner_join_bb, inner_join_val, outer_else_bb, outer_else_val)
    dump_expect::mir_expect_phi_format(f, inner_join_bb, 0, String_from("phi %inner_join_val.1 = [bb2 -> %inner_then_val.1, bb3 -> %inner_else_val.1] : i32"))
    dump_expect::mir_expect_phi_format(f, outer_join_bb, 0, String_from("phi %outer_join_val.1 = [bb4 -> %inner_join_val.1, bb5 -> %outer_else_val.1] : i32"))
    module_functions::MirModule_push_function(m, f)
    dump_core::dump_mir(m)
    stdio::println(String_from("MIR nested phi insertion self-check OK."))
}
