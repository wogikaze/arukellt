// Arukellt Selfhost - MIR module data record.

use mir::function_core_record

pub struct MirModule {
    functions: Vec<MirFunction>,
    string_constants: Vec<String>,
    mono_pruned_count: i32,
}

fn MirModule_new() -> MirModule {
    MirModule { functions: Vec_new_MirFunction(), string_constants: Vec_new_String(), mono_pruned_count: 0 }
}
