// Arukellt Selfhost - MIR module data record.

use mir::function_core_record

pub struct MirModule {
    functions: Vec<MirFunction>,
    string_constants: Vec<String>,
    mono_pruned_count: i32,
    gc_enum_variant_sigs: Vec<String>,
    gc_enum_variant_names: Vec<String>,
}

fn MirModule_new() -> MirModule {
    MirModule { functions: Vec_new_MirFunction(), string_constants: Vec_new_String(), mono_pruned_count: 0, gc_enum_variant_sigs: Vec_new_String(), gc_enum_variant_names: Vec_new_String() }
}
