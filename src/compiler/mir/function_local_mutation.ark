// Arukellt Selfhost - MIR function local mutation API.

use mir::function_locals_record

fn MirFunction_push_local(f: MirFunction, local: MirLocal) {
    function_locals_record::mir_function_push_local(f, local)
}

fn MirFunction_set_local(f: MirFunction, local_id: i32, local: MirLocal) {
    function_locals_record::mir_function_set_local(f, local_id, local)
}
