// Arukellt Selfhost - MIR public boundary.

use mir::dump_core
use mir::fallback_source
use mir::input
use mir::legacy_decl
use mir::lower
use mir::reachability
use mir::verify

pub fn lower_to_mir(input: MirLowerInput) -> MirModule {
    lower::lower_to_mir(input)
}

pub fn lower_to_mir_no_prune(input: MirLowerInput) -> MirModule {
    lower::lower_to_mir_no_prune(input)
}

pub fn dump_mir(m: MirModule) {
    dump_core::dump_mir(m)
}

pub fn mir_lower_input_new(view: CoreHirMirView, fallback_source: MirLowerFallbackSource, wit_paths: Vec<String>, decl_nodes: Vec<AstNode>, target: String) -> MirLowerInput {
    input::mir_lower_input_new(view, fallback_source, wit_paths, decl_nodes, target)
}

pub fn mir_fallback_source_from_decls(decls: Vec<MirLowerLegacyDecl>) -> MirLowerFallbackSource {
    fallback_source::mir_fallback_source_from_decls(decls)
}

pub fn mir_legacy_decl_from_node(node: AstNode) -> MirLowerLegacyDecl {
    legacy_decl::mir_legacy_decl_from_node(node)
}

pub fn mir_prune_unreachable_for_t3(m: MirModule, export_names: Vec<String>) -> i32 {
    reachability::mir_prune_unreachable_for_t3(m, export_names)
}

pub fn verify_mir_warn_only(m: MirModule) -> MirVerifyReport {
    verify::verify_mir_warn_only(m)
}
