use resolver::kinds
// Arukellt Resolver - pattern AST predicates.

use resolver::ast_access

fn node_is_pat_ident(node: AstNode) -> bool {
    ast_access::node_kind_is(node, kinds::NK_PAT_IDENT())
}

fn node_is_pat_variant(node: AstNode) -> bool {
    ast_access::node_kind_is(node, kinds::NK_PAT_VARIANT())
}
