// Arukellt Resolver - extended string and constructor builtin names.
// String functions are now auto-imported from std/prelude.ark.
// Variant constructors (Some, None, Ok, Err) remain as builtins since
// they are enum variant constructors, not regular functions.

fn push_core_string_tail_builtin_symbol_names(names: Vec<String>) {
    push(names, String_from("Some"))
    push(names, String_from("None"))
    push(names, String_from("Ok"))
    push(names, String_from("Err"))
}
