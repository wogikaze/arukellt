// Arukellt Resolver - path expression resolution.

use resolver::scope_lookup
use resolver::ast_access
use resolver::ref_sites
use resolver::scope_error
use resolver::kinds
use resolver::paths
use resolver::host_stub_gate
use resolver::ctx_record

fn resolve_path(ctx: ResolveCtx, node: AstNode) {
    let path = ast_access::node_text(node)
    host_stub_gate::reject_host_stub_call(ctx, clone(path))
    let module_part = paths::path_module_part(clone(path))
    let symbol_part = paths::path_symbol_part(clone(path))
    // When the parser rewrites associated function syntax (Vec::new<i32> →
    // Vec_new_i32, String::from → String_from, i32::from → parse_i32), the
    // NK_PATH node text no longer contains "::". Treat it as a simple ident
    // lookup — the prelude function is already in the scope.
    if eq(clone(module_part), clone(path)) {
        let idx = scope_lookup::lookup(ctx, clone(path))
        if idx < 0 {
            let alias_target = ctx_record::resolve_ctx_lookup_use_alias(ctx, clone(path))
            if len(clone(alias_target)) > 0 {
                ast_access::set_node_text(node, clone(alias_target))
                resolve_qualified_path(ctx, node, clone(alias_target))
                return
            }
        }
        ref_sites::record_use(ctx, idx, ast_access::node_span_start(node), ast_access::node_span_end(node))
        return
    }
    resolve_qualified_path(ctx, node, clone(path))
}

fn resolve_qualified_path(ctx: ResolveCtx, node: AstNode, path: String) {
    let module_part = paths::path_module_part(clone(path))
    let symbol_part = paths::path_symbol_part(clone(path))
    // Associated function syntax on builtin types (Vec::new, String::from,
    // i32::from, ...) — the type is not a module, so skip module lookup.
    if is_builtin_type_name(clone(module_part)) {
        return
    }
    let mod_idx = scope_lookup::lookup(ctx, clone(module_part))
    if mod_idx < 0 {
        scope_error::resolve_error(ctx, concat(String_from("undefined module: "), clone(module_part)))
        return
    }
    let sym_idx = scope_lookup::lookup(ctx, clone(path))
    if sym_idx >= 0 {
        let mod_kind = scope_lookup::lookup_kind(ctx, clone(module_part))
        if mod_kind != commands::SYM_ENUM() {
            if !scope_lookup::lookup_is_pub(ctx, clone(path)) {
                scope_error::resolve_error(
                    ctx,
                    concat(
                        String_from("visibility error: `"),
                        concat(clone(symbol_part), concat(String_from("` is private and cannot be accessed from module `"), concat(clone(module_part), String_from("`"))))
                    )
                )
            }
        }
    }
}

// Builtin type names that support associated function syntax (Type::method).
// These are not modules, so a path like `Vec::new` must bypass module lookup.
fn is_builtin_type_name(name: String) -> bool {
    if eq(clone(name), String_from("Vec")) { return true }
    if eq(clone(name), String_from("String")) { return true }
    if eq(clone(name), String_from("i32")) { return true }
    if eq(clone(name), String_from("i64")) { return true }
    if eq(clone(name), String_from("f64")) { return true }
    if eq(clone(name), String_from("f32")) { return true }
    if eq(clone(name), String_from("bool")) { return true }
    if eq(clone(name), String_from("char")) { return true }
    false
}
