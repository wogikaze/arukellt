// WIT import document loading and lookup (#653, #664).

use component::wit_parse_import
use component::wit_parse_text
use resolver::wit_type_map

fn wit_load_interfaces(paths: Vec<String>) -> Vec<wit_parse_text::WitParsedInterface> {
    let docs = Vec_new_WitParsedInterface()
    for i in 0..len(paths) {
        let doc = wit_parse_import::parse_wit_import_file(get_unchecked(paths, i))
        if len(doc.package) > 0 && len(doc.interface) > 0 {
            push(docs, doc)
        }
    }
    docs
}

fn wit_lookup_import(paths: Vec<String>, package_id: String) -> wit_parse_text::WitParsedInterface {
    return wit_find_interface(wit_load_interfaces(paths), clone(package_id))
}

fn wit_find_interface(docs: Vec<wit_parse_text::WitParsedInterface>, package_id: String) -> wit_parse_text::WitParsedInterface {
    for i in 0..len(docs) {
        let doc = get_unchecked(docs, i)
        if wit_parse_import::wit_import_id_matches(clone(package_id), doc) {
            return doc
        }
    }
    wit_parse_text::WitParsedInterface_empty()
}

fn wit_interface_id(doc: wit_parse_text::WitParsedInterface) -> String {
    wit_interface_id_parts(clone(doc.package), clone(doc.interface))
}

fn wit_interface_id_parts(package: String, interface: String) -> String {
    concat(clone(package), concat(String_from("/"), clone(interface)))
}

fn wit_record_wit_names(doc: wit_parse_text::WitParsedInterface) -> Vec<String> {
    wit_type_map::wit_record_wit_names(doc)
}

fn wit_record_ark_names(doc: wit_parse_text::WitParsedInterface) -> Vec<String> {
    wit_type_map::wit_record_ark_names(doc)
}

fn wit_enum_wit_names(doc: wit_parse_text::WitParsedInterface) -> Vec<String> {
    wit_type_map::wit_enum_wit_names(doc)
}

fn wit_enum_ark_names(doc: wit_parse_text::WitParsedInterface) -> Vec<String> {
    wit_type_map::wit_enum_ark_names(doc)
}

fn wit_func_param_ark_types(func: wit_parse_text::WitParsedFunc, alias: String, doc: wit_parse_text::WitParsedInterface) -> Vec<String> {
    let out = Vec_new_String()
    for pi in 0..len(func.param_wit_types) {
        push(out, wit_type_map::wit_type_to_ark(get_unchecked(func.param_wit_types, pi), clone(alias), doc))
    }
    out
}

fn wit_func_ret_ark_type(func: wit_parse_text::WitParsedFunc, alias: String, doc: wit_parse_text::WitParsedInterface) -> String {
    wit_type_map::wit_type_to_ark(func.ret_wit_type, clone(alias), doc)
}

fn wit_binding_key(interface_id: String, wit_func_name: String) -> String {
    concat(clone(interface_id), concat(String_from("\x1f"), clone(wit_func_name)))
}
