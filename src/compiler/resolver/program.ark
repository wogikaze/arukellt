// Arukellt Resolver - module-level resolution pass

use resolver::bindings
use resolver::ast_decl_predicates
use resolver::context
use resolver::program_impl
use resolver::register

fn resolve_program(decls: Vec<AstNode>, modules: Vec<ModuleDecls>) -> ResolveCtx {
    let ctx = context::ResolveCtx_new()
    register::register_imported_modules(ctx, modules)
    let count = len(decls)
    register::register_decl_headers(ctx, decls)
    let mut j = 0
    while j < count {
        let d = get_unchecked(decls, j)
        if ast_decl_predicates::node_is_fn_decl(d) {
            bindings::resolve_fn(ctx, d)
        } else {
            if ast_decl_predicates::node_is_enum_decl(d) {
                bindings::resolve_enum(ctx, d)
            } else {
                if ast_decl_predicates::node_is_impl_decl(d) {
                    program_impl::resolve_impl(ctx, d)
                }
            }
        }
        j = j + 1
    }
    ctx
}
