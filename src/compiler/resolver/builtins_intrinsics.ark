fn push_intrinsic_builtin_symbol_names(names: Vec<String>) {
    push_intrinsic_vec_collections(names)
    push_intrinsic_string_text(names)
    push_intrinsic_numeric_math(names)
    push_intrinsic_io_env_process(names)
    push_intrinsic_prelude_wrappers(names)
}
