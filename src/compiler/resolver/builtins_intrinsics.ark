// Arukellt Resolver - __intrinsic_* builtin symbol names.
// All __intrinsic_* names used across std/ and src/compiler/ are registered
// here so the resolver can resolve them without prelude auto-import.
// Names already registered in builtins_convert.ark or builtins_hash.ark
// are NOT duplicated here:
//   __intrinsic_println, __intrinsic_stdin_read_to_string,
//   __intrinsic_i32_to_string, __intrinsic_f64_to_string (builtins_convert)
//   __intrinsic_i31_box (builtins_hash)

fn push_intrinsic_vec_collections(names: Vec<String>) {
    push(names, String_from("__intrinsic_Vec_new_String"))
    push(names, String_from("__intrinsic_Vec_new_f64"))
    push(names, String_from("__intrinsic_Vec_new_f64_with_cap"))
    push(names, String_from("__intrinsic_Vec_new_i32"))
    push(names, String_from("__intrinsic_Vec_new_i32_with_cap"))
    push(names, String_from("__intrinsic_Vec_new_i64"))
    push(names, String_from("__intrinsic_Vec_new_i64_with_cap"))
    push(names, String_from("__intrinsic_any_i32"))
    push(names, String_from("__intrinsic_contains"))
    push(names, String_from("__intrinsic_filter_String"))
    push(names, String_from("__intrinsic_filter_f64"))
    push(names, String_from("__intrinsic_filter_i32"))
    push(names, String_from("__intrinsic_filter_i64"))
    push(names, String_from("__intrinsic_find_i32"))
    push(names, String_from("__intrinsic_fold_i32_i32"))
    push(names, String_from("__intrinsic_fold_i64_i64"))
    push(names, String_from("__intrinsic_join"))
    push(names, String_from("__intrinsic_map_String_String"))
    push(names, String_from("__intrinsic_map_f64_f64"))
    push(names, String_from("__intrinsic_map_i32_i32"))
    push(names, String_from("__intrinsic_map_i64_i64"))
    push(names, String_from("__intrinsic_map_option_i32_i32"))
    push(names, String_from("__intrinsic_slice"))
    push(names, String_from("__intrinsic_sort_String"))
    push(names, String_from("__intrinsic_sort_f64"))
    push(names, String_from("__intrinsic_sort_i64"))
    push(names, String_from("__intrinsic_split"))
}

