// Arukellt Resolver - core prelude builtin symbol names.

fn push_core_prelude_builtin_symbol_names(names: Vec<String>) {
    push(names, String_from("println"))
    push(names, String_from("print"))
    push(names, String_from("to_string"))
    push(names, String_from("len"))
    push(names, String_from("push"))
    push(names, String_from("get"))
    push(names, String_from("get_unchecked"))
    push(names, String_from("concat"))
    push(names, String_from("substring"))
    push(names, String_from("clone"))
    push(names, String_from("eq"))
    push(names, String_from("char_at"))
    push(names, String_from("String_from"))
    push(names, String_from("String_new"))
    push(names, String_from("Vec_new_i32"))
    push(names, String_from("Vec_new_String"))
    push(names, String_from("parse_f64"))
    push(names, String_from("parse_i32"))
    push(names, String_from("i32_to_string"))
    push(names, String_from("i64_to_string"))
    push(names, String_from("f64_to_string"))
    push(names, String_from("bool_to_string"))
    push(names, String_from("char_to_string"))
    push(names, String_from("push_char"))
    push(names, String_from("starts_with"))
}
