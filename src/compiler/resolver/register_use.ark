// Arukellt Resolver - use declaration registration

use resolver::scope_lookup
use resolver::ast_decl_predicates
use resolver::ast_access
use resolver::scope_define
use resolver::kinds
use resolver::paths
use resolver::target_gate
use resolver::ctx_record

fn register_use_decl(ctx: ResolveCtx, d: AstNode) {
    let use_path = ast_access::node_text(d)
    target_gate::reject_target_gated_use(ctx, clone(use_path))
    let existing_use = scope_lookup::lookup(ctx, clone(use_path))
    if existing_use < 0 {
        scope_define::define(ctx, use_path, commands::SYM_IMPORT())
    }
    register_use_module_alias(ctx, d)
    register_use_children(ctx, d)
    register_use_decl_func_alias(ctx, d)
}

fn register_use_decl_func_alias(ctx: ResolveCtx, d: AstNode) {
    let use_path = ast_access::node_text(d)
    if ast_access::node_child_count(d) == 0 {
        return
    }
    let child_short = paths::use_module_short_name(clone(use_path))
    register_use_func_alias(ctx, clone(use_path), clone(child_short))
}

fn register_use_module_alias(ctx: ResolveCtx, d: AstNode) {
    let short_name = if ast_access::node_type_ann_count(d) > 0 {
        let alias_node = ast_access::node_type_ann_at(d, 0)
        ast_access::node_text(alias_node)
    } else {
        paths::use_module_short_name(ast_access::node_text(d))
    }
    let existing_mod = scope_lookup::lookup(ctx, clone(short_name))
    if existing_mod < 0 {
        scope_define::define(ctx, clone(short_name), commands::SYM_MODULE())
    }
}

fn register_use_children(ctx: ResolveCtx, d: AstNode) {
    let num_children = ast_access::node_child_count(d)
    let mut ci = 0
    while ci < num_children {
        let child = ast_access::node_child_at(d, ci)
        if ast_decl_predicates::node_is_use(child) {
            let child_path = ast_access::node_text(child)
            target_gate::reject_target_gated_use(ctx, clone(child_path))
            let existing_child = scope_lookup::lookup(ctx, clone(child_path))
            if existing_child < 0 {
                scope_define::define(ctx, clone(child_path), commands::SYM_IMPORT())
            }
            let child_short = paths::use_module_short_name(child_path)
            let existing_child_mod = scope_lookup::lookup(ctx, clone(child_short))
            if existing_child_mod < 0 {
                scope_define::define(ctx, clone(child_short), commands::SYM_MODULE())
            }
            register_use_func_alias(ctx, clone(child_path), clone(child_short))
        }
        ci = ci + 1
    }
}

fn register_use_func_alias(ctx: ResolveCtx, child_path: String, child_short: String) {
    let parent_path = paths::use_module_parent_path(clone(child_path))
    if len(clone(parent_path)) == 0 {
        return
    }
    let parent_short = paths::use_module_short_name(clone(parent_path))
    if len(clone(parent_short)) == 0 {
        return
    }
    let alias_target = concat(clone(parent_short), concat(String_from("::"), clone(child_short)))
    ctx_record::resolve_ctx_add_use_alias(ctx, child_short, alias_target)
}
