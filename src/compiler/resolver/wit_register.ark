// WIT import registration helpers (#663, #664).

use component::wit_parse_text
use resolver::register_exports
use resolver::scope_define
use resolver::scope_lookup
use resolver::wit_surface
use resolver::wit_type_map

fn wit_ensure_module_alias(ctx: ResolveCtx, alias: String) {
    let existing = scope_lookup::lookup(ctx, clone(alias))
    if existing < 0 {
        scope_define::define_pub(ctx, clone(alias), commands::SYM_MODULE())
        return
    }
    if scope_lookup::lookup_kind(ctx, clone(alias)) != commands::SYM_MODULE() {
        scope_define::define_pub(ctx, clone(alias), commands::SYM_MODULE())
    }
}

fn wit_doc_has_surface(doc: wit_parse_text::WitParsedInterface) -> bool {
    len(doc.package) > 0 && len(doc.interface) > 0
}

fn wit_doc_from_import(wit_paths: Vec<String>, package_id: String) -> wit_parse_text::WitParsedInterface {
    wit_surface::wit_lookup_import(wit_paths, clone(package_id))
}

fn register_wit_doc(ctx: ResolveCtx, alias: String, doc: wit_parse_text::WitParsedInterface) {
    if !wit_doc_has_surface(doc) {
        return
    }
    wit_ensure_module_alias(ctx, clone(alias))
    let records = wit_parse_text::WitParsedInterface_records(doc)
    for ri in 0..len(records) {
        let rec = get_unchecked(records, ri)
        register_exports::register_module_export(ctx, clone(alias), clone(rec.ark_name), commands::SYM_STRUCT(), true)
    }
    let enums = wit_parse_text::WitParsedInterface_enums(doc)
    for ei in 0..len(enums) {
        let en = get_unchecked(enums, ei)
        register_exports::register_module_export(ctx, clone(alias), clone(en.ark_name), commands::SYM_ENUM(), true)
        for vi in 0..len(en.variant_ark_names) {
            let variant = get_unchecked(en.variant_ark_names, vi)
            let qual_variant = concat(clone(en.ark_name), concat(String_from("::"), clone(variant)))
            register_exports::register_module_export(ctx, clone(alias), qual_variant, commands::SYM_VARIANT(), true)
        }
    }
    let funcs = wit_parse_text::WitParsedInterface_funcs(doc)
    for fi in 0..len(funcs) {
        let func = get_unchecked(funcs, fi)
        register_exports::register_module_export(ctx, clone(alias), clone(func.ark_name), commands::SYM_FN(), true)
    }
}

fn wit_binding_type_sig(func: wit_parse_text::WitParsedFunc, doc: wit_parse_text::WitParsedInterface) -> String {
    wit_type_map::wit_func_type_sig(func.param_wit_types, func.ret_wit_type, doc)
}

fn wit_binding_qualified_name(alias: String, func: wit_parse_text::WitParsedFunc) -> String {
    concat(clone(alias), concat(String_from("::"), clone(func.ark_name)))
}
