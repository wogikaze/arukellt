// Arukellt Resolver - conversion builtin symbol names.
// All conversion functions are now auto-imported from std/prelude.ark
// or registered in builtins_intrinsics.ark.
// Only __intrinsic_stdin_read_to_string remains (no prelude wrapper yet).

fn push_convert_builtin_symbol_names(names: Vec<String>) {
    push(names, String_from("__intrinsic_stdin_read_to_string"))
}
