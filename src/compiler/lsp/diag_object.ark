use analysis::diagnostic_record
// Arukellt Selfhost - LSP diagnostic JSON object builder.

use analysis
use lsp::diag_position
use std::json::parser

fn phase_code(phase: i32) -> String {
	if phase == analysis::PHASE_LEX() {
		return String_from("ark.lex")
	}
	if phase == analysis::PHASE_PARSE() {
		return String_from("ark.parse")
	}
	if phase == analysis::PHASE_RESOLVE() {
		return String_from("ark.resolve")
	}
	if phase == analysis::PHASE_TYPECHECK() {
		return String_from("ark.typecheck")
	}
	if phase == analysis::PHASE_LINT() {
		return String_from("arukellt-lint")
	}
	String_from("ark.unknown")
}

fn build_diagnostic_object(text: String, diag: AnalysisDiagnostic) -> String {
	let s = diag_position::offset_to_diag_position(clone(text), diagnostic_record::analysis_diagnostic_start(diag))
	let e = diag_position::offset_to_diag_position(clone(text), diagnostic_record::analysis_diagnostic_end(diag))
	let start_obj = parser::json_obj_new()
	push(start_obj, parser::json_field(String_from("line"), parser::json_i32(diag_position::lsp_diag_position_line(s))))
	push(start_obj, parser::json_field(String_from("character"), parser::json_i32(diag_position::lsp_diag_position_character(s))))
	let end_obj = parser::json_obj_new()
	push(end_obj, parser::json_field(String_from("line"), parser::json_i32(diag_position::lsp_diag_position_line(e))))
	push(end_obj, parser::json_field(String_from("character"), parser::json_i32(diag_position::lsp_diag_position_character(e))))
	let range_obj = parser::json_obj_new()
	push(range_obj, parser::json_field(String_from("start"), JsonValue::Object(start_obj)))
	push(range_obj, parser::json_field(String_from("end"), JsonValue::Object(end_obj)))
	let sev = if diagnostic_record::analysis_diagnostic_phase(diag) == analysis::PHASE_LINT() { 2 } else { 1 }
	let fields = parser::json_obj_new()
	push(fields, parser::json_field(String_from("range"), JsonValue::Object(range_obj)))
	push(fields, parser::json_field(String_from("severity"), parser::json_i32(sev)))
	push(fields, parser::json_field(String_from("source"), parser::json_str(String_from("arukellt"))))
	push(fields, parser::json_field(String_from("code"), parser::json_str(phase_code(diagnostic_record::analysis_diagnostic_phase(diag)))))
	push(fields, parser::json_field(String_from("message"), parser::json_str(diagnostic_record::analysis_diagnostic_message(diag))))
	parser::json_obj_string(fields)
}
