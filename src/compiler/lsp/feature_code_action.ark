// Arukellt LSP - code action request handling.

use analysis::ident_span
use analysis::symbols
use lsp::feature_request
use lsp::framing
use lsp::import_graph
use lsp::organize_imports
use lsp::positions
use lsp::responses
use lsp::state_record
use lsp::symbol_index_lookup
use lsp::symbol_index_record
use std::json::parser


fn build_import_action(title: String, uri: String, import_path: String, text: String) -> String {
    let offset = import_graph::first_use_insert_offset(clone(text))
    let pos = positions::offset_to_position(clone(text), offset)
    let start_obj = parser::json_obj_new()
    push(start_obj, parser::json_field(String_from("line"), parser::json_i32(positions::lsp_position_line(pos))))
    push(start_obj, parser::json_field(String_from("character"), parser::json_i32(positions::lsp_position_character(pos))))
    let end_obj = parser::json_obj_new()
    push(end_obj, parser::json_field(String_from("line"), parser::json_i32(positions::lsp_position_line(pos))))
    push(end_obj, parser::json_field(String_from("character"), parser::json_i32(positions::lsp_position_character(pos))))
    let range_obj = parser::json_obj_new()
    push(range_obj, parser::json_field(String_from("start"), JsonValue::Object(start_obj)))
    push(range_obj, parser::json_field(String_from("end"), JsonValue::Object(end_obj)))
    let edit_item = parser::json_obj_new()
    push(edit_item, parser::json_field(String_from("range"), JsonValue::Object(range_obj)))
    push(edit_item, parser::json_field(String_from("newText"), parser::json_str(import_graph::build_use_statement(import_path))))
    let edits_arr = parser::json_arr_new()
    push(edits_arr, JsonValue::Object(edit_item))
    let changes_obj = parser::json_obj_new()
    push(changes_obj, parser::json_field(uri, JsonValue::Array(edits_arr)))
    let edit_obj = parser::json_obj_new()
    push(edit_obj, parser::json_field(String_from("changes"), JsonValue::Object(changes_obj)))
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("title"), parser::json_str(title)))
    push(fields, parser::json_field(String_from("kind"), parser::json_str(String_from("quickfix"))))
    push(fields, parser::json_field(String_from("edit"), JsonValue::Object(edit_obj)))
    parser::json_obj_string(fields)
}

fn build_import_actions_json(state: LspState, uri: String, text: String, name: String) -> String {
    let stdlib = state_record::lsp_state_symbol_stdlib_symbols(state)
    let sn = len(stdlib)
    let mut j = 0
    let items = parser::json_arr_new()
    while j < sn {
        let sym = get_unchecked(stdlib, j)
        if eq(symbol_index_record::stdlib_indexed_symbol_name(sym), clone(name)) {
            let module_path = symbol_index_record::stdlib_indexed_symbol_module_path(sym)
            if len(module_path) > 0 {
                let import_path = import_graph::stdlib_import_path(clone(module_path), clone(name))
                if !import_graph::is_path_imported(clone(text), clone(import_path)) {
                    let title = concat(concat(String_from("Import '"), clone(import_path)), String_from("'"))
                    push(items, parser::json_raw(build_import_action(title, uri, import_path, clone(text))))
                }
            }
        }
        j = j + 1
    }
    parser::json_arr_string(items)
}

pub fn handle_code_action(state: LspState, body: String) {
    let req = feature_request::read_text_position_request(state, clone(body))
    let req_id = feature_request::text_position_request_id(req)
    if !feature_request::text_position_request_has_text(req) {
        framing::append_framed(state, responses::build_empty_array_response(req_id))
        return
    }
    let req_text = feature_request::text_position_request_text(req)
    let req_uri = feature_request::text_position_request_uri(req)
    if organize_imports::request_wants_fix_all(clone(body)) {
        let fix_all = organize_imports::build_fix_all_action(clone(req_uri), clone(req_text))
        let result_items = parser::json_arr_new()
        if len(fix_all) > 0 {
            push(result_items, parser::json_raw(fix_all))
        }
        let fields = parser::json_obj_new()
        push(fields, parser::json_field(String_from("jsonrpc"), parser::json_str(String_from("2.0"))))
        push(fields, parser::json_field(String_from("id"), parser::json_i32(req_id)))
        push(fields, parser::json_field(String_from("result"), JsonValue::Array(result_items)))
        framing::append_framed(state, parser::json_obj_string(fields))
        return
    }
    if organize_imports::request_wants_organize_imports(clone(body)) {
        let organize = organize_imports::build_organize_imports_action(clone(req_uri), clone(req_text))
        let result_items = parser::json_arr_new()
        if len(organize) > 0 {
            push(result_items, parser::json_raw(organize))
        }
        let fields = parser::json_obj_new()
        push(fields, parser::json_field(String_from("jsonrpc"), parser::json_str(String_from("2.0"))))
        push(fields, parser::json_field(String_from("id"), parser::json_i32(req_id)))
        push(fields, parser::json_field(String_from("result"), JsonValue::Array(result_items)))
        framing::append_framed(state, parser::json_obj_string(fields))
        return
    }
    let offset = feature_request::text_position_request_offset(req)
    let span = symbols::ident_span_at_offset(clone(req_text), offset)
    if !ident_span::ident_span_found(span) {
        framing::append_framed(state, responses::build_empty_array_response(req_id))
        return
    }
    let name = ident_span::ident_span_name(span)
    let def = symbol_index_lookup::lookup_definition(state, clone(name))
    if symbol_index_lookup::index_definition_found(def) {
        framing::append_framed(state, responses::build_empty_array_response(req_id))
        return
    }
    let actions = build_import_actions_json(state, clone(req_uri), clone(req_text), clone(name))
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("jsonrpc"), parser::json_str(String_from("2.0"))))
    push(fields, parser::json_field(String_from("id"), parser::json_i32(req_id)))
    push(fields, parser::json_field(String_from("result"), parser::json_raw(actions)))
    framing::append_framed(state, parser::json_obj_string(fields))
}
