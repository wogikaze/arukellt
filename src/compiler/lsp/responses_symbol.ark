// Arukellt LSP - workspace/symbol response builders.

use lsp::positions
use lsp::symbol_index_record
use std::json::parser

fn symbol_location_json(uri: String, text: String, decl_start: i32, decl_end: i32) -> String {
    let start = positions::offset_to_position(clone(text), decl_start)
    let end = positions::offset_to_position(clone(text), decl_end)
    let start_obj = parser::json_obj_new()
    push(start_obj, parser::json_field(String_from("line"), parser::json_i32(positions::lsp_position_line(start))))
    push(start_obj, parser::json_field(String_from("character"), parser::json_i32(positions::lsp_position_character(start))))
    let end_obj = parser::json_obj_new()
    push(end_obj, parser::json_field(String_from("line"), parser::json_i32(positions::lsp_position_line(end))))
    push(end_obj, parser::json_field(String_from("character"), parser::json_i32(positions::lsp_position_character(end))))
    let range_obj = parser::json_obj_new()
    push(range_obj, parser::json_field(String_from("start"), JsonValue::Object(start_obj)))
    push(range_obj, parser::json_field(String_from("end"), JsonValue::Object(end_obj)))
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("uri"), parser::json_str(uri)))
    push(fields, parser::json_field(String_from("range"), JsonValue::Object(range_obj)))
    parser::json_obj_string(fields)
}

fn symbol_information_json(sym: symbol_index_record::IndexedSymbol, text: String) -> String {
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("name"), parser::json_str(symbol_index_record::indexed_symbol_name(sym))))
    push(fields, parser::json_field(String_from("kind"), parser::json_i32(symbol_index_record::indexed_symbol_kind(sym))))
    let loc = if len(text) > 0 && symbol_index_record::indexed_symbol_decl_end(sym) > symbol_index_record::indexed_symbol_decl_start(sym) {
        symbol_location_json(symbol_index_record::indexed_symbol_uri(sym), text, symbol_index_record::indexed_symbol_decl_start(sym), symbol_index_record::indexed_symbol_decl_end(sym))
    } else {
        symbol_location_json(symbol_index_record::indexed_symbol_uri(sym), String_new(), 0, 0)
    }
    push(fields, parser::json_field(String_from("location"), parser::json_raw(loc)))
    let module_path = symbol_index_record::indexed_symbol_module_path(sym)
    if len(module_path) > 0 {
        push(fields, parser::json_field(String_from("containerName"), parser::json_str(module_path)))
    }
    parser::json_obj_string(fields)
}

pub fn build_workspace_symbol_response(id: i32, symbols: Vec<symbol_index_record::IndexedSymbol>, source_texts: Vec<String>) -> String {
    let items = parser::json_arr_new()
    let n = len(symbols)
    let mut i = 0
    while i < n {
        let sym = get_unchecked(symbols, i)
        let text = if i < len(source_texts) {
            get_unchecked(source_texts, i)
        } else {
            String_new()
        }
        push(items, parser::json_raw(symbol_information_json(sym, text)))
        i = i + 1
    }
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("jsonrpc"), parser::json_str(String_from("2.0"))))
    push(fields, parser::json_field(String_from("id"), parser::json_i32(id)))
    push(fields, parser::json_field(String_from("result"), JsonValue::Array(items)))
    parser::json_obj_string(fields)
}
