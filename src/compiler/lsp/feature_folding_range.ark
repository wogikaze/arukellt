// Arukellt LSP - folding range request handling (#219).

use lsp::feature_request
use lsp::framing
use lsp::json_fields
use lsp::responses
use lsp::source_text
use lsp::state_docs
use lsp::state_record
use std::text

fn line_has_open_brace(text: String, line: i32) -> bool {
    let mut i = 0
    let mut cur = 0
    while i < len(text) {
        if char_at(text, i) == 10 {
            if cur == line {
                return false
            }
            cur = cur + 1
            i = i + 1
            continue
        }
        if cur == line && char_at(text, i) == 123 {
            return true
        }
        i = i + 1
    }
    false
}

fn find_brace_end_line(text: String, start_line: i32) -> i32 {
    let mut depth = 0
    let mut i = 0
    let mut cur = 0
    while i < len(text) {
        let ch = char_at(text, i)
        if ch == 10 {
            if cur > start_line && depth <= 0 {
                return cur - 1
            }
            cur = cur + 1
            i = i + 1
            continue
        }
        if cur >= start_line {
            if ch == 123 { depth = depth + 1 }
            if ch == 125 {
                depth = depth - 1
                if depth <= 0 && cur > start_line {
                    return cur
                }
            }
        }
        i = i + 1
    }
    start_line
}

fn append_folding_entry(out: String, start_line: i32, end_line: i32) -> String {
    let mut body = out
    if len(body) > 1 {
        body = text::builder_append(body, String_from(","))
    }
    body = text::builder_append(body, String_from("{\"startLine\":"))
    body = text::builder_append(body, to_string(start_line))
    body = text::builder_append(body, String_from(",\"endLine\":"))
    body = text::builder_append(body, to_string(end_line))
    body = text::builder_append(body, String_from(",\"kind\":\"region\"}"))
    body
}

pub fn handle_folding_range(state: LspState, body: String) {
    let id = json_fields::extract_int_field(clone(body), String_from("id"))
    let uri = json_fields::extract_string_field(clone(body), String_from("uri"))
    let mut text = state_docs::lsp_doc_store_lookup_text(state_record::lsp_state_doc_store(state), clone(uri))
    if len(text) == 0 {
        text = source_text::text_for_uri(state, clone(uri))
    }
    if len(text) == 0 {
        framing::append_framed(state, responses::build_empty_array_response(id))
        return
    }
    let mut line = 0
    let mut items = String_from("[")
    while line < 200 {
        if line_has_open_brace(clone(text), line) {
            let end_line = find_brace_end_line(clone(text), line)
            items = append_folding_entry(items, line, end_line)
        }
        line = line + 1
    }
    items = text::builder_append(items, String_from("]"))
    let mut out = String_from("{\"jsonrpc\":\"2.0\",\"id\":")
    out = text::builder_append(out, to_string(id))
    out = text::builder_append(out, String_from(",\"result\":"))
    out = text::builder_append(out, items)
    out = text::builder_append(out, String_from("}"))
    framing::append_framed(state, out)
}
