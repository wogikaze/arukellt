// Arukellt LSP - folding range request handling (#219).

use lsp::feature_request
use lsp::framing
use lsp::json_fields
use lsp::responses
use lsp::source_text
use lsp::state_docs
use lsp::state_record
use std::json::parser

fn line_has_open_brace(text: String, line: i32) -> bool {
    let mut i = 0
    let mut cur = 0
    while i < len(text) {
        if char_at(text, i) == 10 {
            if cur == line {
                return false
            }
            cur = cur + 1
            i = i + 1
            continue
        }
        if cur == line && char_at(text, i) == 123 {
            return true
        }
        i = i + 1
    }
    false
}

fn find_brace_end_line(text: String, start_line: i32) -> i32 {
    let mut depth = 0
    let mut i = 0
    let mut cur = 0
    while i < len(text) {
        let ch = char_at(text, i)
        if ch == 10 {
            if cur > start_line && depth <= 0 {
                return cur - 1
            }
            cur = cur + 1
            i = i + 1
            continue
        }
        if cur >= start_line {
            if ch == 123 { depth = depth + 1 }
            if ch == 125 {
                depth = depth - 1
                if depth <= 0 && cur > start_line {
                    return cur
                }
            }
        }
        i = i + 1
    }
    start_line
}

fn build_folding_entry(start_line: i32, end_line: i32) -> String {
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("startLine"), parser::json_i32(start_line)))
    push(fields, parser::json_field(String_from("endLine"), parser::json_i32(end_line)))
    push(fields, parser::json_field(String_from("kind"), parser::json_str(String_from("region"))))
    parser::json_obj_string(fields)
}

pub fn handle_folding_range(state: LspState, body: String) {
    let id = json_fields::extract_int_field(clone(body), String_from("id"))
    let uri = json_fields::extract_string_field(clone(body), String_from("uri"))
    let mut text = state_docs::lsp_doc_store_lookup_text(state_record::lsp_state_doc_store(state), clone(uri))
    if len(text) == 0 {
        text = source_text::text_for_uri(state, clone(uri))
    }
    if len(text) == 0 {
        framing::append_framed(state, responses::build_empty_array_response(id))
        return
    }
    let mut line = 0
    let items = parser::json_arr_new()
    while line < 200 {
        if line_has_open_brace(clone(text), line) {
            let end_line = find_brace_end_line(clone(text), line)
            push(items, parser::json_raw(build_folding_entry(line, end_line)))
        }
        line = line + 1
    }
    let fields = parser::json_obj_new()
    push(fields, parser::json_field(String_from("jsonrpc"), parser::json_str(String_from("2.0"))))
    push(fields, parser::json_field(String_from("id"), parser::json_i32(id)))
    push(fields, parser::json_field(String_from("result"), JsonValue::Array(items)))
    framing::append_framed(state, parser::json_obj_string(fields))
}
