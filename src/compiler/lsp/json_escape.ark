// Arukellt Selfhost - LSP JSON string escaping helpers.
//
// Delegates to std::json (issue #704).

use std::json

fn json_escape(s: String) -> String {
    json::json_escape(s)
}

fn quote_string(s: String) -> String {
    concat(String_from("\""), concat(json::json_escape(s), String_from("\"")))
}

fn hex_nibble(n: i32) -> String {
    json::json_hex_nibble(n)
}

fn hex_byte(b: i32) -> String {
    json::json_hex_byte(b)
}
