// Arukellt Selfhost - LSP JSON field extraction helpers

use lsp::json_parse_core
use lsp::json_parse_string
fn extract_string_field(json: String, key: String) -> String {
extract_string_field_after(clone(json), key, 0)
}
fn extract_string_field_after(json: String, key: String, from: i32) -> String {
let p = json_parse_core::find_key_pos(clone(json), key, from)
if p < 0 {
return String_new()
}
let q = json_parse_core::json_skip_ws(clone(json), p)
let n = len(json)
if q >= n || char_at(json, q) != 58 {
return String_new()
}
let r = json_parse_core::json_skip_ws(clone(json), q + 1)
let parsed = json_parse_core::json_parse_string_at(clone(json), r)
if !json_parse_string::json_str_result_ok(parsed) {
return String_new()
}
json_parse_string::json_str_result_value(parsed)
}
fn extract_int_field(json: String, key: String) -> i32 {
let p = json_parse_core::find_key_pos(clone(json), key, 0)
if p < 0 {
return 0
}
let q = json_parse_core::json_skip_ws(clone(json), p)
let n = len(json)
if q >= n || char_at(json, q) != 58 {
return 0
}
json_parse_core::json_parse_int_at(clone(json), q + 1)
}
