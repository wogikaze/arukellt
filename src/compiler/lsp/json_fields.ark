// Arukellt Selfhost - LSP JSON field extraction helpers.
//
// Delegates to std::json (issue #704).

use std::json

fn extract_string_field(json_str: String, key: String) -> String {
    json::json_get_str(json_str, key)
}

fn extract_string_field_after(json_str: String, key: String, from: i32) -> String {
    json::json_get_str_after(json_str, key, from)
}

fn extract_int_field(json_str: String, key: String) -> i32 {
    json::json_get_int(json_str, key)
}
