// Arukellt LSP - document sync method dispatch.

use lsp::documents
use lsp::state_record

fn dispatch_documents(state: LspState, body: String, method: String) -> bool {
    if eq(clone(method), "textDocument/didOpen") {
        documents::handle_did_open(state, clone(body))
        return true
    }
    if eq(clone(method), "textDocument/didChange") {
        documents::handle_did_change(state, clone(body))
        return true
    }
    if eq(clone(method), "textDocument/didClose") {
        documents::handle_did_close(state, clone(body))
        return true
    }
    if eq(clone(method), "textDocument/didSave") {
        documents::handle_did_save(state, clone(body))
        return true
    }
    if eq(clone(method), "workspace/didChangeWatchedFiles") {
        documents::handle_did_change_watched_files(state, clone(body))
        return true
    }
    false
}
