use analysis
use lsp::diagnostics
use lsp::framing
use lsp::init_workspace
use lsp::json_fields
use lsp::json_parse_core
use lsp::lsp_package_definition
use lsp::state_docs
use lsp::state_record
use lsp::symbol_index
use lsp::symbol_index_stdlib
use lsp::symbol_index_update
use lsp::project_resolve_modules

pub fn handle_did_open(state: LspState, body: String) {
    let uri = json_fields::extract_string_field(clone(body), String_from("uri"))
    let text = json_fields::extract_string_field(clone(body), String_from("text"))
    let version = json_fields::extract_int_field(clone(body), String_from("version"))
    state_docs::lsp_doc_store_set(state_record::lsp_state_doc_store(state), clone(uri), clone(text), version)
    symbol_index_stdlib::symbol_index_load_stdlib(state)
    symbol_index_update::symbol_index_update_uri(state, clone(uri), clone(text))
    publish_for(state, clone(uri), clone(text))
}

pub fn handle_did_change(state: LspState, body: String) {
    let uri = json_fields::extract_string_field(clone(body), String_from("uri"))
    let version = json_fields::extract_int_field(clone(body), String_from("version"))
    let cc = json_parse_core::find_key_pos(clone(body), String_from("contentChanges"), 0)
    let text = if cc < 0 {
        json_fields::extract_string_field(clone(body), String_from("text"))
    } else {
        json_fields::extract_string_field_after(clone(body), String_from("text"), cc)
    }
    state_docs::lsp_doc_store_set(state_record::lsp_state_doc_store(state), clone(uri), clone(text), version)
    symbol_index_update::symbol_index_update_uri(state, clone(uri), clone(text))
    publish_for(state, clone(uri), clone(text))
}

pub fn handle_did_close(state: LspState, body: String) {
    let uri = json_fields::extract_string_field(clone(body), String_from("uri"))
    symbol_index::symbol_index_remove_file(state, clone(uri))
}

pub fn handle_did_change_watched_files(state: LspState, body: String) {
    if !lsp_package_definition::watched_files_body_has_ark_toml(clone(body)) {
        return
    }
    init_workspace::rebuild_workspace_package_index_from_manifest_change(state)
}

pub fn handle_did_save(state: LspState, body: String) {
    if !state_record::lsp_state_check_on_save(state) {
        return
    }
    let uri = json_fields::extract_string_field(clone(body), String_from("uri"))
    let text = state_docs::lsp_doc_store_lookup_text(state_record::lsp_state_doc_store(state), clone(uri))
    if len(text) > 0 {
        publish_for(state, clone(uri), clone(text))
    }
}

fn publish_for(state: LspState, uri: String, text: String) {
    let modules = project_resolve_modules::build_resolve_modules_with_prelude(state, clone(uri))
    let snap = analysis::analyze_with_modules(clone(uri), clone(text), modules)
    framing::append_framed(state, diagnostics::build_publish_diagnostics(clone(uri), clone(text), snap))
}
