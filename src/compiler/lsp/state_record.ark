use lsp::state_docs
use lsp::symbol_index_record

pub struct LspState {
    doc_store: LspDocStore,
    symbol_symbols: Vec<symbol_index_record::IndexedSymbol>,
    symbol_stdlib_symbols: Vec<symbol_index_record::StdlibIndexedSymbol>,
    symbol_indexed_uris: Vec<String>,
    project_root: String,
    workspace_roots: Vec<String>,
    hover_detail_level: String,
    enable_code_lens: bool,
    diagnostics_errors_only: bool,
    check_on_save: bool,
    initialized: bool,
    shutdown: bool,
    exited: bool,
    output: String,
}

fn LspState_new() -> LspState {
    LspState {
        doc_store: state_docs::LspDocStore_new(),
        symbol_symbols: Vec_new_IndexedSymbol(),
        symbol_stdlib_symbols: Vec_new_StdlibIndexedSymbol(),
        symbol_indexed_uris: Vec_new_String(),
        project_root: String_new(),
        workspace_roots: Vec_new_String(),
        hover_detail_level: String_new(),
        enable_code_lens: true,
        diagnostics_errors_only: false,
        check_on_save: true,
        initialized: false,
        shutdown: false,
        exited: false,
        output: String_new(),
    }
}

fn lsp_state_doc_store(state: LspState) -> LspDocStore {
    state.doc_store
}

fn lsp_state_symbol_symbols(state: LspState) -> Vec<symbol_index_record::IndexedSymbol> {
    state.symbol_symbols
}

fn lsp_state_symbol_stdlib_symbols(state: LspState) -> Vec<symbol_index_record::StdlibIndexedSymbol> {
    state.symbol_stdlib_symbols
}

fn lsp_state_set_symbol_stdlib_symbols(state: LspState, symbols: Vec<symbol_index_record::StdlibIndexedSymbol>) {
    state.symbol_stdlib_symbols = symbols
}

fn lsp_state_symbol_indexed_uris(state: LspState) -> Vec<String> {
    state.symbol_indexed_uris
}

fn lsp_state_project_root(state: LspState) -> String {
    clone(state.project_root)
}

fn lsp_state_set_project_root(state: LspState, root: String) {
    state.project_root = root
}

fn lsp_state_workspace_roots_len(state: LspState) -> i32 {
    len(state.workspace_roots)
}

fn lsp_state_workspace_root_at(state: LspState, index: i32) -> String {
    clone(get_unchecked(state.workspace_roots, index))
}

fn lsp_state_set_workspace_roots(state: LspState, roots: Vec<String>) {
    state.workspace_roots = roots
}

fn lsp_state_hover_detail_level(state: LspState) -> String {
    clone(state.hover_detail_level)
}

fn lsp_state_set_hover_detail_level(state: LspState, level: String) {
    state.hover_detail_level = level
}

fn lsp_state_enable_code_lens(state: LspState) -> bool {
    state.enable_code_lens
}

fn lsp_state_set_enable_code_lens(state: LspState, enabled: bool) {
    state.enable_code_lens = enabled
}

fn lsp_state_diagnostics_errors_only(state: LspState) -> bool {
    state.diagnostics_errors_only
}

fn lsp_state_set_diagnostics_errors_only(state: LspState, errors_only: bool) {
    state.diagnostics_errors_only = errors_only
}

fn lsp_state_check_on_save(state: LspState) -> bool {
    state.check_on_save
}

fn lsp_state_set_check_on_save(state: LspState, enabled: bool) {
    state.check_on_save = enabled
}

fn lsp_state_mark_initialized(state: LspState) {
    state.initialized = true
}

fn lsp_state_mark_shutdown(state: LspState) {
    state.shutdown = true
}

fn lsp_state_mark_exited(state: LspState) {
    state.exited = true
}

fn lsp_state_has_exited(state: LspState) -> bool {
    state.exited
}

fn lsp_state_append_output(state: LspState, chunk: String) {
    state.output = concat(clone(state.output), chunk)
}

fn lsp_state_output(state: LspState) -> String {
    state.output
}
