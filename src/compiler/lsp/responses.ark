// Arukellt Selfhost - LSP response builders

use lsp::positions
use lsp::responses_lifecycle
use lsp::responses_navigation
use lsp::responses_symbol
use lsp::symbol_index_record
use std::json::parser

pub fn build_initialize_response(id: i32) -> String {
	responses_lifecycle::build_initialize_response(id)
}

pub fn build_shutdown_response(id: i32) -> String {
	responses_lifecycle::build_shutdown_response(id)
}

pub fn build_null_response(id: i32) -> String {
	responses_lifecycle::build_null_response(id)
}

pub fn build_empty_array_response(id: i32) -> String {
	let fields = parser::json_obj_new()
	push(fields, parser::json_field(String_from("jsonrpc"), parser::json_str(String_from("2.0"))))
	push(fields, parser::json_field(String_from("id"), parser::json_i32(id)))
	push(fields, parser::json_field(String_from("result"), JsonValue::Array(parser::json_arr_new())))
	parser::json_obj_string(fields)
}

pub fn build_hover_response(id: i32, markdown: String, start: LspPosition, end: LspPosition) -> String {
	responses_navigation::build_hover_response(id, markdown, start, end)
}

pub fn build_definition_response(id: i32, uri: String, start: LspPosition, end: LspPosition) -> String {
	responses_navigation::build_definition_response(id, uri, start, end)
}

pub fn build_workspace_symbol_response(id: i32, symbols: Vec<symbol_index_record::IndexedSymbol>, source_texts: Vec<String>) -> String {
	responses_symbol::build_workspace_symbol_response(id, symbols, source_texts)
}
