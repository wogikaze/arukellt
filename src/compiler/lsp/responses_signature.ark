use std::text
use lsp::responses_json

fn append_param_labels(items: String, params: Vec<String>) -> String {
    let n = len(params)
    let mut i = 0
    let mut out = items
    while i < n {
        if len(out) > 0 {
            out = text::builder_append(out, String_from(","))
        }
        out = text::builder_append(out, String_from("{\"label\":"))
        out = text::builder_append(out, responses_json::quote_string(get_unchecked(params, i)))
        out = text::builder_append(out, String_from("}"))
        i = i + 1
    }
    out
}

fn signature_info_json(label: String, doc: String, params: Vec<String>) -> String {
    let mut out = String_from("{\"label\":")
    out = text::builder_append(out, responses_json::quote_string(label))
    if len(doc) > 0 {
        out = text::builder_append(out, String_from(",\"documentation\":{\"kind\":\"markdown\",\"value\":"))
        out = text::builder_append(out, responses_json::quote_string(doc))
        out = text::builder_append(out, String_from("}"))
    }
    out = text::builder_append(out, String_from(",\"parameters\":["))
    out = text::builder_append(out, append_param_labels(String_new(), params))
    out = text::builder_append(out, String_from("]}"))
    out
}

pub fn build_signature_help_response(id: i32, label: String, doc: String, params: Vec<String>, active_param: i32) -> String {
    let mut body = String_from("{\"jsonrpc\":\"2.0\",\"id\":")
    body = text::builder_append(body, to_string(id))
    body = text::builder_append(body, String_from(",\"result\":{\"signatures\":["))
    body = text::builder_append(body, signature_info_json(label, doc, params))
    body = text::builder_append(body, String_from("],\"activeSignature\":0,\"activeParameter\":"))
    body = text::builder_append(body, to_string(active_param))
    body = text::builder_append(body, String_from("}}"))
    body
}
