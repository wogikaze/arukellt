// Arukellt Selfhost - LSP completion item JSON builders.

use lsp::import_graph
use lsp::json_escape
use lsp::positions
use std::text


pub fn completion_item(label: String, kind: i32, detail: String) -> String {
    let mut out = text::builder_new()
    out = text::builder_append(out, String_from("{\"label\":"))
    out = text::builder_append(out, json_escape::quote_string(label))
    out = text::builder_append(out, String_from(",\"kind\":"))
    out = text::builder_append(out, to_string(kind))
    out = text::builder_append(out, String_from(",\"detail\":"))
    out = text::builder_append(out, json_escape::quote_string(detail))
    out = text::builder_append(out, String_from("}"))
    text::builder_build(out)
}

pub fn completion_item_json(label: String, kind: i32, detail: String, text: String, import_path: String, needs_import: bool) -> String {
    if !needs_import || len(import_path) == 0 {
        return completion_item(label, kind, detail)
    }
    let offset = import_graph::first_use_insert_offset(clone(text))
    let pos = positions::offset_to_position(clone(text), offset)
    let mut out = text::builder_new()
    out = text::builder_append(out, String_from("{\"label\":"))
    out = text::builder_append(out, json_escape::quote_string(label))
    out = text::builder_append(out, String_from(",\"kind\":"))
    out = text::builder_append(out, to_string(kind))
    out = text::builder_append(out, String_from(",\"detail\":"))
    out = text::builder_append(out, json_escape::quote_string(detail))
    out = text::builder_append(out, String_from(",\"additionalTextEdits\":[{\"range\":{\"start\":{\"line\":"))
    out = text::builder_append(out, to_string(positions::lsp_position_line(pos)))
    out = text::builder_append(out, String_from(",\"character\":"))
    out = text::builder_append(out, to_string(positions::lsp_position_character(pos)))
    out = text::builder_append(out, String_from("},\"end\":{\"line\":"))
    out = text::builder_append(out, to_string(positions::lsp_position_line(pos)))
    out = text::builder_append(out, String_from(",\"character\":"))
    out = text::builder_append(out, to_string(positions::lsp_position_character(pos)))
    out = text::builder_append(out, String_from("}},\"newText\":"))
    out = text::builder_append(out, json_escape::quote_string(import_graph::build_use_statement(import_path)))
    out = text::builder_append(out, String_from("}]}"))
    text::builder_build(out)
}

pub fn append_item(items: String, item: String) -> String {
    if len(items) == 0 {
        return item
    }
    concat(concat(items, String_from(",")), item)
}
