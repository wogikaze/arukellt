// Arukellt LSP - language feature method dispatch.

use lsp::dispatch_features_core
use lsp::dispatch_features_structure

fn dispatch_features(state: LspState, body: String, method: String) -> bool {
    if dispatch_features_structure::dispatch_structure_features(state, clone(body), clone(method)) {
        return true
    }
    dispatch_features_core::dispatch_core_features(state, body, method)
}
