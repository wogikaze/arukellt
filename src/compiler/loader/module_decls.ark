use collections::vec_extend
use loader::module_state_modules
use loader::module_state
pub fn combine_loaded_and_main_decls(modules: Vec<ModuleDecls>, main_decls: Vec<AstNode>) -> Vec<AstNode> {
    let all_decls = Vec_new_AstNode()
    let combined_mc = len(modules)
    let mut combined_mi = 0
    while combined_mi < combined_mc {
        let combined_md = get_unchecked(modules, combined_mi)
        let combined_dc = module_state_modules::ModuleDecls_decl_count(combined_md)
        let mut combined_dk = 0
        while combined_dk < combined_dc {
            push(all_decls, module_state_modules::ModuleDecls_decl_at(combined_md, combined_dk))
            combined_dk = combined_dk + 1
        }
        combined_mi = combined_mi + 1
    }
    vec_extend::Vec_extend_AstNode(all_decls, main_decls)
    all_decls
}
