// Arukellt Selfhost - driver module loading phase.

use loader::module_graph
use loader::module_state
use loader::module_state_modules
use driver::config_record

pub fn load_prelude_modules() -> Vec<ModuleDecls> {
    let state = module_state::LoadState_new()
    module_graph::load_stdlib_module(String_from("std::prelude"), state)
    module_state_modules::LoadState_modules(state)
}

fn load_modules_for_source(source: String, decls: Vec<AstNode>, config: DriverConfig) -> LoadState {
    let load_state = module_state::LoadState_new()
    module_state::LoadState_set_cache_dir(load_state, config_record::config_cache_dir(config))
    module_graph::load_stdlib_module(String_from("std::prelude"), load_state)
    module_graph::load_imported_modules(decls, config_record::config_source_dir(config), load_state)
    if contains(clone(source), String_from("HashMap_")) || contains(clone(source), String_from("HashSet_")) {
        module_graph::load_stdlib_module(String_from("std::collections::hash"), load_state)
    }
    if contains(clone(source), String_from("HashMap_String")) || contains(clone(source), String_from("HashMap_new_String")) || contains(clone(source), String_from("HashMap_i32_String")) || contains(clone(source), String_from("HashMap_new_i32_String")) || contains(clone(source), String_from("HashSet_String")) {
        module_graph::load_stdlib_module(String_from("std::collections::hash_string"), load_state)
    }
    load_state
}
