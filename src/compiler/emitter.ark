                                                                                                                                                                                                                                                                                                                                                                    let err_msg = "parse error: invalid integer"
                                                                                                                                                                                                                                                                                                                                                                    let err_len = len(err_msg)
                                                                                                                                                                                                                                                                                                                                                                    let mut ei = 0
                                                                                                                                                                                                                                                                                                                                                                    while ei < err_len {
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, OP_LOCAL_GET())
                                                                                                                                                                                                                                                                                                                                                                        emit_leb128_u(w, s_base)
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                        emit_leb128_s(w, 4 + ei)
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, OP_I32_ADD())
                                                                                                                                                                                                                                                                                                                                                                        let ch = char_at(err_msg, ei)
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, OP_I32_CONST())
                                                                                                                                                                                                                                                                                                                                                                        emit_leb128_s(w, ch)
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, 58)
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                        emit_byte(w, 0)
                                                                                                                                                                                                                                                                                                                                                                        ei = ei + 1
                                                                                                                                                                                                                                                                                                                                                                    }
