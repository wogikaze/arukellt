            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // memory.copy(result_ptr, ptr_a, len_a)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rp)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_a)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_la)
            emit_byte(w, 0xfc)
            emit_leb128_u(w, 10)  // memory.copy
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // memory.copy(result_ptr + len_a, ptr_b, total - len_a)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rp)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_la)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_b)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_la)
            emit_byte(w, OP_I32_SUB())
