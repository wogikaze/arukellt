            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // Check match at scan_pos: compare from_len bytes
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s10)  // matched = true
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s11)  // j = 0
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s11)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)  // j >= from_len: break inner
            // compare src[scan_pos + j] vs from[j]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s11)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s11)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s10)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)  // break inner loop
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s11)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s11)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)  // continue inner
            emit_byte(w, OP_END())  // end inner loop
            emit_byte(w, OP_END())  // end inner block
            // Check if matched
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s10)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // MATCH: copy src[seg_start..scan_pos] to write_pos
            // seg_len = scan_pos - seg_start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)  // dest = write_pos
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_ADD())  // src = src + seg_start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_SUB())  // count = scan_pos - seg_start
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)
            emit_byte(w, 0)
            emit_byte(w, 0)
            // write_pos += seg_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_END())
            // Copy "to" to write_pos
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)
            emit_byte(w, 0)
            emit_byte(w, 0)
            // write_pos += to_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_END())
            // scan_pos += from_len, seg_start = scan_pos
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_ELSE())
            // NO MATCH: scan_pos += 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_END())
            // continue outer loop
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block
            // Copy remaining: src[seg_start..src_len] to write_pos
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)
            emit_byte(w, 0)
            emit_byte(w, 0)
            // write_pos += remaining
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_END())
            // Store actual length = write_pos - (alloc + 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s9)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s9)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // Return alloc + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s9)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())

        } else if eq(clone(callee), "clamp_i32") {
            // clamp_i32(val, min, max) -> i32
            let s0 = ctx.scratch_base + 0  // val
            let s1 = ctx.scratch_base + 1  // min
            let s2 = ctx.scratch_base + 2  // max
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // if val < min: val = min
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_LT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_END())
            // if val > max: val = max
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)

        } else if eq(clone(callee), "process::exit") || eq(clone(callee), "host::process::exit") {
            // process::exit(code) — no-op stub, just drop the argument
            emit_byte(w, OP_DROP())
        } else {
            // User-defined function call
            let fn_idx = resolve_fn_index(ctx, clone(callee))
            if fn_idx >= 0 {
                emit_byte(w, OP_CALL())
                emit_leb128_u(w, fn_idx + NUM_WASI_IMPORTS())  // offset for wasi imports
            } else {
                // Unknown function — emit unreachable
                emit_byte(w, OP_UNREACHABLE())
            }
        }
    } else if inst.op == 42 {  // RETURN
        emit_byte(w, OP_RETURN())
    } else if inst.op == 70 {  // DROP
        emit_byte(w, OP_DROP())
    } else if inst.op == 71 {  // NOP
        emit_byte(w, OP_NOP())
    } else if inst.op == 72 {  // UNREACHABLE
        emit_byte(w, OP_UNREACHABLE())
    } else if inst.op == 50 {  // BR
        emit_byte(w, OP_BR())
        emit_leb128_u(w, inst.int_val)
    } else if inst.op == 51 {  // BR_IF
        emit_byte(w, OP_BR_IF())
        emit_leb128_u(w, inst.int_val)
    } else if inst.op == 53 {  // BLOCK
        emit_byte(w, OP_BLOCK())
        emit_byte(w, 0x40)  // void block type
    } else if inst.op == 54 {  // LOOP
        emit_byte(w, OP_LOOP())
        emit_byte(w, 0x40)  // void block type
    } else if inst.op == 55 {  // IF
        emit_byte(w, OP_IF())
        emit_byte(w, 0x40)  // void block type
    } else if inst.op == 56 {  // ELSE
        emit_byte(w, OP_ELSE())
    } else if inst.op == 57 {  // END (end of block/loop/if)
        emit_byte(w, OP_END())
    } else if inst.op == 28 {  // LTEQ
        emit_byte(w, OP_I32_LE_S())
    } else if inst.op == 30 {  // GTEQ
        emit_byte(w, OP_I32_GE_S())
    } else if inst.op == 31 {  // AND
        emit_byte(w, OP_I32_AND())
    } else if inst.op == 32 {  // OR
        emit_byte(w, OP_I32_OR())
    } else if inst.op == 33 {  // NEG (0 - val)
        if inst.val_type == VT_F64() {
            // f64.neg is a single instruction
            emit_byte(w, OP_F64_NEG())
        } else {
            // Stack has: [val]. Need [0, val] for i32.sub (0 - val)
            let scratch = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, scratch)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, scratch)
            emit_byte(w, OP_I32_SUB())
        }
    } else if inst.op == 34 {  // NOT (i32.eqz) — value on stack
        emit_byte(w, OP_I32_EQZ())
    } else if inst.op == 58 {  // EQZ — value on stack
        emit_byte(w, OP_I32_EQZ())
    } else if inst.op == 60 {  // STRUCT_NEW — heap allocate
        // global.get 0 (heap ptr) → local.set dest → bump by byte_size
        // Step 1: get current heap pointer
        emit_byte(w, OP_GLOBAL_GET())
        emit_leb128_u(w, 0)
        // Step 2: save to dest local
        emit_byte(w, OP_LOCAL_SET())
        emit_leb128_u(w, inst.dest)
        // Step 3: advance heap pointer by byte_size (int_val is already in bytes)
        emit_byte(w, OP_GLOBAL_GET())
        emit_leb128_u(w, 0)
        emit_byte(w, OP_I32_CONST())
        emit_leb128_s(w, inst.int_val)
        emit_byte(w, OP_I32_ADD())
        emit_byte(w, OP_GLOBAL_SET())
        emit_leb128_u(w, 0)
    } else if inst.op == 61 {  // STRUCT_GET — load from base + byte_offset
        // Base pointer is already on the Wasm stack from preceding lower_expr.
        if inst.int_val > 0 {
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, inst.int_val)
            emit_byte(w, OP_I32_ADD())
        }
        if inst.val_type == VT_F64() {
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)  // align = 8
            emit_byte(w, 0x00)  // offset = 0
        } else {
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)  // align = 4
            emit_byte(w, 0x00)  // offset = 0
        }
    } else if inst.op == 62 {  // STRUCT_SET — store to base + byte_offset
        // Value is on the Wasm stack from preceding instruction.
        // Save value to temp, compute address, push value, store
        // The MIR has: STRUCT_SET(arg0=base, arg1=val_local, int_val=byte_offset)
        // The value was put on stack by the preceding CONST or expr.
        // Save it, then compute address, then restore it.

        // Step 1: save value from stack to val local
        if inst.val_type == VT_F64() {
            // For f64 values, use scratch f64 local
            let f64_temp = ctx.scratch_base + 12
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, f64_temp)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.arg0)  // base ptr
            if inst.int_val > 0 {
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, inst.int_val)
                emit_byte(w, OP_I32_ADD())
            }
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f64_temp)
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)  // align = 8
            emit_byte(w, 0x00)  // offset = 0
        } else {
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, inst.arg1)  // save value from stack to val local
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.arg0)  // base ptr
            if inst.int_val > 0 {
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, inst.int_val)
                emit_byte(w, OP_I32_ADD())
            }
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.arg1)  // restore value
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)  // align = 4
            emit_byte(w, 0x00)  // offset = 0
        }
    } else if inst.op == 63 {  // ARRAY_NEW — heap allocate int_val elements
        // Same as STRUCT_NEW: allocate int_val * 4 bytes on heap
        emit_byte(w, OP_GLOBAL_GET())
        emit_leb128_u(w, 0)
        emit_byte(w, OP_LOCAL_SET())
        emit_leb128_u(w, inst.dest)
        emit_byte(w, OP_GLOBAL_GET())
        emit_leb128_u(w, 0)
        emit_byte(w, OP_I32_CONST())
        emit_leb128_s(w, inst.int_val * 4)
        emit_byte(w, OP_I32_ADD())
        emit_byte(w, OP_GLOBAL_SET())
        emit_leb128_u(w, 0)
    } else if inst.op == 64 {  // ARRAY_GET — load from base + index*4
        // Stack has [base, index] from two preceding lower_expr calls
        emit_byte(w, OP_I32_CONST())
        emit_leb128_s(w, 4)
        emit_byte(w, OP_I32_MUL())
        emit_byte(w, OP_I32_ADD())
        emit_byte(w, OP_I32_LOAD())
        emit_byte(w, 0x02)  // align = 4
        emit_byte(w, 0x00)  // offset = 0
    } else if inst.op == 65 {  // ARRAY_SET — store value at base + int_val*4
        // Stack has [value] from preceding lower_expr. arg0=base local, int_val=static index
        emit_byte(w, OP_LOCAL_SET())
        emit_leb128_u(w, inst.arg1)  // save value from stack
        emit_byte(w, OP_LOCAL_GET())
        emit_leb128_u(w, inst.arg0)  // base ptr
        if inst.int_val > 0 {
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, inst.int_val * 4)
            emit_byte(w, OP_I32_ADD())
        }
        emit_byte(w, OP_LOCAL_GET())
        emit_leb128_u(w, inst.arg1)  // restore value
        emit_byte(w, OP_I32_STORE())
        emit_byte(w, 0x02)  // align = 4
        emit_byte(w, 0x00)  // offset = 0
    }
}

fn val_type_to_wasm(vt: i32) -> i32 {
    if vt == 1 { return WASM_I32() }
    if vt == 2 { return WASM_I64() }
    if vt == 3 { return WASM_F64() }
    if vt == 4 { return WASM_I32() }  // ref → i32 placeholder
    WASM_I32()
}

// ── Public API (used by driver) ──────────────────────────────────────────────

struct MirModule {
    functions: Vec<MirFunction>,
    string_constants: Vec<String>,
}

struct MirFunction {
    name: String,
    params: Vec<MirLocal>,
    locals: Vec<MirLocal>,
    blocks: Vec<MirBlock>,
    return_type: i32,
    next_local: i32,
    next_block: i32,
}

struct MirLocal {
    name: String,
    val_type: i32,
}

struct MirBlock {
    id: i32,
    instructions: Vec<MirInst>,
    terminator: i32,
    succ0: i32,
    succ1: i32,
}

struct MirInst {
    op: i32,
    dest: i32,
    arg0: i32,
    arg1: i32,
    int_val: i32,
    float_val: f64,
    str_val: String,
    val_type: i32,
}

pub fn emit_wasm(mir: MirModule, target: String, opt_level: i32) -> Vec<i32> {
    emit_wasm_module(mir, target, opt_level)
}

// ── WAT Text Emitter ─────────────────────────────────────────────────────────

fn wat_indent(depth: i32) -> String {
    let mut s = String_new()
    let mut i = 0
    while i < depth {
        s = concat(s, String_from("  "))
        i = i + 1
    }
    s
}

fn val_type_name(vt: i32) -> String {
    if vt == 1 { return String_from("i32") }
    if vt == 2 { return String_from("i64") }
    if vt == 3 { return String_from("f64") }
    if vt == 4 { return String_from("i32") }
    String_from("i32")
}

fn mir_op_to_wat(inst: MirInst) -> String {
    if inst.op == 1 {
        return concat(String_from("i32.const "), to_string(inst.int_val))
    }
    if inst.op == 2 {
        return concat(String_from("i64.const "), to_string(inst.int_val))
    }
    if inst.op == 10 {
        return concat(String_from("local.get "), to_string(inst.arg0))
    }
    if inst.op == 11 {
        return concat(String_from("local.set "), to_string(inst.dest))
    }
    if inst.op == 20 { return String_from("i32.add") }
    if inst.op == 21 { return String_from("i32.sub") }
    if inst.op == 22 { return String_from("i32.mul") }
    if inst.op == 23 { return String_from("i32.div_s") }
    if inst.op == 24 { return String_from("i32.rem_s") }
    if inst.op == 25 { return String_from("i32.eq") }
    if inst.op == 26 { return String_from("i32.ne") }
    if inst.op == 27 { return String_from("i32.lt_s") }
    if inst.op == 29 { return String_from("i32.gt_s") }
    if inst.op == 40 {
        return concat(String_from("call "), to_string(inst.arg0))
    }
    if inst.op == 42 { return String_from("return") }
    if inst.op == 50 { return concat(String_from("br "), to_string(inst.int_val)) }
    if inst.op == 51 { return concat(String_from("br_if "), to_string(inst.int_val)) }
    if inst.op == 53 { return String_from("block") }
    if inst.op == 54 { return String_from("loop") }
    if inst.op == 55 { return String_from("if") }
    if inst.op == 28 { return String_from("i32.le_s") }
    if inst.op == 30 { return String_from("i32.ge_s") }
    if inst.op == 31 { return String_from("i32.and") }
    if inst.op == 32 { return String_from("i32.or") }
    if inst.op == 33 { return String_from("i32.neg ;; via sub") }
    if inst.op == 34 { return String_from("i32.eqz") }
    if inst.op == 60 { return String_from(";; struct.new") }
    if inst.op == 61 { return String_from(";; struct.get") }
    if inst.op == 62 { return String_from(";; struct.set") }
    if inst.op == 63 { return String_from(";; array.new") }
    if inst.op == 64 { return String_from(";; array.get") }
    if inst.op == 65 { return String_from(";; array.set") }
    if inst.op == 70 { return String_from("drop") }
    if inst.op == 71 { return String_from("nop") }
    if inst.op == 72 { return String_from("unreachable") }
    concat(String_from(";; unknown op "), to_string(inst.op))
}

pub fn emit_wat(mir: MirModule, target: String, opt_level: i32) -> String {
    let mut out = String_from("(module\n")
    let fn_count = len(mir.functions)

    // Import: WASI fd_write
    out = concat(out, String_from("  (import \"wasi_snapshot_preview1\" \"fd_write\" (func (param i32 i32 i32 i32) (result i32)))\n"))

    // Memory
    out = concat(out, String_from("  (memory (export \"memory\") 1)\n"))

    // Functions
    let mut fi = 0
    while fi < fn_count {
        let f = get_unchecked(mir.functions, fi)
        out = concat(out, concat(String_from("  (func $"), clone(f.name)))

        // Params
        let param_count = len(f.params)
        let mut pi = 0
        while pi < param_count {
            let param = get_unchecked(f.params, pi)
            out = concat(out, concat(String_from(" (param "), concat(val_type_name(param.val_type), String_from(")"))))
            pi = pi + 1
        }

        // Result
        if f.return_type != 0 {
            out = concat(out, concat(String_from(" (result "), concat(val_type_name(f.return_type), String_from(")"))))
        }
        out = concat(out, String_from("\n"))

        // Locals
        let local_count = len(f.locals)
        let mut li = 0
        while li < local_count {
            let loc = get_unchecked(f.locals, li)
            out = concat(out, concat(String_from("    (local "), concat(val_type_name(loc.val_type), String_from(")\n"))))
            li = li + 1
        }

        // Instructions
        let block_count = len(f.blocks)
        let mut bi = 0
        while bi < block_count {
            let block = get_unchecked(f.blocks, bi)
            let inst_count = len(block.instructions)
            let mut ii = 0
            while ii < inst_count {
                let inst = get_unchecked(block.instructions, ii)
                out = concat(out, concat(String_from("    "), concat(mir_op_to_wat(inst), String_from("\n"))))
                ii = ii + 1
            }
            bi = bi + 1
        }

        out = concat(out, String_from("  )\n"))

        // Export main/_start
        if eq(clone(f.name), "main") || eq(clone(f.name), "_start") {
            out = concat(out, concat(String_from("  (export \"_start\" (func $"), concat(clone(f.name), String_from("))\n"))))
        }

        fi = fi + 1
    }

    out = concat(out, String_from(")\n"))
    out
}

// ── Entry Point ──────────────────────────────────────────────────────────────

fn main() {
    let m = MirModule_new()

    // Build a minimal main function
    let f = MirFunction_new(String_from("main"))
    f.return_type = 0  // void
    let entry = alloc_block(f)
    // i32.const 42
    let ci = MirInst_const_i32(42, 0)
    emit_inst(f, entry, ci)
    // drop
    let di = MirInst_new(70)  // MIR_DROP
    emit_inst(f, entry, di)

    push(m.functions, f)

    let bytes = emit_wasm_module(m, String_from("wasm32-wasi-p2"), 0)
    let size = len(bytes)
    stdio::println(concat(String_from("Wasm output: "), concat(to_string(size), String_from(" bytes"))))

    // Verify magic number
    if size >= 4 {
        let b0 = get_unchecked(bytes, 0)
        let b1 = get_unchecked(bytes, 1)
        let b2 = get_unchecked(bytes, 2)
        let b3 = get_unchecked(bytes, 3)
        if b0 == 0 && b1 == 97 && b2 == 115 && b3 == 109 {
            stdio::println(String_from("Magic: OK (\\0asm)"))
        } else {
            stdio::println(String_from("Magic: FAIL"))
        }
    }

    stdio::println(String_from("Emitter OK."))
}

fn MirModule_new() -> MirModule {
    MirModule {
        functions: Vec_new_MirFunction(),
        string_constants: Vec_new_String(),
    }
}

fn MirFunction_new(name: String) -> MirFunction {
    MirFunction {
        name: name,
        params: Vec_new_MirLocal(),
        locals: Vec_new_MirLocal(),
        blocks: Vec_new_MirBlock(),
        return_type: 0,
        next_local: 0,
        next_block: 0,
    }
}

fn alloc_block(f: MirFunction) -> i32 {
    let idx = f.next_block
    f.next_block = f.next_block + 1
    let block = MirBlock {
        id: idx,
        instructions: Vec_new_MirInst(),
        terminator: 42,
        succ0: 0 - 1,
        succ1: 0 - 1,
    }
    push(f.blocks, block)
    idx
}

fn emit_inst(f: MirFunction, block_id: i32, inst: MirInst) {
    let block = get_unchecked(f.blocks, block_id)
    push(block.instructions, inst)
}

fn MirInst_new(op: i32) -> MirInst {
    MirInst {
        op: op, dest: 0 - 1, arg0: 0 - 1, arg1: 0 - 1,
        int_val: 0, float_val: 0.0, str_val: String_new(),
        val_type: 0,
    }
}

fn MirInst_const_i32(val: i32, dest: i32) -> MirInst {
    MirInst {
        op: 1, dest: dest, arg0: 0 - 1, arg1: 0 - 1,
        int_val: val, float_val: 0.0, str_val: String_new(),
        val_type: 1,
    }
}
