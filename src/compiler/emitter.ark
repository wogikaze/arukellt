emit_byte(w, OP_I32_ADD())
emit_byte(w, 35)
emit_leb128_u(w, 0)
emit_byte(w, OP_I32_STORE())
emit_byte(w, 2)
emit_byte(w, 0)
emit_byte(w, 35)
emit_leb128_u(w, 0)
emit_byte(w, OP_I32_CONST())
emit_leb128_s(w, 32)
emit_byte(w, OP_I32_ADD())
emit_byte(w, 36)
emit_leb128_u(w, 0)
emit_byte(w, 35)
emit_leb128_u(w, 0)
emit_byte(w, OP_I32_CONST())
emit_leb128_s(w, 44)
emit_byte(w, OP_I32_SUB())
ctx_mark_vec_local(ctx, inst.dest)
} else {
if eq(clone(callee), "vec_len") {
emit_byte(w, OP_I32_LOAD())
emit_byte(w, 2)
emit_byte(w, 0)
} else {
if eq(clone(callee), "vec_push") || eq(clone(callee), "push") {
let is_void_push = eq(clone(callee), "push")
}
}
