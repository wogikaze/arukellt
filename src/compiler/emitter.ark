            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // new_len = end
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, -4)
            emit_byte(w, OP_I32_AND())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)

        } else if eq(clone(callee), "text::contains") {
            // text::contains(str, substr) -> bool (substring search)
            // Reuse index_of logic: if index_of >= 0 then 1 else 0
            let s0 = ctx.scratch_base + 0
            let s1 = ctx.scratch_base + 1
            let s2 = ctx.scratch_base + 2
            let s3 = ctx.scratch_base + 3
            let s4 = ctx.scratch_base + 4
            let s5 = ctx.scratch_base + 5
            let s6 = ctx.scratch_base + 6
            let s7 = ctx.scratch_base + 7
            // Pop substr, then str
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // sub_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // result = 0 (not found)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s6)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // outer loop
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if i > str_len - sub_len: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // matched = 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s7)
            // j = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            // inner loop
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // str[i+j] != sub[j]?
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // if matched: result = 1; break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)
            emit_byte(w, OP_END())
            // i += 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // push result
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)

        } else if eq(clone(callee), "text::is_empty") {
            // text::is_empty(str) -> bool: len == 0
            let s0 = ctx.scratch_base + 0
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_EQZ())

        } else if eq(clone(callee), "text::len_bytes") {
            // text::len_bytes(str) -> i32: string byte length
            let s0 = ctx.scratch_base + 0
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)

        } else if eq(clone(callee), "pad_left") || eq(clone(callee), "text::pad_left") {
            // pad_left(str, width, fill) -> str
            // Stack: [str_ptr, width_i32, fill_ptr]
            let s_str = ctx.scratch_base + 0
            let s_width = ctx.scratch_base + 1
            let s_fill = ctx.scratch_base + 2
            let s_slen = ctx.scratch_base + 3
            let s_alloc = ctx.scratch_base + 4
            let s_pad = ctx.scratch_base + 5
            let s_i = ctx.scratch_base + 6
            let s_fb = ctx.scratch_base + 7
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fill)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str)
            // s_slen = load(str - 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_slen)
            // if slen >= width → return str
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7F)  // result i32
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_ELSE())
            // pad_count = width - slen
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_pad)
            // fill_byte = load8(fill)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fill)
            emit_byte(w, 0x2D)  // i32.load8_u
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fb)
            // alloc = bump(width + 4)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // store length = width at alloc
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // fill pad bytes: loop i from 0 to pad_count
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_pad)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // store8(alloc + 4 + i, fill_byte)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fb)
            emit_byte(w, 0x3a)  // i32.store8
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // memory.copy(alloc+4+pad, str, slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_pad)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)  // memory.copy
            emit_byte(w, 0)
            emit_byte(w, 0)
            // result: alloc + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_END())  // end if/else

        } else if eq(clone(callee), "pad_right") || eq(clone(callee), "text::pad_right") {
            // pad_right(str, width, fill) -> str
            // Stack: [str_ptr, width_i32, fill_ptr]
            let s_str = ctx.scratch_base + 0
            let s_width = ctx.scratch_base + 1
            let s_fill = ctx.scratch_base + 2
            let s_slen = ctx.scratch_base + 3
            let s_alloc = ctx.scratch_base + 4
            let s_pad = ctx.scratch_base + 5
            let s_i = ctx.scratch_base + 6
            let s_fb = ctx.scratch_base + 7
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fill)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str)
            // s_slen = load(str - 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_slen)
            // if slen >= width → return str
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7F)  // result i32
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_ELSE())
            // pad_count = width - slen
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_pad)
            // fill_byte = load8(fill)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fill)
            emit_byte(w, 0x2D)  // i32.load8_u
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fb)
            // alloc = bump(width + 4)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // store length = width at alloc
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_width)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // memory.copy(alloc+4, str, slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)  // memory.copy
            emit_byte(w, 0)
            emit_byte(w, 0)
            // fill pad bytes: loop i from 0 to pad_count
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_pad)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // store8(alloc + 4 + slen + i, fill_byte)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fb)
            emit_byte(w, 0x3a)  // i32.store8
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // result: alloc + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_END())  // end if/else

        } else if eq(clone(callee), "to_string") || eq(clone(callee), "i32_to_string") || eq(clone(callee), "i64_to_string") || eq(clone(callee), "text::format_i32") || eq(clone(callee), "text::format_i64") {
            // Inline to_string(i32): convert integer on stack to string
            // Stack has: [i32_value]
            // Scratch locals: scratch_base+0 = write_pos, +1 = is_neg, +2 = value
            let s_val = ctx.scratch_base + 2
            let s_wpos = ctx.scratch_base
            let s_neg = ctx.scratch_base + 1
            
            // Save value to scratch local
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_val)
            
            let buf_end = SCRATCH_I32BUF() + 20
            
            // Initialize write position
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, buf_end)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_wpos)
            
            // is_neg = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_neg)
            
            // Check for negative
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_LT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // Negate: val = 0 - val
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_neg)
            emit_byte(w, OP_END())
            
            // Handle zero case
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // Write '0' at write_pos - 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)  // '0'
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_ELSE())
            // Non-zero: extract digits loop
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if val == 0, break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // write_pos -= 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_wpos)
            // store digit: val % 10 + '0' (unsigned to handle INT_MIN)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_REM_U())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)  // '0'
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // val = val / 10 (unsigned to handle INT_MIN)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_DIV_U())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_val)
            // continue loop
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block
            emit_byte(w, OP_END())  // end else
            
            // If negative, prepend '-'
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_neg)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 45)  // '-'
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END())
            
            // Allocate heap copy so each call returns unique memory
            // s3 = length = buf_end - write_pos
            let s_len = ctx.scratch_base + 3
            let s_alloc = ctx.scratch_base + 4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, buf_end)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_len)

            // s_alloc = bump_alloc(len + 4)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)

            // Store length at alloc_ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // memory.copy(alloc_ptr + 4, write_pos, len)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)  // memory.copy
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)

            // Push result: alloc_ptr + 4 (string data pointer)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            
        } else if eq(clone(callee), "f64_to_string") || eq(clone(callee), "text::format_f64") {
            // f64_to_string: convert f64 on stack to string
            // Uses scratch locals: scratch_base+0..+4 (i32) and scratch_base+12..+13 (f64)
            // Strategy: separate sign, integer part, fractional part
            // Write digits to scratch buffer backwards (integer part) then forwards (frac part)
            let s_wpos = ctx.scratch_base + 0
            let s_neg = ctx.scratch_base + 1
            let s_int = ctx.scratch_base + 2    // integer part as i32
            let s_len = ctx.scratch_base + 3
            let s_alloc = ctx.scratch_base + 4
            let s_fdig = ctx.scratch_base + 5   // fractional digit counter
            let s_fpos = ctx.scratch_base + 6   // fractional write position
            let f_val = ctx.scratch_base + 12   // f64 local: value
            let f_frac = ctx.scratch_base + 13  // f64 local: fractional part

            let buf_start = SCRATCH_I32BUF()
            let buf_end = buf_start + 40   // 40 bytes for digits

            // Save f64 value
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, f_val)

            // is_neg = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_neg)

            // Check negative
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_val)
            emit_byte(w, OP_F64_CONST())
            emit_u32_le(w, 0)
            emit_u32_le(w, 0)  // 0.0
            emit_byte(w, OP_F64_LT())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)  // void
            // Negate and set flag
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_val)
            emit_byte(w, OP_F64_NEG())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, f_val)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_neg)
            emit_byte(w, OP_END())

            // s_int = i32.trunc_f64_s(val)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_val)
            emit_byte(w, OP_I32_TRUNC_F64_S())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_int)

            // f_frac = val - f64.convert_i32_s(s_int)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_val)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_F64_CONVERT_I32_S())
            emit_byte(w, OP_F64_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, f_frac)

            // Write integer part backwards from buf_end - 20
            let int_end = buf_start + 20
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, int_end)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_wpos)

            // Handle zero integer
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)  // '0'
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_ELSE())
            // Non-zero integer: extract digits loop
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_REM_U())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_DIV_U())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block
            emit_byte(w, OP_END())  // end else

            // Prepend '-' if negative
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_neg)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 45)  // '-'
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END())

            // Write '.' at int_end
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, int_end)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 46)  // '.'
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)

            // Write fractional digits: multiply frac by 10, take integer part, repeat
            // fpos = int_end + 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, int_end + 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fpos)

            // Write up to 15 fractional digits
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fdig)

            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if fdig >= 15, break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fdig)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 15)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)

            // frac = frac * 10.0
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_frac)
            emit_byte(w, OP_F64_CONST())
            // 10.0 in IEEE 754: lo=0x00000000, hi=0x40240000
            emit_u32_le(w, 0)
            emit_u32_le(w, 1076101120)  // 0x40240000
            emit_byte(w, OP_F64_MUL())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, f_frac)

            // digit = i32.trunc_f64_s(frac)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_frac)
            emit_byte(w, OP_I32_TRUNC_F64_S())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_int)  // reuse s_int as digit temp

            // frac = frac - f64.convert_i32_s(digit)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, f_frac)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_F64_CONVERT_I32_S())
            emit_byte(w, OP_F64_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, f_frac)

            // store digit char at fpos
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_int)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)  // '0'
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x3a)    // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)

            // fpos++, fdig++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fdig)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fdig)

            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block

            // Trim trailing zeros (keep at least 1 digit after dot)
            // fpos is now at end of fractional digits
            // Minimum fpos = int_end + 2 (keeps "X.0" form)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if fpos <= int_end + 2, break (keep at least 1 frac digit)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, int_end + 2)
            emit_byte(w, OP_I32_LE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // if byte at fpos-1 != '0', break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0x00)  // align
            emit_byte(w, 0x00)  // offset
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)  // '0'
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // fpos--
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block

            // Total string: from wpos to fpos
            // len = fpos - wpos
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_fpos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_len)

            // Allocate heap: alloc = bump_alloc(len + 4)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)

            // Store length
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // memory.copy(alloc + 4, wpos, len)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_wpos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)  // memory.copy
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)

            // Push result: alloc + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())

        } else if eq(clone(callee), "sqrt") || eq(clone(callee), "math::sqrt") {
            // sqrt(x: f64) -> f64: Wasm native f64.sqrt
            emit_byte(w, 0x9f) // f64.sqrt

        } else if eq(clone(callee), "parse_f64") || eq(clone(callee), "text::parse_f64") {
            // parse_f64(s: String) -> Result<f64, String>
            // Stack: [str_ptr] → [enum_ptr]
            // Scratch layout:
            //   SCRATCH_P_STR(48)   = str_ptr
            //   SCRATCH_P_LEN(52)   = len
            //   SCRATCH_P_I(56)     = i (index)
            //   SCRATCH_P_NEG(60)   = is_neg
            //   SCRATCH_PF_RESULT(112) = result (f64, 8 bytes)
            //   SCRATCH_P_ERR(68)   = is_err
            //   SCRATCH_P_BYTE(72)  = current byte
            //   SCRATCH_PF_SAWDOT(48 reused after str_ptr saved)  
            //   Actually, use dedicated slots:
            //   SCRATCH_PF_SAWDOT = 48, SCRATCH_PF_DECCOUNT = 52
            //   But we need str_ptr and len too, so use P_I=56 for i, P_NEG=60, P_ERR=68, P_BYTE=72
            //   str_ptr → scratch_base local, len → scratch_base+1 local
            let s_str = ctx.scratch_base + 0
            let s_len_local = ctx.scratch_base + 1
            
            // Save str_ptr to local
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str)
            
            // Compute len: mem[str_ptr - 4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02) // align=2
            emit_byte(w, 0x00) // offset=0
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_len_local)
            
            // Initialize scratch memory
            // result = 0.0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_F64_CONST())
            emit_f64(w, 0.0)
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03) // align=3
            emit_byte(w, 0x00) // offset=0
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // is_neg = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_NEG())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // is_err = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // saw_dot = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_SAWDOT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // decimal_count = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DECCOUNT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            
            // Check for empty string → error
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len_local)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40) // void block type
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END())
            
            // Check for leading '-'
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_EQZ()) // !is_err
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40) // void
            // Load first byte
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0x00) // align=0
            emit_byte(w, 0x00) // offset=0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 45) // '-'
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // is_neg = 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_NEG())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // i = 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Check string isn't just "-"
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len_local)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_LE_U())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END()) // end le check
            emit_byte(w, OP_END()) // end '-' check
            emit_byte(w, OP_END()) // end !is_err
            
            // Digit loop
            emit_byte(w, OP_BLOCK()) // block (break target)
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP()) // loop (continue target)
            emit_byte(w, 0x40)
            // if is_err, break
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1) // break to block
            // if i >= len, break
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len_local)
            emit_byte(w, OP_I32_GE_U())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1) // break to block
            // Load byte at str[i] → SCRATCH_P_BYTE
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str) // str_ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_ADD()) // str_ptr + i
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Check if byte == '.' (46)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 46) // '.'
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // Check if already saw dot → error
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_SAWDOT())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 3) // break to outer block
            emit_byte(w, OP_END()) // end duplicate dot check
            // saw_dot = 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_SAWDOT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // i += 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 1) // continue loop
            emit_byte(w, OP_END()) // end dot check
            // Check byte < '0' || byte > '9'
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48) // '0'
            emit_byte(w, OP_I32_LT_U())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 57) // '9'
            emit_byte(w, OP_I32_GT_U())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2) // break to outer block
            emit_byte(w, OP_END()) // end digit check
            // result = result * 10.0 + f64.convert_i32_u(byte - '0')
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_F64_CONST())
            emit_f64(w, 10.0)
            emit_byte(w, OP_F64_MUL())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48) // '0'
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_F64_CONVERT_I32_U())
            emit_byte(w, OP_F64_ADD())
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            // if saw_dot: decimal_count += 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_SAWDOT())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DECCOUNT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DECCOUNT())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END()) // end saw_dot check
            // i += 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0) // continue loop
            emit_byte(w, OP_END()) // end loop
            emit_byte(w, OP_END()) // end block
            
            // Build Result enum on heap
            // Check is_err
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7f) // result type i32
            // --- Err branch ---
            // Allocate error string "parse error: invalid float" on heap
            // String layout: [len:4][data:N], str_ptr = heap_ptr + 4
            let err_str = "parse error: invalid float"
            let err_len = 26
            // Store len
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0) // heap_ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, err_len)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store string bytes
            let mut ei = 0
            while ei < err_len {
                emit_byte(w, OP_GLOBAL_GET())
                emit_leb128_u(w, 0)
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, 4 + ei)
                emit_byte(w, OP_I32_ADD())
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, char_at(err_str, ei))
                emit_byte(w, OP_I32_STORE8())
                emit_byte(w, 0x00)
                emit_byte(w, 0x00)
                ei = ei + 1
            }
            // str_ptr = heap + 4 → save to SCRATCH_P_BYTE
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap past string
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4 + err_len)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Build Err enum: [tag=1][str_ptr at offset 4]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0) // enum_base (result on stack)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1) // tag = Err
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00) // str_ptr
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap past enum (12 bytes)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 12)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            
            emit_byte(w, OP_ELSE())
            // --- Ok branch ---
            // Compute divisor = 10^decimal_count
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DIVISOR())
            emit_byte(w, OP_F64_CONST())
            emit_f64(w, 1.0)
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            // Loop: multiply divisor by 10 for each decimal_count
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DECCOUNT())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1) // break if 0
            // divisor *= 10.0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DIVISOR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DIVISOR())
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_F64_CONST())
            emit_f64(w, 10.0)
            emit_byte(w, OP_F64_MUL())
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            // decimal_count -= 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DECCOUNT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DECCOUNT())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0) // continue
            emit_byte(w, OP_END()) // end loop
            emit_byte(w, OP_END()) // end block
            
            // Divide result by divisor if saw_dot
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_SAWDOT())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_DIVISOR())
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_F64_DIV())
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END()) // end saw_dot
            
            // Apply negation if is_neg
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_NEG())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_F64_NEG())
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_END()) // end negation
            
            // Build Ok enum: [tag=0][f64 payload at offset 4]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0) // enum_base (result on stack)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0) // tag = Ok
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store f64 payload at offset 4
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_PF_RESULT())
            emit_byte(w, OP_F64_LOAD())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            emit_byte(w, OP_F64_STORE())
            emit_byte(w, 0x03)
            emit_byte(w, 0x00)
            // Bump heap past enum (12 bytes)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 12)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            
            emit_byte(w, OP_END()) // end if/else
            // enum_ptr is now on the stack as the call result
        } else if eq(clone(callee), "fs::read_to_string") {
            // fs::read_to_string(path: String) -> Result<String, String>
            // Stack: [path_ptr]
            // path_ptr points to string data; length prefix is at ptr-4
            // Returns heap-allocated enum: [tag:i32, payload:i32]
            //   tag=0 → Ok(str_ptr), tag=1 → Err(err_str_ptr)
            let s_path = ctx.scratch_base + 2
            // Save path_ptr
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_path)
            // Store path_ptr to scratch
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHPTR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_path)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)  // align=2
            emit_byte(w, 0x00)  // offset=0
            // Compute path_len from length prefix at (path_ptr - 4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHLEN())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_path)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Call path_open(dirfd=3, dirflags=0, path, path_len, oflags=0,
            //   fs_rights_base=2(FD_READ), fs_rights_inheriting=0, fdflags=0, &opened_fd)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)   // dirfd = 3 (first preopened dir)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)   // dirflags
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHPTR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)    // path_ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHLEN())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)    // path_len
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)   // oflags = 0
            emit_byte(w, OP_I64_CONST())
            emit_leb128_s(w, 2)   // fs_rights_base = FD_READ (2)
            emit_byte(w, OP_I64_CONST())
            emit_leb128_s(w, 0)   // fs_rights_inheriting = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)   // fdflags = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_FD())  // &opened_fd
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 3)   // path_open = import 3
            // Check errno: 0 = success, nonzero = error
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_NE())
            // if path_open failed
            emit_byte(w, OP_IF())
            emit_byte(w, WASM_I32())  // result type i32
            // Build Err("file open error") on heap
            // Allocate error message string "file open error" (15 bytes + 4 len prefix)
            // Store length prefix (15)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 15)  // "file open error" = 15 bytes
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Write "file open error" byte by byte
            let err_msg_fo = "file open error"
            let mut ebi = 0
            while ebi < 15 {
                emit_byte(w, OP_GLOBAL_GET())
                emit_leb128_u(w, 0)
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, 4 + ebi)
                emit_byte(w, OP_I32_ADD())
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, char_at(err_msg_fo, ebi))
                emit_byte(w, OP_I32_STORE8())
                emit_byte(w, 0x00)
                emit_byte(w, 0x00)
                ebi = ebi + 1
            }
            // err_str_ptr = global(0) + 4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_STRPTR())
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 4 + 15 = 19
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 19)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Build Result enum: [tag=1(Err), payload=err_str_ptr]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)  // save result ptr
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)  // tag = 1 (Err)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_STRPTR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 8
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_ELSE())
            // path_open succeeded — read file contents
            // Save buf_start = global(0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_BUFSTART())
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Skip 4 bytes for length prefix
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Read loop: block { loop { ... } }
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)  // void
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)  // void
            // Set up iovec: [ptr=global(0), len=FS_BUF_SIZE]
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, FS_BUF_SIZE())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // fd_read(fd, &iov, 1, &nread)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_FD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)    // fd
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())  // &iov
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)   // iov count
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_NREAD())  // &nread
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 4)   // fd_read = import 4
            emit_byte(w, OP_DROP())  // drop errno
            // if nread == 0, break
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_NREAD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)  // break outer block
            // Bump heap by nread
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_NREAD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)  // continue loop
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block
            // Store total_len at buf_start
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_BUFSTART())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)    // buf_start
            // total_len = global(0) - (buf_start + 4)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_BUFSTART())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // fd_close(fd)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_FD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 5)   // fd_close = import 5
            emit_byte(w, OP_DROP())  // drop errno
            // str_ptr = buf_start + 4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_STRPTR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_BUFSTART())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Build Ok enum: [tag=0, payload=str_ptr]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)  // result ptr
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)  // tag = 0 (Ok)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_STRPTR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 8
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end if/else
        } else if eq(clone(callee), "fs::write_string") {
            // fs::write_string(path: String, content: String) -> Result<(), String>
            // Stack: [path_ptr, content_ptr]
            // Returns heap-allocated enum: [tag:i32, payload:i32]
            //   tag=0 → Ok(0), tag=1 → Err(err_str_ptr)
            let s_path_w = ctx.scratch_base + 2
            let s_content = ctx.scratch_base + 3
            // Save content_ptr then path_ptr
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_content)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_path_w)
            // Store path_ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHPTR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_path_w)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Compute path_len from length prefix at (path_ptr - 4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHLEN())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_path_w)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Call path_open(dirfd=3, dirflags=0, path, path_len, oflags=9(CREATE|TRUNC),
            //   fs_rights_base=64(FD_WRITE), fs_rights_inheriting=0, fdflags=0, &opened_fd)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)   // dirfd
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)   // dirflags
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHPTR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_PATHLEN())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 9)   // oflags = CREATE(1) | TRUNC(8)
            emit_byte(w, OP_I64_CONST())
            emit_leb128_s(w, 64)  // fs_rights_base = FD_WRITE (64)
            emit_byte(w, OP_I64_CONST())
            emit_leb128_s(w, 0)   // fs_rights_inheriting
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)   // fdflags
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_FD())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 3)   // path_open = import 3
            // Check errno
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, WASM_I32())
            // Build Err("file write error") on heap
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 16)  // "file write error" = 16 bytes
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            let err_msg_fw = "file write error"
            let mut ebi2 = 0
            while ebi2 < 16 {
                emit_byte(w, OP_GLOBAL_GET())
                emit_leb128_u(w, 0)
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, 4 + ebi2)
                emit_byte(w, OP_I32_ADD())
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, char_at(err_msg_fw, ebi2))
                emit_byte(w, OP_I32_STORE8())
                emit_byte(w, 0x00)
                emit_byte(w, 0x00)
                ebi2 = ebi2 + 1
            }
            // err_str_ptr = global(0) + 4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_STRPTR())
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 4 + 16 = 20
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 20)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Build Result enum: [tag=1(Err), payload=err_str_ptr]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_STRPTR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_ELSE())
            // path_open succeeded — write content then close
            // Set up iovec for write: [ptr=content_data, len=content_len]
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_content)  // content data ptr
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_content)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)    // content_len from prefix
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // fd_write(fd, &iov, 1, &nwritten)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_FD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)    // fd
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NWRITTEN())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 0)   // fd_write = import 0
            emit_byte(w, OP_DROP())
            // fd_close(fd)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_FS_FD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 5)   // fd_close = import 5
            emit_byte(w, OP_DROP())
            // Build Ok enum: [tag=0, payload=0]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)  // tag = 0 (Ok)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)  // payload = 0 (unit)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end if/else
        } else if eq(clone(callee), "char_to_string") {
            // char_to_string: convert codepoint (i32) to single-char string
            // Stack: [char_code]
            // Allocate 5 bytes from heap: [len=1, char_byte]
            let s_tmp = ctx.scratch_base + 2
            let s_alloc = ctx.scratch_base + 3
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_tmp)
            // alloc 5 bytes from bump allocator
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 5)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Store length = 1 at alloc_ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store char byte at alloc_ptr + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_tmp)
            emit_byte(w, 0x3a)  // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // Push pointer to string data (alloc_ptr + 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_alloc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
        } else if eq(clone(callee), "push_char") {
            // push_char(str, char): append char byte to string in place
            // Stack: [str_ptr, char_value]
            // String format: length at ptr-4, data at ptr
            let s_char = ctx.scratch_base
            let s_str = ctx.scratch_base + 1
            let s_len = ctx.scratch_base + 2

            // Save char and str_ptr
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_char)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str)

            // Read current length from [str_ptr - 4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)  // align=4
            emit_byte(w, 0x00)  // offset=0
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_len)

            // Write char byte at str_ptr + len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_char)
            emit_byte(w, 0x3a)  // i32.store8
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)

            // Update length: store len+1 at str_ptr - 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_len)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)  // align=4
            emit_byte(w, 0x00)  // offset=0

            // Push dummy result
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
        } else if eq(clone(callee), "Vec_new_i32") || eq(clone(callee), "Vec_new_String") || eq(clone(callee), "Vec_new_Point") || eq(clone(callee), "Vec_new_MirInst") || eq(clone(callee), "Vec_new_MirLocal") || eq(clone(callee), "Vec_new_MirBlock") || eq(clone(callee), "Vec_new_MirFunction") || eq(clone(callee), "Vec_new_AstNode") || eq(clone(callee), "Vec_new_u8") || eq(clone(callee), "Vec_new_f64") || eq(clone(callee), "Vec_new_bool") || eq(clone(callee), "Vec_new_Item") || eq(clone(callee), "Vec_new_Container") || eq(clone(callee), "Vec_new_Context") || eq(clone(callee), "Vec_new_Holder") || eq(clone(callee), "Vec_new_Inner") || eq(clone(callee), "Vec_new_Outer") || eq(clone(callee), "Vec_new_Token") || eq(clone(callee), "Vec_new_Span") || eq(clone(callee), "Vec_new_Diagnostic") || eq(clone(callee), "Vec_new_TypedFn") || eq(clone(callee), "Vec_new_WasmLocal") || eq(clone(callee), "Vec_new_ImportEntry") || eq(clone(callee), "Vec_new_ExportEntry") || eq(clone(callee), "Vec_new_FuncType") || eq(clone(callee), "Vec_new_Pair") || eq(clone(callee), "Vec_new_Node") {
            // Vec_new_*: allocate Vec header {len:0, cap:8, data_ptr} + data (8*4=32 bytes)
            // Memory layout: [len(4) | cap(4) | data_ptr(4)] then [data(32)]
            // Total: 12 + 32 = 44 bytes
            // Result: pointer to header start

            // len = 0 at heap[0]
            emit_byte(w, 0x23)  // global.get 0 (heap ptr)
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // cap = 8 at heap[4]
            emit_byte(w, 0x23)  // global.get 0
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // Bump heap past header (12 bytes)
            emit_byte(w, 0x23)  // global.get 0
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 12)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x24)  // global.set 0
            emit_leb128_u(w, 0)

            // Store data_ptr = current heap at header+8
            emit_byte(w, 0x23)  // global.get 0
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 12)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x23)  // global.get 0 (data_ptr = current heap)
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // Bump heap past data (8 * 4 = 32 bytes)
            emit_byte(w, 0x23)  // global.get 0
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 32)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x24)  // global.set 0
            emit_leb128_u(w, 0)

            // Result: header ptr = heap - 44
            emit_byte(w, 0x23)  // global.get 0
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 44)
            emit_byte(w, OP_I32_SUB())

            // Mark dest local as vec
            ctx_mark_vec_local(ctx, inst.dest)

        } else if eq(clone(callee), "vec_len") {
            // Vec len: load from v+0 (first field is len)
            // Stack: [vec_ptr]
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

        } else if eq(clone(callee), "vec_push") {
            // vec_push(v, x): grow if needed, store x at data[len*4], increment len
            // Stack: [vec_ptr, value]
            let s_val = ctx.scratch_base
            let s_vec = ctx.scratch_base + 1
            let s_data = ctx.scratch_base + 2
            let s_cap = ctx.scratch_base + 3
            let s_newdata = ctx.scratch_base + 4
            // Save value and vec_ptr from stack
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec)

            // Check if len >= cap: grow if needed
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_LOAD())  // len
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())  // cap
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_cap)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)

            // GROW: new_cap = cap * 2
            // Allocate new data area: new_data = global[0]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_newdata)
            // Bump heap by new_cap * 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_newdata)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_cap)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 2)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)

            // Load old data_ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_data)

            // memory.copy(new_data, old_data, len * 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_newdata)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_LOAD())  // len
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)  // memory.copy
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)

            // Update data_ptr in header
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_newdata)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // Update cap = cap * 2
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_cap)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 2)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            emit_byte(w, OP_END())  // end if grow

            // Now store: data_ptr = load(vec + 8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // data_ptr + len * 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_LOAD())  // len
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())

            // Store value at data[len*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // Increment len: store(vec, load(vec) + 1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_LOAD())  // len
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())  // store len+1
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // Push vec_ptr as result
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)

        } else if eq(clone(callee), "vec_get_unchecked") {
            // vec_get_unchecked(v, i): load data[i*4]
            // Stack: [vec_ptr, index]
            let s_idx = ctx.scratch_base
            let s_vec2 = ctx.scratch_base + 1
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_idx)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec2)

            // data_ptr = load(vec + 8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

            // data_ptr + i * 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_idx)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())

            // Load value
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

        } else if eq(clone(callee), "vec_get") {
            // vec_get(v, i) -> Option<i32>: bounds-checked access
            // Stack: [vec_ptr, index]
            let s_idx2 = ctx.scratch_base
            let s_vec3 = ctx.scratch_base + 1
            let s_res = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_idx2)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec3)

            // Check i < len(v)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_idx2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec3)
            emit_byte(w, OP_I32_LOAD())  // len
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x49)  // i32.lt_u

            // if (result i32)
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x7F)  // block type: i32

            // In bounds: construct Some(data[i]) = heap [tag=0, payload=data[i]]
            // Save result ptr
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_res)
            // Store tag = 0 at heap[0]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store data[i] at heap[4]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            // Load data[i]: data_ptr = load(vec+8), then load(data_ptr + i*4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec3)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())  // data_ptr
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_idx2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())  // data[i]
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())  // store payload
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 8
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push result ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_res)

            // else: out of bounds → None
            emit_byte(w, 0x05)  // else

            // Save result ptr
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_res)
            // Store tag = 1 at heap[0]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 4
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push result ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_res)

            // end if
            emit_byte(w, 0x0B)

        } else if eq(clone(callee), "vec_pop") {
            // vec_pop(v) -> Option<i32>: [tag=0,payload] for Some, [tag=1] for None
            // Option layout: 8 bytes on heap [tag:i32, payload:i32]
            let s_vec_pop = ctx.scratch_base
            let s_newlen = ctx.scratch_base + 1
            let s_optptr = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec_pop)
            // Load current len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_pop)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // if len > 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_GT_U())
            // if (len > 0) → Some path
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7F)  // result i32
            // new_len = len - 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_pop)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_newlen)
            // Store new_len back
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_pop)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_newlen)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Load value = data_ptr[new_len * 4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_pop)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_newlen)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_newlen)  // reuse s_newlen for value
            // Alloc 8 bytes for Option: [tag=0, payload=value]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_optptr)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Store tag = 0 (Some)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_optptr)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store payload = value
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_optptr)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_newlen)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Return option ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_optptr)
            // else → None path
            emit_byte(w, OP_ELSE())
            // Alloc 8 bytes for Option: [tag=1]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_optptr)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Store tag = 1 (None)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_optptr)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Return option ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_optptr)
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "vec_set") {
            // vec_set(v, i, val): store val at data[i*4]
            // Stack: [vec_ptr, index, value]
            let s_val_set = ctx.scratch_base
            let s_idx_set = ctx.scratch_base + 1
            let s_vec_set = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_val_set)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_idx_set)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec_set)
            // data_ptr = load(vec + 8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_set)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // addr = data_ptr + idx * 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_idx_set)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            // Store value
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_val_set)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Push vec_ptr as result
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_set)

        } else if eq(clone(callee), "unwrap") {
            // unwrap(opt): load payload from Option [tag, payload]
            // Stack: [option_ptr]
            // Option layout: [tag:i32, payload:i32] where tag=0 for Some, tag=1 for None
            // Return: payload at opt_ptr + 4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

        } else if eq(clone(callee), "unwrap_or") {
            // unwrap_or(opt, default): if tag==0 return payload, else return default
            // Stack: [option_ptr, default_value]
            let s_def = ctx.scratch_base
            let s_opt = ctx.scratch_base + 1
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_def)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_opt)
            // Check tag: opt[0]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_opt)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // if tag == 0 (Some)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7F)  // result type i32
            // Some: return payload at opt+4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_opt)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x05)  // else
            // None: return default
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_def)
            emit_byte(w, 0x0B)  // end

        } else if eq(clone(callee), "is_empty") {
            // is_empty(s): check string length == 0
            // Stack: [string_ptr]
            // String layout: data starts at ptr, length at ptr-4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_EQZ())

        } else if eq(clone(callee), "is_some") || eq(clone(callee), "is_ok") {
            // is_some/is_ok(opt): tag == 0 (Some/Ok)
            // Stack: [enum_ptr] → [bool]
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00) // load tag
            emit_byte(w, OP_I32_EQZ()) // tag == 0 → 1 (true)

        } else if eq(clone(callee), "is_none") || eq(clone(callee), "is_err") {
            // is_none/is_err(opt): tag != 0 (None/Err)
            // Stack: [enum_ptr] → [bool]
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00) // load tag (1=None/Err, 0=Some/Ok)

        } else if eq(clone(callee), "unwrap") {
            // unwrap(opt): load payload at offset 4
            // Stack: [enum_ptr] → [i32 payload]
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)

        } else if eq(clone(callee), "unwrap_or") {
            // unwrap_or(opt, default): if tag==0 return payload, else default
            // Stack: [enum_ptr, default] → [i32]
            let s_opt = ctx.scratch_base
            let s_def = ctx.scratch_base + 1
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_def) // save default
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_opt) // save enum_ptr
            // Check tag
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_opt)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_EQZ()) // tag == 0?
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7f) // result i32
            // Some/Ok: load payload
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_opt)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_ELSE())
            // None/Err: return default
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_def)
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "contains_i32") {
            // contains_i32(v, needle): scan vec for needle, return bool
            // Stack: [vec_ptr, needle]
            let s_needle = ctx.scratch_base
            let s_vec_ci = ctx.scratch_base + 1
            let s_ci_i = ctx.scratch_base + 2
            let s_ci_len = ctx.scratch_base + 3
            let s_ci_data = ctx.scratch_base + 4
            let s_ci_found = ctx.scratch_base + 5
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_needle)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec_ci)
            // found = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ci_found)
            // len = vec[0]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_ci)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ci_len)
            // data = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_ci)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ci_data)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ci_i)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // br_if 1 if i >= len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ci_i)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ci_len)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // if data[i*4] == needle
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ci_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ci_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_needle)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // found = 1; br 2 (break outer block)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ci_found)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)
            emit_byte(w, 0x0B)  // end if
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ci_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ci_i)
            // br 0 (continue loop)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            // push found
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ci_found)

        } else if eq(clone(callee), "reverse_i32") {
            // reverse_i32(v): reverse vec in place
            // Stack: [vec_ptr]
            let s_vec_rv = ctx.scratch_base
            let s_rv_lo = ctx.scratch_base + 1
            let s_rv_hi = ctx.scratch_base + 2
            let s_rv_data = ctx.scratch_base + 3
            let s_rv_tmp = ctx.scratch_base + 4
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec_rv)
            // data = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_rv)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rv_data)
            // lo = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rv_lo)
            // hi = len - 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_rv)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rv_hi)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // br_if 1 if lo >= hi
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_lo)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_hi)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // tmp = data[lo*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_lo)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rv_tmp)
            // data[lo*4] = data[hi*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_lo)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            // load data[hi*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_hi)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // data[hi*4] = tmp
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_hi)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_tmp)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // lo++, hi--
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_lo)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rv_lo)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rv_hi)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rv_hi)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            // push vec_ptr as result (void but MIR expects something)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec_rv)

        } else if eq(clone(callee), "remove_i32") {
            // remove_i32(v, idx): shift elements left, decrement len
            // Stack: [vec_ptr, idx]
            let s_rm_idx = ctx.scratch_base
            let s_rm_vec = ctx.scratch_base + 1
            let s_rm_data = ctx.scratch_base + 2
            let s_rm_len = ctx.scratch_base + 3
            let s_rm_i = ctx.scratch_base + 4
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rm_idx)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rm_vec)
            // len = vec[0]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_vec)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rm_len)
            // data = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rm_data)
            // i = idx
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_idx)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rm_i)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // br_if 1 if i >= len - 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_i)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_len)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // data[i*4] = data[(i+1)*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            // load data[(i+1)*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_rm_i)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            // vec[0] = len - 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_vec)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_len)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // push vec_ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_rm_vec)

        } else if eq(clone(callee), "String_new") {
            // String_new(): allocate empty string (len=0, data_ptr=heap)
            // Layout: [len:i32 at heap, data after]
            // Return: pointer to data (heap + 4), with len = 0 at (ptr - 4)
            let s_str_base = ctx.scratch_base
            // Save heap ptr
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str_base)
            // Store len=0 at heap[0]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap by 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push data_ptr = base + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())

        } else if eq(clone(callee), "slice") {
            // slice(s, start, end): return substring [start..end)
            // Stack: [str_ptr, start, end]
            let s_sl_end = ctx.scratch_base
            let s_sl_start = ctx.scratch_base + 1
            let s_sl_src = ctx.scratch_base + 2
            let s_sl_base = ctx.scratch_base + 3
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sl_end)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sl_start)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sl_src)
            // new_len = end - start
            // Allocate: [len:i32, data:u8*new_len]
            // Save heap ptr as base
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sl_base)
            // Store new_len at base
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_base)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_end)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Copy bytes: memory.copy(base+4, src+start, new_len)
            // dst = base + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            // src_addr = src + start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_src)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_start)
            emit_byte(w, OP_I32_ADD())
            // count = end - start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_end)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_start)
            emit_byte(w, OP_I32_SUB())
            // memory.copy: 0xFC 0x0A 0x00 0x00
            emit_byte(w, 0xFC)
            emit_byte(w, 0x0A)
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // Bump heap by 4 + new_len (aligned to 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_end)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            // Align to 4: (ptr + 3) & ~3
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, -4)
            emit_byte(w, OP_I32_AND())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push result: base + 4 (data ptr)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sl_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())

        } else if eq(clone(callee), "join") {
            // join(parts: Vec<String>, sep: String) -> String
            // Stack: [vec_ptr, sep_ptr]
            let s_sep = ctx.scratch_base
            let s_jvec = ctx.scratch_base + 1
            let s_jlen = ctx.scratch_base + 2
            let s_jdata = ctx.scratch_base + 3
            let s_ji = ctx.scratch_base + 4
            let s_jbase = ctx.scratch_base + 5
            let s_jdst = ctx.scratch_base + 6
            let s_sep_len = ctx.scratch_base + 7
            let s_str_p = ctx.scratch_base + 8
            let s_str_l = ctx.scratch_base + 9
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sep)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jvec)
            // vec len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jvec)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jlen)
            // vec data
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jvec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jdata)
            // sep len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sep)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sep_len)
            // Allocate: save heap as base, write len placeholder at base
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jbase)
            // dst = base + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jbase)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jdst)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ji)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if i >= len: br 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ji)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jlen)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // If i > 0, copy separator
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ji)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // memory.copy(dst, sep, sep_len)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sep)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sep_len)
            emit_byte(w, 0xFC)
            emit_byte(w, 0x0A)
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // dst += sep_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sep_len)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, 0x0B)  // end if
            // Get string ptr from vec: str_p = data[i*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdata)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ji)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str_p)
            // str_l = str_p[-4] (length)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_p)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str_l)
            // memory.copy(dst, str_p, str_l)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_p)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_l)
            emit_byte(w, 0xFC)
            emit_byte(w, 0x0A)
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // dst += str_l
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_l)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_jdst)
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ji)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ji)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            // Store total_len = dst - (base + 4) at base
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jbase)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jbase)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Update heap: align dst to 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jdst)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, -4)
            emit_byte(w, OP_I32_AND())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push result: base + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_jbase)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())

        } else if eq(clone(callee), "split") {
            // split(s, sep) -> Vec<String>: split string by separator
            // Stack: [str_ptr, sep_ptr]
            let s_sp_sep = ctx.scratch_base
            let s_sp_src = ctx.scratch_base + 1
            let s_sp_slen = ctx.scratch_base + 2
            let s_sp_seplen = ctx.scratch_base + 3
            let s_sp_pos = ctx.scratch_base + 4
            let s_sp_start = ctx.scratch_base + 5
            let s_sp_vec = ctx.scratch_base + 6
            let s_sp_match = ctx.scratch_base + 7
            let s_sp_j = ctx.scratch_base + 8
            let s_sp_sub = ctx.scratch_base + 9
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_sep)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_src)
            // src len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_src)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_slen)
            // sep len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sep)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_seplen)
            // Allocate vec: [len:0, cap:16, data_ptr]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_vec)
            // vec[0] = 0 (len)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // vec[4] = 16 (cap)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 16)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // vec[8] = heap + 12 (data area)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 12)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap past vec header + data area (12 + 16*4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 76)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // pos = 0, start = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_start)
            // Scan loop: block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if pos > slen - seplen: br 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_seplen)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_GT_S())
