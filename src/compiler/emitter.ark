// Arukellt Selfhost — Wasm Binary Emitter
//
// Generates a deterministic Wasm binary from MIR.
// Handles section layout, LEB128 encoding, and T1/T3 target split.

use std::host::stdio

// ── Wasm Section IDs ─────────────────────────────────────────────────────────

fn SEC_TYPE() -> i32 { 1 }
fn SEC_IMPORT() -> i32 { 2 }
fn SEC_FUNCTION() -> i32 { 3 }
fn SEC_TABLE() -> i32 { 4 }
fn SEC_MEMORY() -> i32 { 5 }
fn SEC_GLOBAL() -> i32 { 6 }
fn SEC_EXPORT() -> i32 { 7 }
fn SEC_START() -> i32 { 8 }
fn SEC_ELEMENT() -> i32 { 9 }
fn SEC_CODE() -> i32 { 10 }
fn SEC_DATA() -> i32 { 11 }

// ── Wasm Value Types ─────────────────────────────────────────────────────────

fn WASM_I32() -> i32 { 0x7f }
fn WASM_I64() -> i32 { 0x7e }
fn WASM_F32() -> i32 { 0x7d }
fn WASM_F64() -> i32 { 0x7c }
fn WASM_FUNCREF() -> i32 { 0x70 }
fn WASM_EXTERNREF() -> i32 { 0x6f }

// ── Wasm Opcodes ─────────────────────────────────────────────────────────────

fn OP_UNREACHABLE() -> i32 { 0x00 }
fn OP_NOP() -> i32 { 0x01 }
fn OP_BLOCK() -> i32 { 0x02 }
fn OP_LOOP() -> i32 { 0x03 }
fn OP_IF() -> i32 { 0x04 }
fn OP_ELSE() -> i32 { 0x05 }
fn OP_END() -> i32 { 0x0b }
fn OP_BR() -> i32 { 0x0c }
fn OP_BR_IF() -> i32 { 0x0d }
fn OP_RETURN() -> i32 { 0x0f }
fn OP_CALL() -> i32 { 0x10 }
fn OP_DROP() -> i32 { 0x1a }
fn OP_SELECT() -> i32 { 0x1b }
fn OP_LOCAL_GET() -> i32 { 0x20 }
fn OP_LOCAL_SET() -> i32 { 0x21 }
fn OP_LOCAL_TEE() -> i32 { 0x22 }
fn OP_GLOBAL_GET() -> i32 { 0x23 }
fn OP_GLOBAL_SET() -> i32 { 0x24 }
fn OP_I32_LOAD() -> i32 { 0x28 }
fn OP_F64_LOAD() -> i32 { 0x2b }
fn OP_I32_LOAD8_U() -> i32 { 0x2d }
fn OP_I32_STORE() -> i32 { 0x36 }
fn OP_F64_STORE() -> i32 { 0x39 }
fn OP_I32_STORE8() -> i32 { 0x3a }
fn OP_I32_CONST() -> i32 { 0x41 }
fn OP_I64_CONST() -> i32 { 0x42 }
fn OP_F64_CONST() -> i32 { 0x44 }
fn OP_I32_EQZ() -> i32 { 0x45 }
fn OP_I32_EQ() -> i32 { 0x46 }
fn OP_I32_NE() -> i32 { 0x47 }
fn OP_I32_LT_S() -> i32 { 0x48 }
fn OP_I32_GT_S() -> i32 { 0x4a }
fn OP_I32_GT_U() -> i32 { 0x4b }
fn OP_I32_LE_S() -> i32 { 0x4c }
fn OP_I32_GE_S() -> i32 { 0x4e }
fn OP_I32_ADD() -> i32 { 0x6a }
fn OP_I32_SUB() -> i32 { 0x6b }
fn OP_I32_MUL() -> i32 { 0x6c }
fn OP_I32_DIV_S() -> i32 { 0x6d }
fn OP_I32_DIV_U() -> i32 { 0x6e }
fn OP_I32_REM_S() -> i32 { 0x6f }
fn OP_I32_REM_U() -> i32 { 0x70 }
fn OP_I32_AND() -> i32 { 0x71 }
fn OP_I32_OR() -> i32 { 0x72 }
fn OP_I32_XOR() -> i32 { 0x73 }
fn OP_I32_SHL() -> i32 { 0x74 }
fn OP_I32_SHR_S() -> i32 { 0x75 }
fn OP_I32_LT_U() -> i32 { 0x49 }
fn OP_I32_GE_U() -> i32 { 0x4f }
fn OP_I32_LE_U() -> i32 { 0x4d }
fn OP_F64_CONVERT_I32_U() -> i32 { 0xb8 }

// f64 opcodes
fn OP_F64_EQ() -> i32 { 0x61 }
fn OP_F64_NE() -> i32 { 0x62 }
fn OP_F64_LT() -> i32 { 0x63 }
fn OP_F64_GT() -> i32 { 0x64 }
fn OP_F64_LE() -> i32 { 0x65 }
fn OP_F64_GE() -> i32 { 0x66 }
fn OP_F64_ADD() -> i32 { 0xa0 }
fn OP_F64_SUB() -> i32 { 0xa1 }
fn OP_F64_MUL() -> i32 { 0xa2 }
fn OP_F64_DIV() -> i32 { 0xa3 }
fn OP_F64_NEG() -> i32 { 0x9a }
fn OP_F64_ABS() -> i32 { 0x99 }
fn OP_F64_FLOOR() -> i32 { 0x9c }
fn OP_F64_TRUNC() -> i32 { 0x9f }
fn OP_I32_TRUNC_F64_S() -> i32 { 0xaa }
fn OP_F64_CONVERT_I32_S() -> i32 { 0xb7 }

fn OP_GLOBAL_GET() -> i32 { 0x23 }
fn OP_GLOBAL_SET() -> i32 { 0x24 }

fn SEC_GLOBAL() -> i32 { 6 }

// ── Binary Writer ────────────────────────────────────────────────────────────

struct WasmWriter {
    bytes: Vec<i32>,
}

fn WasmWriter_new() -> WasmWriter {
    WasmWriter { bytes: Vec_new_i32() }
}

fn emit_byte(w: WasmWriter, b: i32) {
    push(w.bytes, b % 256)
}

fn emit_u32_le(w: WasmWriter, v: i32) {
    emit_byte(w, v % 256)
    emit_byte(w, (v / 256) % 256)
    emit_byte(w, (v / 65536) % 256)
    emit_byte(w, (v / 16777216) % 256)
}

fn emit_leb128_u(w: WasmWriter, v: i32) {
    let mut val = v
    if val < 0 { val = 0 }
    let mut done = false
    while !done {
        let mut b = val % 128
        val = val / 128
        if val != 0 {
            b = b + 128
        }
        emit_byte(w, b)
        if val == 0 { done = true }
    }
}

fn emit_leb128_s(w: WasmWriter, v: i32) {
    let mut val = v
    let mut more = true
    while more {
        let raw_mod = val % 128
        let mut b = raw_mod
        if b < 0 { b = b + 128 }
        // Floor division (arithmetic right shift by 7)
        val = val / 128
        if raw_mod < 0 {
            val = val - 1
        }
        // Check if more bytes needed
        if (val == 0 && b < 64) || (val == 0 - 1 && b >= 64) {
            more = false
        } else {
            b = b + 128
        }
        emit_byte(w, b % 256)
    }
}

fn emit_bytes(w: WasmWriter, src: Vec<i32>) {
    let count = len(src)
    let mut i = 0
    while i < count {
        let b = get_unchecked(src, i)
        emit_byte(w, b)
        i = i + 1
    }
}

fn emit_f64(w: WasmWriter, val: f64) {
    let lo = f64_bits_lo(val)
    let hi = f64_bits_hi(val)
    emit_u32_le(w, lo)
    emit_u32_le(w, hi)
}

fn emit_string(w: WasmWriter, s: String) {
    let slen = len(s)
    emit_leb128_u(w, slen)
    let mut i = 0
    while i < slen {
        emit_byte(w, char_at(s, i))
        i = i + 1
    }
}

fn writer_size(w: WasmWriter) -> i32 {
    len(w.bytes)
}

// ── Section Writer ───────────────────────────────────────────────────────────

fn emit_section(out: WasmWriter, section_id: i32, contents: WasmWriter) {
    emit_byte(out, section_id)
    emit_leb128_u(out, writer_size(contents))
    emit_bytes(out, contents.bytes)
}

// ── Wasm Module Emitter ──────────────────────────────────────────────────────

fn emit_wasm_module(mir: MirModule, target: String, opt_level: i32) -> Vec<i32> {
    let out = WasmWriter_new()

    // Magic number: \0asm
    emit_byte(out, 0x00)
    emit_byte(out, 0x61)
    emit_byte(out, 0x73)
    emit_byte(out, 0x6d)
    // Version: 1
    emit_u32_le(out, 1)

    let fn_count = len(mir.functions)

    // Compute string offsets (length-prefixed: [len_i32_le, data...])
    let str_count = len(mir.string_constants)
    let string_offsets = Vec_new_i32()
    let string_lengths = Vec_new_i32()
    let mut data_offset = DATA_START()
    let mut si = 0
    while si < str_count {
        let s = get_unchecked(mir.string_constants, si)
        let slen = len(s)
        // Data layout: [4 bytes length][slen bytes data]
        // Pointer points to data start (after length prefix)
        push(string_offsets, data_offset + 4)  // ptr to data
        push(string_lengths, slen)
        data_offset = data_offset + 4 + slen
        si = si + 1
    }

    // Build emit context
        // Find or add "true" and "false" string indices for bool_to_string
    let mut true_idx = 0 - 1
    let mut false_idx = 0 - 1
    let mut bi = 0
    while bi < str_count {
        let bs = get_unchecked(mir.string_constants, bi)
        if eq(clone(bs), "true") {
            true_idx = bi
        }
        if eq(clone(bs), "false") {
            false_idx = bi
        }
        bi = bi + 1
    }
    // If not found, append them
    if true_idx < 0 {
        true_idx = len(mir.string_constants)
        push(mir.string_constants, String_from("true"))
        push(string_offsets, data_offset + 4)
        push(string_lengths, 4)
        data_offset = data_offset + 4 + 4
    }
    if false_idx < 0 {
        false_idx = len(mir.string_constants)
        push(mir.string_constants, String_from("false"))
        push(string_offsets, data_offset + 4)
        push(string_lengths, 5)
        data_offset = data_offset + 4 + 5
    }

    let mut ctx = SelfEmitCtx {
        functions: mir.functions,
        string_offsets: string_offsets,
        string_lengths: string_lengths,
        string_values: mir.string_constants,
        scratch_base: 0,
        true_str_idx: true_idx,
        false_str_idx: false_idx,
        vec_locals: Vec_new_i32(),
    }

    // Determine if main needs a start wrapper (non-void return type)
    let mut needs_wrapper = 0
    let mut main_check_idx = 0
    while main_check_idx < fn_count {
        let mf = get_unchecked(mir.functions, main_check_idx)
        if eq(clone(mf.name), "main") || eq(clone(mf.name), "_start") {
            if mf.return_type != 0 {
                needs_wrapper = 1
            }
        }
        main_check_idx = main_check_idx + 1
    }

    // Type section
    // Type 0: fd_write/fd_read type (i32, i32, i32, i32) -> (i32)
    // Type 1: wasi_args type (i32, i32) -> (i32) [args_sizes_get, args_get]
    // Type 2: path_open type (i32 x5, i64, i64, i32, i32) -> (i32)
    // Type 3: fd_close type (i32) -> (i32)
    let type_sec = WasmWriter_new()
    emit_leb128_u(type_sec, fn_count + NUM_WASI_TYPES() + needs_wrapper)
    // Type 0: fd_write/fd_read: (fd, iovs_ptr, iovs_len, nwritten_ptr) -> errno
    emit_byte(type_sec, 0x60)
    emit_leb128_u(type_sec, 4)  // 4 params
    emit_byte(type_sec, WASM_I32())
    emit_byte(type_sec, WASM_I32())
    emit_byte(type_sec, WASM_I32())
    emit_byte(type_sec, WASM_I32())
    emit_leb128_u(type_sec, 1)  // 1 result
    emit_byte(type_sec, WASM_I32())
    // Type 1: args_sizes_get / args_get: (i32, i32) -> (i32)
    emit_byte(type_sec, 0x60)
    emit_leb128_u(type_sec, 2)  // 2 params
    emit_byte(type_sec, WASM_I32())
    emit_byte(type_sec, WASM_I32())
    emit_leb128_u(type_sec, 1)  // 1 result
    emit_byte(type_sec, WASM_I32())
    // Type 2: path_open: (dirfd, dirflags, path, path_len, oflags, rights_base, rights_inh, fdflags, fd_out) -> (errno)
    emit_byte(type_sec, 0x60)
    emit_leb128_u(type_sec, 9)  // 9 params
    emit_byte(type_sec, WASM_I32())  // dirfd
    emit_byte(type_sec, WASM_I32())  // dirflags
    emit_byte(type_sec, WASM_I32())  // path
    emit_byte(type_sec, WASM_I32())  // path_len
    emit_byte(type_sec, WASM_I32())  // oflags
    emit_byte(type_sec, WASM_I64())  // fs_rights_base
    emit_byte(type_sec, WASM_I64())  // fs_rights_inheriting
    emit_byte(type_sec, WASM_I32())  // fdflags
    emit_byte(type_sec, WASM_I32())  // fd_out
    emit_leb128_u(type_sec, 1)  // 1 result
    emit_byte(type_sec, WASM_I32())
    // Type 3: fd_close: (fd) -> (errno)
    emit_byte(type_sec, 0x60)
    emit_leb128_u(type_sec, 1)  // 1 param
    emit_byte(type_sec, WASM_I32())
    emit_leb128_u(type_sec, 1)  // 1 result
    emit_byte(type_sec, WASM_I32())
    // User function types (indices 2..fn_count+1)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(mir.functions, i)
        emit_byte(type_sec, 0x60)
        let param_count = len(f.params)
        emit_leb128_u(type_sec, param_count)
        let mut p = 0
        while p < param_count {
            let param = get_unchecked(f.params, p)
            emit_byte(type_sec, val_type_to_wasm(param.val_type))
            p = p + 1
        }
        if f.return_type == 0 {
            emit_leb128_u(type_sec, 0)
        } else {
            emit_leb128_u(type_sec, 1)
            emit_byte(type_sec, val_type_to_wasm(f.return_type))
        }
        i = i + 1
    }
    // Wrapper type: void → void (type index = fn_count + NUM_WASI_TYPES)
    if needs_wrapper == 1 {
        emit_byte(type_sec, 0x60)
        emit_leb128_u(type_sec, 0)  // 0 params
        emit_leb128_u(type_sec, 0)  // 0 results
    }
    emit_section(out, SEC_TYPE(), type_sec)

    // Import section (for WASI)
    let import_sec = WasmWriter_new()
    let wasi_module = String_from("wasi_snapshot_preview1")
    emit_leb128_u(import_sec, NUM_WASI_IMPORTS())
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("fd_write"))
    emit_byte(import_sec, 0x00)  // func import
    emit_leb128_u(import_sec, 0) // type index 0
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("args_sizes_get"))
    emit_byte(import_sec, 0x00)
    emit_leb128_u(import_sec, 1) // type index 1
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("args_get"))
    emit_byte(import_sec, 0x00)
    emit_leb128_u(import_sec, 1) // type index 1
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("path_open"))
    emit_byte(import_sec, 0x00)
    emit_leb128_u(import_sec, 2) // type index 2 (path_open type)
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("fd_read"))
    emit_byte(import_sec, 0x00)
    emit_leb128_u(import_sec, 0) // type index 0 (same as fd_write)
    emit_string(import_sec, clone(wasi_module))
    emit_string(import_sec, String_from("fd_close"))
    emit_byte(import_sec, 0x00)
    emit_leb128_u(import_sec, 3) // type index 3 (fd_close type)
    emit_section(out, SEC_IMPORT(), import_sec)

    // Function section (type indices offset by NUM_WASI_TYPES for wasi types)
    let func_sec = WasmWriter_new()
    emit_leb128_u(func_sec, fn_count + needs_wrapper)
    let mut fi = 0
    while fi < fn_count {
        emit_leb128_u(func_sec, fi + NUM_WASI_TYPES())  // type index = fi + NUM_WASI_TYPES
        fi = fi + 1
    }
    if needs_wrapper == 1 {
        emit_leb128_u(func_sec, fn_count + NUM_WASI_TYPES())  // wrapper type index
    }
    emit_section(out, SEC_FUNCTION(), func_sec)

    // Memory section
    let mem_sec = WasmWriter_new()
    emit_leb128_u(mem_sec, 1)
    emit_byte(mem_sec, 0x00)    // limits: no max
    emit_leb128_u(mem_sec, 1)   // initial: 1 page
    emit_section(out, SEC_MEMORY(), mem_sec)

    // Global section: heap pointer (mutable i32, initialized to data_offset)
    let global_sec = WasmWriter_new()
    emit_leb128_u(global_sec, 1)    // 1 global
    emit_byte(global_sec, WASM_I32()) // type: i32
    emit_byte(global_sec, 0x01)     // mutable
    emit_byte(global_sec, OP_I32_CONST())
    // Align heap start to 8 bytes after string data
    let heap_start = ((data_offset + 7) / 8) * 8
    emit_leb128_s(global_sec, heap_start)
    emit_byte(global_sec, OP_END())
    emit_section(out, SEC_GLOBAL(), global_sec)

    // Export section
    let export_sec = WasmWriter_new()
    let mut export_count = 1  // memory
    // Find _start / main
    let mut main_idx = 0 - 1
    let mut mi = 0
    while mi < fn_count {
        let f = get_unchecked(mir.functions, mi)
        if eq(clone(f.name), "main") || eq(clone(f.name), "_start") {
            main_idx = mi
        }
        mi = mi + 1
    }
    if main_idx >= 0 { export_count = export_count + 1 }
    emit_leb128_u(export_sec, export_count)
    // Export memory
    emit_string(export_sec, String_from("memory"))
    emit_byte(export_sec, 0x02)
    emit_leb128_u(export_sec, 0)
    // Export main/_start
    if main_idx >= 0 {
        emit_string(export_sec, String_from("_start"))
        emit_byte(export_sec, 0x00)
        if needs_wrapper == 1 {
            // Export the wrapper function (index fn_count + NUM_WASI_IMPORTS)
            emit_leb128_u(export_sec, fn_count + NUM_WASI_IMPORTS())
        } else {
            emit_leb128_u(export_sec, main_idx + NUM_WASI_IMPORTS())  // offset by imports
        }
    }
    emit_section(out, SEC_EXPORT(), export_sec)

    // Code section
    let code_sec = WasmWriter_new()
    emit_leb128_u(code_sec, fn_count + needs_wrapper)
    let mut ci = 0
    while ci < fn_count {
        let f = get_unchecked(mir.functions, ci)
        let body = WasmWriter_new()

        // Locals: body locals (skip params) + 3 extra for to_string scratch
        let local_count = len(f.locals)
        let param_count = len(f.params)
        let body_local_count = local_count - param_count
        let extra_locals = 12  // scratch locals for builtin handlers (join/split need up to index 9)
        let extra_f64_locals = 2  // f64 scratch locals for f64_to_string (val, frac)
        emit_leb128_u(body, body_local_count + extra_locals + extra_f64_locals)
        let mut li = param_count
        while li < local_count {
            let loc = get_unchecked(f.locals, li)
            emit_leb128_u(body, 1)
            emit_byte(body, val_type_to_wasm(loc.val_type))
            li = li + 1
        }
        // Extra i32 locals for to_string
        let mut ei = 0
        while ei < extra_locals {
            emit_leb128_u(body, 1)
            emit_byte(body, WASM_I32())
            ei = ei + 1
        }
        // Extra f64 locals for f64_to_string
        let mut efi = 0
        while efi < extra_f64_locals {
            emit_leb128_u(body, 1)
            emit_byte(body, WASM_F64())
            efi = efi + 1
        }

        // Instructions (simplified: emit MIR ops → Wasm ops)
        ctx.scratch_base = local_count
        ctx.vec_locals = Vec_new_i32()
        let block_count = len(f.blocks)
        let mut bi = 0
        while bi < block_count {
            let block = get_unchecked(f.blocks, bi)
            let inst_count = len(block.instructions)
            let mut ii = 0
            while ii < inst_count {
                let inst = get_unchecked(block.instructions, ii)
                emit_mir_inst_ctx(body, inst, ctx)
                ii = ii + 1
            }
            bi = bi + 1
        }

        emit_byte(body, OP_END())

        // Write func body with size prefix
        emit_leb128_u(code_sec, writer_size(body))
        emit_bytes(code_sec, body.bytes)
        ci = ci + 1
    }
    // Add wrapper function: call main, drop return value, end
    if needs_wrapper == 1 {
        let wrapper_body = WasmWriter_new()
        emit_leb128_u(wrapper_body, 0)  // 0 locals
        emit_byte(wrapper_body, OP_CALL())
        emit_leb128_u(wrapper_body, main_idx + NUM_WASI_IMPORTS())  // call main (offset by imports)
        emit_byte(wrapper_body, OP_DROP())
        emit_byte(wrapper_body, OP_END())
        emit_leb128_u(code_sec, writer_size(wrapper_body))
        emit_bytes(code_sec, wrapper_body.bytes)
    }
    emit_section(out, SEC_CODE(), code_sec)

    // Data section (length-prefixed string constants)
    let final_str_count = len(mir.string_constants)
    if final_str_count > 0 {
        let data_sec = WasmWriter_new()
        emit_leb128_u(data_sec, 1)  // single data segment
        emit_byte(data_sec, 0x00)   // active, memory 0
        emit_byte(data_sec, OP_I32_CONST())
        emit_leb128_s(data_sec, DATA_START())
        emit_byte(data_sec, OP_END())
        // Compute total data size
        let mut total_data = 0
        let mut ds = 0
        while ds < final_str_count {
            let s = get_unchecked(mir.string_constants, ds)
            total_data = total_data + 4 + len(s)  // 4 bytes length + data
            ds = ds + 1
        }
        emit_leb128_u(data_sec, total_data)
        // Write strings: [len_le32][data_bytes...]
        let mut ds2 = 0
        while ds2 < final_str_count {
            let s = get_unchecked(mir.string_constants, ds2)
            let slen = len(s)
            // Write length as little-endian i32
            emit_byte(data_sec, slen % 256)
            emit_byte(data_sec, (slen / 256) % 256)
            emit_byte(data_sec, (slen / 65536) % 256)
            emit_byte(data_sec, (slen / 16777216) % 256)
            // Write string bytes
            let mut ci2 = 0
            while ci2 < slen {
                emit_byte(data_sec, char_at(s, ci2))
                ci2 = ci2 + 1
            }
            ds2 = ds2 + 1
        }
        emit_section(out, SEC_DATA(), data_sec)
    }

    out.bytes
}

// ── Wasm Module Emitter ──────────────────────────────────────────────────────

// Scratch memory layout for WASI fd_write
fn SCRATCH_IOV() -> i32 { 0 }       // 8 bytes: ciovec {ptr, len}
fn SCRATCH_NWRITTEN() -> i32 { 8 }  // 4 bytes: nwritten result
fn SCRATCH_I32BUF() -> i32 { 16 }   // 20 bytes: i32-to-string buffer
fn SCRATCH_NEWLINE() -> i32 { 36 }  // 1 byte: newline char
fn SCRATCH_CHARBUF() -> i32 { 40 }  // 5 bytes: [len=1 as i32, char_byte]
// parse_i32 scratch: str_ptr, len, i, is_neg, result, is_err, byte
fn SCRATCH_P_STR() -> i32 { 48 }
fn SCRATCH_P_LEN() -> i32 { 52 }
fn SCRATCH_P_I() -> i32 { 56 }
fn SCRATCH_P_NEG() -> i32 { 60 }
fn SCRATCH_P_RES() -> i32 { 64 }
fn SCRATCH_P_ERR() -> i32 { 68 }
fn SCRATCH_P_BYTE() -> i32 { 72 }
// WASI args scratch
fn SCRATCH_ARGC() -> i32 { 76 }       // 4 bytes: argc result
fn SCRATCH_ARGV_SIZE() -> i32 { 80 }   // 4 bytes: argv_buf_size result
// WASI FS scratch
fn SCRATCH_FS_FD() -> i32 { 84 }      // 4 bytes: opened fd from path_open
fn SCRATCH_FS_PATHPTR() -> i32 { 88 }  // 4 bytes: saved path pointer
fn SCRATCH_FS_PATHLEN() -> i32 { 92 }  // 4 bytes: saved path length
fn SCRATCH_FS_NREAD() -> i32 { 96 }    // 4 bytes: nread result from fd_read
fn SCRATCH_FS_BUFSTART() -> i32 { 100 } // 4 bytes: saved buffer start
fn SCRATCH_FS_STRPTR() -> i32 { 104 }  // 4 bytes: computed string pointer
// parse_f64 scratch (reuses parse_i32 scratch + extra f64 areas)
fn SCRATCH_PF_RESULT() -> i32 { 112 }  // 8 bytes: f64 result accumulator (must be 8-aligned)
fn SCRATCH_PF_DIVISOR() -> i32 { 120 } // 8 bytes: f64 divisor for decimal (must be 8-aligned)
fn SCRATCH_PF_SAWDOT() -> i32 { 48 }   // 4 bytes: saw_dot flag (reuses P_STR)
fn SCRATCH_PF_DECCOUNT() -> i32 { 52 } // 4 bytes: decimal_count (reuses P_LEN)
fn FS_BUF_SIZE() -> i32 { 4096 }       // read buffer chunk size
// Number of WASI imports (fd_write, args_sizes_get, args_get, path_open, fd_read, fd_close)
fn NUM_WASI_IMPORTS() -> i32 { 6 }
// Number of fixed WASI type signatures (before user types)
fn NUM_WASI_TYPES() -> i32 { 4 }
fn DATA_START() -> i32 { 128 }      // string data starts here (scratch uses 0-127)

// Emit context for passing module info to instruction emitter
struct SelfEmitCtx {
    functions: Vec<MirFunction>,
    string_offsets: Vec<i32>,
    string_lengths: Vec<i32>,
    string_values: Vec<String>,
    scratch_base: i32,
    true_str_idx: i32,
    false_str_idx: i32,
    vec_locals: Vec<i32>,
}

fn ctx_mark_vec_local(ctx: SelfEmitCtx, local_idx: i32) {
    let count = len(ctx.vec_locals)
    let mut i = 0
    while i < count {
        if get_unchecked(ctx.vec_locals, i) == local_idx {
            return
        }
        i = i + 1
    }
    push(ctx.vec_locals, local_idx)
}

fn ctx_is_vec_local(ctx: SelfEmitCtx, local_idx: i32) -> bool {
    let count = len(ctx.vec_locals)
    let mut i = 0
    while i < count {
        if get_unchecked(ctx.vec_locals, i) == local_idx {
            return true
        }
        i = i + 1
    }
    false
}

fn resolve_fn_index(ctx: SelfEmitCtx, name: String) -> i32 {
    // Returns function index (0-based, user functions; caller must add 1 for import offset)
    let count = len(ctx.functions)
    let mut i = 0
    while i < count {
        let f = get_unchecked(ctx.functions, i)
        if eq(clone(f.name), name) {
            return i
        }
        i = i + 1
    }
    0 - 1  // not found
}

fn emit_mir_inst_ctx(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx) {
    if inst.op == 1 {  // CONST_I32
        emit_byte(w, OP_I32_CONST())
        emit_leb128_s(w, inst.int_val)
    } else if inst.op == 2 {  // CONST_I64
        emit_byte(w, OP_I64_CONST())
        emit_leb128_s(w, inst.int_val)
    } else if inst.op == 3 {  // CONST_F64
        emit_byte(w, OP_F64_CONST())
        // Emit 8 IEEE 754 bytes using f64_bits_lo/hi
        let lo = f64_bits_lo(inst.float_val)
        let hi = f64_bits_hi(inst.float_val)
        emit_u32_le(w, lo)
        emit_u32_le(w, hi)
    } else if inst.op == 5 {  // CONST_STRING
        // Push string data pointer (offset in memory) onto stack
        // Find this string in the string_constants to get its offset
        let str_count = len(ctx.string_offsets)
        let mut found = false
        let mut si = 0
        while si < str_count && !found {
            // Match by checking offset exists (we use inst.arg0 as string index if set, 
            // otherwise match by str_val content - for now use sequential index tracking)
            si = si + 1
        }
        // Use inst.dest's string index from intern_string
        // The MIR stores the string in str_val and the intern index in int_val
        // Actually we need the string index. Let's use the order.
        // For now, use a linear scan to find the string
        let target_str = clone(inst.str_val)
        let mut str_idx = 0 - 1
        let mut si2 = 0
        let sc2 = len(ctx.string_offsets)
        while si2 < sc2 {
            // We can't easily compare here without the actual strings.
            // Use inst.arg0 if it was set, or use a counter.
            si2 = si2 + 1
        }
        // Fallback: use the sequential position tracking
        // The MIR lowering calls intern_string which returns an index.
        // That index is stored in... let me check. Actually it's NOT stored in the MirInst.
        // We need to track which CONST_STRING we're emitting by counting.
        // For now, use arg0 if >= 0, otherwise match str_val
        if inst.arg0 >= 0 {
            str_idx = inst.arg0
        }
        if str_idx >= 0 && str_idx < len(ctx.string_offsets) {
            let offset = get_unchecked(ctx.string_offsets, str_idx)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, offset)
        } else {
            // Unknown string, push 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
        }
    } else if inst.op == 10 {  // LOCAL_GET
        emit_byte(w, OP_LOCAL_GET())
        emit_leb128_u(w, inst.arg0)
    } else if inst.op == 11 {  // LOCAL_SET
        emit_byte(w, OP_LOCAL_SET())
        emit_leb128_u(w, inst.arg0)
    } else if inst.op == 20 {  // ADD
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_ADD()) }
        else { emit_byte(w, OP_I32_ADD()) }
    } else if inst.op == 21 {  // SUB
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_SUB()) }
        else { emit_byte(w, OP_I32_SUB()) }
    } else if inst.op == 22 {  // MUL
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_MUL()) }
        else { emit_byte(w, OP_I32_MUL()) }
    } else if inst.op == 23 {  // DIV
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_DIV()) }
        else { emit_byte(w, OP_I32_DIV_S()) }
    } else if inst.op == 24 {  // MOD
        emit_byte(w, OP_I32_REM_S())
    } else if inst.op == 25 {  // EQ
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_EQ()) }
        else { emit_byte(w, OP_I32_EQ()) }
    } else if inst.op == 26 {  // NEQ
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_NE()) }
        else { emit_byte(w, OP_I32_NE()) }
    } else if inst.op == 27 {  // LT
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_LT()) }
        else { emit_byte(w, OP_I32_LT_S()) }
    } else if inst.op == 28 {  // LTEQ
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_LE()) }
        else { emit_byte(w, OP_I32_LE_S()) }
    } else if inst.op == 29 {  // GT
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_GT()) }
        else { emit_byte(w, OP_I32_GT_S()) }
    } else if inst.op == 30 {  // GTEQ
        if inst.val_type == VT_F64() { emit_byte(w, OP_F64_GE()) }
        else { emit_byte(w, OP_I32_GE_S()) }
    } else if inst.op == 31 {  // AND (logical)
        emit_byte(w, OP_I32_AND())
    } else if inst.op == 32 {  // OR (logical)
        emit_byte(w, OP_I32_OR())
    } else if inst.op == 35 {  // BIT_AND
        emit_byte(w, OP_I32_AND())
    } else if inst.op == 36 {  // BIT_OR
        emit_byte(w, OP_I32_OR())
    } else if inst.op == 37 {  // BIT_XOR
        emit_byte(w, OP_I32_XOR())
    } else if inst.op == 38 {  // SHL
        emit_byte(w, OP_I32_SHL())
    } else if inst.op == 39 {  // SHR
        emit_byte(w, OP_I32_SHR_S())
    } else if inst.op == 40 {  // CALL
        let callee = clone(inst.str_val)
        if eq(clone(callee), "stdio::println") || eq(clone(callee), "println") {
            // Inline println: the string pointer is on the stack
            // We need to: store string ptr, compute length, set up IOV, call fd_write, write newline
            //
            // Stack has: [string_ptr]
            // We need a local to hold the string ptr - use a temp approach:
            // 1. local.tee to save ptr while keeping it on stack
            // Actually we need to store the ptr, compute the string length, set up IOV.
            // For length-prefixed strings: [len:4bytes, data...]
            // ptr points to data start, len is at ptr-4
            //
            // For our selfhost model: strings in data section are raw bytes.
            // The CONST_STRING pushes the data offset. We also need the length.
            // Problem: the length isn't on the stack.
            //
            // Solution: use the to_string approach like the Rust emitter.
            // For string constants, we know the length at compile time.
            // We'll store it using the length-prefixed model:
            // Data section: [len_i32_le, data_bytes...] for each string
            // CONST_STRING pushes ptr to start of data (after length prefix)
            // To get length: i32.load [ptr - 4]

            // Save string ptr to temp local (we always have locals available)
            // Actually the Wasm stack model means we can use local.tee
            // For now, simple approach: read length from [ptr-4]
            
            // Stack: [str_ptr]
            // Store in IOV: iov.ptr = str_ptr, iov.len = len
            
            // i32.const SCRATCH_IOV    ; IOV base address
            // local.get str_ptr (on stack already)
            // But we need to save the ptr first...
            
            // Use a different approach: length is encoded before the string
            // ptr points to data, length at ptr-4
            
            // Step 1: Save string ptr
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, inst.dest)  // reuse dest local as temp
            
            // Step 2: Store ptr into IOV[0].ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())  // addr = 0
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)  // align=4
            emit_byte(w, 0x00)  // offset=0
            
            // Step 3: Read string length from [ptr - 4]
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)  // addr = 4 (iov.len)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())  // ptr - 4
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)  // align=4
            emit_byte(w, 0x00)  // offset=0
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)  // align=4
            emit_byte(w, 0x00)  // offset=0
            
            // Step 4: Call fd_write(1, SCRATCH_IOV, 1, SCRATCH_NWRITTEN)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)  // fd = stdout
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())  // iovs ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)  // iovs count
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NWRITTEN())  // nwritten ptr
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 0)  // fd_write is import index 0
            emit_byte(w, OP_DROP())  // discard errno
            
            // Step 5: Write newline
            // Store newline char (10) at SCRATCH_NEWLINE
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NEWLINE())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)  // '\n'
            // i32.store8 opcode = 0x3a
            emit_byte(w, 0x3a)  // i32.store8
            emit_byte(w, 0x00)  // align=1
            emit_byte(w, 0x00)  // offset=0
            
            // IOV for newline
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NEWLINE())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)  // len = 1
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)  // fd = stdout
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NWRITTEN())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 0)  // fd_write
            emit_byte(w, OP_DROP())

            // Push dummy result (println is void, but caller may LOCAL_SET the "result")
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            
        } else if eq(clone(callee), "stdio::print") || eq(clone(callee), "print") {
            // Inline print (no newline): same as println but skip newline step
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, inst.dest)
            // Store ptr into IOV[0].ptr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Read string length from [ptr - 4]
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Call fd_write(1, IOV, 1, nwritten)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NWRITTEN())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_DROP())
            // Push dummy result
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)

        } else if eq(clone(callee), "String_from") || eq(clone(callee), "clone") {
            // String_from and clone are no-op identities: value is already on stack
            let _nop = 0
        } else if eq(clone(callee), "stdio::eprintln") || eq(clone(callee), "eprintln") {
            // Inline eprintln: same as println but fd=2 (stderr)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // fd_write(2, ...)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 2)  // fd = stderr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NWRITTEN())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_DROP())
            // Write newline to stderr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NEWLINE())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, 0x3a)
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NEWLINE())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV() + 4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 2)  // fd = stderr
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_IOV())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_NWRITTEN())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_DROP())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
        } else if eq(clone(callee), "bool_to_string") || eq(clone(callee), "text::format_bool") {
            // Inline bool_to_string: if value != 0 → "true" ptr, else → "false" ptr
            let s_tmp = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_tmp)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_tmp)
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x7f)  // blocktype i32
            // true branch
            let true_offset = get_unchecked(ctx.string_offsets, ctx.true_str_idx)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, true_offset)
            emit_byte(w, 0x05)  // else
            // false branch
            let false_offset = get_unchecked(ctx.string_offsets, ctx.false_str_idx)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, false_offset)
            emit_byte(w, 0x0b)  // end
        } else if eq(clone(callee), "len") {
            // String len: load i32 from [ptr - 4] (length prefix)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())  // ptr - 4
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
        } else if eq(clone(callee), "eq") {
            // String eq: compare two strings by content
            // Stack: [ptr_a, ptr_b]
            let s_a = ctx.scratch_base
            let s_b = ctx.scratch_base + 1
            let s_la = ctx.scratch_base + 2
            let s_i = ctx.scratch_base + 3
            // Save args
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_b)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_a)
            // If ptrs equal → true (shortcut)
            // len_a = load(ptr_a - 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_a)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_la)
            // len_b = load(ptr_b - 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_b)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // If len_a != len_b → false
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_la)
            emit_byte(w, 0x47)  // i32.ne
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x7f)  // blocktype i32
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)  // false
            emit_byte(w, 0x05)  // else
            // Lengths equal. Compare bytes with a loop.
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_i)
            // block (for break-out with result)
            emit_byte(w, 0x02)  // block
            emit_byte(w, 0x40)  // void
            // loop
            emit_byte(w, 0x03)  // loop
            emit_byte(w, 0x40)  // void
            // if i >= len_a → all equal, break with true
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_la)
            emit_byte(w, 0x4e)  // i32.ge_s
            emit_byte(w, 0x0d)  // br_if
            emit_leb128_u(w, 1)  // break to outer block
            // if a[i] != b[i] → not equal, push 0 and break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_a)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x2d)  // i32.load8_u
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_b)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x2d)  // i32.load8_u
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, 0x47)  // i32.ne
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            // Store 0 (false) in inst.dest and break
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, inst.dest)
            emit_byte(w, 0x0c)  // br
            emit_leb128_u(w, 2)  // break to outer block
            emit_byte(w, 0x0b)  // end if
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_i)
            // br 0 (continue loop)
            emit_byte(w, 0x0c)  // br
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0b)  // end loop
            emit_byte(w, 0x0b)  // end block
            // If we broke out naturally (i >= len), it's true
            // But if we broke via mismatch, inst.dest = 0
            // We need a way to distinguish. Let me set inst.dest = 1 before loop.
            // Wait, I already emitted the code. Let me rethink.
            // Actually: if we break from the ge_s check (br_if 1), we fall to after block.
            // In that case all bytes matched → true. If mismatch (br 2), also after block
            // but inst.dest = 0.
            // I'll pre-set inst.dest = 1 (true), and mismatch sets it to 0.
            // But I already emitted the block/loop without setting inst.dest first.
            // The br_if 1 on ge_s needs to also set the result...
            // Hmm, this is getting complex. Let me use a simpler structure.

            // Since I already emitted, let me load from inst.dest.
            // Before the block, I need inst.dest = 1. But I can't redo.
            // Let me just always push the result after the block using inst.dest.
            // Pre-loop: inst.dest = 1 (assume equal). Mismatch sets inst.dest = 0.
            // But I need to emit "inst.dest = 1" BEFORE the block, and I'm past that.

            // OK - I'll work around: use s_i as result flag.
            // Actually the loop already broke. After loop ends, check if i >= len_a.
            // If yes → equal (1), else not (0).
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_i)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_la)
            emit_byte(w, 0x4e)  // i32.ge_s → 1 if loop completed, 0 if broke early
            emit_byte(w, 0x0b)  // end (if/else)
