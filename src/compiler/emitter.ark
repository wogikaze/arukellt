// Arukellt Selfhost — Wasm Binary Emitter
//
// Generates a deterministic Wasm binary from MIR.
// Handles section layout, LEB128 encoding, and T1/T3 target split.
use std::host::stdio

fn SEC_TYPE() -> i32 {
    1
}

fn SEC_IMPORT() -> i32 {
    2
}

fn SEC_FUNCTION() -> i32 {
    3
}

fn SEC_TABLE() -> i32 {
    4
}

fn SEC_MEMORY() -> i32 {
    5
}

fn SEC_GLOBAL() -> i32 {
    6
}

fn SEC_EXPORT() -> i32 {
    7
}

fn SEC_START() -> i32 {
    8
}

fn SEC_ELEMENT() -> i32 {
    9
}

fn SEC_CODE() -> i32 {
    10
}

fn SEC_DATA() -> i32 {
    11
}

