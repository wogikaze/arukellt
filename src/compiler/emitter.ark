            // match = 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_match)
            // j = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_j)
            // block { loop { check each byte
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_j)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_seplen)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // if src[pos+j] != sep[j]: match=0, br 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_src)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_j)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sep)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_j)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_match)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)  // break inner comparison loop
            emit_byte(w, 0x0B)  // end if
            // j++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_j)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_j)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end inner loop
            emit_byte(w, 0x0B)  // end inner block
            // If match: create substring [start..pos], push to vec
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_match)
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // Create substring: slice(src, start, pos)
            // Allocate [len, data] for substring
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_sub)
            // len = pos - start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // memory.copy(sub+4, src+start, pos-start)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_src)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, 0xFC)
            emit_byte(w, 0x0A)
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // Bump heap
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, -4)
            emit_byte(w, OP_I32_AND())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push str_ptr (sub+4) to vec via inline vec_push
            // vec_data = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // data[vec_len * 4] = sub + 4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // vec_len++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // start = pos + seplen
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_seplen)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_start)
            // pos = start (skip separator)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 1)  // continue outer loop
            emit_byte(w, 0x0B)  // end if match
            // pos++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_pos)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end outer loop
            emit_byte(w, 0x0B)  // end outer block
            // Push last segment: slice(src, start, slen)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_src)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, 0xFC)
            emit_byte(w, 0x0A)
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            // Bump heap
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_slen)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_start)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, -4)
            emit_byte(w, OP_I32_AND())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push last str to vec
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_sub)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // vec_len++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Push vec ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_sp_vec)

        } else if eq(clone(callee), "parse_i32") {
            // parse_i32(s: String) -> Result<i32, String>
            // Stack: [str_ptr]
            let s_tmp = ctx.scratch_base
            // Save str_ptr from stack
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_tmp)
            // Store str_ptr at SCRATCH_P_STR
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_STR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_tmp)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Load string length from ptr-4
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_LEN())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_tmp)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Init i=0, is_neg=0, result=0, is_err=0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_NEG())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_RES())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Check empty string → is_err=1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_LEN())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x45)  // i32.eqz
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x0B)  // end if
            // Check first char '-'
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x45)  // i32.eqz (!is_err)
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            // Load first byte
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_STR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x2D)  // i32.load8_u align=0 offset=0
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 45)  // '-'
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            // is_neg=1, i=1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_NEG())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Check len <= 1 (just "-") → is_err=1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_LEN())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, 0x4D)  // i32.le_u
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x0B)  // end if (len<=1)
            emit_byte(w, 0x0B)  // end if (is '-')
            emit_byte(w, 0x0B)  // end if (!is_err)
            // Digit loop: block { loop { ... } }
            emit_byte(w, 0x02)  // block
            emit_byte(w, 0x40)  // void
            emit_byte(w, 0x03)  // loop
            emit_byte(w, 0x40)  // void
            // if is_err → br 1 (break block)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x0D)  // br_if
            emit_leb128_u(w, 1)
            // if i >= len → br 1 (break block)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_LEN())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x4F)  // i32.ge_u
            emit_byte(w, 0x0D)  // br_if
            emit_leb128_u(w, 1)
            // byte = str[i]
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_STR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, 0x2D)  // i32.load8_u
            emit_byte(w, 0x00)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Check byte < '0' || byte > '9'
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)  // '0'
            emit_byte(w, 0x49)  // i32.lt_u
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 57)  // '9'
            emit_byte(w, 0x4B)  // i32.gt_u
            emit_byte(w, 0x72)  // i32.or
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x0C)  // br 2 (break outer block)
            emit_leb128_u(w, 2)
            emit_byte(w, 0x0B)  // end if
            // result = result * 10 + (byte - '0')
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_RES())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_RES())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_BYTE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 48)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // i += 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_I())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // br 0 (continue loop)
            emit_byte(w, 0x0C)  // br
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            // Check is_err: if err → build Err struct, else → build Ok struct
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_ERR())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x04)  // if (result i32)
            emit_byte(w, 0x7F)
            // Err path: build heap string "parse error: invalid integer"
            // then build Result::Err [tag=1, str_ptr]
            // Write error string on heap: [len:4, data:28]
            let s_base = ctx.scratch_base + 1
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_base)
            // Store len=28 at heap
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 28)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Write "parse error: invalid integer" byte-by-byte
            let err_msg = "parse error: invalid integer"
            let err_len = len(err_msg)
            let mut ei = 0
            while ei < err_len {
                emit_byte(w, OP_LOCAL_GET())
                emit_leb128_u(w, s_base)
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, 4 + ei)
                emit_byte(w, OP_I32_ADD())
                let ch = char_at(err_msg, ei)
                emit_byte(w, OP_I32_CONST())
                emit_leb128_s(w, ch)
                emit_byte(w, 0x3A)  // i32.store8 align=0 offset=0
                emit_byte(w, 0x00)
                emit_byte(w, 0x00)
                ei = ei + 1
            }
            // str_ptr = base + 4
            let s_str_ptr = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_str_ptr)
            // Bump heap past string (4+28=32)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_base)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 32)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Build enum [tag=1, payload=str_ptr]
            let s_enum = ctx.scratch_base + 3
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_enum)
            // Store tag=1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_enum)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store str_ptr at enum+4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_enum)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str_ptr)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap 8
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push enum ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_enum)
            // else: Ok path
            emit_byte(w, 0x05)  // else
            // Apply negation if is_neg
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_NEG())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x04)  // if
            emit_byte(w, 0x40)  // void
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_RES())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_RES())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, 0x0B)  // end if
            // Build Result::Ok [tag=0, payload=result]
            let s_ok = ctx.scratch_base + 3
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_ok)
            // Store tag=0
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ok)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Store result at ok+4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ok)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_P_RES())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 0x02)
            emit_byte(w, 0x00)
            // Bump heap 8
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Push enum ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_ok)
            // end if/else
            emit_byte(w, 0x0B)

        } else if eq(clone(callee), "env::arg_count") {
            // env::arg_count() -> i32: call args_sizes_get, return argc
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGC())       // ptr for argc
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGV_SIZE())   // ptr for buf_size
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 1)  // args_sizes_get = import 1
            emit_byte(w, OP_DROP())  // drop errno
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGC())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)  // align=4
            emit_leb128_u(w, 0)  // offset=0
            // subtract 1 to skip argv[0] (program name)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())

        } else if eq(clone(callee), "env::args") {
            // env::args() -> Vec<String>: returns heap-allocated vec of strings from WASI args
            // Step 1: get arg count and buf size
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGC())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGV_SIZE())
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 1)  // args_sizes_get
            emit_byte(w, OP_DROP())
            // Load argc
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGC())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            let s_argc = ctx.scratch_base + 0
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_argc)
            // Allocate Vec: [len=0, cap=8, data_ptr]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            let s_vec = ctx.scratch_base + 1
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 12)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Store len=0
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            // Store cap=8
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 8)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 4)
            // Allocate data area
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            let s_data = ctx.scratch_base + 2
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_data)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 32)  // 8 slots * 4 bytes
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Store data ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_data)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 8)
            // If argc > 0, populate vec from WASI args
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40) // void block
            // Allocate argv ptrs and buf
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, SCRATCH_ARGV_SIZE())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            let s_bufsize = ctx.scratch_base + 3
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_bufsize)
            // argv ptrs
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            let s_argv = ctx.scratch_base + 4
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_argv)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // argv buf
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            let s_argv_buf = ctx.scratch_base + 5
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_argv_buf)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_bufsize)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Call args_get
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argv)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argv_buf)
            emit_byte(w, OP_CALL())
            emit_leb128_u(w, 2)  // args_get = import 2
            emit_byte(w, OP_DROP())
            // Update vec len = argc - 1 (skip argv[0])
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argc)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            // Build String objects from null-terminated C strings
            // Loop: for i in 1..argc (skip argv[0])
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            let s_li = ctx.scratch_base + 3  // reuse bufsize
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_li)
            emit_byte(w, OP_BLOCK())  // outer block for break
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())   // loop
            emit_byte(w, 0x40)
            // Check i < argc
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_li)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argc)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, 0x0D)  // br_if
            emit_leb128_u(w, 1) // break outer
            // Get C string ptr: argv[i]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_argv)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_li)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            // C string ptr on stack; compute strlen
            let s_cstr = ctx.scratch_base + 4  // reuse argv
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_cstr)
            // Strlen: scan for null byte
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            let s_slen = ctx.scratch_base + 5  // reuse argv_buf
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_cstr)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)  // align
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, 0x0D)  // br_if
            emit_leb128_u(w, 1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, 0x0C)  // br
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            // Allocate Arukellt string: [len_i32, data...]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            let s_str = ctx.scratch_base + 4  // reuse
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_str)
            // Store length
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            // Copy string data
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())  // dest = str+4
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_cstr)    // src = cstr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)    // len
            emit_byte(w, 0xFC)  // memory.copy prefix
            emit_leb128_u(w, 10) // memory.copy opcode
            emit_leb128_u(w, 0) // src mem
            emit_leb128_u(w, 0) // dst mem
            // Bump heap
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_slen)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // Store string ptr+4 in vec data[i-1] (i starts at 1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_data)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_li)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())  // i-1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_str)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())  // ptr to string data (past len)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_li)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s_li)
            emit_byte(w, 0x0C)  // br loop
            emit_leb128_u(w, 0)
            emit_byte(w, 0x0B)  // end loop
            emit_byte(w, 0x0B)  // end block
            emit_byte(w, 0x0B)  // end if
            // Push vec ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_vec)

        } else if eq(clone(callee), "env::has_flag") {
            // env::has_flag(flag: String) -> bool
            // Simple: always false for now (args check would need iteration)
            emit_byte(w, OP_DROP()) // drop the flag string arg
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)  // false

        } else if eq(clone(callee), "env::arg_at") {
            // env::arg_at(n: i32) -> Option<String>
            // Returns None (tag=1, heap alloc) since we don't iterate args here
            emit_byte(w, OP_DROP()) // drop index arg
            // Alloc [tag=1] for None
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            let s_none = ctx.scratch_base + 0
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s_none)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)  // None tag = 1
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_leb128_u(w, 0)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s_none)

        } else if eq(clone(callee), "sum_i32") {
            // sum_i32(vec) -> i32: sum all elements
            let s0 = ctx.scratch_base + 0  // vec ptr
            let s1 = ctx.scratch_base + 1  // index
            let s2 = ctx.scratch_base + 2  // accumulator
            let s3 = ctx.scratch_base + 3  // data ptr
            let s4 = ctx.scratch_base + 4  // len
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // acc = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // len = vec[0]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // data_ptr = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 8)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if i >= len: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // acc += data[i*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // push result
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)

        } else if eq(clone(callee), "product_i32") {
            // product_i32(vec) -> i32: multiply all elements
            let s0 = ctx.scratch_base + 0
            let s1 = ctx.scratch_base + 1
            let s2 = ctx.scratch_base + 2
            let s3 = ctx.scratch_base + 3
            let s4 = ctx.scratch_base + 4
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // acc = 1
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // data_ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 8)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // acc *= data[i*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)

        } else if eq(clone(callee), "is_some") {
            // is_some(opt_ptr) -> bool: tag == 0 means Some
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_EQZ())

        } else if eq(clone(callee), "is_none") {
            // is_none(opt_ptr) -> bool: tag != 0 means None
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_NE())

        } else if eq(clone(callee), "abs") {
            // abs(x) -> i32: if x < 0 then 0 - x else x
            let s0 = ctx.scratch_base + 0
            emit_byte(w, OP_LOCAL_TEE())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_I32_LT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x7F)  // returns i32
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_ELSE())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "min") {
            // min(a, b) -> i32
            let s0 = ctx.scratch_base + 0
            let s1 = ctx.scratch_base + 1
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_LE_S())
            emit_byte(w, OP_SELECT())

        } else if eq(clone(callee), "max") {
            // max(a, b) -> i32
            let s0 = ctx.scratch_base + 0
            let s1 = ctx.scratch_base + 1
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_SELECT())

        } else if eq(clone(callee), "assert") {
            // assert(cond): trap if false
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_UNREACHABLE())
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "assert_eq") || eq(clone(callee), "assert_eq_i64") {
            // assert_eq(a, b): trap if a != b
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_UNREACHABLE())
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "assert_ne") {
            // assert_ne(a, b): trap if a == b
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_UNREACHABLE())
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "assert_eq_str") {
            // assert_eq_str(a, b): string compare, trap if different
            let s0 = ctx.scratch_base + 0  // str_a ptr
            let s1 = ctx.scratch_base + 1  // str_b ptr
            let s2 = ctx.scratch_base + 2  // len_a
            let s3 = ctx.scratch_base + 3  // index
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // len_a = str_a[-4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // if len_a != len_b: trap
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_UNREACHABLE())
            emit_byte(w, OP_END())
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if i >= len_a: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // if str_a[i] != str_b[i]: trap
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_UNREACHABLE())
            emit_byte(w, OP_END())
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "contains_String") {
            // contains_String(vec, needle) -> bool
            let s0 = ctx.scratch_base + 0  // vec ptr
            let s1 = ctx.scratch_base + 1  // needle ptr
            let s2 = ctx.scratch_base + 2  // index
            let s3 = ctx.scratch_base + 3  // len
            let s4 = ctx.scratch_base + 4  // data ptr
            let s5 = ctx.scratch_base + 5  // elem ptr
            let s6 = ctx.scratch_base + 6  // needle len
            let s7 = ctx.scratch_base + 7  // elem len
            let s8 = ctx.scratch_base + 8  // byte index
            let s9 = ctx.scratch_base + 9  // found flag
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // found = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s9)
            // len = vec[0]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // data_ptr = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 8)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // needle_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s6)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if i >= len || found: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s9)
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // elem_ptr = data[i*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            // elem_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s7)
            // if elem_len == needle_len: compare bytes
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s7)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            // assume match, check each byte
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s9)
            // byte_idx = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s8)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if byte_idx >= needle_len: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s6)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // if elem[byte_idx] != needle[byte_idx]: found=0, break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s9)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)  // break inner loop
            emit_byte(w, OP_END())
            // byte_idx++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s8)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block
            emit_byte(w, OP_END())  // end if len==
            // i++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())  // end loop
            emit_byte(w, OP_END())  // end block
            // push found flag
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s9)

        } else if eq(clone(callee), "reverse_String") {
            // reverse_String(vec): in-place swap of string pointers
            let s0 = ctx.scratch_base + 0  // vec ptr
            let s1 = ctx.scratch_base + 1  // left index
            let s2 = ctx.scratch_base + 2  // right index
            let s3 = ctx.scratch_base + 3  // data ptr
            let s4 = ctx.scratch_base + 4  // temp
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // data_ptr = vec[8]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 8)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // left = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            // right = len - 1
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // block { loop {
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if left >= right: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // temp = data[left*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // data[left*4] = data[right*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            // value: data[right*4]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // data[right*4] = temp
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // left++, right--
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())

        } else if eq(clone(callee), "starts_with") || eq(clone(callee), "text::starts_with") {
            // starts_with(str, prefix) -> bool
            let s0 = ctx.scratch_base + 0  // str ptr
            let s1 = ctx.scratch_base + 1  // prefix ptr
            let s2 = ctx.scratch_base + 2  // str len
            let s3 = ctx.scratch_base + 3  // prefix len
            let s4 = ctx.scratch_base + 4  // byte index
            let s5 = ctx.scratch_base + 5  // result
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // prefix_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // if prefix_len > str_len: return false
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_ELSE())
            // result = 1 (assume match)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // compare str[i] vs prefix[i]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)

        } else if eq(clone(callee), "ends_with") || eq(clone(callee), "text::ends_with") {
            // ends_with(str, suffix) -> bool
            let s0 = ctx.scratch_base + 0  // str ptr
            let s1 = ctx.scratch_base + 1  // suffix ptr
            let s2 = ctx.scratch_base + 2  // str len
            let s3 = ctx.scratch_base + 3  // suffix len
            let s4 = ctx.scratch_base + 4  // byte index
            let s5 = ctx.scratch_base + 5  // result
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // suffix_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // if suffix_len > str_len: return false
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_GT_S())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_ELSE())
            // result = 1 (assume match)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // compare str[str_len - suffix_len + i] vs suffix[i]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_I32_NE())
            emit_byte(w, OP_IF())
            emit_byte(w, 0x40)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 2)
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)

        } else if eq(clone(callee), "trim") || eq(clone(callee), "text::trim") {
            // trim(str) -> str: trim leading/trailing ASCII whitespace
            let s0 = ctx.scratch_base + 0  // str ptr
            let s1 = ctx.scratch_base + 1  // str len
            let s2 = ctx.scratch_base + 2  // start
            let s3 = ctx.scratch_base + 3  // end (exclusive)
            let s4 = ctx.scratch_base + 4  // new len
            let s5 = ctx.scratch_base + 5  // new ptr
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            // start = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // scan forward: while start < len && is_ws(str[start])
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            // if start >= len: break
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // ch = str[start]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            // is_ws: ch==32(space) || ch==9(tab) || ch==10(lf) || ch==13(cr)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)  // reuse s4 as temp
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 32)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 9)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 13)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)  // not ws → break
            // start++
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // end = len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // scan backward: while end > start && is_ws(str[end-1])
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_LE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // ch = str[end-1]
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_LOAD8_U())
            emit_byte(w, 0)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 32)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 9)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 10)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 13)
            emit_byte(w, OP_I32_EQ())
            emit_byte(w, OP_I32_OR())
            emit_byte(w, OP_I32_EQZ())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)  // not ws → break
            // end--
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 1)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_BR())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_END())
            emit_byte(w, OP_END())
            // new_len = end - start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // Allocate new string: [len][bytes]
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // new_ptr = heap + 4
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            // copy bytes
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)  // dest
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_ADD())  // src = str + start
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)  // count
            emit_byte(w, 0xFC)
            emit_leb128_u(w, 10)
            emit_byte(w, 0)
            emit_byte(w, 0)
            // bump heap: align(heap + 4 + new_len)
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 3)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, -4)
            emit_byte(w, OP_I32_AND())
            emit_byte(w, OP_GLOBAL_SET())
            emit_leb128_u(w, 0)
            // push new_ptr
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)

        } else if eq(clone(callee), "repeat") || eq(clone(callee), "text::repeat") {
            // repeat(str, count) -> str
            let s0 = ctx.scratch_base + 0  // str ptr
            let s1 = ctx.scratch_base + 1  // count
            let s2 = ctx.scratch_base + 2  // str len
            let s3 = ctx.scratch_base + 3  // total len
            let s4 = ctx.scratch_base + 4  // new ptr
            let s5 = ctx.scratch_base + 5  // iter index
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s0)
            // str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_SUB())
            emit_byte(w, OP_I32_LOAD())
            emit_byte(w, 2)
            emit_byte(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s2)
            // total_len = str_len * count
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s3)
            // Write length prefix
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s3)
            emit_byte(w, OP_I32_STORE())
            emit_byte(w, 2)
            emit_byte(w, 0)
            // new_ptr = heap + 4
            emit_byte(w, OP_GLOBAL_GET())
            emit_leb128_u(w, 0)
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 4)
            emit_byte(w, OP_I32_ADD())
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s4)
            // i = 0
            emit_byte(w, OP_I32_CONST())
            emit_leb128_s(w, 0)
            emit_byte(w, OP_LOCAL_SET())
            emit_leb128_u(w, s5)
            // loop: copy str_len bytes count times
            emit_byte(w, OP_BLOCK())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOOP())
            emit_byte(w, 0x40)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s1)
            emit_byte(w, OP_I32_GE_S())
            emit_byte(w, OP_BR_IF())
            emit_leb128_u(w, 1)
            // dest = new_ptr + i * str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s4)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s5)
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, OP_I32_MUL())
            emit_byte(w, OP_I32_ADD())
            // src = s0
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s0)
            // len = str_len
            emit_byte(w, OP_LOCAL_GET())
            emit_leb128_u(w, s2)
            emit_byte(w, 0xFC)
