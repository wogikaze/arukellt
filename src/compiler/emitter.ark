            let s_a = ctx.scratch_base       // ptr_a
            let s_b = ctx.scratch_base + 1   // ptr_b
            let s_la = ctx.scratch_base + 2  // len_a
            let s_rp = ctx.scratch_base + 3  // result_ptr
