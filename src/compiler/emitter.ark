// Arukellt Selfhost — Wasm Binary Emitter
//
// Generates a deterministic Wasm binary from MIR.
// Handles section layout, LEB128 encoding, and T1/T3 target split.
use std::host::stdio
use emit_opcodes
use emit_writer
use emit_scratch
use emit_inst_ctx
use emit_inst_const
use emit_inst_struct
use emit_inst_locals
use emit_inst_convert
use emit_inst_control
use emit_inst_arith
use emit_intrinsic_string
use emit_intrinsic_math
use emit_intrinsic_vec
use emit_intrinsic_io

// ── Wasm Module Emitter ──────────────────────────────────────────────────────
fn emit_wasm_module(mir: MirModule, target: String, opt_level: i32) -> Vec<i32> {
    let out = emit_writer::WasmWriter_new()
    emit_writer::emit_byte(out, 0)
    emit_writer::emit_byte(out, 97)
    emit_writer::emit_byte(out, 115)
    emit_writer::emit_byte(out, 109)
    emit_writer::emit_u32_le(out, 1)
    let fn_count = len(mir.functions)
    let str_count = len(mir.string_constants)
    let string_offsets = Vec_new_i32()
    let string_lengths = Vec_new_i32()
    let mut data_offset = emit_scratch::DATA_START()
    let mut si = 0
    while si < str_count {
        let s = get_unchecked(mir.string_constants, si)
        let slen = len(s)
        push(string_offsets, data_offset + 4)
        push(string_lengths, slen)
        data_offset = data_offset + 4 + slen
        si = si + 1
    }
    let mut true_idx = 0 - 1
    let mut false_idx = 0 - 1
    let mut bi = 0
    while bi < str_count {
        let bs = get_unchecked(mir.string_constants, bi)
        if eq(clone(bs), "true") {
            true_idx = bi
    }
        if eq(clone(bs), "false") {
            false_idx = bi
    }
        bi = bi + 1
    }
    if true_idx < 0 {
        true_idx = len(mir.string_constants)
        push(mir.string_constants, String_from("true"))
        push(string_offsets, data_offset + 4)
        push(string_lengths, 4)
        data_offset = data_offset + 4 + 4
    }
    if false_idx < 0 {
        false_idx = len(mir.string_constants)
        push(mir.string_constants, String_from("false"))
        push(string_offsets, data_offset + 4)
        push(string_lengths, 5)
        data_offset = data_offset + 4 + 5
    }
    let mut ctx = SelfEmitCtx { functions: mir.functions, string_offsets: string_offsets, string_lengths: string_lengths, string_values: mir.string_constants, scratch_base: 0, true_str_idx: true_idx, false_str_idx: false_idx, vec_locals: Vec_new_i32() }
    let mut needs_wrapper = 0
    let mut main_check_idx = 0
    while main_check_idx < fn_count {
        let mf = get_unchecked(mir.functions, main_check_idx)
        if eq(clone(mf.name), "main") || eq(clone(mf.name), "_start") {
            if mf.return_type != 0 {
                needs_wrapper = 1
    }
    }
        main_check_idx = main_check_idx + 1
    }
    let type_sec = emit_writer::WasmWriter_new()
    emit_writer::emit_leb128_u(type_sec, fn_count + emit_scratch::NUM_WASI_TYPES() + needs_wrapper)
    emit_writer::emit_byte(type_sec, 96)
    emit_writer::emit_leb128_u(type_sec, 4)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_leb128_u(type_sec, 1)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, 96)
    emit_writer::emit_leb128_u(type_sec, 2)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_leb128_u(type_sec, 1)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, 96)
    emit_writer::emit_leb128_u(type_sec, 9)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I64())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I64())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_leb128_u(type_sec, 1)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, 96)
    emit_writer::emit_leb128_u(type_sec, 1)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_leb128_u(type_sec, 1)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(type_sec, 96)
    emit_writer::emit_leb128_u(type_sec, 1)
    emit_writer::emit_byte(type_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_leb128_u(type_sec, 0)
    let mut i = 0
    while i < fn_count {
        let f = get_unchecked(mir.functions, i)
        emit_writer::emit_byte(type_sec, 96)
        let param_count = len(f.params)
        emit_writer::emit_leb128_u(type_sec, param_count)
        let mut p = 0
        while p < param_count {
            let param = get_unchecked(f.params, p)
            emit_writer::emit_byte(type_sec, val_type_to_wasm(param.val_type))
            p = p + 1
    }
        if f.return_type == 0 {
            emit_writer::emit_leb128_u(type_sec, 0)
        } else {
            emit_writer::emit_leb128_u(type_sec, 1)
            emit_writer::emit_byte(type_sec, val_type_to_wasm(f.return_type))
    }
        i = i + 1
    }
    if needs_wrapper == 1 {
        emit_writer::emit_byte(type_sec, 96)
        emit_writer::emit_leb128_u(type_sec, 0)
        emit_writer::emit_leb128_u(type_sec, 0)
    }
    emit_writer::emit_section(out, emit_opcodes::SEC_TYPE(), type_sec)
    let import_sec = emit_writer::WasmWriter_new()
    let wasi_module = String_from("wasi_snapshot_preview1")
    emit_writer::emit_leb128_u(import_sec, emit_scratch::NUM_WASI_IMPORTS())
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("fd_write"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 0)
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("args_sizes_get"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 1)
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("args_get"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 1)
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("path_open"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 2)
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("fd_read"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 0)
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("fd_close"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 3)
    emit_writer::emit_string(import_sec, clone(wasi_module))
    emit_writer::emit_string(import_sec, String_from("proc_exit"))
    emit_writer::emit_byte(import_sec, 0)
    emit_writer::emit_leb128_u(import_sec, 4)
    emit_writer::emit_section(out, emit_opcodes::SEC_IMPORT(), import_sec)
    let func_sec = emit_writer::WasmWriter_new()
    emit_writer::emit_leb128_u(func_sec, fn_count + needs_wrapper)
    let mut fi = 0
    while fi < fn_count {
        emit_writer::emit_leb128_u(func_sec, fi + emit_scratch::NUM_WASI_TYPES())
        fi = fi + 1
    }
    if needs_wrapper == 1 {
        emit_writer::emit_leb128_u(func_sec, fn_count + emit_scratch::NUM_WASI_TYPES())
    }
    emit_writer::emit_section(out, emit_opcodes::SEC_FUNCTION(), func_sec)
    let mem_sec = emit_writer::WasmWriter_new()
    emit_writer::emit_leb128_u(mem_sec, 1)
    emit_writer::emit_byte(mem_sec, 0)
    emit_writer::emit_leb128_u(mem_sec, 8192)
    emit_writer::emit_section(out, emit_opcodes::SEC_MEMORY(), mem_sec)
    let global_sec = emit_writer::WasmWriter_new()
    emit_writer::emit_leb128_u(global_sec, 1)
    emit_writer::emit_byte(global_sec, emit_opcodes::WASM_I32())
    emit_writer::emit_byte(global_sec, 1)
    emit_writer::emit_byte(global_sec, emit_opcodes::OP_I32_CONST())
    let heap_start = (data_offset + 7) / 8 * 8
    emit_writer::emit_leb128_s(global_sec, heap_start)
    emit_writer::emit_byte(global_sec, emit_opcodes::OP_END())
    emit_writer::emit_section(out, emit_opcodes::SEC_GLOBAL(), global_sec)
    let export_sec = emit_writer::WasmWriter_new()
    let mut export_count = 1
    let mut main_idx = 0 - 1
    let mut mi = 0
    while mi < fn_count {
        let f = get_unchecked(mir.functions, mi)
        if eq(clone(f.name), "main") || eq(clone(f.name), "_start") {
            main_idx = mi
        } else {
            let fname = clone(f.name)
            let flen = len(fname)
            if !(flen > 2 && char_at(fname, 0) == 95 && char_at(fname, 1) == 95) {
                export_count = export_count + 1
            }
        }
        mi = mi + 1
    }
    if main_idx >= 0 {
        export_count = export_count + 1
    }
    emit_writer::emit_leb128_u(export_sec, export_count)
    emit_writer::emit_string(export_sec, String_from("memory"))
    emit_writer::emit_byte(export_sec, 2)
    emit_writer::emit_leb128_u(export_sec, 0)
    if main_idx >= 0 {
        emit_writer::emit_string(export_sec, String_from("_start"))
        emit_writer::emit_byte(export_sec, 0)
        if needs_wrapper == 1 {
            emit_writer::emit_leb128_u(export_sec, fn_count + emit_scratch::NUM_WASI_IMPORTS())
        } else {
            emit_writer::emit_leb128_u(export_sec, main_idx + emit_scratch::NUM_WASI_IMPORTS())
    }
    }
    let mut exi = 0
    while exi < fn_count {
        let ef = get_unchecked(mir.functions, exi)
        let ef_name = clone(ef.name)
        let ef_len = len(ef_name)
        if eq(clone(ef_name), "main") || eq(clone(ef_name), "_start") {
        } else {
            if !(ef_len > 2 && char_at(ef_name, 0) == 95 && char_at(ef_name, 1) == 95) {
                emit_writer::emit_string(export_sec, ef_name)
                emit_writer::emit_byte(export_sec, 0)
                emit_writer::emit_leb128_u(export_sec, exi + emit_scratch::NUM_WASI_IMPORTS())
            }
        }
        exi = exi + 1
    }
    emit_writer::emit_section(out, emit_opcodes::SEC_EXPORT(), export_sec)
    let code_sec = emit_writer::WasmWriter_new()
    emit_writer::emit_leb128_u(code_sec, fn_count + needs_wrapper)
    let mut ci = 0
    while ci < fn_count {
        let f = get_unchecked(mir.functions, ci)
        let body = emit_writer::WasmWriter_new()
        let local_count = len(f.locals)
        let param_count = len(f.params)
        let body_local_count = local_count - param_count
        let extra_locals = 12
        let extra_f64_locals = 2
        let extra_i64_locals = 1
        emit_writer::emit_leb128_u(body, body_local_count + extra_locals + extra_f64_locals + extra_i64_locals)
        let mut li = param_count
        while li < local_count {
            let loc = get_unchecked(f.locals, li)
            emit_writer::emit_leb128_u(body, 1)
            emit_writer::emit_byte(body, val_type_to_wasm(loc.val_type))
            li = li + 1
    }
        let mut ei = 0
        while ei < extra_locals {
            emit_writer::emit_leb128_u(body, 1)
            emit_writer::emit_byte(body, emit_opcodes::WASM_I32())
            ei = ei + 1
    }
        let mut efi = 0
        while efi < extra_f64_locals {
            emit_writer::emit_leb128_u(body, 1)
            emit_writer::emit_byte(body, emit_opcodes::WASM_F64())
            efi = efi + 1
    }
        let mut eii = 0
        while eii < extra_i64_locals {
            emit_writer::emit_leb128_u(body, 1)
            emit_writer::emit_byte(body, emit_opcodes::WASM_I64())
            eii = eii + 1
    }
        ctx.scratch_base = local_count
        ctx.vec_locals = Vec_new_i32()
        let block_count = len(f.blocks)
        let mut bi = 0
        while bi < block_count {
            let block = get_unchecked(f.blocks, bi)
            let inst_count = len(block.instructions)
            let mut ii = 0
            while ii < inst_count {
                let inst = get_unchecked(block.instructions, ii)
                let mut prev_op = 0 - 1
                let mut prev_arg0 = 0 - 1
                if ii > 0 {
                    let prev = get_unchecked(block.instructions, ii - 1)
                    prev_op = prev.op
                    prev_arg0 = prev.arg0
                } else {
                    if bi > 0 {
                        let prev_block = get_unchecked(f.blocks, bi - 1)
                        let prev_count = len(prev_block.instructions)
                        if prev_count > 0 {
                            let prev = get_unchecked(prev_block.instructions, prev_count - 1)
                            prev_op = prev.op
                            prev_arg0 = prev.arg0
                        }
                    }
                }
                let mut next_op = 0 - 1
                let mut next_arg0 = 0 - 1
                let mut next_arg1 = 0 - 1
                let mut next2_op = 0 - 1
                if ii + 1 < inst_count {
                    let peek = get_unchecked(block.instructions, ii + 1)
                    next_op = peek.op
                    next_arg0 = peek.arg0
                    next_arg1 = peek.arg1
                } else {
                    if bi + 1 < block_count {
                        let next_block = get_unchecked(f.blocks, bi + 1)
                        if len(next_block.instructions) > 0 {
                            let peek = get_unchecked(next_block.instructions, 0)
                            next_op = peek.op
                            next_arg0 = peek.arg0
                            next_arg1 = peek.arg1
                        }
                    }
                }
                if ii + 2 < inst_count {
                    let peek2 = get_unchecked(block.instructions, ii + 2)
                    next2_op = peek2.op
                } else {
                    if ii + 1 < inst_count {
                        if bi + 1 < block_count {
                            let next_block2 = get_unchecked(f.blocks, bi + 1)
                            if len(next_block2.instructions) > 0 {
                                let peek2 = get_unchecked(next_block2.instructions, 0)
                                next2_op = peek2.op
                            }
                        }
                    } else {
                        if bi + 1 < block_count {
                            let next_block3 = get_unchecked(f.blocks, bi + 1)
                            if len(next_block3.instructions) > 1 {
                                let peek2 = get_unchecked(next_block3.instructions, 1)
                                next2_op = peek2.op
                            }
                        }
                    }
                }
                emit_mir_inst_ctx(body, inst, ctx, prev_op, prev_arg0, next_op, next_arg0, next_arg1, next2_op)
                ii = ii + 1
    }
            bi = bi + 1
    }
        emit_writer::emit_byte(body, emit_opcodes::OP_END())
        emit_writer::emit_leb128_u(code_sec, emit_writer::writer_size(body))
        emit_writer::emit_bytes(code_sec, body.bytes)
        ci = ci + 1
    }
    if needs_wrapper == 1 {
        let wrapper_body = emit_writer::WasmWriter_new()
        emit_writer::emit_leb128_u(wrapper_body, 0)
        emit_writer::emit_byte(wrapper_body, emit_opcodes::OP_CALL())
        emit_writer::emit_leb128_u(wrapper_body, main_idx + emit_scratch::NUM_WASI_IMPORTS())
        emit_writer::emit_byte(wrapper_body, emit_opcodes::OP_DROP())
        emit_writer::emit_byte(wrapper_body, emit_opcodes::OP_END())
        emit_writer::emit_leb128_u(code_sec, emit_writer::writer_size(wrapper_body))
        emit_writer::emit_bytes(code_sec, wrapper_body.bytes)
    }
    emit_writer::emit_section(out, emit_opcodes::SEC_CODE(), code_sec)
    let final_str_count = len(mir.string_constants)
    if final_str_count > 0 {
        let data_sec = emit_writer::WasmWriter_new()
        emit_writer::emit_leb128_u(data_sec, 1)
        emit_writer::emit_byte(data_sec, 0)
        emit_writer::emit_byte(data_sec, emit_opcodes::OP_I32_CONST())
        emit_writer::emit_leb128_s(data_sec, emit_scratch::DATA_START())
        emit_writer::emit_byte(data_sec, emit_opcodes::OP_END())
        let mut total_data = 0
        let mut ds = 0
        while ds < final_str_count {
            let s = get_unchecked(mir.string_constants, ds)
            total_data = total_data + 4 + len(s)
            ds = ds + 1
    }
        emit_writer::emit_leb128_u(data_sec, total_data)
        let mut ds2 = 0
        while ds2 < final_str_count {
            let s = get_unchecked(mir.string_constants, ds2)
            let slen = len(s)
            emit_writer::emit_byte(data_sec, slen % 256)
            emit_writer::emit_byte(data_sec, slen / 256 % 256)
            emit_writer::emit_byte(data_sec, slen / 65536 % 256)
            emit_writer::emit_byte(data_sec, slen / 16777216 % 256)
            let mut ci2 = 0
            while ci2 < slen {
                emit_writer::emit_byte(data_sec, char_at(s, ci2))
                ci2 = ci2 + 1
    }
            ds2 = ds2 + 1
    }
        emit_writer::emit_section(out, emit_opcodes::SEC_DATA(), data_sec)
    }
    out.bytes
    }

fn emit_store_result_if_needed(w: WasmWriter, inst: MirInst, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32, result_on_stack: bool) {
    if result_on_stack {
        if inst.dest < 0 {
            return
        }
        if inst.op == 10 && inst.dest == inst.arg0 {
            return
        }
        if inst.op == 10 && next_op == 11 {
            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
            emit_writer::emit_leb128_u(w, inst.dest)
            return
        }
        if inst.op == 40 && next_op == 11 && next_arg1 < 0 {
            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
            emit_writer::emit_leb128_u(w, inst.dest)
            return
        }
        if next_op == 42 {
            if next_arg0 < 0 {
                return
            }
        }
        if next_op >= 20 && next_op <= 39 {
            return
        }
        if next_op == 33 {
            return
        }
        if next_op == 34 {
            return
        }
        if next_op == 45 {
            return
        }
        if next_op == 46 {
            return
        }
        if next_op == 58 {
            return
        }
        if next_op == 40 {
            return
        }
        if next_op == 61 {
            return
        }
        if next_op == 10 {
            if next2_op == 10 {
                return
            }
            if next2_op == 1 {
                return
            }
            if next2_op == 2 {
                return
            }
            if next2_op == 3 {
                return
            }
            if next2_op == 5 {
                return
            }
            if next2_op == 40 {
                return
            }
            if next2_op >= 20 && next2_op <= 39 {
                return
            }
            if next2_op == 33 {
                return
            }
            if next2_op == 34 {
                return
            }
            if next2_op == 45 {
                return
            }
            if next2_op == 46 {
                return
            }
            if next2_op == 58 {
                return
            }
            if next2_op == 61 {
                return
            }
        }
        if next_op == 1 {
            return
        }
        if next_op == 2 {
            return
        }
        if next_op == 3 {
            return
        }
        if next_op == 5 {
            return
        }
        if next_op == 11 {
            if next2_op == 11 {
                emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
                emit_writer::emit_leb128_u(w, inst.dest)
                return
            }
            if next_arg1 < 0 {
                return
            }
            if inst.op == 10 && inst.arg0 == next_arg1 {
                return
            }
        }
        if next_op == 70 {
            return
        }
        if next_op == 55 {
            return
        }
        if next_op == 51 {
            return
        }
        if inst.op == 10 {
            emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_TEE())
            emit_writer::emit_leb128_u(w, inst.dest)
            return
        }
        emit_writer::emit_byte(w, emit_opcodes::OP_LOCAL_SET())
        emit_writer::emit_leb128_u(w, inst.dest)
    }
}

fn is_eq_callee_name(callee: String) -> bool {
    if len(callee) != 2 {
        return false
    }
    char_at(clone(callee), 0) == 101 && char_at(clone(callee), 1) == 113
}

// ── Wasm Module Emitter ──────────────────────────────────────────────────────
// Scratch memory layout for WASI fd_write
fn emit_mir_inst_ctx(w: WasmWriter, inst: MirInst, ctx: SelfEmitCtx, prev_op: i32, prev_arg0: i32, next_op: i32, next_arg0: i32, next_arg1: i32, next2_op: i32) {
    if inst.op == 1 {
        emit_inst_const::emit_const_i32(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 2 {
        emit_inst_const::emit_const_i64(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 3 {
        emit_inst_const::emit_const_f64(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 5 {
        emit_inst_const::emit_const_string(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 10 {
        if next_op == 62 {
            return
        }
        emit_inst_locals::emit_local_get(w, inst, ctx)
