        emit_inst_control::emit_if(w, inst, ctx)
        return
    }
    if inst.op == 56 {
        emit_inst_control::emit_else(w, inst, ctx)
        return
    }
    if inst.op == 57 {
        emit_inst_control::emit_end(w, inst, ctx)
        return
    }
    if inst.op == 33 {
        emit_inst_convert::emit_neg(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 34 {
        emit_inst_convert::emit_eqz(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 58 {
        emit_inst_convert::emit_eqz_dup(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 60 {
        emit_inst_struct::emit_struct_new(w, inst, ctx)
        return
    }
    if inst.op == 61 {
        emit_inst_struct::emit_struct_get(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 62 {
        emit_inst_struct::emit_struct_set(w, inst, ctx)
        return
    }
    if inst.op == 63 {
        emit_inst_struct::emit_array_new(w, inst, ctx)
        return
    }
    if inst.op == 64 {
        emit_inst_struct::emit_array_get(w, inst, ctx)
        emit_store_result_if_needed(w, inst, next_op, next_arg0, next_arg1, next2_op, true)
        return
    }
    if inst.op == 65 {
        emit_inst_struct::emit_array_set(w, inst, ctx)
        return
    }
}
fn val_type_to_wasm(vt: i32) -> i32 {
    if vt == 1 {
        return emit_opcodes::WASM_I32()
    }
    if vt == 2 {
        return emit_opcodes::WASM_I64()
    }
    if vt == 3 {
        return emit_opcodes::WASM_F64()
    }
    if vt == 4 {
        return emit_opcodes::WASM_I32()
    }
    emit_opcodes::WASM_I32()
    }

// ── Public API (used by driver) ──────────────────────────────────────────────
pub fn emit_wasm(mir: MirModule, target: String, opt_level: i32) -> Vec<i32> {
    emit_wasm_module(mir, target, opt_level)
    }

