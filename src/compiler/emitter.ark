fn resolve_fn_index(ctx: SelfEmitCtx, name: String) -> i32 {
let count = len(ctx.functions)
let mut i = 0
while i < count {
let f = get_unchecked(ctx.functions, i)
if eq(clone(f.name), clone(name)) {
return i
}
i = i + 1
}
let short_name = strip_module_prefix(clone(name))
if !eq(clone(short_name), clone(name)) {
let mut j = 0
while j < count {
let f = get_unchecked(ctx.functions, j)
if eq(clone(f.name), clone(short_name)) {
return j
