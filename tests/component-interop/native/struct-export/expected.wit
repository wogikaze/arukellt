// Expected WIT for struct-export scenario

package arukellt:component-interop@1.0.0;

interface struct-functions {
  record point {
    x: s32,
    y: s32,
  }

  /// Create a point
  create-point: func(x: s32, y: s32) -> point;

  /// Calculate distance between two points
  point-distance: func(p1: point, p2: point) -> float64;
}

world struct-export {
  export struct-functions;
}
