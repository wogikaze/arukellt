// Component interop test fixture: struct (record) exports via canonical ABI.
//
// Tests that all-scalar-field structs can be exported through the Component
// Model using canonical ABI adapter functions (flat scalars ↔ struct.new/get).
struct Point {
    x: i32,
    y: i32,
}

pub fn distance_sq(p: Point) -> i32 {
    p.x * p.x + p.y * p.y
}

pub fn add_points(a: Point, b: Point) -> Point {
    Point { x: a.x + b.x, y: a.y + b.y }
}

fn main() {
}
