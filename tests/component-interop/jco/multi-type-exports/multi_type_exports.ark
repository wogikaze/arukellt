// Component interop test fixture: mixed-type multi-export world.
//
// Tests that a single component can export functions with different
// scalar types (i32, i64, f64, bool) through the Component Model ABI.
// This validates heterogeneous function signatures in one world.

pub fn add_i32(a: i32, b: i32) -> i32 {
    a + b
}

pub fn add_i64(a: i64, b: i64) -> i64 {
    a + b
}

pub fn mul_f64(a: f64, b: f64) -> f64 {
    a * b
}

pub fn is_positive(x: i32) -> bool {
    x > 0
}

pub fn abs_i32(x: i32) -> i32 {
    if x < 0 {
        -x
    } else {
        x
    }
}

fn main() {}
