use std::host::stdio
use std::json

fn main() {
    // Differential test: parse then stringify, compare against known-correct golden output
    // Golden: {"a":1,"b":false,"c":null}
    let raw = "{\"a\":1,\"b\":false,\"c\":null}"
    match json::parse(raw) {
        Result::Ok(v) => {
            let out = json::stringify(v)
            // Verify individual fields match golden values
            match json::json_get(v, "a") {
                Option::Some(av) => {
                    match json::json_as_i32(av) {
                        Option::Some(n) => stdio::println(i32_to_string(n)),
                        None => stdio::println("not number"),
                    }
                },
                None => stdio::println("not found"),
            }
            match json::json_get(v, "b") {
                Option::Some(bv) => {
                    match json::json_as_bool(bv) {
                        Option::Some(b) => stdio::println(bool_to_string(b)),
                        None => stdio::println("not bool"),
                    }
                },
                None => stdio::println("not found"),
            }
            match json::json_get(v, "c") {
                Option::Some(cv) => stdio::println(bool_to_string(json::is_null(cv))),
                None => stdio::println("not found"),
            }
            // Re-parse the stringified output and verify it still has same structure
            match json::parse(out) {
                Result::Ok(v2) => {
                    stdio::println(bool_to_string(json::is_object(v2)))
                },
                Result::Err(e) => stdio::println(concat("differential re-parse error:", e)),
            }
        },
        Result::Err(e) => stdio::println(concat("error:", e)),
    }
}
// differential test: mixed-type object stringify output re-parses correctly
