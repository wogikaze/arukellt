use std::host::stdio
use std::json

fn main() {
    // null scalar
    match json::parse("null") {
        Result::Ok(v) => {
            stdio::println((json::is_null(v)).to_string())
            stdio::println(json::stringify(v))
        },
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
    // bool true
    match json::parse("true") {
        Result::Ok(v) => {
            match json::json_as_bool(v) {
                Option::Some(b) => stdio::println((b).to_string()),
                None => stdio::println("not bool"),
            }
        },
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
    // bool false
    match json::parse("false") {
        Result::Ok(v) => {
            match json::json_as_bool(v) {
                Option::Some(b) => stdio::println((b).to_string()),
                None => stdio::println("not bool"),
            }
        },
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
    // number zero
    match json::parse("0") {
        Result::Ok(v) => {
            match json::json_as_i32(v) {
                Option::Some(n) => stdio::println((n).to_string()),
                None => stdio::println("not number"),
            }
        },
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
    // negative number
    match json::parse("-42") {
        Result::Ok(v) => {
            match json::json_as_i32(v) {
                Option::Some(n) => stdio::println((n).to_string()),
                None => stdio::println("not number"),
            }
        },
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
    // type checks
    match json::parse("null") {
        Result::Ok(v) => stdio::println((json::is_bool(v)).to_string()),
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
    match json::parse("true") {
        Result::Ok(v) => stdio::println((json::is_bool(v)).to_string()),
        Result::Err(e) => stdio::println(concat("error:", json::parse_error_message(e))),
    }
}
// scalar edge cases: null, bool, number, type predicate checks
