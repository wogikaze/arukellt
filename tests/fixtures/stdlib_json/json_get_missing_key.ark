use std::json
use std::test

fn main() {
    match json::parse("{\"a\":1}") {
        Result::Ok(v) => {
            match json::json_get(v, "missing") {
                Option::Some(_) => panic("expected None for missing key"),
                None => {},
            }
            match json::json_get(v, "a") {
                Option::Some(_) => {},
                None => panic("expected Some for existing key a"),
            }
        },
        Result::Err(e) => panic(concat("parse failed: ", json::parse_error_message(e))),
    }
}
