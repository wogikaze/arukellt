use std::json
use std::test

fn main() {
    match json::parse("{}") {
        Result::Ok(v) => {
            test::assert_true(json::is_object(v))
            test::assert_false(json::is_array(v))
            match json::json_get(v, "x") {
                Option::Some(_) => panic("expected None for empty object"),
                None => {},
            }
        },
        Result::Err(e) => panic(concat("parse {} failed: ", json::parse_error_message(e))),
    }
}
