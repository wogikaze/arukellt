use std::json
use std::test

fn main() {
    match json::parse("null") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "null"),
        Result::Err(e) => panic(concat("parse null failed: ", json::parse_error_message(e))),
    }
    match json::parse("true") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "true"),
        Result::Err(e) => panic(concat("parse true failed: ", json::parse_error_message(e))),
    }
    match json::parse("42") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "42"),
        Result::Err(e) => panic(concat("parse 42 failed: ", json::parse_error_message(e))),
    }
    match json::parse("\"hi\"") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "\"hi\""),
        Result::Err(e) => panic(concat("parse string failed: ", json::parse_error_message(e))),
    }
}
