use std::json
use std::test

fn main() {
    match json::parse("42") {
        Result::Ok(v) => match json::json_as_i32(v) {
            Option::Some(n) => test::assert_eq_i32(n, 42),
            None => panic("expected Some(42)"),
        },
        Result::Err(e) => panic(concat("parse failed: ", json::parse_error_message(e))),
    }
    match json::parse("-7") {
        Result::Ok(v) => match json::json_as_i32(v) {
            Option::Some(n) => test::assert_eq_i32(n, -7),
            None => panic("expected Some(-7)"),
        },
        Result::Err(e) => panic(concat("parse -7 failed: ", json::parse_error_message(e))),
    }
    // Type mismatch: json_as_i32 on non-number returns None
    match json::parse("true") {
        Result::Ok(v) => match json::json_as_i32(v) {
            Option::Some(_) => panic("expected None for non-number"),
            None => {},
        },
        Result::Err(e) => panic(concat("parse true failed: ", json::parse_error_message(e))),
    }
}
