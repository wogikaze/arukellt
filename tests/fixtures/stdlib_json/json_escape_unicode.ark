use std::json
use std::test

fn main() {
    match json::parse("\"\\u0041\"") {
        Result::Ok(v) => match json::json_as_string(v) {
            Option::Some(s) => test::assert_eq_string(s, "A"),
            None => panic("expected string"),
        },
        Result::Err(e) => panic(concat("parse unicode failed: ", json::parse_error_message(e))),
    }
}
