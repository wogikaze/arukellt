use std::json
use std::test

fn main() {
    match json::parse("\"hello\"") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "\"hello\""),
        Result::Err(e) => panic(concat("parse failed: ", json::parse_error_message(e))),
    }
    match json::parse("\"\"") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "\"\""),
        Result::Err(e) => panic(concat("parse empty failed: ", json::parse_error_message(e))),
    }
    match json::parse("\"a\\nb\"") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "\"a\\nb\""),
        Result::Err(e) => panic(concat("parse escaped failed: ", json::parse_error_message(e))),
    }
}
