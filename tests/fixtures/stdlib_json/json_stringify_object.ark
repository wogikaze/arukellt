use std::json
use std::test

fn main() {
    match json::parse("{\"a\":1}") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "{\"a\":1}"),
        Result::Err(e) => panic(concat("parse object failed: ", json::parse_error_message(e))),
    }
    match json::parse("{}") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "{}"),
        Result::Err(e) => panic(concat("parse empty object failed: ", json::parse_error_message(e))),
    }
    match json::parse("{\"a\":1,\"b\":true}") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "{\"a\":1,\"b\":true}"),
        Result::Err(e) => panic(concat("parse multi object failed: ", json::parse_error_message(e))),
    }
}
