use std::json
use std::test

fn main() {
    match json::parse("[1,2]") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 0), "[\n1,\n2\n]"),
        Result::Err(e) => panic(concat("parse failed: ", json::parse_error_message(e))),
    }
    match json::parse("{\"a\":1}") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 0), "{\n\"a\": 1\n}"),
        Result::Err(e) => panic(concat("parse object failed: ", json::parse_error_message(e))),
    }
}
