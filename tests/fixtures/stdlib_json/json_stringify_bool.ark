use std::json
use std::test

fn main() {
    match json::parse("true") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "true"),
        Result::Err(e) => panic(concat("parse true failed: ", json::parse_error_message(e))),
    }
    match json::parse("false") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "false"),
        Result::Err(e) => panic(concat("parse false failed: ", json::parse_error_message(e))),
    }
}
