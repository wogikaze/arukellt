use std::json
use std::test

fn main() {
    match json::parse("42") {
        Result::Ok(v) => {
            match json::json_get_index(v, 0) {
                Option::Some(_) => panic("expected None: get_index on non-array"),
                None => {},
            }
        },
        Result::Err(e) => panic(concat("parse failed: ", json::parse_error_message(e))),
    }
    match json::parse("{\"a\":1}") {
        Result::Ok(v) => {
            match json::json_get_index(v, 0) {
                Option::Some(_) => panic("expected None: get_index on object"),
                None => {},
            }
        },
        Result::Err(e) => panic(concat("parse object failed: ", json::parse_error_message(e))),
    }
}
