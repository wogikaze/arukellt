use std::json
use std::test

fn main() {
    match json::parse("42") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "42"),
        Result::Err(e) => panic(concat("parse 42 failed: ", json::parse_error_message(e))),
    }
    match json::parse("0") {
        Result::Ok(v) => test::assert_eq_string(json::stringify(v), "0"),
        Result::Err(e) => panic(concat("parse 0 failed: ", json::parse_error_message(e))),
    }
}
