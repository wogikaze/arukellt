use std::json
use std::test

fn main() {
    match json::parse("\"a\\tb\\nc\\\\d\\\"e\"") {
        Result::Ok(v) => match json::json_as_string(v) {
            Option::Some(s) => test::assert_eq_string(s, "a\tb\nc\\d\"e"),
            None => panic("expected string"),
        },
        Result::Err(e) => panic(concat("parse multiple escapes failed: ", json::parse_error_message(e))),
    }
}
