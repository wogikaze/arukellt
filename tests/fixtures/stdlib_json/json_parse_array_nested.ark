use std::json
use std::test

fn main() {
    match json::parse("[[1,2],[3,4]]") {
        Result::Ok(v) => {
            match json::json_get_index(v, 0) {
                Option::Some(inner) => {
                    test::assert_true(json::is_array(inner))
                    match json::json_get_index(inner, 0) {
                        Option::Some(e) => match json::json_as_i32(e) {
                            Option::Some(n) => test::assert_eq_i32(n, 1),
                            None => panic("expected 1"),
                        },
                        None => panic("expected inner element 0"),
                    }
                },
                None => panic("expected outer element 0"),
            }
            match json::json_get_index(v, 1) {
                Option::Some(inner) => match json::json_get_index(inner, 1) {
                    Option::Some(e) => match json::json_as_i32(e) {
                        Option::Some(n) => test::assert_eq_i32(n, 4),
                        None => panic("expected 4"),
                    },
                    None => panic("expected inner element 1"),
                },
                None => panic("expected outer element 1"),
            }
        },
        Result::Err(e) => panic(concat("parse nested array failed: ", json::parse_error_message(e))),
    }
}
