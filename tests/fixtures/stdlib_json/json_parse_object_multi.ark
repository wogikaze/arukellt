use std::json
use std::test

fn main() {
    match json::parse("{\"a\":1,\"b\":true,\"c\":null,\"d\":\"str\"}") {
        Result::Ok(v) => {
            match json::json_get(v, "a") {
                Option::Some(fv) => match json::json_as_i32(fv) {
                    Option::Some(n) => test::assert_eq_i32(n, 1),
                    None => panic("expected number for a"),
                },
                None => panic("expected key a"),
            }
            match json::json_get(v, "b") {
                Option::Some(fv) => match json::json_as_bool(fv) {
                    Option::Some(b) => test::assert_eq_bool(b, true),
                    None => panic("expected bool for b"),
                },
                None => panic("expected key b"),
            }
            match json::json_get(v, "c") {
                Option::Some(fv) => test::assert_true(json::is_null(fv)),
                None => panic("expected key c"),
            }
            match json::json_get(v, "d") {
                Option::Some(fv) => match json::json_as_string(fv) {
                    Option::Some(s) => test::assert_eq_string(s, "str"),
                    None => panic("expected string for d"),
                },
                None => panic("expected key d"),
            }
        },
        Result::Err(e) => panic(concat("parse multi-object failed: ", json::parse_error_message(e))),
    }
}
