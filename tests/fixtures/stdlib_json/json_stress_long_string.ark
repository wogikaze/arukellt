use std::json
use std::test

fn main() {
    let raw = "\"abcdefghijklmnopqrstuvwxyz0123456789ABCDEFGHIJKLMNOPQRSTUVWXYZ\""
    match json::parse(raw) {
        Result::Ok(v) => match json::json_as_string(v) {
            Option::Some(s) => test::assert_eq_i32(len(s), 62),
            None => panic("expected string"),
        },
        Result::Err(e) => panic(concat("parse long string failed: ", json::parse_error_message(e))),
    }
}
