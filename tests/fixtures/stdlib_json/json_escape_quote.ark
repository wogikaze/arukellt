use std::json
use std::test

fn main() {
    match json::parse("\"say \\\"hi\\\"\"") {
        Result::Ok(v) => match json::json_as_string(v) {
            Option::Some(s) => test::assert_eq_string(s, "say \"hi\""),
            None => panic("expected string"),
        },
        Result::Err(e) => panic(concat("parse quote failed: ", json::parse_error_message(e))),
    }
}
