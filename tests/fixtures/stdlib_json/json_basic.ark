use std::json

fn main() {
    println(json::json_stringify_i32(42))
    println(json::json_stringify_bool(true))
    println(json::json_stringify_string("hello"))
    println(json::json_null())
    println(i32_to_string(json::json_parse_i32("123")))
    println(bool_to_string(json::json_parse_bool("true")))
}
