use std::host::stdio
use std::json

fn main() {
    stdio::println(json::json_stringify_i32(42))
    stdio::println(json::json_stringify_bool(true))
    stdio::println(json::json_stringify_string("hello"))
    stdio::println(json::json_null())
    stdio::println(i32_to_string(json::json_parse_i32("123")))
    stdio::println(bool_to_string(json::json_parse_bool("true")))
}
