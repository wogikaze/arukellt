use std::json
use std::test

fn main() {
    match json::parse("1e5") {
        Result::Ok(v) => {
            test::assert_true(json::is_number(v))
        },
        Result::Err(e) => panic(concat("parse 1e5 failed: ", json::parse_error_message(e))),
    }
    match json::parse("1.5e3") {
        Result::Ok(v) => test::assert_true(json::is_number(v)),
        Result::Err(e) => panic(concat("parse 1.5e3 failed: ", json::parse_error_message(e))),
    }
    match json::parse("2E10") {
        Result::Ok(v) => test::assert_true(json::is_number(v)),
        Result::Err(e) => panic(concat("parse 2E10 failed: ", json::parse_error_message(e))),
    }
}
