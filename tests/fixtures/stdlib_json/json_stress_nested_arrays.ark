use std::json
use std::test

fn main() {
    match json::parse("[[[[1]]]]") {
        Result::Ok(v) => {
            match json::json_get_index(v, 0) {
                Option::Some(l1) => match json::json_get_index(l1, 0) {
                    Option::Some(l2) => match json::json_get_index(l2, 0) {
                        Option::Some(l3) => match json::json_get_index(l3, 0) {
                            Option::Some(l4) => match json::json_as_i32(l4) {
                                Option::Some(n) => test::assert_eq_i32(n, 1),
                                None => panic("expected number"),
                            },
                            None => panic("expected element"),
                        },
                        None => panic("expected element"),
                    },
                    None => panic("expected element"),
                },
                None => panic("expected element"),
            }
        },
        Result::Err(e) => panic(concat("parse deeply nested arrays failed: ", json::parse_error_message(e))),
    }
}
