use std::json
use std::test

fn main() {
    match json::parse("[]") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "[]"),
        Result::Err(e) => panic(concat("parse [] failed: ", json::parse_error_message(e))),
    }
    match json::parse("{}") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "{}"),
        Result::Err(e) => panic(concat("parse {} failed: ", json::parse_error_message(e))),
    }
}
