use std::json
use std::test

fn main() {
    match json::parse("\"line1\\nline2\"") {
        Result::Ok(v) => match json::json_as_string(v) {
            Option::Some(s) => test::assert_eq_string(s, "line1\nline2"),
            None => panic("expected string"),
        },
        Result::Err(e) => panic(concat("parse newline failed: ", json::parse_error_message(e))),
    }
}
