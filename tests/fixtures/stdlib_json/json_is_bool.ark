use std::json
use std::test

fn main() {
    match json::parse("true") {
        Result::Ok(v) => {
            test::assert_true(json::is_bool(v))
            test::assert_false(json::is_null(v))
            test::assert_false(json::is_number(v))
            test::assert_false(json::is_string(v))
            test::assert_false(json::is_array(v))
            test::assert_false(json::is_object(v))
        },
        Result::Err(e) => panic(concat("parse failed: ", json::parse_error_message(e))),
    }
    match json::parse("false") {
        Result::Ok(v) => test::assert_true(json::is_bool(v)),
        Result::Err(e) => panic(concat("parse false failed: ", json::parse_error_message(e))),
    }
}
