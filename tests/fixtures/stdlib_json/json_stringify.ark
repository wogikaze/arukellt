use std::host::stdio
use std::json

fn main() {
    match json::parse("null") {
        Result::Ok(v) => stdio::println(json::stringify(v)),
        Result::Err(e) => stdio::println(concat("error:", e)),
    }
    match json::parse("true") {
        Result::Ok(v) => stdio::println(json::stringify(v)),
        Result::Err(e) => stdio::println(concat("error:", e)),
    }
    match json::parse("123") {
        Result::Ok(v) => stdio::println(json::stringify(v)),
        Result::Err(e) => stdio::println(concat("error:", e)),
    }
    match json::parse("\"world\"") {
        Result::Ok(v) => stdio::println(json::stringify(v)),
        Result::Err(e) => stdio::println(concat("error:", e)),
    }
    stdio::println(json::json_encode_string("hello"))
    stdio::println(json::json_encode_string("a\"b"))
}
// stringify null → "null"
// stringify bool
// stringify number
// stringify string (round-trip)
// json_encode_string produces valid JSON string literal
