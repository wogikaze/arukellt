use std::json
use std::test

fn main() {
    match json::parse("\"a\\fb\"") {
        Result::Ok(v) => match json::json_as_string(v) {
            Option::Some(s) => test::assert_eq_i32(len(s), 3),
            None => panic("expected string"),
        },
        Result::Err(e) => panic(concat("parse formfeed failed: ", json::parse_error_message(e))),
    }
}
