use std::json
use std::host::stdio

fn main() {
    // i32 roundtrip: stringify then parse
    let n = 42
    let s = json::json_stringify_i32(n)
    let back = json::json_parse_i32(s)
    stdio::println(i32_to_string(back))

    // bool roundtrip: stringify then parse
    let b = true
    let bs = json::json_stringify_bool(b)
    let bb = json::json_parse_bool(bs)
    stdio::println(bool_to_string(bb))

    // negative number roundtrip
    let neg = -7
    let ns = json::json_stringify_i32(neg)
    let nb = json::json_parse_i32(ns)
    stdio::println(i32_to_string(nb))

    // zero roundtrip
    let z = 0
    let zs = json::json_stringify_i32(z)
    let zb = json::json_parse_i32(zs)
    stdio::println(i32_to_string(zb))

    // false roundtrip
    let f = false
    let fs = json::json_stringify_bool(f)
    let fb = json::json_parse_bool(fs)
    stdio::println(bool_to_string(fb))

    // string roundtrip
    let st = json::json_stringify_string("hello world")
    stdio::println(st)

    // null
    stdio::println(json::json_null())
}
