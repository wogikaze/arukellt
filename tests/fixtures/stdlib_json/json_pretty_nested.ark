use std::json
use std::test

fn main() {
    match json::parse("{\"a\":[1,2]}") {
        Result::Ok(v) => test::assert_eq_string(json::stringify_pretty(v, 2), "{\n  \"a\": [\n    1,\n    2\n  ]\n}"),
        Result::Err(e) => panic(concat("parse nested failed: ", json::parse_error_message(e))),
    }
}
