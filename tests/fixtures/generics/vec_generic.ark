use std::host::stdio
fn first<T>(v: Vec<T>) -> Option<T> {
    if len(v) > 0 {
        Some(get_unchecked(v, 0))
    } else {
        None
    }
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 99)
    match first(v) {
        Some(val) => stdio::println(i32_to_string(val)),
        None => stdio::println("empty"),
    }
}
