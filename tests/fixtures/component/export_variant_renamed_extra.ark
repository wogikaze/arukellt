// The Shape adapter supports exactly one Shape -> f64 export.
enum Shape {
    Circle(f64),
    Square(f64),
}

pub fn measure(s: Shape) -> f64 {
    match s {
        Shape::Circle(r) => 3.14159 * r * r,
        Shape::Square(side) => side * side,
    }
}

pub fn perimeter_hint(s: Shape) -> f64 {
    match s {
        Shape::Circle(r) => 6.28318 * r,
        Shape::Square(side) => 4.0 * side,
    }
}

fn main() {
}
