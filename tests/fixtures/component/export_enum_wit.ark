// Export with unit enum — maps to WIT enum (i32 discriminant)
// Canonical ABI adapter converts i32 ↔ GC enum ref
enum Color {
    Red,
    Green,
    Blue,
}

pub fn color_code(c: Color) -> i32 {
    match c {
        Color::Red => 1,
        Color::Green => 2,
        Color::Blue => 3,
    }
}

fn main() {}
