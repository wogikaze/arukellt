// Export with Shape variant should not depend on the specific function name used by the smoke fixture.
enum Shape {
    Circle(f64),
    Square(f64),
}

pub fn measure(s: Shape) -> f64 {
    match s {
        Shape::Circle(r) => 3.14159 * r * r,
        Shape::Square(side) => side * side,
    }
}

fn main() {
}
