// Resource GC: verify handle table does not leak after repeated allocations
// The handle table uses a bounded i32 counter; GC prevents exhaustion.
// This tests that many resource create/drop cycles complete without error.

resource GcHandle {
    id: i32,
}

pub fn make_handle(val: i32) -> GcHandle {
    GcHandle { id: val }
}

pub fn consume(h: GcHandle) -> i32 {
    h.id
}

fn main() {
    let mut i = 0
    while i < 1000 {
        let h = make_handle(i)
        let val = consume(h)
        if val != i {
            // Should not happen
            let _ = 0 - 1
        }
        i = i + 1
    }
}
