use std::bytes
use std::host::stdio

fn main() {
    let b: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(b, 10)
    bytes::bytes_push(b, 20)
    bytes::bytes_push(b, 30)
    bytes::bytes_push(b, 40)
    bytes::bytes_push(b, 50)
    let sub: Vec<i32> = bytes::bytes_slice(b, 1, 4)
    stdio::println((bytes::bytes_len(sub)).to_string())
    stdio::println((bytes::bytes_get(sub, 0)).to_string())
    stdio::println((bytes::bytes_get(sub, 1)).to_string())
    stdio::println((bytes::bytes_get(sub, 2)).to_string())
    let empty: Vec<i32> = bytes::bytes_slice(b, 2, 2)
    stdio::println((bytes::bytes_len(empty)).to_string())
    let full: Vec<i32> = bytes::bytes_slice(b, 0, 5)
    stdio::println((bytes::bytes_len(full)).to_string())
    stdio::println((bytes::bytes_eq(b, full)).to_string())
}
// bytes_slice: extract sub-range
// Empty slice
// Full slice (copy)
