use std::bytes
use std::host::stdio

fn main() {
    let b: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(b, 72)
    bytes::bytes_push(b, 101)
    bytes::bytes_push(b, 108)
    stdio::println((bytes::bytes_len(b)).to_string())
    stdio::println((bytes::bytes_get(b, 0)).to_string())
    let h: String = bytes::hex_encode(b)
    stdio::println(h)
    let decoded: Vec<i32> = bytes::hex_decode("48656c")
    stdio::println((bytes::bytes_len(decoded)).to_string())
    stdio::println((bytes::bytes_get(decoded, 0)).to_string())
    let leb: Vec<i32> = bytes::leb128_encode_u32(624485)
    stdio::println((bytes::bytes_len(leb)).to_string())
    stdio::println((bytes::bytes_get(leb, 0)).to_string())
    stdio::println((bytes::bytes_get(leb, 1)).to_string())
    stdio::println((bytes::bytes_get(leb, 2)).to_string())
    let le: Vec<i32> = bytes::u32_to_le_bytes(305419896)
    stdio::println((bytes::bytes_get(le, 0)).to_string())
    stdio::println((bytes::bytes_get(le, 1)).to_string())
    let rt: i32 = bytes::u32_from_le_bytes(le)
    stdio::println((rt).to_string())
}
// bytes_new and push
// hex encode
// hex decode roundtrip
// leb128 encode u32
// endian u32 LE
