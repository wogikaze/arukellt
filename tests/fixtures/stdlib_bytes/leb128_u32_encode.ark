use std::bytes
use std::test

fn main() {
    let leb: Vec<i32> = bytes::leb128_encode_u32(624485)
    test::assert_eq_i32(bytes::bytes_len(leb), 3)
    test::assert_eq_i32(bytes::bytes_get(leb, 0), 229)
    test::assert_eq_i32(bytes::bytes_get(leb, 1), 142)
    test::assert_eq_i32(bytes::bytes_get(leb, 2), 38)
}
