use std::bytes
use std::test

fn main() {
    let b: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(b, 1)
    bytes::bytes_push(b, 2)
    bytes::bytes_push(b, 3)
    bytes::bytes_push(b, 4)
    bytes::bytes_push(b, 5)
    let enc: String = bytes::base64_encode(b)
    let dec: Vec<i32> = bytes::base64_decode(enc)
    test::assert_true(bytes::bytes_eq(b, dec))
}
