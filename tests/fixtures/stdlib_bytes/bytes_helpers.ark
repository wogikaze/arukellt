use std::bytes
use std::host::stdio

fn main() {
    let b = bytes::bytes_from_string("hi")
    stdio::println((bytes::bytes_len(b)).to_string())
    let s = bytes::string_from_bytes(b)
    stdio::println(s)
    let a = bytes::bytes_new()
    bytes::bytes_push(a, 1)
    bytes::bytes_push(a, 2)
    let c = bytes::bytes_new()
    bytes::bytes_push(c, 3)
    bytes::bytes_push(c, 4)
    let merged = bytes::bytes_concat(a, c)
    stdio::println((bytes::bytes_len(merged)).to_string())
    stdio::println((bytes::bytes_get(merged, 0)).to_string())
    stdio::println((bytes::bytes_get(merged, 2)).to_string())
    stdio::println((bytes::bytes_get(merged, 3)).to_string())
    let sub = bytes::bytes_slice(merged, 1, 3)
    stdio::println((bytes::bytes_len(sub)).to_string())
    stdio::println((bytes::bytes_get(sub, 0)).to_string())
    stdio::println((bytes::bytes_get(sub, 1)).to_string())
    let empty = bytes::bytes_new()
    let from_empty = bytes::bytes_from_string("")
    stdio::println((bytes::bytes_len(from_empty)).to_string())
    let s2 = bytes::string_from_bytes(empty)
    stdio::println((len(s2)).to_string())
    let hb = bytes::bytes_new()
    bytes::bytes_push(hb, 0)
    bytes::bytes_push(hb, 255)
    bytes::bytes_push(hb, 127)
    let hex = bytes::hex_encode(hb)
    stdio::println(hex)
    let decoded = bytes::hex_decode(hex)
    stdio::println((bytes::bytes_eq(hb, decoded)).to_string())
}
// bytes_from_string / string_from_bytes roundtrip
// bytes_concat
// bytes_slice
// empty operations
// hex roundtrip
