use std::bytes
use std::host::stdio

fn main() {
    let le16: Vec<i32> = bytes::u16_to_le_bytes(513)
    stdio::println((bytes::bytes_get(le16, 0)).to_string())
    stdio::println((bytes::bytes_get(le16, 1)).to_string())
    let rt16: i32 = bytes::u16_from_le_bytes(le16)
    stdio::println((rt16).to_string())
    let le32: Vec<i32> = bytes::u32_to_le_bytes(305419896)
    stdio::println((bytes::bytes_len(le32)).to_string())
    stdio::println((bytes::bytes_get(le32, 0)).to_string())
    let rt32: i32 = bytes::u32_from_le_bytes(le32)
    stdio::println((rt32).to_string())
    let be32: Vec<i32> = bytes::u32_to_be_bytes(16909060)
    stdio::println((bytes::bytes_get(be32, 0)).to_string())
    stdio::println((bytes::bytes_get(be32, 1)).to_string())
    stdio::println((bytes::bytes_get(be32, 2)).to_string())
    stdio::println((bytes::bytes_get(be32, 3)).to_string())
    let rt32be: i32 = bytes::u32_from_be_bytes(be32)
    stdio::println((rt32be).to_string())
}
// u16 little-endian roundtrip
// u32 little-endian roundtrip
// u32 big-endian roundtrip
