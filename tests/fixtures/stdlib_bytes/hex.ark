use std::bytes
use std::host::stdio

fn main() {
    // hex_encode
    let b: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(b, 0)
    bytes::bytes_push(b, 255)
    bytes::bytes_push(b, 16)
    bytes::bytes_push(b, 171)
    let hex: String = bytes::hex_encode(b)
    stdio::println(hex)

    // hex_decode roundtrip
    let decoded: Vec<i32> = bytes::hex_decode(hex)
    stdio::println(i32_to_string(bytes::bytes_len(decoded)))
    stdio::println(bool_to_string(bytes::bytes_eq(b, decoded)))

    // hex_decode: uppercase
    let upper: Vec<i32> = bytes::hex_decode("DEADBEEF")
    stdio::println(i32_to_string(bytes::bytes_len(upper)))
    stdio::println(i32_to_string(bytes::bytes_get(upper, 0)))
    stdio::println(i32_to_string(bytes::bytes_get(upper, 3)))

    // empty
    let empty: Vec<i32> = bytes::hex_decode("")
    stdio::println(i32_to_string(bytes::bytes_len(empty)))

    let empty_enc: String = bytes::hex_encode(bytes::bytes_new())
    stdio::println(bool_to_string(eq(empty_enc, "")))
}
