use std::bytes
use std::host::stdio

fn main() {
    let b: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(b, 0)
    bytes::bytes_push(b, 255)
    bytes::bytes_push(b, 16)
    bytes::bytes_push(b, 171)
    let hex: String = bytes::hex_encode(b)
    stdio::println(hex)
    let decoded: Vec<i32> = bytes::hex_decode(hex)
    stdio::println((bytes::bytes_len(decoded)).to_string())
    stdio::println((bytes::bytes_eq(b, decoded)).to_string())
    let upper: Vec<i32> = bytes::hex_decode("DEADBEEF")
    stdio::println((bytes::bytes_len(upper)).to_string())
    stdio::println((bytes::bytes_get(upper, 0)).to_string())
    stdio::println((bytes::bytes_get(upper, 3)).to_string())
    let empty: Vec<i32> = bytes::hex_decode("")
    stdio::println((bytes::bytes_len(empty)).to_string())
    let empty_enc: String = bytes::hex_encode(bytes::bytes_new())
    stdio::println((eq(empty_enc, "")).to_string())
}
// hex_encode
// hex_decode roundtrip
// hex_decode: uppercase
// empty
