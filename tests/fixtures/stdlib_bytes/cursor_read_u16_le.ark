use std::bytes
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 20)
    bytes::bytes_push(data, 30)
    let c: Vec<i32> = bytes::cursor_new(data)
    test::assert_eq_i32(bytes::read_u16_le(c), 7700)
    test::assert_eq_i32(bytes::cursor_remaining(c), 0)
}
