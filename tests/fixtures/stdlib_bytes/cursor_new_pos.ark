use std::bytes
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 1)
    bytes::bytes_push(data, 2)
    let c: Vec<i32> = bytes::cursor_new(data)
    test::assert_eq_i32(bytes::cursor_pos(c), 0)
    test::assert_eq_i32(bytes::cursor_remaining(c), 2)
}
