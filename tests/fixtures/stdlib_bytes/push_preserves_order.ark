use std::bytes
use std::test

fn main() {
    let b: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(b, 10)
    bytes::bytes_push(b, 20)
    bytes::bytes_push(b, 30)
    test::assert_eq_i32(bytes::bytes_get(b, 0), 10)
    test::assert_eq_i32(bytes::bytes_get(b, 1), 20)
    test::assert_eq_i32(bytes::bytes_get(b, 2), 30)
}
