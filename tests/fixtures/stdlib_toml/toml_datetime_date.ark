use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("d = 1979-05-27")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "d") {
            Option::Some(v) => match toml::toml_as_string(v) {
                Option::Some(s) => test::assert_eq_string(s, "1979-05-27"),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// date literal YYYY-MM-DD stored as String
