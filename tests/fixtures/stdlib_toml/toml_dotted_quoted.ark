use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("a.\"b c\".d = 1")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "a") {
            Option::Some(a) => match toml::toml_get(a, "b c") {
                Option::Some(bc) => match toml::toml_get(bc, "d") {
                    Option::Some(v) => match toml::toml_as_int(v) {
                        Option::Some(n) => test::assert_eq_i32(n, 1),
                        None => assert(false),
                    },
                    None => assert(false),
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// dotted key with quoted segment containing space
