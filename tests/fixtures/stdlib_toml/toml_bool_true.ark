use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("flag = true")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "flag") {
            Option::Some(v) => match toml::toml_as_bool(v) {
                Option::Some(b) => test::assert_true(b),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// boolean true parses to Boolean
