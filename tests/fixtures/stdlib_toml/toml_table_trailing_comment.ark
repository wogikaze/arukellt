use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("[server] # comment\nhost = \"x\"")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "server") {
            Option::Some(s) => match toml::toml_get(s, "host") {
                Option::Some(v) => match toml::toml_as_string(v) {
                    Option::Some(str) => test::assert_eq_string(str, "x"),
                    None => assert(false),
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// trailing comment after table header is ignored
