use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("a = [1, 2, 3]")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "a") {
            Option::Some(v) => test::assert_eq_string(toml::toml_stringify(v), "[1, 2, 3]"),
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// toml_stringify on Array produces bracketed comma-separated values
