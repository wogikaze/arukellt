use std::host::stdio
use std::toml
use std::test

fn main() {
    let content = "name = \"arukellt\"\nport = 8080"
    let val = toml::find_toml_value(content, "name")
    test::assert_eq_string(val, "arukellt")
    stdio::println("OK")
}
// find_toml_value extracts unquoted double-quoted string value
