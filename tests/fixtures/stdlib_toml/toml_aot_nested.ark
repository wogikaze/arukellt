use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("[[servers]]\nname = \"a\"\n[servers.ports]\nhttp = 80")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "servers") {
            Option::Some(v) => match toml::toml_as_array(v) {
                Option::Some(arr) => {
                    test::assert_eq_i32(len(arr), 1)
                    let first = get_unchecked(arr, 0)
                    match toml::toml_get(first, "ports") {
                        Option::Some(ports) => match toml::toml_get(ports, "http") {
                            Option::Some(h) => match toml::toml_as_int(h) {
                                Option::Some(n) => test::assert_eq_i32(n, 80),
                                None => assert(false),
                            },
                            None => assert(false),
                        },
                        None => assert(false),
                    }
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// [servers.ports] sub-table attaches to last array-of-tables entry
