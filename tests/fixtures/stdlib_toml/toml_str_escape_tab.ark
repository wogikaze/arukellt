use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("val = \"a\\tb\"")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "val") {
            Option::Some(v) => match toml::toml_as_string(v) {
                Option::Some(s) => test::assert_eq_string(s, "a\tb"),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// \\t escape decodes to tab in basic string
