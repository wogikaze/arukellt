use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("[a.b.c]\nval = 7")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "a") {
            Option::Some(a) => match toml::toml_get(a, "b") {
                Option::Some(b) => match toml::toml_get(b, "c") {
                    Option::Some(c) => match toml::toml_get(c, "val") {
                        Option::Some(v) => match toml::toml_as_int(v) {
                            Option::Some(n) => test::assert_eq_i32(n, 7),
                            None => assert(false),
                        },
                        None => assert(false),
                    },
                    None => assert(false),
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// dotted table header [a.b.c] creates nested tables
