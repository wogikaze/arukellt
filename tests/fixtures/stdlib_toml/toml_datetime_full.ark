use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("dt = 1979-05-27T07:32:00Z")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "dt") {
            Option::Some(v) => match toml::toml_as_string(v) {
                Option::Some(s) => test::assert_eq_string(s, "1979-05-27T07:32:00Z"),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// full RFC3339 datetime stored as String
