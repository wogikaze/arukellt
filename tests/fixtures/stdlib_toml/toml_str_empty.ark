use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("name = \"\"")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "name") {
            Option::Some(v) => match toml::toml_as_string(v) {
                Option::Some(s) => test::assert_eq_string(s, ""),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// empty basic string parses to empty String
