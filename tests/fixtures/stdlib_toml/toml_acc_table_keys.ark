use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("a = 1\nb = 2\nc = 3")
    match t {
        Result::Ok(table) => {
            let keys = toml::toml_table_keys(table)
            test::assert_eq_i32(len(keys), 3)
            test::assert_eq_string(get_unchecked(keys, 0), "a")
            test::assert_eq_string(get_unchecked(keys, 1), "b")
            test::assert_eq_string(get_unchecked(keys, 2), "c")
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// toml_table_keys returns all keys in order
