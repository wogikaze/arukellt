use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("t = 07:32:00")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "t") {
            Option::Some(v) => match toml::toml_as_string(v) {
                Option::Some(s) => test::assert_eq_string(s, "07:32:00"),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// time literal HH:MM:SS stored as String
