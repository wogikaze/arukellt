use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("val = 0xDEAD")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "val") {
            Option::Some(v) => match toml::toml_as_int(v) {
                Option::Some(n) => test::assert_eq_i32(n, 57005),
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// uppercase hex 0xDEAD parses to 57005
