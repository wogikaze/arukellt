use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("names = [\"a\", \"b\"]")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "names") {
            Option::Some(v) => match toml::toml_as_array(v) {
                Option::Some(arr) => {
                    test::assert_eq_i32(len(arr), 2)
                    match toml::toml_as_string(get_unchecked(arr, 0)) {
                        Option::Some(s) => test::assert_eq_string(s, "a"),
                        None => assert(false),
                    }
                    match toml::toml_as_string(get_unchecked(arr, 1)) {
                        Option::Some(s) => test::assert_eq_string(s, "b"),
                        None => assert(false),
                    }
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// array of strings parses with correct element values
