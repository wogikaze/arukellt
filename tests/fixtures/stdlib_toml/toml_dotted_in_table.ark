use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("[section]\na.b = 5")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "section") {
            Option::Some(s) => match toml::toml_get(s, "a") {
                Option::Some(a) => match toml::toml_get(a, "b") {
                    Option::Some(v) => match toml::toml_as_int(v) {
                        Option::Some(n) => test::assert_eq_i32(n, 5),
                        None => assert(false),
                    },
                    None => assert(false),
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// dotted key inside [section] nests within the section table
