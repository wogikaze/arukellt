use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("[\"my table\"]\nval = 1")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "my table") {
            Option::Some(s) => match toml::toml_get(s, "val") {
                Option::Some(v) => match toml::toml_as_int(v) {
                    Option::Some(n) => test::assert_eq_i32(n, 1),
                    None => assert(false),
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// quoted key in table header supports spaces
