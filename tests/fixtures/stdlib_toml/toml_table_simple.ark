use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("[server]\nhost = \"localhost\"\nport = 8080")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "server") {
            Option::Some(server) => {
                match toml::toml_get(server, "host") {
                    Option::Some(v) => match toml::toml_as_string(v) {
                        Option::Some(s) => test::assert_eq_string(s, "localhost"),
                        None => assert(false),
                    },
                    None => assert(false),
                }
                match toml::toml_get(server, "port") {
                    Option::Some(v) => match toml::toml_as_int(v) {
                        Option::Some(n) => test::assert_eq_i32(n, 8080),
                        None => assert(false),
                    },
                    None => assert(false),
                }
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// [table] header creates a nested table with key=value entries
