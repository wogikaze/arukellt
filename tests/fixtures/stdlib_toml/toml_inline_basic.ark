use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("point = { x = 1, y = 2 }")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "point") {
            Option::Some(pt) => {
                match toml::toml_get(pt, "x") {
                    Option::Some(v) => match toml::toml_as_int(v) {
                        Option::Some(n) => test::assert_eq_i32(n, 1),
                        None => assert(false),
                    },
                    None => assert(false),
                }
                match toml::toml_get(pt, "y") {
                    Option::Some(v) => match toml::toml_as_int(v) {
                        Option::Some(n) => test::assert_eq_i32(n, 2),
                        None => assert(false),
                    },
                    None => assert(false),
                }
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// inline table { x = 1, y = 2 } parses to nested table
