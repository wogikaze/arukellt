use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("m = [[1, 2], [3, 4]]")
    match t {
        Result::Ok(table) => match toml::toml_get(table, "m") {
            Option::Some(v) => match toml::toml_as_array(v) {
                Option::Some(arr) => {
                    test::assert_eq_i32(len(arr), 2)
                    match toml::toml_as_array(get_unchecked(arr, 0)) {
                        Option::Some(inner) => test::assert_eq_i32(len(inner), 2),
                        None => assert(false),
                    }
                },
                None => assert(false),
            },
            None => assert(false),
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// nested array of arrays parses
