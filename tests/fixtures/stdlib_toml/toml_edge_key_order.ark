use std::host::stdio
use std::toml
use std::test

fn main() {
    let t = toml::toml_parse("zebra = 1\napple = 2\nmango = 3")
    match t {
        Result::Ok(table) => {
            let keys = toml::toml_table_keys(table)
            test::assert_eq_i32(len(keys), 3)
            test::assert_eq_string(get_unchecked(keys, 0), "zebra")
            test::assert_eq_string(get_unchecked(keys, 2), "mango")
        },
        Result::Err(_) => assert(false),
    }
    stdio::println("OK")
}
// table_keys preserves source insertion order
