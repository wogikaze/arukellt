enum AppError {
    Io(String),
    Parse,
}

impl From for AppError {
    fn from(e: String) -> AppError {
        AppError::Io(e)
    }
}

fn read_data() -> Result<String, String> {
    Err(String_from("file not found"))
}

fn process() -> Result<i32, AppError> {
    let s = read_data()?
    Ok(42)
}

fn main() -> i32 {
    match process() {
        Ok(n) => println(n),
        Err(e) => {
            match e {
                AppError::Io(msg) => println(msg),
                AppError::Parse => println(String_from("parse error")),
            }
        }
    }
    0
}
