struct Point {
    x: i32,
    y: i32,
}

fn main() {
    let p = Point { x: 10, y: 20 }
    let f = |n: i32| -> i32 {
        p.x + p.y + n
    }
    println(i32_to_string(f(5)))

    let s = String_from("hello ")
    let g = |x: i32| -> String {
        concat(s, i32_to_string(x))
    }
    println(g(42))
}
