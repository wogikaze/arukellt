use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

fn main() {
    let p = Point { x: 10, y: 20 }
    let f = |n: i32| -> i32 {
        p.x + p.y + n
    }
    stdio::println((f(5)).to_string())
    let s = String_from("hello ")
    let g = |x: i32| -> String {
        concat(s, (x).to_string())
    }
    stdio::println(g(42))
}
