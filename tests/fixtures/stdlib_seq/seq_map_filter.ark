use std::host::stdio
use std::seq

fn double(x: i32) -> i32 {
    x * 2
}

fn is_even(x: i32) -> bool {
    x / 2 * 2 == x
}

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    let doubled: Vec<i32> = seq::map_i32_i32(v, double)
    stdio::println((len(doubled)).to_string())
    stdio::println((get_unchecked(doubled, 0)).to_string())
    stdio::println((get_unchecked(doubled, 4)).to_string())
    let evens: Vec<i32> = seq::filter_i32(v, is_even)
    stdio::println((len(evens)).to_string())
    stdio::println((get_unchecked(evens, 0)).to_string())
    stdio::println((get_unchecked(evens, 1)).to_string())
}
// map: double each element
// filter: keep even numbers
