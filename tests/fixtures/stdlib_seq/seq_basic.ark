use std::seq

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 3)
    push(v, 1)
    push(v, 4)
    push(v, 1)
    push(v, 5)

    println(i32_to_string(seq::sum_i32(v)))
    println(i32_to_string(seq::min_i32(v)))
    println(i32_to_string(seq::max_i32(v)))
    println(bool_to_string(seq::seq_contains(v, 4)))
    println(bool_to_string(seq::seq_contains(v, 9)))
    println(i32_to_string(seq::count_eq(v, 1)))

    // binary search on sorted vec
    sort_i32(v)
    let idx: i32 = seq::binary_search(v, 4)
    println(i32_to_string(idx))

    // unique
    let u: Vec<i32> = seq::unique(v)
    println(i32_to_string(len(u)))
}
