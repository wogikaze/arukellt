use std::host::stdio
use std::seq

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 3)
    push(v, 1)
    push(v, 4)
    push(v, 1)
    push(v, 5)
    stdio::println((seq::sum_i32(v)).to_string())
    stdio::println((seq::min_i32(v)).to_string())
    stdio::println((seq::max_i32(v)).to_string())
    stdio::println((seq::seq_contains(v, 4)).to_string())
    stdio::println((seq::seq_contains(v, 9)).to_string())
    stdio::println((seq::count_eq(v, 1)).to_string())
    sort_i32(v)
    let idx: i32 = seq::binary_search(v, 4)
    stdio::println((idx).to_string())
    let u: Vec<i32> = seq::unique(v)
    stdio::println((len(u)).to_string())
}
// binary search on sorted vec
// unique
