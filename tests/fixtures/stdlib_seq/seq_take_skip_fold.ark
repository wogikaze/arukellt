use std::host::stdio
use std::seq

fn add(a: i32, b: i32) -> i32 {
    a + b
}

fn mul(a: i32, b: i32) -> i32 {
    a * b
}

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    let taken: Vec<i32> = seq::take_i32(v, 3)
    stdio::println((len(taken)).to_string())
    stdio::println((get_unchecked(taken, 0)).to_string())
    stdio::println((get_unchecked(taken, 2)).to_string())
    let skipped: Vec<i32> = seq::skip_i32(v, 2)
    stdio::println((len(skipped)).to_string())
    stdio::println((get_unchecked(skipped, 0)).to_string())
    stdio::println((get_unchecked(skipped, 2)).to_string())
    let total: i32 = seq::fold_i32_i32(v, 0, add)
    stdio::println((total).to_string())
    let product: i32 = seq::fold_i32_i32(v, 1, mul)
    stdio::println((product).to_string())
    let all: Vec<i32> = seq::take_i32(v, 100)
    stdio::println((len(all)).to_string())
    let empty: Vec<i32> = seq::skip_i32(v, 100)
    stdio::println((len(empty)).to_string())
}
// take: first 3 elements
// skip: skip first 2 elements
// fold: sum
// fold: product
// take more than length: should return all
// skip more than length: should return empty
