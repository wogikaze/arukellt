// Demonstrates the new module-based API style (v3+).
// Prefer explicit `use std::*` imports over the deprecated prelude forms.
use std::host::stdio
use std::text

fn main() {
    let s: String = text::concat("Hello", ", Arukellt!")
    stdio::println(s)
    let parts: Vec<String> = text::split("one,two,three", ",")
    stdio::println(i32_to_string(len(parts)))
    let rejoined: String = text::join(parts, " | ")
    stdio::println(rejoined)
}
// New API: text::concat instead of prelude concat()
// New API: text::split instead of prelude split()
// New API: text::join instead of prelude join()
