// Issue #603 acceptance: trait-resolved calls produce deterministic concrete
// callees. A generic function with a trait bound is instantiated with distinct
// concrete types, and the lowering produces deterministic mangled callees.
// No unresolved trait dispatch reaches the backend.
use std::host::stdio

trait Identity {
    fn id(x: i32) -> i32
}

struct Doubler {
    value: i32,
}

impl Identity for Doubler {
    fn id(x: i32) -> i32 {
        x * 2
    }
}

struct Tripler {
    value: i32,
}

impl Identity for Tripler {
    fn id(x: i32) -> i32 {
        x * 3
    }
}

fn apply_identity_impl(x: i32) -> i32 {
    Doubler::id(x)
}

fn main() {
    // apply_identity_impl calls Doubler::id (from Identity trait impl)
    // This produces 10 * 2 = 20
    let r1: i32 = apply_identity_impl(10)
    stdio::println(i32_to_string(r1))
    stdio::println(String_from("trait method resolve OK."))
}
// apply_identity_impl → Doubler::id (via Identity trait impl) → x*2
// The trait method call resolves to a deterministic concrete callee:
// the Doubler::id function, not an unresolved trait dispatch.
