// Issue #688 acceptance: std::core traits (Eq, Display, Hash) callable
// through generic dispatch, not only via concrete wrappers.
//
// This fixture defines generic functions bounded by std::core traits and
// calls trait methods on the bounded parameters. The fixture proves that
// existing Eq/Display/Hash trait definitions in std::core are callable
// through generic dispatch (monomorphization-based static dispatch).
use std::host::stdio
use std::core::cmp
use std::core::convert
use std::core::hash

// Generic function that uses Display trait dispatch.
// `x.to_string()` must resolve to the correct impl after monomorphization.
fn print_value<T: Display>(x: T) {
    let s: String = x.to_string()
    stdio::println(s)
}

// Generic function that uses Eq trait dispatch.
// `a.eq(b)` must resolve to the correct impl after monomorphization.
fn check_eq<T: Eq>(a: T, b: T) -> bool {
    a.eq(b)
}

// Generic function that uses Hash trait dispatch.
// `x.hash()` must resolve to the correct impl after monomorphization.
fn compute_hash<T: Hash>(x: T) -> i32 {
    x.hash()
}

fn main() {
    // Display dispatch: i32 and String both impl Display in std::core::convert
    print_value(42)
    print_value(String_from("hello"))

    // Eq dispatch: i32 and String both impl Eq in std::core::cmp
    let eq_i32 = check_eq(1, 1)
    stdio::println(if eq_i32 { String_from("i32 eq: true") } else { String_from("i32 eq: false") } )

    let eq_str = check_eq(String_from("abc"), String_from("abc"))
    stdio::println(if eq_str { String_from("String eq: true") } else { String_from("String eq: false") } )

    // Negative case: different values should not be equal
    let neq = check_eq(1, 2)
    stdio::println(if neq { String_from("1==2: true") } else { String_from("1==2: false") } )

    // Hash dispatch: i32 and String both impl Hash in std::core::hash
    let h_i32 = compute_hash(42)
    stdio::println(h_i32)

    let h_str = compute_hash(String_from("hello"))
    stdio::println(h_str)
}
