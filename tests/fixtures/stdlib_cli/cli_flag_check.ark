use std::cli
use std::host::stdio

fn main() {
    // arg_count and parse_args return empty vectors in test runner
    stdio::println(i32_to_string(cli::arg_count()))

    // has_flag: "--verbose" not in empty arg vector
    stdio::println(bool_to_string(cli::has_flag("--verbose")))

    // arg_at: out of range
    match cli::arg_at(0) {
        Some(s) => stdio::println(s),
        None => stdio::println("no arg"),
    }

    // flag: explicit vector test
    let args = Vec_new_String()
    push(args, "--debug")
    push(args, "--output")
    push(args, "out.txt")
    stdio::println(bool_to_string(cli::flag(args, "--debug")))
    stdio::println(bool_to_string(cli::flag(args, "--verbose")))

    // option: --output out.txt
    match cli::option(args, "--output") {
        Some(v) => stdio::println(v),
        None => stdio::println("not found"),
    }

    // option: embedded = form
    let args2 = Vec_new_String()
    push(args2, "--name=world")
    match cli::option(args2, "--name") {
        Some(v) => stdio::println(v),
        None => stdio::println("not found"),
    }
}
