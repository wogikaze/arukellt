use std::host::stdio

enum Expr {
    Num(i32),
    Add(i32, i32),
    Sub(i32, i32),
    Mul(i32, i32),
}

fn eval(e: Expr) -> i32 {
    match e {
        Expr::Num(n) => n,
        Expr::Add(a, b) => a + b,
        Expr::Sub(a, b) => a - b,
        Expr::Mul(a, b) => a * b,
    }
}

fn main() {
    stdio::println((eval(Expr::Num(42))).to_string())
    stdio::println((eval(Expr::Add(10, 20))).to_string())
    stdio::println((eval(Expr::Sub(50, 8))).to_string())
    stdio::println((eval(Expr::Mul(6, 7))).to_string())
}
