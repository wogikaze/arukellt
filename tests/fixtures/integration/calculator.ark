enum Expr {
    Num(i32),
    Add(i32, i32),
    Sub(i32, i32),
    Mul(i32, i32),
}

fn eval(e: Expr) -> i32 {
    match e {
        Expr::Num(n) => n,
        Expr::Add(a, b) => a + b,
        Expr::Sub(a, b) => a - b,
        Expr::Mul(a, b) => a * b,
    }
}

fn main() {
    println(i32_to_string(eval(Expr::Num(42))))
    println(i32_to_string(eval(Expr::Add(10, 20))))
    println(i32_to_string(eval(Expr::Sub(50, 8))))
    println(i32_to_string(eval(Expr::Mul(6, 7))))
}
