fn fib(n: i32) -> i32 {
    if n <= 1 {
        return n
    }
    let mut a: i32 = 0
    let mut b: i32 = 1
    let mut i: i32 = 2
    while i <= n {
        let next: i32 = a + b
        a = b
        b = next
        i = i + 1
    }
    b
}

fn main() {
    let mut i: i32 = 0
    while i <= 10 {
        println(i32_to_string(fib(i)))
        i = i + 1
    }
}
