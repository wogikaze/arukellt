fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 5)
    push(v, 3)
    push(v, 8)
    push(v, 1)
    push(v, 9)
    push(v, 2)
    push(v, 7)
    push(v, 4)
    push(v, 6)
    push(v, 10)
    sort_i32(v)
    let mut parts: Vec<String> = Vec_new_String()
    let mut i: i32 = 0
    while i < len(v) {
        push(parts, i32_to_string(get_unchecked(v, i)))
        i = i + 1
    }
    println(join(parts, String_from(" ")))
}
