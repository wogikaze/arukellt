use std::host::env
use std::host::stdio

fn main() {
    let a = env::args()
    stdio::println((len(a)).to_string())
    stdio::println((env::arg_count()).to_string())
    let d = match env::var("ARUKELLT_NONEXISTENT_ENV_VAR_XYZ") {
        Option::Some(s) => s,
        None => String_from("default_val"),
    }
    stdio::println(d)
    let w = env::var("ARUKELLT_NONEXISTENT_ENV_VAR_XYZ")
    match w {
        Option::Some(s) => stdio::println("unexpected"),
        None => stdio::println("none"),
    }
}
// var with default: use match on env::var
// var: unknown var should return None
