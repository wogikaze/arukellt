use std::host::env
use std::host::stdio

fn main() {
    let v = env::var("PATH")
    match v {
        Option::Some(s) => stdio::println("found PATH"),
        None => stdio::println("PATH not found"),
    }
    let w = env::var("ARUKELLT_NONEXISTENT_XYZ")
    match w {
        Option::Some(s) => stdio::println("unexpected"),
        None => stdio::println("none as expected"),
    }
}
// PATH is virtually always set on Unix systems
// Nonexistent variable
