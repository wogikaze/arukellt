use std::host::stdio

fn main() {
    let x = 42
    let name = String_from("Alice")
    stdio::println((x).to_string())
    stdio::println(name)
    let mut counter = 0
    counter = counter + 1
    stdio::println((counter).to_string())
    let n: i32 = 10
    let s: String = String_from("hello")
    stdio::println((n).to_string())
    stdio::println(s)
}
