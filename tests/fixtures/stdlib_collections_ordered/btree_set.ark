use std::collections::ordered
use std::host::stdio

fn main() {
    let s: Vec<i32> = ordered::btree_set_new()
    stdio::println((ordered::btree_set_insert(s, 30)).to_string())
    stdio::println((ordered::btree_set_insert(s, 10)).to_string())
    stdio::println((ordered::btree_set_insert(s, 20)).to_string())
    stdio::println((ordered::btree_set_insert(s, 10)).to_string())
    stdio::println((ordered::btree_set_len(s)).to_string())
    stdio::println((ordered::btree_set_contains(s, 10)).to_string())
    stdio::println((ordered::btree_set_contains(s, 20)).to_string())
    stdio::println((ordered::btree_set_contains(s, 99)).to_string())
}
