use std::collections::ordered
use std::host::stdio

fn main() {
    let m: Vec<i32> = ordered::btree_new()
    ordered::btree_insert(m, 30, 300)
    ordered::btree_insert(m, 10, 100)
    ordered::btree_insert(m, 20, 200)
    stdio::println((ordered::btree_len(m)).to_string())
    stdio::println((ordered::btree_get(m, 10)).to_string())
    stdio::println((ordered::btree_get(m, 20)).to_string())
    stdio::println((ordered::btree_get(m, 30)).to_string())
    stdio::println((ordered::btree_contains_key(m, 20)).to_string())
    stdio::println((ordered::btree_contains_key(m, 99)).to_string())
    ordered::btree_remove(m, 20)
    stdio::println((ordered::btree_len(m)).to_string())
    stdio::println((ordered::btree_contains_key(m, 20)).to_string())
}
