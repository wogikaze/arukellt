use std::collections::ordered
use std::host::stdio

fn main() {
    let bs: Vec<i32> = ordered::bitset_new()
    ordered::bitset_set(bs, 5)
    ordered::bitset_set(bs, 42)
    ordered::bitset_set(bs, 100)
    stdio::println((ordered::bitset_test(bs, 5)).to_string())
    stdio::println((ordered::bitset_test(bs, 6)).to_string())
    ordered::bitset_clear(bs, 5)
    stdio::println((ordered::bitset_test(bs, 5)).to_string())
    stdio::println((ordered::bitset_count(bs)).to_string())
    let a: Vec<i32> = ordered::bitset_with_capacity(64)
    ordered::bitset_set(a, 1)
    ordered::bitset_set(a, 3)
    let b: Vec<i32> = ordered::bitset_with_capacity(64)
    ordered::bitset_set(b, 2)
    ordered::bitset_set(b, 3)
    let u: Vec<i32> = ordered::bitset_union(a, b)
    stdio::println((ordered::bitset_count(u)).to_string())
    stdio::println((ordered::bitset_test(u, 1)).to_string())
    stdio::println((ordered::bitset_test(u, 2)).to_string())
    stdio::println((ordered::bitset_test(u, 3)).to_string())
    let x: Vec<i32> = ordered::bitset_intersection(a, b)
    stdio::println((ordered::bitset_count(x)).to_string())
    stdio::println((ordered::bitset_test(x, 3)).to_string())
}
// Test bitset_set / bitset_clear / bitset_test
