use std::core::iter
use std::test

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)

    let it = iter::vec_iter(v)
    match it.next() {
        Some(x) => test::assert_eq_i32(x, 10),
        None => panic("expected Some(10)"),
    }
    test::assert_eq_i32(iter::iter_count_i32(v), 3)
}
