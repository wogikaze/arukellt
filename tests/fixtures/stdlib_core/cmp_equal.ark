use std::core::cmp
use std::test

fn main() {
    match 5.cmp(5) {
        Ordering::Less => panic("expected Equal"),
        Ordering::Equal => test::assert_true(true),
        Ordering::Greater => panic("expected Equal"),
    }
    match 0.cmp(0) {
        Ordering::Equal => test::assert_true(true),
        _ => panic("expected Equal"),
    }
    match (-3).cmp(-3) {
        Ordering::Equal => test::assert_true(true),
        _ => panic("expected Equal"),
    }
}
