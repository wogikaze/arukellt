// Property: hash is deterministic — same input always produces same output.
use std::core::hash
use std::test

fn main() {
    let mut i: i32 = 0
    while i < 100 {
        test::assert_eq_i32(i.hash(), i.hash())
        i = i + 1
    }
    // String determinism
    let strings = ["a", "ab", "abc", "hello", "world"]
    let mut j = 0
    while j < 5 {
        let s = get_unchecked(strings, j)
        test::assert_eq_i32(s.hash(), s.hash())
        j = j + 1
    }
}
