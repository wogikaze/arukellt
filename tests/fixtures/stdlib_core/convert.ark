use std::core::convert
use std::host::stdio

fn main() {
    stdio::println(42.to_string())
    stdio::println(3.14.to_string())
    stdio::println(true.to_string())
    let parsed = convert::parse_i32("123")
    match parsed {
        Option::Some(v) => stdio::println(v.to_string()),
        None => stdio::println("parse failed"),
    }
}
