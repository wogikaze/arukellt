use std::core::math
use std::test

fn main() {
    test::assert_eq_i32(0.popcount(), 0)
    test::assert_eq_i32(1.popcount(), 1)
    test::assert_eq_i32(3.popcount(), 2)
    test::assert_eq_i32(7.popcount(), 3)
    test::assert_eq_i32(255.popcount(), 8)
    test::assert_eq_i32((-1).popcount(), 32)
}
