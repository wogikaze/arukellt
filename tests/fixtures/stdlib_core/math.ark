use std::core::math
use std::host::stdio

fn main() {
    stdio::println((-42).abs().to_string())
    stdio::println(10.min(3).to_string())
    stdio::println(10.max(3).to_string())
    stdio::println(15.clamp(0, 10).to_string())
    stdio::println((-5).clamp(0, 10).to_string())
    stdio::println(2.pow(10).to_string())
    stdio::println(math::gcd(12, 8).to_string())
}
