use std::core::math

fn main() {
    println(i32_to_string(math::abs(-42)))
    println(i32_to_string(math::min(10, 3)))
    println(i32_to_string(math::max(10, 3)))
    println(i32_to_string(math::clamp(15, 0, 10)))
    println(i32_to_string(math::clamp(-5, 0, 10)))
    println(i32_to_string(math::pow_i32(2, 10)))
    println(i32_to_string(math::gcd(12, 8)))
}
