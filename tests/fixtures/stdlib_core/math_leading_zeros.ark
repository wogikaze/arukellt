use std::core::math
use std::test

fn main() {
    test::assert_eq_i32(math::leading_zeros(0), 32)
    test::assert_eq_i32(math::leading_zeros(1), 31)
    test::assert_eq_i32(math::leading_zeros(0x40000000), 1)
    // Negative numbers have no leading zeros (sign bit is set)
    test::assert_eq_i32(math::leading_zeros(-1), 0)
}
