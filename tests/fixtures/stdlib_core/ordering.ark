use std::core::cmp
use std::host::stdio

fn main() {
    match 1.cmp(2) {
        Ordering::Less => stdio::println("less"),
        Ordering::Equal => stdio::println("equal"),
        Ordering::Greater => stdio::println("greater"),
    }
    match 9.cmp(9) {
        Ordering::Less => stdio::println("less"),
        Ordering::Equal => stdio::println("equal"),
        Ordering::Greater => stdio::println("greater"),
    }
    match 7.cmp(3) {
        Ordering::Less => stdio::println("less"),
        Ordering::Equal => stdio::println("equal"),
        Ordering::Greater => stdio::println("greater"),
    }
    stdio::println(10.min(3).to_string())
    stdio::println(10.max(3).to_string())
    stdio::println(9.clamp(0, 7).to_string())
}
