use std::core::convert
use std::test

fn main() {
    match convert::parse_i64("9001") {
        Option::Some(v) => test::assert_eq_i64(v, 9001i64),
        None => panic("expected Some(9001)"),
    }
    match convert::parse_i64("0") {
        Option::Some(v) => test::assert_eq_i64(v, 0i64),
        None => panic("expected Some(0)"),
    }
    match convert::parse_i64("abc") {
        Option::Some(v) => panic("expected None for abc"),
        None => {
        },
    }
}
