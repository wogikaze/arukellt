use std::core::error

fn check_error(e: Error) -> String {
    match e {
        Error::InvalidArgument(msg) => msg,
        Error::IoError(msg) => msg,
        Error::NotFound(msg) => msg,
        _ => "other error",
    }
}

fn main() {
    let e1 = Error::InvalidArgument("bad")
    println(check_error(e1))
    let e2 = Error::NotFound("file.txt")
    println(check_error(e2))
    let e3 = Error::Timeout
    println(check_error(e3))
}
