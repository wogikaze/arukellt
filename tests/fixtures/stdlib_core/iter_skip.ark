use std::core::iter
use std::test

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    push(v, 40)
    push(v, 50)

    let skipped = iter::collect_skip_i32(v, 2)
    test::assert_eq_i32(len(skipped), 3)
    test::assert_eq_i32(get_unchecked(skipped, 0), 30)
    test::assert_eq_i32(get_unchecked(skipped, 2), 50)

    // Skip more than available
    let skipped_all = iter::collect_skip_i32(v, 100)
    test::assert_eq_i32(len(skipped_all), 0)
}
