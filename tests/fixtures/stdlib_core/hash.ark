use std::core::hash
use std::host::stdio

fn main() {
    let h1 = 42.hash()
    let h2 = 42.hash()
    let h3 = 0.hash()
    let hs1 = "hello".hash()
    let hs2 = "hello".hash()
    stdio::println((h1 == h2).to_string())
    stdio::println((h1 != h3).to_string())
    stdio::println((hs1 == hs2).to_string())
    let combined = hash::combine(h1, hs1)
    stdio::println((combined != 0).to_string())
}
