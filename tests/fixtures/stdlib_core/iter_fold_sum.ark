use std::core::iter
use std::test

fn add(a: i32, b: i32) -> i32 { a + b }

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)

    let sum = iter::iter_fold_i32(v, 0, add)
    test::assert_eq_i32(sum, 15)

    let sum2 = iter::iter_sum_i32(v)
    test::assert_eq_i32(sum2, 15)

    // any / all
    fn is_pos(x: i32) -> bool { x > 0 }
    test::assert_true(iter::iter_any_i32(v, is_pos))
    test::assert_true(iter::iter_all_i32(v, is_pos))
}
