use std::core::cmp
use std::test

fn main() {
    match 10.cmp(3) {
        Ordering::Less => panic("expected Greater"),
        Ordering::Equal => panic("expected Greater"),
        Ordering::Greater => test::assert_true(true),
    }
    match 0.cmp(-1) {
        Ordering::Greater => test::assert_true(true),
        _ => panic("expected Greater"),
    }
}
