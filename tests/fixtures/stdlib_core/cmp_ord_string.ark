use std::core::cmp
use std::test

fn main() {
    // Ord trait dispatch for String — lexicographic comparison
    match String_from("abc").cmp(String_from("abd")) {
        Ordering::Less => test::assert_true(true),
        _ => panic("expected Less"),
    }
    match String_from("abc").cmp(String_from("abc")) {
        Ordering::Equal => test::assert_true(true),
        _ => panic("expected Equal"),
    }
    match String_from("abd").cmp(String_from("abc")) {
        Ordering::Greater => test::assert_true(true),
        _ => panic("expected Greater"),
    }
}
