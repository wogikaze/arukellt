use std::host::stdio
use std::time

fn main() {
    let d1 = time::duration_ms(0i64, 5000000i64)
    assert_eq_i64(d1, 5i64)
    let d2 = time::duration_us(0i64, 5000000i64)
    assert_eq_i64(d2, 5000i64)
    let d3 = time::duration_ns(0i64, 5000000i64)
    assert_eq_i64(d3, 5000000i64)
    let d4 = time::duration_ms(10000000i64, 5000000i64)
    assert_eq_i64(d4, 0i64)
    stdio::println("duration ok")
}
// Test duration_ms calculation
// Test duration_us
// Test duration_ns
// Negative duration should be 0
