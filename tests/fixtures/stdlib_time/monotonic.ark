use std::host::clock
use std::host::stdio
use std::time

fn main() {
    let t1 = clock::monotonic_now()
    let mut x = 0
    while x < 1000 {
        x = x + 1
    }
    let t2 = clock::monotonic_now()
    let elapsed = time::duration_ns(t1, t2)
    assert(elapsed >= 0)
    stdio::println("monotonic ok")
}
