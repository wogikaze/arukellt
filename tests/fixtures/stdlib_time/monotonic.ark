use std::time
use std::host::stdio
use std::host::clock

fn main() {
    let t1 = clock::monotonic_now()
    // Do some work
    let mut x = 0
    while x < 1000 {
        x = x + 1
    }
    let t2 = clock::monotonic_now()
    // t2 should be >= t1
    let elapsed = time::duration_ns(t1, t2)
    assert(elapsed >= 0)
    stdio::println("monotonic ok")
}
