use std::host::stdio

struct Holder {
    name: String,
    items: Vec<String>,
}

fn main() {
    let mut h = Holder { name: String_from("test"), items: Vec_new_String() }
    h = Holder { name: h.name, items: push(h.items, String_from("alpha")) }
    h = Holder { name: h.name, items: push(h.items, String_from("beta")) }
    h = Holder { name: h.name, items: push(h.items, String_from("gamma")) }
    stdio::println(h.name)
    stdio::println(get_unchecked(h.items, 0))
    stdio::println(get_unchecked(h.items, 1))
    stdio::println(get_unchecked(h.items, 2))
    let local_ref = h.items
    stdio::println(get_unchecked(local_ref, 0))
}
