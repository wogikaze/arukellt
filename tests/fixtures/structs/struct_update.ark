use std::host::stdio

struct Config {
    width: i32,
    height: i32,
    title: String,
}

fn with_title(c: Config, new_title: String) -> Config {
    Config { width: c.width, height: c.height, title: new_title }
}

fn main() {
    let c1: Config = Config { width: 800, height: 600, title: String_from("old") }
    let c2: Config = with_title(c1, String_from("new"))
    stdio::println(c2.title)
    stdio::println(i32_to_string(c2.width))
}
