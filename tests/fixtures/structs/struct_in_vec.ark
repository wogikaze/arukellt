use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

fn main() {
    let mut points: Vec<Point> = Vec_new_Point()
    push(points, Point { x: 1, y: 2 })
    push(points, Point { x: 3, y: 4 })
    let mut i: i32 = 0
    while i < len(points) {
        let p: Point = get_unchecked(points, i)
        stdio::println(concat(concat((p.x).to_string(), String_from(",")), (p.y).to_string()))
        i = i + 1
    }
}
