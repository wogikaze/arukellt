// Regression test: push into a Vec accessed through chained field access
// Previously caused len to increment by 2 instead of 1
use std::host::stdio

struct Item {
    name: String,
    value: i32,
}

struct Container {
    items: Vec<Item>,
}

struct Context {
    container: Container,
    current: Item,
}

fn main() {
    let ctx = Context {
        container: Container { items: Vec_new_Item() },
        current: Item { name: String_from("first"), value: 10 },
    }
    stdio::println(i32_to_string(len(ctx.container.items)))
    push(ctx.container.items, ctx.current)
    stdio::println(i32_to_string(len(ctx.container.items)))
    let i0 = get_unchecked(ctx.container.items, 0)
    stdio::println(i0.name)
    stdio::println(i32_to_string(i0.value))
    // Push a second item
    ctx.current = Item { name: String_from("second"), value: 20 }
    push(ctx.container.items, ctx.current)
    stdio::println(i32_to_string(len(ctx.container.items)))
    let i1 = get_unchecked(ctx.container.items, 1)
    stdio::println(i1.name)
    stdio::println(i32_to_string(i1.value))
}
