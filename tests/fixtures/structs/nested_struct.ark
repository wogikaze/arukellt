use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

struct Rect {
    origin: Point,
    width: i32,
    height: i32,
}

fn main() {
    let r: Rect = Rect { origin: Point { x: 1, y: 2 }, width: 10, height: 20 }
    stdio::println((r.origin.x).to_string())
    stdio::println((r.origin.y).to_string())
    stdio::println((r.width).to_string())
    stdio::println((r.height).to_string())
}
