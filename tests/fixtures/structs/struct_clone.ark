use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

fn clone_point(p: Point) -> Point {
    Point { x: p.x, y: p.y }
}

fn main() {
    let p1: Point = Point { x: 10, y: 20 }
    let p2: Point = clone_point(p1)
    stdio::println((p2.x).to_string())
    stdio::println((p2.y).to_string())
}
