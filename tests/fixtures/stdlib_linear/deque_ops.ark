use std::collections::linear
use std::host::stdio

fn main() {
    let d: Vec<i32> = linear::deque_new()
    linear::deque_push_back(d, 42)
    stdio::println((linear::deque_front(d)).to_string())
    stdio::println((linear::deque_back(d)).to_string())
    linear::deque_push_back(d, 99)
    linear::deque_push_front(d, 1)
    stdio::println((linear::deque_front(d)).to_string())
    stdio::println((linear::deque_back(d)).to_string())
    stdio::println((linear::deque_len(d)).to_string())
    let v: Vec<i32> = linear::deque_to_vec(d)
    stdio::println((len(v)).to_string())
    stdio::println((get_unchecked(v, 0)).to_string())
    stdio::println((get_unchecked(v, 2)).to_string())
    linear::deque_clear(d)
    stdio::println((linear::deque_len(d)).to_string())
    stdio::println((linear::deque_is_empty(d)).to_string())
}
// front/back on single element
