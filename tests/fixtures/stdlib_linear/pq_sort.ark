use std::collections::linear
use std::host::stdio

fn main() {
    let pq: Vec<i32> = linear::pq_new()

    // Push in arbitrary order
    linear::pq_push(pq, 50)
    linear::pq_push(pq, 10)
    linear::pq_push(pq, 90)
    linear::pq_push(pq, 30)
    linear::pq_push(pq, 70)
    linear::pq_push(pq, 20)
    linear::pq_push(pq, 80)
    linear::pq_push(pq, 40)
    linear::pq_push(pq, 60)

    stdio::println((linear::pq_len(pq)).to_string())  // 9

    // Pop all: should come out sorted ascending (min-heap)
    stdio::println((linear::pq_pop(pq)).to_string())  // 10
    stdio::println((linear::pq_pop(pq)).to_string())  // 20
    stdio::println((linear::pq_pop(pq)).to_string())  // 30
    stdio::println((linear::pq_pop(pq)).to_string())  // 40
    stdio::println((linear::pq_pop(pq)).to_string())  // 50
    stdio::println((linear::pq_pop(pq)).to_string())  // 60
    stdio::println((linear::pq_pop(pq)).to_string())  // 70
    stdio::println((linear::pq_pop(pq)).to_string())  // 80
    stdio::println((linear::pq_pop(pq)).to_string())  // 90

    stdio::println((linear::pq_is_empty(pq)).to_string())  // true
    stdio::println((linear::pq_len(pq)).to_string())  // 0
}
// pq_len after 9 pushes
// pq_pop returns sorted ascending (min-heap property)
// pq_is_empty after draining all
// pq_len after draining all
