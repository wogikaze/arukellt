use std::collections::linear
use std::host::stdio

fn main() {
    let d: Vec<i32> = linear::deque_new()

    // Phase 1: shift head and tail to mid-buffer
    linear::deque_push_back(d, 1)
    linear::deque_push_back(d, 2)
    linear::deque_push_back(d, 3)
    linear::deque_push_back(d, 4)
    linear::deque_push_back(d, 5)
    stdio::println(i32_to_string(linear::deque_pop_front(d)))  // 1
    stdio::println(i32_to_string(linear::deque_pop_front(d)))  // 2
    // head=2, tail=5, count=3  (vals: 3,4,5 at pos 2,3,4)

    // Phase 2: push_front wraps head around (15 -> 0 -> ...)
    linear::deque_push_front(d, 10)  // head=1, pos 1=10
    linear::deque_push_front(d, 20)  // head=0, pos 0=20
    linear::deque_push_front(d, 30)  // head=15, pos 15=30
    // head=15, tail=5, count=6
    // Ring: pos15=30, pos0=20, pos1=10, pos2=3, pos3=4, pos4=5

    // Phase 3: push_back after wrap
    linear::deque_push_back(d, 60)   // tail=6, pos 6=60
    linear::deque_push_back(d, 70)   // tail=7, pos 7=70
    // head=15, tail=7, count=8

    // Phase 4: pop from both ends with wrapped reads
    stdio::println(i32_to_string(linear::deque_pop_front(d)))  // 30 from pos15
    stdio::println(i32_to_string(linear::deque_pop_back(d)))   // 70 from pos7
    stdio::println(i32_to_string(linear::deque_pop_front(d)))  // 20 from pos0
    stdio::println(i32_to_string(linear::deque_pop_back(d)))   // 60 from pos6
    // head=1, tail=5, count=4  (vals: 10,3,4,5 at pos 1,2,3,4)

    // Phase 5: deque_to_vec after wrap
    let v: Vec<i32> = linear::deque_to_vec(d)
    stdio::println(i32_to_string(len(v)))  // 4
    stdio::println(i32_to_string(get_unchecked(v, 0)))  // 10
    stdio::println(i32_to_string(get_unchecked(v, 1)))  // 3
    stdio::println(i32_to_string(get_unchecked(v, 2)))  // 4
    stdio::println(i32_to_string(get_unchecked(v, 3)))  // 5

    // Phase 6: clear after wrap
    linear::deque_clear(d)
    stdio::println(i32_to_string(linear::deque_len(d)))  // 0
    stdio::println(bool_to_string(linear::deque_is_empty(d)))  // true
}
// push_front wrap-around (head wraps from 0 to 15)
// push_back after wrap
// pop_front and pop_back with wrapped head/tail
// deque_to_vec after wrap
// deque_clear after wrap
