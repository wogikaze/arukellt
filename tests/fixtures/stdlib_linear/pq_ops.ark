use std::collections::linear
use std::host::stdio

fn main() {
    let pq: Vec<i32> = linear::pq_new()
    linear::pq_clear(pq)
    stdio::println((linear::pq_is_empty(pq)).to_string())
    linear::pq_push(pq, 50)
    linear::pq_push(pq, 10)
    linear::pq_push(pq, 30)
    linear::pq_push(pq, 5)
    stdio::println((linear::pq_len(pq)).to_string())
    stdio::println((linear::pq_peek(pq)).to_string())
    let a: i32 = linear::pq_pop(pq)
    let b: i32 = linear::pq_pop(pq)
    let c: i32 = linear::pq_pop(pq)
    stdio::println((a).to_string())
    stdio::println((b).to_string())
    stdio::println((c).to_string())
    stdio::println((linear::pq_len(pq)).to_string())
    linear::pq_push(pq, 99)
    linear::pq_clear(pq)
    stdio::println((linear::pq_is_empty(pq)).to_string())
}
// pq_clear on empty
// push and peek
// pop in order (min-heap: smallest first)
// pq_clear
