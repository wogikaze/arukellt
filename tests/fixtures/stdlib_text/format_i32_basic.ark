use std::test
use std::text

fn main() {
    test::assert_eq_string(text::format_i32(0), "0")
    test::assert_eq_string(text::format_i32(1), "1")
    test::assert_eq_string(text::format_i32(42), "42")
    test::assert_eq_string(text::format_i32(100), "100")
    test::assert_eq_string(text::format_i32(123456), "123456")
    test::assert_eq_string(text::format_i32(7), "7")
    test::assert_eq_string(text::format_i32(999999), "999999")
}
