use std::test
use std::text

fn main() {
    // Empty range — start == end
    test::assert_eq_string(text::slice_bytes("hello", 2, 2), "")
    // Full string
    test::assert_eq_string(text::slice_bytes("hello", 0, 5), "hello")
    // Empty string
    test::assert_eq_string(text::slice_bytes("", 0, 0), "")
    // Single char slice
    test::assert_eq_string(text::slice_bytes("abc", 1, 2), "b")
}
