use std::test
use std::text::fmt

fn main() {
    // Empty Vec<i32> -> "[]"
    let empty: Vec<i32> = Vec_new_i32()
    test::assert_eq_string(fmt::debug_format_vec_i32(empty), "[]")

    // Vec<i32> -> "[1, 2, 3]"
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    test::assert_eq_string(fmt::debug_format_vec_i32(v), "[1, 2, 3]")

    // Single element
    let one: Vec<i32> = Vec_new_i32()
    push(one, 42)
    test::assert_eq_string(fmt::debug_format_vec_i32(one), "[42]")

    // Vec<String> -> ["a", "b"] (elements quoted via Debug for String)
    let vs: Vec<String> = Vec_new_String()
    push(vs, "a")
    push(vs, "b")
    test::assert_eq_string(fmt::debug_format_vec_string(vs), "[\"a\", \"b\"]")
}
