use std::test
use std::text

fn main() {
    // Basic ASCII bytes to string
    let bytes = Vec_new_i32()
    push(bytes, 72)
    push(bytes, 105)
    let s = text::from_utf8(bytes)
    test::assert_eq_string(s, "Hi")
    test::assert_eq_i32(len(s), 2)

    // Single byte
    let bytes2 = Vec_new_i32()
    push(bytes2, 65)
    let s2 = text::from_utf8(bytes2)
    test::assert_eq_string(s2, "A")

    // Empty byte array
    let bytes3 = Vec_new_i32()
    let s3 = text::from_utf8(bytes3)
    test::assert_eq_string(s3, "")
    test::assert_eq_i32(len(s3), 0)
}
