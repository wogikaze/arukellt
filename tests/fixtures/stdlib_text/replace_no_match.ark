use std::test
use std::text

fn main() {
    // No match — string unchanged
    test::assert_eq_string(text::replace("hello", "xyz", "!"), "hello")
    // Empty string with no match
    test::assert_eq_string(text::replace("", "a", "b"), "")
    // Replace with same string
    test::assert_eq_string(text::replace("abc", "b", "b"), "abc")
}
