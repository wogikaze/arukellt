use std::test
use std::text

fn main() {
    // Empty needle is always found
    test::assert_true(text::contains("hello", ""))
    test::assert_true(text::contains("", ""))
    // Non-empty needle in empty haystack is not found
    test::assert_false(text::contains("", "a"))
    // Single char haystack
    test::assert_true(text::contains("a", "a"))
    test::assert_false(text::contains("a", "b"))
}
