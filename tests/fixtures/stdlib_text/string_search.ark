use std::host::stdio
use std::text

fn main() {
    let s = "hello world"
    stdio::println((text::contains(s, "world")).to_string())
    stdio::println((text::contains(s, "xyz")).to_string())
    stdio::println((text::contains(s, "")).to_string())
    stdio::println((text::contains("", "")).to_string())
    stdio::println((text::contains("", "a")).to_string())
    stdio::println((text::index_of(s, "hello")).to_string())
    stdio::println((text::index_of(s, "world")).to_string())
    stdio::println((text::index_of(s, " ")).to_string())
    stdio::println((text::index_of(s, "xyz")).to_string())
    stdio::println((text::index_of(s, "")).to_string())
    stdio::println((starts_with(s, "hello")).to_string())
    stdio::println((starts_with(s, "world")).to_string())
    stdio::println((starts_with(s, "")).to_string())
    stdio::println((ends_with(s, "world")).to_string())
    stdio::println((ends_with(s, "hello")).to_string())
    stdio::println((ends_with(s, "")).to_string())
    stdio::println((text::index_of("a", "a")).to_string())
    stdio::println((text::index_of("a", "b")).to_string())
}
// String search operations: contains, index_of, starts_with, ends_with
// contains
// index_of
// starts_with / ends_with (prelude)
// Edge: single char search
