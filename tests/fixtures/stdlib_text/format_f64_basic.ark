use std::test
use std::text

fn main() {
    test::assert_eq_string(text::format_f64(0.0), "0")
    test::assert_eq_string(text::format_f64(1.0), "1")
    test::assert_eq_string(text::format_f64(3.14), "3.14")
    test::assert_eq_string(text::format_f64(100.0), "100")
    test::assert_eq_string(text::format_f64(0.5), "0.5")
}
