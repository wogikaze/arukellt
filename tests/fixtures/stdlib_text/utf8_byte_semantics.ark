use std::host::stdio
use std::text

fn main() {
    let ascii = "hello"
    stdio::println((len(ascii)).to_string())
    stdio::println((len("")).to_string())
    stdio::println((len(" ")).to_string())
    stdio::println((len("\n")).to_string())
    stdio::println((len("\t")).to_string())
    let world = slice(ascii, 0, 3)
    stdio::println(world)
    let mid = slice(ascii, 1, 4)
    stdio::println(mid)
    let full = slice(ascii, 0, 5)
    stdio::println(full)
    let empty = slice(ascii, 2, 2)
    stdio::println((len(empty)).to_string())
    stdio::println((text::len_bytes("abc")).to_string())
    stdio::println((text::is_empty("")).to_string())
    stdio::println((text::is_empty("a")).to_string())
}
// UTF-8 byte length vs perceived character count
// Arukellt len() measures BYTES, not Unicode scalars.
// ASCII: 1 byte per char
// Empty string: 0 bytes
// Single space: 1 byte
// Newline: 1 byte
// Tab: 1 byte
// Byte-level slice of ASCII works as expected
// Slice from middle
// Slice entire string
// Slice empty range
// text::len_bytes matches len
