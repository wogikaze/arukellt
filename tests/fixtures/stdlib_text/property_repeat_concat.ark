use std::test
use std::text

fn main() {
    // repeat(concat(a, b), n) == concat(repeat(a, n), repeat(b, n))
    let a = "ab"
    let b = "cd"
    let n = 3
    let left = text::repeat(text::concat(a, b), n)
    let right = text::concat(text::repeat(a, n), text::repeat(b, n))
    test::assert_eq_string(left, right)
    test::assert_eq_string(left, "abcdabcdabcd")

    // repeat(a, m+n) == concat(repeat(a, m), repeat(a, n))
    let m = 2
    let nn = 3
    let left2 = text::repeat("x", m + nn)
    let right2 = text::concat(text::repeat("x", m), text::repeat("x", nn))
    test::assert_eq_string(left2, right2)
}
