use std::test
use std::text

fn main() {
    // String already meets width — returned unchanged
    test::assert_eq_string(text::pad_right("hello", 3, "0"), "hello")
    test::assert_eq_string(text::pad_right("abc", 3, "0"), "abc")
    // Width equals length — no padding needed
    test::assert_eq_string(text::pad_right("ab", 2, "x"), "ab")
    // Empty string padded to width
    test::assert_eq_string(text::pad_right("", 3, "0"), "000")
    test::assert_eq_string(text::pad_right("", 0, "0"), "")
}
