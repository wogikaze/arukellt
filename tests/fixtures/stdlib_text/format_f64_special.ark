use std::test
use std::text

fn main() {
    test::assert_eq_string(text::format_f64(-1.5), "-1.5")
    test::assert_eq_string(text::format_f64(-0.25), "-0.25")
    test::assert_eq_string(text::format_f64(-100.0), "-100")
    test::assert_eq_string(text::format_f64(0.0), "0")
    test::assert_eq_string(text::format_f64(-0.0), "0")
}
