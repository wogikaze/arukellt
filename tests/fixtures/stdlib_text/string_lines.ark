use std::host::stdio
use std::text

fn main() {
    let input: String = String_from("line1\nline2\nline3")
    let result: Vec<String> = split(input, String_from("\n"))
    stdio::println((len(result)).to_string())
    let mut i: i32 = 0
    while i < len(result) {
        stdio::println(get_unchecked(result, i))
        i = i + 1
    }
    stdio::println((text::is_empty("")).to_string())
    stdio::println((text::len_bytes("hello")).to_string())
}
