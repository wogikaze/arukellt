use std::test
use std::text

fn main() {
    test::assert_eq_string(text::format_i64(0), "0")
    test::assert_eq_string(text::format_i64(42), "42")
    test::assert_eq_string(text::format_i64(-100), "-100")
    test::assert_eq_string(text::format_i64(1000000), "1000000")
    test::assert_eq_string(text::format_i64(-999999), "-999999")
}
