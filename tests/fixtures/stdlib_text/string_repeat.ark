use std::host::stdio
use std::text

fn main() {
    stdio::println(text::repeat("ab", 3))
    stdio::println(text::repeat("x", 5))
    let empty = text::repeat("hi", 0)
    stdio::println((text::len_bytes(empty)).to_string())
    stdio::println((text::is_empty(empty)).to_string())
    stdio::println((text::is_empty("hello")).to_string())
}
