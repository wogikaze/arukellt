use std::host::stdio
fn main() {
    let mut v: Vec<String> = Vec_new_String()
    push(v, String_from("hello"))
    push(v, String_from("world"))
    let a: bool = contains_String(v, String_from("world"))
    stdio::println(a)
    let b: bool = contains_String(v, String_from("foo"))
    stdio::println(b)
}
