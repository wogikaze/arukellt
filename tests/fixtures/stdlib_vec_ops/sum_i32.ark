use std::host::stdio

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    stdio::println((sum_i32(v)).to_string())
    let empty: Vec<i32> = Vec_new_i32()
    stdio::println((sum_i32(empty)).to_string())
    let single: Vec<i32> = Vec_new_i32()
    push(single, 42)
    stdio::println((sum_i32(single)).to_string())
}
