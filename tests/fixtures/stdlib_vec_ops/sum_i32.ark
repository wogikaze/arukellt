use std::host::stdio
fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    stdio::println(i32_to_string(sum_i32(v)))

    let empty: Vec<i32> = Vec_new_i32()
    stdio::println(i32_to_string(sum_i32(empty)))

    let single: Vec<i32> = Vec_new_i32()
    push(single, 42)
    stdio::println(i32_to_string(sum_i32(single)))
}
