use std::host::stdio
fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    push(v, 40)
    remove_i32(v, 1)
    stdio::println(len(v))
    let mut i: i32 = 0
    while i < len(v) {
        stdio::println(get_unchecked(v, i))
        i = i + 1
    }
}
