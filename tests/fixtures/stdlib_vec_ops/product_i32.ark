use std::host::stdio

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    stdio::println((product_i32(v)).to_string())
    let single: Vec<i32> = Vec_new_i32()
    push(single, 7)
    stdio::println((product_i32(single)).to_string())
    let mixed: Vec<i32> = Vec_new_i32()
    push(mixed, 2)
    push(mixed, 3)
    push(mixed, 4)
    stdio::println((product_i32(mixed)).to_string())
}
