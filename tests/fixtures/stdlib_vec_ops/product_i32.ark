fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    println(i32_to_string(product_i32(v)))

    let single: Vec<i32> = Vec_new_i32()
    push(single, 7)
    println(i32_to_string(product_i32(single)))

    let mixed: Vec<i32> = Vec_new_i32()
    push(mixed, 2)
    push(mixed, 3)
    push(mixed, 4)
    println(i32_to_string(product_i32(mixed)))
}
