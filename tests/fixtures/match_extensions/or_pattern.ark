fn main() {
    let x = 3
    let result = match x {
        1 | 2 => "one or two",
        3 | 4 | 5 => "three to five",
        _ => "other"
    }
    println(result)

    let y = 7
    let r2 = match y {
        1 | 3 | 5 | 7 | 9 => "odd",
        2 | 4 | 6 | 8 | 10 => "even",
        _ => "out of range"
    }
    println(r2)
}
