fn main() {
    let x = 5
    let result = match x {
        n if n > 10 => "big",
        n if n > 0 => "positive",
        _ => "other"
    }
    println(result)

    let y: Option<i32> = Some(42)
    match y {
        Some(v) if v > 10 => println("large some"),
        Some(v) => println("small some"),
        None => println("none")
    }
}
