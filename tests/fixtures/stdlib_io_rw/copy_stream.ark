use std::bytes
use std::host::stdio
use std::io

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 104)
    bytes::bytes_push(data, 101)
    bytes::bytes_push(data, 108)
    bytes::bytes_push(data, 108)
    bytes::bytes_push(data, 111)
    bytes::bytes_push(data, 32)
    bytes::bytes_push(data, 119)
    bytes::bytes_push(data, 111)
    bytes::bytes_push(data, 114)
    bytes::bytes_push(data, 108)
    bytes::bytes_push(data, 100)
    let src: Vec<i32> = io::reader_from_bytes(data)
    let dst: Vec<i32> = io::writer_new()
    let res: Result<i32, io::IoError> = io::copy_bytes(src, dst)
    match res {
        Result::Ok(n) => stdio::println(i32_to_string(n)),
        Result::Err(e) => stdio::println(e),
    }
    let out: Vec<i32> = io::writer_to_bytes(dst)
    stdio::println(bytes::string_from_bytes(out))
    stdio::println(bool_to_string(io::reader_eof(src)))
}
// Source reader with "hello world"
// h
// e
// l
// l
// o
// ' '
// w
// o
// r
// l
// d
// dst should now hold all bytes
// src should be at eof
