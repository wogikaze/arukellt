use std::bytes
use std::host::stdio
use std::io

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 72)
    bytes::bytes_push(data, 101)
    bytes::bytes_push(data, 108)
    bytes::bytes_push(data, 108)
    bytes::bytes_push(data, 111)
    bytes::bytes_push(data, 10)
    bytes::bytes_push(data, 87)
    bytes::bytes_push(data, 111)
    bytes::bytes_push(data, 114)
    bytes::bytes_push(data, 108)
    bytes::bytes_push(data, 100)
    let r: Vec<i32> = io::reader_from_bytes(data)
    stdio::println(bool_to_string(io::reader_eof(r)))
    let res: Result<Vec<i32>, io::IoError> = io::reader_read(r, 5)
    match res {
        Result::Ok(chunk) => stdio::println(bytes::string_from_bytes(chunk)),
        Result::Err(e) => stdio::println(e),
    }
    let res2: Result<String, io::IoError> = io::reader_read_line(r)
    match res2 {
        Result::Ok(line) => stdio::println(line),
        Result::Err(e) => stdio::println(e),
    }
    stdio::println(bool_to_string(io::reader_eof(r)))
}
// Build bytes: "Hello\nWorld"
// H
// e
// l
// l
// o
// \n
// W
// o
// r
// l
// d
// reader_eof should be false
// read 5 bytes -> "Hello"
// read_line -> "World" (skips the \n)
// reader_eof should now be true
