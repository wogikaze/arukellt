use std::io
use std::bytes
use std::host::stdio

fn main() {
    // Build data "Line1\nLine2\nLine3"
    let data: Vec<i32> = bytes::bytes_new()
    // "Line1\n"
    bytes::bytes_push(data, 76)   // L
    bytes::bytes_push(data, 105)  // i
    bytes::bytes_push(data, 110)  // n
    bytes::bytes_push(data, 101)  // e
    bytes::bytes_push(data, 49)   // 1
    bytes::bytes_push(data, 10)   // \n
    // "Line2\n"
    bytes::bytes_push(data, 76)
    bytes::bytes_push(data, 105)
    bytes::bytes_push(data, 110)
    bytes::bytes_push(data, 101)
    bytes::bytes_push(data, 50)   // 2
    bytes::bytes_push(data, 10)
    // "Line3" (no trailing newline)
    bytes::bytes_push(data, 76)
    bytes::bytes_push(data, 105)
    bytes::bytes_push(data, 110)
    bytes::bytes_push(data, 101)
    bytes::bytes_push(data, 51)   // 3

    let r: Vec<i32> = io::reader_from_bytes(data)
    let br: Vec<i32> = io::buf_reader_new(r, 64)

    let l1: Result<String, String> = io::buf_reader_read_line(br)
    match l1 {
        Ok(s) => stdio::println(s),
        Err(e) => stdio::println(e),
    }

    let l2: Result<String, String> = io::buf_reader_read_line(br)
    match l2 {
        Ok(s) => stdio::println(s),
        Err(e) => stdio::println(e),
    }

    let l3: Result<String, String> = io::buf_reader_read_line(br)
    match l3 {
        Ok(s) => stdio::println(s),
        Err(e) => stdio::println(e),
    }

    // BufWriter with small cap — auto-flushes at 8 bytes
    let out: Vec<i32> = io::stdout()
    let bw: Vec<i32> = io::buf_writer_new(out, 8)
    let _: Result<i32, String> = io::buf_writer_write_str(bw, "buffered")
    let _: Result<(), String> = io::buf_writer_flush(bw)
    stdio::println("")
    stdio::println("done")
}
