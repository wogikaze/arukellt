use std::bytes
use std::host::stdio
use std::io

fn main() {
    let w: Vec<i32> = io::writer_new()
    let r1: Result<i32, String> = io::writer_write_str(w, "hello")
    match r1 {
        Result::Ok(n) => stdio::println(i32_to_string(n)),
        Result::Err(e) => stdio::println(e),
    }
    let r2: Result<i32, String> = io::writer_write_str(w, " world")
    match r2 {
        Result::Ok(n) => stdio::println(i32_to_string(n)),
        Result::Err(e) => stdio::println(e),
    }
    let b: Vec<i32> = io::writer_to_bytes(w)
    stdio::println(bytes::string_from_bytes(b))
    let rf: Result<(), String> = io::writer_flush(w)
    match rf {
        Result::Ok(_) => stdio::println("flush ok"),
        Result::Err(e) => stdio::println(e),
    }
}
// Memory writer
// write_str
// write more
// to_bytes and string_from_bytes
// flush is a no-op but should return Ok
