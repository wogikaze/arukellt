use std::collections::hash
use std::host::stdio

fn main() {
    let m: Vec<i32> = hash::hashmap_new()
    hash::hashmap_set(m, 42, 100)
    hash::hashmap_set(m, 7, 200)
    stdio::println((hash::hashmap_size(m)).to_string())
    stdio::println((hash::hashmap_get(m, 42)).to_string())
    stdio::println((hash::hashmap_get(m, 7)).to_string())
    stdio::println((hash::hashmap_contains(m, 42)).to_string())
    stdio::println((hash::hashmap_contains(m, 99)).to_string())
    hash::hashmap_set(m, 42, 300)
    stdio::println((hash::hashmap_get(m, 42)).to_string())
    stdio::println((hash::hashmap_size(m)).to_string())
}
