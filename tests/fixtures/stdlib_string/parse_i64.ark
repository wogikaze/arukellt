fn main() {
    let x: i64 = parse_i64(String_from("42"))
    println(i64_to_string(x))

    let y: i64 = parse_i64(String_from("-100"))
    println(i64_to_string(y))

    let z: i64 = parse_i64(String_from("0"))
    println(i64_to_string(z))

    let big: i64 = parse_i64(String_from("9999999999"))
    println(i64_to_string(big))
}
