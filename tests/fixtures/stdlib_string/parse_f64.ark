use std::test

fn main() {
    let r1: Result<f64, String> = parse_f64(String_from("3.14"))
    match r1 {
        Result::Ok(v) => test::assert_eq_f64(v, 3.14),
        Result::Err(e) => panic("expected Ok, got Err"),
    }
    let r2: Result<f64, String> = parse_f64(String_from("-2.5"))
    match r2 {
        Result::Ok(v) => test::assert_eq_f64(v, -2.5),
        Result::Err(e) => panic("expected Ok, got Err"),
    }
    let r3: Result<f64, String> = parse_f64(String_from("42"))
    match r3 {
        Result::Ok(v) => test::assert_eq_f64(v, 42.0),
        Result::Err(e) => panic("expected Ok, got Err"),
    }
    let r4: Result<f64, String> = parse_f64(String_from("0.001"))
    match r4 {
        Result::Ok(v) => test::assert_eq_string(f64_to_string(v), "0.001"),
        Result::Err(e) => panic("expected Ok, got Err"),
    }
    let r5: Result<f64, String> = parse_f64(String_from("xyz"))
    match r5 {
        Result::Ok(v) => panic("expected Err, got Ok"),
        Result::Err(e) => test::assert_eq_string(e, "parse error: invalid float"),
    }
}
