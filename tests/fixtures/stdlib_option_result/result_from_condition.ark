use std::host::stdio
use std::test
fn main() {
    let n: i32 = 10
    let r: Result<i32, String> = if n > 5 { Ok(n) } else { Err(String_from("too small")) }
    test::assert_true(is_ok(r))
    match r { Result::Ok(v) => test::assert_eq_i32(v, 10), Result::Err(e) => panic(e) }
    let r2: Result<i32, String> = if n > 100 { Ok(n) } else { Err(String_from("too small")) }
    test::assert_true(is_err(r2))
    stdio::println("ok")
}
