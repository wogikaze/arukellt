use std::host::stdio
use std::test
fn main() {
    let ok_r: Result<i32, i32> = Ok(10)
    let ok_val: i32 = match ok_r { Result::Ok(v) => v, Result::Err(e) => 0 }
    test::assert_eq_i32(ok_val, 10)
    let err_r: Result<i32, i32> = Err(3)
    let err_val: i32 = match err_r { Result::Ok(v) => 0, Result::Err(e) => -e }
    test::assert_eq_i32(err_val, -3)
    stdio::println("ok")
}
