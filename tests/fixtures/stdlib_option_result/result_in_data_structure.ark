use std::host::stdio
use std::test
fn main() {
    let ok_r: Result<Result<i32, i32>, i32> = Ok(Ok(1))
    match ok_r {
        Result::Ok(inner) => match inner {
            Result::Ok(v) => test::assert_eq_i32(v, 1),
            Result::Err(e) => panic("inner err"),
        },
        Result::Err(e) => panic("outer err"),
    }
    let err_r: Result<Result<i32, i32>, i32> = Ok(Err(2))
    match err_r {
        Result::Ok(inner) => match inner {
            Result::Ok(v) => panic("inner ok"),
            Result::Err(e) => test::assert_eq_i32(e, 2),
        },
        Result::Err(e) => panic("outer err"),
    }
    stdio::println("ok")
}
