use std::host::stdio
use std::test
fn double(x: i32) -> i32 { x * 2 }
fn main() {
    for i in 0..20 {
        let opt: Option<i32> = if i % 3 == 0 { None } else { Some(i) }
        let m = map_option_i32_i32(opt, double)
        if i % 3 == 0 {
            match m { Option::Some(v) => panic("some"), None => {} }
        } else {
            match m { Option::Some(v) => test::assert_eq_i32(v, i * 2), None => panic("none") }
        }
    }
    stdio::println("ok")
}
