use std::host::stdio
use std::test
fn double(x: i32) -> i32 { x * 2 }
fn main() {
    let r: Result<i32, i32> = Ok(21)
    let m: Result<i32, i32> = match r { Result::Ok(v) => Ok(double(v)), Result::Err(e) => Err(e) }
    match m { Result::Ok(v) => test::assert_eq_i32(v, 42), Result::Err(e) => panic("err") }
    stdio::println("ok")
}
