use std::host::stdio
use std::test
fn main() {
    let r: Result<i32, i32> = Err(99)
    test::assert_true(is_err(r))
    test::assert_false(is_ok(r))
    match r { Result::Ok(v) => panic("ok"), Result::Err(e) => test::assert_eq_i32(e, 99) }
    test::assert_eq_i32(unwrap_or(r, 0), 0)
    stdio::println("ok")
}
