use std::host::stdio
use std::test
fn main() {
    for i in 0..30 {
        let opt: Option<i32> = if i % 2 == 0 { Some(i) } else { None }
        let result: i32 = match opt { Option::Some(v) => v, None => -1 }
        if i % 2 == 0 { test::assert_eq_i32(result, i) }
        else { test::assert_eq_i32(result, -1) }
    }
    stdio::println("ok")
}
