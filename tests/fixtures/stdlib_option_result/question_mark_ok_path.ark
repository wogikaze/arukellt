use std::host::stdio
use std::test
fn parse_and_double(s: String) -> Result<i32, String> {
    let val: i32 = parse_i32(s)?
    Ok(val * 2)
}
fn main() {
    let r = parse_and_double(String_from("21"))
    match r { Result::Ok(v) => test::assert_eq_i32(v, 42), Result::Err(e) => panic(e) }
    stdio::println("ok")
}
