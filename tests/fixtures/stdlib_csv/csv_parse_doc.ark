use std::csv
use std::host::stdio

fn main() {
    match csv::csv_parse("a,b\n1,2") {
        Result::Ok(rows) => stdio::println(i32_to_string(len(rows))),
        Result::Err(e) => stdio::println(e),
    }
    let rows = Vec_new_Vec_String()
    push(rows, csv::csv_parse_row("x,y"))
    push(rows, csv::csv_parse_row("1,2"))
    stdio::println(csv::csv_stringify(rows))
}
// csv_parse row count
// csv_stringify round-trip shape
