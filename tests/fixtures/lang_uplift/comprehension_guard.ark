fn main() {
    let xs: Vec<i32> = Vec_new_i32()
    push(xs, 1)
    push(xs, 2)
    push(xs, 3)
    push(xs, 4)
    push(xs, 5)
    let filtered = [x for x in xs if x >= 3]
    let mut sum = 0
    for v in values(filtered) {
        sum = sum + v
    }
    __intrinsic_print(concat(i32_to_string(sum), "\n"))
}
