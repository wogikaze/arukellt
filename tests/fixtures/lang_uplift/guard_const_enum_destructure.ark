enum Opt {
    Some(i32),
    None,
}

fn describe(Opt::Some(v)) -> String | v > 10 = "big"
fn describe(Opt::Some(_)) -> String = "small"
fn describe(Opt::None) -> String = "none"

fn main() {
    __intrinsic_print(concat(describe(Opt::Some(42)), "\n"))
    __intrinsic_print(concat(describe(Opt::Some(5)), "\n"))
    __intrinsic_print(concat(describe(Opt::None), "\n"))
}
