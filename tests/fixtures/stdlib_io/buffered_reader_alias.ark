use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 65)
    bytes::bytes_push(data, 10)
    let r: Vec<i32> = io::reader_from_bytes(data)
    let br1: Vec<i32> = io::buf_reader_new(r, 64)
    let br2: Vec<i32> = io::buffered_reader(r, 64)
    let l1: Result<String, io::IoError> = io::buf_reader_read_line(br1)
    let l2: Result<String, io::IoError> = io::buf_reader_read_line(br2)
    match l1 {
        Result::Ok(s) => test::assert_eq_string(s, "A"),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
    match l2 {
        Result::Ok(s) => test::assert_eq_string(s, "A"),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
}
