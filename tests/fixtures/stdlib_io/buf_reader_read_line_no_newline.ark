use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 88)
    bytes::bytes_push(data, 89)
    bytes::bytes_push(data, 90)
    let r: Vec<i32> = io::reader_from_bytes(data)
    let br: Vec<i32> = io::buf_reader_new(r, 16)
    let res: Result<String, io::IoError> = io::buf_reader_read_line(br)
    match res {
        Result::Ok(line) => test::assert_eq_string(line, "XYZ"),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
}
