use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    let r: Vec<i32> = io::reader_from_bytes(data)
    let res: Result<Vec<i32>, io::IoError> = io::reader_read_all(r)
    match res {
        Result::Ok(chunk) => test::assert_eq_i32(bytes::bytes_len(chunk), 0),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
    test::assert_true(io::reader_eof(r))
}
