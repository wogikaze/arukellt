use std::host::fs
use std::test

fn main() {
    match fs::read_dir("some_dir") {
        Result::Ok(_) => panic("expected error"),
        Result::Err(err) => match err {
            fs::FsError::IoError(msg) => test::assert_true(contains(msg, "not yet supported")),
            _ => panic("expected IoError"),
        },
    }
}
