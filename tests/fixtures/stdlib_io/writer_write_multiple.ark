use std::bytes
use std::io
use std::test

fn main() {
    let w: Vec<i32> = io::writer_new()
    let _: Result<i32, io::IoError> = io::writer_write_str(w, "hello")
    let _: Result<i32, io::IoError> = io::writer_write_str(w, " world")
    let b: Vec<i32> = io::writer_to_bytes(w)
    test::assert_eq_string(bytes::string_from_bytes(b), "hello world")
}
