use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    let mut i: i32 = 0
    while i < 50 {
        bytes::bytes_push(data, i & 255)
        i = i + 1
    }
    let r: Vec<i32> = io::reader_from_bytes(data)
    let mut total: i32 = 0
    while !io::reader_eof(r) {
        let res: Result<Vec<i32>, io::IoError> = io::reader_read(r, 3)
        match res {
            Result::Ok(chunk) => total = total + bytes::bytes_len(chunk),
            Result::Err(e) => panic(io::io_error_message(e)),
        }
    }
    test::assert_eq_i32(total, 50)
}
