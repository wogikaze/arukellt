use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 1)
    bytes::bytes_push(data, 2)
    bytes::bytes_push(data, 3)
    bytes::bytes_push(data, 4)
    bytes::bytes_push(data, 5)
    let r: Vec<i32> = io::reader_from_bytes(data)
    let mut total: i32 = 0
    let mut i: i32 = 0
    while i < 5 {
        let res: Result<Vec<i32>, io::IoError> = io::reader_read(r, 1)
        match res {
            Result::Ok(chunk) => total = total + bytes::bytes_len(chunk),
            Result::Err(e) => panic(io::io_error_message(e)),
        }
        i = i + 1
    }
    test::assert_eq_i32(total, 5)
    test::assert_true(io::reader_eof(r))
}
