use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 104)
    bytes::bytes_push(data, 105)
    bytes::bytes_push(data, 106)
    let src: Vec<i32> = io::reader_from_bytes(data)
    let dst: Vec<i32> = io::writer_new()
    let res: Result<i32, io::IoError> = io::copy_bytes(src, dst)
    match res {
        Result::Ok(n) => test::assert_eq_i32(n, 3),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
    let b: Vec<i32> = io::writer_to_bytes(dst)
    test::assert_eq_string(bytes::string_from_bytes(b), "hij")
    test::assert_true(io::reader_eof(src))
}
