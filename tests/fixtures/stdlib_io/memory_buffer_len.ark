use std::bytes
use std::io
use std::test

fn main() {
    let buf: Vec<i32> = io::new_memory_buffer()
    test::assert_eq_i64(io::buffer_len(buf), 0)
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 1)
    bytes::bytes_push(data, 2)
    bytes::bytes_push(data, 3)
    let _: i32 = io::write_bytes(buf, data)
    test::assert_eq_i64(io::buffer_len(buf), 3)
}
