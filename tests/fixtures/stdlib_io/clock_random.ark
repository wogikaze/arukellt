use std::host::clock
use std::host::random as host_random
use std::host::stdio

fn main() {
    let t = clock::monotonic_now()
    let t_str = (t).to_string()
    let not_zero = t_str != String_from("0")
    stdio::println((not_zero).to_string())
    let r = host_random::random_i32()
    let has_value = r != 0 || r == 0
    stdio::println((has_value).to_string())
}
