use std::bytes
use std::io
use std::test

fn main() {
    let data: Vec<i32> = bytes::bytes_new()
    bytes::bytes_push(data, 10)
    bytes::bytes_push(data, 88)
    let r: Vec<i32> = io::reader_from_bytes(data)
    let res: Result<String, io::IoError> = io::reader_read_line(r)
    match res {
        Result::Ok(line) => test::assert_eq_string(line, ""),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
    let res2: Result<String, io::IoError> = io::reader_read_line(r)
    match res2 {
        Result::Ok(line) => test::assert_eq_string(line, "X"),
        Result::Err(e) => panic(io::io_error_message(e)),
    }
}
