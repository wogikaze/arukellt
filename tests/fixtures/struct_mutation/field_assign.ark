struct Point {
    x: i32,
    y: i32,
}

impl Point {
    fn translate(self, dx: i32, dy: i32) {
        self.x = self.x + dx
        self.y = self.y + dy
    }
}

fn main() -> i32 {
    let p = Point { x: 10, y: 20 }
    println(p.x)
    println(p.y)
    p.translate(5, 3)
    println(p.x)
    println(p.y)
    p.x = 100
    println(p.x)
    0
}
