use std::host::stdio

/// User-defined Eq trait verifying trait-based equality on structs with String fields.
trait Eq {
    fn eq(self: Eq, other: Eq) -> bool
}

struct Person {
    name: String,
    age: i32,
}

impl Eq for Person {
    fn eq(self: Person, other: Person) -> bool {
        eq(self.name, other.name) && self.age == other.age
    }
}

/// Generic function with Eq trait bound (pass-through).
fn check_eq<T: Eq>(a: T, b: T) -> T {
    a
}

fn main() {
    let alice = Person { name: String_from("Alice"), age: 30 }
    let alice2 = Person { name: String_from("Alice"), age: 30 }
    let bob = Person { name: String_from("Bob"), age: 30 }

    // Direct trait method call -- uses String field equality
    stdio::println((eq(alice, alice2)).to_string())
    stdio::println((eq(alice, bob)).to_string())

    // Generic function with Eq trait bound
    let p = check_eq(alice, alice2)
    stdio::println((eq(p, alice2)).to_string())
    stdio::println((eq(p, bob)).to_string())
}
