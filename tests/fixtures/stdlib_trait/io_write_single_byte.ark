use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    push(data, 65)

    let written = io::write_bytes(buf, data)
    test::assert_eq_i32(written, 1)

    let blen: i64 = io::buffer_len(buf)
    test::assert_eq_i64(blen, 1)

    let read = io::read_bytes(buf, 1)
    test::assert_eq_i32(len(read), 1)
    test::assert_eq_i32(get_unchecked(read, 0), 65)
}
