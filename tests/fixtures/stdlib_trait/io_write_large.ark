use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    for i in 0..100 {
        push(data, i % 256)
    }

    let written = io::write_bytes(buf, data)
    test::assert_eq_i32(written, 100)

    let blen: i64 = io::buffer_len(buf)
    test::assert_eq_i64(blen, 100)

    let read = io::read_bytes(buf, 100)
    test::assert_eq_i32(len(read), 100)
    test::assert_eq_i32(get_unchecked(read, 0), 0)
    test::assert_eq_i32(get_unchecked(read, 50), 50)
    test::assert_eq_i32(get_unchecked(read, 99), 99)
}
