use std::seq
use std::test

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)

    let s = seq::sort_by(v)
    test::assert_eq_i32(len(s), 5)
    test::assert_eq_i32(get_unchecked(s, 0), 1)
    test::assert_eq_i32(get_unchecked(s, 1), 2)
    test::assert_eq_i32(get_unchecked(s, 2), 3)
    test::assert_eq_i32(get_unchecked(s, 3), 4)
    test::assert_eq_i32(get_unchecked(s, 4), 5)
}
