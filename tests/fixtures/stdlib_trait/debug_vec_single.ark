use std::text::fmt
use std::test

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 42)
    test::assert_eq_string(fmt::debug_format_vec_i32(v), "[42]")

    let vs: Vec<String> = Vec_new_String()
    push(vs, String_from("a"))
    test::assert_eq_string(fmt::debug_format_vec_string(vs), "[\"a\"]")
}
