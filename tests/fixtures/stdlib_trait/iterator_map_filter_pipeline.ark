use std::core::iter
use std::test

fn double(x: i32) -> i32 { x * 2 }
fn is_even(x: i32) -> bool { x / 2 * 2 == x }

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)

    let result = iter::collect_map_filter_i32(v, double, is_even)
    test::assert_eq_i32(len(result), 2)
    test::assert_eq_i32(get_unchecked(result, 0), 4)
    test::assert_eq_i32(get_unchecked(result, 1), 8)
}
