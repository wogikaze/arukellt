use std::core::iter
use std::test

fn main() {
    let a: Vec<i32> = Vec_new_i32()
    let b: Vec<i32> = Vec_new_i32()
    push(b, 10)
    push(b, 20)

    let chained = iter::collect_chain_i32(a, b)
    test::assert_eq_i32(len(chained), 2)
    test::assert_eq_i32(get_unchecked(chained, 0), 10)
    test::assert_eq_i32(get_unchecked(chained, 1), 20)
}
