use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    push(data, 65)
    push(data, 66)
    push(data, 67)
    let _w = io::write_bytes(buf, data)

    // Advance cursor
    let _r = io::read_bytes(buf, 2)
    let pos1: i64 = io::position(buf)
    test::assert_eq_i64(pos1, 2)

    // Seek back to 0
    let pos2: i64 = io::seek_to(buf, 0)
    test::assert_eq_i64(pos2, 0)

    // Read from start
    let r = io::read_bytes(buf, 1)
    test::assert_eq_i32(get_unchecked(r, 0), 65)
}
