use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    push(data, 1)
    push(data, 2)
    push(data, 3)
    push(data, 4)
    push(data, 5)
    let _w = io::write_bytes(buf, data)

    let pos0: i64 = io::position(buf)
    test::assert_eq_i64(pos0, 0)

    let _r1 = io::read_bytes(buf, 2)
    let pos1: i64 = io::position(buf)
    test::assert_eq_i64(pos1, 2)

    let _r2 = io::read_bytes(buf, 2)
    let pos2: i64 = io::position(buf)
    test::assert_eq_i64(pos2, 4)

    let _r3 = io::read_bytes(buf, 2)
    let pos3: i64 = io::position(buf)
    test::assert_eq_i64(pos3, 5)
}
