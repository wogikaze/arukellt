// Issue #692: Clone / Default / From / Into trait group.
//
// Verifies:
// - Clone trait is defined with scalar impls.
// - Default trait is defined with scalar impls.
// - From<T> / Into<T> traits are defined with numeric widening impls.
//
// Note: Generic dispatch through `fn dup<T: Clone>(x: T) -> T { x.clone() }`
// requires `Self` return type support in the typechecker, which is not yet
// available. This fixture verifies that the trait definitions and impls
// compile correctly. Generic dispatch will be tested once `Self` support
// is added.
use std::host::stdio
use std::core::clone
use std::core::convert

fn main() {
    // Direct call to Clone::clone for i32 (via impl method dispatch).
    let n: i32 = 42
    let m: i32 = n.clone()
    stdio::println(i32_to_string(m))

    // Direct call to Clone::clone for String (via impl method dispatch).
    let s: String = String_from("hello")
    let t: String = s.clone()
    stdio::println(t)

    // Direct call to Into<i64> for i32 (via impl method dispatch).
    let wide: i64 = 456.into()
    stdio::println(i64_to_string(wide))
}
