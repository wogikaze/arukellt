use std::core::cmp
use std::test

fn main() {
    match (1.5).cmp(2.5) {
        Ordering::Less => {}
        _ => panic("expected Less"),
    }
    match (3.0).cmp(3.0) {
        Ordering::Equal => {}
        _ => panic("expected Equal"),
    }
    match (5.0).cmp(1.0) {
        Ordering::Greater => {}
        _ => panic("expected Greater"),
    }
}
