use std::core::iter
use std::test

fn add(a: i32, b: i32) -> i32 { a + b }

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, -10)
    push(v, -20)
    push(v, -30)
    push(v, -40)
    push(v, -50)

    let sum = iter::iter_sum_i32(v)
    test::assert_eq_i32(sum, -150)

    let folded = iter::iter_fold_i32(v, 0, add)
    test::assert_eq_i32(folded, -150)
}
