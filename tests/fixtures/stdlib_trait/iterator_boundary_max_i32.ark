use std::core::iter
use std::test

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 2147483647)
    push(v, 0)
    push(v, -2147483647)

    test::assert_eq_i32(get_unchecked(v, 0), 2147483647)
    test::assert_eq_i32(get_unchecked(v, 1), 0)
    test::assert_eq_i32(get_unchecked(v, 2), -2147483647)

    let collected = iter::collect_take_i32(v, 1)
    test::assert_eq_i32(get_unchecked(collected, 0), 2147483647)
}
