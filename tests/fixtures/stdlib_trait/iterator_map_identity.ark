use std::core::iter
use std::test

fn identity(x: i32) -> i32 { x }

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)

    let mapped = iter::collect_map_i32(v, identity)
    test::assert_eq_i32(len(mapped), 3)
    test::assert_eq_i32(get_unchecked(mapped, 0), 10)
    test::assert_eq_i32(get_unchecked(mapped, 1), 20)
    test::assert_eq_i32(get_unchecked(mapped, 2), 30)
}
