use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    push(data, 1)
    push(data, 2)
    let _w = io::write_bytes(buf, data)

    let read = io::read_bytes(buf, 0)
    test::assert_eq_i32(len(read), 0)

    let pos: i64 = io::position(buf)
    test::assert_eq_i64(pos, 0)
}
