use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    push(data, 10)
    push(data, 20)
    push(data, 30)
    push(data, 40)
    let _w = io::write_bytes(buf, data)

    // Consume 2 bytes
    let _r = io::read_bytes(buf, 2)

    // fill_buf should return remaining 2 bytes
    let filled = io::fill_buffer(buf)
    test::assert_eq_i32(len(filled), 2)
    test::assert_eq_i32(get_unchecked(filled, 0), 30)
    test::assert_eq_i32(get_unchecked(filled, 1), 40)

    // Cursor should still be at 2
    let pos: i64 = io::position(buf)
    test::assert_eq_i64(pos, 2)
}
