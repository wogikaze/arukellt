use std::core::iter
use std::test

fn main() {
    let v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)

    let skipped = iter::collect_skip_i32(v, 2)
    test::assert_eq_i32(len(skipped), 3)
    test::assert_eq_i32(get_unchecked(skipped, 0), 3)
    test::assert_eq_i32(get_unchecked(skipped, 1), 4)
    test::assert_eq_i32(get_unchecked(skipped, 2), 5)
}
