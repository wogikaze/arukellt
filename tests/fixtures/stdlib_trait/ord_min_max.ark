use std::core::cmp
use std::test

fn main() {
    test::assert_eq_i32(cmp::min(3, 7), 3)
    test::assert_eq_i32(cmp::min(7, 3), 3)
    test::assert_eq_i32(cmp::min(5, 5), 5)

    test::assert_eq_i32(cmp::max(3, 7), 7)
    test::assert_eq_i32(cmp::max(7, 3), 7)
    test::assert_eq_i32(cmp::max(5, 5), 5)

    // Negative values
    test::assert_eq_i32(cmp::min(-5, 3), -5)
    test::assert_eq_i32(cmp::max(-5, 3), 3)
}
