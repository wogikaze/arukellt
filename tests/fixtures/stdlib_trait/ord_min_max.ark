use std::core::cmp
use std::test

fn main() {
    test::assert_eq_i32(3.min(7), 3)
    test::assert_eq_i32(7.min(3), 3)
    test::assert_eq_i32(5.min(5), 5)

    test::assert_eq_i32(3.max(7), 7)
    test::assert_eq_i32(7.max(3), 7)
    test::assert_eq_i32(5.max(5), 5)

    // Negative values
    test::assert_eq_i32(-5.min(3), -5)
    test::assert_eq_i32(-5.max(3), 3)
}
