use std::io
use std::test

fn main() {
    let buf = io::new_memory_buffer()
    let data: Vec<i32> = Vec_new_i32()
    push(data, 1)
    push(data, 2)
    push(data, 3)
    push(data, 4)
    push(data, 5)
    let _w = io::write_bytes(buf, data)

    let filled = io::fill_buffer(buf)
    test::assert_eq_i32(len(filled), 5)
    test::assert_eq_i32(get_unchecked(filled, 0), 1)
    test::assert_eq_i32(get_unchecked(filled, 4), 5)

    // fill_buf does not consume
    let pos: i64 = io::position(buf)
    test::assert_eq_i64(pos, 0)
}
