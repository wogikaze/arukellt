use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

impl Add for Point {
    fn add(self: Point, other: Point) -> Point {
        Point { x: self.x + other.x, y: self.y + other.y }
    }
}

fn main() {
    let a = Point { x: 1, y: 2 }
    let b = Point { x: 3, y: 4 }
    let c = a + b
    stdio::println(c.x)
    stdio::println(c.y)
}
