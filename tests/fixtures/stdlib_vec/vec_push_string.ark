use std::test

fn main() {
    let mut v: Vec<String> = Vec_new_String()
    push(v, String_from("alpha"))
    push(v, String_from("beta"))
    push(v, String_from("gamma"))
    test::assert_eq_i32(len(v), 3)
    test::assert_eq_string(get_unchecked(v, 0), String_from("alpha"))
    test::assert_eq_string(get_unchecked(v, 1), String_from("beta"))
    test::assert_eq_string(get_unchecked(v, 2), String_from("gamma"))
}
