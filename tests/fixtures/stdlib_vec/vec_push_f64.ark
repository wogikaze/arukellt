use std::test

fn main() {
    let mut v: Vec<f64> = Vec_new_f64()
    push(v, 1.5)
    push(v, 2.5)
    push(v, 3.5)
    test::assert_eq_i32(len(v), 3)
    test::assert_eq_f64(get_unchecked(v, 0), 1.5)
    test::assert_eq_f64(get_unchecked(v, 1), 2.5)
    test::assert_eq_f64(get_unchecked(v, 2), 3.5)
}
