use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    test::assert_eq_i32(len(v), 2)
    test::assert_eq_i32(get_unchecked(v, 0), 10)
    test::assert_eq_i32(get_unchecked(v, 1), 20)
    set(v, 0, 100)
    set(v, 1, 200)
    test::assert_eq_i32(get_unchecked(v, 0), 100)
    test::assert_eq_i32(get_unchecked(v, 1), 200)
}
