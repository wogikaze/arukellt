use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    reverse_i32(v)
    test::assert_eq_i32(get_unchecked(v, 0), 4)
    test::assert_eq_i32(get_unchecked(v, 1), 3)
    test::assert_eq_i32(get_unchecked(v, 2), 2)
    test::assert_eq_i32(get_unchecked(v, 3), 1)
}
