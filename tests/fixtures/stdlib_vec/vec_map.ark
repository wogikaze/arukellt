use std::test

fn double(x: i32) -> i32 {
    x * 2
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    let doubled: Vec<i32> = map_i32_i32(v, double)
    test::assert_eq_i32(len(doubled), 3)
    test::assert_eq_i32(get_unchecked(doubled, 0), 2)
    test::assert_eq_i32(get_unchecked(doubled, 1), 4)
    test::assert_eq_i32(get_unchecked(doubled, 2), 6)
}
