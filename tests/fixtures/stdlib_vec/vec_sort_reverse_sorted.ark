use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 50)
    push(v, 40)
    push(v, 30)
    push(v, 20)
    push(v, 10)
    sort_i32(v)
    test::assert_eq_i32(get_unchecked(v, 0), 10)
    test::assert_eq_i32(get_unchecked(v, 1), 20)
    test::assert_eq_i32(get_unchecked(v, 2), 30)
    test::assert_eq_i32(get_unchecked(v, 3), 40)
    test::assert_eq_i32(get_unchecked(v, 4), 50)
}
