use std::test

fn square(x: i32) -> i32 {
    x * x
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    let result: Vec<i32> = map_i32_i32(v, square)
    test::assert_eq_i32(get_unchecked(result, 0), 1)
    test::assert_eq_i32(get_unchecked(result, 1), 4)
    test::assert_eq_i32(get_unchecked(result, 2), 9)
    test::assert_eq_i32(get_unchecked(result, 3), 16)
}
