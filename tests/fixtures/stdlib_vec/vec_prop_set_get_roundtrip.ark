use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    set(v, 0, 100)
    match get(v, 0) {
        Option::Some(val) => test::assert_eq_i32(val, 100),
        None => panic("expected Some, got None"),
    }
    set(v, 2, 300)
    match get(v, 2) {
        Option::Some(val) => test::assert_eq_i32(val, 300),
        None => panic("expected Some, got None"),
    }
    test::assert_eq_i32(get_unchecked(v, 1), 20)
}
