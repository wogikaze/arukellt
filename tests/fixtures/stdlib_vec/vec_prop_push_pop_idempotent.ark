use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    let len_before: i32 = len(v)
    match pop(v) {
        Option::Some(_) => {
        },
        None => panic("expected Some, got None"),
    }
    push(v, 30)
    test::assert_eq_i32(len(v), len_before)
    test::assert_eq_i32(get_unchecked(v, 0), 10)
    test::assert_eq_i32(get_unchecked(v, 1), 20)
    test::assert_eq_i32(get_unchecked(v, 2), 30)
}
