use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 42)
    test::assert_eq_i32(len(v), 1)
    test::assert_false(is_empty(v))
    test::assert_eq_i32(get_unchecked(v, 0), 42)
    match get(v, 0) {
        Option::Some(val) => test::assert_eq_i32(val, 42),
        None => panic("expected Some, got None"),
    }
    match pop(v) {
        Option::Some(val) => test::assert_eq_i32(val, 42),
        None => panic("expected Some, got None"),
    }
    test::assert_eq_i32(len(v), 0)
    test::assert_true(is_empty(v))
}
