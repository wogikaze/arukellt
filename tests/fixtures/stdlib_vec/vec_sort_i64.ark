use std::test

fn main() {
    let mut v: Vec<i64> = Vec_new_i64()
    let a: i64 = 30
    let b: i64 = 10
    let c: i64 = 20
    push(v, a)
    push(v, b)
    push(v, c)
    sort_i64(v)
    test::assert_eq_i64(get_unchecked(v, 0), 10)
    test::assert_eq_i64(get_unchecked(v, 1), 20)
    test::assert_eq_i64(get_unchecked(v, 2), 30)
}
