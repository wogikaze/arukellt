use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, -10)
    push(v, 30)
    push(v, -5)
    push(v, 20)
    push(v, 0)
    sort_i32(v)
    test::assert_eq_i32(get_unchecked(v, 0), -10)
    test::assert_eq_i32(get_unchecked(v, 1), -5)
    test::assert_eq_i32(get_unchecked(v, 2), 0)
    test::assert_eq_i32(get_unchecked(v, 3), 20)
    test::assert_eq_i32(get_unchecked(v, 4), 30)
}
