use std::test

fn identity(x: i32) -> i32 {
    x
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    let result: Vec<i32> = map_i32_i32(v, identity)
    test::assert_eq_i32(len(result), 3)
    test::assert_eq_i32(get_unchecked(result, 0), 10)
    test::assert_eq_i32(get_unchecked(result, 1), 20)
    test::assert_eq_i32(get_unchecked(result, 2), 30)
}
