use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    let mut i: i32 = 0
    while i < 100 {
        push(v, i * 2)
        i = i + 1
    }
    test::assert_eq_i32(len(v), 100)
    test::assert_eq_i32(get_unchecked(v, 0), 0)
    test::assert_eq_i32(get_unchecked(v, 50), 100)
    test::assert_eq_i32(get_unchecked(v, 99), 198)
}
