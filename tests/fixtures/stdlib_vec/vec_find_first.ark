use std::test

fn is_three(x: i32) -> bool {
    x == 3
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    let result = find_i32(v, is_three)
    match result {
        Option::Some(val) => test::assert_eq_i32(val, 3),
        None => panic("expected Some, got None"),
    }
}
