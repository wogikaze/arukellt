use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    let mut i: i32 = 0
    while i < 100 {
        push(v, 0)
        i = i + 1
    }
    let mut j: i32 = 0
    while j < 100 {
        set(v, j, j * 3)
        j = j + 1
    }
    test::assert_eq_i32(len(v), 100)
    test::assert_eq_i32(get_unchecked(v, 0), 0)
    test::assert_eq_i32(get_unchecked(v, 50), 150)
    test::assert_eq_i32(get_unchecked(v, 99), 297)
}
