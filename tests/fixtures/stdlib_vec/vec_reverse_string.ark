use std::test

fn main() {
    let mut v: Vec<String> = Vec_new_String()
    push(v, String_from("a"))
    push(v, String_from("b"))
    push(v, String_from("c"))
    reverse_String(v)
    test::assert_eq_string(get_unchecked(v, 0), String_from("c"))
    test::assert_eq_string(get_unchecked(v, 1), String_from("b"))
    test::assert_eq_string(get_unchecked(v, 2), String_from("a"))
}
