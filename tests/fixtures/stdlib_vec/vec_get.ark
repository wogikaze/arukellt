fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    match get(v, 1) {
        Some(val) => println(i32_to_string(val)),
        None => println("out of bounds"),
    }
    match get(v, 5) {
        Some(val) => println(i32_to_string(val)),
        None => println("out of bounds"),
    }
}
