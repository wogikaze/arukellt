use std::host::stdio

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    match get(v, 1) {
        Option::Some(val) => stdio::println(i32_to_string(val)),
        None => stdio::println("out of bounds"),
    }
    match get(v, 5) {
        Option::Some(val) => stdio::println(i32_to_string(val)),
        None => stdio::println("out of bounds"),
    }
}
