use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    match get(v, 1) {
        Option::Some(val) => test::assert_eq_i32(val, 20),
        None => panic("expected Some, got None"),
    }
    match get(v, 5) {
        Option::Some(val) => panic("expected None, got Some"),
        None => {
        },
    }
}
