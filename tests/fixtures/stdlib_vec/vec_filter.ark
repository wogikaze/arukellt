fn is_even(x: i32) -> bool {
    x % 2 == 0
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    push(v, 5)
    let evens: Vec<i32> = filter_i32(v, is_even)
    let mut i: i32 = 0
    while i < len(evens) {
        println(i32_to_string(get_unchecked(evens, i)))
        i = i + 1
    }
}
