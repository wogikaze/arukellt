use std::host::stdio

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    let last: Option<i32> = pop(v)
    match last {
        Option::Some(val) => stdio::println(i32_to_string(val)),
        None => stdio::println("empty"),
    }
    stdio::println(i32_to_string(len(v)))
}
