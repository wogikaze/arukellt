use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    let last: Option<i32> = pop(v)
    match last {
        Option::Some(val) => test::assert_eq_i32(val, 20),
        None => panic("expected Some, got None"),
    }
    test::assert_eq_i32(len(v), 1)
}
