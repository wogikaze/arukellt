use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    set(v, 0, 10)
    set(v, 1, 20)
    set(v, 2, 30)
    test::assert_eq_i32(get_unchecked(v, 0), 10)
    test::assert_eq_i32(get_unchecked(v, 1), 20)
    test::assert_eq_i32(get_unchecked(v, 2), 30)
}
