fn is_even(x: i32) -> bool {
    x % 2 == 0
}

fn is_negative(x: i32) -> bool {
    x < 0
}

fn main() {
    let v = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)

    let has_even: bool = any_i32(v, is_even)
    if has_even {
        println(String_from("has even: true"))
    } else {
        println(String_from("has even: false"))
    }

    let found = find_i32(v, is_even)
    match found {
        Some(x) => println(f"first even: {x}"),
        None => println(String_from("none")),
    }

    let empty = Vec_new_i32()
    let any_empty: bool = any_i32(empty, is_even)
    if any_empty {
        println(String_from("empty has even: true"))
    } else {
        println(String_from("empty has even: false"))
    }

    let find_neg = find_i32(v, is_negative)
    match find_neg {
        Some(x) => println(f"found negative: {x}"),
        None => println(String_from("no negatives")),
    }
}
