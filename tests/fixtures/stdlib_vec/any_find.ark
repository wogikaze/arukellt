use std::test

fn is_even(x: i32) -> bool {
    x % 2 == 0
}

fn is_negative(x: i32) -> bool {
    x < 0
}

fn main() {
    let v = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    push(v, 4)
    let has_even: bool = any_i32(v, is_even)
    test::assert_true(has_even)

    let found = find_i32(v, is_even)
    match found {
        Option::Some(x) => test::assert_eq_i32(x, 2),
        None => panic("expected Some, got None"),
    }

    let empty = Vec_new_i32()
    let any_empty: bool = any_i32(empty, is_even)
    test::assert_false(any_empty)

    let find_neg = find_i32(v, is_negative)
    match find_neg {
        Option::Some(x) => panic("expected None, got Some"),
        None => {
        },
    }
}
