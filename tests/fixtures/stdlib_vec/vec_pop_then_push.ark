use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    match pop(v) {
        Option::Some(val) => test::assert_eq_i32(val, 20),
        None => panic("expected Some, got None"),
    }
    push(v, 30)
    test::assert_eq_i32(len(v), 2)
    test::assert_eq_i32(get_unchecked(v, 0), 10)
    test::assert_eq_i32(get_unchecked(v, 1), 30)
}
