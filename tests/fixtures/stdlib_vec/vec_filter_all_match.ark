use std::test

fn is_positive(x: i32) -> bool {
    x > 0
}

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 1)
    push(v, 2)
    push(v, 3)
    let result: Vec<i32> = filter_i32(v, is_positive)
    test::assert_eq_i32(len(result), 3)
    test::assert_eq_i32(get_unchecked(result, 0), 1)
    test::assert_eq_i32(get_unchecked(result, 1), 2)
    test::assert_eq_i32(get_unchecked(result, 2), 3)
}
