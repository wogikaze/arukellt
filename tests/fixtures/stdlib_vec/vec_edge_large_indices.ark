use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    match get(v, 1000) {
        Option::Some(val) => panic("expected None, got Some"),
        None => {
        },
    }
    match get(v, 99999) {
        Option::Some(val) => panic("expected None, got Some"),
        None => {
        },
    }
}
