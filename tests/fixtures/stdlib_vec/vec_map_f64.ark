use std::test

fn square(x: f64) -> f64 {
    x * x
}

fn main() {
    let mut v: Vec<f64> = Vec_new_f64()
    push(v, 2.0)
    push(v, 3.0)
    push(v, 4.0)
    let result: Vec<f64> = map_f64_f64(v, square)
    test::assert_eq_f64(get_unchecked(result, 0), 4.0)
    test::assert_eq_f64(get_unchecked(result, 1), 9.0)
    test::assert_eq_f64(get_unchecked(result, 2), 16.0)
}
