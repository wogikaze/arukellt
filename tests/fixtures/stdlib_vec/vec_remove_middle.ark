use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    push(v, 40)
    push(v, 50)
    remove_i32(v, 2)
    test::assert_eq_i32(len(v), 4)
    test::assert_eq_i32(get_unchecked(v, 0), 10)
    test::assert_eq_i32(get_unchecked(v, 1), 20)
    test::assert_eq_i32(get_unchecked(v, 2), 40)
    test::assert_eq_i32(get_unchecked(v, 3), 50)
}
