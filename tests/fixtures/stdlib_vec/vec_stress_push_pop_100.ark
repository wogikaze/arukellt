use std::test

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    let mut i: i32 = 0
    while i < 100 {
        push(v, i)
        i = i + 1
    }
    let mut j: i32 = 0
    while j < 50 {
        match pop(v) {
            Option::Some(val) => test::assert_eq_i32(val, 99 - j),
            None => panic("expected Some, got None"),
        }
        j = j + 1
    }
    test::assert_eq_i32(len(v), 50)
    test::assert_eq_i32(get_unchecked(v, 0), 0)
    test::assert_eq_i32(get_unchecked(v, 49), 49)
}
