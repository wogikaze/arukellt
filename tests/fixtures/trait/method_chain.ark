struct Vec2 {
    x: i32,
    y: i32,
}

impl Vec2 {
    fn new(x: i32, y: i32) -> Vec2 {
        Vec2 { x: x, y: y }
    }

    fn add(self, other: Vec2) -> Vec2 {
        Vec2 { x: self.x + other.x, y: self.y + other.y }
    }

    fn scale(self, factor: i32) -> Vec2 {
        Vec2 { x: self.x * factor, y: self.y * factor }
    }

    fn magnitude_sq(self) -> i32 {
        self.x * self.x + self.y * self.y
    }
}

fn main() {
    let a = Vec2 { x: 1, y: 2 }
    let b = Vec2 { x: 3, y: 4 }
    let c = a.add(b)
    println(c.x)
    println(c.y)

    let d = a.scale(10)
    println(d.x)
    println(d.y)

    println(a.magnitude_sq())
}
