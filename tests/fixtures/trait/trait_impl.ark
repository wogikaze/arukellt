use std::host::stdio

trait Greet {
    fn greet(self: Greet) -> String
}

struct Dog {
    name: String,
}

impl Greet for Dog {
    fn greet(self: Dog) -> String {
        concat(String_from("Woof! I'm "), self.name)
    }
}

fn main() {
    let d: Dog = Dog { name: String_from("Rex") }
    stdio::println(d.greet())
}
