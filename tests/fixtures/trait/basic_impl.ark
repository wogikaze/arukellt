use std::host::stdio

struct Point {
    x: i32,
    y: i32,
}

impl Point {
    fn sum(self: Point) -> i32 {
        self.x + self.y
    }

    fn add(self: Point, other: Point) -> Point {
        Point { x: self.x + other.x, y: self.y + other.y }
    }
}

fn main() {
    let p = Point { x: 3, y: 4 }
    let q = Point { x: 10, y: 20 }
    stdio::println(p.sum())
    let r = p.add(q)
    stdio::println(r.x)
    stdio::println(r.y)
}
