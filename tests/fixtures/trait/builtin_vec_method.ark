use std::host::stdio

fn main() {
    // Vec<T> method syntax via impl Vec<T> block (approach (a) for #700)
    let v = Vec_new_i32()
    v.push(10)
    v.push(20)
    v.push(30)
    stdio::println(v.len())
    stdio::println(v.get_unchecked(0))
    stdio::println(v.get_unchecked(1))
    stdio::println(v.get_unchecked(2))
}
