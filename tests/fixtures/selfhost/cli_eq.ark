use std::host::stdio

fn cli_str_eq(a: String, b: String) -> bool {
    let alen = len(clone(a))
    let blen = len(clone(b))
    if alen != blen {
        return false
    }
    let mut i = 0
    while i < alen {
        let ca = char_at(clone(a), i)
        let cb = char_at(clone(b), i)
        if ca != cb {
            return false
        }
        i = i + 1
    }
    true
}

fn main() {
    stdio::println(to_string(cli_str_eq(String_from("a"), String_from("b"))))
}
