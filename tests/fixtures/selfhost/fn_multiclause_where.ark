// Positive fixture: where clause with value bindings shared across multi-clause fn
// Tests that where bindings can reference the clause param and are scoped to all clauses
use std::host::stdio

struct Point { x: i32, y: i32 }

fn describe(pt) -> String | m == 0 = "origin"
fn describe(pt) -> String | m < 10 = "near"
fn describe(_) -> String = "far"
where
    m = pt.x * pt.x + pt.y * pt.y

fn main() {
    stdio::println(describe(Point { x: 0, y: 0 }))
    stdio::println(describe(Point { x: 1, y: 2 }))
    stdio::println(describe(Point { x: 5, y: 5 }))
}
