// Test: selfhost typechecker detects return type mismatch in explicit return statements.
// Exercises: function with declared return type i32 but explicit return of String.
use std::host::stdio

fn bad() -> i32 {
    return String_from("hello")
}

fn main() {
    stdio::println(String_from("should not reach"))
}
// Explicit return statement returns String, but function declares i32 return type
