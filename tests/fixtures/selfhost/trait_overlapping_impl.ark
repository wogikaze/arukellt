use std::host::stdio

trait Foo {
    fn id(x: i32) -> i32,
}

struct MyStruct {
    value: i32,
}

impl Foo for MyStruct {
    fn id(x: MyStruct) -> i32 {
        x.value
    }
}

impl Foo for MyStruct {
    fn id(x: MyStruct) -> i32 {
        x.value + 1
    }
}

fn main() {
    stdio::println(String_from("hello"))
}
