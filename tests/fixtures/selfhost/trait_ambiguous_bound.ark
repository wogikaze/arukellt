use std::host::stdio

trait Foo {
    fn id(x: i32) -> i32,
}

struct MyStruct {
    value: i32,
}

impl Foo for MyStruct {
    fn id(x: MyStruct) -> i32 {
        x.value
    }
}

// T only appears in the return type, so inference from call site
// cannot resolve it to a concrete type
fn ambiguous<T: Foo>() -> i32 {
    0
}

fn main() {
    // T cannot be inferred → ambiguous trait bound
    let item = ambiguous()
    stdio::println(to_string(item))
}
