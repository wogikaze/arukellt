use std::host::stdio

trait Foo {
    fn id(x: i32) -> i32,
}

impl Foo for i32 {
    fn id(x: i32) -> i32 {
        x
    }
}

// T appears only in return type, not in params, so T stays unresolved
// from the argument types at call site
fn ambiguous<T: Foo>() -> T {
    // This won't type check either, but the ambiguity should be caught first
    let x = 42
    x // type mismatch
}

fn main() {
    let item = ambiguous()
    stdio::println(to_string(item))
}
