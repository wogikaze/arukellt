use std::host::stdio

struct MyStruct {
    value: i32,
}

impl Foo for MyStruct {
    fn id(x: MyStruct) -> i32 {
        x.value
    }
}

struct OtherStruct {
    value: i32,
}

fn take_foo<T: Foo>(x: T) -> T {
    x
}

fn main() {
    let item = take_foo(OtherStruct { value: 7 })
    stdio::println(to_string(item.value))
}
