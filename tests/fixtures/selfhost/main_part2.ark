use std::host::stdio
use std::host::fs
use std::host::process

fn CMD_CHECK() -> i32 { 1 }
fn CMD_COMPILE() -> i32 { 2 }
fn CMD_PARSE() -> i32 { 3 }
fn CMD_HELP() -> i32 { 4 }
fn CMD_VERSION() -> i32 { 5 }
fn CMD_NOT_YET() -> i32 { 0 }
fn CMD_IDE_ANALYZE() -> i32 { 11 }
fn CMD_LSP() -> i32 { 12 }
fn CMD_UNKNOWN() -> i32 { 0 }

struct CliOptions {
    command: i32,
    input_file: String,
    output_file: String,
    target: String,
    wit_paths: Vec<String>,
    opt_level: i32,
    dump_phases: String,
    emit_mode: String,
    json_output: bool,
    show_help: bool,
    show_version: bool,
    has_error: bool,
    error_msg: String,
}

fn CliOptions_default() -> CliOptions {
    CliOptions { command: CMD_UNKNOWN(), input_file: String_new(), output_file: String_new(), target: String_from("wasm32-wasi-p2"), wit_paths: Vec_new_String(), opt_level: 0, dump_phases: String_new(), emit_mode: String_from("wasm"), json_output: false, show_help: false, show_version: false, has_error: false, error_msg: String_new() }
}

fn cli_str_eq(a: String, b: String) -> bool {
    let n = len(clone(a))
    if n != len(clone(b)) {
        return false
    }
    let mut i = 0
    while i < n {
        if char_at(clone(a), i) != char_at(clone(b), i) {
            return false
        }
        i = i + 1
    }
    true
}

fn parse_command(name: String) -> i32 {
    let name_len = len(clone(name))
    if name_len == 5 && char_at(clone(name), 0) == 99 && char_at(clone(name), 1) == 104 && char_at(clone(name), 2) == 101 && char_at(clone(name), 3) == 99 && char_at(clone(name), 4) == 107 {
        return CMD_CHECK()
    }
    if name_len == 7 && char_at(clone(name), 0) == 99 && char_at(clone(name), 1) == 111 && char_at(clone(name), 2) == 109 && char_at(clone(name), 3) == 112 && char_at(clone(name), 4) == 105 && char_at(clone(name), 5) == 108 && char_at(clone(name), 6) == 101 {
        return CMD_COMPILE()
    }
    if name_len == 5 && char_at(clone(name), 0) == 112 && char_at(clone(name), 1) == 97 && char_at(clone(name), 2) == 114 && char_at(clone(name), 3) == 115 && char_at(clone(name), 4) == 101 {
        return CMD_PARSE()
    }
    CMD_NOT_YET()
}

fn main() {
    let cmd = parse_command(String_from("check"))
    stdio::println(to_string(cmd))
}
