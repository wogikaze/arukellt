// Positive fixture: enum-pattern multi-clause function with guards
// Tests that enum variant patterns with guards work on clause heads
// Note: The MIR lowerer has a known issue with enum+guard+non-matching-tag
// (see enum_match_guard_bug.ark), so this only tests the matching case.
use std::host::stdio

enum Level { Low, Medium, High }

fn describe(Level::Low) -> String | true = "low"
fn describe(_) -> String = "other"

fn main() {
    stdio::println(describe(Level::Low))
}
