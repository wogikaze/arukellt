// Positive fixture: enum-pattern multi-clause function with guards
// Tests that enum variant patterns with guards work on clause heads
use std::host::stdio

enum Num { Small(i32), Large(i32) }

fn describe(Small(n)) -> String | n < 10 = "tiny"
fn describe(Small(n)) -> String = "small"
fn describe(Large(n)) -> String | n > 1000 = "huge"
fn describe(Large(_)) -> String = "large"

fn main() {
    stdio::println(describe(Num::Small(5)))
    stdio::println(describe(Num::Small(15)))
    stdio::println(describe(Num::Large(2000)))
    stdio::println(describe(Num::Large(500)))
}
