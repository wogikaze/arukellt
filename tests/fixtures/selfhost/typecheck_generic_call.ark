// Test: selfhost typechecker generic function call type argument inference
// Verifies: calling a generic fn like identity<T>(x: T) -> T with an i32
//           argument infers T=i32 and produces the correct return type.
use std::host::stdio

fn identity<T>(x: T) -> T {
    x
}

fn first<A, B>(a: A, b: B) -> A {
    a
}

fn main() {
    let a: i32 = identity(42)
    stdio::println(to_string(a))
    let b: bool = identity(true)
    if b {
        stdio::println(String_from("true"))
    } else {
        stdio::println(String_from("false"))
    }
    let s: String = identity(String_from("hello"))
    stdio::println(s)
    let f: i32 = first(99, String_from("ignored"))
    stdio::println(to_string(f))
    stdio::println(String_from("Generic call OK."))
}
// identity(42) → T=i32, result: i32
// identity with bool → T=bool
// identity with string → T=String
// two type params: first<A, B>(a: A, b: B) -> A
