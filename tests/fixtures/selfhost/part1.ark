// Arukellt Selfhost — CLI Entry Point
//
// Command surface for the self-hosted compiler.
// Supports: parse, compile, check subcommands.
// Exit code: 0 = success, 1 = failure.
use std::host::env
use std::host::fs
use std::host::process
use std::host::stdio

use driver
use diagnostics
use analysis
use lsp
fn CMD_PARSE() -> i32 {
    1
}

fn CMD_COMPILE() -> i32 {
    2
}

fn CMD_CHECK() -> i32 {
    3
}

fn CMD_HELP() -> i32 {
    4
}

fn CMD_VERSION() -> i32 {
    5
}

fn CMD_RUN() -> i32 {
    6
}

fn CMD_BUILD() -> i32 {
    7
}

fn CMD_TEST() -> i32 {
    8
}

fn CMD_UNKNOWN() -> i32 {
    0
}

fn CMD_NOT_YET() -> i32 {
    10
}

fn CMD_IDE_ANALYZE() -> i32 {
    11
}

fn CMD_LSP() -> i32 {
    12
}

// ── Parsed CLI ───────────────────────────────────────────────────────────────
struct CliOptions {
    command: i32,
    input_file: String,
    output_file: String,
    target: String,
    wit_paths: Vec<String>,
    opt_level: i32,
    dump_phases: String,
    emit_mode: String,
    json_output: bool,
    show_help: bool,
    show_version: bool,
    has_error: bool,
    error_msg: String,
}

fn CliOptions_default() -> CliOptions {
    CliOptions { command: CMD_UNKNOWN(), input_file: String_new(), output_file: String_new(), target: String_from("wasm32-wasi-p2"), wit_paths: Vec_new_String(), opt_level: 0, dump_phases: String_new(), emit_mode: String_from("wasm"), json_output: false, show_help: false, show_version: false, has_error: false, error_msg: String_new() }
}

// ── Argument Parsing ─────────────────────────────────────────────────────────
fn cli_str_eq(a: String, b: String) -> bool {
    let n = len(clone(a))
    if n != len(clone(b)) {
        return false
    }
    let mut i = 0
    while i < n {
        if char_at(clone(a), i) != char_at(clone(b), i) {
            return false
        }
        i = i + 1
    }
    true
}

fn parse_command(name: String) -> i32 {
    let name_len = len(clone(name))
    if name_len == 5 && char_at(clone(name), 0) == 99 && char_at(clone(name), 1) == 104 && char_at(clone(name), 2) == 101 && char_at(clone(name), 3) == 99 && char_at(clone(name), 4) == 107 {
        return CMD_CHECK()
    }
    if name_len == 7 && char_at(clone(name), 0) == 99 && char_at(clone(name), 1) == 111 && char_at(clone(name), 2) == 109 && char_at(clone(name), 3) == 112 && char_at(clone(name), 4) == 105 && char_at(clone(name), 5) == 108 && char_at(clone(name), 6) == 101 {
        return CMD_COMPILE()
    }
    if name_len == 5 && char_at(clone(name), 0) == 112 && char_at(clone(name), 1) == 97 && char_at(clone(name), 2) == 114 && char_at(clone(name), 3) == 115 && char_at(clone(name), 4) == 101 {
        return CMD_PARSE()
    }
    if name_len == 4 && char_at(clone(name), 0) == 104 && char_at(clone(name), 1) == 101 && char_at(clone(name), 2) == 108 && char_at(clone(name), 3) == 112 {
        return CMD_HELP()
    }
    if name_len == 7 && char_at(clone(name), 0) == 118 && char_at(clone(name), 1) == 101 && char_at(clone(name), 2) == 114 && char_at(clone(name), 3) == 115 && char_at(clone(name), 4) == 105 && char_at(clone(name), 5) == 111 && char_at(clone(name), 6) == 110 {
        return CMD_VERSION()
    }
    if cli_str_eq(clone(name), String_from("parse")) {
        return CMD_PARSE()
    }
    if cli_str_eq(clone(name), String_from("compile")) {
        return CMD_COMPILE()
    }
    if cli_str_eq(clone(name), String_from("check")) {
        return CMD_CHECK()
    }
    if cli_str_eq(clone(name), String_from("run")) {
        return CMD_RUN()
    }
    if cli_str_eq(clone(name), String_from("build")) {
        return CMD_BUILD()
    }
    if cli_str_eq(clone(name), String_from("test")) {
        return CMD_TEST()
    }
    if cli_str_eq(clone(name), String_from("help")) {
        return CMD_HELP()
    }
    if cli_str_eq(clone(name), String_from("version")) {
        return CMD_VERSION()
    }
    if cli_str_eq(clone(name), String_from("init")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("fmt")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("targets")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("script")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("component")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("lsp")) {
        return CMD_LSP()
    }
    if cli_str_eq(clone(name), String_from("debug-adapter")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("lint")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("analyze")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("ide-analyze")) {
        return CMD_IDE_ANALYZE()
    }
    if cli_str_eq(clone(name), String_from("doc")) {
        return CMD_NOT_YET()
    }
    if cli_str_eq(clone(name), String_from("compose")) {
        return CMD_NOT_YET()
    }
    CMD_UNKNOWN()
}

fn parse_args(argv: Vec<String>) -> CliOptions {
    let opts = CliOptions_default()
    let argc = len(argv)
    if argc <= 1 {
        opts.show_help = true
        return opts
    }
    let cmd_str = get_unchecked(argv, 1)
    let cmd_len = len(clone(cmd_str))
    let cmd_is_check = cmd_len == 5 && char_at(clone(cmd_str), 0) == 99 && char_at(clone(cmd_str), 1) == 104 && char_at(clone(cmd_str), 2) == 101 && char_at(clone(cmd_str), 3) == 99 && char_at(clone(cmd_str), 4) == 107
    let cmd_is_compile = cmd_len == 7 && char_at(clone(cmd_str), 0) == 99 && char_at(clone(cmd_str), 1) == 111 && char_at(clone(cmd_str), 2) == 109 && char_at(clone(cmd_str), 3) == 112 && char_at(clone(cmd_str), 4) == 105 && char_at(clone(cmd_str), 5) == 108 && char_at(clone(cmd_str), 6) == 101
    if cmd_len == 6 && char_at(clone(cmd_str), 0) == 45 && char_at(clone(cmd_str), 1) == 45 && char_at(clone(cmd_str), 2) == 104 && char_at(clone(cmd_str), 3) == 101 && char_at(clone(cmd_str), 4) == 108 && char_at(clone(cmd_str), 5) == 112 {
        opts.show_help = true
        return opts
    }
    if cmd_len == 2 && char_at(clone(cmd_str), 0) == 45 && char_at(clone(cmd_str), 1) == 104 {
        opts.show_help = true
        return opts
    }
    if cmd_len == 9 && char_at(clone(cmd_str), 0) == 45 && char_at(clone(cmd_str), 1) == 45 && char_at(clone(cmd_str), 2) == 118 && char_at(clone(cmd_str), 3) == 101 && char_at(clone(cmd_str), 4) == 114 && char_at(clone(cmd_str), 5) == 115 && char_at(clone(cmd_str), 6) == 105 && char_at(clone(cmd_str), 7) == 111 && char_at(clone(cmd_str), 8) == 110 {
        opts.show_version = true
