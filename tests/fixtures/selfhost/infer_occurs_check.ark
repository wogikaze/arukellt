// Test: selfhost typechecker occurs check in bind_var prevents self-referential types.
// Exercises: normal type inference works correctly with occurs check installed.
use std::host::stdio

fn double(n: i32) -> i32 {
    n * 2
}

fn main() {
    let x = 21
    let y = double(x)
    stdio::println(to_string(y))
    stdio::println(String_from("occurs check OK"))
}
// Simple type inference with occurs check — should compile and run fine
