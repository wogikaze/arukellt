use std::host::stdio
use std::host::process

struct PhiArg {
    pred_block: i32,
    local: i32,
}

struct Phi {
    dest: i32,
    val_type: i32,
    args: Vec<PhiArg>,
}

struct Block {
    id: i32,
    preds: Vec<i32>,
    dom_frontier: Vec<i32>,
    last_value: i32,
}

fn Phi_new(dest: i32, val_type: i32) -> Phi {
    Phi { dest: dest, val_type: val_type, args: Vec_new_PhiArg() }
}

fn phi_add_arg(phi: Phi, pred_block: i32, local: i32) {
    push(phi.args, PhiArg { pred_block: pred_block, local: local })
}

fn block_ids_contains(ids: Vec<i32>, block_id: i32) -> bool {
    let count = len(ids)
    let mut i = 0
    while i < count {
        if get_unchecked(ids, i) == block_id {
            return true
        }
        i = i + 1
    }
    false
}

fn try_insert_simple_join_phi(join_block: Block, pred0: Block, pred1: Block, dest_local: i32, dest_vt: i32) -> Phi {
    if len(join_block.preds) != 2 {
        stdio::eprintln(String_from("join predecessor count mismatch"))
        process::exit(1)
    }
    if !block_ids_contains(pred0.dom_frontier, join_block.id) {
        stdio::eprintln(String_from("pred0 frontier missing join"))
        process::exit(1)
    }
    if !block_ids_contains(pred1.dom_frontier, join_block.id) {
        stdio::eprintln(String_from("pred1 frontier missing join"))
        process::exit(1)
    }

    let phi = Phi_new(dest_local, dest_vt)
    phi_add_arg(phi, pred0.id, pred0.last_value)
    phi_add_arg(phi, pred1.id, pred1.last_value)
    phi
}

fn format_phi(phi: Phi) -> String {
    let arg0 = get_unchecked(phi.args, 0)
    let arg1 = get_unchecked(phi.args, 1)
    let mut out = String_from("phi %")
    out = concat(out, to_string(phi.dest))
    out = concat(out, String_from(" = [bb"))
    out = concat(out, to_string(arg0.pred_block))
    out = concat(out, String_from(" -> %"))
    out = concat(out, to_string(arg0.local))
    out = concat(out, String_from(", bb"))
    out = concat(out, to_string(arg1.pred_block))
    out = concat(out, String_from(" -> %"))
    out = concat(out, to_string(arg1.local))
    out = concat(out, String_from("] : i32"))
    out
}

fn main() {
    let then_block = Block {
        id: 1,
        preds: Vec_new_i32(),
        dom_frontier: Vec_new_i32(),
        last_value: 1,
    }
    let else_block = Block {
        id: 2,
        preds: Vec_new_i32(),
        dom_frontier: Vec_new_i32(),
        last_value: 2,
    }
    let join_block = Block {
        id: 3,
        preds: Vec_new_i32(),
        dom_frontier: Vec_new_i32(),
        last_value: 0 - 1,
    }

    push(join_block.preds, then_block.id)
    push(join_block.preds, else_block.id)
    push(then_block.dom_frontier, join_block.id)
    push(else_block.dom_frontier, join_block.id)

    let phi = try_insert_simple_join_phi(join_block, then_block, else_block, 3, 1)
    stdio::println(String_from("diamond join bb3"))
    stdio::println(format_phi(phi))
    stdio::println(String_from("MIR phi insertion smoke OK."))
}