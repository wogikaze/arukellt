// Two clauses: enum variant with guard
use std::host::stdio

enum Level { Low, Medium, High }

fn describe(Level::Low) -> String | true = "low"
fn describe(Level::Medium) -> String | true = "medium"
fn describe(_) -> String = "high"

fn main() {
    stdio::println(describe(Level::Low))
    stdio::println(describe(Level::Medium))
    stdio::println(describe(Level::High))
}
