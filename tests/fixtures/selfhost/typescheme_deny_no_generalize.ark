// Test: non-syntactic-value let bindings are NOT generalized
// A block expression initializer prevents generalization. The binding
// has a concrete type annotation, so mismatched use produces a type error.
use std::host::stdio

fn main() {
    // Block expression is NOT a syntactic value -> x is NOT generalized
    let x: i32 = {
        let step = true
        if step { 1 } else { 2 }
    }
    // x has concrete type i32
    // Using x with bool in an operation should produce type mismatch
    stdio::println(to_string(x))
    let z = x + true
    stdio::println(to_string(z))
}
// x is bound via block (non-syntactic-value) -> NOT generalized -> type is i32
// x + true -> unify(i32, bool) -> type mismatch: i32 vs bool
