use std::host::stdio
use std::host::fs
use std::host::process

fn CMD_CHECK() -> i32 { 1 }
fn CMD_COMPILE() -> i32 { 2 }
fn CMD_PARSE() -> i32 { 3 }
fn CMD_HELP() -> i32 { 4 }
fn CMD_VERSION() -> i32 { 5 }
fn CMD_NOT_YET() -> i32 { 0 }
fn CMD_IDE_ANALYZE() -> i32 { 11 }
fn CMD_LSP() -> i32 { 12 }

struct CliOptions {
    command: i32,
    input_file: String,
    output_file: String,
    target: String,
    wit_paths: Vec<String>,
    opt_level: i32,
    dump_phases: String,
    emit_mode: String,
    json_output: bool,
    show_help: bool,
    show_version: bool,
    has_error: bool,
    error_msg: String,
}

fn CliOptions_default() -> CliOptions {
    CliOptions { command: CMD_UNKNOWN(), input_file: String_new(), output_file: String_new(), target: String_from("wasm32-wasi-p2"), wit_paths: Vec_new_String(), opt_level: 0, dump_phases: String_new(), emit_mode: String_from("wasm"), json_output: false, show_help: false, show_version: false, has_error: false, error_msg: String_new() }
}

fn CMD_UNKNOWN() -> i32 { 0 }

fn main() {
    stdio::println(String_from("hello"))
}
