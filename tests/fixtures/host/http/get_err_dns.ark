// Fixture: http::get with a non-resolvable domain should return a dns error.
// CI-safe: no real network needed — the .invalid TLD is guaranteed never to resolve.
use std::host::http
use std::host::stdio

fn main() {
    match http::get("http://this.domain.does.not.exist.invalid/") {
        Result::Ok(_body) => stdio::println("unexpected ok"),
        Result::Err(e) => stdio::println(e),
    }
}
