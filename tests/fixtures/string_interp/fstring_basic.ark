use std::host::stdio
fn main() {
    let name: String = String_from("world")
    stdio::println(f"Hello, {name}!")

    let x: i32 = 42
    stdio::println(f"The answer is {x}.")

    let flag: bool = true
    stdio::println(f"flag is {flag}")

    let pi: f64 = 3.14
    stdio::println(f"pi = {pi}")
}
