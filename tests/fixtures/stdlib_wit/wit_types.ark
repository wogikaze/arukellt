use std::host::stdio
use std::wit

fn main() {
    stdio::println((wit::wit_type_id(wit::wit_type_bool())).to_string())
    stdio::println((wit::wit_type_id(wit::wit_type_u32())).to_string())
    stdio::println((wit::wit_type_id(wit::wit_type_string())).to_string())
    stdio::println(wit::wit_type_name(wit::wit_type_from_id(1)))
    stdio::println(wit::wit_type_name(wit::wit_type_from_id(4)))
    stdio::println(wit::wit_type_name(wit::wit_type_from_id(13)))
    stdio::println(wit::wit_type_name(wit::wit_type_from_id(99)))
    stdio::println((wit::wit_type_id(wit::wit_type_from_id(7))).to_string())
    stdio::println((wit::wit_type_id(wit::wit_type_from_id(99))).to_string())
}
