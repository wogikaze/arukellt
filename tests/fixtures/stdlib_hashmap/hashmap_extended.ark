use std::collections::hash
use std::test

fn main() {
    let m: Vec<i32> = hash::hashmap_with_capacity(4)
    hash::hashmap_set(m, 10, 100)
    hash::hashmap_set(m, 20, 200)
    test::assert_eq_i32(hash::hashmap_size(m), 2)
    let empty: Vec<i32> = hash::hashmap_new()
    test::assert_true(hash::hashmap_is_empty(empty))
    hash::hashmap_set(empty, 5, 50)
    match hash::hashmap_get_option(empty, 5) {
        Option::Some(v) => test::assert_eq_i32(v, 50),
        None => panic("expected Some(50)"),
    }
    match hash::hashmap_get_option(empty, 99) {
        Option::Some(v) => panic("expected None"),
        None => {
        },
    }
    let m2: Vec<i32> = hash::hashmap_new()
    hash::hashmap_set(m2, 1, 10)
    hash::hashmap_set(m2, 2, 20)
    hash::hashmap_set(m2, 3, 30)
    test::assert_eq_i32(hash::hashmap_size(m2), 3)
    test::assert_eq_i32(len(hash::hashmap_keys(m2)), 3)
    test::assert_eq_i32(len(hash::hashmap_values(m2)), 3)
    match hash::hashmap_remove(m2, 2) {
        Option::Some(v) => test::assert_eq_i32(v, 20),
        None => panic("expected Some(20)"),
    }
    test::assert_eq_i32(hash::hashmap_size(m2), 2)
    match hash::hashmap_remove(m2, 99) {
        Option::Some(v) => panic("expected None"),
        None => {
        },
    }
    hash::hashmap_clear(m2)
    test::assert_true(hash::hashmap_is_empty(m2))
}
