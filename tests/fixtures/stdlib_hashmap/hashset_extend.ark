// HashSet: extend adds all elements from other set
use std::collections::hash
use std::test

fn main() {
    let a = hash::hashset_new()
    hash::hashset_insert(a, 1)
    hash::hashset_insert(a, 2)

    let b = hash::hashset_new()
    hash::hashset_insert(b, 2)
    hash::hashset_insert(b, 3)
    hash::hashset_insert(b, 4)

    hash::hashset_extend(a, b)
    test::assert_eq_i32(hash::hashset_len(a), 4)
    test::assert_true(hash::hashset_contains(a, 1))
    test::assert_true(hash::hashset_contains(a, 2))
    test::assert_true(hash::hashset_contains(a, 3))
    test::assert_true(hash::hashset_contains(a, 4))
}
