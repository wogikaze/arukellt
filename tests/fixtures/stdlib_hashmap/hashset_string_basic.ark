use std::collections::hash
use std::host::stdio

fn main() {
    let s = hash::hashset_str_new()
    stdio::println(bool_to_string(hash::hashset_str_insert(s, "apple")))
    stdio::println(bool_to_string(hash::hashset_str_insert(s, "banana")))
    stdio::println(bool_to_string(hash::hashset_str_insert(s, "cherry")))
    stdio::println(bool_to_string(hash::hashset_str_insert(s, "apple")))
    stdio::println(i32_to_string(hash::hashset_str_len(s)))
    stdio::println(bool_to_string(hash::hashset_str_contains(s, "banana")))
    stdio::println(bool_to_string(hash::hashset_str_contains(s, "mango")))
    stdio::println(bool_to_string(hash::hashset_str_remove(s, "banana")))
    stdio::println(bool_to_string(hash::hashset_str_remove(s, "mango")))
    stdio::println(i32_to_string(hash::hashset_str_len(s)))
}
// insert new elements
// duplicate insert returns false
// len
// contains
// remove
// len after remove
