use std::collections::hash
use std::test

fn main() {
    let s = hash::hashset_str_new()
    test::assert_true(hash::hashset_str_insert(s, "apple"))
    test::assert_true(hash::hashset_str_insert(s, "banana"))
    test::assert_true(hash::hashset_str_insert(s, "cherry"))
    test::assert_false(hash::hashset_str_insert(s, "apple"))
    test::assert_eq_i32(hash::hashset_str_len(s), 3)
    test::assert_true(hash::hashset_str_contains(s, "banana"))
    test::assert_false(hash::hashset_str_contains(s, "mango"))
    test::assert_true(hash::hashset_str_remove(s, "banana"))
    test::assert_false(hash::hashset_str_remove(s, "mango"))
    test::assert_eq_i32(hash::hashset_str_len(s), 2)
}
