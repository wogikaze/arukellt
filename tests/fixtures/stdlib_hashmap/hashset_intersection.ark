// HashSet: intersection contains only common elements
use std::collections::hash
use std::test

fn main() {
    let a = hash::hashset_new()
    hash::hashset_insert(a, 1)
    hash::hashset_insert(a, 2)
    hash::hashset_insert(a, 3)
    hash::hashset_insert(a, 4)

    let b = hash::hashset_new()
    hash::hashset_insert(b, 3)
    hash::hashset_insert(b, 4)
    hash::hashset_insert(b, 5)

    let inter = hash::hashset_intersection(a, b)
    test::assert_eq_i32(hash::hashset_len(inter), 2)
    test::assert_true(hash::hashset_contains(inter, 3))
    test::assert_true(hash::hashset_contains(inter, 4))
    test::assert_false(hash::hashset_contains(inter, 1))
    test::assert_false(hash::hashset_contains(inter, 5))
}
