// Typed map: String->String basic operations
use std::collections::hash_map
use std::test

fn main() {
    let m = hash_map::hashmap_str_str_new()
    hash_map::hashmap_str_str_insert(m, "en", "hello")
    hash_map::hashmap_str_str_insert(m, "fr", "bonjour")

    test::assert_eq_i32(hash_map::hashmap_str_str_len(m), 2)
    test::assert_true(hash_map::hashmap_str_str_contains(m, "en"))
    test::assert_false(hash_map::hashmap_str_str_contains(m, "de"))

    match hash_map::hashmap_str_str_get(m, "en") {
        Option::Some(v) => test::assert_eq_str(v, "hello"),
        None => panic("expected Some(hello)"),
    }
    match hash_map::hashmap_str_str_get(m, "fr") {
        Option::Some(v) => test::assert_eq_str(v, "bonjour"),
        None => panic("expected Some(bonjour)"),
    }
}
