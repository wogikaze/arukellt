// HashSet: contains after insert, absent after remove
use std::collections::hash
use std::test

fn main() {
    let s = hash::hashset_new()
    hash::hashset_insert(s, 10)
    hash::hashset_insert(s, 20)

    test::assert_true(hash::hashset_contains(s, 10))
    test::assert_true(hash::hashset_contains(s, 20))
    test::assert_false(hash::hashset_contains(s, 30))

    test::assert_true(hash::hashset_remove(s, 10))
    test::assert_false(hash::hashset_contains(s, 10))
    test::assert_true(hash::hashset_contains(s, 20))
    test::assert_eq_i32(hash::hashset_len(s), 1)
}
