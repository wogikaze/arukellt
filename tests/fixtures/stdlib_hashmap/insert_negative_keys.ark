// Insert: negative keys are handled correctly
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    hash::hashmap_set(m, 0 - 1, 100)
    hash::hashmap_set(m, 0 - 100, 200)
    hash::hashmap_set(m, 0 - 2147483648, 300)
    test::assert_eq_i32(hash::hashmap_size(m), 3)
    test::assert_eq_i32(hash::hashmap_get(m, 0 - 1), 100)
    test::assert_eq_i32(hash::hashmap_get(m, 0 - 100), 200)
    test::assert_eq_i32(hash::hashmap_get(m, 0 - 2147483648), 300)
    test::assert_true(hash::hashmap_contains(m, 0 - 1))
    test::assert_true(hash::hashmap_contains(m, 0 - 100))
    test::assert_true(hash::hashmap_contains(m, 0 - 2147483648))
}
