// HashSet: union contains all elements from both sets
use std::collections::hash
use std::test

fn main() {
    let a = hash::hashset_new()
    hash::hashset_insert(a, 1)
    hash::hashset_insert(a, 2)
    hash::hashset_insert(a, 3)

    let b = hash::hashset_new()
    hash::hashset_insert(b, 3)
    hash::hashset_insert(b, 4)
    hash::hashset_insert(b, 5)

    let u = hash::hashset_union(a, b)
    test::assert_eq_i32(hash::hashset_len(u), 5)
    test::assert_true(hash::hashset_contains(u, 1))
    test::assert_true(hash::hashset_contains(u, 2))
    test::assert_true(hash::hashset_contains(u, 3))
    test::assert_true(hash::hashset_contains(u, 4))
    test::assert_true(hash::hashset_contains(u, 5))
}
