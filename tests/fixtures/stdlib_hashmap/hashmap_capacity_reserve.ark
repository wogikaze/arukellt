use std::collections::hash
use std::test

fn assert_get(m: Vec<i32>, key: i32, expected: i32) {
    match hash::hashmap_get_option(m, key) {
        Option::Some(v) => test::assert_eq_i32(v, expected),
        None => panic("expected Some"),
    }
}

fn main() {
    let m = hash::hashmap_with_capacity(1)
    test::assert_eq_i32(hash::hashmap_capacity(m), 1)
    hash::hashmap_reserve(m, 3)
    test::assert_true(hash::hashmap_capacity(m) >= 4)
    test::assert_true(hash::hashmap_try_reserve(m, 2))

    test::assert_true(hash::hashmap_set(m, 1, 10))
    test::assert_true(hash::hashmap_set(m, 2, 20))
    test::assert_true(hash::hashmap_set(m, 3, 30))
    assert_get(m, 1, 10)
    assert_get(m, 2, 20)
    assert_get(m, 3, 30)

    hash::hashmap_shrink_to_fit(m)
    test::assert_true(hash::hashmap_capacity(m) >= 4)
    test::assert_eq_i32(hash::hashmap_size(m), 3)
    assert_get(m, 2, 20)
}
