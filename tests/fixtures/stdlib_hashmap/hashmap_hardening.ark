use std::collections::hash
use std::test

fn main() {
    let m: Vec<i32> = hash::hashmap_with_capacity(2)
    test::assert_true(hash::hashmap_set(m, 1, 0))
    test::assert_true(hash::hashmap_set(m, 3, 30))

    match hash::hashmap_get_option(m, 1) {
        Option::Some(v) => test::assert_eq_i32(v, 0),
        None => panic("expected Some(0)"),
    }

    match hash::hashmap_get_option(m, 2) {
        Option::Some(v) => panic("expected None for key 2"),
        None => {
        },
    }

    test::assert_true(hash::hashmap_set(m, 5, 50))
    test::assert_eq_i32(hash::hashmap_size(m), 3)
    test::assert_true(hash::hashmap_contains(m, 5))
}
