// Shrink_to_fit: reduces capacity, preserves data
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_with_capacity(100)
    hash::hashmap_set(m, 1, 10)
    hash::hashmap_set(m, 2, 20)

    let cap_before = hash::hashmap_capacity(m)
    hash::hashmap_shrink_to_fit(m)
    let cap_after = hash::hashmap_capacity(m)
    test::assert_true(cap_after <= cap_before)

    // Data preserved
    test::assert_eq_i32(hash::hashmap_size(m), 2)
    test::assert_eq_i32(hash::hashmap_get(m, 1), 10)
    test::assert_eq_i32(hash::hashmap_get(m, 2), 20)

    // Can still insert after shrink
    hash::hashmap_set(m, 3, 30)
    test::assert_eq_i32(hash::hashmap_get(m, 3), 30)
}
