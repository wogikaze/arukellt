use std::collections::hash
use std::collections::hash_map
use std::host::stdio

fn print_set_state(len_value: i32, has_value: bool) {
    stdio::println(i32_to_string(len_value))
    stdio::println(bool_to_string(has_value))
}

fn main() {
    let direct = hash::hashset_str_new()
    stdio::println(bool_to_string(hash::hashset_str_insert(direct, "red")))
    stdio::println(bool_to_string(hash::hashset_str_insert(direct, "red")))
    print_set_state(hash::hashset_str_len(direct), hash::hashset_str_contains(direct, "red"))

    let compat = hash_map::hashset_str_new()
    stdio::println(bool_to_string(hash_map::hashset_str_insert(compat, "green")))
    stdio::println(bool_to_string(hash_map::hashset_str_remove(compat, "green")))
    print_set_state(hash_map::hashset_str_len(compat), hash_map::hashset_str_contains(compat, "green"))

    let second = hash_map::hashset_str_new()
    stdio::println(bool_to_string(hash_map::hashset_str_insert(second, "blue")))
    stdio::println(bool_to_string(hash_map::hashset_str_remove(second, "missing")))
    print_set_state(hash_map::hashset_str_len(second), hash_map::hashset_str_contains(second, "blue"))
}
