use std::collections::hash
use std::collections::hash_map
use std::test

fn main() {
    let direct = hash::hashset_str_new()
    test::assert_true(hash::hashset_str_insert(direct, "red"))
    test::assert_false(hash::hashset_str_insert(direct, "red"))
    test::assert_eq_i32(hash::hashset_str_len(direct), 1)
    test::assert_true(hash::hashset_str_contains(direct, "red"))

    let compat = hash_map::hashset_str_new()
    test::assert_true(hash_map::hashset_str_insert(compat, "green"))
    test::assert_true(hash_map::hashset_str_remove(compat, "green"))
    test::assert_eq_i32(hash_map::hashset_str_len(compat), 0)
    test::assert_false(hash_map::hashset_str_contains(compat, "green"))

    let second = hash_map::hashset_str_new()
    test::assert_true(hash_map::hashset_str_insert(second, "blue"))
    test::assert_false(hash_map::hashset_str_remove(second, "missing"))
    test::assert_eq_i32(hash_map::hashset_str_len(second), 1)
    test::assert_true(hash_map::hashset_str_contains(second, "blue"))
}
