// Stress: mixed insert/remove/lookup cycle
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()

    // Phase 1: insert 0-19
    let mut i = 0
    while i < 20 {
        hash::hashmap_set(m, i, i)
        i = i + 1
    }
    test::assert_eq_i32(hash::hashmap_size(m), 20)

    // Phase 2: remove 0-9
    i = 0
    while i < 10 {
        hash::hashmap_remove(m, i)
        i = i + 1
    }
    test::assert_eq_i32(hash::hashmap_size(m), 10)

    // Phase 3: insert 20-29
    i = 20
    while i < 30 {
        hash::hashmap_set(m, i, i)
        i = i + 1
    }
    test::assert_eq_i32(hash::hashmap_size(m), 20)

    // Verify: 0-9 absent, 10-19 present, 20-29 present
    i = 0
    while i < 10 {
        test::assert_false(hash::hashmap_contains(m, i))
        i = i + 1
    }
    i = 10
    while i < 30 {
        test::assert_true(hash::hashmap_contains(m, i))
        test::assert_eq_i32(hash::hashmap_get(m, i), i)
        i = i + 1
    }
}
