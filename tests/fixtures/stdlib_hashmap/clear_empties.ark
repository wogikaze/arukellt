// Clear: empties the map, capacity preserved or reset
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    hash::hashmap_set(m, 1, 10)
    hash::hashmap_set(m, 2, 20)
    hash::hashmap_set(m, 3, 30)
    test::assert_eq_i32(hash::hashmap_size(m), 3)

    hash::hashmap_clear(m)
    test::assert_eq_i32(hash::hashmap_size(m), 0)
    test::assert_true(hash::hashmap_is_empty(m))
    test::assert_false(hash::hashmap_contains(m, 1))
    test::assert_false(hash::hashmap_contains(m, 2))
    test::assert_false(hash::hashmap_contains(m, 3))
    test::assert_eq_i32(len(hash::hashmap_keys(m)), 0)
    test::assert_eq_i32(len(hash::hashmap_values(m)), 0)
}
