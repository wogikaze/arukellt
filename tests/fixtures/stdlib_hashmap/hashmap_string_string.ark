use std::test

fn main() {
    let m = HashMap_new_String_String()
    HashMap_String_String_insert(m, "greeting", "hello")
    HashMap_String_String_insert(m, "farewell", "goodbye")
    HashMap_String_String_insert(m, "color", "red")
    HashMap_String_String_insert(m, "color", "blue")
    test::assert_eq_i32(HashMap_String_String_len(m), 3)
    match HashMap_String_String_get(m, "greeting") {
        Option::Some(v) => test::assert_eq_string(v, "hello"),
        None => panic("expected Some(hello)"),
    }
    match HashMap_String_String_get(m, "color") {
        Option::Some(v) => test::assert_eq_string(v, "blue"),
        None => panic("expected Some(blue)"),
    }
    match HashMap_String_String_get(m, "missing") {
        Option::Some(v) => panic("expected None"),
        None => {
        },
    }
    test::assert_true(HashMap_String_String_contains_key(m, "farewell"))
    test::assert_false(HashMap_String_String_contains_key(m, "unknown"))
}
