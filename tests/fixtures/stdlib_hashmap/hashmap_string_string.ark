use std::host::stdio

fn main() {
    let m = HashMap_new_String_String()
    HashMap_String_String_insert(m, "greeting", "hello")
    HashMap_String_String_insert(m, "farewell", "goodbye")
    HashMap_String_String_insert(m, "color", "red")
    HashMap_String_String_insert(m, "color", "blue")
    stdio::println(i32_to_string(HashMap_String_String_len(m)))
    match HashMap_String_String_get(m, "greeting") {
        Option::Some(v) => stdio::println(v),
        None => stdio::println("not found"),
    }
    match HashMap_String_String_get(m, "color") {
        Option::Some(v) => stdio::println(v),
        None => stdio::println("not found"),
    }
    match HashMap_String_String_get(m, "missing") {
        Option::Some(v) => stdio::println(v),
        None => stdio::println("not found"),
    }
    stdio::println(bool_to_string(HashMap_String_String_contains_key(m, "farewell")))
    stdio::println(bool_to_string(HashMap_String_String_contains_key(m, "unknown")))
}
