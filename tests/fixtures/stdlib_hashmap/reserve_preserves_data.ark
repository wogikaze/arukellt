// Reserve: existing data is preserved after capacity growth
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_with_capacity(2)
    hash::hashmap_set(m, 1, 10)
    hash::hashmap_set(m, 2, 20)

    hash::hashmap_reserve(m, 100)

    test::assert_eq_i32(hash::hashmap_size(m), 2)
    test::assert_eq_i32(hash::hashmap_get(m, 1), 10)
    test::assert_eq_i32(hash::hashmap_get(m, 2), 20)
    test::assert_true(hash::hashmap_contains(m, 1))
    test::assert_true(hash::hashmap_contains(m, 2))

    // Can still insert after reserve
    hash::hashmap_set(m, 3, 30)
    test::assert_eq_i32(hash::hashmap_get(m, 3), 30)
    test::assert_eq_i32(hash::hashmap_size(m), 3)
}
