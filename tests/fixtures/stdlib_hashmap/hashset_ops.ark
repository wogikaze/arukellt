use std::collections::hash
use std::test

fn main() {
    let a: Vec<i32> = hash::hashset_new()
    let _ = hash::hashset_insert(a, 1)
    let _ = hash::hashset_insert(a, 2)
    let _ = hash::hashset_insert(a, 3)
    let b: Vec<i32> = hash::hashset_new()
    let _ = hash::hashset_insert(b, 2)
    let _ = hash::hashset_insert(b, 3)
    let _ = hash::hashset_insert(b, 4)
    let u: Vec<i32> = hash::hashset_union(a, b)
    test::assert_eq_i32(hash::hashset_len(u), 4)
    test::assert_true(hash::hashset_contains(u, 1))
    test::assert_true(hash::hashset_contains(u, 4))
    test::assert_false(hash::hashset_contains(u, 99))
    let i: Vec<i32> = hash::hashset_intersection(a, b)
    test::assert_eq_i32(hash::hashset_len(i), 2)
    test::assert_true(hash::hashset_contains(i, 2))
    test::assert_false(hash::hashset_contains(i, 1))
    let d: Vec<i32> = hash::hashset_difference(a, b)
    test::assert_eq_i32(hash::hashset_len(d), 1)
    test::assert_true(hash::hashset_contains(d, 1))
    test::assert_false(hash::hashset_contains(d, 2))
}
