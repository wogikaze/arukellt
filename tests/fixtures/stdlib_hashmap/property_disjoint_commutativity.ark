// Property fixture for issue #528 — disjoint-key insert commutativity.
//
// Invariant: inserting a set of disjoint keys into a fresh HashMap yields
// the same logical map regardless of insertion order.
use std::collections::hash
use std::test

fn assert_probe(m: Vec<i32>, key: i32, expected: i32) {
    match hash::hashmap_get_option(m, key) {
        Option::Some(v) => test::assert_eq_i32(v, expected),
        None => panic("expected Some"),
    }
}

fn main() {
    // Map A: ascending insertion order.
    let a: Vec<i32> = hash::hashmap_new()
    hash::hashmap_set(a, 10, 100)
    hash::hashmap_set(a, 20, 200)
    hash::hashmap_set(a, 30, 300)
    hash::hashmap_set(a, 40, 400)

    // Map B: descending (reversed) insertion order over the SAME disjoint keys.
    let b: Vec<i32> = hash::hashmap_new()
    hash::hashmap_set(b, 40, 400)
    hash::hashmap_set(b, 30, 300)
    hash::hashmap_set(b, 20, 200)
    hash::hashmap_set(b, 10, 100)

    // A and B must agree on size and on every probe.
    test::assert_eq_i32(hash::hashmap_size(a), hash::hashmap_size(b))
    assert_probe(a, 10, 100)
    assert_probe(b, 10, 100)
    assert_probe(a, 20, 200)
    assert_probe(b, 20, 200)
    assert_probe(a, 30, 300)
    assert_probe(b, 30, 300)
    assert_probe(a, 40, 400)
    assert_probe(b, 40, 400)
}
