// HashSet: clear empties the set
use std::collections::hash
use std::test

fn main() {
    let s = hash::hashset_new()
    hash::hashset_insert(s, 1)
    hash::hashset_insert(s, 2)
    hash::hashset_insert(s, 3)
    test::assert_eq_i32(hash::hashset_len(s), 3)

    hash::hashset_clear(s)
    test::assert_eq_i32(hash::hashset_len(s), 0)
    test::assert_true(hash::hashset_is_empty(s))
    test::assert_false(hash::hashset_contains(s, 1))
    test::assert_false(hash::hashset_contains(s, 2))
    test::assert_false(hash::hashset_contains(s, 3))

    // Reusable after clear
    hash::hashset_insert(s, 4)
    test::assert_eq_i32(hash::hashset_len(s), 1)
    test::assert_true(hash::hashset_contains(s, 4))
}
