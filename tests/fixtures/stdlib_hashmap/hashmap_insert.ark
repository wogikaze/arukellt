use std::collections::hash
use std::host::stdio

fn expect_some(v: Option<i32>, expected: i32) {
    match v {
        Option::Some(x) => assert_eq(x, expected),
        None => assert(false),
    }
}

fn expect_none(v: Option<i32>) {
    match v {
        Option::Some(_) => assert(false),
        None => {}
    }
}

fn main() {
    let m = hash::hashmap_new()
    assert(hash::hashmap_is_empty(m))
    assert_eq(hash::hashmap_size(m), 0)

    // Insert new keys returns None (no previous value).
    expect_none(hash::hashmap_insert(m, 1, 100))
    expect_none(hash::hashmap_insert(m, 2, 200))
    expect_none(hash::hashmap_insert(m, 3, 300))
    assert(!hash::hashmap_is_empty(m))
    assert_eq(hash::hashmap_size(m), 3)

    // contains / get
    assert(hash::hashmap_contains(m, 1))
    assert(hash::hashmap_contains(m, 2))
    assert(hash::hashmap_contains(m, 3))
    assert(!hash::hashmap_contains(m, 999))
    expect_some(hash::hashmap_get_option(m, 1), 100)
    expect_some(hash::hashmap_get_option(m, 2), 200)
    expect_some(hash::hashmap_get_option(m, 3), 300)
    expect_none(hash::hashmap_get_option(m, 999))

    // Update existing key returns previous value.
    expect_some(hash::hashmap_insert(m, 1, 111))
    expect_some(hash::hashmap_get_option(m, 1), 111)
    assert_eq(hash::hashmap_size(m), 3)

    // Zero-value lookup must distinguish missing from stored zero.
    expect_none(hash::hashmap_insert(m, 5, 0))
    assert(hash::hashmap_contains(m, 5))
    expect_some(hash::hashmap_get_option(m, 5), 0)

    // keys / values snapshots
    assert_eq(len(hash::hashmap_keys(m)), 4)
    assert_eq(len(hash::hashmap_values(m)), 4)

    stdio::println("OK")
}
