// Remove: all keys one by one, map becomes empty
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    let mut i = 0
    while i < 10 {
        hash::hashmap_set(m, i, i * 100)
        i = i + 1
    }
    test::assert_eq_i32(hash::hashmap_size(m), 10)

    i = 0
    while i < 10 {
        match hash::hashmap_remove(m, i) {
            Option::Some(v) => test::assert_eq_i32(v, i * 100),
            None => panic("expected Some on remove"),
        }
        i = i + 1
    }
    test::assert_eq_i32(hash::hashmap_size(m), 0)
    test::assert_true(hash::hashmap_is_empty(m))

    i = 0
    while i < 10 {
        test::assert_false(hash::hashmap_contains(m, i))
        i = i + 1
    }
}
