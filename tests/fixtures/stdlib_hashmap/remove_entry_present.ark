// Remove_entry: returns [key, value] for present key
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    hash::hashmap_set(m, 7, 77)
    hash::hashmap_set(m, 8, 88)

    let entry = hash::hashmap_remove_entry(m, 7)
    test::assert_eq_i32(len(entry), 2)
    test::assert_eq_i32(get_unchecked(entry, 0), 7)
    test::assert_eq_i32(get_unchecked(entry, 1), 77)
    test::assert_eq_i32(hash::hashmap_size(m), 1)
    test::assert_false(hash::hashmap_contains(m, 7))
    test::assert_true(hash::hashmap_contains(m, 8))
}
