// HashSet: remove absent returns false
use std::collections::hash
use std::test

fn main() {
    let s = hash::hashset_new()
    hash::hashset_insert(s, 1)

    test::assert_false(hash::hashset_remove(s, 999))
    test::assert_eq_i32(hash::hashset_len(s), 1)
    test::assert_true(hash::hashset_contains(s, 1))

    // Remove from empty set
    let s2 = hash::hashset_new()
    test::assert_false(hash::hashset_remove(s2, 1))
}
