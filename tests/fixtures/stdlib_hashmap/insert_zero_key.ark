// Insert: key=0 is a valid key, not a sentinel
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    hash::hashmap_set(m, 0, 42)
    test::assert_true(hash::hashmap_contains(m, 0))
    test::assert_eq_i32(hash::hashmap_get(m, 0), 42)
    test::assert_eq_i32(hash::hashmap_size(m), 1)

    // Overwrite key=0
    hash::hashmap_set(m, 0, 99)
    test::assert_eq_i32(hash::hashmap_get(m, 0), 99)
    test::assert_eq_i32(hash::hashmap_size(m), 1)

    // Remove key=0
    match hash::hashmap_remove(m, 0) {
        Option::Some(v) => test::assert_eq_i32(v, 99),
        None => panic("expected Some(99) on remove"),
    }
    test::assert_false(hash::hashmap_contains(m, 0))
    test::assert_eq_i32(hash::hashmap_size(m), 0)
}
