// HashSet: insert returns true for new, false for duplicate
use std::collections::hash
use std::test

fn main() {
    let s = hash::hashset_new()
    test::assert_true(hash::hashset_insert(s, 1))
    test::assert_true(hash::hashset_insert(s, 2))
    test::assert_true(hash::hashset_insert(s, 3))
    test::assert_false(hash::hashset_insert(s, 1))  // duplicate
    test::assert_false(hash::hashset_insert(s, 2))  // duplicate
    test::assert_eq_i32(hash::hashset_len(s), 3)
}
