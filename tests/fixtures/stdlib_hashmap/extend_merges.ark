// Extend: merges other map into self, overwriting duplicates
use std::collections::hash
use std::test

fn main() {
    let m1 = hash::hashmap_new()
    hash::hashmap_set(m1, 1, 10)
    hash::hashmap_set(m1, 2, 20)

    let m2 = hash::hashmap_new()
    hash::hashmap_set(m2, 2, 200)  // overwrite
    hash::hashmap_set(m2, 3, 300)  // new

    hash::hashmap_extend(m1, m2)

    test::assert_eq_i32(hash::hashmap_size(m1), 3)
    test::assert_eq_i32(hash::hashmap_get(m1, 1), 10)   // original
    test::assert_eq_i32(hash::hashmap_get(m1, 2), 200)  // overwritten
    test::assert_eq_i32(hash::hashmap_get(m1, 3), 300)  // new from m2
}
