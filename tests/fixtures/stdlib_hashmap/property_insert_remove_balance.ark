// Property fixture for issue #528 — insert/remove balance.
//
// Invariant: after inserting N disjoint keys and then removing the same N
// keys, the map is empty (size 0, is_empty true) and every removed key is
// reported absent. Each `hashmap_remove` must also return the value that
// was inserted for that key.
use std::collections::hash
use std::test

fn main() {
    let m: Vec<i32> = hash::hashmap_new()

    // Insert N = 16 disjoint keys with value = key * 10.
    for i in 1..17 {
        hash::hashmap_set(m, i, i * 10)
    }
    test::assert_eq_i32(hash::hashmap_size(m), 16)

    // Remove the same 16 keys. Each remove must return the inserted value.
    for i in 1..17 {
        match hash::hashmap_remove(m, i) {
            Option::Some(v) => test::assert_eq_i32(v, i * 10),
            None => panic("expected Some on remove"),
        }
    }

    // Post-condition: map is empty, and every removed key is now absent.
    test::assert_eq_i32(hash::hashmap_size(m), 0)
    test::assert_true(hash::hashmap_is_empty(m))
    for i in 1..17 {
        test::assert_false(hash::hashmap_contains(m, i))
    }
}
