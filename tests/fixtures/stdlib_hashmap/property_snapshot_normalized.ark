// Property fixture for issue #528 — deterministic snapshot comparison.
//
// Invariant: a snapshot of a HashMap is independent of the hash map's
// iteration order when the snapshot is produced under an explicit
// normalization rule.
use std::collections::hash
use std::test

// Inline ascending insertion sort on a `Vec<i32>`.
fn sort_asc(v: Vec<i32>) {
    let n: i32 = len(v)
    for i in 1..n {
        let key: i32 = get_unchecked(v, i)
        let mut k: i32 = i
        let mut placed: bool = false
        while k > 0 {
            let prev: i32 = get_unchecked(v, k - 1)
            if prev > key {
                set(v, k, prev)
                k = k - 1
            } else {
                set(v, k, key)
                k = 0
                placed = true
            }
        }
        if !placed {
            set(v, 0, key)
        }
    }
}

fn assert_snapshot(m: Vec<i32>) {
    let keys: Vec<i32> = hash::hashmap_keys(m)
    sort_asc(keys)
    let n: i32 = len(keys)
    test::assert_eq_i32(n, 5)
    // Sorted keys must be 1, 3, 5, 7, 11
    test::assert_eq_i32(get_unchecked(keys, 0), 1)
    test::assert_eq_i32(get_unchecked(keys, 1), 3)
    test::assert_eq_i32(get_unchecked(keys, 2), 5)
    test::assert_eq_i32(get_unchecked(keys, 3), 7)
    test::assert_eq_i32(get_unchecked(keys, 4), 11)
    // Each key must map to key * 10
    for i in 0..n {
        let k: i32 = get_unchecked(keys, i)
        match hash::hashmap_get_option(m, k) {
            Option::Some(v) => test::assert_eq_i32(v, k * 10),
            None => panic("expected Some"),
        }
    }
}

fn main() {
    // Build X in one order.
    let x: Vec<i32> = hash::hashmap_new()
    hash::hashmap_set(x, 7, 70)
    hash::hashmap_set(x, 3, 30)
    hash::hashmap_set(x, 11, 110)
    hash::hashmap_set(x, 5, 50)
    hash::hashmap_set(x, 1, 10)

    // Build Y with the SAME logical entries in a DIFFERENT insertion order.
    let y: Vec<i32> = hash::hashmap_new()
    hash::hashmap_set(y, 1, 10)
    hash::hashmap_set(y, 11, 110)
    hash::hashmap_set(y, 3, 30)
    hash::hashmap_set(y, 5, 50)
    hash::hashmap_set(y, 7, 70)

    assert_snapshot(x)
    assert_snapshot(y)
}
