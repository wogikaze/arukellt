use std::collections::hash
use std::test

fn main() {
    let s: Vec<i32> = hash::hashset_new()
    test::assert_true(hash::hashset_is_empty(s))
    test::assert_true(hash::hashset_insert(s, 1))
    test::assert_true(hash::hashset_insert(s, 2))
    test::assert_true(hash::hashset_insert(s, 3))
    test::assert_false(hash::hashset_insert(s, 2))
    test::assert_eq_i32(hash::hashset_len(s), 3)
    test::assert_true(hash::hashset_contains(s, 1))
    test::assert_false(hash::hashset_contains(s, 99))
    test::assert_true(hash::hashset_remove(s, 2))
    test::assert_eq_i32(hash::hashset_len(s), 2)
    test::assert_false(hash::hashset_remove(s, 99))
    test::assert_eq_i32(len(hash::hashset_to_vec(s)), 2)
    let _ = hash::hashset_remove(s, 1)
    let _ = hash::hashset_remove(s, 3)
    test::assert_true(hash::hashset_is_empty(s))
}
