// Stress: insert 100, remove even keys, verify odd remain
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    let mut i = 0
    while i < 100 {
        hash::hashmap_set(m, i, i)
        i = i + 1
    }

    // Remove even keys
    i = 0
    while i < 100 {
        hash::hashmap_remove(m, i)
        i = i + 2
    }
    test::assert_eq_i32(hash::hashmap_size(m), 50)

    // Verify odd keys remain
    i = 1
    while i < 100 {
        test::assert_true(hash::hashmap_contains(m, i))
        test::assert_eq_i32(hash::hashmap_get(m, i), i)
        i = i + 2
    }

    // Verify even keys are gone
    i = 0
    while i < 100 {
        test::assert_false(hash::hashmap_contains(m, i))
        i = i + 2
    }
}
