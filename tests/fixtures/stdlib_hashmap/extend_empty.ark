// Extend with empty map is a no-op
use std::collections::hash
use std::test

fn main() {
    let m1 = hash::hashmap_new()
    hash::hashmap_set(m1, 1, 10)

    let m2 = hash::hashmap_new()
    hash::hashmap_extend(m1, m2)

    test::assert_eq_i32(hash::hashmap_size(m1), 1)
    test::assert_eq_i32(hash::hashmap_get(m1, 1), 10)
}
