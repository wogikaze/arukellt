use std::test

fn main() {
    let m = HashMap_new_String_i32()
    HashMap_String_i32_insert(m, "apple", 3)
    HashMap_String_i32_insert(m, "banana", 7)
    HashMap_String_i32_insert(m, "cherry", 1)
    HashMap_String_i32_insert(m, "banana", 42)
    test::assert_eq_i32(HashMap_String_i32_len(m), 3)
    match HashMap_String_i32_get(m, "apple") {
        Option::Some(v) => test::assert_eq_i32(v, 3),
        None => panic("expected Some(3)"),
    }
    match HashMap_String_i32_get(m, "banana") {
        Option::Some(v) => test::assert_eq_i32(v, 42),
        None => panic("expected Some(42)"),
    }
    match HashMap_String_i32_get(m, "durian") {
        Option::Some(v) => panic("expected None"),
        None => {
        },
    }
    test::assert_true(HashMap_String_i32_contains_key(m, "cherry"))
    test::assert_false(HashMap_String_i32_contains_key(m, "mango"))
}
