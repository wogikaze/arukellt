// Insert: i32 max/min boundary keys
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    hash::hashmap_set(m, 2147483647, 1)
    hash::hashmap_set(m, 0 - 2147483648, 2)
    test::assert_eq_i32(hash::hashmap_size(m), 2)
    test::assert_eq_i32(hash::hashmap_get(m, 2147483647), 1)
    test::assert_eq_i32(hash::hashmap_get(m, 0 - 2147483648), 2)
    test::assert_true(hash::hashmap_contains(m, 2147483647))
    test::assert_true(hash::hashmap_contains(m, 0 - 2147483648))
}
