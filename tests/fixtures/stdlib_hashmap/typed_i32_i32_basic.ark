// Typed map: i32->i32 basic operations
use std::collections::hash_map
use std::test

fn main() {
    let m = hash_map::hashmap_i32_i32_new()
    test::assert_true(hash_map::hashmap_i32_i32_is_empty(m))

    hash_map::hashmap_i32_i32_insert(m, 1, 100)
    hash_map::hashmap_i32_i32_insert(m, 2, 200)
    test::assert_eq_i32(hash_map::hashmap_i32_i32_len(m), 2)

    match hash_map::hashmap_i32_i32_get(m, 1) {
        Option::Some(v) => test::assert_eq_i32(v, 100),
        None => panic("expected Some(100)"),
    }
    test::assert_true(hash_map::hashmap_i32_i32_contains(m, 1))
    test::assert_false(hash_map::hashmap_i32_i32_contains(m, 99))
}
