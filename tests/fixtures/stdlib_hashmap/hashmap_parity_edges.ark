use std::collections::hash
use std::collections::hash_map
use std::test

fn assert_some(v: Option<i32>, expected: i32) {
    match v {
        Option::Some(x) => test::assert_eq_i32(x, expected),
        None => panic("expected Some"),
    }
}

fn assert_none(v: Option<i32>) {
    match v {
        Option::Some(_) => panic("expected None"),
        None => {
        },
    }
}

fn main() {
    let m: Vec<i32> = hash::hashmap_with_capacity(2)
    test::assert_true(hash::hashmap_set(m, 1, 0))
    test::assert_true(hash::hashmap_set(m, 3, 30))
    assert_some(hash::hashmap_get_option(m, 1), 0)
    assert_some(hash::hashmap_insert(m, 3, 33), 30)
    assert_some(hash::hashmap_get_option(m, 3), 33)

    let removed_one: Option<i32> = hash::hashmap_remove(m, 1)
    assert_some(removed_one, 0)
    assert_some(hash::hashmap_get_option(m, 3), 33)

    test::assert_true(hash::hashmap_set(m, 5, 50))
    test::assert_eq_i32(hash::hashmap_size(m), 2)
    test::assert_true(hash::hashmap_contains(m, 5))

    let entry_pairs: Vec<i32> = hash::hashmap_entries(m)
    test::assert_eq_i32(len(entry_pairs), 4)
    let removed_entry: Vec<i32> = hash::hashmap_remove_entry(m, 3)
    test::assert_eq_i32(len(removed_entry), 2)
    test::assert_eq_i32(get_unchecked(removed_entry, 0), 3)
    test::assert_eq_i32(get_unchecked(removed_entry, 1), 33)
    assert_none(hash::hashmap_get_option(m, 3))

    let drained: Vec<i32> = hash::hashmap_drain(m)
    test::assert_eq_i32(len(drained), 2)
    test::assert_true(hash::hashmap_is_empty(m))

    let s: Vec<String> = hash_map::hashset_str_new()
    test::assert_true(hash_map::hashset_str_insert(s, "alpha"))
    test::assert_false(hash_map::hashset_str_insert(s, "alpha"))
    test::assert_true(hash_map::hashset_str_contains(s, "alpha"))
    test::assert_true(hash_map::hashset_str_remove(s, "alpha"))
    test::assert_false(hash_map::hashset_str_contains(s, "alpha"))
}
