use std::collections::hash
use std::collections::hash_map
use std::host::stdio

fn print_i32_option(v: Option<i32>) {
    match v {
        Option::Some(x) => stdio::println(concat("some:", i32_to_string(x))),
        None => stdio::println("none"),
    }
}

fn main() {
    let m: Vec<i32> = hash::hashmap_with_capacity(2)
    stdio::println(bool_to_string(hash::hashmap_set(m, 1, 0)))
    stdio::println(bool_to_string(hash::hashmap_set(m, 3, 30)))
    print_i32_option(hash::hashmap_get_option(m, 1))
    print_i32_option(hash::hashmap_insert(m, 3, 33))
    print_i32_option(hash::hashmap_get_option(m, 3))

    let removed_one: Option<i32> = hash::hashmap_remove(m, 1)
    print_i32_option(removed_one)
    print_i32_option(hash::hashmap_get_option(m, 3))

    stdio::println(bool_to_string(hash::hashmap_set(m, 5, 50)))
    stdio::println(i32_to_string(hash::hashmap_size(m)))
    stdio::println(bool_to_string(hash::hashmap_contains(m, 5)))

    let entry_pairs: Vec<i32> = hash::hashmap_entries(m)
    stdio::println(i32_to_string(len(entry_pairs)))
    let removed_entry: Vec<i32> = hash::hashmap_remove_entry(m, 3)
    stdio::println(i32_to_string(len(removed_entry)))
    stdio::println(i32_to_string(get_unchecked(removed_entry, 0)))
    stdio::println(i32_to_string(get_unchecked(removed_entry, 1)))
    print_i32_option(hash::hashmap_get_option(m, 3))

    let drained: Vec<i32> = hash::hashmap_drain(m)
    stdio::println(i32_to_string(len(drained)))
    stdio::println(bool_to_string(hash::hashmap_is_empty(m)))

    let s: Vec<String> = hash_map::hashset_str_new()
    stdio::println(bool_to_string(hash_map::hashset_str_insert(s, "alpha")))
    stdio::println(bool_to_string(hash_map::hashset_str_insert(s, "alpha")))
    stdio::println(bool_to_string(hash_map::hashset_str_contains(s, "alpha")))
    stdio::println(bool_to_string(hash_map::hashset_str_remove(s, "alpha")))
    stdio::println(bool_to_string(hash_map::hashset_str_contains(s, "alpha")))
}
