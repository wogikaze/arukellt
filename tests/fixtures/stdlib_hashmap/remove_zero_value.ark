// Remove: key with zero value returns Some(0), not None
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_new()
    hash::hashmap_set(m, 5, 0)
    test::assert_true(hash::hashmap_contains(m, 5))

    match hash::hashmap_remove(m, 5) {
        Option::Some(v) => test::assert_eq_i32(v, 0),
        None => panic("expected Some(0) for stored-zero value"),
    }
    test::assert_false(hash::hashmap_contains(m, 5))
    test::assert_eq_i32(hash::hashmap_size(m), 0)
}
