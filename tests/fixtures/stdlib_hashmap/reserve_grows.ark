// Reserve: increases capacity by at least additional
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_with_capacity(4)
    let cap_before = hash::hashmap_capacity(m)
    test::assert_eq_i32(cap_before, 4)

    hash::hashmap_reserve(m, 10)
    test::assert_true(hash::hashmap_capacity(m) >= cap_before + 10)
    test::assert_eq_i32(hash::hashmap_size(m), 0)
    test::assert_true(hash::hashmap_is_empty(m))
}
