// Stress: insert beyond initial capacity triggers resize, data preserved
use std::collections::hash
use std::test

fn main() {
    let m = hash::hashmap_with_capacity(4)
    let mut i = 0
    while i < 50 {
        hash::hashmap_set(m, i, i * 10)
        i = i + 1
    }
    test::assert_eq_i32(hash::hashmap_size(m), 50)
    test::assert_true(hash::hashmap_capacity(m) >= 50)

    // All data accessible after resize
    i = 0
    while i < 50 {
        test::assert_eq_i32(hash::hashmap_get(m, i), i * 10)
        i = i + 1
    }
}
