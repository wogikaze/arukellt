use std::host::stdio
use std::wasm

fn main() {
    let magic: Vec<i32> = wasm::wasm_magic()
    stdio::println((get_unchecked(magic, 0)).to_string())
    stdio::println((get_unchecked(magic, 1)).to_string())
    stdio::println((wasm::section_type()).to_string())
    stdio::println((wasm::valtype_i32()).to_string())
}
