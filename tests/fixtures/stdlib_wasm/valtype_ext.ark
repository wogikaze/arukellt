use std::host::stdio
use std::wasm

fn main() {
    stdio::println((wasm::valtype_i32()).to_string())
    stdio::println((wasm::valtype_i64()).to_string())
    stdio::println((wasm::valtype_f32()).to_string())
    stdio::println((wasm::valtype_f64()).to_string())
    stdio::println((wasm::valtype_v128()).to_string())
    stdio::println((wasm::valtype_funcref()).to_string())
    stdio::println((wasm::valtype_externref()).to_string())
    stdio::println((wasm::reftype_funcref()).to_string())
    stdio::println((wasm::reftype_externref()).to_string())
}
