use std::host::stdio
use std::wasm

fn main() {
    stdio::println((wasm::op_unreachable()).to_string())
    stdio::println((wasm::op_nop()).to_string())
    stdio::println((wasm::op_end()).to_string())
    stdio::println((wasm::op_return()).to_string())
    stdio::println((wasm::op_call()).to_string())
    stdio::println((wasm::op_local_get()).to_string())
    stdio::println((wasm::op_local_set()).to_string())
    stdio::println((wasm::op_i32_const()).to_string())
    stdio::println((wasm::op_i32_add()).to_string())
    stdio::println((wasm::op_i32_sub()).to_string())
    stdio::println((wasm::op_i32_eqz()).to_string())
    stdio::println((wasm::op_i32_eq()).to_string())
}
