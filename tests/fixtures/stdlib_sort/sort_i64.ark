use std::test

fn main() {
    let mut v: Vec<i64> = Vec_new_i64()
    let a: i64 = 30
    let b: i64 = 10
    let c: i64 = 50
    let d: i64 = 20
    let e: i64 = 40
    push(v, a)
    push(v, b)
    push(v, c)
    push(v, d)
    push(v, e)
    sort_i64(v)
    test::assert_eq_i32(len(v), 5)
    test::assert_eq_i64(get_unchecked(v, 0), 10)
    test::assert_eq_i64(get_unchecked(v, 1), 20)
    test::assert_eq_i64(get_unchecked(v, 2), 30)
    test::assert_eq_i64(get_unchecked(v, 3), 40)
    test::assert_eq_i64(get_unchecked(v, 4), 50)
}
