use std::test

fn main() {
    let mut v: Vec<f64> = Vec_new_f64()
    let a: f64 = 3.5
    let b: f64 = 1.2
    let c: f64 = 5.0
    let d: f64 = 2.8
    let e: f64 = 4.1
    push(v, a)
    push(v, b)
    push(v, c)
    push(v, d)
    push(v, e)
    sort_f64(v)
    test::assert_eq_i32(len(v), 5)
    test::assert_eq_f64(get_unchecked(v, 0), 1.2)
    test::assert_eq_f64(get_unchecked(v, 1), 2.8)
    test::assert_eq_f64(get_unchecked(v, 2), 3.5)
    test::assert_eq_f64(get_unchecked(v, 3), 4.1)
    test::assert_eq_f64(get_unchecked(v, 4), 5.0)
}
