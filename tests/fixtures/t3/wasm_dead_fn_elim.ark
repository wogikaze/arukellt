// Regression fixture for T3 dead function elimination on --emit wasm (#650).
//
// Verifies that pub fn exports not called from main survive reachability pruning
// on the general wasm emit path, while truly dead functions are removed.
//
// Layout:
//   pub fn exported_helper(x: i32) -> i32  -- wasm export root, NOT called from main
//     calls private fn helper_double(y: i32) -> i32  -- transitive callee, must survive
//   fn truly_dead_never_called() -> i32  -- not exported, not called, should be pruned
//   fn main() {}  -- entry root
//
// Expected behavior:
//   - `exported_helper` is preserved (export root)
//   - `helper_double` is preserved (transitive callee of export root)
//   - `truly_dead_never_called` is pruned (no root path)
//   - T3 wasm compile succeeds with no missing-function errors

pub fn exported_helper(x: i32) -> i32 {
    helper_double(x)
}

fn helper_double(y: i32) -> i32 {
    y * 2
}

fn truly_dead_never_called() -> i32 {
    42
}

fn main() {
}
