use std::host::stdio
use std::random

fn main() {
    let a = random::seeded_random(1)
    assert(a != 0)
    let b = random::seeded_random(1)
    assert_eq(a, b)
    let r = random::seeded_range(42, 0, 10)
    assert(r >= 0)
    assert(r < 10)
    stdio::println("random_basic ok")
}
// seeded_random returns a non-zero i32 for any non-zero seed
// seeded_random is deterministic
// seeded_range: result is in [lo, hi)
