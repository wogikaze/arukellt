use std::host::stdio
use std::random

fn main() {
    let v = Vec_new_i32()
    push(v, 10)
    push(v, 20)
    push(v, 30)
    push(v, 40)
    push(v, 50)
    let shuffled = random::shuffle_i32(v, 42)
    assert_eq(len(shuffled), 5)
    assert_eq(get_unchecked(shuffled, 0), 30)
    assert_eq(get_unchecked(shuffled, 1), 40)
    assert_eq(get_unchecked(shuffled, 2), 20)
    assert_eq(get_unchecked(shuffled, 3), 50)
    assert_eq(get_unchecked(shuffled, 4), 10)
    stdio::println("shuffle ok")
}
// Same length
// Exact permutation is reproducible for a fixed seed
