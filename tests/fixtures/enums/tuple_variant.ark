use std::host::stdio

enum Shape {
    Circle(f64),
    Rectangle(f64, f64),
}

fn describe(s: Shape) -> String {
    match s {
        Shape::Circle(r) => concat(String_from("circle r="), (r).to_string()),
        Shape::Rectangle(w, h) => concat(concat(String_from("rect "), (w).to_string()), concat(String_from("x"), (h).to_string())),
    }
}

fn main() {
    stdio::println(describe(Shape::Circle(5.0)))
    stdio::println(describe(Shape::Rectangle(3.0, 4.0)))
}
