enum Shape {
    Circle { radius: i32 },
    Rect { width: i32, height: i32 },
}

fn area(s: Shape) -> i32 {
    match s {
        Shape::Circle { radius } => radius * radius * 3,
        Shape::Rect { width, height } => width * height,
    }
}

fn main() {
    let c = Shape::Circle { radius: 5 }
    let r = Shape::Rect { width: 4, height: 6 }
    println(i32_to_string(area(c)))
    println(i32_to_string(area(r)))
}
