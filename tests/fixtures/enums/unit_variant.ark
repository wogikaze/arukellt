use std::host::stdio
enum Color {
    Red,
    Green,
    Blue,
}

fn color_name(c: Color) -> String {
    match c {
        Color::Red => String_from("red"),
        Color::Green => String_from("green"),
        Color::Blue => String_from("blue"),
    }
}

fn main() {
    stdio::println(color_name(Color::Green))
}
