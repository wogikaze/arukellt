use std::component::handle
use std::host::stdio

fn main() {
    let t: Vec<i32> = handle::handle_table_new()
    stdio::println((handle::handle_len(t)).to_string())
    let h0: i32 = handle::handle_new(t, 42)
    let h1: i32 = handle::handle_new(t, 99)
    stdio::println((handle::handle_len(t)).to_string())
    match handle::handle_get(t, h0) {
        Option::Some(v) => stdio::println((v).to_string()),
        None => stdio::println("missing"),
    }
    match handle::handle_get(t, h1) {
        Option::Some(v) => stdio::println((v).to_string()),
        None => stdio::println("missing"),
    }
    match handle::handle_drop(t, h0) {
        Option::Some(v) => stdio::println((v).to_string()),
        None => stdio::println("missing"),
    }
    stdio::println((handle::handle_len(t)).to_string())
    match handle::handle_get(t, h0) {
        Option::Some(v) => stdio::println((v).to_string()),
        None => stdio::println("dropped"),
    }
}
// Tests Component Model handle table (SlotMap-backed)
// Empty table length
// Insert two handles
// Get by handle
// Drop returns value
// Dropped handle is gone
