use std::collections::compiler
use std::host::stdio

fn main() {
    let m: Vec<i32> = compiler::slotmap_new()
    stdio::println((compiler::slotmap_len(m)).to_string())
    let k0: i32 = compiler::slotmap_insert(m, 42)
    let k1: i32 = compiler::slotmap_insert(m, 99)
    stdio::println((compiler::slotmap_len(m)).to_string())
    stdio::println((compiler::slotmap_contains(m, k0)).to_string())
    stdio::println((compiler::slotmap_contains(m, k1)).to_string())
    let removed: Option<i32> = compiler::slotmap_remove(m, k0)
    match removed {
        Option::Some(v) => stdio::println((v).to_string()),
        None => stdio::println("not found"),
    }
    stdio::println((compiler::slotmap_len(m)).to_string())
    stdio::println((compiler::slotmap_contains(m, k0)).to_string())
    stdio::println((compiler::slotmap_contains(m, k1)).to_string())
}
