use std::collections::compiler
use std::host::stdio

fn main() {
    let a = compiler::arena_new()
    stdio::println((compiler::arena_len(a)).to_string())
    let id0 = compiler::arena_alloc(a, 42)
    stdio::println((compiler::arena_len(a)).to_string())
    let id1 = compiler::arena_alloc(a, 99)
    let id2 = compiler::arena_alloc(a, 77)
    stdio::println((compiler::arena_len(a)).to_string())
    stdio::println((compiler::arena_get(a, id0)).to_string())
    stdio::println((compiler::arena_get(a, id1)).to_string())
    stdio::println((compiler::arena_get(a, id2)).to_string())
}
