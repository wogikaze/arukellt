import stdin
import console

fn parse_or_zero(text: String) -> Int:
  match parse.i64(text):
    Ok(value) -> value
    Err(_) -> 0

fn main():
  let tokens = stdin.read_text().split_whitespace()
  let a = parse_or_zero(tokens[0])
  let b = parse_or_zero(tokens[1])
  if (a * b) % 2 == 0:
    "Even" |> console.println
  else:
    "Odd" |> console.println
