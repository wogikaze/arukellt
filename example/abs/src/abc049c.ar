import stdin
import console

fn can_form(text: String) -> Bool:
  if text == "":
    true
  else:
    ["dreamer", "eraser", "dream", "erase"].any(suffix -> strip_suffix(text, suffix).map(can_form).unwrap_or(false))

fn main():
  let text = stdin.read_text().split_whitespace()[0]
  if can_form(text):
    "YES" |> console.println
  else:
    "NO" |> console.println
