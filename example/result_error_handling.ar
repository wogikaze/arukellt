import console

type Error =
  DivisionByZero

fn divide(a: i64, b: i64) -> Result<i64, Error>:
  if b == 0:
    Err(DivisionByZero)
  else:
    Ok(a / b)

fn render_error(error: Error) -> String:
  match error:
    DivisionByZero -> "error"

fn render_result(result: Result<i64, Error>) -> String:
  match result:
    Ok(value) -> value |> string
    Err(error) -> error |> render_error

fn main():
  divide(10, 0)
    |> render_result
    |> console.println
