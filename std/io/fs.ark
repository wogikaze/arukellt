// std/io/fs — Filesystem operations (WASI preview1)
//
// These wrappers delegate to compiler intrinsics that emit inline WASI
// syscalls (path_open, fd_read, fd_write, fd_close).

pub fn fs_read_file(path: String) -> Result<String, String> {
    __intrinsic_fs_read_file(path)
}

pub fn fs_write_file(path: String, content: String) -> Result<(), String> {
    __intrinsic_fs_write_file(path, content)
}
