// Bulk memory operations
pub fn memory_copy(dst: i32, src: i32, len: i32) {
    __intrinsic_memory_copy(dst, src, len)
}

pub fn memory_fill(ptr: i32, val: i32, len: i32) {
    __intrinsic_memory_fill(ptr, val, len)
}
