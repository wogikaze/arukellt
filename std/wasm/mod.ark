// --- FuncType ---
//
// Backed by Vec<i32>.
// Layout: [param_count, p0, p1, ..., result_count, r0, r1, ...]
//
// functype_new(params: Vec<i32>, results: Vec<i32>) -> Vec<i32>
pub fn functype_new(params: Vec<i32>, results: Vec<i32>) -> Vec<i32> {
    let ft: Vec<i32> = Vec_new_i32()
    let plen: i32 = len(params)
    push(ft, plen)
    let mut pi: i32 = 0
    while pi < plen {
        push(ft, get_unchecked(params, pi))
        pi = pi + 1
    }
    let rlen: i32 = len(results)
    push(ft, rlen)
    let mut ri: i32 = 0
    while ri < rlen {
        push(ft, get_unchecked(results, ri))
        ri = ri + 1
    }
    ft
}

pub fn functype_param_count(ft: Vec<i32>) -> i32 {
    get_unchecked(ft, 0)
}

pub fn functype_result_count(ft: Vec<i32>) -> i32 {
    let plen: i32 = get_unchecked(ft, 0)
    get_unchecked(ft, 1 + plen)
}

pub fn functype_get_param(ft: Vec<i32>, idx: i32) -> i32 {
    get_unchecked(ft, 1 + idx)
}

pub fn functype_get_result(ft: Vec<i32>, idx: i32) -> i32 {
    let plen: i32 = get_unchecked(ft, 0)
    get_unchecked(ft, 2 + plen + idx)
}

// --- Limits ---
//
// Backed by Vec<i32>.
// Layout: [min, has_max, max]
pub fn limits_unbounded(min: i32) -> Vec<i32> {
    let l: Vec<i32> = Vec_new_i32()
    push(l, min)
    push(l, 0)
    push(l, 0)
    l
}

pub fn limits_bounded(min: i32, max: i32) -> Vec<i32> {
    let l: Vec<i32> = Vec_new_i32()
    push(l, min)
    push(l, 1)
    push(l, max)
    l
}

pub fn limits_min(l: Vec<i32>) -> i32 {
    get_unchecked(l, 0)
}

pub fn limits_has_max(l: Vec<i32>) -> bool {
    get_unchecked(l, 1) == 1
}

pub fn limits_max(l: Vec<i32>) -> i32 {
    get_unchecked(l, 2)
}

// --- WasmModuleBuilder ---
//
// Minimal stub producing a valid Wasm MVP binary (magic + version only).
// Functions/memories/exports are counted but not yet encoded into full sections.
//
// State Vec<i32> layout: [func_type_count, func_count, mem_count, export_count]
pub fn module_new() -> Vec<i32> {
    let m: Vec<i32> = Vec_new_i32()
    push(m, 0)
    push(m, 0)
    push(m, 0)
    push(m, 0)
    m
}

pub fn module_add_type(m: Vec<i32>, ft: Vec<i32>) -> i32 {
    let idx: i32 = get_unchecked(m, 0)
    set(m, 0, idx + 1)
    idx
}

pub fn module_add_func(m: Vec<i32>, type_idx: i32) -> i32 {
    let idx: i32 = get_unchecked(m, 1)
    set(m, 1, idx + 1)
    idx
}

pub fn module_add_memory(m: Vec<i32>, limits: Vec<i32>) -> i32 {
    let idx: i32 = get_unchecked(m, 2)
    set(m, 2, idx + 1)
    idx
}

pub fn module_add_export_func(m: Vec<i32>, name: String, func_idx: i32) {
    let cnt: i32 = get_unchecked(m, 3)
    set(m, 3, cnt + 1)
}

pub fn module_type_count(m: Vec<i32>) -> i32 {
    get_unchecked(m, 0)
}

pub fn module_func_count(m: Vec<i32>) -> i32 {
    get_unchecked(m, 1)
}

pub fn module_mem_count(m: Vec<i32>) -> i32 {
    get_unchecked(m, 2)
}

pub fn module_export_count(m: Vec<i32>) -> i32 {
    get_unchecked(m, 3)
}

/// Encode the module to a Wasm binary header (magic + version).
/// Full section encoding is a v4 task; this stub returns a valid 8-byte header.
pub fn module_encode_header() -> Vec<i32> {
    let out: Vec<i32> = Vec_new_i32()
    push(out, 0)
    push(out, 97)
    push(out, 115)
    push(out, 109)
    push(out, 1)
    push(out, 0)
    push(out, 0)
    push(out, 0)
    out
}

// --- LEB128 encoding ---
/// Encode a u32 as unsigned LEB128. Returns Vec<i32> of bytes.
pub fn leb128_encode_u32(x: i32) -> Vec<i32> {
    let out: Vec<i32> = Vec_new_i32()
    let mut val: i32 = x
    let mut done: bool = false
    while done == false {
        let byte: i32 = val & 127
        val = val / 128
        if val == 0 {
            push(out, byte)
            done = true
        } else {
            push(out, byte | 128)
        }
    }
    out
}

/// Return the number of bytes needed to encode x as unsigned LEB128.
pub fn leb128_size_u32(x: i32) -> i32 {
    if x < 128 {
        1
    } else {
        if x < 16384 {
            2
        } else {
            if x < 2097152 {
                3
            } else {
                if x < 268435456 {
                    4
                } else {
                    5
                }
            }
        }
    }
}

