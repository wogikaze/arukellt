//! Host environment helpers.
//!
//! Provides CLI argument access and environment variable lookup backed by
//! WASI intrinsics (args_sizes_get / args_get, environ_sizes_get / environ_get).
//!
//! **Availability:** All targets (`wasm32` + `wasm32-gc`). Environment variable access
//! (`var`) requires WASI Preview 2 component model (not available on P1).

/// Returns the process argument vector (excluding argv[0]).
pub fn args() -> Vec<String> {
    __intrinsic_args()
}

/// Returns the number of process arguments (excluding argv[0]).
pub fn arg_count() -> i32 {
    __intrinsic_arg_count()
}

/// Returns the argument at the given index when in range.
pub fn arg_at(index: i32) -> Option<String> {
    let v = args()
    get(v, index)
}

/// Looks up an environment variable by name.
pub fn var(name: String) -> Option<String> {
    __intrinsic_env_var(name)
}

/// Returns true when the argument vector contains the given flag.
pub fn has_flag(flag: String) -> bool {
    let values = args()
    let mut i = 0
    while i < len(values) {
        if get_unchecked(values, i) == flag {
            return true
        }
        i = i + 1
    }
    false
}

/// Looks up an environment variable by name (alias for clarity).
pub fn get_var(name: String) -> Option<String> {
    __intrinsic_env_var(name)
}

/// Looks up an environment variable, returning a default if not set.
pub fn var_or_default(name: String, default: String) -> String {
    match __intrinsic_env_var(name) {
        Option::Some(v) => v,
        Option::None => default,
    }
}
