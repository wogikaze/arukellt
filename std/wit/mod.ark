//! Experimental WIT helpers.
//!
//! Primitive helpers remain in this module for backward compatibility.
//! Compound types, world builders, and parse/print live in submodules.

use std::wit::types

pub fn wit_type_bool() -> types::WitType {
    types::wit_type_bool()
}

pub fn wit_type_u8() -> types::WitType {
    types::wit_type_u8()
}

pub fn wit_type_u16() -> types::WitType {
    types::wit_type_u16()
}

pub fn wit_type_u32() -> types::WitType {
    types::wit_type_u32()
}

pub fn wit_type_u64() -> types::WitType {
    types::wit_type_u64()
}

pub fn wit_type_s8() -> types::WitType {
    types::wit_type_s8()
}

pub fn wit_type_s16() -> types::WitType {
    types::wit_type_s16()
}

pub fn wit_type_s32() -> types::WitType {
    types::wit_type_s32()
}

pub fn wit_type_s64() -> types::WitType {
    types::wit_type_s64()
}

pub fn wit_type_f32() -> types::WitType {
    types::wit_type_f32()
}

pub fn wit_type_f64() -> types::WitType {
    types::wit_type_f64()
}

pub fn wit_type_char() -> types::WitType {
    types::wit_type_char()
}

pub fn wit_type_string() -> types::WitType {
    types::wit_type_string()
}

pub fn wit_type_id(ty: types::WitType) -> i32 {
    types::wit_type_id(ty)
}

pub fn wit_type_from_id(id: i32) -> types::WitType {
    types::wit_type_from_id(id)
}

pub fn wit_type_name(ty: types::WitType) -> String {
    types::wit_type_name(ty)
}
