// std::core::math — mathematical functions
//
// Wrappers around compiler intrinsics for math operations.

pub fn abs(x: i32) -> i32 {
    __intrinsic_abs(x)
}

pub fn abs_i32(x: i32) -> i32 {
    abs(x)
}

pub fn min(a: i32, b: i32) -> i32 {
    __intrinsic_min(a, b)
}

pub fn min_i32(a: i32, b: i32) -> i32 {
    min(a, b)
}

pub fn max(a: i32, b: i32) -> i32 {
    __intrinsic_max(a, b)
}

pub fn max_i32(a: i32, b: i32) -> i32 {
    max(a, b)
}

pub fn sqrt(x: f64) -> f64 {
    __intrinsic_sqrt(x)
}

pub fn clamp(x: i32, lo: i32, hi: i32) -> i32 {
    if x < lo {
        lo
    } else if x > hi {
        hi
    } else {
        x
    }
}

pub fn pow_i32(base: i32, exp: i32) -> i32 {
    let mut result = 1
    let mut i = 0
    while i < exp {
        result = result * base
        i = i + 1
    }
    result
}

pub fn gcd(a: i32, b: i32) -> i32 {
    let mut x = a
    let mut y = b
    if x < 0 { x = 0 - x }
    if y < 0 { y = 0 - y }
    while y != 0 {
        let t = y
        y = x - (x / y) * y
        x = t
    }
    x
}
