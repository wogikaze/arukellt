//! Process-control helpers.
//!
//! The current implementation uses lightweight fallbacks because the WASI
//! `proc_exit` import is not wired in yet.

/// Requests process termination with the given exit code.
pub fn exit(code: i32) {
    if code == 0 {
        // Clean exit: no-op (let program end naturally)
    } else {
        panic(concat("exit: non-zero code ", i32_to_string(code)))
    }
}

/// Aborts execution immediately by panicking.
pub fn abort() {
    panic("abort: process aborted")
}
