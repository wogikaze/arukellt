// std::process — process control
//
// exit/abort for process termination.
// NOTE: WASI proc_exit not yet imported; exit uses panic as fallback.

pub fn exit(code: i32) {
    if code == 0 {
        // Clean exit: no-op (let program end naturally)
    } else {
        panic(concat("exit: non-zero code ", i32_to_string(code)))
    }
}

pub fn abort() {
    panic("abort: process aborted")
}
