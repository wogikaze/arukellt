// std::collections::linear — Deque and PriorityQueue (i32 monomorphic)
//
// Deque: double-ended queue using a ring buffer (Vec<i32>).
// PriorityQueue: min-heap using Vec<i32>.
// Generic versions deferred to v4 (requires generics).

// --- Deque (ring buffer) ---

pub fn deque_new() -> Vec<i32> {
    // Layout: [head, tail, count, cap, ...data(cap)]
    let cap: i32 = 16
    let d: Vec<i32> = Vec_new_i32()
    push(d, 0)
    push(d, 0)
    push(d, 0)
    push(d, cap)
    let mut i: i32 = 0
    while i < cap {
        push(d, 0)
        i = i + 1
    }
    d
}

pub fn deque_push_back(d: Vec<i32>, val: i32) {
    let tail: i32 = get_unchecked(d, 1)
    let count: i32 = get_unchecked(d, 2)
    let cap: i32 = get_unchecked(d, 3)
    set(d, 4 + tail, val)
    set(d, 1, (tail + 1) % cap)
    set(d, 2, count + 1)
}

pub fn deque_push_front(d: Vec<i32>, val: i32) {
    let head: i32 = get_unchecked(d, 0)
    let count: i32 = get_unchecked(d, 2)
    let cap: i32 = get_unchecked(d, 3)
    let new_head: i32 = (head - 1 + cap) % cap
    set(d, 4 + new_head, val)
    set(d, 0, new_head)
    set(d, 2, count + 1)
}

pub fn deque_pop_front(d: Vec<i32>) -> i32 {
    let head: i32 = get_unchecked(d, 0)
    let cap: i32 = get_unchecked(d, 3)
    let val: i32 = get_unchecked(d, 4 + head)
    set(d, 0, (head + 1) % cap)
    let count: i32 = get_unchecked(d, 2)
    set(d, 2, count - 1)
    val
}

pub fn deque_pop_back(d: Vec<i32>) -> i32 {
    let tail: i32 = get_unchecked(d, 1)
    let cap: i32 = get_unchecked(d, 3)
    let new_tail: i32 = (tail - 1 + cap) % cap
    let val: i32 = get_unchecked(d, 4 + new_tail)
    set(d, 1, new_tail)
    let count: i32 = get_unchecked(d, 2)
    set(d, 2, count - 1)
    val
}

pub fn deque_len(d: Vec<i32>) -> i32 {
    get_unchecked(d, 2)
}

pub fn deque_is_empty(d: Vec<i32>) -> bool {
    get_unchecked(d, 2) == 0
}

// --- PriorityQueue (min-heap) ---

pub fn pq_new() -> Vec<i32> {
    // Layout: [count, ...heap_data]
    let pq: Vec<i32> = Vec_new_i32()
    push(pq, 0)
    pq
}

pub fn pq_push(pq: Vec<i32>, val: i32) {
    let count: i32 = get_unchecked(pq, 0)
    push(pq, val)
    set(pq, 0, count + 1)
    // Sift up
    let mut idx: i32 = count
    let mut cont: bool = idx > 0
    while cont {
        let parent: i32 = (idx - 1) / 2
        let child_val: i32 = get_unchecked(pq, 1 + idx)
        let parent_val: i32 = get_unchecked(pq, 1 + parent)
        if child_val < parent_val {
            set(pq, 1 + idx, parent_val)
            set(pq, 1 + parent, child_val)
            idx = parent
            cont = idx > 0
        } else {
            cont = false
        }
    }
}

pub fn pq_pop(pq: Vec<i32>) -> i32 {
    let count: i32 = get_unchecked(pq, 0)
    let result: i32 = get_unchecked(pq, 1)
    let last: i32 = get_unchecked(pq, count)
    set(pq, 1, last)
    set(pq, 0, count - 1)
    // Sift down
    let new_count: i32 = count - 1
    let mut idx: i32 = 0
    let mut cont: bool = true
    while cont {
        let left: i32 = idx * 2 + 1
        let right: i32 = idx * 2 + 2
        let mut smallest: i32 = idx
        if left < new_count {
            if get_unchecked(pq, 1 + left) < get_unchecked(pq, 1 + smallest) {
                smallest = left
            }
        }
        if right < new_count {
            if get_unchecked(pq, 1 + right) < get_unchecked(pq, 1 + smallest) {
                smallest = right
            }
        }
        if smallest != idx {
            let tmp: i32 = get_unchecked(pq, 1 + idx)
            set(pq, 1 + idx, get_unchecked(pq, 1 + smallest))
            set(pq, 1 + smallest, tmp)
            idx = smallest
        } else {
            cont = false
        }
    }
    result
}

pub fn pq_peek(pq: Vec<i32>) -> i32 {
    get_unchecked(pq, 1)
}

pub fn pq_len(pq: Vec<i32>) -> i32 {
    get_unchecked(pq, 0)
}

pub fn pq_is_empty(pq: Vec<i32>) -> bool {
    get_unchecked(pq, 0) == 0
}
