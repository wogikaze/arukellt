//! std::collections::hash_map — HashMap API wrappers
//!
//! Provides user-facing wrappers around the monomorphic HashMap intrinsics.
//! For HashMap<i32,i32>:  use HashMap_i32_i32_new / HashMap_i32_i32_insert etc.
//! For HashMap<String,i32>: use the functions below.

use std::collections::hash

/// Create a new HashMap<i32, i32> (alias for HashMap_i32_i32_new).
pub fn hashmap_i32_i32_new() -> HashMap<i32, i32> {
    HashMap_i32_i32_new()
}

/// Insert into a HashMap<i32, i32> and return the previous value if present.
pub fn hashmap_i32_i32_insert(m: HashMap<i32, i32>, key: i32, value: i32) -> Option<i32> {
    let old: Option<i32> = HashMap_i32_i32_get(m, key)
    HashMap_i32_i32_insert(m, key, value)
    old
}

/// Get from a HashMap<i32, i32>.
pub fn hashmap_i32_i32_get(m: HashMap<i32, i32>, key: i32) -> Option<i32> {
    HashMap_i32_i32_get(m, key)
}

/// Check containment in a HashMap<i32, i32>.
pub fn hashmap_i32_i32_contains(m: HashMap<i32, i32>, key: i32) -> bool {
    HashMap_i32_i32_contains_key(m, key)
}

/// Return the number of entries in a HashMap<i32, i32>.
pub fn hashmap_i32_i32_len(m: HashMap<i32, i32>) -> i32 {
    HashMap_i32_i32_len(m)
}

/// Returns true if the HashMap<i32, i32> has no entries.
pub fn hashmap_i32_i32_is_empty(m: HashMap<i32, i32>) -> bool {
    HashMap_i32_i32_len(m) == 0
}

/// Create a new HashMap<String, i32>.
pub fn hashmap_str_i32_new() -> HashMap<String, i32> {
    HashMap_new_String_i32()
}

/// Insert into a HashMap<String, i32> and return the previous value if present.
pub fn hashmap_str_i32_insert(m: HashMap<String, i32>, key: String, value: i32) -> Option<i32> {
    let old: Option<i32> = HashMap_String_i32_get(m, clone(key))
    HashMap_String_i32_insert(m, key, value)
    old
}

/// Get from a HashMap<String, i32>.
pub fn hashmap_str_i32_get(m: HashMap<String, i32>, key: String) -> Option<i32> {
    HashMap_String_i32_get(m, key)
}

/// Check containment in a HashMap<String, i32>.
pub fn hashmap_str_i32_contains(m: HashMap<String, i32>, key: String) -> bool {
    HashMap_String_i32_contains_key(m, key)
}

/// Return the number of entries in a HashMap<String, i32>.
pub fn hashmap_str_i32_len(m: HashMap<String, i32>) -> i32 {
    HashMap_String_i32_len(m)
}

/// Returns true if the HashMap<String, i32> has no entries.
pub fn hashmap_str_i32_is_empty(m: HashMap<String, i32>) -> bool {
    HashMap_String_i32_len(m) == 0
}

/// Create a new HashMap<i32, String>.
pub fn hashmap_i32_str_new() -> HashMap<i32, String> {
    HashMap_new_i32_String()
}

/// Insert into a HashMap<i32, String> and return the previous value if present.
pub fn hashmap_i32_str_insert(m: HashMap<i32, String>, key: i32, value: String) -> Option<String> {
    let old: Option<String> = HashMap_i32_String_get(m, key)
    HashMap_i32_String_insert(m, key, value)
    old
}

/// Get from a HashMap<i32, String>.
pub fn hashmap_i32_str_get(m: HashMap<i32, String>, key: i32) -> Option<String> {
    HashMap_i32_String_get(m, key)
}

/// Check containment in a HashMap<i32, String>.
pub fn hashmap_i32_str_contains(m: HashMap<i32, String>, key: i32) -> bool {
    HashMap_i32_String_contains_key(m, key)
}

/// Return the number of entries in a HashMap<i32, String>.
pub fn hashmap_i32_str_len(m: HashMap<i32, String>) -> i32 {
    HashMap_i32_String_len(m)
}

/// Returns true if the HashMap<i32, String> has no entries.
pub fn hashmap_i32_str_is_empty(m: HashMap<i32, String>) -> bool {
    HashMap_i32_String_len(m) == 0
}

/// Create a new HashMap<String, String>.
pub fn hashmap_str_str_new() -> HashMap<String, String> {
    HashMap_new_String_String()
}

/// Insert into a HashMap<String, String> and return the previous value if present.
pub fn hashmap_str_str_insert(m: HashMap<String, String>, key: String, value: String) -> Option<String> {
    let old: Option<String> = HashMap_String_String_get(m, clone(key))
    HashMap_String_String_insert(m, key, value)
    old
}

/// Get from a HashMap<String, String>.
pub fn hashmap_str_str_get(m: HashMap<String, String>, key: String) -> Option<String> {
    HashMap_String_String_get(m, key)
}

/// Check containment in a HashMap<String, String>.
pub fn hashmap_str_str_contains(m: HashMap<String, String>, key: String) -> bool {
    HashMap_String_String_contains_key(m, key)
}

/// Return the number of entries in a HashMap<String, String>.
pub fn hashmap_str_str_len(m: HashMap<String, String>) -> i32 {
    HashMap_String_String_len(m)
}

/// Returns true if the HashMap<String, String> has no entries.
pub fn hashmap_str_str_is_empty(m: HashMap<String, String>) -> bool {
    HashMap_String_String_len(m) == 0
}

/// Create a new HashSet<String>.
pub fn hashset_str_new() -> Vec<String> {
    Vec_new_String()
}

/// Insert a value into a HashSet<String>. Returns true if the value was newly inserted.
pub fn hashset_str_insert(_s: Vec<String>, _value: String) -> bool {
    false
}

/// Returns true if the HashSet<String> contains the value.
pub fn hashset_str_contains(_s: Vec<String>, _value: String) -> bool {
    false
}

/// Remove a value from the HashSet<String>. Returns true if the value was present.
pub fn hashset_str_remove(_s: Vec<String>, _value: String) -> bool {
    false
}

/// Return the number of elements in a HashSet<String>.
pub fn hashset_str_len(_s: Vec<String>) -> i32 {
    0
}

/// Returns true if the HashSet<String> is empty.
pub fn hashset_str_is_empty(_s: Vec<String>) -> bool {
    true
