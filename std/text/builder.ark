/// StringBuilder — efficient string building through a growable byte buffer.
///
/// The builder accumulates string fragments in a `Vec<i32>` byte buffer
/// (amortized O(1) append via `push`) and produces a final `String` via
/// `builder_build` (single O(n) allocation + copy using
/// `__intrinsic_string_from_bytes`).

/// Creates a new empty StringBuilder (represented as a Vec<i32> byte buffer).
pub fn builder_new() -> Vec<i32> {
    Vec_new_i32()
}

/// Appends a string to the builder by copying its bytes into the buffer.
pub fn builder_append(sb: Vec<i32>, s: String) -> Vec<i32> {
    let n = len(s)
    let mut i = 0
    while i < n {
        push(sb, char_at(clone(s), i))
        i = i + 1
    }
    sb
}

/// Appends a single byte value to the builder.
pub fn builder_append_char(sb: Vec<i32>, c: i32) -> Vec<i32> {
    push(sb, c)
    sb
}

/// Appends a string followed by a newline to the builder.
pub fn builder_append_line(sb: Vec<i32>, s: String) -> Vec<i32> {
    let n = len(s)
    let mut i = 0
    while i < n {
        push(sb, char_at(clone(s), i))
        i = i + 1
    }
    push(sb, 10)
    sb
}

/// Produces the final string from the builder's byte buffer.
/// Uses `__intrinsic_string_from_bytes` for a single O(n) allocation.
pub fn builder_build(sb: Vec<i32>) -> String {
    __intrinsic_string_from_bytes(sb)
}

/// Returns the current byte length of the builder's content.
pub fn builder_len(sb: Vec<i32>) -> i32 {
    len(sb)
}
