//! TOML streaming scanner utilities for `std::toml`.
//!
//! This top-level file contains only the low-level section/value
//! extraction functions that the compiler's manifest/script/project
//! parsers need. The full TOML parser with `pub enum TomlValue` lives
//! in `std/toml/parser.ark` (loaded as `std::toml::parser`) to avoid
//! the bootstrap compiler stubbing the entire module.

/// Filter a single TOML source line: returns the line unchanged for key=value
/// lines and returns `""` for comments and blank lines.
pub fn toml_parse_line(line: String) -> String {
    let n: i32 = len(line)
    if n == 0 {
        ""
    } else {
        let first: String = slice(line, 0, 1)
        if eq(first, "#") {
            ""
        } else {
            line
        }
    }
}

/// Extract the body of a TOML section `[section]` from `content`.
/// Returns the text between the section header and the next section header
/// (or end of content).  Returns an empty string if the section is not found.
pub fn toml_find_section(content: String, section: String) -> String {
    let section_header = concat(String_from("["), concat(clone(section), String_from("]")))
    let header_len = len(section_header)
    let content_len = len(content)
    let mut i = 0
    while i < content_len {
        if i == 0 || char_at(content, i - 1) == 10 {
            let j_max = content_len - i
            let match_len = if header_len < j_max { header_len } else { j_max }
            let mut j = 0
            while j < match_len && char_at(content, i + j) == char_at(section_header, j) {
                j = j + 1
            }
            if j == header_len && (i + j >= content_len || char_at(content, i + j) == 10) {
                let section_start = i + j
                if section_start >= content_len {
                    return String_new()
                }
                let body_start = if char_at(content, section_start) == 10 { section_start + 1 } else { section_start }
                let mut k = body_start
                while k < content_len {
                    if char_at(content, k) == 10 && k + 1 < content_len && char_at(content, k + 1) == 91 {
                        return substring(content, body_start, k)
                    }
                    k = k + 1
                }
                return substring(content, body_start, content_len)
            }
        }
        i = i + 1
    }
    String_new()
}

/// Extract the string value of `key = "value"` from a TOML content block.
/// Scans line-by-line for a line starting with `key` followed by optional
/// whitespace, `=`, optional whitespace, and a double-quoted string.
/// Returns the unquoted string value, or an empty string if not found.
pub fn toml_find_value(content: String, key: String) -> String {
    let content_len = len(content)
    let key_len = len(key)
    let mut line_start = 0
    let mut i = 0
    while i < content_len {
        if char_at(content, i) == 10 || i == content_len - 1 {
            let line_end = if char_at(content, i) == 10 { i } else { i + 1 }
            let line = substring(content, line_start, line_end)
            let line_len = len(line)
            if line_len > key_len + 3 {
                if eq(substring(line, 0, key_len), clone(key)) {
                    let mut j = key_len
                    while j < line_len && char_at(line, j) == 32 { j = j + 1 }
                    if j < line_len && char_at(line, j) == 61 {
                        j = j + 1
                        while j < line_len && char_at(line, j) == 32 { j = j + 1 }
                        if j < line_len && char_at(line, j) == 34 {
                            let val_start = j + 1
                            let mut k = val_start
                            while k < line_len && char_at(line, k) != 34 { k = k + 1 }
                            return substring(line, val_start, k)
                        }
                    }
                }
            }
            line_start = i + 1
        }
        i = i + 1
    }
    String_new()
}

// ─── Re-exports from std/toml/parser.ark ────────────────────────────────────
// The full TOML parser (toml_parse, toml_stringify, toml_get, etc.) lives in
// std/toml/parser.ark.  These wrappers delegate to the parser submodule so
// that `use std::toml` callers can invoke `toml::toml_parse(...)` directly.

use std::toml::parser

pub fn toml_parse(s: String) -> Result<parser::TomlValue, String> {
    parser::toml_parse(s)
}

pub fn toml_stringify(v: parser::TomlValue) -> String {
    parser::toml_stringify(v)
}

pub fn toml_as_string(v: parser::TomlValue) -> Option<String> {
    parser::toml_as_string(v)
}

pub fn toml_as_int(v: parser::TomlValue) -> Option<i32> {
    parser::toml_as_int(v)
}

pub fn toml_as_bool(v: parser::TomlValue) -> Option<bool> {
    parser::toml_as_bool(v)
}

pub fn toml_get(v: parser::TomlValue, key: String) -> Option<parser::TomlValue> {
    parser::toml_get(v, key)
}

pub fn toml_table_keys(v: parser::TomlValue) -> Vec<String> {
    parser::toml_table_keys(v)
}

pub fn toml_test_wrapper() -> String {
    String_from("wrapper_ok")
}
