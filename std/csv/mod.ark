//! CSV parser/serializer for std::csv.
//!
//! Supports RFC 4180 quoted fields and basic multi-row documents.

// ─── Legacy helper ───────────────────────────────────────────────────────────

/// Split a single CSV line on commas (no quote handling).
pub fn csv_split_line(line: String) -> Vec<String> {
    split(line, String_from(","))
}

// ─── RFC 4180 row parser ─────────────────────────────────────────────────────

/// Parse a single CSV line into fields, handling RFC 4180 quoted fields.
///
/// Quoted fields may contain embedded commas, double-quotes (escaped as `""`),
/// and newlines.
pub fn csv_parse_row(line: String) -> Vec<String> {
    let result = Vec_new_String()
    let n = len(line)
    let mut i = 0
    while i <= n {
        // Parse one field
        let mut field = ""
        if i < n && char_at(line, i) == 34 {
            // Quoted field
            i = i + 1
            while i < n {
                let c = char_at(line, i)
                if c == 34 {
                    if i + 1 < n && char_at(line, i + 1) == 34 {
                        // Escaped quote ""
                        field = concat(field, "\"")
                        i = i + 2
                    } else {
                        // End of quoted field
                        i = i + 1
                        break
                    }
                } else {
                    field = concat(field, slice(line, i, i + 1))
                    i = i + 1
                }
            }
            // Skip comma after closing quote
            if i < n && char_at(line, i) == 44 {
                i = i + 1
            }
        } else {
            // Unquoted field — read until comma or end
            let start = i
            while i < n && char_at(line, i) != 44 {
                i = i + 1
            }
            field = slice(line, start, i)
            if i < n {
                i = i + 1
            }
        }
        push(result, field)
        if i == n && n > 0 && char_at(line, n - 1) == 44 {
            // Trailing comma — add empty field
            push(result, "")
        }
        if i >= n { break }
    }
    result
}

/// Serialize a row of fields back to a CSV line.
///
/// Fields that contain commas, double-quotes, or newlines are quoted.
pub fn csv_stringify_row(fields: Vec<String>) -> String {
    let n = len(fields)
    let mut result = ""
    let mut i = 0
    while i < n {
        if i > 0 { result = concat(result, ",") }
        let field = get_unchecked(fields, i)
        let needs_quote = contains(field, ",") || contains(field, "\"") || contains(field, "\n")
        if needs_quote {
            // Escape embedded double-quotes
            let escaped = replace(field, "\"", "\"\"")
            result = concat(result, concat("\"", concat(escaped, "\"")))
        } else {
            result = concat(result, field)
        }
        i = i + 1
    }
    result
}

// ─── Multi-row accessors ─────────────────────────────────────────────────────

/// Count the number of non-empty lines in a CSV string.
pub fn csv_count_rows(s: String) -> i32 {
    let lines = split(s, "\n")
    let n = len(lines)
    let mut count = 0
    let mut i = 0
    while i < n {
        let line = get_unchecked(lines, i)
        if len(line) > 0 {
            count = count + 1
        }
        i = i + 1
    }
    count
}

/// Return the raw text of row `row_index` (0-based, skipping empty lines).
pub fn csv_get_row_raw(s: String, row_index: i32) -> String {
    let lines = split(s, "\n")
    let n = len(lines)
    let mut current = 0
    let mut i = 0
    while i < n {
        let line = get_unchecked(lines, i)
        if len(line) > 0 {
            if current == row_index {
                return line
            }
            current = current + 1
        }
        i = i + 1
    }
    ""
}

/// Parse row `row_index` from a multi-row CSV string.
pub fn csv_parse_row_at(s: String, row_index: i32) -> Vec<String> {
    csv_parse_row(csv_get_row_raw(s, row_index))
}

/// Parse a CSV document with a header row.
///
/// Returns `(header_fields, rows)` — the first row becomes the header and
/// the remaining rows are returned as separate Vec<String> rows packed into
/// a flat Vec<String> with field_count-wide strides.
///
/// NOTE: the simple flat encoding means row `i` starts at
/// `header.len() * i` in the body vector.
pub fn csv_parse_with_header(s: String) -> Result<Vec<String>, String> {
    let lines = split(s, "\n")
    let n = len(lines)
    if n == 0 { return Err("empty document") }
    let first_line = get_unchecked(lines, 0)
    if len(first_line) == 0 { return Err("empty header") }
    // Return just the header fields for simplicity; callers can re-parse rows
    Ok(csv_parse_row(first_line))
}
