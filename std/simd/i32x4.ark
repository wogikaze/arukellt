//! i32x4 — 4 × 32-bit signed integer SIMD lane type.
//!
//! Each value is a v128 with 4 i32 lanes.
//! All APIs are experimental (ADR-014).

// --- Construct ---

/// Create a v128 with all 4 lanes set to the same i32 value.
pub fn splat(x: i32) -> v128 {
    __simd_i32x4_splat(x)
}

/// Create a v128 from 4 i32 lane values.
pub fn new(a: i32, b: i32, c: i32, d: i32) -> v128 {
    let v = splat(a)
    v = __simd_i32x4_replace_lane(v, 1, b)
    v = __simd_i32x4_replace_lane(v, 2, c)
    v = __simd_i32x4_replace_lane(v, 3, d)
    v
}

/// Create a v128 with all lanes zeroed.
pub fn zero() -> v128 {
    splat(0)
}

// --- Lane access ---

/// Extract a single i32 lane (0..3) from a v128.
pub fn extract_lane(v: v128, lane: i32) -> i32 {
    if lane == 0 { return __simd_i32x4_extract_lane(v, 0) }
    if lane == 1 { return __simd_i32x4_extract_lane(v, 1) }
    if lane == 2 { return __simd_i32x4_extract_lane(v, 2) }
    if lane == 3 { return __simd_i32x4_extract_lane(v, 3) }
    panic("i32x4::extract_lane: lane out of range")
    0
}

/// Replace a single i32 lane (0..3) in a v128, returning a new v128.
pub fn replace_lane(v: v128, lane: i32, x: i32) -> v128 {
    if lane == 0 { return __simd_i32x4_replace_lane(v, 0, x) }
    if lane == 1 { return __simd_i32x4_replace_lane(v, 1, x) }
    if lane == 2 { return __simd_i32x4_replace_lane(v, 2, x) }
    if lane == 3 { return __simd_i32x4_replace_lane(v, 3, x) }
    panic("i32x4::replace_lane: lane out of range")
    v
}

// --- Arithmetic ---

/// Lane-wise addition: a + b
pub fn add(a: v128, b: v128) -> v128 {
    __simd_i32x4_add(a, b)
}

/// Lane-wise subtraction: a - b
pub fn sub(a: v128, b: v128) -> v128 {
    __simd_i32x4_sub(a, b)
}

/// Lane-wise multiplication: a * b
pub fn mul(a: v128, b: v128) -> v128 {
    __simd_i32x4_mul(a, b)
}

/// Lane-wise negation: -a
pub fn neg(a: v128) -> v128 {
    __simd_i32x4_neg(a)
}

/// Lane-wise absolute value.
pub fn abs(a: v128) -> v128 {
    __simd_i32x4_abs(a)
}

// --- Comparison ---

/// Lane-wise equality. Each lane is all-1s if equal, all-0s otherwise.
pub fn eq(a: v128, b: v128) -> v128 {
    __simd_i32x4_eq(a, b)
}

/// Lane-wise inequality. Each lane is all-1s if not equal, all-0s otherwise.
pub fn ne(a: v128, b: v128) -> v128 {
    __simd_i32x4_ne(a, b)
}

/// Lane-wise less-than (signed). Each lane is all-1s if a < b, all-0s otherwise.
pub fn lt(a: v128, b: v128) -> v128 {
    __simd_i32x4_lt_s(a, b)
}

/// Lane-wise less-than-or-equal (signed).
pub fn le(a: v128, b: v128) -> v128 {
    __simd_i32x4_le_s(a, b)
}

/// Lane-wise greater-than (signed).
pub fn gt(a: v128, b: v128) -> v128 {
    __simd_i32x4_gt_s(a, b)
}

/// Lane-wise greater-than-or-equal (signed).
pub fn ge(a: v128, b: v128) -> v128 {
    __simd_i32x4_ge_s(a, b)
}

// --- Bitwise ---

/// Lane-wise bitwise AND.
pub fn and(a: v128, b: v128) -> v128 {
    __simd_v128_and(a, b)
}

/// Lane-wise bitwise OR.
pub fn or(a: v128, b: v128) -> v128 {
    __simd_v128_or(a, b)
}

/// Lane-wise bitwise XOR.
pub fn xor(a: v128, b: v128) -> v128 {
    __simd_v128_xor(a, b)
}

/// Lane-wise bitwise NOT.
pub fn not(a: v128) -> v128 {
    __simd_v128_not(a)
}

// --- Shift ---

/// Lane-wise left shift by a scalar shift amount.
pub fn shl(a: v128, shift: i32) -> v128 {
    __simd_i32x4_shl(a, shift)
}

/// Lane-wise right shift (signed / arithmetic).
pub fn shr_s(a: v128, shift: i32) -> v128 {
    __simd_i32x4_shr_s(a, shift)
}

/// Lane-wise right shift (unsigned / logical).
pub fn shr_u(a: v128, shift: i32) -> v128 {
    __simd_i32x4_shr_u(a, shift)
}

// --- Min / Max ---

/// Lane-wise minimum (signed).
pub fn min_s(a: v128, b: v128) -> v128 {
    __simd_i32x4_min_s(a, b)
}

/// Lane-wise maximum (signed).
pub fn max_s(a: v128, b: v128) -> v128 {
    __simd_i32x4_max_s(a, b)
}

/// Lane-wise minimum (unsigned).
pub fn min_u(a: v128, b: v128) -> v128 {
    __simd_i32x4_min_u(a, b)
}

/// Lane-wise maximum (unsigned).
pub fn max_u(a: v128, b: v128) -> v128 {
    __simd_i32x4_max_u(a, b)
}
