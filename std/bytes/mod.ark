                                                                                                                                                                                                                                                58
                                                                                                                                                                                                                                            } else {
                                                                                                                                                                                                                                                if eq(c, "7") {
                                                                                                                                                                                                                                                    59
                                                                                                                                                                                                                                                } else {
                                                                                                                                                                                                                                                    if eq(c, "8") {
                                                                                                                                                                                                                                                        60
                                                                                                                                                                                                                                                    } else {
                                                                                                                                                                                                                                                        if eq(c, "9") {
                                                                                                                                                                                                                                                            61
                                                                                                                                                                                                                                                        } else {
                                                                                                                                                                                                                                                            if eq(c, "+") {
                                                                                                                                                                                                                                                                62
                                                                                                                                                                                                                                                            } else {
                                                                                                                                                                                                                                                                if eq(c, "/") {
                                                                                                                                                                                                                                                                    63
                                                                                                                                                                                                                                                                } else {
                                                                                                                                                                                                                                                                    0 - 1
                                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                                }
                                                                                                                                                                                                                                            }
                                                                                                                                                                                                                                        }
                                                                                                                                                                                                                                    }
                                                                                                                                                                                                                                }
                                                                                                                                                                                                                            }
                                                                                                                                                                                                                        }
                                                                                                                                                                                                                    }
                                                                                                                                                                                                                }
                                                                                                                                                                                                            }
                                                                                                                                                                                                        }
                                                                                                                                                                                                    }
                                                                                                                                                                                                }
                                                                                                                                                                                            }
                                                                                                                                                                                        }
                                                                                                                                                                                    }
                                                                                                                                                                                }
                                                                                                                                                                            }
                                                                                                                                                                        }
                                                                                                                                                                    }
                                                                                                                                                                }
                                                                                                                                                            }
                                                                                                                                                        }
                                                                                                                                                    }
                                                                                                                                                }
                                                                                                                                            }
                                                                                                                                        }
                                                                                                                                    }
                                                                                                                                }
                                                                                                                            }
                                                                                                                        }
                                                                                                                    }
                                                                                                                }
                                                                                                            }
                                                                                                        }
                                                                                                    }
                                                                                                }
                                                                                            }
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

pub fn base64_encode(b: Vec<i32>) -> String {
    let mut result = ""
    let n = len(b)
    let mut i = 0
    while i < n {
        let b0 = get_unchecked(b, i) & 255
        let b1 = if i + 1 < n {
            get_unchecked(b, i + 1) & 255
        } else {
            0
        }
        let b2 = if i + 2 < n {
            get_unchecked(b, i + 2) & 255
        } else {
            0
        }
        let idx0 = b0 >> 2
        let idx1 = b0 & 3 << 4 | b1 >> 4
        let idx2 = b1 & 15 << 2 | b2 >> 6
        let idx3 = b2 & 63
        result = concat(result, base64_char(idx0))
        result = concat(result, base64_char(idx1))
        if i + 1 < n {
            result = concat(result, base64_char(idx2))
        } else {
            result = concat(result, "=")
        }
        if i + 2 < n {
            result = concat(result, base64_char(idx3))
        } else {
            result = concat(result, "=")
        }
        i = i + 3
    }
    result
}

pub fn base64_decode(s: String) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let n = len(s)
    let mut i = 0
    while i + 3 < n {
        let c0 = base64_val(slice(s, i, i + 1))
        let c1 = base64_val(slice(s, i + 1, i + 2))
        let c2 = base64_val(slice(s, i + 2, i + 3))
        let c3 = base64_val(slice(s, i + 3, i + 4))
        if c0 >= 0 {
            if c1 >= 0 {
                push(result, c0 << 2 | c1 >> 4)
                if c2 >= 0 {
                    push(result, c1 & 15 << 4 | c2 >> 2)
                    if c3 >= 0 {
                        push(result, c2 & 3 << 6 | c3)
                    }
                }
            }
        }
        i = i + 4
    }
    result
}

// ─── LEB128 decode ───────────────────────────────────────────────────────────
/// Decode an unsigned LEB128 u32 from a ByteCursor.
/// Returns 0 if the cursor is empty or the encoding is malformed/overlong.
/// Advances the cursor position by the number of bytes consumed.
pub fn leb128_decode_u32(c: Vec<i32>) -> i32 {
    let mut result = 0
    let mut shift = 0
    let mut done = false
    while done == false {
        if cursor_remaining(c) < 1 {
            done = true
        } else {
            let byte = read_u8(c)
            result = result | byte & 127 << shift
            shift = shift + 7
            if byte & 128 == 0 {
                done = true
            }
            if shift >= 35 {
                done = true
            }
        }
    }
    result
}

/// Decode a signed LEB128 i32 from a ByteCursor.
/// Advances the cursor position.
pub fn leb128_decode_i32(c: Vec<i32>) -> i32 {
    let mut result = 0
    let mut shift = 0
    let mut last_byte = 0
    let mut done = false
    while done == false {
        if cursor_remaining(c) < 1 {
            done = true
        } else {
            let byte = read_u8(c)
            last_byte = byte
            result = result | byte & 127 << shift
            shift = shift + 7
            if byte & 128 == 0 {
                done = true
            }
            if shift >= 35 {
                done = true
            }
        }
    }
    if shift < 32 {
        if last_byte & 64 != 0 {
            result = result | 0 - 1 << shift
        }
    }
    result
}

// ─── LEB128 u64 ──────────────────────────────────────────────────────────────
// NOTE: u64 is not a distinct type; i64 is used throughout.
pub fn leb128_encode_u64(x: i64) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let mut val: i64 = x
    let mut done: bool = false
    while done == false {
        let byte: i32 = i64_to_i32(val & i32_to_i64(127))
        val = val >> i32_to_i64(7)
        if val != i32_to_i64(0) {
            push(result, byte | 128)
        } else {
            push(result, byte)
            done = true
        }
    }
    result
}

/// Decode an unsigned LEB128 u64 from a ByteCursor.
/// Returns the decoded value as i64.
pub fn leb128_decode_u64(c: Vec<i32>) -> i64 {
    let mut result: i64 = i32_to_i64(0)
    let mut shift: i64 = i32_to_i64(0)
    let mut done: bool = false
    while done == false {
        if cursor_remaining(c) < 1 {
            done = true
        } else {
            let byte = read_u8(c)
            let chunk = i32_to_i64(byte & 127) << shift
            result = result | chunk
            shift = shift + i32_to_i64(7)
            if byte & 128 == 0 {
                done = true
            }
            if shift >= i32_to_i64(70) {
                done = true
            }
        }
    }
    result
}
