/// Binary data helpers built on `Vec<i32>`.
/// 
/// Each element is treated as a byte in the `0..=255` range.
/// 
/// # Type aliases (runtime representation)
/// 
/// - `Bytes`      = `Vec<i32>` (treated as immutable)
/// - `ByteBuf`    = `Vec<i32>` (mutable buffer)
/// - `ByteCursor` = `Vec<i32>` where index 0 is the cursor position and
/// indices 1..n hold the data bytes
/// 
/// # Limitations
/// 
/// u8/u16/u32/u64 are not first-class types in the current runtime.
/// All byte values are represented as i32 (masked to 0-255 on write).
/// 64-bit values use i64.
/// Vec<u8> is unavailable; Vec<i32> is used throughout.
// --- Byte buffer creation ---
pub fn bytes_new() -> Vec<i32> {
    let b: Vec<i32> = Vec_new_i32()
    b
}

/// Create a byte buffer from the raw bytes of a UTF-8 string.
pub fn bytes_from_string(s: String) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let n = len(s)
    let mut i = 0
    while i < n {
        let ch = slice(s, i, i + 1)
        push(result, char_at(s, i))
        i = i + 1
    }
    result
}

/// Interpret a byte buffer as a UTF-8 string (best-effort, one byte = one char).
pub fn string_from_bytes(b: Vec<i32>) -> String {
    let mut result = ""
    let n = len(b)
    let mut i = 0
    while i < n {
        let byte_val = get_unchecked(b, i) & 255
        result = concat(result, char_to_string(byte_val))
        i = i + 1
    }
    result
}

pub fn bytes_len(b: Vec<i32>) -> i32 {
    len(b)
}

pub fn bytes_get(b: Vec<i32>, index: i32) -> i32 {
    get_unchecked(b, index)
}

pub fn bytes_push(b: Vec<i32>, byte: i32) {
    push(b, byte & 255)
}

pub fn bytes_eq(a: Vec<i32>, b: Vec<i32>) -> bool {
    let al: i32 = len(a)
    let bl: i32 = len(b)
    if al != bl {
        false
    } else {
        let mut i: i32 = 0
        let mut same: bool = true
        while i < al {
            if get_unchecked(a, i) != get_unchecked(b, i) {
                same = false
            }
            i = i + 1
        }
        same
    }
}

/// Concatenate two byte buffers into a new one.
pub fn bytes_concat(a: Vec<i32>, b: Vec<i32>) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let an = len(a)
    let bn = len(b)
    let mut i = 0
    while i < an {
        push(result, get_unchecked(a, i))
        i = i + 1
    }
    i = 0
    while i < bn {
        push(result, get_unchecked(b, i))
        i = i + 1
    }
    result
}

/// Extract a sub-range of bytes as a new buffer.
pub fn bytes_slice(b: Vec<i32>, start: i32, end: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let mut i = start
    while i < end {
        push(result, get_unchecked(b, i))
        i = i + 1
    }
    result
}

pub fn byte_length(s: String) -> i32 {
    len(s)
}

// --- Hex encoding ---
pub fn hex_char(nibble: i32) -> String {
    if nibble < 10 {
        i32_to_string(nibble)
    } else {
        if nibble == 10 {
            "a"
        } else {
            if nibble == 11 {
                "b"
            } else {
                if nibble == 12 {
                    "c"
                } else {
                    if nibble == 13 {
                        "d"
                    } else {
                        if nibble == 14 {
                            "e"
                        } else {
                            "f"
                        }
                    }
                }
            }
        }
    }
}

pub fn hex_encode(b: Vec<i32>) -> String {
    let mut result: String = ""
    let mut i: i32 = 0
    let n: i32 = len(b)
    while i < n {
        let byte: i32 = get_unchecked(b, i) & 255
        let hi: i32 = byte >> 4
        let lo: i32 = byte & 15
        result = concat(result, concat(hex_char(hi), hex_char(lo)))
        i = i + 1
    }
    result
}

pub fn hex_val_char(ch: String) -> i32 {
    if eq(ch, "0") {
        0
    } else {
        if eq(ch, "1") {
            1
        } else {
            if eq(ch, "2") {
                2
            } else {
                if eq(ch, "3") {
                    3
                } else {
                    if eq(ch, "4") {
                        4
                    } else {
                        if eq(ch, "5") {
                            5
                        } else {
                            if eq(ch, "6") {
                                6
                            } else {
                                if eq(ch, "7") {
                                    7
                                } else {
                                    if eq(ch, "8") {
                                        8
                                    } else {
                                        if eq(ch, "9") {
                                            9
                                        } else {
                                            if eq(ch, "a") {
                                                10
                                            } else {
                                                if eq(ch, "b") {
                                                    11
                                                } else {
                                                    if eq(ch, "c") {
                                                        12
                                                    } else {
                                                        if eq(ch, "d") {
                                                            13
                                                        } else {
                                                            if eq(ch, "e") {
                                                                14
                                                            } else {
                                                                if eq(ch, "f") {
                                                                    15
                                                                } else {
                                                                    if eq(ch, "A") {
                                                                        10
                                                                    } else {
                                                                        if eq(ch, "B") {
                                                                            11
                                                                        } else {
                                                                            if eq(ch, "C") {
                                                                                12
                                                                            } else {
                                                                                if eq(ch, "D") {
                                                                                    13
                                                                                } else {
                                                                                    if eq(ch, "E") {
                                                                                        14
                                                                                    } else {
                                                                                        if eq(ch, "F") {
                                                                                            15
                                                                                        } else {
                                                                                            0 - 1
                                                                                        }
                                                                                    }
                                                                                }
                                                                            }
                                                                        }
                                                                    }
                                                                }
                                                            }
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

pub fn hex_decode(s: String) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let n: i32 = len(s)
    let mut i: i32 = 0
    while i + 1 < n {
        let hi_ch: String = slice(s, i, i + 1)
        let lo_ch: String = slice(s, i + 1, i + 2)
        let hi: i32 = hex_val_char(hi_ch)
        let lo: i32 = hex_val_char(lo_ch)
        if hi >= 0 {
            if lo >= 0 {
                push(result, hi * 16 + lo)
            }
        }
        i = i + 2
    }
    result
}

// --- LEB128 encoding ---
pub fn leb128_encode_u32(x: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let mut val: i32 = x
    let mut done: bool = false
    while done == false {
        let byte: i32 = val & 127
        val = val >> 7
        if val != 0 {
            push(result, byte | 128)
        } else {
            push(result, byte)
            done = true
        }
    }
    result
}

pub fn leb128_encode_i32(x: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let mut val: i32 = x
    let mut done: bool = false
    while done == false {
        let byte: i32 = val & 127
        val = val >> 7
        if val == 0 {
            if byte & 64 == 0 {
                push(result, byte)
                done = true
            } else {
                push(result, byte | 128)
                push(result, 0)
                done = true
            }
        } else {
            if val == 0 - 1 {
                if byte & 64 != 0 {
                    push(result, byte)
                    done = true
                } else {
                    push(result, byte | 128)
                    push(result, 127)
                    done = true
                }
            } else {
                push(result, byte | 128)
            }
        }
    }
    result
}

// --- Endian utilities ---
pub fn u16_to_le_bytes(x: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    push(result, x & 255)
    push(result, x >> 8 & 255)
    result
}

pub fn u16_from_le_bytes(b: Vec<i32>) -> i32 {
    let lo: i32 = get_unchecked(b, 0) & 255
    let hi: i32 = get_unchecked(b, 1) & 255
    lo + hi * 256
}

pub fn u32_to_le_bytes(x: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    push(result, x & 255)
    push(result, x >> 8 & 255)
    push(result, x >> 16 & 255)
    push(result, x >> 24 & 255)
    result
}

pub fn u32_from_le_bytes(b: Vec<i32>) -> i32 {
    let b0: i32 = get_unchecked(b, 0) & 255
    let b1: i32 = get_unchecked(b, 1) & 255
    let b2: i32 = get_unchecked(b, 2) & 255
    let b3: i32 = get_unchecked(b, 3) & 255
    b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
}

pub fn u32_to_be_bytes(x: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    push(result, x >> 24 & 255)
    push(result, x >> 16 & 255)
    push(result, x >> 8 & 255)
    push(result, x & 255)
    result
}

pub fn u32_from_be_bytes(b: Vec<i32>) -> i32 {
    let b0: i32 = get_unchecked(b, 0) & 255
    let b1: i32 = get_unchecked(b, 1) & 255
    let b2: i32 = get_unchecked(b, 2) & 255
    let b3: i32 = get_unchecked(b, 3) & 255
    b0 * 16777216 + b1 * 65536 + b2 * 256 + b3
}

// ─── bytes_from_array ───────────────────────────────────────────────────────
// NOTE: Vec<u8> is not a distinct type in the current runtime; xs is Vec<i32>
// with byte values in 0..=255.
pub fn bytes_from_array(xs: Vec<i32>) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    let n = len(xs)
    let mut i = 0
    while i < n {
        push(result, get_unchecked(xs, i) & 255)
        i = i + 1
    }
    result
}

// ─── ByteBuf ─────────────────────────────────────────────────────────────────
// ByteBuf is represented as Vec<i32> (mutable accumulator for byte output).
pub fn buf_new() -> Vec<i32> {
    Vec_new_i32()
}

/// Allocate a ByteBuf with a preallocated capacity hint.
/// Capacity is advisory only; the current runtime does not expose
/// Vec::with_capacity, so this behaves identically to buf_new().
pub fn buf_with_capacity(cap: i32) -> Vec<i32> {
    Vec_new_i32()
}

pub fn buf_push_u8(buf: Vec<i32>, x: i32) {
    push(buf, x & 255)
}

pub fn buf_push_u16_le(buf: Vec<i32>, x: i32) {
    push(buf, x & 255)
    push(buf, x >> 8 & 255)
}

pub fn buf_push_u32_le(buf: Vec<i32>, x: i32) {
    push(buf, x & 255)
    push(buf, x >> 8 & 255)
    push(buf, x >> 16 & 255)
    push(buf, x >> 24 & 255)
}

/// Push a 64-bit little-endian value.
/// x is passed as i64; bytes are extracted with 8-bit masks.
pub fn buf_push_u64_le(buf: Vec<i32>, x: i64) {
    let mask: i64 = i32_to_i64(255)
    push(buf, i64_to_i32(x & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(8) & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(16) & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(24) & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(32) & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(40) & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(48) & mask))
    push(buf, i64_to_i32(x >> i32_to_i64(56) & mask))
}

pub fn buf_extend(buf: Vec<i32>, bytes: Vec<i32>) {
    let n = len(bytes)
    let mut i = 0
    while i < n {
        push(buf, get_unchecked(bytes, i))
        i = i + 1
    }
}

/// Freeze a ByteBuf into an immutable Bytes value.
/// In the current runtime both types are Vec<i32>, so this is identity.
pub fn buf_freeze(buf: Vec<i32>) -> Vec<i32> {
    buf
}

pub fn buf_len(buf: Vec<i32>) -> i32 {
    len(buf)
}

// ─── ByteCursor ──────────────────────────────────────────────────────────────
// Layout: c[0] = current position (i32), c[1..] = data bytes (i32 each).
// Cursor reads advance the position stored at index 0 via `set`.
pub fn cursor_new(data: Vec<i32>) -> Vec<i32> {
    let c: Vec<i32> = Vec_new_i32()
    push(c, 0)
    let n = len(data)
    let mut i = 0
    while i < n {
        push(c, get_unchecked(data, i))
        i = i + 1
    }
    c
}

pub fn cursor_pos(c: Vec<i32>) -> i32 {
    get_unchecked(c, 0)
}

pub fn cursor_remaining(c: Vec<i32>) -> i32 {
    len(c) - 1 - get_unchecked(c, 0)
}

/// Read one byte from the cursor and advance its position.
/// Returns -1 if no bytes remain (error sentinel).
pub fn read_u8(c: Vec<i32>) -> i32 {
    let pos = get_unchecked(c, 0)
    if cursor_remaining(c) < 1 {
        0 - 1
    } else {
        let byte = get_unchecked(c, pos + 1)
        set(c, 0, pos + 1)
        byte
    }
}

/// Read two bytes little-endian from the cursor.
/// Returns -1 if fewer than 2 bytes remain.
pub fn read_u16_le(c: Vec<i32>) -> i32 {
    if cursor_remaining(c) < 2 {
        0 - 1
    } else {
        let b0 = read_u8(c) & 255
        let b1 = read_u8(c) & 255
        b0 + b1 * 256
    }
}

/// Read four bytes little-endian from the cursor.
/// Returns -1 if fewer than 4 bytes remain.
pub fn read_u32_le(c: Vec<i32>) -> i32 {
    if cursor_remaining(c) < 4 {
        0 - 1
    } else {
        let b0 = read_u8(c) & 255
        let b1 = read_u8(c) & 255
        let b2 = read_u8(c) & 255
        let b3 = read_u8(c) & 255
        b0 + b1 * 256 + b2 * 65536 + b3 * 16777216
    }
}

/// Read eight bytes little-endian from the cursor as i64.
/// Returns -1 (as i64) if fewer than 8 bytes remain.
pub fn read_u64_le(c: Vec<i32>) -> i64 {
    if cursor_remaining(c) < 8 {
        i32_to_i64(0) - i32_to_i64(1)
    } else {
        let b0 = i32_to_i64(read_u8(c) & 255)
        let b1 = i32_to_i64(read_u8(c) & 255)
        let b2 = i32_to_i64(read_u8(c) & 255)
        let b3 = i32_to_i64(read_u8(c) & 255)
        let b4 = i32_to_i64(read_u8(c) & 255)
        let b5 = i32_to_i64(read_u8(c) & 255)
        let b6 = i32_to_i64(read_u8(c) & 255)
        let b7 = i32_to_i64(read_u8(c) & 255)
        let k256: i64 = i32_to_i64(256)
        let k65536: i64 = i32_to_i64(65536)
        let k16m: i64 = i32_to_i64(16777216)
        let k32: i64 = k65536 * k65536
        let k40: i64 = k32 * k256
        let k48: i64 = k32 * k65536
        let k56: i64 = k48 * k256
        b0 + b1 * k256 + b2 * k65536 + b3 * k16m + b4 * k32 + b5 * k40 + b6 * k48 + b7 * k56
    }
}

/// Read four bytes big-endian from the cursor.
/// Returns -1 if fewer than 4 bytes remain.
pub fn read_u32_be(c: Vec<i32>) -> i32 {
    if cursor_remaining(c) < 4 {
        0 - 1
    } else {
        let b0 = read_u8(c) & 255
        let b1 = read_u8(c) & 255
        let b2 = read_u8(c) & 255
        let b3 = read_u8(c) & 255
        b0 * 16777216 + b1 * 65536 + b2 * 256 + b3
    }
}

/// Read n bytes from the cursor into a new byte buffer.
/// Returns an empty buffer if fewer than n bytes remain.
pub fn read_bytes(c: Vec<i32>, n: i32) -> Vec<i32> {
    let result: Vec<i32> = Vec_new_i32()
    if cursor_remaining(c) < n {
        result
    } else {
        let mut i = 0
        while i < n {
            push(result, read_u8(c))
            i = i + 1
        }
        result
    }
}

// ─── Base64 encoding ─────────────────────────────────────────────────────────
fn base64_alphabet() -> String {
    "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789+/"
}

fn base64_char(idx: i32) -> String {
    let alpha = base64_alphabet()
    slice(alpha, idx, idx + 1)
}

fn base64_val(ch: String) -> i32 {
    let c = slice(ch, 0, 1)
    if eq(c, "A") {
        0
    } else {
        if eq(c, "B") {
            1
        } else {
            if eq(c, "C") {
                2
            } else {
                if eq(c, "D") {
                    3
                } else {
                    if eq(c, "E") {
                        4
                    } else {
                        if eq(c, "F") {
                            5
                        } else {
                            if eq(c, "G") {
                                6
                            } else {
                                if eq(c, "H") {
                                    7
                                } else {
                                    if eq(c, "I") {
                                        8
                                    } else {
                                        if eq(c, "J") {
                                            9
                                        } else {
                                            if eq(c, "K") {
                                                10
                                            } else {
                                                if eq(c, "L") {
                                                    11
                                                } else {
                                                    if eq(c, "M") {
                                                        12
                                                    } else {
                                                        if eq(c, "N") {
                                                            13
                                                        } else {
                                                            if eq(c, "O") {
                                                                14
                                                            } else {
                                                                if eq(c, "P") {
                                                                    15
                                                                } else {
                                                                    if eq(c, "Q") {
                                                                        16
                                                                    } else {
                                                                        if eq(c, "R") {
                                                                            17
                                                                        } else {
                                                                            if eq(c, "S") {
                                                                                18
                                                                            } else {
                                                                                if eq(c, "T") {
                                                                                    19
                                                                                } else {
                                                                                    if eq(c, "U") {
                                                                                        20
                                                                                    } else {
                                                                                        if eq(c, "V") {
                                                                                            21
                                                                                        } else {
                                                                                            if eq(c, "W") {
                                                                                                22
                                                                                            } else {
                                                                                                if eq(c, "X") {
                                                                                                    23
                                                                                                } else {
                                                                                                    if eq(c, "Y") {
                                                                                                        24
                                                                                                    } else {
                                                                                                        if eq(c, "Z") {
                                                                                                            25
                                                                                                        } else {
                                                                                                            if eq(c, "a") {
                                                                                                                26
                                                                                                            } else {
                                                                                                                if eq(c, "b") {
                                                                                                                    27
                                                                                                                } else {
                                                                                                                    if eq(c, "c") {
                                                                                                                        28
                                                                                                                    } else {
                                                                                                                        if eq(c, "d") {
                                                                                                                            29
                                                                                                                        } else {
                                                                                                                            if eq(c, "e") {
                                                                                                                                30
                                                                                                                            } else {
                                                                                                                                if eq(c, "f") {
                                                                                                                                    31
                                                                                                                                } else {
                                                                                                                                    if eq(c, "g") {
                                                                                                                                        32
                                                                                                                                    } else {
                                                                                                                                        if eq(c, "h") {
                                                                                                                                            33
                                                                                                                                        } else {
                                                                                                                                            if eq(c, "i") {
                                                                                                                                                34
                                                                                                                                            } else {
                                                                                                                                                if eq(c, "j") {
                                                                                                                                                    35
                                                                                                                                                } else {
                                                                                                                                                    if eq(c, "k") {
                                                                                                                                                        36
                                                                                                                                                    } else {
                                                                                                                                                        if eq(c, "l") {
                                                                                                                                                            37
                                                                                                                                                        } else {
                                                                                                                                                            if eq(c, "m") {
                                                                                                                                                                38
                                                                                                                                                            } else {
                                                                                                                                                                if eq(c, "n") {
                                                                                                                                                                    39
                                                                                                                                                                } else {
