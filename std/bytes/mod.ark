                                                                                                                                                                                42
                                                                                                                                                                            } else {
                                                                                                                                                                                if eq(c, "r") {
                                                                                                                                                                                    43
                                                                                                                                                                                } else {
                                                                                                                                                                                    if eq(c, "s") {
                                                                                                                                                                                        44
                                                                                                                                                                                    } else {
                                                                                                                                                                                        if eq(c, "t") {
                                                                                                                                                                                            45
                                                                                                                                                                                        } else {
