// Math
pub fn sqrt(x: f64) -> f64 {
    __intrinsic_sqrt(x)
}

pub fn abs(x: i32) -> i32 {
    if x < 0 { 0 - x } else { x }
}

pub fn min(a: i32, b: i32) -> i32 {
    if a < b { a } else { b }
}

pub fn max(a: i32, b: i32) -> i32 {
    if a > b { a } else { b }
}

// Math: clamp (i32)
pub fn clamp_i32(x: i32, lo: i32, hi: i32) -> i32 {
    if x < lo { lo } else if x > hi { hi } else { x }
}

