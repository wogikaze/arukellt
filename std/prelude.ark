fn __core_math_abs_impl(x: i32) -> i32 {
    if x < 0 {
        0 - x
    } else {
        x
    }
}

pub fn abs(x: i32) -> i32 {
    __core_math_abs_impl(x)
}

fn __core_math_min_impl(a: i32, b: i32) -> i32 {
    if a < b {
        a
    } else {
        b
    }
}

pub fn min(a: i32, b: i32) -> i32 {
    __core_math_min_impl(a, b)
}

fn __core_math_max_impl(a: i32, b: i32) -> i32 {
    if a > b {
        a
    } else {
        b
    }
}

pub fn max(a: i32, b: i32) -> i32 {
    __core_math_max_impl(a, b)
}

// Math: clamp (i32)
fn __core_math_clamp_impl(x: i32, lo: i32, hi: i32) -> i32 {
    if x < lo {
        lo
    } else if x > hi {
        hi
    } else {
        x
    }
}

pub fn clamp_i32(x: i32, lo: i32, hi: i32) -> i32 {
    __core_math_clamp_impl(x, lo, hi)
}

// Control
pub fn panic(s: String) {
    panic(String_new())
}

