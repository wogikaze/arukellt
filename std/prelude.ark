// Math
// Deprecated prelude free function pow_i32 has been removed per ADR-036.
// Use inherent method `base.pow(exp)` instead.

fn __core_math_gcd_impl(a: i32, b: i32) -> i32 {
    let mut x = a
    let mut y = b
    if x < 0 {
        x = 0 - x
    }
    if y < 0 {
        y = 0 - y
    }
    while y != 0 {
        let next = y
        y = x - x / y * y
        x = next
    }
    x
}

fn __core_math_pow_i32_impl(base: i32, exponent: i32) -> i32 {
    let mut result = 1
    let mut index = 0
    while index < exponent {
        result = result * base
        index = index + 1
    }
    result
}

pub fn gcd(a: i32, b: i32) -> i32 {
    __core_math_gcd_impl(a, b)
}

