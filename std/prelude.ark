// Vec sorting (deprecated)
// @deprecated: use `v.sort()` (Vec method, #697) instead. See ADR-036.
fn __core_seq_sort_i32_impl(v: Vec<i32>) {
    let mut index = 1
    while index < len(v) {
        let value = get_unchecked(v, index)
        let mut insertion = index
        while insertion > 0 && get_unchecked(v, insertion - 1) > value {
            set(v, insertion, get_unchecked(v, insertion - 1))
            insertion = insertion - 1
        }
        set(v, insertion, value)
        index = index + 1
    }
}

pub fn sort_i32(v: Vec<i32>) {
    __core_seq_sort_i32_impl(v)
}

pub fn sort_String(v: Vec<String>) {
    panic(String_new())
}

