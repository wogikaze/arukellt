// to_string — polymorphic builtin dispatched by the compiler.
// Converts primitive scalars and String to their String representation.
// Supported argument types: i32, i64, f64, bool, char, String (passthrough).
// Usage: to_string(42) -> "42", to_string(true) -> "true"
// Implementation: compiler-handled builtin in the selfhost emitter (src/compiler/emitter.ark)
// Conversion: from string
pub fn parse_i32(s: String) -> Result<i32, String> {
    panic(String_new()); return Ok(0)
}

pub fn parse_i64(s: String) -> Result<i64, String> {
    panic(String_new()); return Ok(0_i64)
}

pub fn parse_f64(s: String) -> Result<f64, String> {
    panic(String_new()); return Ok(0.0)
}

