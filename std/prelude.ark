fn __core_vec_contains_i32_impl(v: Vec<i32>, x: i32) -> bool {
    let mut i: i32 = 0
    while i < len(v) {
        if get_unchecked(v, i) == x {
            return true
        }
        i = i + 1
    }
    false
}

pub fn contains_i32(v: Vec<i32>, x: i32) -> bool {
    __core_vec_contains_i32_impl(v, x)
}

pub fn contains_String(v: Vec<String>, x: String) -> bool {
    let mut i: i32 = 0
    while i < len(v) {
        if eq(get_unchecked(v, i), x) {
            return true
        }
        i = i + 1
    }
    false
}

fn __core_vec_reverse_i32_impl(v: Vec<i32>) {
    let n: i32 = len(v)
    let mut lo: i32 = 0
    let mut hi: i32 = n - 1
    while lo < hi {
        let tmp: i32 = get_unchecked(v, lo)
        set(v, lo, get_unchecked(v, hi))
        set(v, hi, tmp)
        lo = lo + 1
        hi = hi - 1
    }
}

pub fn reverse_i32(v: Vec<i32>) {
    __core_vec_reverse_i32_impl(v)
}

fn __core_vec_reverse_string_impl(v: Vec<String>) {
    let n: i32 = len(v)
    let mut lo: i32 = 0
    let mut hi: i32 = n - 1
    while lo < hi {
        let tmp: String = get_unchecked(v, lo)
        set(v, lo, get_unchecked(v, hi))
        set(v, hi, tmp)
        lo = lo + 1
        hi = hi - 1
    }
}

pub fn reverse_String(v: Vec<String>) {
    __core_vec_reverse_string_impl(v)
}

pub fn remove_i32(v: Vec<i32>, index: i32) {
    let n: i32 = len(v)
    let mut i: i32 = index
    while i < n - 1 {
        set(v, i, get_unchecked(v, i + 1))
        i = i + 1
    }
    pop(v)
}

// Vec aggregation (Ark-native)
fn __core_seq_sum_i32_impl(v: Vec<i32>) -> i32 {
    let mut total: i32 = 0
    let mut i: i32 = 0
    while i < len(v) {
        total = total + get_unchecked(v, i)
        i = i + 1
    }
    total
}

pub fn sum_i32(v: Vec<i32>) -> i32 {
    __core_seq_sum_i32_impl(v)
}

fn __core_seq_product_i32_impl(v: Vec<i32>) -> i32 {
    let mut total: i32 = 1
    let mut i: i32 = 0
    while i < len(v) {
        total = total * get_unchecked(v, i)
        i = i + 1
    }
    total
}

pub fn product_i32(v: Vec<i32>) -> i32 {
    __core_seq_product_i32_impl(v)
}

