// Assertions
pub fn assert(cond: bool) {
    if !cond { panic(String_from("assertion failed")); }
}

pub fn assert_eq(a: i32, b: i32) {
    if a != b { panic(String_from("assertion failed")); }
}

pub fn assert_ne(a: i32, b: i32) {
    if a == b { panic(String_from("assertion failed")); }
}

pub fn assert_eq_i64(a: i64, b: i64) {
    if a != b { panic(String_from("assertion failed")); }
}

pub fn assert_eq_str(a: String, b: String) {
    if !eq(a, b) { panic(String_from("assertion failed")); }
}

