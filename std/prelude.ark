// Vec sorting (Ark-native bubble sort)
pub fn sort_i32(v: Vec<i32>) {
    let n: i32 = len(v)
    let mut i: i32 = 0
    while i < n - 1 {
        let mut j: i32 = 0
        while j < n - i - 1 {
            if get_unchecked(v, j) > get_unchecked(v, j + 1) {
                let tmp: i32 = get_unchecked(v, j)
                set(v, j, get_unchecked(v, j + 1))
                set(v, j + 1, tmp)
            }
            j = j + 1
        }
        i = i + 1
    }
}

pub fn sort_String(v: Vec<String>) {
    __intrinsic_sort_String(v);
}

