//! Resource handle table for Component Model boundaries (#044, #473).
//!
//! `HandleTable<T>` is monomorphized per payload type. The i32 table uses
//! SlotMap layout from `std::collections::compiler`.

use std::collections::compiler

pub struct HandleTableI32 {
    slots: Vec<i32>,
}

pub fn handle_table_i32_new() -> HandleTableI32 {
    HandleTableI32 { slots: compiler::slotmap_new() }
}

pub fn handle_table_i32_new_handle(table: HandleTableI32, value: i32) -> i32 {
    compiler::slotmap_insert(table.slots, value)
}

pub fn handle_table_i32_get(table: HandleTableI32, handle: i32) -> Option<i32> {
    compiler::slotmap_get(table.slots, handle)
}

pub fn handle_table_i32_drop(table: HandleTableI32, handle: i32) -> Option<i32> {
    compiler::slotmap_remove(table.slots, handle)
}

pub fn handle_table_i32_len(table: HandleTableI32) -> i32 {
    compiler::slotmap_len(table.slots)
}

/// Create an empty handle table (SlotMap-backed storage) for `i32` payloads.
pub fn handle_table_new() -> Vec<i32> {
    compiler::slotmap_new()
}

/// Insert `value` and return a stable handle index.
pub fn handle_new(table: Vec<i32>, value: i32) -> i32 {
    compiler::slotmap_insert(table, value)
}

/// Look up a live handle without removing it.
pub fn handle_get(table: Vec<i32>, handle: i32) -> Option<i32> {
    compiler::slotmap_get(table, handle)
}

/// Drop a handle and return its value, if still live.
pub fn handle_drop(table: Vec<i32>, handle: i32) -> Option<i32> {
    compiler::slotmap_remove(table, handle)
}

/// Return the number of live handles in the table.
pub fn handle_len(table: Vec<i32>) -> i32 {
    compiler::slotmap_len(table)
}
