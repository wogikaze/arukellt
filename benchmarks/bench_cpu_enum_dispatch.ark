use std::host::stdio

enum Shape {
    Circle {
        radius: i32,
    },
    Square {
        side: i32,
    },
    Triangle {
        base: i32,
        height: i32,
    },
}

fn area(s: Shape) -> i32 {
    match s {
        Shape::Circle { radius } => radius * radius * 3,
        Shape::Square { side } => side * side,
        Shape::Triangle { base, height } => base * height / 2,
    }
}

fn main() {
    let mut sum: i32 = 0
    let mut i: i32 = 0
    while i < 100000 {
        let kind: i32 = i - i / 3 * 3
        let result: i32 = if kind == 0 {
            area(Shape::Circle { radius: 5 })
        } else {
            if kind == 1 {
                area(Shape::Square { side: 4 })
            } else {
                area(Shape::Triangle { base: 6, height: 8 })
            }
        }
        sum = sum + result
        i = i + 1
    }
    stdio::println(i32_to_string(sum))
}
