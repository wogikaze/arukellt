use std::host::stdio

fn main() {
    let mut v: Vec<i32> = Vec_new_i32()
    let mut i: i32 = 0
    while i < 100000 {
        push(v, i)
        i = i + 1
    }
    let count: i32 = len(v)
    stdio::println((count).to_string())
    let mut j: i32 = 0
    while j < 100000 {
        let _popped: Option<i32> = pop(v)
        j = j + 1
    }
    stdio::println((len(v)).to_string())
}
