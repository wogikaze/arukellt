// file_read.ark — File I/O heavy benchmark (ADR-002 fixture).
// Writes a file once, then reads it many times to stress the host fs
// path and string construction.
use std::host::fs
use std::host::stdio

fn main() {
    let path = "arukellt_bench_file_read.txt"
    let payload = "abcdefghijklmnopqrstuvwxyz0123456789ABCDEFGHIJ\n"
    let mut data = String_from("")
    let mut i: i32 = 0
    while i < 200 {
        data = concat(data, payload)
        i = i + 1
    }

    let write_result = fs::write_string(path, clone(data))
    match write_result {
        Result::Ok(_) => {},
        Result::Err(e) => {
            stdio::println(concat("write error: ", e))
            return
        },
    }

    let mut checksum: i32 = 0
    let mut iter: i32 = 0
    while iter < 50 {
        let read_result = fs::read_to_string(path)
        match read_result {
            Result::Ok(contents) => {
                checksum = checksum + len(contents)
            },
            Result::Err(e) => {
                stdio::println(concat("read error: ", e))
                return
            },
        }
        iter = iter + 1
    }

    stdio::println((checksum).to_string())
}
