// Stdlib benchmark: hash map insert/get with string keys and i32 values.
// Exercises std::collections::hash hashmap_str_* and hashmap_str_str_*
// hot paths: insert, get, contains, remove, plus hash_i32/str_hash.
use std::collections::hash
use std::host::stdio

fn main() {
    let m = hash::hashmap_new()
    let mut checksum: i32 = 0
    let mut i: i32 = 0

    // Insert 100 entries
    while i < 100 {
        let key = concat("key_", i32_to_string(i))
        let val = concat("val_", i32_to_string(i))
        let prev = hash::hashmap_str_str_set(m, key, 1)
        if prev {
            checksum = checksum + 1000
        } else {
            checksum = checksum + 1
        }
        i = i + 1
    }

    // Get each entry
    i = 0
    while i < 100 {
        let key = concat("key_", i32_to_string(i))
        match hash::hashmap_str_str_get(m, key) {
            Option::Some(v) => checksum = checksum + len(v),
            None => checksum = checksum + 10000,
        }
        i = i + 1
    }

    // Check containment
    i = 0
    while i < 100 {
        let key = concat("key_", i32_to_string(i))
        if hash::hashmap_str_str_contains(m, key) {
            checksum = checksum + 1
        }
        i = i + 1
    }

    // Remove every other entry
    i = 0
    while i < 100 {
        let key = concat("key_", i32_to_string(i))
        match hash::hashmap_str_str_remove(m, key) {
            Option::Some(_) => checksum = checksum + 2,
            None => checksum = checksum + 20000,
        }
        i = i + 2
    }

    // Check size
    checksum = checksum + hash::hashmap_str_str_len(m)

    stdio::println(i32_to_string(checksum))
}
