暗黙的ヘッダ取り込みを排除した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"v2vfU","x":100,"y":17780,"name":"L1-1::Group 26 :: Group 1 :: Group 23 :: Group 123 :: Sticky Note dr12:49","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CGswq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは隠れたヒープ確保を避けるためAllocatorの明示受け渡しを要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"y0HDd","x":384,"y":17780,"name":"L1-1::Group 26 :: Group 1 :: Group 23 :: Group 123 :: Sticky Note dr14:41","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"knP5q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ZigはAllocator明示受け渡しで動的メモリ利用点を可視化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ijVMO","x":668,"y":17780,"name":"L1-1::Group 26 :: Group 1 :: Group 29 :: Group 48 :: Sticky Note dr14:38","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WM4dU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは隠れた制御フローと隠れたメモリ割り当てを許容しない方針を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"2nWrG","x":952,"y":17780,"name":"L1-1::Group 26 :: Group 1 :: Group 29 :: Group 48 :: Sticky Note dr15:52","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HGJDK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zig は error set と !T エラーユニオンで隠れた制御フローを排した設計を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"odbeB","x":100,"y":17980,"name":"L1-1::Group 26 :: Group 1 :: Lone 178 :: Lone 200 :: Sticky Note dr2:57","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cjwNj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはアロケータを引数で明示的に渡して確保責務をAPIに露出させる設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zopBC","x":384,"y":17980,"name":"L1-1::Group 26 :: Group 1 :: Lone 248 :: Lone 285 :: Sticky Note dr4:30","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VsjU1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはno hidden control flowとno hidden allocationsを明示原則に置く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"JvDx8","x":952,"y":18780,"name":"L1-1::Group 45 :: Group 1 :: Group 100 :: Group 111 :: Sticky Note dr6:40","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HAh6i","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの`comptime`は特殊マクロ構文を増やさず通常コードでコンパイル時計算を行う方針を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QG01n","x":668,"y":18780,"name":"L1-1::Group 45 :: Group 1 :: Group 100 :: Group 111 :: Sticky Note dr16:25","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"twRRI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはcomptimeでコンパイル時評価を統一し、別系統のマクロ言語を持たない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TSkdX","x":100,"y":18980,"name":"L1-1::Group 45 :: Group 1 :: Lone 350 :: Lone 395 :: Sticky Note dr6:41","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"evZxI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのコンパイル時リフレクションはランタイム負荷を増やさず表現力を得るがビルド時間設計の規律を要する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"P10Cy","x":384,"y":18980,"name":"L1-1::Group 45 :: Group 1 :: Lone 379 :: Lone 429 :: Sticky Note dr11:30","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nE76C","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの ?T はC互換メモリ表現を保ちながらコンパイル時アンラップ強制で安全性を確保する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KBufC","x":668,"y":18980,"name":"L1-1::Group 45 :: Group 1 :: Lone 620 :: Lone 684 :: Sticky Note dr16:75","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nIjDt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは@typeInfoと@TypeOfをcomptimeで処理し、実行時RTTI依存を避ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"s2jNZ","x":668,"y":17980,"name":"L1-1::Group 56 :: Group 1 :: Group 14 :: Group 10 :: Sticky Note dr2:17","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"likHK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのZGCはテラバイト級ヒープでも1ms未満ポーズを狙う低レイテンシ設計を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pkOvM","x":952,"y":17980,"name":"L1-1::Group 56 :: Group 1 :: Lone 158 :: Lone 174 :: Sticky Note dr2:18","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kUE5M","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのZGCはカラー付きポインタとロードバリアで多くの処理をアプリ実行と並行化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vnxPq","x":100,"y":18180,"name":"L1-1::Group 56 :: Group 1 :: Lone 159 :: Lone 175 :: Sticky Note dr2:19","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CV4px","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのZGCは短ポーズと高スケーラビリティを実現したがバリア常時実行コストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"afsGu","x":384,"y":18180,"name":"L1-1::Group 56 :: Group 1 :: Lone 403 :: Lone 453 :: Sticky Note dr12:6","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NoryC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ZGCはColored PointersとLoad Barriersで大規模ヒープでも超低ポーズを狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"WPvaA","x":952,"y":19380,"name":"L1-1::Group 59 :: Group 1 :: Group 29 :: Group 48 :: Sticky Note dr16:26","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zpjxX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの設計は可読性と追跡可能性を優先し、隠れた制御フローを避ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Z8uq3","x":384,"y":19580,"name":"L1-1::Group 59 :: Group 1 :: Group 91 :: Group 100 :: Sticky Note dr5:32","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6j2rW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのunreachableは到達不能前提を最適化と診断に利用させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ADl5s","x":100,"y":19580,"name":"L1-1::Group 59 :: Group 1 :: Group 91 :: Group 100 :: Sticky Note dr15:54","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Uqjrn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zig の unreachable は Debug では安全停止を促し ReleaseFast では誤用時 UB を招く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"bMyTs","x":384,"y":19980,"name":"L1-1::Group 61 :: Group 1 :: Group 37 :: Group 31 :: Sticky Note dr2:80","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bGwH9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaはZGCやShenandoahで低ポーズ化を進め適用可能領域を広げたがハードリアルタイム保証は難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"lfogG","x":952,"y":19580,"name":"L1-1::Group 104 :: Group 1 :: Group 20 :: Lone 479 :: Sticky Note dr12:52","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uqxzN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのdeferは手動管理でも解放忘れを減らす実務的手段である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"3F3m4","x":100,"y":19780,"name":"L1-1::Group 104 :: Group 1 :: Group 23 :: Lone 488 :: Sticky Note dr12:62","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gEMzR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのstd.heap.ArenaAllocatorは木構造などの一括解放に向く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"nVKtl","x":384,"y":19780,"name":"L1-1::Group 104 :: Group 1 :: Lone 187 :: Lone 209 :: Sticky Note dr2:67","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uB5Bn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのアリーナアロケータは早期returnが多い処理でfree漏れ低減に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1J65M","x":668,"y":19380,"name":"L1-1::Group 129 :: Group 1 :: Lone 188 :: Lone 210 :: Sticky Note dr2:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mEzQi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのアリーナは長寿命データを入れると実質リーク化しやすく運用設計が重要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"gYt7L","x":952,"y":18580,"name":"L1-1::Group 135 :: Group 1 :: Lone 284 :: Lone 326 :: Sticky Note dr4:87","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EsPtB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはbuild.zigでビルド記述を言語内に統合し外部ツール依存を減らした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"VDqsF","x":100,"y":18780,"name":"L1-1::Group 135 :: Group 1 :: Lone 285 :: Lone 327 :: Sticky Note dr4:88","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LU1Ud","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの内蔵ビルドは一貫体験を与えるがビルド学習対象を追加する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"NfJhq","x":384,"y":18780,"name":"L1-1::Group 135 :: Group 1 :: Lone 621 :: Lone 685 :: Sticky Note dr16:76","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pqKrz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの型内省はinline forと組み合わせてゼロオーバーヘッド生成を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QamYm","x":952,"y":19780,"name":"L1-1::Group 203 :: Group 1 :: Lone 179 :: Lone 201 :: Sticky Note dr2:58","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"S4ZRg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは確保地点の可視性を高める代わりに呼び出し側ボイラープレートを増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"gUglD","x":100,"y":19980,"name":"L1-1::Group 203 :: Group 1 :: Lone 514 :: Lone 573 :: Sticky Note dr14:39","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qq6e5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigでは明示された関数呼び出し以外の副次的呼び出しが発生しない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"np72i","x":668,"y":19780,"name":"L1-1::Lone 274 :: Group 1 :: Lone 146 :: Lone 161 :: Sticky Note dr1:65","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5JYhc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CeylonとZigの流れはHoareの反省と先行言語の成功事例に影響されている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pz78g","x":668,"y":18580,"name":"L1-1::Lone 312 :: Group 1 :: Lone 405 :: Lone 455 :: Sticky Note dr12:8","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D7D9L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 21のZGCはGenerationalモードで世代仮説の利点を取り込んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"DY8XQ","x":668,"y":19580,"name":"L1-1::Lone 339 :: Group 1 :: Lone 530 :: Lone 590 :: Sticky Note dr14:62","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YR78I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"高品質なLanguage ServerはRustやZigやGleamの普及を加速する基盤である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ao8aU","x":3292,"y":11520,"name":"L1-9::Group 4 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr13:9","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6ZX7F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ErlangのLet it crashは障害回復を局所化する設計原則である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Y6MfS","x":3576,"y":11520,"name":"L1-9::Group 4 :: Group 1 :: Lone 312 :: Lone 355 :: Sticky Note dr5:35","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nKSpt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlangは局所回復より再起動戦略で可用性を確保する設計を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"sJ7bk","x":3292,"y":11720,"name":"L1-9::Group 10 :: Group 1 :: Lone 490 :: Lone 544 :: Sticky Note dr13:87","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wV385","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"std::threadの設計はRAIIと例外安全との相性問題を露出した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KrkyX","x":3008,"y":12120,"name":"L1-9::Group 22 :: Group 1 :: Lone 531 :: Lone 591 :: Sticky Note dr14:63","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"phgMM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DenoはNode.jsエコシステムのツール断片化に対する統合的回答として設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"7585G","x":3008,"y":9120,"name":"L1-9::Group 23 :: Group 1 :: Lone 124 :: Group 92 :: Sticky Note dr5:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Wia7T","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの検査例外は回復可能な失敗の処理をコンパイル時に強制する設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"iNPlW","x":3292,"y":9120,"name":"L1-9::Group 23 :: Group 1 :: Lone 325 :: Lone 369 :: Sticky Note dr5:59","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ytt5I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのchecked例外史は効果注釈設計に対する実務的な警鐘として参照される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"JYLu4","x":2724,"y":8520,"name":"L1-9::Group 29 :: Group 1 :: Lone 271 :: Lone 311 :: Sticky Note dr4:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jrf7l","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Gleamは小規模言語ゆえ初期からエラーUXを設計中核に据えられた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"z8aWA","x":2724,"y":11920,"name":"L1-9::Group 30 :: Group 1 :: Group 52 :: Group 124 :: Sticky Note dr13:42","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hLofz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのTaskGroupは分岐した非同期処理の合流を安全に表現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"faVOh","x":2724,"y":11320,"name":"L1-9::Group 31 :: Group 1 :: Lone 473 :: Lone 527 :: Sticky Note dr13:58","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nRZCj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"構造化並行性はタスク寿命をブロックスコープへ閉じ込める設計原則である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"sAFlJ","x":3576,"y":12120,"name":"L1-9::Group 32 :: Group 1 :: Group 7 :: Group 11 :: Sticky Note dr2:24","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"n0fn8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/BEAMはあるプロセスのGC影響を他プロセスへ広げにくい設計を実現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4hdpD","x":3576,"y":9120,"name":"L1-9::Group 33 :: Group 1 :: Group 17 :: Group 26 :: Sticky Note dr15:27","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YhKKi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# は checked exception を採用せず開発速度と API 可変性を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"VNjaH","x":2724,"y":9320,"name":"L1-9::Group 33 :: Group 1 :: Group 41 :: Group 38 :: Sticky Note dr5:7","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Vz8zs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#はchecked例外を採用せずAPI進化の自由度を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"iZKwy","x":3008,"y":9320,"name":"L1-9::Group 33 :: Group 1 :: Lone 123 :: Group 74 :: Sticky Note dr13:28","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BSYX4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#の普及は他言語の非同期構文設計に強い影響を与えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Ny6po","x":3292,"y":9320,"name":"L1-9::Group 33 :: Group 1 :: Lone 302 :: Lone 344 :: Sticky Note dr5:8","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8GqqH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#の例外はすべてuncheckedのためコンパイラ強制より設計規約が重要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"l7XDi","x":2724,"y":11520,"name":"L1-9::Group 34 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr1:43","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CdKc7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのOptional設計はObjective-C時代のnil由来クラッシュ削減を目的に導入された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Hmma1","x":3008,"y":11520,"name":"L1-9::Group 34 :: Group 1 :: Group 13 :: Lone 185 :: Sticky Note dr2:35","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LCjvD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftはObjective-C互換を保ちつつARCで決定的解放と性能を両立する設計を選んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SRonA","x":3292,"y":9520,"name":"L1-9::Group 36 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr15:49","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YDmJj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の fatalError() と preconditionFailure() は回復不能状態で即時停止を強制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"z0Brs","x":3292,"y":10120,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr1:10","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iYddO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartは初期課題を受けてsound null safetyを含む健全な型システムへ再設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zsoUQ","x":3576,"y":10120,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr1:12","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LeZFQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartのsound null safetyはunsafeなnull使用を分析エラーとして早期検出する設計を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rPFkA","x":2724,"y":10320,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr1:13","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SyNUu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartのsound null safetyは非null値の初期化を必須化してnullアクセス不具合を実行前に減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"0gOjN","x":3008,"y":10120,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr11:9","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zuj2q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DartはDart 1の不健全オプショナル型付けを捨てDart 2以降でSound Null Safetyへ移行した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tmh81","x":3008,"y":10320,"name":"L1-9::Group 38 :: Group 1 :: Lone 127 :: Lone 137 :: Sticky Note dr1:14","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CvvWC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartの分析エラーモデルはIDEとビルド段階でnull関連バグを捕捉する開発体験を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"lYSSY","x":3008,"y":8520,"name":"L1-9::Group 39 :: Group 1 :: Group 28 :: Lone 400 :: Sticky Note dr6:51","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9HKwk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# Source Generatorはランタイム反射コストを減らせるがジェネレータ設計の学習負荷を新たに生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"H5UCJ","x":3576,"y":9520,"name":"L1-9::Group 46 :: Group 1 :: Group 109 :: Group 122 :: Sticky Note dr12:37","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eeZb2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはデータ競合を型システムで予防する設計を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"gA1S1","x":2724,"y":9720,"name":"L1-9::Group 46 :: Group 1 :: Group 109 :: Group 122 :: Sticky Note dr13:17","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"31xaa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの設計はデータ競合の主要経路を型検査で遮断する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"dRPTZ","x":3008,"y":9720,"name":"L1-9::Group 46 :: Group 1 :: Lone 363 :: Lone 412 :: Sticky Note dr11:1","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JaNyt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"型システムと型推論の設計は言語の表現力と安全性と開発体験を同時に規定する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1T7x5","x":3292,"y":9720,"name":"L1-9::Group 46 :: Group 1 :: Lone 558 :: Lone 618 :: Sticky Note dr15:22","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IbrOR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"医療制御や重要インフラ制御ではクラッシュ許容より防御的設計が優先される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"0pgqd","x":3008,"y":11320,"name":"L1-9::Group 51 :: Group 1 :: Group 17 :: Group 26 :: Sticky Note dr15:25","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WVXcP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"throws Exception や空 catch は checked exception 運用で生じやすい代表的アンチパターンである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Wrwi7","x":3292,"y":8520,"name":"L1-9::Group 59 :: Group 1 :: Lone 327 :: Lone 371 :: Sticky Note dr5:61","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lstAc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"エラー設計の要点は回復可能性と可読性と進化容易性のバランス最適化である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"a6iou","x":3008,"y":12320,"name":"L1-9::Group 62 :: Group 1 :: Group 38 :: Group 32 :: Sticky Note dr2:84","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ya4F2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのARCも強参照サイクルでリークし得るためweak/unowned設計が重要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"XLutX","x":2724,"y":12320,"name":"L1-9::Group 62 :: Group 1 :: Group 38 :: Group 32 :: Sticky Note dr12:33","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DW3oR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ARCは循環参照を自動解決しないためweakやunowned設計が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Qnjir","x":3576,"y":9320,"name":"L1-9::Group 73 :: Group 1 :: Group 85 :: Group 93 :: Sticky Note dr5:9","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NIQrb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは回復可能エラーをResult<T,E>で明示する設計を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"bIxEz","x":3576,"y":10720,"name":"L1-9::Group 75 :: Group 1 :: Group 112 :: Group 128 :: Sticky Note nishio:1","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gvVEm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"プログラミング言語は人間が設計するため、設計判断の違いと修正の歴史を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"BjGAm","x":2724,"y":10920,"name":"L1-9::Group 75 :: Group 1 :: Group 112 :: Group 128 :: Sticky Note nishio:2","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CCH55","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"完璧なプログラミング言語は存在しないという前提で比較すると設計意図が見えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"bjkLe","x":3008,"y":10920,"name":"L1-9::Group 75 :: Group 1 :: Lone 493 :: Lone 547 :: Sticky Note dr14:3","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Hx1PT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"構文設計は美学ではなくコード理解と誤読率に直接影響する認知設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"mijIA","x":3292,"y":10920,"name":"L1-9::Group 75 :: Group 1 :: Lone 538 :: Lone 598 :: Sticky Note dr14:73","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EnJdn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語設計の成熟は速度競争から人間工学と生態系設計の競争への移行として説明できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FnmGU","x":3576,"y":9720,"name":"L1-9::Group 76 :: Group 1 :: Lone 399 :: Lone 449 :: Sticky Note dr11:54","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GUKJa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの双方向推論とJavaのSealed設計とC++20 Conceptsはその収束点を示す代表例である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"n6Zpv","x":3292,"y":10320,"name":"L1-9::Group 78 :: Group 1 :: Lone 172 :: Lone 194 :: Sticky Note dr2:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"y9bQX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのunsafeは低レベル操作を禁止せず危険領域を明示境界に閉じ込める妥協設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qVOcm","x":3576,"y":10320,"name":"L1-9::Group 78 :: Group 1 :: Lone 424 :: Lone 474 :: Sticky Note dr12:43","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nP2qU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Safe Abstractionはunsafe内部実装を安全API境界で封じ込める要点である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"F70i4","x":3576,"y":8520,"name":"L1-9::Group 79 :: Group 1 :: Lone 191 :: Lone 213 :: Sticky Note dr2:71","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UHepr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは値型優先で共有可変状態を減らしスレッド安全性を上げる設計を重視した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pyDra","x":2724,"y":8720,"name":"L1-9::Group 79 :: Group 1 :: Lone 436 :: Lone 490 :: Sticky Note dr12:64","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vadcP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは値型優先設計でローカル推論しやすい状態管理を促進する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"MSbwt","x":3008,"y":8720,"name":"L1-9::Group 79 :: Group 1 :: Lone 451 :: Lone 505 :: Sticky Note dr13:1","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QLFmh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"並行性設計では共有メモリよりメッセージパッシングを優先すると状態競合を減らしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rWtax","x":3008,"y":11920,"name":"L1-9::Group 80 :: Group 1 :: Lone 222 :: Lone 250 :: Sticky Note dr3:62","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A3235","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Julia の設計は高水準 API を維持したまま BLAS や GPU バックエンドへの最適化分岐を実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"BWFfV","x":3292,"y":11320,"name":"L1-9::Group 81 :: Group 1 :: Lone 224 :: Lone 252 :: Sticky Note dr3:64","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lOCaG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Mojo は parallelize などでスレッド並列とベクトル並列を同一言語層で扱える設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Sln6X","x":3292,"y":11920,"name":"L1-9::Group 90 :: Group 1 :: Lone 627 :: Lone 692 :: Sticky Note nishio:6","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"46uZC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HMMMMLでは条件式内のx = 0をx == 0として扱う設計がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TePHZ","x":3292,"y":9920,"name":"L1-9::Group 96 :: Group 1 :: Group 5 :: Group 9 :: Sticky Note dr3:39","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FTqXA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"What Color is Your Function? 問題に対して Rust、Swift、Kotlin は async/await の着色を受け入れつつ増殖制御を設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HxEWN","x":2724,"y":9920,"name":"L1-9::Group 96 :: Group 1 :: Group 110 :: Group 125 :: Sticky Note dr13:43","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bvVMt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"colored function問題は非同期関数呼び出しが同期関数に伝染する設計課題である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YCapm","x":3008,"y":9920,"name":"L1-9::Group 96 :: Group 1 :: Group 110 :: Group 125 :: Sticky Note dr15:57","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zaA4X","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Result ベース設計は呼び出し側へ効果が伝播する colored function 問題を生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tr2H4","x":3008,"y":10520,"name":"L1-9::Group 98 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr1:64","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QT1HM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CeylonとZigはnullable明示と非nullableデフォルトを志向するnull安全設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5rsXK","x":2724,"y":10520,"name":"L1-9::Group 98 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr11:28","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8F3z5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ceylonの Null | String はNullを特別扱いせず集合論的に表現する設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ACMrW","x":3292,"y":8720,"name":"L1-9::Group 99 :: Group 1 :: Group 8 :: Lone 150 :: Sticky Note dr1:32","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Iuzzw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ALGOL Wのnull参照導入はTony Hoareが後にbillion dollar mistakeと呼んだ設計判断として知られる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"C0SFi","x":3576,"y":10920,"name":"L1-9::Group 101 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr13:35","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hf2WE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはcallback中心設計からPromiseへ移行した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"G5lzj","x":2724,"y":11120,"name":"L1-9::Group 101 :: Group 1 :: Lone 230 :: Lone 259 :: Sticky Note dr3:76","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tmLdK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Node.js は初期のコールバック中心設計で制御フローとエラー処理の可読性を大きく損ねた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"VveU9","x":3292,"y":12320,"name":"L1-9::Group 117 :: Group 1 :: Group 72 :: Group 75 :: Sticky Note dr3:28","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cW3nG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の Pin 設計は自己参照 future の安全性を確保するために必要とされた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"daDoT","x":3576,"y":12320,"name":"L1-9::Group 117 :: Group 1 :: Lone 465 :: Lone 519 :: Sticky Note dr13:29","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Cog57","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのFutureはランタイム非依存の抽象として設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rASGB","x":3292,"y":8920,"name":"L1-9::Group 123 :: Group 1 :: Group 108 :: Group 121 :: Sticky