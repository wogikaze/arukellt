 1 :: Lone 355 :: Lone 401 :: Sticky Note dr6:52","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LM1sI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`derive`は標準トレイト実装の反復を削減し日常コードの冗長性を大きく下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"bdh5e","x":2264,"y":3060,"name":"L1-6::Group 137 :: Group 1 :: Lone 304 :: Lone 346 :: Sticky Note dr5:11","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IIcm3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの?演算子はResultとOptionの早期リターンを簡潔に記述できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FtbMQ","x":1412,"y":3260,"name":"L1-6::Group 137 :: Group 1 :: Lone 305 :: Lone 347 :: Sticky Note dr5:12","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UDnas","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのFrom変換は?演算子利用時のエラー型統合を支援する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"A1Kb8","x":1696,"y":3260,"name":"L1-6::Group 137 :: Group 1 :: Lone 566 :: Lone 629 :: Sticky Note dr15:42","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"l7H64","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の ? 演算子は Err 時の早期 return と Into によるエラー変換を簡潔に実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YZM47","x":1980,"y":6660,"name":"L1-6::Group 139 :: Group 1 :: Lone 328 :: Lone 372 :: Sticky Note dr6:1","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JqM25","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust 2018 editionは`extern crate`依存を減らし`crate::`を含む統一的パス解決でモジュール学習コストを下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YI2uh","x":1696,"y":8260,"name":"L1-6::Group 160 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note nishio:118","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NA2WH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"配列範囲外アクセス時にRubyはnil、JavaScriptはundefinedを返す実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Ixz5h","x":1980,"y":3260,"name":"L1-6::Group 167 :: Group 1 :: Group 5 :: Group 34 :: Sticky Note dr13:47","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JPqgl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのFearless Concurrencyは競合不安を減らす開発体験として定着した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qUNHu","x":1696,"y":7860,"name":"L1-6::Group 171 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr11:26","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kaPSx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの Option<T> は Option<Option<T>> のようなネスト表現を自然に扱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"iraJS","x":2264,"y":6660,"name":"L1-6::Group 179 :: Group 1 :: Group 59 :: Group 57 :: Sticky Note dr2:82","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9VXR3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは安全性向上の代償として一部データ構造設計自由度を下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pSS4V","x":1980,"y":8260,"name":"L1-6::Group 180 :: Group 1 :: Group 62 :: Group 62 :: Sticky Note dr2:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VNZu7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのPoloniusは借用解析をDatalogベースで再定式化して精度と説明性の改善を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"8Nt7V","x":1696,"y":7460,"name":"L1-6::Group 182 :: Group 1 :: Group 83 :: Group 90 :: Sticky Note dr4:83","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QO67Z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのcargoはビルド依存公開までを一体化し新規参入障壁を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"OqBSe","x":1980,"y":7460,"name":"L1-6::Group 182 :: Group 1 :: Group 83 :: Group 90 :: Sticky Note dr4:84","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ec1LB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのcargoはcargo new, cargo test, cargo fmtの統一操作で開発体験を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"cA76r","x":2264,"y":6060,"name":"L1-6::Group 183 :: Group 1 :: Group 86 :: Group 94 :: Sticky Note dr5:13","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QmmvD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustではthiserrorがライブラリ向けの厳密なエラー型定義に使われる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"y9LmE","x":2264,"y":4860,"name":"L1-6::Group 184 :: Group 1 :: Group 87 :: Group 95 :: Sticky Note dr5:14","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType"