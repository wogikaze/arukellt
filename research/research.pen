ize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"X0iKV","x":1412,"y":11720,"name":"L1-2::Group 11 :: Group 1 :: Lone 148 :: Lone 163 :: Sticky Note dr2:3","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6tlOd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは簡潔な並行コードを書きやすくした一方でリアルタイム用途ではGCポーズが課題になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"cVpJR","x":1696,"y":11720,"name":"L1-2::Group 11 :: Group 1 :: Lone 203 :: Lone 227 :: Sticky Note dr3:6","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pAB5C","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go では goroutine の低コスト化と引き換えに、リークや starvation の診断が難しい課題が残る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"kgYsX","x":1980,"y":11720,"name":"L1-2::Group 11 :: Group 1 :: Lone 272 :: Lone 312 :: Sticky Note dr4:69","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0tEAj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは継承抑制や機能選別でチーム保守向けの単純さを優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"3JDAo","x":2264,"y":11720,"name":"L1-2::Group 11 :: Group 1 :: Lone 410 :: Lone 460 :: Sticky Note dr12:14","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D8yVx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは主要GCノブをGOGCへ集約して運用複雑性を抑えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"PG16g","x":1412,"y":11920,"name":"L1-2::Group 11 :: Group 1 :: Lone 510 :: Lone 568 :: Sticky Note dr14:32","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dHOx1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは大規模組織の協調開発を前提に機能制約でシンプルさを実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"uVRBG","x":1696,"y":11920,"name":"L1-2::Group 11 :: Group 1 :: Lone 512 :: Lone 571 :: Sticky Note dr14:35","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Uu4a5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの簡潔な表面構文はランタイム側の高度な複雑性隠蔽に支えられている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1pDaq","x":2264,"y":9920,"name":"L1-2::Group 13 :: Group 1 :: Group 95 :: Group 104 :: Sticky Note dr6:7","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fTvU8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go Modulesは`go.mod`で場所非依存ビルドとバージョン固定依存管理を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"V9xi4","x":1980,"y":9920,"name":"L1-2::Group 13 :: Group 1 :: Group 95 :: Group 104 :: Sticky Note dr16:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vbwo1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはGOPATH依存の管理からGo Modulesへ移行し、go.modで依存関係の再現性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9aUoj","x":1412,"y":10120,"name":"L1-2::Group 13 :: Group 1 :: Lone 147 :: Lone 162 :: Sticky Note dr2:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dfXj8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは手動管理やRCではなくトレーシングGCを前提に採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QB4yN","x":1696,"y":10120,"name":"L1-2::Group 13 :: Group 1 :: Lone 253 :: Lone 290 :: Sticky Note dr4:36","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8y2xg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはgofmt前提の設計でスタイル差より内容議論にレビューを集中させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"kimTj","x":1980,"y":10120,"name":"L1-2::Group 13 :: Group 1 :: Lone 281 :: Lone 323 :: Sticky Note dr4:82","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DAnt3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのgofmtは言語設計と不可分の標準フォーマット文化を形成した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"VB8Jp","x":2264,"y":10120,"name":"L1-2::Group 13 :: Group 1 :: Lone 332 :: Lone 376 :: Sticky Note dr6:6","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wNnLM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは当初GOPATH固定レイアウトで学習コストを抑えたが大規模開発では柔軟性不足が顕在化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1j76Z","x":1412,"y":10320,"name":"L1-2::Group 13 :: Group 1 :: Lone 511 :: Lone 570 :: Sticky Note dr14:34","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pdm7a","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはgofmtを必須文化としてスタイル議論を運用コストから除去した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"W6W1e","x":1696,"y":10320,"name":"L1-2::Group 13 :: Group 1 :: Lone 577 :: Lone 640 :: Sticky Note dr16:2","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KlvzZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go ModulesはMVS（Minimal Version Selection）で依存解決を決定的にし、SATソルバ依存を避けた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"eT45j","x":1980,"y":10920,"name":"L1-2::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr13:72","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kOuVO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futharkは純粋関数型前提でGPU向け依存解析を単純化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QvZGZ","x":2264,"y":10920,"name":"L1-2::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr13:73","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rdDsF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futharkはflattening変換で入れ子並列をGPU実行形へ写像する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"oyt4f","x":1412,"y":11320,"name":"L1-2::Group 27 :: Group 1 :: Group 36 :: Group 30 :: Sticky Note dr2:2","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4REqw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはCのようなメモリバグを避けつつgoroutineとchannelを単純に保つためにGC前提設計を選んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"poNMy","x":1696,"y":11320,"name":"L1-2::Group 27 :: Group 1 :: Group 36 :: Group 30 :: Sticky Note dr3:1","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DLg1A","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go は goroutine と channel を標準に組み込み、CSP の発想で共有メモリより通信を推奨した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HsbMH","x":2264,"y":11120,"name":"L1-2::Group 27 :: Group 1 :: Group 36 :: Group 30 :: Sticky Note dr13:4","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f79tc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはgoroutineとchannelを言語コアに置き並行性と並列性を区別して設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KHFm7","x":2264,"y":11320,"name":"L1-2::Group 27 :: Group 1 :: Group 76 :: Group 80 :: Sticky Note dr3:73","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xytt1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go は fire-and-forget 的な go 文により、キャンセル漏れで goroutine リークやチャネルデッドロックを起こしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"RzU81","x":1980,"y":11320,"name":"L1-2::Group 27 :: Group 1 :: Group 76 :: Group 80 :: Sticky Note dr13:81","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JYUQJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは受信者不在チャネル送信や無期限待機でgoroutineリークを起こしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9S9xG","x":1412,"y":11520,"name":"L1-2::Group 27 :: Group 1 :: Lone 455 :: Lone 509 :: Sticky Note dr13:6","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"m2bys","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは明示ロック中心の設計より通信中心の協調を推奨する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ivdMV","x":1696,"y":11520,"name":"L1-2::Group 37 :: Group 1 :: Lone 402 :: Lone 452 :: Sticky Note dr12:5","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OljLZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"G1 GCはリージョン分割とGarbage-First回収でポーズ予測性とスループットを両立する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"N9zeZ","x":1696,"y":12720,"name":"L1-2::Group 39 :: Group 1 :: Group 46 :: Group 45 :: Sticky Not