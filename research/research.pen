6","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XqLKe","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの短縮語は英語自然性が低く初学者には意味推測しづらい場合がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5Dell","x":1980,"y":6460,"name":"L1-6::Group 73 :: Group 1 :: Group 85 :: Group 93 :: Sticky Note dr15:40","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"q41pM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust は Result<T, E> により回復可能エラーを型で表し未処理をコンパイルで拒否する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"sJFwZ","x":2264,"y":6460,"name":"L1-6::Group 73 :: Group 1 :: Lone 567 :: Lone 630 :: Sticky Note dr15:45","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"POlCt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の panic! は回復不能な契約違反に使うべきで回復可能エラーとは分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"l6nSw","x":2264,"y":5060,"name":"L1-6::Group 74 :: Group 1 :: Group 94 :: Group 103 :: Sticky Note dr6:5","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OfZrH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustではcrate境界が可視性と最適化の境界になるためcrate分割方針が設計品質とビルド時間を左右する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"kEbc2","x":1980,"y":5060,"name":"L1-6::Group 74 :: Group 1 :: Group 94 :: Group 103 :: Sticky Note dr6:27","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"l2kmC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustでは依存削減とcrate分割とインクリメンタル活用が体感ビルド時間を改善する主要戦略になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Afo0R","x":1412,"y":5260,"name":"L1-6::Group 74 :: Group 1 :: Lone 610 :: Lone 674 :: Sticky Note dr16:52","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"h5uCR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはcrate単位コンパイルで最適化余地を確保するが再ビルド範囲が大きくなりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"aGvPo","x":1696,"y":5260,"name":"L1-6::Group 74 :: Group 1 :: Lone 612 :: Lone 676 :: Sticky Note dr16:54","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tXEjq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust開発ではWorkspace分割やcodegen_units調整でビルド時間を緩和する運用が一般化した。","lineHei