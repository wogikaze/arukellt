xt","id":"1Hk5g","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PythonはPEP 3156でasyncio基盤を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ZKuDt","x":3576,"y":21500,"name":"L1-11::Group 1 :: Group 1 :: Group 5 :: Group 9 :: Sticky Note dr3:21","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KcbqJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift は Concurrency Manifesto の流れで async/await と actor を導入し、非同期制御を構文で明示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"W3sN0","x":2724,"y":21900,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr3:33","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6itNs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScript は Promise を先に導入し、その後 async/await を重ねて callback hell の複雑性を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"B0yVx","x":3008,"y":21900,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr3:34","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"N2Y3f","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScript の async/await はエラーハンドリングを簡潔化したが、Promise API との相互運用設計を継続的に要した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"z8WpK","x":3292,"y":21900,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr3:77","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7dbnj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Node.js は Promise と async/await の導入で callback hell を段階的に改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GxKh5","x":3576,"y":21900,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr5:36","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"e9C4K","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはcallbackとPromiseとasync/awaitが混在しエラースタイルが分断されやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"iHz04","x":3008,"y":21700,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr13:36","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xBJFg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはPromiseからasyncとawaitへ進化してエラー処理を単純化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"04wNX","x":3292,"y":21700,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr13:85","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vcZR5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PromiseとasyncとawaitはNode.js非同期設計の可読性問題を大幅に改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wbixN","x":3576,"y":21700,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr15:36","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KidWy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Promise の .catch() と async/await は JavaScript 非同期エラー処理の標準経路を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"nfocy","x":2724,"y":21500,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 9 :: Sticky Note dr3:75","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Wlo2I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の async/await はランタイム非同梱方針により Tokio と async-std などのエコシステム分断を生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"awwys","x":3008,"y":21300,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 20 :: Sticky Note dr3:24","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"