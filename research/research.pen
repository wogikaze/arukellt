t":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pjOdJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"値の平坦化は同時更新時のtearing対策を言語仕様側へ要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"z3xjn","x":384,"y":4460,"name":"L1-7::Lone 322 :: Group 1 :: Lone 444 :: Lone 498 :: Sticky Note dr12:74","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Yb91j","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DisruptorはMechanical Sympathyに基づき偽共有回避と遅延削減を徹底した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Q1sQx","x":668,"y":8460,"name":"L1-7::Lone 325 :: Group 1 :: Lone 450 :: Lone 504 :: Sticky Note dr12:80","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OK0bs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"単一の最適解はなくドメイン要件に合わせた選択が必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qJt7b","x":100,"y":12460,"name":"L1-7::Lone 326 :: Group 1 :: Lone 452 :: Lone 506 :: Sticky Note dr13:2","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KJEUX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CSPは独立実行単位とチャネル通信で並行制御を構造化する考え方である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"2XWGO","x":384,"y":11660,"name":"L1-7::Lone 329 :: Group 1 :: Lone 479 :: Lone 533 :: Sticky Note dr13:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YZUJc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JuliaはTwo-Language Problemを緩和し単一言語内最適化を進めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"kIqi2","x":668,"y":4460,"name":"L1-7::Lone 332 :: Group 1 :: Lone 496 :: Lone 551 :: Sticky Note dr14:7","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0yxhN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ABCで導入されたコロンはブロック開始の視覚アンカーとして初心者の理解を補助した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"lhLKi","x":384,"y":12460,"name":"L1-7::Lone 336 :: Group 1 :: Lone 524 :: Lone 584 :: Sticky Note dr14:56","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eNYvP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Gleamは局所エラー後も解析継続してIDEフィードバックを維持する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"kMCID","x":100,"y":10660,"name":"L1-7::Lone 338 :: Group 1 :: Lone 529 :: Lone 589 :: Sticky Note dr14:61","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8XYf7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSPはAST統一ではなく文書位置と診断交換の標準化に焦点を置いた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"AF03G","x":952,"y":4460,"name":"L1-7::Lone 342 :: Group 1 :: Lone 537 :: Lone 597 :: Sticky Note dr14:72","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4W2W0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"主流言語は同図像性を全面採用せず限定的マクロやリフレクションで折衷する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"sWXN6","x":668,"y":6060,"name":"L1-7::Lone 344 :: Group 1 :: Lone 542 :: Lone 602 :: Sticky Note dr15:3","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BM5i5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"再現可能な研究ではデータ処理と分析手順をコード化した実行フローが必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"WmKdu","x":952,"y":8460,"name":"L1-7::Lone 345 :: Group 1 :: Lone 543 :: Lone 603 :: Sticky Note dr15:4","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"u0DWv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Stata の .do ファイルは経済学や社会科学で標準的な分析実行単位として使われる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pCDDl","x":668,"y":12460,"name":"L1-7::Lone 346 :: Group 1 :: Lone 545 :: Lone 605 :: Sticky Note dr15:6","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lgFw8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"0-master.do は実データ処理よりも環境変数定義と段階実行の制御を担うべきである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"lvfzV","x":384,"y":10660,"name":"L1-7::Lone 348 :: Group 1 :: Lone 551 :: Lone 611 :: Sticky Note dr15:12","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mMNAH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"研究パイプラインはローカル実行だけでなく GitHub Actions や GitLab CI に統合されるべきである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"LZSEe","x":668,"y":11660,"name":"L1-7::Lone 349 :: Group 1 :: Lone 552 :: Lone 612 :: Sticky Note dr15:13","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nLgt0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"マルチリポジトリ CI/CD は上流データ変更が下流分析に与える退行を自動検証できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"AuFJC","x":384,"y":7260,"name":"L1-7::Lone 350 :: Group 1 :: Lone 553 :: Lone 613 :: Sticky Note dr15:14","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iCPY2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LLM エージェントを使ったデータラングリング自動化は探索的分析の初期時間を短縮できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wEnKg","x":100,"y":9660,"name":"L1-7::Lone 351 :: Group 1 :: Lone 554 :: Lone 614 :: Sticky Note dr15:15","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ISvIG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"実行完了後のデータとコードは DOI 付き永続リポジトリへ固定アーカイブするべきである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"cTrpe","x":100,"y":4660,"name":"L1-7::Lone 352 :: Group 1 :: Lone 555 :: Lone 615 :: Sticky Note dr15:16","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"03gEV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"研究中のデータ保全には 3-2-1 バックアップルールの遵守が有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"LgzK1","x":952,"y":13260,"name":"L1-7::Lone 353 :: Group 1 :: Lone 564 :: Lone 626 :: Sticky Note dr15:34","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sOLQy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"EAFP は存在確認と実操作の時間差で起きる race condition を減らせる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TCA4f","x":668,"y":14060,"name":"L1-7::Lone 357 :: Group 1 :: Lone 586 :: Lone 649 :: Sticky Note dr16:15","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dMDYu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ブラウザ側は非同期ロード要件からAMDとRequireJSが普及した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qvx36","x":668,"y":10660,"name":"L1-7::Lone 358 :: Group 1 :: Lone 587 :: Lone 650 :: Sticky Note dr16:17","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QBenX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ESMはimport/exportの静的解析を可能にし、ツリーシェイキングを促進した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4CmLN","x":384,"y":4660,"name":"L1-7::Lone 362 :: Group 1 :: Lone 615 :: Lone 679 :: Sticky Note dr16:61","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","c