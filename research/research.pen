単一路線は完全ではない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hLtDY","x":1696,"y":21040,"name":"L1-0::Lone 290 :: Group 1 :: Lone 286 :: Lone 328 :: Sticky Note dr4:89","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CG0RD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python, Ruby, Elixir, ScalaのREPL文化は試行錯誤と学習の即時性を高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"RsMKx","x":1980,"y":21040,"name":"L1-0::Lone 300 :: Group 1 :: Lone 366 :: Lone 415 :: Sticky Note dr11:8","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0PoqC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"mypy などの外部ツール普及によりPython大規模開発で型検査が実務標準になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"maH9C","x":2264,"y":21440,"name":"L1-0::Lone 309 :: Group 1 :: Lone 385 :: Lone 435 :: Sticky Note dr11:36","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mwf0J","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonのパターンで単純名はキャプチャになり定数比較にはドット付き名が必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"6r7zN","x":2264,"y":20240,"name":"L1-0::Lone 355 :: Group 1 :: Lone 584 :: Lone 647 :: Sticky Note dr16:11","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DQ8MH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonはsys.modulesへの途中登録仕様によりpartially initialized moduleエラーが発生し得る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ix85r","x":100,"y":14920,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Group 52 :: Sticky Note dr1:21","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IOrbY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは推論範囲をローカルに制限してコンパイル時間とエラー品質を制御する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"2aBQL","x":384,"y":14920,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Group 52 :: Sticky Note dr1:22","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8CX1z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは制約解決不能時にコンパイルエラーを返して曖昧な推論結果を残さない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ia56X","x":668,"y":14920,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Lone 142 :: Sticky Note dr1:19","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yZBgC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinはローカル型推論と関数シグネチャ推論を制約ソルバーで統合する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"IWpQd","x":952,"y":14920,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Lone 145 :: Sticky Note dr1:26","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RxTbE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは曖昧な推論を許容せず明示的型指定を促すことで後続エラー連鎖を防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fuDSy","x":100,"y":15120,"name":"L1-8::Group 3 :: Group 1 :: Group 56 :: Group 53 :: Sticky Note dr1:23","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3zmXB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのbuilder-style inferenceはDSLで型引数明記を減らすために後ろ向き制約解決を追加する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"iwxWa","x":384,"y":15120,"name":"L1-8::Group 3 :: Group 1 :: Group 56 :: Group 53 :: Sticky Note dr1:24","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jvbML","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","conten