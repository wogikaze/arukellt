検査は Err 分岐の取りこぼしを防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9nuuM","x":100,"y":13860,"name":"L1-7::Group 77 :: Group 1 :: Lone 161 :: Lone 177 :: Sticky Note dr2:25","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HLdv1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMはプロセス間共有を避けるためにデータコピーを基本とするモデルを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FXPMX","x":384,"y":13860,"name":"L1-7::Group 77 :: Group 1 :: Lone 162 :: Lone 178 :: Sticky Note dr2:26","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aSFTV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMは共有ミュータブル状態を減らしてGCと並行実行モデルを単純化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"51tA6","x":668,"y":13860,"name":"L1-7::Group 77 :: Group 1 :: Lone 163 :: Lone 179 :: Sticky Note dr2:27","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"L32FJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMは半空間コピーや世代別GCを比較的単純に保てる利点を得た。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"huisN","x":952,"y":13860,"name":"L1-7::Group 77 :: Group 1 :: Lone 414 :: Lone 464 :: Sticky Note dr12:23","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2RDn7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMは不変データ前提のため世代間参照管理が比較的単純になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wtoMB","x":668,"y":11460,"name":"L1-7::Group 79 :: Group 1 :: Lone 309 :: Lone 351 :: Sticky Note dr5:23","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Uk1KH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのswitchは列挙型の網羅性チェックで分岐漏れを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FFoed","x":100,"y":7060,"name":"L1-7::Group 80 :: Group 1 :: Lone 221 :: Lone 249 :: Sticky Note dr3:61","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4Z8px","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Julia は多重ディスパッチを中核に据え、型に応じた SIMD、マルチスレッド、分散実装の選択を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FX7E7","x":384,"y":7060,"name":"L1-7::Group 80 :: Group 1 :: Lone 480 :: Lone 534 :: Sticky Note dr13:69","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sKpUX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JuliaはLLVM経由でCPUとGPU双方のコード生成に適応する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HjINA","x":100,"y":9460,"name":"L1-7::Group 81 :: Group 1 :: Lone 482 :: Lone 536 :: Sticky Note dr13:71","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6XY2D","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Mojoは所有権的制御とハードウェア近接最適化をAI用途へ持ち込む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"yIG6P","x":952,"y":13060,"name":"L1-7::Group 83 :: Group 1 :: Lone 322 :: Lone 366 :: Sticky Note dr5:55","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kWb5f","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Algebraic Effectsは効果ハンドラで失敗処理と制御構造を統一的に表現できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"8x3e0","x":100,"y":13260,"name":"L1-7::Group 83 :: Group 1 :: Lone 557 :: Lone 617 :: Sticky Note dr15:21","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7aUx5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"let it crash は再試行可能なステートレス分散処理で特に効果を発揮する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SlQPr","x":384,"y":13260,"name":"L1-7::Group 83 :: Group 1 :: Lone 570 :: Lone 633 :: Sticky Note dr15:58","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RGuVh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"代数的エフェクトは effect 宣言と handler 実装を分離して再開可能な失敗処理を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"0rSfi","x":668,"y":12260,"name":"L1-7::Group 86 :: Group 1 :: Lone 595 :: Lone 659 :: Sticky Note dr16:31","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5TGC4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OCamlはFunctorで実装注入を明示化し、依存関係の見通しを高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Pm4fA","x":952,"y":12260,"name":"L1-7::Group 86 :: Group 1 :: Lone 636 :: Lone 705 :: Sticky Note nishio:24","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AKwts","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OCamlは引数0個をunitで表現し、必要時に()を渡す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"8bHWl","x":100,"y":14060,"name":"L1-7::Group 87 :: Group 1 :: Lone 678 :: Lone 754 :: Sticky Note nishio:96","wid