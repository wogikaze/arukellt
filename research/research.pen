":"text","id":"0vHrW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の std::simd は API 形状の議論を継続しつつ安定化へ向けて進んでいる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"I96sa","x":2264,"y":6860,"name":"L1-6::Group 49 :: Group 1 :: Lone 483 :: Lone 537 :: Sticky Note dr13:75","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MysBu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのPortable SIMDはSimd<T, N>でアーキ非依存のベクタ演算を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"yC1na","x":1412,"y":7060,"name":"L1-6::Group 69 :: Group 1 :: Lone 393 :: Lone 443 :: Sticky Note dr11:45","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LuUW7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの完全単相化は高性能を得る代償としてコンパイル時間とバイナリ肥大化を招きうる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"WYWQy","x":1696,"y":7060,"name":"L1-6::Group 69 :: Group 1 :: Lone 619 :: Lone 683 :: Sticky Note dr16:72","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eC6wp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust derive多用はビルド時間増加と開発体験の悪化を招く場合がある。","lineHeight":1.6,"fontFamily":"I