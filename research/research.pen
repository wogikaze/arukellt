"width":"fill_container","content":"Rustのbumpaloやtyped-arenaは所有権モデルと併用される実践的手段である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"RxW4Y","x":2264,"y":7060,"name":"L1-6::Group 188 :: Group 1 :: Group 97 :: Group 106 :: Sticky Note dr6:10","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3QELJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`pub` `pub(crate)` `pub(super)`はデフォルト非公開を維持しつつ段階的公開を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Uzta2","x":1980,"y":7060,"name":"L1-6::Group 188 :: Group 1 :: Group 97 :: Group 106 :: Sticky Note dr16:34","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"b0Z2H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust可視性はprivate既定に加えてpub(crate)やpub(super)で公開範囲を段階化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"7MO9f","x":2264,"y":8260,"name":"L1-6::Group 190 :: Group 1 :: Group 113 :: Group 132 :: Sticky Note nishio:79","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1mCJe","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rubyはendでブロック終端を明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Is9Ot","x":1412,"y":6260,"name":"L1-6::Group 193 :: Group 1 :: Lone 129 :: Lone 139 :: Sticky Note dr1:16","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OCrc9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権と借用とライフタイム制約を扱うため一方向推論だけでは実用性が不足する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"xWwQt","x":2264,"y":7460,"name":"L1-6::Group 202 :: Group 1 :: Lone 422 :: Lone 472 :: Sticky Note dr12:39","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MFEK3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのNLLはMIR制御フロー解析で実用的な受理範囲を広げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ewz1f","x":1980,"y":3660,"name":"L1-6::Group 207 :: Group 1 :: Lone 392 :: Lone 442 :: Sticky Note dr11:44","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tDrU9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのトレイト境界付き単相化はゼロコスト抽象化を実現する中核戦略である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vQaHd","x":1412,"y":7660,"name":"L1-6::Group 212 :: Group 1 :: Lone 198 :: Lone 221 :: Sticky Note dr2:81","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9fulK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは自己参照構造や循環グラフで安全表現が難しくPinやunsafeや追加抽象が必要になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KGu6u","x":1696,"y":7660,"name":"L1-6::Group 212 :: Group 1 :: Lone 287 :: Lone 329 :: Sticky Note dr4:90","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"V4npB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go, Rust初期, C/C++はファイル単位実行中心のため試行サイクルが重くなりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5GN0P","x":1980,"y":4260,"name":"L1-6::Group 215 :: Group 1 :: Lone 211 :: Lone 239 :: Sticky Note dr3:29","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DjBVn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の非同期基盤は利用者側を簡潔に保つ一方で、ライブラリ作者には Pin、Poll、Unsafe の複雑性を要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"s43DH","x":1412,"y":5060,"name":"L1-6::Group 224 :: Group 1 :: Lone 280 :: Lone 322 :: Sticky Note dr4:81","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9CmMS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは入門資料とコンパイラUX改善で初期学習負荷を継続的に緩和している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ZHob5","x":1696,"y":5060,"name":"L1-6::Group 224 :: Group 1 :: Lone 583 :: Lone 646 :: Sticky Note dr16:8","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LMnGK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは旧式のmod.rs構成も維持し、移行コストに配慮した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"O10af","x":2264,"y":4260,"name":"L1-6::Group 225 :: Group 1 :: Lone 505 :: Lone 562 :: Sticky Note dr14:23","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AOCpW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは複数implブロックで機能群や条件付き実装を整理しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"EfkSy","x":2264,"y":3660,"name":"L1-6::Group 227 :: Group 1 :: Lone 303 :: Lone 345 :: Sticky Note dr5:10","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sIN4m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはpanicをバグや致命的状態に限定する文化を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"fram