g":[32,28,28,28],"children":[{"type":"text","id":"dTZtu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Odinは制御性が高い一方でライフタイムバグ責任を開発者が負う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wqDVb","x":3008,"y":5260,"name":"L1-5::Group 213 :: Group 1 :: Lone 200 :: Lone 224 :: Sticky Note dr2:86","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iOYgO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"手動管理志向言語は予測可能性と性能を優先しつつ責務と学習コストを開発者側へ移す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zgYyd","x":3576,"y":7460,"name":"L1-5::Group 222 :: Group 1 :: Lone 275 :: Lone 316 :: Sticky Note dr4:74","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WLvFb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PerlはTMTOWTDIで表現自由度を最大化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QmjcI","x":3292,"y":5260,"name":"L1-5::Group 223 :: Group 1 :: Lone 276 :: Lone 317 :: Sticky Note dr4:75","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"btFlc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Perlは短い記述力を得た反面で可読性低下からwrite-only language批判を受けた。","lineHeight":1.6,"fontFami