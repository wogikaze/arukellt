ur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QFZNd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonのインデント設計はABC言語の教育的ユーザビリティ実験を継承している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"31SwZ","x":1696,"y":19240,"name":"L1-0::Group 14 :: Group 1 :: Group 1 :: Lone 552 :: Sticky Note dr14:8","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LZ1lg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonがコロンとインデントを組み合わせたのは人間の構造認識を優先したためである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Y0AYW","x":1980,"y":19240,"name":"L1-0::Group 14 :: Group 1 :: Lone 236 :: Lone 267 :: Sticky Note dr4:7","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AJS1x","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonの設計はGuido van Rossumの読みやすさ優先思想を反映している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9cYuf","x":1980,"y":18240,"name":"L1-0::Group 21 :: Group 1 :: Group 1 :: Group 1 :: Sticky Note dr2:31","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wS5Gd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CPythonは参照カウントを主軸にしてオブジェクト寿命の即時管理を実現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ebApx","x":2264,"y":18240,"name":"L1-0::Group 21 :: Group 1 :: Group 1 :: Group 1 :: Sticky Note dr3:47","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"X9bjl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python の GIL は CPython の単純性と参照カウント整合性を優先して導入された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Fey9w","x":1696,"y":18440,"name":"L1-0::Group 21 :: Group 1 :: Group 1 :: Group 60 :: Sticky Note dr2:33","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jQvQv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CPythonは循環参照対策として補助的な世代別トレーシングGCを追加採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TRjdf","x":1412,"y":18440,"name":"L1-0::Group 21 :: Group 1 :: Group 1 :: Group 60 :: Sticky Note dr12:30","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"R3Pgo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonは参照カウントに世代別トレーシングGCを併用して循環参照へ対処する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"IWGeN","x":1980,"y":18440,"name":"L1-0::Group 21 :: Group 1 :: Group 1 :: Lone 184 :: Sticky Note dr2:34","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"R2jQk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CPythonは循環リークを軽減したがヒープ走査コストと追加ポーズが発生する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zw4WS","x":2264,"y":18440,"name":"L1-0::Group 21 :: Group 1 :: Group 1 :: Lone 222 :: Sticky Note dr2:83","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Yf4Gl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PythonのRCは循環参照で回収不能になり得るため補助GCが必須になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GOKnY","x":1412,"y":18640,"name":"L1-0::Group 51 :: Group 1 :: Group 1 :: Lone 356 :: Sticky Note dr5:39","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XizTY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonは例外仕様がシグネチャに出にくく呼び出し側の捕捉方針が難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"JAjH4","x":1696,"y":18640,"name":"L1-0::Group 51 :: Group 1 :: Group 1 :: Lone 625 :: Sticky Note dr15:33","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FRpgC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python は LBYL より EAFP を推奨し例外捕捉で失敗経路を扱う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"MA3bv","x":1980,"y":18640,"name":"L1-0::Group 51 :: Group 1 :: Group 17 :: Group 26 :: Sticky Note dr5:40","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"r3RN2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonのexcept Exception: passは障害隠蔽を招く代表的アンチパターンである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"eugnD","x":1980,"y":19640,"name":"L1-0::Group 64 :: Group 1 :: Group 47 :: Group 47 :: Sticky Note dr6:58","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Gta1G","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pythonのimportは実行時評価前提のため循環依存が途中初期化状態を露出しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rSsGj","x":1412,"y":19640,"name":"L1-0::Group 64 :: Group 1 :: Group 47 :: Group 47 :: Sticky Note dr16:10","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Bwi1R","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python importは実行時評