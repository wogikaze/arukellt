45 :: Sticky Note dr14:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f6j7Z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代の言語設計は機械効率よりも人間の認知負荷と保守性を重視する方向へ移行している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ElMND","x":2724,"y":10720,"name":"L1-9::Group 215 :: Group 1 :: Lone 214 :: Lone 242 :: Sticky Note dr3:43","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qvWsb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust で unsafe による Send/Sync 実装を行う場合はライブラリ作者が強い不変条件を保証する責任を負う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4Jh57","x":3008,"y":9520,"name":"L1-9::Group 216 :: Group 1 :: Lone 218 :: Lone 246 :: Sticky Note dr3:51","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TTSIu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ruby の MRI は GVL により Ruby バイトコード実行を実質単一スレッド化する設計を採った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"8GlYv","x":3008,"y":8320,"name":"L1-9::Group 219 :: Group 1 :: Lone 282 :: Lone 324 :: Sticky Note dr4:85","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2j1JW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSPの普及は言語設計段階から補完やリファクタ提供を前提にする圧力を生んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"IkQEd","x":2724,"y":10120,"name":"L1-9::Group 228 :: Group 1 :: Lone 569 :: Lone 632 :: Sticky Note dr15:56","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YsFbr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Result や Either の普及は例外の暗黙制御フロー問題を減らした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"3TLaA","x":3008,"y":10720,"name":"L1-9::Group 235 :: Group 1 :: Lone 352 :: Lone 397 :: Sticky Note dr6:43","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gQQgZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Terraの設計は研究用途で有効だが一般アプリ開発での採用は限定的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TnYaO","x":3292,"y":10720,"name":"L1-9::Group 235 :: Group 1 :: Lone 398 :: Lone 448 :: Sticky Note dr11:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YbHRN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代言語設計の実務解は制約注釈を適度に要求し推論の暴走を抑える方向に収束している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Mjgr9","x":3008,"y":12520,"name":"L1-9::Group 237 :: Group 1 :: Lone 364 :: Lone 413 :: Sticky Note dr11:2","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vzso1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"型設計の中心課題は数学的健全性と実用的互換性のトレードオフである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9OGXj","x":3292,"y":12520,"name":"L1-9::Group 237 :: Group 1 :: Lone 540 :: Lone 600 :: Sticky Note dr15:1","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oFwUk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"計算研究の信頼性は予期しない障害を管理できる実行設計に依存する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"uLHo5","x":3292,"y":8320,"name":"L1-9::Group 239 :: Group 1 :: Lone 387 :: Lone 437 :: Sticky Note dr11:39","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"y2aok","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ジェネリクス設計は再利用性と実行時表現と互換性の三者最適化問題である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fzi0S","x":3576,"y":8320,"name":"L1-9::Group 239 :: Group 1 :: Lone 445 :: Lone 499 :: Sticky Note dr12:75","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3f6PK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HFT領域ではGCポーズ回避のためオブジェクト再利用設計が有効になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QHOt2","x":3292,"y":12120,"name":"L1-9::Group 242 :: Group 1 :: Lone 449 :: Lone 503 :: Sticky Note dr12:79","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ljaXr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語のメモリ管理選択はスループット、レイテンシ、開発体験のトレードオフで決まる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"frm8k","x":3292,"y":11120,"name":"L1-9::Group 251 :: Group 1 :: Lone 556 :: Lone 616 :: Sticky Note dr15:17","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lFKb4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"障害対処の設計は予防中心のワークフロー設計と実行時反応の言語機構に分かれる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"r7vbc","x":3576,"y":11120,"name":"L1-9::Group 251 :: Group 1 :: Lone 559 :: Lone 620 :: Sticky Note dr15:28","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DaeWf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# 設計では例外の詳細型を中間層で列挙するより上位集中処理を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"PCY69","x":3576,"y":8720,"name":"L1-9::Lone 269 :: Group 1 :: Group 53 :: Group 130 :: Sticky Note nishio:26","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FtrtY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Smalltalkは式を左結合で評価する設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SK3wB","x":2724,"y":8920,"name":"L1-9::Lone 279 :: Group 1 :: Lone 190 :: Lone 212 :: Sticky Note dr2:70","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PExEj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ゲーム開発のプールアロケータは局所性を高める一方でサイズ設計を誤るとメモリ効率が悪化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"AguEs","x":2724,"y":11720,"name":"L1-9::Lone 294 :: Group 1 :: Lone 307 :: Lone 349 :: Sticky Note dr5:18","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"drqDo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのpanicとrecoverは通常系ではなく異常系の境界処理に使う設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vFIKl","x":3008,"y":11720,"name":"L1-9::Lone 304 :: Group 1 :: Lone 378 :: Lone 428 :: Sticky Note dr11:29","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JRyFl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CeylonのUnion型設計は理論的一貫性を得る代わりに推論実装を重くする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"dibS2","x":3576,"y":9920,"name":"L1-9::Lone 316 :: Group 1 :: Lone 418 :: Lone 468 :: Sticky Note dr12:28","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"h3ZtI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaはバリア設計と再スキャン戦略でオーバーヘッドを抑えている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HU3ez","x":3576,"y":11920,"name":"L1-9::Lone 330 :: Group 1 :: Lone 485 :: Lone 539 :: Sticky Note dr13:77","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GFeAI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"失敗事例の検証は次世代並行性設計の品質向上に不可欠である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YXdq2","x":2724,"y":9520,"name":"L1-9::Lone 343 :: Group 1 :: Lone 541 :: Lone 601 :: Sticky Note dr15:2","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"44Lag","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"research.do のような研究スクリプト運用と高負荷サーバー設計は障害管理という同じ課題を共有する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fihi4","x":3008,"y":8920,"name":"L1-9::Lone 379 :: Group 1 :: Lone 679 :: Lone 755 :: Sticky Note nishio:98","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"N6ujg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Groovyは数値リテラルをBigDecimal寄りに扱う設計がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"cKOzJ","x":1980,"y":14580,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr3:44","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8TuJ7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java は Project Loom で Virtual Thread を導入し、既存 Thread API の互換性を保ちながら軽量スレッド化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fDXUO","x":2264,"y":14580,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr3:45","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"o5jQ4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java の Virtual Thread はブロッキングスタイルの可読性を維持しつつ高並行性を狙う設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"LVWfe","x":2264,"y":14380,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr13:44","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bbilB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaはProject LoomでVirtual Threadsを導入し色分け依存を弱めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"daMyJ","x":1412,"y":14580,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr13:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"J14se","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java Virtual Threadsは多数接続を同期スタイルで扱う実装を容易にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TzkDM","x":1696,"y":14580,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr15:63","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oOO4v","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java Project Loom は Virtual Threads で thread-per-request の高コスト問題を緩和する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"cTQtP","x":1696,"y":14380,"name":"L1-4::Group 8 :: Group 1 :: Group 111 :: Group 126 :: Sticky Note dr13:49","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iHaE8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JVMはブロッキング時に仮想スレッドをアンマウントしてキャリアを再利用する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"2ItMB","x":1980,"y":14380,"name":"L1-4::Group 8 :: Group 1 :: Group 111 :: Group 126 :: Sticky Note dr15:64","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oi0zH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Virtual Threads はブロッキング時に JVM が unmount しキャリアスレッドを再利用できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"0IpsS","x":1412,"y":14780,"name":"L1-4::Group 8 :: Group 1 :: Lone 215 :: Lone 243 :: Sticky Note dr3:46","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PEiyL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java の Loom は従来のスレッド数上限問題を緩和し、Executor とブロッキング API の運用を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"IC4ON","x":1696,"y":15980,"name":"L1-4::Group 20 :: Group 1 :: Group 103 :: Group 116 :: Sticky Note dr6:64","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yiBVp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java JPMSは`module-info.java`で依存とエクスポートを明示しJDK自体の分割にも寄与した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"P5Nam","x":1412,"y":15980,"name":"L1-4::Group 20 :: Group 1 :: Group 103 :: Group 116 :: Sticky Note dr16:19","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TbCLx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JPMS（Project Jigsaw）はclass path中心の依存解決をmodule-info.java中心へ転換した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vNyxN","x":1980,"y":15980,"name":"L1-4::Group 20 :: Group 1 :: Lone 360 :: Lone 409 :: Sticky Note dr6:65","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uQXSE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java JPMSは既存Maven/OSGi資産との整合コストが高く全面採用は限定的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4w7TK","x":2264,"y":15980,"name":"L1-4::Group 20 :: Group 1 :: Lone 589 :: Lone 652 :: Sticky Note dr16:20","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"typ