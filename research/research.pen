イム生成を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SEbx8","x":2264,"y":16780,"name":"L1-4::Lone 365 :: Group 1 :: Lone 633 :: Lone 700 :: Sticky Note nishio:17","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tvwhc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは関数そのものを持たない時代があり、メソッド操作はリフレクション中心だった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"jxci7","x":1696,"y":14780,"name":"L1-4::Lone 378 :: Group 1 :: Lone 677 :: Lone 752 :: Sticky Note nishio:93","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IlFPx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは文字列連結時にtoString相当の変換を許容する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"6j0Vd","x":3576,"y":13180,"name":"L1-10::Group 5 :: Group 1 :: Group 51 :: Group 110 :: Sticky Note dr6:35","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"teAuN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++プリプロセッサマクロは条件分岐には有効だが型安全性欠如とデバッグ困難を招きやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wuf5V","x":3292,"y":13180,"name":"L1-10::Group 5 :: Group 1 :: Group 51 :: Group 110 :: Sticky Note dr16:59","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sLrGT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++プリプロセッサマクロは型やスコープ非認識のため副作用バグを生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KVCsa","x":2724,"y":13380,"name":"L1-10::Group 5 :: Group 1 :: Group 51 :: Lone 390 :: Sticky Note dr6:34","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fJk35","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++プリプロセッサマクロは実装容易性と移植性を優先したテキスト置換機構として成立した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"k5aex","x":3008,"y":13380,"name":"L1-10::Group 5 :: Group 1 :: Lone 175 :: Lone 197 :: Sticky Note dr2:51","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"I4ieX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++は手動確保解放で最大制御性を得る代わりにメモリ安全バグを生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"WJAJF","x":3292,"y":13380,"name":"L1-10::Group 5 :: Group 1 :: Lone 176 :: Lone 198 :: Sticky Note dr2:52","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Hfc1m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++は境界検査や所有権追跡を言語が強制しないため脆弱性が実行時まで露出しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"MEYkq","x":3576,"y":13380,"name":"L1-10::Group 5 :: Group 1 :: Lone 338 :: Lone 382 :: Sticky Note dr6:20","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wtQH8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++のヘッダ＋リンカモデルは当時の計算資源制約で分割コンパイルを成立させる実用解だった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"istM5","x":2724,"y":13580,"name":"L1-10::Group 5 :: Group 1 :: Lone 339 :: Lone 383 :: Sticky Note dr6:21","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DZXoO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++のヘッダ文化は宣言定義二重管理とODR問題と再コンパイル肥大を長期負債として残した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"NLOth","x":3008,"y":13580,"name":"L1-10::Group 5 :: Group 1 :: Lone 446 :: Lone 500 :: Sticky Note dr12:76","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mb5Sm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++のメモリ安全欠陥は重大脆弱性の主要因として長年報告されている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"f2AdU","x":3292,"y":13580,"name":"L1-10::Group 5 :: Group 1 :: Lone 605 :: Lone 669 :: Sticky Note dr16:46","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"84OVr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++は#include前処理と翻訳単位分割で黎明期ハードウェア制約に適応した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"OWmx7","x":3576,"y":13580,"name":"L1-10::Group 5 :: Group 1 :: Lone 606 :: Lone 670 :: Sticky Note dr16:47","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sAyKp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代C++では巨大ヘッダ再パースがコンパイル時間の主要ボトルネックになっている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"nyL0z","x":2724,"y":13780,"name":"L1-10::Group 5 :: Group 1 :: Lone 623 :: Lone 687 :: Sticky Note dr16:79","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tAuQL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++ヘッダモデルは大規模化でビルド時間破綻を招き、Modules移行が進行中である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QwJ6V","x":3008,"y":13780,"name":"L1-10::Group 5 :: Group 1 :: Lone 644 :: Lone 714 :: Sticky Note nishio:37","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"juLjk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CとC++はGCを前提にせず、手動管理やRAIIで性能制御を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"69sBI","x":3292,"y":13780,"name":"L1-10::Group 5 :: Group 1 :: Lone 647 :: Lone 717 :: Sticky Note nishio:40","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FT2Bw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CとC++は未初期化を許す設計で、性能と安全性の責任を開発者に置く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Nf5RB","x":2724,"y":14980,"name":"L1-10::Group 9 :: Group 1 :: Group 33 :: Group 131 :: Sticky Note nishio:28","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rK2BJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は演算子オーバーロードを許し、表現力と可読性のトレードオフがある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Vi7zJ","x":3008,"y":14980,"name":"L1-10::Group 9 :: Group 1 :: Group 50 :: Lone 406 :: Sticky Note dr6:61","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"r2wMv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は`constexpr`とConcepts導入で旧来テンプレートメタプログラミングの難読性を緩和している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"T90Sp","x":3292,"y":14780,"name":"L1-10::Group 9 :: Group 1 :: Group 106 :: Group 119 :: Sticky Note dr11:47","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iyAQg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ ConceptsはSFINAE依存の複雑な回避策を減らし安全な汎用設計を促した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"G3xXk","x":3576,"y":14780,"name":"L1-10::Group 9 :: Group 1 :: Group 106 :: Group 119 :: Sticky Note dr16:83","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aIyuF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ TMPはSFINAE時代の可読性危機を経てConceptsで制約記述を明示化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"nBVXp","x":3292,"y":14980,"name":"L1-10::Group 9 :: Group 1 :: Lone 269 :: Lone 307 :: Sticky Note dr4:63","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7lRpo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++はテンプレート柔軟性の代償として診断が内部表現寄りで長文化しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4I8qB","x":3576,"y":14980,"name":"L1-10::Group 9 :: Group 1 :: Lone 293 :: Lone 335 :: Sticky Note dr4:99","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0uBMu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は>>曖昧性やdecltypeやrequiresなど文脈依存が強く完全パースが難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"JmLbk","x":2724,"y":15180,"name":"L1-10::Group 9 :: Group 1 :: Lone 357 :: Lone 405 :: Sticky Note dr6:60","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IQThL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++テンプレートメタプログラミングは高表現力を得る一方で可読性低下とコンパイル遅延を悪化させやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"eB3la","x":3008,"y":15180,"name":"L1-10::Group 9 :: Group 1 :: Lone 502 :: Lone 559 :: Sticky Note dr14:18","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ojTJH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のMost Vexing Parseは文脈依存文法が開発体験を悪化させる典型例である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"oWGN3","x":3576,"y":15180,"name":"L1-10::Group 10 :: Group 1 :: Group 64 :: Group 64 :: Sticky Note dr2:53","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Lpog5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のRAIIはリソース寿命をスコープへ結び付けて例外時解放を自動化する設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5ptN0","x":3292,"y":15180,"name":"L1-10::Group 10 :: Group 1 :: Group 64 :: Group 64 :: Sticky Note dr12:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D9u6T","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のRAIIはスコープ終了時解放を言語習慣として定着させた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"gnE2v","x":2724,"y":15380,"name":"L1-10::Group 10 :: Group 1 :: Lone 300 :: Lone 342 :: Sticky Note dr5:5","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ACuWH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の例外はRAIIと組み合わせて後始末を自動化できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Btgmj","x":3008,"y":15380,"name":"L1-10::Group 10 :: Group 1 :: Lone 301 :: Lone 343 :: Sticky Note dr5:6","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RK1zJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の例外は例外安全保証とABI懸念の運用コストが高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"MnGSC","x":3292,"y":15380,"name":"L1-10::Group 10 :: Group 1 :: Lone 326 :: Lone 370 :: Sticky Note dr5:60","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EAZbR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++低遅延領域では例外禁止方針が採られライブラリ設計制約が強くなる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"eC8dj","x":3576,"y":15380,"name":"L1-10::Group 10 :: Group 1 :: Lone 516 :: Lone 576 :: Sticky Note dr14:48","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nf348","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++とRustのRAIIは安全性が高い一方で制御フローの可視性を下げる場面がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"10sBe","x":2724,"y":15580,"name":"L1-10::Group 10 :: Group 1 :: Lone 560 :: Lone 621 :: Sticky Note dr15:29","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5TDPa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ 例外は stack unwinding と RAII に依存し安全性と性能の設計トレードオフが大きい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"EkS9a","x":3008,"y":15580,"name":"L1-10::Group 10 :: Group 1 :: Lone 563 :: Lone 624 :: Sticky Note dr15:32","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uDxIL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"高性能領域では C++ 例外を無効化してエラーコードへ戻す運用が今も多い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"dxamx","x":3008,"y":14380,"name":"L1-10::Group 19 :: Group 1 :: Group 40 :: Group 36 :: Sticky Note dr13:88","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tyhJT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20のstd::jthreadは自動joinと停止要求でこの欠点を補った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HsrTD","x":3576,"y":14380,"name":"L1-10::Group 19 :: Group 1 :: Group 50 :: Group 88 :: Sticky Note dr4:64","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iJXzp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20以降はconceptsなどにより診断可読性が段階的に改善している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"RniY9","x":3292,"y":14380,"name":"L1-10::Group 19 :: Group 1 