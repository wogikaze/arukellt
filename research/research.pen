text","id":"bTgpT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cではx == y & zが(x == y) & zとして解釈されるため意図確認が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"oXEZy","x":668,"y":8060,"name":"L1-7::Group 255 :: Group 1 :: Lone 630 :: Lone 696 :: Sticky Note nishio:11","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xYZy2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cではintのビット幅が環境依存で、移植時に追加確認が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5XN8c","x":384,"y":11260,"name":"L1-7::Group 259 :: Group 1 :: Lone 664 :: Lone 738 :: Sticky Note nishio:70","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"p0YSp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SMLは負数リテラルに~1記法を使う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"nYoeG","x":668,"y":13260,"name":"L1-7::Lone 263 :: Group 1 :: Group 2 :: Lone 294 :: Sticky Note dr4:43","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OFBH9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptコミュニティではASI由来の罠を避けるためlint規約が重視された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":