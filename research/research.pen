[{"type":"text","id":"aOe8o","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftとKotlinのnull処理差は言語哲学の違いであり可読性と簡潔性のトレードオフを生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"LrYdf","x":3576,"y":3860,"name":"L1-5::Group 168 :: Group 1 :: Group 81 :: Group 87 :: Sticky Note dr4:54","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BP1Xo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのdeferは後始末処理を局所化して読みやすさを高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"UTK2n","x":3292,"y":4660,"name":"L1-5::Group 170 :: Group 1 :: Group 8 :: Lone 416 :: Sticky Note dr11:10","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A5Lvv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartの non-nullable by default はAOT最適化を改善しFlutter実行性能とバイナリ効率を押し上げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"voPhm","x":2724,"y":5260,"name":"L1-5::Group 173 :: Group 1 :: Group 16 :: Group 18 :: Sticky Note dr6:49","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gkEQG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのアノテーション依存は設定の可視性低下とビルド複雑化を招きアノテーション地獄と批判される。","lin