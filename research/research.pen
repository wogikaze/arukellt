","content":"PostScriptとForthは逆ポーランド記法で優先順位括弧への依存を減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"r0AUU","x":952,"y":10660,"name":"L1-7::Lone 368 :: Group 1 :: Lone 643 :: Lone 713 :: Sticky Note nishio:35","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YrLgS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Perl系でもC3 MROを採用する実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"6HFha","x":668,"y":7260,"name":"L1-7::Lone 370 :: Group 1 :: Lone 648 :: Lone 718 :: Sticky Note nishio:41","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"llMWn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"初期化強制の言語は未定義値起因のバグを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"LE3ZU","x":384,"y":9660,"name":"L1-7::Lone 371 :: Group 1 :: Lone 660 :: Lone 734 :: Sticky Note nishio:65","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fn5b2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pascalは算術と比較と論理の優先順位を明確に分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"kI8UU","x":668,"y":4660,"name":"L1-7::Lone 372 :: Group 1 :: Lone 663 :: Lo