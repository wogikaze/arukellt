ainer","content":"Denoはnode_modules依存を弱めURLベース取り込みでWeb標準寄りの運用を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"6fPEa","x":100,"y":5260,"name":"L1-7::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr3:66","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"P54Zl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futhark は OpenCL や GPU カーネル生成の詳細をコンパイラに隠蔽し、自動並列化を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hbaej","x":952,"y":5060,"name":"L1-7::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr13:74","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VjbjB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"FutharkはOpenCL生成で高性能と可搬性の両立を目指す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"7lLD9","x":384,"y":5260,"name":"L1-7::Group 24 :: Group 1 :: Lone 225 :: Lone 253 :: Sticky Note dr3:65","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vW9FO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futhark は純関数データ並列言語として map、reduce、scan を中核に据える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"xe9KF","x":952,