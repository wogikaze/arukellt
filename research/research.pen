","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PAldU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Do-file エディタの構文強調と折りたたみは forvalues や if/else の異常検出に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rdHfv","x":100,"y":9060,"name":"L1-7::Group 221 :: Group 1 :: Lone 270 :: Lone 310 :: Sticky Note dr4:67","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GCMLJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GleamはBEAM上で型安全と親切な診断を両立する方針を明確にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"8vwQW","x":384,"y":9060,"name":"L1-7::Group 221 :: Group 1 :: Lone 415 :: Lone 465 :: Sticky Note dr12:25","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RSaGp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMのコピーGCはライブデータ量次第で2倍近いメモリ余裕を要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"2GsNv","x":384,"y":3460,"name":"L1-7::Group 222 :: Group 1 :: Lone 508 :: Lone 565 :: Sticky Note dr14:27","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text"