me","id":"26SLz","x":3008,"y":6460,"name":"L1-5::Group 44 :: Group 1 :: Group 82 :: Group 89 :: Sticky Note dr4:77","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jU0AD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3はenum導入や構文整理で教育容易性と可読性を重視する方向に寄せた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TM3lE","x":2724,"y":6460,"name":"L1-5::Group 44 :: Group 1 :: Group 82 :: Group 89 :: Sticky Note dr14:12","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VMrFa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3は任意の波括弧省略を導入し可読性と学習容易性を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"G06cv","x":3576,"y":6260,"name":"L1-5::Group 44 :: Group 1 :: Group 105 :: Group 118 :: Sticky Note dr14:37","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MaKEo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3はimplicitの分割により抽象化能力を保ったまま予測可能性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"eHAgE","x":2724,"y":4260,"name":"L1-5::Group 48 :: Group 1 :: Lone 166 :: Lone 182 :: Sticky Note dr2:30","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7uSkz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaはポーズ分散に有利だが総GC時間と実装複雑性の増加を伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"M3JFI","x":3008,"y":4260,"name":"L1-5::Group 48 :: Group 1 :: Lone 233 :: Lone 262 :: Sticky Note dr4:2","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dPG4e","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文はパーサ実装が比較的容易で処理系実装コストを抑えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pVGOs","x":3292,"y":4260,"name":"L1-5::Group 48 :: Group 1 :: Lone 283 :: Lone 325 :: Sticky Note dr4:86","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Regyg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSP時代では構文複雑性がそのままツール実装コストと普及速度に反映される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"w2yhM","x":3576,"y":4260,"name":"L1-5::Group 48 :: Group 1 :: Lone 406 :: Lone 456 :: Sticky Note dr12:9","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Fn0fP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"低レイテンシGCはCPUオーバーヘッドと実装複雑性を代償にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SGx7h","x":2724,"y":4460,"name":"L1-5::Group 48 :: Group 1 :: Lone 517 :: Lone 577 :: Sticky Note dr14:49","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"e7weI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのdeferは終了処理を単純化するが実装コスト特性の理解は必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vrToX","x":3008,"y":4860,"name":"L1-5::Group 50 :: Group 1 :: Lone 343 :: Lone 387 :: Sticky Note dr6:29","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oxJwP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lisp系マクロ文化は表現力が高い反面で方言ごとの慣習学習を必須にし読解障壁を上げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"aXCHl","x":3292,"y":4860,"name":"L1-5::Group 50 :: Group 1 :: Lone 346 :: Lone 391 :: Sticky Note dr6:36","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nrtLm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"NimのASTマクロはC系文法のままLisp級メタプログラミングを提供しDSL柔軟性を高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SWJaR","x":3576,"y":4860,"name":"L1-5::Group 50 :: Group 1 :: Lone 347 :: Lone 392 :: Sticky Note dr6:37","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OEYaw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Nimの強力マクロは表現力の対価としてコンパイラ理解と学習コストを増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"AAxvf","x":2724,"y":5060,"name":"L1-5::Group 50 :: Group 1 :: Lone 613 :: Lone 677 :: Sticky Note dr16:56","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iz45L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispマクロは言語拡張力が高い一方で構文文化差による学習障壁を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ILe41","x":3008,"y":5060,"name":"L1-5::Group 50 :: Group 1 :: Lone 614 :: Lone 678 :: Sticky Note dr16:60","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wCMoP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"NimはAST操作マクロを静的型付け言語に統合し、DSL実装力を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qavnw","x":2724,"y":6060,"name":"L1-5::Group 61 :: Group 1 :: Group 37 :: Group 31 :: Sticky Note dr2:21","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"la