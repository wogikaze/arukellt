et":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Lj0j9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElmはCompiler Errors for Humansで診断を主要UIとして再定義した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"egCMD","x":384,"y":11460,"name":"L1-7::Group 29 :: Group 1 :: Lone 520 :: Lone 580 :: Sticky Note dr14:52","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XGk53","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elmの診断は該当コード提示と平易な説明で修正ループを短縮する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Ma9kl","x":384,"y":6660,"name":"L1-7::Group 30 :: Group 1 :: Group 27 :: Group 37 :: Sticky Note dr14:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZoTWY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのguardで束縛した値は後続スコープで安全に利用できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ZF45k","x":668,"y":6660,"name":"L1-7::Group 30 :: Group 1 :: Group 52 :: Group 124 :: Sticky Note dr13:63","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ap0LZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのwithTaskGroupはスコープ外タスク漏出を防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QVxvC","x":384,"y":9260,"name":"L1-7::Group 31 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr3:54","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oTBpQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Structured Concurrency は fire-and-forget を抑制し、タスク生成と join を同一スコープに閉じる原則を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"dZKnf","x":668,"y":9260,"name":"L1-7::Group 31 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr3:55","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1U37u","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Structured Concurrency の目的はエラー伝搬、キャンセル、リソース回収を親子タスク木で一貫化することにある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5FNaS","x":100,"y":9260,"name":"L1-7::Group 31 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr15:66","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TCo31","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Project Loom の Structured Concurrency は親子タスクのライフサイクルを統合管理する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"V6InF","x":952,"y":9260,"name":"L1-7::Group 31 :: Group 1 :: Lone 474 :: Lone 528 :: Sticky Note dr13:59","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xxO5q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"構造化並行性はfire-and-forget起因のリークと例外消失を減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"r5GiM","x":952,"y":3460,"name":"L1-7::Group 32 :: Group 1 :: Group 7 :: Group 11 :: Sticky Note dr2:22","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fhvks","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/BEAMは軽量プロセスごとに独立ヒープを持つプロセス局所GCを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TGnFC","x":668,"y":3460,"name":"L1-7::Group 32 :: Group 1 :: Group 7 :: Group 11 :: Sticky Note dr12:21","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xBzPT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ErlangのBEAMはプロセスごとに独立ヒープを持ち全体STWを回避しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"yyXmg","x":100,"y":3660,"name":"L1-7::Group 32 :: Group 1 :: Lone 117 :: Group 11 :: Sticky Note dr12:22","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"o