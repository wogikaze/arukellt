xed-width","width":"fill_container","content":"Pony はアクターモデルに reference capabilities を組み合わせ、参照エイリアス可能性を型で表現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GVmcm","x":3576,"y":19040,"name":"L1-3::Group 178 :: Group 1 :: Group 55 :: Group 51 :: Sticky Note dr1:8","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nxph8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dart初期版は型注釈を任意にするoptional typingで段階的導入の書きやすさを優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Vct7M","x":2724,"y":19240,"name":"L1-3::Group 178 :: Group 1 :: Group 55 :: Group 51 :: Sticky Note dr1:9","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IWxmZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dart初期版のoptional typingはnull由来不具合の抑止が弱く型と実行時挙動の整合性に課題を残した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GOavU","x":3292,"y":19840,"name":"L1-3::Group 181 :: Group 1 :: Group 67 :: Group 67 :: Sticky Note dr2:61","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z0fsp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cycloneはリージョン注釈と型安全を組み合わせてGCなし安全性を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1ToiJ","x":3008,"y":19840,"name":"L1-3::Group 181 :: Group 1 :: Group 67 :: Group 67 :: Sticky Note dr12:58","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LDn3F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cycloneはリージョンと型安全を組み合わせてC系安全化を試みた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"bpBXX","x":3008,"y":19640,"name":"L1-3::Group 187 :: Group 1 :: Group 93 :: Group 102 :: Sticky Note dr5:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XpEfU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Unisonのabilitiesは関数依存効果を型に載せてハンドラ分離を促進する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HyzhP","x":2724,"y":18040,"name":"L1-3::Group 196 :: Group 1 :: Lone 141 :: Lone 156 :: Sticky Note dr1:56","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1i4uk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Option系モデリングは不在ケースを型レベルに持ち上げて網羅的処理を強制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YLdpp","x":3576,"y":20040,"name":"L1-3::Group 244 :: Group 1 :: Lone 460 :: Lone 514 :: Sticky Note dr13:19","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kKGH7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ponylangのisoとvalは可変共有の危険を型で表現して回避する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ehjMN","x":3576,"y":18840,"name":"L1-3::Lone 262 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note nishio:58","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qQJxT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptは整数専用型を基本仕様に持たない時代が長かった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vmIg8","x":3008,"y":19240,"name":"L1-3::Lone 268 :: Group 1 :: Group 43 :: Group 40 :: Sticky Note dr15:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zHjaA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift 6 の typed throws は throws(NetworkError) のような型付き伝播を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fw42R","x":3008,"y":19440,"name":"L1-3::Lone 273 :: Group 1 :: Lone 144 :: Lone 159 :: Sticky Note dr1:59","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XR3Gu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OptionやMaybeの冗長性は高信頼領域では受容されやすいがスクリプト用途では負担になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"flVUg","x":3576,"y":19640,"name":"L1-3::Lone 297 :: Group 1 :: Lone 321 :: Lone 365 :: Sticky Note dr5:54","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Xfvrp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Effect Systemは例外やI/Oなどの効果を型で追跡する研究領域である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zBO3P","x":2724,"y":19040,"name":"L1-3::Lone 302 :: Group 1 :: Lone 373 :: Lone 423 :: Sticky Note dr11:19","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bHJyo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftの過負荷解決と暗黙変換は型チェック遅延を招きコンパイラ最適化を継続的に必要とした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ZWCkp","x":3292,"y":20040,"name":"L1-3::Lone 310 :: Group 1 :: Lone 388 :: Lone 438 :: Sticky Note dr11:40","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zeJ2d","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 5は移行互換性のため型消去を選び実行時型情報欠落とボクシング負荷を受容した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Jm3ja","x":3576,"y":19840,"name":"L1-3::Lone 311 :: Group 1 :: Lone 394 :: Lone 444 :: Sticky Note dr11:48","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xKqDo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのAssociated Typesはプロトコル内の型関係を簡潔に記述するための仕組みである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FkFx9","x":3292,"y":19440,"name":"L1-3::Lone 323 :: Group 1 :: Lone 447 :: Lone 501 :: Sticky Note dr12:77","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uRyBv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CISAやNSAはMemory Safe Languages移行を促すロードマップ策定を推奨している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"yv3AC","x":3008,"y":20240,"name":"L1-3::Lone 374 :: Group 1 :: Lone 669 :: Lone 743 :: Sticky Note nishio:76","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TCN5Y","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ML系では多相参照に関する型安全性問題が歴史的に議論された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KO52H","x":1696,"y":5660,"name":"L1-6::Group 16 :: Group 1 :: Group 3 :: Lone 308 :: Sticky Note dr4:65","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"W8XKf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは高度な型推論を優先してきた歴史から診断難解性の批判が根強い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"dnWQp","x":1696,"y":3460,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr6:30","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GX0hD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`macro_rules!`はCプリプロセッサより構文安全な宣言的マクロでDSL的記述を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"dqR5f","x":1980,"y":3460,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr6:32","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EZta6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`proc_macro`は`#[derive]`や属性マクロで高度なコード生成を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rlsXn","x":2264,"y":3260,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr16:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BG2h2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust macro_rules!は衛生的な定型展開に強く、proc_macroは高度生成に向く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qGVCF","x":1412,"y":3460,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr16:58","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9NWA5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust proc_macroはsynやquote依存を含めてコンパイル時間を押し上げやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5uG3d","x":2264,"y":3460,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Lone 402 :: Sticky Note dr6:53","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4OiCA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのユーザー定義`derive`は便利だが内部的に`proc_macro`依存を増やしビルド時間に影響する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qaKqG","x":1412,"y":3660,"name":"L1-6::Group 17 :: Group 1 :: Lone 344 :: Lone 388 :: Sticky Note dr6:31","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MLtyB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの宣言的マクロは便利だが展開エラーの読みにくさと設計難度が普及の摩擦になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tA7JH","x":1696,"y":3660,"name":"L1-6::Group 17 :: Group 1 :: Lone 345 :: Lone 389 :: Sticky Note dr6:33","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"r0aqM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの手続き的マクロはボイラープレート削減に効く一方で追加crateビルドによりコンパイル時間を押し上げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"v77r8","x":1980,"y":4460,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Group 44 :: Sticky Note dr6:26","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4vQjM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権解析と強い型検査をコンパイル時に集中させるため安全性と引き換えにビルドが重くなる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"BJXeX","x":1412,"y":4460,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Group 44 :: Sticky Note dr12:35","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5hjaE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権、借用、ライフタイムをコンパイル時検査してメモリ安全性を得る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"O8v6a","x":1696,"y":4460,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Group 44 :: Sticky Note dr13:16","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JwdH5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権とMoveにより送信後アクセス禁止をコンパイル時に保証する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hF9Vp","x":2264,"y":4460,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Lone 190 :: Sticky Note dr2:41","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z8O1d","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは実行時コストを抑えて安全性を得る代わりに学習コストをコンパイル時へ移した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"yqMOG","x":1412,"y":4660,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Lone 321 :: Sticky Note dr4:80","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"u1Jth","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権と借用で安全性と性能を両立する代わりに学習曲線を急にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zaHTm","x":1696,"y":4660,"name":"L1-6::Group 25 :: Group 1 :: Lone 168 :: Lone 189 :: Sticky Note dr2:40","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":1