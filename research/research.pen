,"x":3292,"y":5660,"name":"L1-5::Group 11 :: Group 1 :: Lone 152 :: Lone 167 :: Sticky Note dr2:8","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3shqR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは一般ユーザにとって運用容易性を高めた一方で特殊ワークロード向けの細粒度制御は弱い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1SF4D","x":3576,"y":5660,"name":"L1-5::Group 11 :: Group 1 :: Lone 273 :: Lone 313 :: Sticky Note dr4:70","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iOKs6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの単純さは習得容易性を高める一方で抽象化不足の批判も受ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"VkueV","x":2724,"y":5860,"name":"L1-5::Group 11 :: Group 1 :: Lone 624 :: Lone 688 :: Sticky Note dr16:82","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YMHvy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go依存管理移行は技術的成功とコミュニティ合意形成の難しさを同時に示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"k5OKR","x":3292,"y":6660,"name":"L1-5::Group 16 :: Group 1 :: Group 3 :: Lone 309 :: Sticky Note dr4:66","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","off