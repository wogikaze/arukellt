ntainer","content":"SwiftとObjective-Cの混在環境では構文感覚の切替が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"7z3eM","x":668,"y":5260,"name":"L1-7::Group 34 :: Group 1 :: Group 13 :: Group 25 :: Sticky Note dr12:32","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MxWPW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftとObjective-CのARCはGCより予測可能な解放タイミングを提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ajBm7","x":100,"y":8260,"name":"L1-7::Group 35 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr1:52","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CeD7H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはoptionalを早期unwrapして以後をnon-optionalとして記述する文体を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"vb2TP","x":952,"y":8060,"name":"L1-7::Group 35 :: Group 1 :: Group 11 :: Group 56 :: Sticky Note dr1:46","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1OFJN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはif letとguard中心の制御構造でoptionalを早期処理する傾向がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"nTjI3","x":