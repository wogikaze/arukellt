":"Elixir は BEAM の並行性と耐障害性を継承しつつ、モダンな構文とマクロで開発体験を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GSYFi","x":3576,"y":22300,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Lone 567 :: Sticky Note dr14:31","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"e1UhW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはErlangの強固な耐障害性を保ちながら構文障壁を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"CYoCh","x":3292,"y":22500,"name":"L1-11::Group 2 :: Group 1 :: Group 25 :: Group 19 :: Sticky Note dr3:13","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uGKBz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elixir は OTP を DSL 的に扱いやすくし、Phoenix などの Web 開発でアクターモデル活用を広げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4IX3s","x":3576,"y":22500,"name":"L1-11::Group 2 :: Group 1 :: Group 25 :: Group 19 :: Sticky Note dr4:28","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SHiRg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはPhoenixなどを通じてRuby経験者の関数型移行を促進した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"RKVak","x":2724,"y