y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Glfd7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Modulesの実務普及は既存コードとビルドツール互換の移行コストにより段階的に進んでいる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"p4mXf","x":3576,"y":14580,"name":"L1-10::Group 19 :: Group 1 :: Lone 607 :: Lone 671 :: Sticky Note dr16:49","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oCGRh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Modulesはツールチェーン差異と既存資産移行の難しさで普及が漸進的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"041a5","x":2724,"y":16780,"name":"L1-10::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr3:67","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TqMz3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futhark コンパイラは高水準記述を GPU 向けカーネル群とホストコードへ変換して最適化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"6vA39","x":2724,"y":14780,"name":"L1-10::Group 49 :: Group 1 :: Lone 226 :: Lone 254 :: Sticky Note dr3:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DXAbP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の std::simd 構想は fearless SIMD を掲げ、unsafe を減らした型安全なベクトル演算を目指す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Fi3IY","x":3008,"y":14780,"name":"L1-10::Group 49 :: Group 1 :: Lone 484 :: Lone 538 :: Sticky Note dr13:76","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Fj3a8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"std::simdは対応命令へ最適化し非対応環境では安全にスカラへフォールバックする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"M53jz","x":2724,"y":15780,"name":"L1-10::Group 60 :: Group 1 :: Group 33 :: Lone 701 :: Sticky Note nishio:18","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pS2bo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は関数オブジェクトで呼び出し演算子をオーバーロードできる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wAhd3","x":3008,"y":15780,"name":"L1-10::Group 60 :: Group 1 :: Lone 278 :: Lone 319 :: Sticky Note dr4:78","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3N6nV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は後方互換を維持しながら機能追加を重ねた結果として仕様が肥大化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","