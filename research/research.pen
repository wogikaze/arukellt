ent":"Objective-CのMRCは手動所有権管理により解放漏れと二重解放が起きやすかった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9zQfj","x":952,"y":3060,"name":"L1-7::Group 172 :: Group 1 :: Group 13 :: Lone 188 :: Sticky Note dr2:39","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eOJs4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Objective-CのARC移行はMRCボイラープレート削減に有効だったが混在運用で移行負荷が残った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Y6SV6","x":100,"y":7860,"name":"L1-7::Group 175 :: Group 1 :: Lone 428 :: Lone 480 :: Sticky Note dr12:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A6jhZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Odinは暗黙context経由でAllocatorを伝播し記述量を削減する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Ft25h","x":100,"y":13660,"name":"L1-7::Group 177 :: Group 1 :: Group 39 :: Group 33 :: Sticky Note dr13:18","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ATAoQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PonylangはアクターモデルにReference Capabilitiesを統合した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"QGYMt","x":668,"y":6260