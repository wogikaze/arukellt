:"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MVJAS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cの配列範囲外アクセスは未定義動作でクラッシュや脆弱性につながる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"phdC0","x":3008,"y":15980,"name":"L1-10::Group 70 :: Group 1 :: Group 65 :: Group 65 :: Sticky Note dr2:55","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3DHQi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のunique_ptrは単一所有権を型で表して二重解放とリークを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ivBBx","x":2724,"y":15980,"name":"L1-10::Group 70 :: Group 1 :: Group 65 :: Group 65 :: Sticky Note dr12:46","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aoV77","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のstd::unique_ptrは単一所有権を明示して解放責務を単純化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hNwTJ","x":3576,"y":15980,"name":"L1-10::Group 70 :: Group 1 :: Group 66 :: Group 66 :: Sticky Note dr2:56","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WOa20","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のshared_ptrは共有所有権を実現する一方で循環参照と原子参照更新コストを生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"EAV01","x":3292,"y":15980,"name":"L1-10::Group 70 :: Group 1 :: Group 66 :: Group 66 :: Sticky Note dr12:47","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PYFW9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のstd::shared_ptrは共有所有を扱えるが参照カウントコストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Ju7vC","x":3008,"y":13980,"name":"L1-10::Group 85 :: Group 1 :: Lone 336 :: Lone 380 :: Sticky Note dr6:18","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"G580H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の`friend`は公開APIを増やさず密結合協調を実現する例外アクセス機構として導入された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hK40i","x":3292,"y":13980,"name":"L1-10::Group 85 :: Group 1 :: Lone 337 :: Lone 381 :: Sticky Note dr6:19","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cOiYU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の`friend`は演算子実装などで有効だが乱用するとカプセル化と依存可読性を損なう。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rly2H","x":3576,"y":13980,"name":"L1-10::Group 85 :: Group 1 :: Lone 602 :: Lone 666 :: Sticky Note dr16:42","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tUl2a","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ friendは非メンバ演算子や密結合コンポーネントの効率的連携に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"TvBw7","x":2724,"y":14180,"name":"L1-10::Group 85 :: Group 1 :: Lone 603 :: Lone 667 :: Sticky Note dr16:43","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"748LI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ friendは責務分離不足のコードで乱用されると保守性を悪化させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"VXqVv","x":3008,"y":16580,"name":"L1-10::Group 108 :: Group 1 :: Lone 208 :: Lone 234 :: Sticky Note dr3:19","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ma98b","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pony は実行時オーバーヘッドを抑えるため、ケイパビリティ検査を主にコンパイル時に行う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"eBLmJ","x":3576,"y":14180,"name":"L1-10::Group 109 :: Group 1 :: Group 40 :: Group 36 :: Sticky Note dr3:78","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AtME3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ の std::thread は join と detach の管理責務が重く、低レベル過ぎるという批判を受ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fOKpY","x":3292,"y":14180,"name":"L1-10::Group 109 :: Group 1 :: Group 40 :: Group 36 :: Sticky Note dr13:86","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xrNhd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++11のstd::threadはjoinまたはdetach忘れでstd::terminateを招く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"C1hEo","x":2724,"y":14380,"name":"L1-10::Group 109 :: Group 1 :: Lone 231 :: Lone 260 :: Sticky Note dr3:79","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AYzql","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ では std::thread の上位抽象として std::async や Boost.Asio や独自スレッドプールの利用が一般化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"WTAot","x":3292,"y":15580,"name":"L1-10::Group 120 :: Group 1 :: Group 101 :: Group 112 :: Sticky Note dr6:44","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PEU9Y","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"D言語CTFEは通常関数をコンパイル時実行可能にしてテンプレート依存を緩和した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1oLOw","x":3576,"y":16780,"name":"L1-10::Group 132 :: Group 1 :: Lone 235 :: Lone 265 :: Sticky Note dr4:5","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TxSPz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文では波括弧対応やセミコロン漏れが日常的な構文エラー要因になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"qEMNt","x":2724,"y":16980,"name":"L1-10::Group 132 :: Group 1 :: Lone 670 :: Lone 744 :: Sticky Note nishio:77","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LKd9z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはインデントと実際の構文ブロックがずれるコードを書けてしまう。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"iOgjw","x":3008,"y":16380,"name":"L1-10::Group 136 :: Group 1 :: Lone 294 :: Lone 336 :: Sticky Note dr4:100","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2L2Y7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ClangとGCCはC++実装における事実上の参照実装として重い役割を担う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"OMiga","x":3292,"y":16380,"name":"L1-10::Group 136 :: Group 1 :: Lone 568 :: Lone 631 :: Sticky Note dr15:47","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LSQx4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の実装は C++ 風の重い unwind ではなく戻り値ベース変換で効率を確保する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"cJHjv","x":3576,"y":15580,"name":"L1-10::Group 140 :: Group 1 :: Lone 503 :: Lone 560 :: Sticky Note dr14:19","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2a1Dr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代言語はC++的な曖昧性を避けるため決定論的な構文解析を志向する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"5hnDs","x":2724,"y":16180,"name":"L1-10::Group 141 :: Group 1 :: Lone 561 :: Lone 622 :: Sticky Note dr15:30","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HFJOc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ の基本保証は例外時でもリソースリークを防ぐことを要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"umOsZ","x":3008,"y":16180,"name":"L1-10::Group 141 :: Group 1 :: Lone 562 :: Lone 623 :: Sticky Note dr15:31","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ODtjo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ の強い保証は失敗時の完全ロールバックを要求し copy-and-swap などのコストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"lr3IF","x":3292,"y":16180,"name":"L1-10::Group 141 :: Group 1 :: Lone 658 :: Lone 732 :: Sticky Note nishio:62","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eOvYS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++とJavaはconstやfinalで再代入禁止を局所的に指定する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"erpVk","x":3008,"y":16980,"name":"L1-10::Group 142 :: Group 1 :: Lone 675 :: Lone 750 :: Sticky Note nishio:87","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dsha5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyとC++の文字列は破壊的更新を許す実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"rlpGL","x":3292,"y":16580,"name":"L1-10::Group 158 :: Group 1 :: Lone 640 :: Lone 709 :: Sticky Note nishio:31","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aWhxK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の多重継承はダイヤモンド問題を生みうる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"mVz5s","x":3292,"y":16980,"name":"L1-10::Group 163 :: Group 1 :: Group 2 :: Lone 264 :: Sticky Note dr4:4","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ugal5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文の普及はC, C++, Java, C#, JavaScript間の学習移行を容易にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Paw3r","x":3576,"y":16980,"name":"L1-10::Group 163 :: Group 1 :: Lone 681 :: Lone 757 :: Sticky Note nishio:101","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Whz8i","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++はCの型システムを拡張してクラスと継承を導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"MNrww","x":2724,"y":13180,"name":"L1-10::Group 185 :: Group 1 :: Lone 298 :: Lone 340 :: Sticky Note dr5:3","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MXrH3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはエラーコード返却を中心とするため呼び出し側のチェック漏れが起きやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Stg8g","x":3576,"y":16180,"name":"L1-10::Group 201 :: Group 1 :: Lone 177 :: Lone 199 :: Sticky Note dr2:54","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"32Tea","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のRAIIは強力だがコピー/ムーブ設計を誤ると所有権バグを招く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Kv1Iz","x":3576,"y":16380,"name":"L1-10::Group 226 :: Group 1 :: Lone 649 :: Lone 720 :: Sticky Note nishio:44","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PwVJz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはグローバル変数を直接定義できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"2pjkT","x":2724,"y":16580,"name":"L1-10::Group 236 :: Group 1 :: Lone 362 :: Lone 411 :: Sticky Note dr6:67","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VQGdm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"インクリメンタルコンパイルは開発体験を改善するがC/C++とRustでは依存構造次第で限界が残る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"76IWY","x":2724,"y":16380,"name":"L1-10::Group 241 :: Group 1 :: Lone 425 :: Lone 475 :: Sticky Note dr12:44","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"w6ddC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cのmalloc/free運用はリーク、二重解放、Use-after-freeの温床になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"zDsDY","x":3008,"y":16780,"name":"L1-10::Group 254 :: Group 1 :: Lone 628 :: Lone 693 :: Sticky Note nishio:7","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"deVJZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cの関数引数は値渡しであり、参照的な更新はポインタ値を渡して実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ROti8","x":3292,"y":16780,"name":"L1-10::Group 254 :: Group 1 :: Lone 632 :: Lone 699 :: Sticky Note nishio:16","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xNM5X","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cは関数ポインタを作成でき、高階的な呼び出しを実装できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ZHqiR","x":3008,"y":13180,"name":"L1-10::Group 255 :: Group 1 :: Lone 676 :: Lone 751 :: Sticky Note nishio:89","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"O7D02","name":"body","fill"