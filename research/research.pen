{"type":"text","id":"hdCqy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはWrite Barrierでミューテータが白オブジェクトを隠す事態を防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GCK4t","x":2264,"y":11520,"name":"L1-2::Lone 327 :: Group 1 :: Lone 454 :: Lone 508 :: Sticky Note dr13:5","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sdOmV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのselectは複数チャネル待機を一つの制御点で扱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"GqsPD","x":1980,"y":12720,"name":"L1-2::Lone 369 :: Group 1 :: Lone 646 :: Lone 716 :: Sticky Note nishio:39","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QQbr1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"リージョン推論だけでは速度要件を満たせずGC併用に戻る事例がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"37Ucp","x":2724,"y":20240,"name":"L1-3::Group 4 :: Group 1 :: Lone 206 :: Lone 230 :: Sticky Note dr3:10","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mHaUG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang の関数型スタイルは起源の影響が大きく、アクターモデル自体が関数型を必須にするわけではない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"lzu1c","x":3292,"y":18240,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:1","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iYcnT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptは既存JavaScript資産を壊さず静的型検査を段階導入できる漸進的型付けを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YAoPZ","x":3576,"y":18240,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:3","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bIsit","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptは型注釈ありと型注釈なしの混在コードでもIDEの型エラー検出と補完を提供した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ovY8x","x":2724,"y":18440,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:4","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AADhR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptの漸進的型付けは既存エコシステム互換を維持しながら型安全性を高める実務解として定着した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tMC0s","x":3008,"y":18440,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:5","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qwx4L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptのtypes as comments構想はJavaScriptエンジンが型注釈を無視する前提で設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1FcD9","x":3292,"y":18440,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:6","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6WwM5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptのtypes as comments構想は型意味論を外部型チェッカーに委譲してランタイムと型検査を分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"086TF","x":3576,"y":18440,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:7","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"19Ev7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptのtypes as comments構想はトランスパイル依存を減らして型付き構文の実行互換を高める方向を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"m8WWH","x":3292,"y":18040,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:3","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FGqn5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptはJavaScript互換を最優先して意図的に不健全な漸進的型付けを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fcu4O","x":3576,"y":18040,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:4","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z6k24","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptの any と型アサーションは移行を容易にする一方で実行時 TypeError の穴を残す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Bc1mU","x":2724,"y":18240,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:5","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UojHN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptは型消去を採用するため実行時の型安全を保証しない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YVeEs","x":3008,"y":18240,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:51","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"N2of0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptの any 依存は不正確な型定義経由で安全性崩壊を全体へ伝播させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"77vrr","x":2724,"y":18640,"name":"L1-3::Group 6 :: Group 1 :: Lone 389 :: Lone 439 :: Sticky Note dr11:41","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VuOsc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの型消去はRaw typeとの共存移行を可能にしたがヒープ汚染リスクを残した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fvg42","x":3292,"y":20240,"name":"L1-3::Group 15 :: Group 1 :: Group 3 :: Lone 657 :: Sticky Note dr16:29","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VKVjw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは同一型への複数振る舞い注入でnewtype回避策を要することが多い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"0KVIq","x":3576,"y":17640,"name":"L1-3::Group 16 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:97","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dB9dn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは型クラスと推論により1/2の具体型を決める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"H8ESg","x":2724,"y":17840,"name":"L1-3::Group 16 :: Group 1 