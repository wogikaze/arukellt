":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wWZsC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"文ベース言語は分岐と代入が分離されるため定型コードが増えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"1Qum6","x":3576,"y":5860,"name":"L1-5::Group 231 :: Group 1 :: Lone 324 :: Lone 368 :: Sticky Note dr5:58","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DGIr8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Effect System実用化には表現力と開発体験のトレードオフ解決が必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"CLOvC","x":3008,"y":4060,"name":"L1-5::Group 238 :: Group 1 :: Lone 395 :: Lone 445 :: Sticky Note dr11:49","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jPBJk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはsomeとanyを含む高度型機構により表現力を得る一方で全体複雑度が上がる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SuQZm","x":2724,"y":7660,"name":"L1-5::Group 242 :: Group 1 :: Lone 494 :: Lone 548 :: Sticky Note dr14:4","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2O9Jg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"字句選択は開発者のチャンク化と視線誘導を通じて読解速度を左右する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"9gU1q","x":3292,"y":6260,"name":"L1-5::Group 244 :: Group 1 :: Lone 462 :: Lone 516 :: Sticky Note dr13:21","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5fRZ7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ponylangは厳格な型規律のため学習コストが高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"4wmRb","x":3576,"y":7060,"name":"L1-5::Group 247 :: Group 1 :: Lone 509 :: Lone 566 :: Sticky Note dr14:28","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uZeDa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rubyのメタプログラミングとモンキーパッチは高い柔軟性と高い統制コストを併せ持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Mquia","x":3292,"y":4060,"name":"L1-5::Group 248 :: Group 1 :: Lone 527 :: Lone 587 :: Sticky Note dr14:59","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eIVKk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSP以前は言語数とエディタ数の積に比例して統合コストが増大した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Wf7Mt","x":3576,"y":4660,"name":"L1-5::Group 250 :: Group 1 :: Lone 547 :: Lone 607 :: Sticky Note dr15:8","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ne98U","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Stata 実行では log using logname.txt, replace text のようなテキストログ出力が監査性を高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"XzASL","x":2724,"y":4860,"name":"L1-5::Group 250 :: Group 1 :: Lone 550 :: Lone 610 :: Sticky Note dr15:11","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JrDg9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Stata では * コメントを使って入力データと出力物と理論前提を明示すると査読性が上がる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"HoXQK","x":3008,"y":5660,"name":"L1-5::Lone 293 :: Group 1 :: Lone 292 :: Lone 334 :: Sticky Note dr4:98","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Jkz3I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PHPは後方互換制約により関数名と引数順の一貫化を全面的に進めにくい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hBeOs","x":3292,"y":6860,"name":"L1-5::Lone 296 :: Group 1 :: Lone 314 :: Lone 358 :: Sticky Note dr5:42","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QKfGg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"値ベースエラーは制御フローを明示できるが記述量が増えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"KK8jW","x":3008,"y":3860,"name":"L1-5::Lone 299 :: Group 1 :: Lone 356 :: Lone 403 :: Sticky Note dr6:55","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oqGbz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GraalVMのポリグロットは統合余地が大きい一方で既存VM互換性と運用成熟度が普及の制約になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"FWbbI","x":3576,"y":6860,"name":"L1-5::Lone 306 :: Group 1 :: Lone 381 :: Lone 431 :: Sticky Note dr11:32","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f7DKx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ADTとmatchは不正状態を実行時ではなくコンパイル時に排除しやすくする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tgERN","x":3008,"y":4460,"name":"L1-5::Lone 308 :: Group 1 :: Lone 384 :: Lone 434 :: Sticky Note dr11:35","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IrIXW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python 3.10のmatchは構造分解能力を拡張したがキャプチャ規則が学習コストを増やした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tb8zc","x":3292,"y":4460,"name":"L1-5::Lone 328 :: Group 1 :: Lone 464 :: Lone 518 :: Sticky Note dr13:27","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WG3nR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#は非同期状態機械をコンパイラ変換で隠蔽して可読性を上げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YpdGs","x":3008,"y":6060,"name":"L1-5::Lone 331 :: Group 1 :: Lone 492 :: Lone 546 :: Sticky Note dr14:2","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"99ZCC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語アーキテクチャは理論計算機科学とHCIと実務ソフトウェア工学の交点で最適化される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"s6Al4","x":3292,"y":6460,"name":"L1-5::Lone 334 :: Group 1 :: Lone 518 :: Lone 578 :: Sticky Note dr14:50","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mDpHG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"コンパイラUXは厳格な拒否装置から学習支援装置へ進化している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Y1Kbc","x":2724,"y":7260,"name":"L1-5::Lone 337 :: Group 1 :: Lone 525 :: Lone 585 :: Sticky Note dr14:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IVyDs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Gleamは表示名に開発者が書いたimport aliasを反映して認知変換コストを下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"DbWlD","x":3292,"y":5060,"name":"L1-5::Lone 340 :: Group 1 :: Lone 533 :: Lone 593 :: Sticky Note dr14:66","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vyazv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Deno 2は実務導入拡大のためnpm互換を強化する現実路線を取っている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"YwfRv","x":3292,"y":6060,"name":"L1-5::Lone 341 :: Group 1 :: Lone 536 :: Lone 596 :: Sticky Note dr14:71","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7cpCH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"同図像性は機械処理の一貫性を高める一方で人間の視覚識別性を下げることがある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"O5PS9","x":3008,"y":7260,"name":"L1-5::Lone 347 :: Group 1 :: Lone 548 :: Lone 608 :: Sticky Note dr15:9","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VbvH0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"プレーンテキストログは SCML よりも外部ツール連携と閲覧互換性が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"UJTgj","x":3576,"y":6060,"name":"L1-5::Lone 361 :: Group 1 :: Lone 601 :: Lone 665 :: Sticky Note dr16:41","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RB0ik","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのfileprivateとprivate分離は粒度を上げる一方で学習負荷を増やした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"IcneW","x":3576,"y":6460,"name":"L1-5::Lone 364 :: Group 1 :: Lone 618 :: Lone 682 :: Sticky Note dr16:70","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gS71w","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lombokは内部API介入で既存ASTを書き換えるためIDE整合性問題を起こしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"ZyS3j","x":100,"y":3260,"name":"L1-7::Group 2 :: Group 1 :: Group 12 :: Group 71 :: Sticky Note dr13:12","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ASyJo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはBEAMとOTP資産を保持したまま構文と開発体験を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hRW2M","x":384,"y":3260,"name":"L1-7::Group 2 :: Group 1 :: Lone 349 :: Lone 394 :: Sticky Note dr6:39","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2oAIH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elixirではマクロ利用者とマクロ作者で必要知識の層が分かれやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"LsJAE","x":100,"y":5660,"name":"L1-7::Group 4 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr3:7","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mXcaD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/OTP は軽量プロセスとメッセージパッシングを中核にし、let it crash と監視ツリーで耐障害性を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"SHMr3","x":384,"y":5460,"name":"L1-7::Group 4 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr13:8","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1UF6c","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlangはメモリ非共有の軽量プロセスと非同期メッセージを中核に据える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"fGvSe","x":668,"y":5460,"name":"L1-7::Group 4 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr15:18","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bOMBf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang は let it crash を採用し回復責任をスーパーバイザ層へ分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"hF1R6","x":952,"y":5460,"name":"L1-7::Group 4 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr15:19","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uvgvh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang のアクターモデルは共有メモリを避けメッセージパッシングで障害汚染を局所化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"BKY5m","x":384,"y":5660,"name":"L1-7::Group 4 :: Group 1 :: Lone 160 :: Lone 176 :: Sticky Note dr2:23","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DDnAX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/BEAMはグローバルGCポーズを避けることで分散システムのレイテンシ安定性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"Ast8a","x":668,"y":5660,"name":"L1-7::Group 4 :: Group 1 :: Lone 204 :: Lone 228 :: Sticky Note dr3:8","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1ijzN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/OTP は電話交換機のような停止不能システム向けに、プロセス隔離とホットコード更新を重視した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"3pe3A","x":952,"y":5660,"name":"L1-7::Group 4 :: Group 1 :: Lone 205 :: Lone 229 :: Sticky Note dr3:9","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vksu6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/OTP の supervisor tree と gen_server は耐障害分散システムの定番パターンとして定着した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"pKeWQ","x":100,"y":5860,"name":"L1-7::Group 4 :: Group 1 :: Lone 207 :: Lone 231 :: Sticky Note dr3:11","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gymq8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang では不変データとアクターモデルの組み合わせが並行バグを減らす実践として広く受容された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"wSpPq","x":384,"y":5860,"name":"L1-7::Group 4 :: Group 1 :: Lone 458 :: Lone 512 :: Sticky Note dr13:11","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mTOpP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlangは高可用な通信基盤の実運用で強みを示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"BE82H","x":668,"y":5860,"name":"L1-7::Group 4 :: Group 1 :: Lone 659 :: Lone 733 :: Sticky Note nishio:64","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PkyHq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ErlangとOCamlは不変束縛中心だが可変領域を別途提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"OSdn0","x":668,"y":7460,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:23","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZpRnl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは通常の関数適用で括弧をほとんど使わない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":"tDhjI","x":952,"y":7460,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:63","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"U8zP3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは通常の束縛を再代入不可にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}],"enabled":false},{"type":"frame","id":