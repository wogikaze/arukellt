"textGrowth":"fixed-width","width":"fill_container","content":"Zigはdeferやerrdeferを含む制御をソース上で追跡可能に保つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QSjM5","x":1768,"y":484,"name":"L1-1::Group 12 :: Group 1 :: Group 20 :: Group 24 :: Sticky Note dr5:31","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"677vR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのerrdeferはエラー時のみ実行する後始末を明示できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XXAGl","x":1768,"y":284,"name":"L1-1::Group 12 :: Group 1 :: Group 20 :: Group 24 :: Sticky Note dr15:53","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MuOls","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zig の defer は常時クリーンアップを記述し errdefer はエラー時のみの巻き戻しを記述する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"B5971","x":1768,"y":684,"name":"L1-1::Group 12 :: Group 1 :: Group 89 :: Group 98 :: Sticky Note dr5:29","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kgZYq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ZigのエラーユニオンT!Eは値かエラーかを型で表す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"jeLg4","x":2052,"y":484,"name":"L1-1::Group 12 :: Group 1 :: Group 89 :: Group 98 :: Sticky Note dr14:42","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wC6jE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのエラーユニオンは失敗経路を型として表現し処理漏れを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"O4O7x","x":2052,"y":684,"name":"L1-1::Group 12 :: Group 1 :: Group 90 :: Group 99 :: Sticky Note dr5:30","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"deSr4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのtryはエラー伝播の糖衣でcatchは局所ハンドリングを担う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EsTVj","x":1768,"y":884,"name":"L1-1::Group 12 :: Group 1 :: Lone 249 :: Lone 286 :: Sticky Note dr4:31","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XfcIV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ZigはC級の制御性を維持しつつ未定義動作の削減を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"U61w8","x":2052,"y":884,"name":"L1-1::Group 12 :: Group 1 :: Lone 427 :: Lone 477 :: Sticky Note dr12:50","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kQBG7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの設計はOOM可能性を型に表出させて失敗処理を強制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GLXBs","x":4692,"y":284,"name":"L1-1::Group 18 :: Group 1 :: Group 20 :: Group 24 :: Sticky Note dr14:43","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UCGyp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのdeferは静的展開的に扱われ実行コストの見積りを容易にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LYYK8","x":4976,"y":284,"name":"L1-1::Group 18 :: Group 1 :: Group 23 :: Lone 478 :: Sticky Note dr12:51","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HKJoU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは環境別にAllocator実装を差し替えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"b4VwG","x":4692,"y":484,"name":"L1-1::Group 18 :: Group 1 :: Lone 250 :: Lone 287 :: Sticky Note dr4:33","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"r4zJ5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは予測可能性を重視するシステム開発者に支持される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xyytm","x":4976,"y":484,"name":"L1-1::Group 18 :: Group 1 :: Lone 251 :: Lone 288 :: Sticky Note dr4:34","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HDHPr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは例外やGCに慣れた開発者には学習初期の認知負荷が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6Z6zw","x":4692,"y":684,"name":"L1-1::Group 18 :: Group 1 :: Lone 429 :: Lone 482 :: Sticky Note dr12:55","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UUt9N","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは明示性を最優先しOdinは生産性と簡潔さを優先する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Jeeev","x":4976,"y":684,"name":"L1-1::Group 18 :: Group 1 :: Lone 515 :: Lone 574 :: Sticky Note dr14:40","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6EnCQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは例外と暗黙的デストラクタを排して監査可能性を高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"w40Sq","x":4692,"y":884,"name":"L1-1::Group 18 :: Group 1 :: Lone 593 :: Lone 656 :: Sticky Note dr16:24","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"t7wSt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは@importを中心に暗黙的ヘッダ取り込みを排除した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"v2vfU","x":164,"y":284,"name":"L1-1::Group 26 :: Group 1 :: Group 23 :: Group 123 :: Sticky Note dr12:49","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CGswq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは隠れたヒープ確保を避けるためAllocatorの明示受け渡しを要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"y0HDd","x":448,"y":284,"name":"L1-1::Group 26 :: Group 1 :: Group 23 :: Group 123 :: Sticky Note dr14:41","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"knP5q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ZigはAllocator明示受け渡しで動的メモリ利用点を可視化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ijVMO","x":164,"y":484,"name":"L1-1::Group 26 :: Group 1 :: Group 29 :: Group 48 :: Sticky Note dr14:38","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WM4dU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは隠れた制御フローと隠れたメモリ割り当てを許容しない方針を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2nWrG","x":448,"y":484,"name":"L1-1::Group 26 :: Group 1 :: Group 29 :: Group 48 :: Sticky Note dr15:52","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HGJDK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zig は error set と !T エラーユニオンで隠れた制御フローを排した設計を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"odbeB","x":164,"y":684,"name":"L1-1::Group 26 :: Group 1 :: Lone 178 :: Lone 200 :: Sticky Note dr2:57","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cjwNj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはアロケータを引数で明示的に渡して確保責務をAPIに露出させる設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zopBC","x":448,"y":684,"name":"L1-1::Group 26 :: Group 1 :: Lone 248 :: Lone 285 :: Sticky Note dr4:30","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VsjU1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはno hidden control flowとno hidden allocationsを明示原則に置く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JvDx8","x":3372,"y":284,"name":"L1-1::Group 45 :: Group 1 :: Group 100 :: Group 111 :: Sticky Note dr6:40","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HAh6i","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの`comptime`は特殊マクロ構文を増やさず通常コードでコンパイル時計算を行う方針を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QG01n","x":3088,"y":284,"name":"L1-1::Group 45 :: Group 1 :: Group 100 :: Group 111 :: Sticky Note dr16:25","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"twRRI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはcomptimeでコンパイル時評価を統一し、別系統のマクロ言語を持たない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TSkdX","x":3088,"y":484,"name":"L1-1::Group 45 :: Group 1 :: Lone 350 :: Lone 395 :: Sticky Note dr6:41","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"evZxI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのコンパイル時リフレクションはランタイム負荷を増やさず表現力を得るがビルド時間設計の規律を要する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"P10Cy","x":3372,"y":484,"name":"L1-1::Group 45 :: Group 1 :: Lone 379 :: Lone 429 :: Sticky Note dr11:30","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nE76C","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの ?T はC互換メモリ表現を保ちながらコンパイル時アンラップ強制で安全性を確保する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KBufC","x":3088,"y":684,"name":"L1-1::Group 45 :: Group 1 :: Lone 620 :: Lone 684 :: Sticky Note dr16:75","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nIjDt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは@typeInfoと@TypeOfをcomptimeで処理し、実行時RTTI依存を避ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"s2jNZ","x":866,"y":284,"name":"L1-1::Group 56 :: Group 1 :: Group 14 :: Group 10 :: Sticky Note dr2:17","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"likHK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのZGCはテラバイト級ヒープでも1ms未満ポーズを狙う低レイテンシ設計を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pkOvM","x":1150,"y":284,"name":"L1-1::Group 56 :: Group 1 :: Lone 158 :: Lone 174 :: Sticky Note dr2:18","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kUE5M","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのZGCはカラー付きポインタとロードバリアで多くの処理をアプリ実行と並行化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vnxPq","x":866,"y":484,"name":"L1-1::Group 56 :: Group 1 :: Lone 159 :: Lone 175 :: Sticky Note dr2:19","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CV4px","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのZGCは短ポーズと高スケーラビリティを実現したがバリア常時実行コストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"afsGu","x":1150,"y":484,"name":"L1-1::Group 56 :: Group 1 :: Lone 403 :: Lone 453 :: Sticky Note dr12:6","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NoryC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ZGCはColored PointersとLoad Barriersで大規模ヒープでも超低ポーズを狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WPvaA","x":164,"y":1292,"name":"L1-1::Group 59 :: Group 1 :: Group 29 :: Group 48 :: Sticky Note dr16:26","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zpjxX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの設計は可読性と追跡可能性を優先し、隠れた制御フローを避ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Z8uq3","x":164,"y":1492,"name":"L1-1::Group 59 :: Group 1 :: Group 91 :: Group 100 :: Sticky Note dr5:32","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6j2rW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのunreachableは到達不能前提を最適化と診断に利用させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ADl5s","x":448,"y":1292,"name":"L1-1::Group 59 :: Group 1 :: Group 91 :: Group 100 :: Sticky Note dr15:54","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Uqjrn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zig の unreachable は Debug では安全停止を促し ReleaseFast では誤用時 UB を招く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bMyTs","x":4102,"y":1292,"name":"L1-1::Group 61 :: Group 1 :: Group 37 :: Group 31 :: Sticky Note dr2:80","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bGwH9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaはZGCやShenandoahで低ポーズ化を進め適用可能領域を広げたがハードリアルタイム保証は難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lfogG","x":1902,"y":1292,"name":"L1-1::Group 104 :: Group 1 :: Group 20 :: Lone 479 :: Sticky Note dr12:52","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uqxzN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのdeferは手動管理でも解放忘れを減らす実務的手段である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3F3m4","x":2186,"y":1292,"name":"L1-1::Group 104 :: Group 1 :: Group 23 :: Lone 488 :: Sticky Note dr12:62","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gEMzR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのstd.heap.ArenaAllocatorは木構造などの一括解放に向く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nVKtl","x":1902,"y":1492,"name":"L1-1::Group 104 :: Group 1 :: Lone 187 :: Lone 209 :: Sticky Note dr2:67","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uB5Bn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのアリーナアロケータは早期returnが多い処理でfree漏れ低減に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1J65M","x":866,"y":1292,"name":"L1-1::Group 129 :: Group 1 :: Lone 188 :: Lone 210 :: Sticky Note dr2:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mEzQi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigのアリーナは長寿命データを入れると実質リーク化しやすく運用設計が重要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"gYt7L","x":3790,"y":284,"name":"L1-1::Group 135 :: Group 1 :: Lone 284 :: Lone 326 :: Sticky Note dr4:87","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EsPtB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigはbuild.zigでビルド記述を言語内に統合し外部ツール依存を減らした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VDqsF","x":4074,"y":284,"name":"L1-1::Group 135 :: Group 1 :: Lone 285 :: Lone 327 :: Sticky Note dr4:88","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LU1Ud","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの内蔵ビルドは一貫体験を与えるがビルド学習対象を追加する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NfJhq","x":3790,"y":484,"name":"L1-1::Group 135 :: Group 1 :: Lone 621 :: Lone 685 :: Sticky Note dr16:76","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pqKrz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigの型内省はinline forと組み合わせてゼロオーバーヘッド生成を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QamYm","x":3222,"y":1292,"name":"L1-1::Group 203 :: Group 1 :: Lone 179 :: Lone 201 :: Sticky Note dr2:58","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"S4ZRg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigは確保地点の可視性を高める代わりに呼び出し側ボイラープレートを増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"gUglD","x":3222,"y":1492,"name":"L1-1::Group 203 :: Group 1 :: Lone 514 :: Lone 573 :: Sticky Note dr14:39","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qq6e5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Zigでは明示された関数呼び出し以外の副次的呼び出しが発生しない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"np72i","x":2604,"y":1292,"name":"L1-1::Lone 274 :: Group 1 :: Lone 146 :: Lone 161 :: Sticky Note dr1:65","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5JYhc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CeylonとZigの流れはHoareの反省と先行言語の成功事例に影響されている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pz78g","x":2470,"y":284,"name":"L1-1::Lone 312 :: Group 1 :: Lone 405 :: Lone 455 :: Sticky Note dr12:8","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D7D9L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 21のZGCはGenerationalモードで世代仮説の利点を取り込んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"DY8XQ","x":1284,"y":1292,"name":"L1-1::Lone 339 :: Group 1 :: Lone 530 :: Lone 590 :: Sticky Note dr14:62","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"lay