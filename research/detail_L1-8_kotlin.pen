thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"frame","id":"plate_00018","x":100,"y":80,"name":"Nameplate::[L1] Kotlinの安全・簡潔設計と","width":260,"fill":"#FFCC80","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"plate_00018_t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"[L1] Kotlinの安全・簡潔設計と実務効果","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"600"}]},{"type":"frame","id":"ix85r","x":164,"y":284,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Group 52 :: Sticky Note dr1:21","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IOrbY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは推論範囲をローカルに制限してコンパイル時間とエラー品質を制御する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2aBQL","x":448,"y":284,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Group 52 :: Sticky Note dr1:22","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8CX1z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは制約解決不能時にコンパイルエラーを返して曖昧な推論結果を残さない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ia56X","x":732,"y":284,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Lone 142 :: Sticky Note dr1:19","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yZBgC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinはローカル型推論と関数シグネチャ推論を制約ソルバーで統合する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IWpQd","x":164,"y":484,"name":"L1-8::Group 3 :: Group 1 :: Group 30 :: Lone 145 :: Sticky Note dr1:26","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RxTbE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは曖昧な推論を許容せず明示的型指定を促すことで後続エラー連鎖を防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fuDSy","x":448,"y":484,"name":"L1-8::Group 3 :: Group 1 :: Group 56 :: Group 53 :: Sticky Note dr1:23","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3zmXB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのbuilder-style inferenceはDSLで型引数明記を減らすために後ろ向き制約解決を追加する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iwxWa","x":732,"y":484,"name":"L1-8::Group 3 :: Group 1 :: Group 56 :: Group 53 :: Sticky Note dr1:24","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jvbML","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのbuilder-style inferenceは推論失敗時にエラー化して型安全性を維持する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AJEEK","x":448,"y":684,"name":"L1-8::Group 3 :: Group 1 :: Group 74 :: Group 77 :: Sticky Note dr3:36","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kioJ2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlin の coroutineScope は子失敗を全体に波及させ、supervisorScope は失敗分離を選べる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EuFEi","x":164,"y":684,"name":"L1-8::Group 3 :: Group 1 :: Group 74 :: Group 77 :: Sticky Note dr13:39","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dEgu7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinはCoroutineScopeを必須化してタスクの親子関係を明示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"peRzL","x":732,"y":684,"name":"L1-8::Group 3 :: Group 1 :: Lone 133 :: Lone 144 :: Sticky Note dr1:25","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hQnZ4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlin仕様は自由型変数を残さない推論解を最適解として扱う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"e5MFT","x":164,"y":884,"name":"L1-8::Group 3 :: Group 1 :: Lone 262 :: Lone 300 :: Sticky Note dr4:56","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9G9o6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのwhenはswitchより式志向で柔軟な分岐表現を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Hu1Z4","x":448,"y":884,"name":"L1-8::Group 3 :: Group 1 :: Lone 310 :: Lone 352 :: Sticky Note dr5:25","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qCWmf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのwhenはsealed classと組み合わせると網羅的エラー分解に向く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SCabe","x":732,"y":884,"name":"L1-8::Group 3 :: Group 1 :: Lone 467 :: Lone 521 :: Sticky Note dr13:38","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pfOUC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinはsuspendを最小言語機能としてコルーチンをライブラリ主導で構築した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Rh4kn","x":164,"y":1084,"name":"L1-8::Group 3 :: Group 1 :: Lone 476 :: Lone 530 :: Sticky Note dr13:62","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pX8jT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのjob階層は親子キャンセルと失敗伝播を予測可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oRc4J","x":448,"y":1084,"name":"L1-8::Group 3 :: Group 1 :: Lone 501 :: Lone 558 :: Sticky Note dr14:17","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5duz9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは改行許容位置を文法で厳密化して省略終端の安全性を確保する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VREmc","x":1350,"y":684,"name":"L1-8::Group 7 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:49","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aQd1E","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftは小さな実行時コストよりクラッシュ削減価値を優先してnull安全を設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hb6dZ","x":1634,"y":684,"name":"L1-8::Group 7 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:50","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"J8Q3N","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftではnull安全機構が性能ボトルネックになる実例は一般に少ない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XmAri","x":1918,"y":684,"name":"L1-8::Group 7 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:54","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pWnW5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinやDartはモバイル文脈でnull安全を主要価値として打ち出した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"blh38","x":1350,"y":884,"name":"L1-8::Group 7 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:66","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UOasj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftは型チェックとnull安全とエラーハンドリングを組み合わせてクラッシュ削減を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fmyW1","x":1634,"y":884,"name":"L1-8::Group 7 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:67","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GDD2s","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftの安全機構は実サービスのnull由来障害分析を背景に設計され市場で受容された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TYVKX","x":1350,"y":284,"name":"L1-8::Group 7 :: Group 1 :: Group 13 :: Group 25 :: Sticky Note dr11:25","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zyJaO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftの T? は軽量で既存JavaやObjective-C資産との相互運用に有利である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"grVNx","x":1634,"y":284,"name":"L1-8::Group 7 :: Group 1 :: Group 35 :: Group 29 :: Sticky Note dr1:39","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TjxOL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは安全呼び出し演算子とElvis演算子でnull処理を明示化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9Lequ","x":1918,"y":284,"name":"L1-8::Group 7 :: Group 1 :: Group 35 :: Group 29 :: Sticky Note dr1:47","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YvqSU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinは安全呼び出しとElvis演算子でnull処理を式として簡潔に記述する傾向がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JNWIT","x":1350,"y":484,"name":"L1-8::Group 7 :: Group 1 :: Group 35 :: Group 29 :: Sticky Note dr1:51","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"t0w5Q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinはnullと共存しつつ演算子で安全に扱う文体を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"onERQ","x":1634,"y":484,"name":"L1-8::Group 7 :: Group 1 :: Group 58 :: Group 55 :: Sticky Note dr1:40","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NINoP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのnull安全設計はAndroidで頻発したNPEの抑止に実務的効果を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hGU8w","x":1918,"y":484,"name":"L1-8::Group 7 :: Group 1 :: Group 58 :: Group 55 :: Sticky Note dr4:40","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EathT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlin導入はAndroid開発でボイラープレート削減効果を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kDirY","x":2820,"y":284,"name":"L1-8::Group 41 :: Group 1 :: Group 44 :: Group 42 :: Sticky Note dr6:12","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XUFPc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinの`internal`はJavaにないモジュール内公開を提供しビルド単位でAPI境界を切りやすくした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WoSSr","x":2536,"y":484,"name":"L1-8::Group 41 :: Group 1 :: Group 44 :: Group 42 :: Sticky Note dr6:13","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9gsNY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinの`internal`はGradle等のモジュール定義と結び付くため設定理解なしでは誤用が起きやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8hWMN","x":2536,"y":284,"name":"L1-8::Group 41 :: Group 1 :: Group 44 :: Group 42 :: Sticky Note dr16:38","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"l6oUq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinはpackage-privateの代わりにモジュール境界のinternalを導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MMk8t","x":2536,"y":684,"name":"L1-8::Group 41 :: Group 1 :: Group 88 :: Group 96 :: Sticky Note dr5:24","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oipM6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinのResultとrunCatchingは例外を値へ変換して連鎖処理しやすくする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WDf08","x":2820,"y":484,"name":"L1-8::Group 41 :: Group 1 :: Group 88 :: Group 96 :: Sticky Note dr15:50","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mBKVo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlin は checked exception を持たず runCatching による Result 連鎖を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"j60f9","x":1350,"y":1212,"name":"L1-8::Group 47 :: Group 1 :: Lone 132 :: Lone 143 :: Sticky Note dr1:20","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tTlyw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinの型推論方針はJava相互運用性を維持しつつ記述量を削減する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VgyPc","x":1634,"y":1212,"name":"L1-8::Group 47 :: Group 1 :: Lone 256 :: Lone 293 :: Sticky Note dr4:39","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Mc78F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinはJava互換性を保ちながら視覚ノイズ削減を実現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wnTxE","x":1350,"y":1412,"name":"L1-8::Group 47 :: Group 1 :: Lone 261 :: Lone 299 :: Sticky Note dr4:55","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VnuFL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのfun, val, var, whenはJava利用者にも直感的な移行点を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ftQmv","x":1634,"y":1412,"name":"L1-8::Group 47 :: Group 1 :: Lone 263 :: Lone 301 :: Sticky Note dr4:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"teGip","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとJava混在環境では同概念の命名差が認知負荷を増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rVuke","x":1350,"y":1612,"name":"L1-8::Group 47 :: Group 1 :: Lone 600 :: Lone 664 :: Sticky Note dr16:39","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"w49qA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinのdefault publicはDSL記述を簡潔にするが意図しない公開の温床になり得る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Wdgdi","x":448,"y":1412,"name":"L1-8::Group 53 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr3:35","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HAtj7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlin は coroutines と structured concurrency を標準化し、親子ジョブ単位でキャンセルと例外伝搬を扱う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8wN44","x":164,"y":1412,"name":"L1-8::Group 53 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr15:51","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BW7mv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlin runCatching は CancellationException を握り潰すと structured concurrency を壊しうる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZdRhe","x":164,"y":1612,"name":"L1-8::Group 53 :: Group 1 :: Lone 220 :: Lone 248 :: Sticky Note dr3:56","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9Scxp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Trio、Kotlin、Swift、Java は構造化並行性 API を採用し、タスクリークを防ぐ方向へ収束した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bYgP6","x":448,"y":1612,"name":"L1-8::Group 53 :: Group 1 :: Lone 468 :: Lone 522 :: Sticky Note dr13:40","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YLM8x","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Kotlinの構造化並行性はキャンセル伝播とリーク抑止に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"F8V8V","x":3438,"y":284,"name":"L1-8::Group 54 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:35","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZzjK9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftとRustとDartはnullをデフォルト許容しない方向へ設計を転換した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"55t30","x":3722,"y":284,"name":"L1-8::Group 54 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:36","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"H7Jse","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"KotlinとSwiftとRustとDartはOption系型やT?でnull可能性を型として明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2BWKo","x":3438,"y":484,"name":"L1-8::Group 54 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr1:55","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MqifU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HaskellとRustとSwiftとKotlin系は不在値をnull特別値ではなくOption系型でモデリングする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NbnqQ","x":3722,"y":484,"name":"L1-8::Group 54 :: Group 1 :: Group 6 :: Group 3 :: Sticky Note dr5:47","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sOL41","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustとHaskellとSwiftとKotlinは網羅性検査で分岐漏れ検出を支援する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ujhXW","x":164,"y":2020,"name":"L1-8::Group 98 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr1:38","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","col