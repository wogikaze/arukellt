"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KrkyX","x":3490,"y":3012,"name":"L1-9::Group 22 :: Group 1 :: Lone 531 :: Lone 591 :: Sticky Note dr14:63","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"phgMM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DenoはNode.jsエコシステムのツール断片化に対する統合的回答として設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"7585G","x":2604,"y":284,"name":"L1-9::Group 23 :: Group 1 :: Lone 124 :: Group 92 :: Sticky Note dr5:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Wia7T","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの検査例外は回復可能な失敗の処理をコンパイル時に強制する設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iNPlW","x":2604,"y":484,"name":"L1-9::Group 23 :: Group 1 :: Lone 325 :: Lone 369 :: Sticky Note dr5:59","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ytt5I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのchecked例外史は効果注釈設計に対する実務的な警鐘として参照される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JYLu4","x":1284,"y":284,"name":"L1-9::Group 29 :: Group 1 :: Lone 271 :: Lone 311 :: Sticky Note dr4:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jrf7l","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Gleamは小規模言語ゆえ初期からエラーUXを設計中核に据えられた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"z8aWA","x":2036,"y":3012,"name":"L1-9::Group 30 :: Group 1 :: Group 52 :: Group 124 :: Sticky Note dr13:42","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hLofz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのTaskGroupは分岐した非同期処理の合流を安全に表現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"faVOh","x":4476,"y":1876,"name":"L1-9::Group 31 :: Group 1 :: Lone 473 :: Lone 527 :: Sticky Note dr13:58","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nRZCj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"構造化並行性はタスク寿命をブロックスコープへ閉じ込める設計原則である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sAFlJ","x":3908,"y":3012,"name":"L1-9::Group 32 :: Group 1 :: Group 7 :: Group 11 :: Sticky Note dr2:24","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"n0fn8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/BEAMはあるプロセスのGC影響を他プロセスへ広げにくい設計を実現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4hdpD","x":1902,"y":284,"name":"L1-9::Group 33 :: Group 1 :: Group 17 :: Group 26 :: Sticky Note dr15:27","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YhKKi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# は checked exception を採用せず開発速度と API 可変性を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VNjaH","x":2186,"y":284,"name":"L1-9::Group 33 :: Group 1 :: Group 41 :: Group 38 :: Sticky Note dr5:7","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Vz8zs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#はchecked例外を採用せずAPI進化の自由度を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iZKwy","x":1902,"y":484,"name":"L1-9::Group 33 :: Group 1 :: Lone 123 :: Group 74 :: Sticky Note dr13:28","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BSYX4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#の普及は他言語の非同期構文設計に強い影響を与えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ny6po","x":2186,"y":484,"name":"L1-9::Group 33 :: Group 1 :: Lone 302 :: Lone 344 :: Sticky Note dr5:8","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8GqqH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#の例外はすべてuncheckedのためコンパイラ強制より設計規約が重要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"l7XDi","x":582,"y":3012,"name":"L1-9::Group 34 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr1:43","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CdKc7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのOptional設計はObjective-C時代のnil由来クラッシュ削減を目的に導入された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Hmma1","x":582,"y":3212,"name":"L1-9::Group 34 :: Group 1 :: Group 13 :: Lone 185 :: Sticky Note dr2:35","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LCjvD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftはObjective-C互換を保ちつつARCで決定的解放と性能を両立する設計を選んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SRonA","x":3640,"y":812,"name":"L1-9::Group 36 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr15:49","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YDmJj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の fatalError() と preconditionFailure() は回復不能状態で即時停止を強制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"z0Brs","x":448,"y":1876,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr1:10","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iYddO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartは初期課題を受けてsound null safetyを含む健全な型システムへ再設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zsoUQ","x":164,"y":2076,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr1:12","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LeZFQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartのsound null safetyはunsafeなnull使用を分析エラーとして早期検出する設計を取る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rPFkA","x":448,"y":2076,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr1:13","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SyNUu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartのsound null safetyは非null値の初期化を必須化してnullアクセス不具合を実行前に減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0gOjN","x":164,"y":1876,"name":"L1-9::Group 38 :: Group 1 :: Group 24 :: Group 17 :: Sticky Note dr11:9","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zuj2q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DartはDart 1の不健全オプショナル型付けを捨てDart 2以降でSound Null Safetyへ移行した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tmh81","x":164,"y":2276,"name":"L1-9::Group 38 :: Group 1 :: Lone 127 :: Lone 137 :: Sticky Note dr1:14","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CvvWC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartの分析エラーモデルはIDEとビルド段階でnull関連バグを捕捉する開発体験を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lYSSY","x":164,"y":812,"name":"L1-9::Group 39 :: Group 1 :: Group 28 :: Lone 400 :: Sticky Note dr6:51","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9HKwk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# Source Generatorはランタイム反射コストを減らせるがジェネレータ設計の学習負荷を新たに生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"H5UCJ","x":3640,"y":284,"name":"L1-9::Group 46 :: Group 1 :: Group 109 :: Group 122 :: Sticky Note dr12:37","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eeZb2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはデータ競合を型システムで予防する設計を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"gA1S1","x":3924,"y":284,"name":"L1-9::Group 46 :: Group 1 :: Group 109 :: Group 122 :: Sticky Note dr13:17","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"31xaa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの設計はデータ競合の主要経路を型検査で遮断する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dRPTZ","x":3640,"y":484,"name":"L1-9::Group 46 :: Group 1 :: Lone 363 :: Lone 412 :: Sticky Note dr11:1","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JaNyt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"型システムと型推論の設計は言語の表現力と安全性と開発体験を同時に規定する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1T7x5","x":3924,"y":484,"name":"L1-9::Group 46 :: Group 1 :: Lone 558 :: Lone 618 :: Sticky Note dr15:22","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IbrOR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"医療制御や重要インフラ制御ではクラッシュ許容より防御的設計が優先される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0pgqd","x":3640,"y":2404,"name":"L1-9::Group 51 :: Group 1 :: Group 17 :: Group 26 :: Sticky Note dr15:25","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WVXcP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"throws Exception や空 catch は checked exception 運用で生じやすい代表的アンチパターンである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Wrwi7","x":582,"y":812,"name":"L1-9::Group 59 :: Group 1 :: Lone 327 :: Lone 371 :: Sticky Note dr5:61","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lstAc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"エラー設計の要点は回復可能性と可読性と進化容易性のバランス最適化である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"a6iou","x":3072,"y":3212,"name":"L1-9::Group 62 :: Group 1 :: Group 38 :: Group 32 :: Sticky Note dr2:84","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ya4F2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのARCも強参照サイクルでリークし得るためweak/unowned設計が重要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XLutX","x":3072,"y":3012,"name":"L1-9::Group 62 :: Group 1 :: Group 38 :: Group 32 :: Sticky Note dr12:33","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DW3oR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ARCは循環参照を自動解決しないためweakやunowned設計が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Qnjir","x":3022,"y":284,"name":"L1-9::Group 73 :: Group 1 :: Group 85 :: Group 93 :: Sticky Note dr5:9","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NIQrb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは回復可能エラーをResult<T,E>で明示する設計を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bIxEz","x":1902,"y":1876,"name":"L1-9::Group 75 :: Group 1 :: Group 112 :: Group 128 :: Sticky Note nishio:1","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gvVEm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"プログラミング言語は人間が設計するため、設計判断の違いと修正の歴史を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BjGAm","x":2186,"y":1876,"name":"L1-9::Group 75 :: Group 1 :: Group 112 :: Group 128 :: Sticky Note nishio:2","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CCH55","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"完璧なプログラミング言語は存在しないという前提で比較すると設計意図が見えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bjkLe","x":1902,"y":2076,"name":"L1-9::Group 75 :: Group 1 :: Lone 493 :: Lone 547 :: Sticky Note dr14:3","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Hx1PT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"構文設計は美学ではなくコード理解と誤読率に直接影響する認知設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"mijIA","x":2186,"y":2076,"name":"L1-9::Group 75 :: Group 1 :: Lone 538 :: Lone 598 :: Sticky Note dr14:73","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EnJdn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語設計の成熟は速度競争から人間工学と生態系設計の競争への移行として説明できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FnmGU","x":4058,"y":812,"name":"L1-9::Group 76 :: Group 1 :: Lone 399 :: Lone 449 :: Sticky Note dr11:54","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GUKJa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの双方向推論とJavaのSealed設計とC++20 Conceptsはその収束点を示す代表例である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"n6Zpv","x":866,"y":1876,"name":"L1-9::Group 78 :: Group 1 :: Lone 172 :: Lone 194 :: Sticky Note dr2:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"y9bQX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのunsafeは低レベル操作を禁止せず危険領域を明示境界に閉じ込める妥協設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qVOcm","x":866,"y":2076,"name":"L1-9::Group 78 :: Group 1 :: Lone 424 :: Lone 474 :: Sticky Note dr12:43","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nP2qU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Safe Abstractionはunsafe内部実装を安全API境界で封じ込める要点である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"F70i4","x":164,"y":284,"name":"L1-9::Group 79 :: Group 1 :: Lone 191 :: Lone 213 :: Sticky Note dr2:71","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UHepr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは値型優先で共有可変状態を減らしスレッド安全性を上げる設計を重視した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pyDra","x":448,"y":284,"name":"L1-9::Group 79 :: Group 1 :: Lone 436 :: Lone 490 :: Sticky Note dr12:64","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vadcP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは値型優先設計でローカル推論しやすい状態管理を促進する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MSbwt","x":164,"y":484,"name":"L1-9::Group 79 :: Group 1 :: Lone 451 :: Lone 505 :: Sticky Note dr13:1","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QLFmh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"並行性設計では共有メモリよりメッセージパッシングを優先すると状態競合を減らしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rWtax","x":2454,"y":3012,"name":"L1-9::Group 80 :: Group 1 :: Lone 222 :: Lone 250 :: Sticky Note dr3:62","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A3235","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Julia の設計は高水準 API を維持したまま BLAS や GPU バックエンドへの最適化分岐を実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BWFfV","x":4058,"y":2404,"name":"L1-9::Group 81 :: Group 1 :: Lone 224 :: Lone 252 :: Sticky Note dr3:64","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lOCaG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Mojo は parallelize などでスレッド並列とベクトル並列を同一言語層で扱える設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Sln6X","x":1618,"y":3340,"name":"L1-9::Group 90 :: Group 1 :: Lone 627 :: Lone 692 :: Sticky Note nishio:6","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"46uZC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HMMMMLでは条件式内のx = 0をx == 0として扱う設計がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TePHZ","x":4342,"y":484,"name":"L1-9::Group 96 :: Group 1 :: Group 5 :: Group 9 :: Sticky Note dr3:39","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FTqXA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"What Color is Your Function? 問題に対して Rust、Swift、Kotlin は async/await の着色を受け入れつつ増殖制御を設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HxEWN","x":4342,"y":284,"name":"L1-9::Group 96 :: Group 1 :: Group 110 :: Group 125 :: Sticky Note dr13:43","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bvVMt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"colored function問題は非同期関数呼び出しが同期関数に伝染する設計課題である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YCapm","x":4626,"y":284,"name":"L1-9::Group 96 :: Group 1 :: Group 110 :: Group 125 :: Sticky Note dr15:57","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zaA4X","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Result ベース設計は呼び出し側へ効果が伝播する colored function 問題を生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tr2H4","x":1284,"y":2076,"name":"L1-9::Group 98 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr1:64","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QT1HM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CeylonとZigはnullable明示と非nullableデフォルトを志向するnull安全設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5rsXK","x":1284,"y":1876,"name":"L1-9::Group 98 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr11:28","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8F3z5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ceylonの Null | String はNullを特別扱いせず集合論的に表現する設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ACMrW","x":1000,"y":812,"name":"L1-9::Group 99 :: Group 1 :: Group 8 :: Lone 150 :: Sticky Note dr1:32","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Iuzzw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ALGOL Wのnull参照導入はTony Hoareが後にbillion dollar mistakeと呼んだ設計判断として知られる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"C0SFi","x":3640,"y":1876,"name":"L1-9::Group 101 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr13:35","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hf2WE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはcallback中心設計からPromiseへ移行した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"G5lzj","x":3640,"y":2076,"name":"L1-9::Group 101 :: Group 1 :: Lone 230 :: Lone 259 :: Sticky Note dr3:76","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tmLdK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Node.js は初期のコールバック中心設計で制御フローとエラー処理の可読性を大きく損ねた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VveU9","x":4526,"y":3012,"name":"L1-9::Group 117 :: Group 1 :: Group 72 :: Group 75 :: Sticky Note dr3:28","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cW3nG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の Pin 設計は自己参照 future の安全性を確保するために必要とされた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"daDoT","x":4526,"y":3212,"name":"L1-9::Group 117 :: Group 1 :: Lone 465 :: Lone 519 :: Sticky Note dr13:29","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Cog57","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのFutureはランタイム非依存の抽象として設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rASGB","x":1902,"y":812,"name":"L1-9::Group 123 :: Group 1 :: Group 108 :: Group 121 :: Sticky Note dr12:17","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"L0QY1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":".NETはWorkstation GCとServer GCを用途で切り替える設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"P5XbI","x":164,"y":1140,"name":"L1-9::Group 159 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note dr4:41","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DxZ8m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptのASIは文末を自動推論してセミコロンを補う設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NBDew","x":2036,"y":3340,"name":"L1-9::Group 160 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note nishio:43","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IKKyg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはundefinedを明示値として扱う設計で未定義状態を表現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RYfh7","x":5362,"y":3012,"name":"L1-9::Group 167 :: Group 1 :: Lone 507 :: Lone 564 :: Sticky Note dr14:25","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pqknm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語設計の主要対立は開発者幸福の最大化と実行予測可能性の最大化である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aWW30","x":2320,"y":812,"name":"L1-9::Group 183 :: Group 1 :: Group 86 :: Group 94 :: Sticky Note dr15:43","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"h6Ktu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の thiserror は公開ライブラリ向けの明示的エラー enum 設計に適する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4JXvy","x":2604,"y":1876,"name":"L1-9::Group 195 :: Group 1 :: Lone 139 :: Lone 153 :: Sticky Note dr1:37","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EWGss","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"null安全設計への転換はHoareの反省と長年の実務障害データの蓄積に後押しされた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yPB8O","x":2604,"y":2076,"name":"L1-9::Group 195 :: Group 1 :: Lone 140 :: Lone 155 :: Sticky Note dr1:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Nx3nb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JVM系とモバイル領域ではnull未処理クラッシュ比率が高いという報告が設計判断を後押しした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RclUj","x":4476,"y":2404,"name":"L1-9::Group 201 :: Group 1 :: Lone 169 :: Lone 191 :: Sticky Note dr2:42","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QkB54","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの所有権規則は線形型系の発想とRAIIの実務知見を統合した設計と位置付けられる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3DRwi","x":3072,"y":3540,"name":"L1-9::Group 202 :: Group 1 :: Lone 170 :: Lone 192 :: Sticky Note dr2:43","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ifAVM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのNLLは借用の寿命をレキシカル範囲でなく実使用範囲で判定する設計を導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"o0W2z","x":1000,"y":3012,"name":"L1-9::Group 204 :: Group 1 :: Lone 180 :: Lone 202 :: Sticky Note dr2:59","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rxyTE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OdinはGC前提を避けて明示的アロケータ管理で性能制御を優先する設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"y5ido","x":2738,"y":812,"name":"L1-9::Group 213 :: Group 1 :: Lone 491 :: Lone 545 :: Sticky Note dr14:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f6j7Z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代の言語設計は機械効率よりも人間の認知負荷と保守性を重視する方向へ移行している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ElMND","x":1902,"y":2404,"name":"L1-9::Group 215 :: Group 1 :: Lone 214 :: Lone 242 :: Sticky Note dr3:43","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qvWsb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust で unsafe による Send/Sync 実装を行う場合はライブラリ作者が強い不変条件を保証する責任を負う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4Jh57","x":4476,"y":812,"name":"L1-9::Group 216 :: Group 1 :: Lone 218 :: Lone 246 :: Sticky Note dr3:51","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TTSIu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ruby の MRI は GVL により Ruby バイトコード実行を実質単一スレッド化する設計を採った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8GlYv","x":582,"y":1140,"name":"L1-9::Group 219 :: Group 1 :: Lone 282 :: Lone 324 :: Sticky Note dr4:85","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2j1JW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSPの普及は言語設計段階から補完やリファクタ提供を前提にする圧力を生んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IkQEd","x":164,"y":2604,"name":"L1-9::Group 228 :: Group 1 :: Lone 569 :: Lone 632 :: Sticky Note dr15:56","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YsFbr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Result や Either の普及は例外の暗黙制御フロー問題を減らした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3TLaA","x":3022,"y":1876,"name":"L1-9::Group 235 :: Group 1 :: Lone 352 :: Lone 397 :: Sticky Note dr6:43","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gQQgZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Terraの設計は研究用途で有効だが一般アプリ開発での採用は限定的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TnYaO","x":3022,"y":2076,"name":"L1-9::Group 235 :: Group 1 :: Lone 398 :: Lone 448 :: Sticky Note dr11:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YbHRN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代言語設計の実務解は制約注釈を適度に要求し推論の暴走を抑える方向に収束している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Mjgr9","x":4944,"y":3012,"name":"L1-9::Group 237 :: Group 1 :: Lone 364 :: Lone 413 :: Sticky Note dr11:2","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vzso1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"型設計の中心課題は数学的健全性と実用的互換性のトレードオフである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9OGXj","x":4944,"y":3212,"name":"L1-9::Group 237 :: Group 1 :: Lone 540 :: Lone 600 :: Sticky Note dr15:1","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oFwUk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"計算研究の信頼性は予期しない障害を管理できる実行設計に依存する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"uLHo5","x":866,"y":284,"name":"L1-9::Group 239 :: Group 1 :: Lone 387 :: Lone 437 :: Sticky Note dr11:39","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"y2aok","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ジェネリクス設計は再利用性と実行時表現と互換性の三者最適化問題である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fzi0S","x":866,"y":484,"name":"L1-9::Group 239 :: Group 1 :: Lone 445 :: Lone 499 :: Sticky Note dr12:75","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3f6PK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HFT領域ではGCポーズ回避のためオブジェクト再利用設計が有効になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QHOt2","x":3490,"y":3540,"name":"L1-9::Group 242 :: Group 1 :: Lone 449 :: Lone 503 :: Sticky Note dr12:79","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ljaXr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語のメモリ管理選択はスループット、レイテンシ、開発体験のトレードオフで決まる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"frm8k","x":4058,"y":1876,"name":"L1-9::Group 251 :: Group 1 :: Lone 556 :: Lone 616 :: Sticky Note dr15:17","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lFKb4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"障害対処の設計は予防中心のワークフロー設計と実行時反応の言語機構に分かれる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"r7vbc","x":4058,"y":2076,"name":"L1-9::Group 251 :: Group 1 :: Lone 559 :: Lone 620 :: Sticky Note dr15:28","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DaeWf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# 設計では例外の詳細型を中間層で列挙するより上位集中処理を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"PCY69","x":1000,"y":1140,"name":"L1-9::Lone 269 :: Group 1 :: Group 53 :: Group 130 :: Sticky Note nishio:26","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FtrtY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Smalltalkは式を左結合で評価する設計を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SK3wB","x":164,"y":1468,"name":"L1-9::Lone 279 :: Group 1 :: Lone 190 :: Lone 212 :: Sticky Note dr2:70","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PExEj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ゲーム開発のプールアロケータは局所性を高める一方でサイズ設計を誤るとメモリ効率が悪化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AguEs","x":164,"y":3540,"name":"L1-9::Lone 294 :: Group 1 :: Lone 307 :: Lone 349 :: Sticky Note dr5:18","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"drqDo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのpanicとrecoverは通常系ではなく異常系の境界処理に使う設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vFIKl","x":582,"y":3540,"name":"L1-9::Lone 304 :: Group 1 :: Lone 378 :: Lone 428 :: Sticky Note dr11:29","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JRyFl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CeylonのUnion型設計は理論的一貫性を得る代わりに推論実装を重くする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dibS2","x":3640,"y":1140,"name":"L1-9::Lone 316 :: Group 1 :: Lone 418 :: Lone 468 :: Sticky Note dr12:28","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"h3ZtI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaはバリア設計と再スキャン戦略でオーバーヘッドを抑えている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HU3ez","x":2454,"y":3340,"name":"L1-9::Lone 330 :: Group 1 :: Lone 485 :: Lone 539 :: Sticky Note dr13:77","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GFeAI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"失敗事例の検証は次世代並行性設計の品質向上に不可欠である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YXdq2","x":1902,"y":11