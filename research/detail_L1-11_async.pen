2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"htX5F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirマクロはErlang VM上でDSL中心フレームワーク開発を加速させる設計として機能している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"F99cm","x":2202,"y":1084,"name":"L1-11::Group 2 :: Group 1 :: Lone 459 :: Lone 513 :: Sticky Note dr13:13","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0UiFg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirのマクロとDSL機構はドメイン記述力を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xNaCx","x":2820,"y":812,"name":"L1-11::Group 8 :: Group 1 :: Lone 320 :: Lone 364 :: Sticky Note dr5:52","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ChFYF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Project Loomの仮想スレッドは同期風コードでI/O待機を扱いやすくする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3EPWl","x":3104,"y":284,"name":"L1-11::Group 28 :: Group 1 :: Group 77 :: Group 82 :: Sticky Note dr4:11","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9ULwk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはMatzの開発者幸福哲学に基づき自然言語寄りの柔らかい構文を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HADcK","x":2820,"y":284,"name":"L1-11::Group 28 :: Group 1 :: Group 77 :: Group 82 :: Sticky Note dr14:26","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kdCkB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはMatzの人間中心哲学に基づき表現力と記述の楽しさを優先する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"P478S","x":2820,"y":484,"name":"L1-11::Group 28 :: Group 1 :: Lone 237 :: Lone 271 :: Sticky Note dr4:13","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OeNv7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはDSL記述に強くRailsの可読性重視スタイルを後押しした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vkJ61","x":164,"y":1692,"name":"L1-11::Group 30 :: Group 1 :: Group 5 :: Group 9 :: Sticky Note dr3:37","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aXPsr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift は structured concurrency で TaskGroup と async let を導入し、タスク階層を明示化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xI3id","x":164,"y":1892,"name":"L1-11::Group 30 :: Group 1 :: Group 52 :: Group 9 :: Sticky Note dr3:38","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XUhKn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の TaskGroup は動的並列、async let は少数の静的並列に向く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"mWPmz","x":1200,"y":1692,"name":"L1-11::Group 33 :: Group 1 :: Group 9 :: Group 74 :: Sticky Note dr3:26","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XtoMR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# の async/await モデルは JavaScript、Kotlin、Swift など後続言語の設計に強い影響を与えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iPELp","x":4424,"y":484,"name":"L1-11::Group 94 :: Group 1 :: Group 2 :: Group 41 :: Sticky Note dr5:37","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NZYHT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptは非同期境界でtry-catchの有効範囲が直感とずれやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tBnLf","x":4424,"y":284,"name":"L1-11::Group 94 :: Group 1 :: Group 2 :: Group 41 :: Sticky Note dr13:37","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SRklt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはtryとcatchで非同期失敗を追跡しやすくなった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hEMTe","x":4708,"y":284,"name":"L1-11::Group 94 :: Group 1 :: Group 2 :: Group 41 :: Sticky Note dr15:35","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NCLsW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScript の同期 try/catch は setTimeout など非同期コールバック内の例外を直接捕捉できない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bXZeg","x":582,"y":1692,"name":"L1-11::Group 110 :: Group 1 :: Group 42 :: Group 39 :: Sticky Note dr5:33","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3Omhc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elixirは{:ok, value}と{:error, reason}で失敗を値として扱う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"CYIns","x":3806,"y":284,"name":"L1-11::Group 118 :: Group 1 :: Group 75 :: Group 78 :: Sticky Note dr3:52","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oiubA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ruby は並列性補完のために Ractor を導入し、共有制限とメッセージパッシング中心のモデルを追加した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pY9OM","x":3522,"y":284,"name":"L1-11::Group 118 :: Group 1 :: Group 75 :: Group 78 :: Sticky Note dr13:55","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rK2aF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはGVL制約下の並列化課題に対してRactorを導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9RdMq","x":3522,"y":484,"name":"L1-11::Group 118 :: Group 1 :: Lone 219 :: Lone 247 :: Sticky Note dr3:53","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"O35Eu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ruby の Ractor は真の並列実行を提供する一方で、既存ライブラリ適合と API 制約の課題を伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UhMvG","x":5126,"y":284,"name":"L1-11::Lone 264 :: Group 1 :: Group 5 :: Group 9 :: Sticky Note dr13:23","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GveGk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift ConcurrencyはData Isolationを言語仕様として前面化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hrncA","x":2080,"y":1692,"name":"L1-11::Lone 356 :: Group 1 :: Lone 585 :: Lone 648 :: Sticky Note dr16:14","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4