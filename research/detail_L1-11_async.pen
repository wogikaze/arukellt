th":592,"height":408,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"rectangle","id":"island_l1_11_Lone_264","name":"Island::Swift Concurrencyは… (1枚)","x":5102,"y":260,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"rectangle","id":"island_l1_11_Lone_356","name":"Island::Node.jsはローカルI/O前提で… (1枚)","x":2056,"y":1668,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"frame","id":"plate_00003","x":100,"y":80,"name":"Nameplate::[L1] 非同期処理と言語人間工学の進化","width":260,"fill":"#FFCC80","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"plate_00003_t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"[L1] 非同期処理と言語人間工学の進化を示す群。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"600"}]},{"type":"frame","id":"VyItY","x":448,"y":284,"name":"L1-11::Group 1 :: Group 1 :: Group 1 :: Group 21 :: Sticky Note dr3:30","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aGcoB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python は PEP 3156 で asyncio を導入し、イベントループと Future/Task を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IWjRQ","x":164,"y":284,"name":"L1-11::Group 1 :: Group 1 :: Group 1 :: Group 21 :: Sticky Note dr13:32","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1Hk5g","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PythonはPEP 3156でasyncio基盤を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZKuDt","x":1016,"y":684,"name":"L1-11::Group 1 :: Group 1 :: Group 5 :: Group 9 :: Sticky Note dr3:21","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KcbqJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift は Concurrency Manifesto の流れで async/await と actor を導入し、非同期制御を構文で明示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"W3sN0","x":164,"y":1084,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr3:33","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6itNs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScript は Promise を先に導入し、その後 async/await を重ねて callback hell の複雑性を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"B0yVx","x":448,"y":1084,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr3:34","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"N2Y3f","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScript の async/await はエラーハンドリングを簡潔化したが、Promise API との相互運用設計を継続的に要した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"z8WpK","x":732,"y":1084,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr3:77","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7dbnj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Node.js は Promise と async/await の導入で callback hell を段階的に改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GxKh5","x":1016,"y":1084,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr5:36","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"e9C4K","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはcallbackとPromiseとasync/awaitが混在しエラースタイルが分断されやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iHz04","x":448,"y":884,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr13:36","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xBJFg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはPromiseからasyncとawaitへ進化してエラー処理を単純化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"04wNX","x":732,"y":884,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr13:85","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vcZR5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PromiseとasyncとawaitはNode.js非同期設計の可読性問題を大幅に改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wbixN","x":1016,"y":884,"name":"L1-11::Group 1 :: Group 1 :: Group 9 :: Group 5 :: Sticky Note dr15:36","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KidWy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Promise の .catch() と async/await は JavaScript 非同期エラー処理の標準経路を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nfocy","x":164,"y":684,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 9 :: Sticky Note dr3:75","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Wlo2I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の async/await はランタイム非同梱方針により Tokio と async-std などのエコシステム分断を生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"awwys","x":448,"y":484,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 20 :: Sticky Note dr3:24","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rZfmV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# は async/await を導入し、継続渡し中心の非同期 I/O を同期風の制御フローで記述可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Z5yxS","x":732,"y":284,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 20 :: Sticky Note dr13:25","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XUzcz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"asyncとawaitは非同期制御を同期風に記述するための標準構文になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lAUab","x":1016,"y":284,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 20 :: Sticky Note dr13:26","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GLiiq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#は主要言語として早期にasyncとawaitを導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BSTyj","x":164,"y":484,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 20 :: Sticky Note dr13:41","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kSRVH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはasyncとawaitをthrowsと統合して非同期失敗処理を自然化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2uH7p","x":1016,"y":484,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 21 :: Sticky Note dr3:32","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"URKjw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python では PEP 492 以降の async/await が asyncio 基盤と結合し、標準非同期スタックが確立した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FhHd7","x":732,"y":484,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Group 21 :: Sticky Note dr13:34","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5Vjp0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PythonはPEP 492でnative asyncとawaitを導入して記述性を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"23Sv0","x":448,"y":684,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Lone 236 :: Sticky Note dr3:22","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LM3Ld","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の async/await はコールバック中心の記述を減らし、既存コードを段階的に移行しやすくした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"s1W7c","x":732,"y":684,"name":"L1-11::Group 1 :: Group 1 :: Group 10 :: Lone 237 :: Sticky Note dr3:25","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VErvx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# の async/await は Task ベース非同期パターンの普及を後押しし、例外処理とリソース解放を自然化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bk1eJ","x":164,"y":884,"name":"L1-11::Group 1 :: Group 1 :: Group 73 :: Group 76 :: Sticky Note dr3:31","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jxkeN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python の asyncio は Twisted や Tornado など分散していた非同期流儀の収斂を狙って設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QR89Q","x":164,"y":1284,"name":"L1-11::Group 1 :: Group 1 :: Lone 210 :: Lone 238 :: Sticky Note dr3:27","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Pn8Ic","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の async/await はゼロコスト抽象化方針に従い、Future の状態機械化と Pin による移動制約を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Q2ppg","x":448,"y":1284,"name":"L1-11::Group 1 :: Group 1 :: Lone 212 :: Lone 240 :: Sticky Note dr3:40","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TSWrT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"async main や TaskGroup や nursery の導入は非同期色の伝播をエントリポイントとスコープで吸収する戦略である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nC0LH","x":1918,"y":884,"name":"L1-11::Group 2 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr5:34","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xB9no","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはErlangのlet it crash哲学を継承し監視プロセスで回復する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SE3HT","x":1634,"y":484,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Group 23 :: Sticky Note dr4:26","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5yz3w","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはBEAMの信頼性を保ったままRuby風構文で参入障壁を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3EWEP","x":1634,"y":284,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Group 23 :: Sticky Note dr14:30","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kNMU0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはRuby的な人間工学をBEAMの並行分散基盤に接続した設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sk9qh","x":1918,"y":284,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Group 23 :: Sticky Note dr14:68","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RQFp4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirやRubyの対話性は初期開発段階の心理的障壁を下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nIhpg","x":2202,"y":284,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Group 23 :: Sticky Note dr16:63","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9wa1F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはRuby風表記の表面構文とLisp由来のメタプログラミング性を両立した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"X9CxL","x":1918,"y":484,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Group 71 :: Sticky Note dr3:12","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1Hmlw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elixir は BEAM の並行性と耐障害性を継承しつつ、モダンな構文とマクロで開発体験を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GSYFi","x":2202,"y":484,"name":"L1-11::Group 2 :: Group 1 :: Group 12 :: Lone 567 :: Sticky Note dr14:31","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"e1UhW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはErlangの強固な耐障害性を保ちながら構文障壁を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"CYoCh","x":2202,"y":684,"name":"L1-11::Group 2 :: Group 1 :: Group 25 :: Group 19 :: Sticky Note dr3:13","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uGKBz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elixir は OTP を DSL 的に扱いやすくし、Phoenix などの Web 開発でアクターモデル活用を広げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4IX3s","x":1634,"y":884,"name":"L1-11::Group 2 :: Group 1 :: Group 25 :: Group 19 :: Sticky Note dr4:28","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SHiRg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElixirはPhoenixなどを通じてRuby経験者の関数型移行を促進した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RKVak","x":1634,"y":684,"name":"L1-11::Group 2 :: Group 1 :: Group 25 :: Group 19 :: Sticky Note dr13:14","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ebOAA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PhoenixはElixir採用をWeb分散領域で拡大した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","i