2,28,28,28],"children":[{"type":"text","id":"8TuJ7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java は Project Loom で Virtual Thread を導入し、既存 Thread API の互換性を保ちながら軽量スレッド化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fDXUO","x":164,"y":884,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr3:45","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"o5jQ4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java の Virtual Thread はブロッキングスタイルの可読性を維持しつつ高並行性を狙う設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LVWfe","x":164,"y":484,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr13:44","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bbilB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaはProject LoomでVirtual Threadsを導入し色分け依存を弱めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"daMyJ","x":448,"y":484,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr13:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"J14se","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java Virtual Threadsは多数接続を同期スタイルで扱う実装を容易にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TzkDM","x":164,"y":684,"name":"L1-4::Group 8 :: Group 1 :: Group 18 :: Group 13 :: Sticky Note dr15:63","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oOO4v","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java Project Loom は Virtual Threads で thread-per-request の高コスト問題を緩和する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cTQtP","x":164,"y":284,"name":"L1-4::Group 8 :: Group 1 :: Group 111 :: Group 126 :: Sticky Note dr13:49","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iHaE8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JVMはブロッキング時に仮想スレッドをアンマウントしてキャリアを再利用する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2ItMB","x":448,"y":284,"name":"L1-4::Group 8 :: Group 1 :: Group 111 :: Group 126 :: Sticky Note dr15:64","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oi0zH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Virtual Threads はブロッキング時に JVM が unmount しキャリアスレッドを再利用できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0IpsS","x":448,"y":884,"name":"L1-4::Group 8 :: Group 1 :: Lone 215 :: Lone 243 :: Sticky Note dr3:46","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PEiyL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java の Loom は従来のスレッド数上限問題を緩和し、Executor とブロッキング API の運用を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IC4ON","x":448,"y":1620,"name":"L1-4::Group 20 :: Group 1 :: Group 103 :: Group 116 :: Sticky Note dr6:64","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yiBVp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java JPMSは`module-info.java`で依存とエクスポートを明示しJDK自体の分割にも寄与した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"P5Nam","x":164,"y":1620,"name":"L1-4::Group 20 :: Group 1 :: Group 103 :: Group 116 :: Sticky Note dr16:19","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TbCLx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JPMS（Project Jigsaw）はclass path中心の依存解決をmodule-info.java中心へ転換した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vNyxN","x":164,"y":1820,"name":"L1-4::Group 20 :: Group 1 :: Lone 360 :: Lone 409 :: Sticky Note dr6:65","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uQXSE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java JPMSは既存Maven/OSGi資産との整合コストが高く全面採用は限定的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4w7TK","x":448,"y":1820,"name":"L1-4::Group 20 :: Group 1 :: Lone 589 :: Lone 652 :: Sticky Note dr16:20","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lFsRH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JPMSはJAR Hellの実行時顕在化を明示依存宣言で抑制する狙いを持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IuuBA","x":164,"y":2020,"name":"L1-4::Group 20 :: Group 1 :: Lone 590 :: Lone 653 :: Sticky Note dr16:21","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VJxdO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JPMSはStrong EncapsulationでJDK内部APIへの非公開アクセスを制限した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2VctC","x":448,"y":2020,"name":"L1-4::Group 20 :: Group 1 :: Lone 592 :: Lone 655 :: Sticky Note dr16:23","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"omeWD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JPMS導入はSpringなど反射依存ライブラリに移行負荷を生んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GvnKw","x":164,"y":2220,"name":"L1-4::Group 20 :: Group 1 :: Lone 604 :: Lone 668 :: Sticky Note dr16:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aTsYO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JPMS exportsとopensはJavaにモジュール境界での公開制御を追加した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XlHq9","x":3506,"y":284,"name":"L1-4::Group 23 :: Group 1 :: Group 17 :: Group 26 :: Sticky Note dr15:26","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gYpYg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 8 の Streams とラムダは checked exception との合成で追加ラッパーを要しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GSjnx","x":3790,"y":284,"name":"L1-4::Group 23 :: Group 1 :: Group 17 :: Group 92 :: Sticky Note dr15:23","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cEVYY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java は checked exception で回復可能エラー処理をコンパイル時に強制した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZvHn3","x":3506,"y":484,"name":"L1-4::Group 23 :: Group 1 :: Group 17 :: Lone 619 :: Sticky Note dr15:24","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Gn12b","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java の checked exception は API 進化時に throws 連鎖更新を誘発し互換性負担を増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yyzef","x":3790,"y":484,"name":"L1-4::Group 23 :: Group 1 :: Lone 297 :: Lone 339 :: Sticky Note dr5:2","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IWLek","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの検査例外は大規模コードベースでthrows汚染とラップ例外増加を招きやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nbB1h","x":1902,"y":284,"name":"L1-4::Group 37 :: Group 1 :: Group 14 :: Group 10 :: Sticky Note dr12:1","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uuDvx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは用途別にSerial GC、Parallel GC、G1 GC、ZGC、Shenandoah GCを提供してきた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qHc1F","x":2186,"y":284,"name":"L1-4::Group 37 :: Group 1 :: Group 14 :: Lone 169 :: Sticky Note dr2:10","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bTnUg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのSerial GCは小規模用途では有効だったが大規模ヒープでは長いポーズが問題化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1EleC","x":1902,"y":484,"name":"L1-4::Group 37 :: Group 1 :: Lone 156 :: Lone 172 :: Sticky Note dr2:15","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YOgCZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのG1はリージョン単位管理と目標ポーズ時間制御で大規模ヒープ向け汎用性を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"67Jgi","x":2186,"y":484,"name":"L1-4::Group 37 :: Group 1 :: Lone 157 :: Lone 173 :: Sticky Note dr2:16","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VOmOK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのG1は多くのサーバで実用的なバランスを実現した一方で設定項目が増えて複雑化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yD6Pz","x":1484,"y":1620,"name":"L1-4::Group 55 :: Group 1 :: Group 16 :: Group 18 :: Sticky Note dr1:61","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ghn5W","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのnullableアノテーション方式は互換性に優れる一方で注釈欠落時の保証が弱い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"29MIf","x":1484,"y":1820,"name":"L1-4::Group 55 :: Group 1 :: Group 16 :: Group 18 :: Sticky 