ffect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"d4ZYp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのSerial GCは単純なSTW方式を採用して実装容易性と予測可能性を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"InTLl","x":2938,"y":1820,"name":"L1-4::Group 111 :: Group 1 :: Group 45 :: Group 43 :: Sticky Note dr6:16","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1Tf2D","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのpackage-private既定は同一パッケージを内部実装境界として使う前提で設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YcQJz","x":2938,"y":1620,"name":"L1-4::Group 111 :: Group 1 :: Group 45 :: Group 43 :: Sticky Note dr16:44","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gDR2O","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java package-privateは同一パッケージ内協調を容易にするがJAR境界を保証しない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"jVVWi","x":3506,"y":812,"name":"L1-4::Group 113 :: Group 1 :: Group 68 :: Group 68 :: Sticky Note dr2:76","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TmLc4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは参照オーバーヘッド反省からProject Valhallaで値クラス導入を進めている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"84FSa","x":164,"y":1212,"name":"L1-4::Group 138 :: Group 1 :: Lone 573 :: Lone 636 :: Sticky Note dr15:62","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ayoJE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Koka は evidence-passing と選択的 CPS で重いランタイム依存を抑える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oZLrL","x":2938,"y":2148,"name":"L1-4::Group 161 :: Group 1 :: Group 2 :: Group 114 :: Sticky Note dr6:54","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"o3Kjc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GraalVMはTruffle/Graal上でJava JavaScript Ruby Python等を横断実行するポリグロット基盤を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tdDKC","x":1902,"y":1620,"name":"L1-4::Group 165 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:107","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PtvRT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaとHaskellは真偽値型以外を条件式に入れない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FDzWt","x":1902,"y":1820,"name":"L1-4::Group 165 :: Group 1 :: Lone 382 :: Lone 432 :: Sticky Note dr11:33","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PZBm1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのSealed ClassesとRecordsは直和型と直積型を言語標準で表現可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6TFlw","x":164,"y":2628,"name":"L1-4::Group 174 :: Group 1 :: Group 22 :: Lone 217 :: Sticky Note dr2:75","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kxvuI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは統一オブジェクトモデルを優先して参照型中心設計を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ebjxW","x":164,"y":2828,"name":"L1-4::Group 174 :: Group 1 :: Lone 440 :: Lone 494 :: Sticky Note dr12:69","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lQv1t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの参照型中心設計はポインタ追跡増加でキャッシュ効率を下げやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"z7AgC","x":3924,"y":812,"name":"L1-4::Group 193 :: Group 1 :: Lone 641 :: Lone 710 :: Sticky Note nishio:32","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rhpvF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは実装継承を単一に制限し、インターフェース多重実装で補う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Iq0KS","x":1902,"y":812,"name":"L1-4::Group 197 :: Group 1 :: Lone 145 :: Lone 160 :: Sticky Note dr1:63","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LGvYQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java方式の限界はより強いnull安全言語への移行動機になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FT3zV","x":1902,"y":1012,"name":"L1-4::Group 197 :: Group 1 :: Lone 639 :: Lone 708 :: Sticky Note nishio:29","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nf3lw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaはユーザー定義演算子を制限し、x + yよりx.add(y)が増えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"uPOnw","x":866,"y":284,"name":"L1-4::Group 198 :: Group 1 :: Lone 154 :: Lone 170 :: Sticky Note dr2:13","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"K6TqI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのCMSは並行マークでSTW時間を削減して応答性向上を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3f8X5","x":866,"y":484,"name":"L1-4::Group 198 :: Group 1 :: Lone 622 :: Lone 686 :: Sticky Note dr16:78","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OeGl9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GraalVM Native ImageはJavaの起動遅延とメモリ負荷をAOTで大きく改善する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KgRmy","x":1200,"y":2628,"name":"L1-4::Group 199 :: Group 1 :: Lone 155 :: Lone 171 :: Sticky Note dr2:14","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ODQO9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのCMSは平均ポーズ短縮に成功したが断片化と予測不能なフルGCが運用負荷を増やした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"C7VZD","x":3356,"y":1620,"name":"L1-4::Group 211 :: Group 1 :: Lone 197 :: Lone 220 :: Sticky Note dr2:79","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5zGKx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの従来GCは長ポーズにより低遅延分野で採用障壁になった歴史がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cjRP1","x":3356,"y":1820,"name":"L1-4::Group 211 :: Group 1 :: Lone 317 :: Lone 361 :: Sticky Note dr5:46","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2yyKH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの歴史的switchは網羅性検査が弱くdefaultへ流れやすかった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZfNIu","x":5094,"y":1620,"name":"L1-4::Group 256 :: Group 1 :: Lone 631 :: Lone 697 :: Sticky Note nishio:12","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oMNsD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaはintなどのサイズと範囲を言語仕様で固定する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ql92R","x":5094,"y":1820,"name":"L1-4::Group 256 :: Group 1 :: Lone 656 :: Lone 729 :: Sticky Note nishio:57","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vFbBT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CとJavaは固定幅整数を維持し、暗黙の多倍長化をしない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tMJNq","x":2320,"y":812,"name":"L1-4::Group 257 :: Group 1 :: Lone 650 :: Lone 721 :: Sticky Note nishio:45","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"o8qgS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaはトップレベル変数を持たず、静的メンバで近い効果を作る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9Uch8","x":2320,"y":1012,"name":"L1-4::Group 257 :: Group 1 :: Lone 674 :: Lone 748 :: Sticky Note nishio:85","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YZ1oY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaはthisを暗黙に提供し必要時に明示参照できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dQJ5f","x":582,"y":1212,"name":"L1-4::Group 258 :: Group 1 :: Lone 653 :: Lone 724 :: Sticky Note nishio:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"daMPv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaとC99は整数除算を0方向へ丸める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qwY1X","x":1618,"y":2628,"name":"L1-4::Group 259 :: Group 1 :: Lone 665 :: Lone 739 :: Sticky Note nishio:71","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"r4b1Y","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"J言語は負数を_1記法で表す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"V1CVZ","x":2738,"y":812,"name":"L1-4::Lone 307 :: Group 1 :: Lone 383 :: Lone 433 :: Sticky Note dr11:34","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vOT4t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのJEP 409とJEP 395はVisitor依存を減らし宣言的で安全な分岐を促進した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"PFUIA","x":582,"y":2628,"name":"L1-4::Lone 354 :: Group 1 :: Lone 574 :: Lone 637 :: Sticky Note dr15:65","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Zt90Z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"I/O 完了後の remount により Java は同期記述のまま高並行性を得られる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iURxJ","x":2036,"y":2628,"name":"L1-4::Lone 359 :: Group 1 :: Lone 591 :: Lone 654 :: Sticky Note dr16:22","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cW6Kx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"jlinkは必要モジュールのみのカスタムランタイム生成を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SEbx8","x":1484,"y":2148,"name":"L1-4::Lone 365 :: Group 1 :: Lone 633 :: Lone 700 :: Sticky Note nishio:17","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tvwhc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java