Ja9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 5はオートボクシングでプリミティブとオブジェクトの橋渡しをした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bBga2","x":2888,"y":484,"name":"L1-4::Group 57 :: Group 1 :: Group 22 :: Lone 698 :: Sticky Note nishio:15","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SEE6T","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java配列はオブジェクトとして扱われ、値として渡せる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SZo5b","x":1284,"y":284,"name":"L1-4::Group 58 :: Group 1 :: Group 26 :: Group 22 :: Sticky Note dr13:64","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"poDJ5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 21のStructuredTaskScopeは関連サブタスクを一単位で管理する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wxsNq","x":3774,"y":1620,"name":"L1-4::Group 61 :: Group 1 :: Group 37 :: Group 31 :: Sticky Note dr2:20","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6Q2EH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのShenandoahは並行エバキュエーションでコンパクション起因の長ポーズ回避を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tv2Fr","x":2320,