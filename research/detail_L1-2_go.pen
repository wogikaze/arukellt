":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6tlOd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは簡潔な並行コードを書きやすくした一方でリアルタイム用途ではGCポーズが課題になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cVpJR","x":2186,"y":1748,"name":"L1-2::Group 11 :: Group 1 :: Lone 203 :: Lone 227 :: Sticky Note dr3:6","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pAB5C","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go では goroutine の低コスト化と引き換えに、リークや starvation の診断が難しい課題が残る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kgYsX","x":1902,"y":1948,"name":"L1-2::Group 11 :: Group 1 :: Lone 272 :: Lone 312 :: Sticky Note dr4:69","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0tEAj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは継承抑制や機能選別でチーム保守向けの単純さを優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3JDAo","x":2186,"y":1948,"name":"L1-2::Group 11 :: Group 1 :: Lone 410 :: Lone 460 :: Sticky Note dr12:14","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D8yVx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは主要GCノブをGOGCへ集約して運用複雑性を抑えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"PG16g","x":1902,"y":2148,"name":"L1-2::Group 11 :: Group 1 :: Lone 510 :: Lone 568 :: Sticky Note dr14:32","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dHOx1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは大規模組織の協調開発を前提に機能制約でシンプルさを実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"uVRBG","x":2186,"y":2148,"name":"L1-2::Group 11 :: Group 1 :: Lone 512 :: Lone 571 :: Sticky Note dr14:35","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Uu4a5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの簡潔な表面構文はランタイム側の高度な複雑性隠蔽に支えられている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1pDaq","x":2186,"y":284,"name":"L1-2::Group 13 :: Group 1 :: Group 95 :: Group 104 :: Sticky Note dr6:7","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fTvU8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go Modulesは`go.mod`で場所非依存ビルドとバージョン固定依存管理を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"V9xi4","x":1902,"y":284,"name":"L1-2::Group 13 :: Group 1 :: Group 95 :: Group 104 :: Sticky Note dr16:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vbwo1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはGOPATH依存の管理からGo Modulesへ移行し、go.modで依存関係の再現性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9aUoj","x":1902,"y":484,"name":"L1-2::Group 13 :: Group 1 :: Lone 147 :: Lone 162 :: Sticky Note dr2:1","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dfXj8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは手動管理やRCではなくトレーシングGCを前提に採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QB4yN","x":2186,"y":484,"name":"L1-2::Group 13 :: Group 1 :: Lone 253 :: Lone 290 :: Sticky Note dr4:36","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8y2xg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはgofmt前提の設計でスタイル差より内容議論にレビューを集中させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kimTj","x":1902,"y":684,"name":"L1-2::Group 13 :: Group 1 :: Lone 281 :: Lone 323 :: Sticky Note dr4:82","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DAnt3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのgofmtは言語設計と不可分の標準フォーマット文化を形成した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VB8Jp","x":2186,"y":684,"name":"L1-2::Group 13 :: Group 1 :: Lone 332 :: Lone 376 :: Sticky Note dr6:6","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wNnLM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは当初GOPATH固定レイアウトで学習コストを抑えたが大規模開発では柔軟性不足が顕在化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1j76Z","x":1902,"y":884,"name":"L1-2::Group 13 :: Group 1 :: Lone 511 :: Lone 570 :: Sticky Note dr14:34","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pdm7a","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはgofmtを必須文化としてスタイル議論を運用コストから除去した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"W6W1e","x":2186,"y":884,"name":"L1-2::Group 13 :: Group 1 :: Lone 577 :: Lone 640 :: Sticky Note dr16:2","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KlvzZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go ModulesはMVS（Minimal Version Selection）で依存解決を決定的にし、SATソルバ依存を避けた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eT45j","x":3640,"y":812,"name":"L1-2::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr13:72","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kOuVO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futharkは純粋関数型前提でGPU向け依存解析を単純化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QvZGZ","x":3640,"y":1012,"name":"L1-2::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr13:73","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rdDsF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futharkはflattening変換で入れ子並列をGPU実行形へ写像する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oyt4f","x":448,"y":1748,"name":"L1-2::Group 27 :: Group 1 :: Group 36 :: Group 30 :: Sticky Note dr2:2","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4REqw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはCのようなメモリバグを避けつつgoroutineとchannelを単純に保つためにGC前提設計を選んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"poNMy","x":164,"y":1948,"name":"L1-2::Group 27 :: Group 1 :: Group 36 :: Group 30 :: Sticky Note dr3:1","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DLg1A","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go は goroutine と channel を標準に組み込み、CSP の発想で共有メモリより通信を推奨した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HsbMH","x":164,"y":1748,"name":"L1-2::Group 27 :: Group 1 :: Group 36 :: Group 30 :: Sticky Note dr13:4","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f79tc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはgoroutineとchannelを言語コアに置き並行性と並列性を区別して設計した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KHFm7","x":164,"y":2148,"name":"L1-2::Group 27 :: Group 1 :: Group 76 :: Group 80 :: Sticky Note dr3:73","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xytt1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go は fire-and-forget 的な go 文により、キャンセル漏れで goroutine リークやチャネルデッドロックを起こしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RzU81","x":448,"y":1948,"name":"L1-2::Group 27 :: Group 1 :: Group 76 :: Group 80 :: Sticky Note dr13:81","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JYUQJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは受信者不在チャネル送信や無期限待機でgoroutineリークを起こしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9S9xG","x":448,"y":2148,"name":"L1-2::Group 27 :: Group 1 :: Lone 455 :: Lone 509 :: Sticky Note dr13:6","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"m2bys","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは明示ロック中心の設計より通信中心の協調を推奨する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ivdMV","x":1284,"y":1748,"name":"L1-2::Group 37 :: Group 1 :: Lone 402 :: Lone 452 :: Sticky Note dr12:5","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OljLZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"G1 GCはリージョン分割とGarbage-First回収でポーズ予測性とスループットを両立する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"N9zeZ","x":4476,"y":1748,"name":"L1-2::Group 39 :: Group 1 :: Group 46 :: Group 45 :: Sticky Note dr16:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gH8y0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go generateはビルド魔法を減らす一方で生成コード管理コストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OopzX","x":2604,"y":1748,"name":"L1-2::Group 61 :: Group 1 :: Lone 404 :: Lone 454 :: Sticky Note dr12:7","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cHbGS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Shenandoah GCはBrooks forwarding pointersで並行コンパクションを実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"E7wbH","x":164,"y":1340,"name":"L1-2::Group 62 :: Group 1 :: Group 38 :: Group 32 :: Sticky Note dr2:37","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2aemd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのARCはGCポーズを避ける代わりに強参照サイクル対策としてweak/unownedを要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bCj2Y","x":1902,"y":2884,"name":"L1-2::Group 68 :: Group 1 :: Group 60 :: Group 59 :: Sticky Note dr2:4","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"m6xnd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go 1.5のGCは並行三色マークスイープを採用して低レイテンシを主目標に置いた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ijCys","x":1618,"y":2884,"name":"L1-2::Group 68 :: Group 1 :: Group 60 :: Group 59 :: Sticky Note dr12:11","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"w85aE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go 1.5は並行三色マークスイープへ移行して長い停止を大幅に削減した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"29yKn","x":1618,"y":3084,"name":"L1-2::Group 68 :: Group 1 :: Lone 149 :: Lone 164 :: Sticky Note dr2:5","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BPiAQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go 1.5のGCはThroughputよりポーズ時間短縮を優先してミリ秒級ポーズを狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"q8q4s","x":1902,"y":3084,"name":"L1-2::Group 68 :: Group 1 :: Lone 150 :: Lone 165 :: Sticky Note dr2:6","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2BV4b","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go 1.5のGCはポーズ改善と引き換えにCPUオーバーヘッド増加のトレードオフを持った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"B0GZJ","x":164,"y":284,"name":"L1-2::Group 82 :: Group 1 :: Lone 260 :: Lone 298 :: Sticky Note dr4:51","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"F4N3g","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは言語機能を抑える代わりにライブラリと慣習への依存が相対的に強い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SMuod","x":448,"y":284,"name":"L1-2::Group 82 :: Group 1 :: Lone 341 :: Lone 385 :: Sticky Note dr6:24","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vx5R8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは言語機能を抑制して並列コンパイル前提のツールチェーンを選びビルド速度を最優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KxoiG","x":164,"y":484,"name":"L1-2::Group 82 :: Group 1 :: Lone 370 :: Lone 420 :: Sticky Note dr11:16","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4ABdC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは := による局所推論に限定して可読性と超高速コンパイルを優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"W9pIp","x":448,"y":484,"name":"L1-2::Group 82 :: Group 1 :: Lone 608 :: Lone 672 :: Sticky Note dr16:50","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TnXAe","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは循環import禁止で依存グラフをDAGに固定し高速ビルドを実現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3R8Ek","x":582,"y":1340,"name":"L1-2::Group 102 :: Group 1 :: Group 14 :: Group 10 :: Sticky Note dr12:3","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"niRO0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Parallel GCはスループット重視でバッチ処理に向くがポーズ時間が伸びやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4HZmY","x":164,"y":3084,"name":"L1-2::Group 110 :: Group 1 :: Group 42 :: Group 39 :: Sticky Note dr5:15","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"95b53","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは(T, error)の多値返却で失敗を値として扱う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"jcI4F","x":164,"y":2884,"name":"L1-2::Group 110 :: Group 1 :: Group 42 :: Group 39 :: Sticky Note dr15:37","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VohnR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go は errors are values を掲げて例外より多値返却の error を基本にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Pl1br","x":1150,"y":284,"name":"L1-2::Group 112 :: Group 1 :: Group 46 :: Group 45 :: Sticky Note dr6:46","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bQnmx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの`go generate`は言語内マクロを避け外部生成ツール呼び出しを標準化する実務的折衷案である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"owhP4","x":866,"y":284,"name":"L1-2::Group 112 :: Group 1 :: Group 46 :: Group 45 :: Sticky Note dr16:67","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VEv42","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go generateは//go:generate経由で外部CLIを実行し、静的コード生成を明示的に行う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"szjRi","x":866,"y":484,"name":"L1-2::Group 112 :: Group 1 :: Lone 354 :: Lone 399 :: Sticky Note dr6:47","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ArWrn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの生成コード運用はコミット方針と必須手順の合意がないとチーム摩擦を生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kqf1o","x":3924,"y":284,"name":"L1-2::Group 114 :: Group 1 :: Group 69 :: Group 69 :: Sticky Note dr3:3","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LH4M8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go の M:N スケジューラは goroutine を OS スレッドより軽量に運用できるように設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"u74on","x":3640,"y":284,"name":"L1-2::Group 114 :: Group 1 :: Group 69 :: Group 69 :: Sticky Note dr13:53","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PIaRl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoランタイムはM:Nスケジューリングでgoroutineを少数OSスレッドへ多重化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eOAwd","x":3640,"y":484,"name":"L1-2::Group 114 :: Group 1 :: Lone 513 :: Lone 572 :: Sticky Note dr14:36","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zcf8D","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのgoroutineは並行実行の実装負荷を開発者からランタイムへ移譲する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UQkHX","x":4676,"y":2884,"name":"L1-2::Group 115 :: Group 1 :: Group 70 :: Group 70 :: Sticky Note dr3:5","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Tf8pB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go のスケジューラはプリエンプションとワークスティーリングを取り込み、スループットと公平性を改善してきた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eAhzI","x":4392,"y":2884,"name":"L1-2::Group 115 :: Group 1 :: Group 70 :: Group 70 :: Sticky Note dr13:54","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1zOGJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはプリエンプション改善で長時間実行ループの公平性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"C2C5l","x":4392,"y":3084,"name":"L1-2::Group 115 :: Group 1 :: Lone 580 :: Lone 643 :: Sticky Note dr16:5","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"48fQT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goエコシステムはモジュールプロキシ導入で取得経路の安定性と検証性を強化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ry5xG","x":3640,"y":1948,"name":"L1-2::Group 119 :: Group 1 :: Group 96 :: Group 105 :: Sticky Note dr6:8","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"U1b5k","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの公開規則は識別子先頭の大文字小文字で可視性を表すため構文は軽いが粒度は粗い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TTjC3","x":3640,"y":1748,"name":"L1-2::Group 119 :: Group 1 :: Group 96 :: Group 105 :: Sticky Note dr16:36","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tTZ7N","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは識別子先頭の大文字小文字で公開範囲を判定し、修飾子構文を省いた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vMH44","x":164,"y":812,"name":"L1-2::Group 122 :: Group 1 :: Group 107 :: Group 120 :: Sticky Note dr12:16","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UuyKr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoのEscape Analysisはスタック割り当てを増やしてGC対象を減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"otuiB","x":448,"y":812,"name":"L1-2::Group 122 :: Group 1 :: Group 107 :: Group 120 :: Sticky Note dr12:68","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qaKrc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoのEscape Analysisはヒープ回避でキャッシュ局所性とGC効率に寄与する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UIyl9","x":164,"y":1012,"name":"L1-2::Group 122 :: Group 1 :: Lone 411 :: Lone 461 :: Sticky Note dr12:15","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HhHeS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoのPacerはGC開始時点を動的制御してポーズとメモリ成長を調整する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FAQ0r","x":2604,"y":284,"name":"L1-2::Group 123 :: Group 1 :: Lone 412 :: Lone 462 :: Sticky Note dr12:19","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yuaTx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Server GCはコアごとのヒープと専用GCスレッドで高スループットを狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"C1GB2","x":2604,"y":484,"name":"L1-2::Group 123 :: Group 1 :: Lone 413 :: Lone 463 :: Sticky Note dr12:20","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FMPG4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Server GCはメモリ消費増加と同期コストを受け入れて性能を得る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"c4eG3","x":4342,"y":284,"name":"L1-2::Group 124 :: Group 1 :: Group 108 :: Group 121 :: Sticky Note dr12:18","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CYrzA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Workstation GCはUI応答性重視で小さなポーズを優先する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0Dmqz","x":4626,"y":284,"name":"L1-2::Group 124 :: Group 1 :: Lone 199 :: Lone 223 :: Sticky Note dr2:85","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QQxlt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GC採用言語は負担軽減と安全性を優先しつつレイテンシとスループットの配分で戦略を分化させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YfUml","x":4342,"y":484,"name":"L1-2::Group 124 :: Group 1 :: Lone 407 :: Lone 457 :: Sticky Note dr12:10","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WfsA4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoのGC方針はスループット最適化より低レイテンシ維持を優先する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6ohCX","x":4058,"y":812,"name":"L1-2::Group 134 :: Group 1 :: Lone 252 :: Lone 289 :: Sticky Note dr4:35","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ex5U3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは字句規則でセミコロンを自動挿入しソース上の;を原則省略する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iIhCO","x":4058,"y":1012,"name":"L1-2::Group 134 :: Group 1 :: Lone 500 :: Lone 557 :: Sticky Note dr14:16","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"591Zu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは字句解析段階で決定的なセミコロン挿入規則を適用して曖昧さを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"H06IX","x":2938,"y":2884,"name":"L1-2::Group 176 :: Group 1 :: Group 29 :: Lone 628 :: Sticky Note dr15:39","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KdrWx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go のエラー冗長性を減らす try/check 提案は隠れた制御フロー懸念で却下された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"jSbai","x":2938,"y":3084,"name":"L1-2::Group 176 :: Group 1 :: Lone 306 :: Lone 348 :: Sticky Note dr5:17","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Zr0gk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはtry構文提案を見送りerrorラッピングと慣用句で運用している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"g599W","x":866,"y":812,"name":"L1-2::Group 192 :: Group 1 :: Lone 122 :: Group 58 :: Sticky Note dr5:16","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dW3pP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのif err != nil反復は可読性と冗長性のトレードオフを生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bVrl4","x":866,"y":1012,"name":"L1-2::Group 192 :: Group 1 :: Lone 565 :: Lone 627 :: Sticky Note dr15:38","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lADnN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go では if err != nil { return err } の明示分岐が障害経路を可視化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zcWTZ","x":3640,"y":2276,"name":"L1-2::Group 199 :: Group 1 :: Lone 401 :: Lone 451 :: Sticky Note dr12:4","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gsVak","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CMS GCは低ポーズ化に寄与したが断片化問題と保守負荷で廃止された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pewPx","x":3356,"y":2884,"name":"L1-2::Group 206 :: Group 1 :: Lone 189 :: Lone 211 :: Sticky Note dr2:69","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MEAvE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ゲーム開発はGCポーズ回避と断片化抑制のためフレームアリーナを広く活用する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oJuBl","x":4058,"y":1748,"name":"L1-2::Group 209 :: Group 1 :: Lone 195 :: Lone 218 :: Sticky Note dr2:77","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DHYO2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは値渡し基本にエスケープ解析最適化を組み合わせて単純さと性能を両立する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"O8gDz","x":4058,"y":1948,"name":"L1-2::Group 209 :: Group 1 :: Lone 609 :: Lone 673 :: Sticky Note dr16:51","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BEVIf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはヘッダレス設計とエクスポート情報埋め込みで再解析コストを抑える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3pfLm","x":582,"y":2884,"name":"L1-2::Group 210 :: Group 1 :: Lone 196 :: Lone 219 :: Sticky Note dr2:78","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XIgfH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはポインタ利用を明示させることで共有可変状態の責任をコード上に表出させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"q0hM2","x":582,"y":3084,"name":"L1-2::Group 210 :: Group 1 :: Lone 439 :: Lone 493 :: Sticky Note dr12:67","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YZy8m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは値渡しを基本とし必要時のみポインタで共有を表現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3BURU","x":4476,"y":812,"name":"L1-2::Group 214 :: Group 1 :: Lone 202 :: Lone 226 :: Sticky Note dr3:4","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"G8L07","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go の設計は多数接続サーバで大量タスクを扱いやすくし、スレッド数管理の負担を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZMqmb","x":3774,"y":2884,"name":"L1-2::Group 216 :: Group 1 :: Lone 371 :: Lone 421 :: Sticky Note dr11:17","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YBNn3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの保守的推論方針は巨大コードベースでの予測可能性を重視する設計判断である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"mWuoG","x":866,"y":1748,"name":"L1-2::Group 217 :: Group 1 :: Lone 229 :: Lone 258 :: Sticky Note dr3:74","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"G0d7F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go では context.Context と errgroup が構造化並行性を補う実務パターンとして広く使われる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LQYaj","x":866,"y":1948,"name":"L1-2::Group 217 :: Group 1 :: Lone 487 :: Lone 541 :: Sticky Note dr13:82","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uCCWb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goではcontextによるタイムアウトとキャンセル伝播が実運用の必須規律となった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kHvML","x":164,"y":3412,"name":"L1-2::Group 220 :: Group 1 :: Lone 254 :: Lone 291 :: Sticky Note dr4:37","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tVAvY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは改行位置が構文に影響するためifやforヘッダ改行に罠がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bHrn5","x":3022,"y":284,"name":"L1-2::Group 233 :: Group 1 :: Lone 333 :: Lone 377 :: Sticky Note dr6:9","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kCnUy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの可視性モデルはキーワード追加を避ける設計思想と引き換えに細粒度アクセス制御を捨てている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aHYBQ","x":3022,"y":484,"name":"L1-2::Group 233 :: Group 1 :: Lone 456 :: Lone 510 :: Sticky Note dr13:7","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YaWye","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのモデルはクラウドネイティブ実装で高い採用を得た。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2l1Pp","x":1000,"y":2884,"name":"L1-2::Group 240 :: Group 1 :: Lone 390 :: Lone 440 :: Sticky Note dr11:42","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nOiaP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは長期にジェネリクスを見送り単純性を維持した後Go 1.18で制約付き型パラメータを導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6Tok3","x":1000,"y":3084,"name":"L1-2::Group 240 :: Group 1 :: Lone 391 :: Lone 441 :: Sticky Note dr11:43","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7Mc5N","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go 1.18実装は単相化と辞書渡しを併用し性能とコンパイル時間の均衡を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AviU4","x":1284,"y":812,"name":"L1-2::Group 252 :: Group 1 :: Lone 578 :: Lone 641 :: Sticky Note dr16:3","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jtOZr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go Modules移行期にはdepコミュニティとの調整不足が摩擦を生んだ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IYV2m","x":1284,"y":1012,"name":"L1-2::Group 252 :: Group 1 :: Lone 579 :: Lone 642 :: Sticky Note dr16:4","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5rZ2K","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go Modulesはセマンティックインポートバージョニングで複数メジャー共存を実現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Nl7nW","x":164,"y":2476,"name":"L1-2::Lone 267 :: Group 1 :: Group 33 :: Lone 569 :: Sticky Note dr14:33","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wX99G","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goはクラス継承や演算子オーバーロードを排し方言化の拡大を抑制した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VRnBM","x":5094,"y":2884,"name":"L1-2::Lone 275 :: Group 1 :: Lone 151 :: Lone 166 :: Sticky Note dr2:7","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JEeBL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはJVM系GCの複雑なチューニング文化を避けて設定不要で実用的なレイテンシを重視した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9s1xn","x":3022,"y":1748,"name":"L1-2::Lone 281 :: Group 1 :: Lone 201 :: Lone 225 :: Sticky Note dr3:2","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jFW7i","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go は並行性を問題分割の構造として扱い、並列性を実行機構として分離した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MI0fw","x":2938,"y":3412,"name":"L1-2::Lone 286 :: Group 1 :: Lone 259 :: Lone 297 :: Sticky Note dr4:50","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zaWDT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goは約25語の小さなキーワード集合で仕様全体の把握容易性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"L6fZc","x":1902,"y":2476,"name":"L1-2::Lone 291 :: Group 1 :: Lone 288 :: Lone 330 :: Sticky Note dr4:91","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4pQT1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go Playgroundやcargo runはREPL不足を補う反復手段として発達した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"903fV","x":2320,"y":2884,"name":"L1-2::Lone 298 :: Group 1 :: Lone 342 :: Lone 386 :: Sticky Note dr6:25","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OVhcQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの高速ビルドは強みだが高度メタプログラミング機能の制限を不満とする開発者もいる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VjU02","x":1902,"y":1212,"name":"L1-2::Lone 313 :: Group 1 :: Lone 408 :: Lone 458 :: Sticky Note dr12:12","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pYJIE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの三色マーキングは白灰黒の状態遷移で到達可能性を管理する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SxZpd","x":3640,"y":1340,"name":"L1-2::Lone 314 :: Group 1 :: Lone 409 :: Lone 459 :: Sticky Note dr12:13","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hdCqy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GoはWrite Barrierでミューテータが白オブジェクトを隠す事態を防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GCK4t","x":582,"y":2476,"name":"L1-2::Lone 327 :: Group 1 :: Lone 454 :: Lone 508 :: Sticky Note dr13:5","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sdOmV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのselectは複数チャネル待機を一つの制御点で扱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GqsPD","x":4058,"y":2276,"name":"L1-2::Lone 369 :: Group 1 :: Lone 646 :: Lone 716 :: Sticky Note nishio:39","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QQbr1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"リージョン推論だけでは速度要件を満たせずGC併用に戻る事例がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"path","id":"rel_l1_2_01_line","name":"RelationLine","x":436.0,"y":2028.0,"width":1738.0,"height":1,"geometry":"M 1738.00 0.00 L 0.00 0.00","stroke":{"thickness":1.6,"fill":"#C0392B","dashPattern":[8,4]},"fill":"none"},{"type":"path","id":"rel_l1_2_01_head_t","name":"RelationHead","x":436.0,"y":2020.000000004603,"width":13.999999991944776,"height":15.999999990794095,"geometry":"M 0.00 8.00 L 14.00 0.00 L 14.00 16.00 Z","fill":"#C039