tGrowth":"fixed-width","width":"fill_container","content":"Dart 2.12以降は非nullデフォルトとT?によるnullable明示を導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OqU2x","x":3490,"y":2348,"name":"L1-3::Group 171 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr1:42","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MbN0s","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは値の不在をT?またはOptional<T>で表し非optional型でnilを禁止する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0PjBc","x":1000,"y":2348,"name":"L1-3::Group 177 :: Group 1 :: Group 39 :: Group 33 :: Sticky Note dr3:17","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1Pazn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pony はアクターモデルに reference capabilities を組み合わせ、参照エイリアス可能性を型で表現した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GVmcm","x":1618,"y":2348,"name":"L1-3::Group 178 :: Group 1 :: Group 55 :: Group 51 :: Sticky Note dr1:8","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nxph8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dart初期版は型注釈を任意にするoptional typingで段階的導入の書きやすさを優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Vct7M","x":1618,"y":2548,"name":"L1-3::Group 178 :: Group 1 :: Group 55 :: Group 51 :: Sticky Note dr1:9","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IWxmZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dart初期版のoptional typingはnull由来不具合の抑止が弱く型と実行時挙動の整合性に課題を残した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GOavU","x":3072,"y":2548,"name":"L1-3::Group 181 :: Group 1 :: Group 67 :: Group 67 :: Sticky Note dr2:61","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z0fsp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cycloneはリージョン注釈と型安全を組み合わせてGCなし安全性を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1ToiJ","x":3072,"y":2348,"name":"L1-3::Group 181 :: Group 1 :: Group 67 :: Group 67 :: Sticky Note dr12:58","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LDn3F","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cycloneはリージョンと型安全を組み合わせてC系安全化を試みた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bpBXX","x":164,"y":2676,"name":"L1-3::Group 187 :: Group 1 :: Group 93 :: Group 102 :: Sticky Note dr5:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XpEfU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Unisonのabilitiesは関数依存効果を型に載せてハンドラ分離を促進する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HyzhP","x":582,"y":1940,"name":"L1-3::Group 196 :: Group 1 :: Lone 141 :: Lone 156 :: Sticky Note dr1:56","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1i4uk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Option系モデリングは不在ケースを型レベルに持ち上げて網羅的処理を強制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YLdpp","x":4944,"y":2348,"name":"L1-3::Group 244 :: Group 1 :: Lone 460 :: Lone 514 :: Sticky Note dr13:19","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kKGH7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ponylangのisoとvalは可変共有の危険を型で表現して回避する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ehjMN","x":3022,"y":284,"name":"L1-3::Lone 262 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note nishio:58","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qQJxT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptは整数専用型を基本仕様に持たない時代が長かった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vmIg8","x":1618,"y":2876,"name":"L1-3::Lone 268 :: Group 1 :: Group 43 :: Group 40 :: Sticky Note dr15:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zHjaA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift 6 の typed throws は throws(NetworkError) のような型付き伝播を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fw42R","x":4342,"y":284,"name":"L1-3::Lone 273 :: Group 1 :: Lone 144 :: Lone 159 :: Sticky Note dr1:59","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XR3Gu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OptionやMaybeの冗長性は高信頼領域では受容されやすいがスクリプト用途では負担になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"flVUg","x":582,"y":2676,"name":"L1-3::Lone 297 :: Group 1 :: Lone 321 :: Lone 365 :: Sticky Note dr5:54","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Xfvrp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Effect Systemは例外やI/Oなどの効果を型で追跡する研究領域である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zBO3P","x":1902,"y":812,"name":"L1-3::Lone 302 :: Group 1 :: Lone 373 :: Lone 423 :: Sticky Note dr11:19","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":