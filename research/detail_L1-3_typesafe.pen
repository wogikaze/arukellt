-width","width":"fill_container","content":"CISAやNSAはMemory Safe Languages移行を促すロードマップ策定を推奨している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yv3AC","x":5362,"y":2348,"name":"L1-3::Lone 374 :: Group 1 :: Lone 669 :: Lone 743 :: Sticky Note nishio:76","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TCN5Y","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ML系では多相参照に関する型安全性問題が歴史的に議論された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"path","id":"rel_l1_3_01_line","name":"RelationLine","x":1414,"y":1292,"width":334,"height":1664,"geometry":"M 0.00 0.00 L 334.00 1664.00","stroke":{"thickness":2,"fill":"#616161","strokeAlignment":"outside","alignment":"outside","align":"outside","stroke-alignment":"outside","strokeAlign":"outside","alignMode":"outside","outerAlign":"outer"},"fill":"none","strokeAlignment":"outside","stroke-alignment":"outside"},{"type":"path","id":"rel_l1_3_02_line","name":"RelationLine","x":1414,"y":892,"width":618,"height":400,"geometry":"M 0.00 400.00 L 618.00 0.00","stroke":{"thickness":2,"fill":"#C0392B","dashPattern":[8,4],"strokeAlignment":"outside","alignment":"outside","align":"outside","stroke-alignment":"outside","strokeAlign":"outside","alignMode":"outside","outerAlign":"outer"},"fill":"none","strokeAlignment":"outside","stroke-alignment":"outside"},{"type":"path","id":"rel_l1_3_02_head_t","name":"RelationHead","x":2015.9001270164108,"y":892,"width":16.099872983589194,"height":14.323072961438129,"geometry":"M 16.10 0.00 L 8.69 14.32 L 0.00 0.89 Z","fill":"#C0392B"},{"type":"path","id":"rel_l1_3_02_head_s","name":"RelationHead","x":1414,"y":1277.676927038562,"width":16.099872983589194,"height":14.323072961437902,"geometry":"M 0.