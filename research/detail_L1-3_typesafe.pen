id":"BCTsy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#のvarは動的型付けではなく静的型の省略記法として設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WHG7x","x":2186,"y":284,"name":"L1-3::Group 42 :: Group 1 :: Lone 134 :: Lone 146 :: Sticky Note dr1:27","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YBHiV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#は右辺式の静的型からローカル変数型を推論するvarを導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oITx9","x":1902,"y":484,"name":"L1-3::Group 42 :: Group 1 :: Lone 136 :: Lone 148 :: Sticky Note dr1:30","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IJFJ2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#は型を確定できないvar宣言をコンパイルエラーにする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3SLEc","x":2186,"y":484,"name":"L1-3::Group 42 :: Group 1 :: Lone 137 :: Lone 149 :: Sticky Note dr1:31","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D0a6H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#のvarルールは型が途中で変わる動的言語的挙動を排除する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MW3LA","x":164,"y":3484,"name":"L1-3::Group 55 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr1:60","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"o1BlY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaは型体系を変えず@Nullableと@NonNullでnullabilityを表す方式を広く使ってきた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3yI1r","x":164,"y":3284,"name":"L1-3::Group 55 :: Group 1 :: Group 8 :: Group 8 :: Sticky Note dr11:24","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oncgc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Null安全性にはNullable注釈とOption型とUnion型とアンボックスト表現という主要系統がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nKxnh","x":1200,"y":3284,"name":"L1-3::Group 90 :: Group 1 :: Lone 626 :: Lone 690 :: Sticky Note nishio:4","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tOkfZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaではif (x = 0)は条件式の型不一致でコンパイルエラーになる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LP92V","x":3640,"y":284,"name":"L1-3::Group 93 :: Group 1 :: Group 2 :: Group 27 :: Sticky Note dr16:80","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CIfJn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptモジュール分裂はESM時代でも互換層の複雑性として技術負債を残す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UZZno","x":3924,"y":284,"name":"L1-3::Group 93 :: Group 1 :: Group 2 :: Lone 404 :: Sticky Note dr6:57","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kqpnY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptエコシステムはESM収束が進んだが互換維持のため形式混在対応が依然必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oSmQM","x":3640,"y":484,"name":"L1-3::Group 93 :: Group 1 :: Lone 588 :: Lone 651 :: Sticky Note dr16:18","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Gyn88","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ESM移行後もCommonJS互換問題がデュアルパッケージ問題として残存している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"foV9Z","x":164,"y":2348,"name":"L1-3::Group 97 :: Group 1 :: Group 5 :: Group 34 :: Sticky Note dr3:41","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nnduY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の fearless concurrency は Send と Sync でスレッド間送受信可能性と共有可能性を型に刻む。","lineHeight":1.6,"f