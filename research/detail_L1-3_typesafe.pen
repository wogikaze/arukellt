},"cornerRadius":8},{"type":"rectangle","id":"island_l1_3_Lone_310","name":"Island::型安全と互換性の論点 (1枚)","x":2012,"y":3260,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"rectangle","id":"island_l1_3_Lone_311","name":"Island::型安全の論点 (1枚)","x":3884,"y":2324,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"rectangle","id":"island_l1_3_Lone_323","name":"Island::CISAやNSAはMemory Sa… (1枚)","x":4736,"y":260,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"rectangle","id":"island_l1_3_Lone_374","name":"Island::型安全の論点 (1枚)","x":5338,"y":2324,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"frame","id":"plate_00013","x":100,"y":80,"name":"Nameplate::[L1] 言語設計における型安全と移行互","width":260,"fill":"#FFCC80","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"plate_00013_t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"[L1] 言語設計における型安全と移行互換の知見","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"600"}]},{"type":"frame","id":"37Ucp","x":4526,"y":2348,"name":"L1-3::Group 4 :: Group 1 :: Lone 206 :: Lone 230 :: Sticky Note dr3:10","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mHaUG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang の関数型スタイルは起源の影響が大きく、アクターモデル自体が関数型を必須にするわけではない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lzu1c","x":448,"y":484,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:1","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iYcnT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptは既存JavaScript資産を壊さず静的型検査を段階導入できる漸進的型付けを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YAoPZ","x":732,"y":484,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:3","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bIsit","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptは型注釈ありと型注釈なしの混在コードでもIDEの型エラー検出と補完を提供した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ovY8x","x":164,"y":684,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:4","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AADhR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptの漸進的型付けは既存エコシステム互換を維持しながら型安全性を高める実務解として定着した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tMC0s","x":448,"y":684,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:5","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qwx4L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptのtypes as comments構想はJavaScriptエンジンが型注釈を無視する前提で設計された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1FcD9","x":732,"y":684,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:6","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6WwM5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptのtypes as comments構想は型意味論を外部型チェッカーに委譲してランタイムと型検査を分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"086TF","x":164,"y":884,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr1:7","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"19Ev7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptのtypes as comments構想はトランスパイル依存を減らして型付き構文の実行互換を高める方向を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"m8WWH","x":164,"y":284,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:3","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FGqn5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptはJavaScript互換を最優先して意図的に不健全な漸進的型付けを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fcu4O","x":448,"y":284,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:4","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z6k24","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptの any と型アサーションは移行を容易にする一方で実行時 TypeError の穴を残す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Bc1mU","x":732,"y":284,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:5","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UojHN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptは型消去を採用するため実行時の型安全を保証しない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YVeEs","x":164,"y":484,"name":"L1-3::Group 6 :: Group 1 :: Group 4 :: Group 2 :: Sticky Note dr11:51","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"N2of0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TypeScriptの any 依存は不正確な型定義経由で安全性崩壊を全体へ伝播させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"77vrr","x":448,"y":884,"name":"L1-3::Group 6 :: Group 1 :: Lone 389 :: Lone 439 :: Sticky Note dr11:41","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VuOsc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaの型消去はRaw typeとの共存移行を可能にしたがヒープ汚染リスクを残した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fvg42","x":582,"y":3284,"name":"L1-3::Group 15 :: Group 1 :: Group 3 :: Lone 657 :: Sticky Note dr16:29","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VKVjw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは同一型への複数振る舞い注入でnewtype回避策を要することが多い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0KVIq","x":164,"y":1412,"name":"L1-3::Group 16 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:97","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dB9dn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは型クラスと推論により1/2の具体型を決める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"H8ESg","x":448,"y":1412,"name":"L1-3::Group 16 :: Group 1 :: Group 3 :: Group 97 :: Sticky Note dr5:26","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jzh3A","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HaskellのMaybeは理由不要の欠損を表現する型である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hsSnD","x":164,"y":1212,"name":"L1-3::Group 16 :: Group 1 :: Group 3 :: Group 127 :: Sticky Note dr16:27","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"U5OjW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellはモジュール関数よりTypeclass中心の抽象化を発展させた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hzMSo","x":448,"y":1212,"name":"L1-3::Group 16 :: Group 1 :: Group 3 :: Group 127 :: Sticky Note dr16:28","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aVnMG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskell Typeclassは暗黙解決の表現力が高い一方で解決経路の追跡が難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"PSxfv","x":164,"y":1612,"name":"L1-3::Group 16 :: Group 1 :: Lone 396 :: Lone 446 :: Sticky Note dr11:50","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"abwIM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HaskellのOrphan Instances許容は型クラス一貫性を崩し得る設計負債として知られる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NfCtJ","x":2604,"y":284,"name":"L1-3::Group 22 :: Group 1 :: Group 4 :: Group 2 :