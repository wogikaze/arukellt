0026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eOJs4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Objective-CのARC移行はMRCボイラープレート削減に有効だったが混在運用で移行負荷が残った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Y6SV6","x":164,"y":5044,"name":"L1-7::Group 175 :: Group 1 :: Lone 428 :: Lone 480 :: Sticky Note dr12:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A6jhZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Odinは暗黙context経由でAllocatorを伝播し記述量を削減する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ft25h","x":1000,"y":8884,"name":"L1-7::Group 177 :: Group 1 :: Group 39 :: Group 33 :: Sticky Note dr13:18","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ATAoQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PonylangはアクターモデルにReference Capabilitiesを統合した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QGYMt","x":4342,"y":1540,"name":"L1-7::Group 180 :: Group 1 :: Group 62 :: Group 62 :: Sticky Note dr12:40","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CD8yC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PoloniusはDatalogベースで借用関係を精密解析する次世代案である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"X81im","x":582,"y":5044,"name":"L1-7::Group 185 :: Group 1 :: Group 90 :: Group 99 :: Sticky Note dr5:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zYPCb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"仮想スレッドの普及はtry-catch中心の直線的エラーハンドリング再評価を促す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XWjB7","x":582,"y":7092,"name":"L1-7::Group 189 :: Group 1 :: Group 104 :: Group 117 :: Sticky Note dr11:11","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aF4xT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ML系のHindley-Milner推論は主型を推論できる完成度と高効率を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dkCxL","x":3506,"y":1868,"name":"L1-7::Group 190 :: Group 1 :: Group 113 :: Group 132 :: Sticky Note nishio:82","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"T1oD9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HMMMMLはXML風タグでブロック終端を明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4KqIn","x":2888,"y":3788,"name":"L1-7::Group 191 :: Group 1 :: Group 114 :: Group 133 :: Sticky Note nishio:90","width":260,"fill"