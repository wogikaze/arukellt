h","width":"fill_container","content":"Option系モデリングはランタイムnull例外の発生を構造的に減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ulb5p","x":3506,"y":1012,"name":"L1-7::Group 200 :: Group 1 :: Lone 165 :: Lone 181 :: Sticky Note dr2:29","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"I7CQa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaは三色マーキングを分割実行してフレーム単位の負荷制御をしやすくした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"E59hT","x":3506,"y":1212,"name":"L1-7::Group 200 :: Group 1 :: Lone 416 :: Lone 466 :: Sticky Note dr12:26","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"n6iDy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lua 5.1はインクリメンタル三色GCでフレーム落ち要因の長停止を緩和した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"q6BqK","x":582,"y":4516,"name":"L1-7::Group 205 :: Group 1 :: Lone 183 :: Lone 205 :: Sticky Note dr2:63","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"akhOG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"MLKitはリージョン推論で静的割当解放を進めて予測可能性向上を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HiGYi","x":582,"y":4716,"name":"L1-7::Group 205 :: Group 1 :: Lone 430 :: Lone 483 :: Sticky Note dr12:56","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ir0bm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"リージョン推論は静的解析で寿命群を管理して個別解放を避ける発想である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cIwHF","x":1902,"y":7292,"name":"L1-7::Group 206 :: Group 1 :: Lone 434 :: Lone 487 :: Sticky Note dr12:61","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UHKQt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ゲームループではフレーム単位アリーナのリセットが定番手法である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"uvD0x","x":164,"y":9212,"name":"L1-7::Group 207 :: Group 1 :: Lone 192 :: Lone 214 :: Sticky Note dr2:72","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lDQXR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは大きな値型のコピーコストをCoW最適化で吸収する実装戦略を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1gMnG","x":3924,"y":4316,"name":"L1-7::Group 208 :: Group 1 :: Lone 193 :: Lone 215 :: Sticky Note dr2:73","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MZQ9p","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#はstructを小さく不変な値データに限定してclassと役割分担する方針を推奨する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UZz91","x":3924,"y":4516,"name":"L1-7::Group 208 :: Group 1 :: Lone 438 :: Lone 492 :: Sticky Note dr12:66","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pdTu5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#はclassとstructを分けてヒープ負荷とコピー特性を設計できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cv2BZ","x":2738,"y":2268,"name":"L1-7::Group 214 :: Group 1 :: Lone 575 :: Lone 638 :: Sticky Note dr15:67","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GkvkY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"親タスク失敗時に従属仮想スレッドを一括終了できるためリークと孤児タスクを減らせる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"G3OAq","x":4342,"y":4316,"name":"L1-7::Group 218 :: Group 1 :: Lone 240 :: Lone 277 :: Sticky Note dr4:20","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QEa4S","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispは構文を極小化して言語仕様と処理系の単純性を保つ設計美学を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"DIfZo","x":4342,"y":4516,"name":"L1-7::Group 218 :: Group 1 :: Lone 535 :: Lone 595 :: Sticky Note dr14:70","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oI6BO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LispのS式中心設計はメタプログラミングを単純なリスト操作へ還元する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sht60","x":1000,"y":7092,"name":"L1-7::Group 219 :: Group 1 :: Lone 241 :: Lone 278 :: Sticky Note dr4:21","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YWL12","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispは括弧密度の高さが普及上の心理的障壁になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bvwDV","x":3924,"y":1868,"name":"L1-7::Group 220 :: Group 1 :: Lone 549 :: Lone 609 :: Sticky Note dr15:10","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PAldU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Do-file エディタの構文強調と折りたたみは forvalues や if/else の異常検出に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rdHfv","x":1768,"y":4316,"name":"L1-7::Group 221 :: Group 1 :: Lone 270 :: Lone 310 :: Sticky Note dr4:67","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GCMLJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GleamはBEAM上で型安全と親切な診断を両立する方針を明確にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8vwQW","x":1768,"y":4516,"name":"L1-7::Group 221 :: Group 1 :: Lone 415 :: Lone 465 :: Sticky Note dr12:25","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RSaGp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMのコピーGCはライブデータ量次第で2倍近いメモリ余裕を要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2GsNv","x":1000,"y":1868,"name":"L1-7::Group 222 :: Group 1 :: Lone 508 :: Lone 565 :: Sticky Note dr14:27","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lCqqC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはTMTOWTDIにより同一課題への複数記法を許容する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fSk6F","x":2320,"y":7292,"name":"L1-7::Group 226 :: Group 1 :: Lone 299 :: Lone 341 :: Sticky Note dr5:4","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1vJN5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cのerrnoは原因伝達を簡単にするがグローバル状態依存のため見落としやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Hsu4p","x":164,"y":7420,"name":"L1-7::Group 229 :: Group 1 :: Lone 315 :: Lone 359 :: Sticky Note dr5:43","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"h77lV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"式ベース言語はifやmatchを値として扱い分岐結果を直接束縛しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zvXDh","x":3924,"y":1012,"name":"L1-7::Group 230 :: Group 1 :: Lone 318 :: Lone 362 :: Sticky Note dr5:48","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jrWw7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ラベル付きbreakとcontinueはgotoなしで多重ループ脱出を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"R4hRx","x":3924,"y":1212,"name":"L1-7::Group 230 :: Group 1 :: Lone 666 :: Lone 740 :: Sticky Note nishio:72","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"10Y7V","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはforとwhileとgotoなど複数のループ手段を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6w0Gd","x":2186,"y":5172,"name":"L1-7::Group 231 :: Group 1 :: Lone 576 :: Lone 639 :: Sticky Note dr15:68","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UEVDH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"堅牢な計算システムにはモジュール化実行と明示的エラー表現と回復戦略の分離が必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aVbmb","x":2738,"y":1740,"name":"L1-7::Group 234 :: Group 1 :: Lone 351 :: Lone 396 :: Sticky Note dr6:42","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dUbIq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TerraはLua連携のmulti-stageで高水準生成ロジックと低水準高速コードを接続する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xw3xS","x":2738,"y":1940,"name":"L1-7::Group 234 :: Group 1 :: Lone 616 :: Lone 680 :: Sticky Note dr16:64","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4DChi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TerraはLuaを上位ステージとして用い、LLVM向け低レベルコードを多段生成する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IhXTS","x":4342,"y":4844,"name":"L1-7::Group 238 :: Group 1 :: Lone 372 :: Lone 422 :: Sticky Note dr11:18","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nyPzS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは制約ソルバ中心の高度推論で高表現力を得たが組み合わせ爆発に直面した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tyPro","x":2604,"y":5172,"name":"L1-7::Group 241 :: Group 1 :: Lone 645 :: Lone 715 :: Sticky Note nishio:38","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HO4MH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"一部言語はGCとmalloc/freeの併用を可能にして選択肢を残す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NimQJ","x":3774,"y":6764,"name":"L1-7::Group 243 :: Group 1 :: Lone 453 :: Lone 507 :: Sticky Note dr13:3","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7LGed","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"アクターモデルは隔離された実体間の非同期メッセージ交換で故障分離を実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Y0Jhh","x":3774,"y":6964,"name":"L1-7::Group 243 :: Group 1 :: Lone 463 :: Lone 517 :: Sticky Note dr13:24","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qZAMU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのDistributed Actorsは同じメンタルモデルを分散先へ拡張する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"L29Bo","x":1000,"y":4516,"name":"L1-7::Group 245 :: Group 1 :: Lone 471 :: Lone 525 :: Sticky Note dr13:56","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9Rr29","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ractorは不変共有とムーブ転送を軸にデータ競合を抑制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9mhUS","x":1000,"y":4716,"name":"L1-7::Group 245 :: Group 1 :: Lone 472 :: Lone 526 :: Sticky Note dr13:57","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eQJPk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ractorは既存Gem適合や性能面で移行課題を残す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rAU7z","x":2320,"y":6764,"name":"L1-7::Group 246 :: Group 1 :: Lone 495 :: Lone 549 :: Sticky Note dr14:5","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2wBZa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"インデントを意味化するオフサイドルールは視覚構造と実行構造の一致を強制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bW6UC","x":2320,"y":6964,"name":"L1-7::Group 246 :: Group 1 :: Lone 497 :: Lone 554 :: Sticky Note dr14:10","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"v6IuH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"オフサイドルールはLandinのISWIMに起源を持ちHaskell系まで継承されている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sy7sm","x":3506,"y":5172,"name":"L1-7::Group 248 :: Group 1 :: Lone 528 :: Lone 588 :: Sticky Note dr14:60","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vxMSv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Language Server ProtocolはJSON-RPC標準化で統合コストを言語数とエディタ数の和へ近づけた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GMJJ0","x":1284,"y":6236,"name":"L1-7::Group 249 :: Group 1 :: Lone 544 :: Lone 604 :: Sticky Note dr15:5","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sC8ex","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"巨大な単一スクリプトよりも 0-master.do と従属 .do ファイルに分割した構成が保守に強い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ejcNJ","x":1284,"y":6436,"name":"L1-7::Group 249 :: Group 1 :: Lone 546 :: Lone 606 :: Sticky Note dr15:7","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HzsXX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"1-merge.do と 2-stylized-facts.do と 3-regressions.do の分離は失敗時の再実行コストを下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"M9MGh","x":4192,"y":6764,"name":"L1-7::Group 253 :: Group 1 :: Lone 625 :: Lone 689 :: Sticky Note nishio:3","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zefBd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cでは代入が式なのでif (x = 0)は代入として評価され、意図しない条件になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HRMeG","x":4192,"y":6964,"name":"L1-7::Group 253 :: Group 1 :: Lone 662 :: Lone 736 :: Sticky Note nishio:67","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bTgpT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cではx == y & zが(x == y) & zとして解釈されるため意図確認が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oXEZy","x":1000,"y":5044,"name":"L1-7::Group 255 :: Group 1 :: Lone 630 :: Lone 696 :: Sticky Note nishio:11","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xYZy2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cではintのビット幅が環境依存で、移植時に追加確認が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5XN8c","x":582,"y":7420,"name":"L1-7::Group 259 :: Group 1 :: Lone 664 :: Lone 738 :: Sticky Note nishio:70","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"p0YSp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SMLは負数リテラルに~1記法を使う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nYoeG","x":3774,"y":7292,"name":"L1-7::Lone 263 :: Group 1 :: Group 2 :: Lone 294 :: Sticky Note dr4:43","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OFBH9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptコミュニティではASI由来の罠を避けるためlint規約が重視された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VZAR7","x":4342,"y":1868,"name":"L1-7::Lone 270 :: Group 1 :: Group 53 :: Group 130 :: Sticky Note nishio:100","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rwi3P","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Smalltalkはメッセージ送信中心の純オブジェクト観を徹底した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HfdJy","x":1768,"y":5500,"name":"L1-7::Lone 271 :: Group 1 :: Group 71 :: Group 73 :: Sticky Note dr13:22","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HOw8e","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftはActor型で参照型状態への同時アクセスを直列化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"42sX3","x":164,"y":2396,"name":"L1-7::Lone 272 :: Group 1 :: Group 81 :: Group 87 :: Sticky Note dr14:46","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JPxgE","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのdeferはスコープ終了時にLIFOで実行されクリーンアップを局所化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"r3Unn","x":582,"y":9212,"name":"L1-7::Lone 277 :: Group 1 :: Lone 182 :: Lone 204 :: Sticky Note dr2:62","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DHHvV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cycloneは注釈負担を残しつつ既存C資産を比較的低コストで移植可能と報告された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"98MTr","x":3506,"y":2196,"name":"L1-7::Lone 280 :: Group 1 :: Lone 194 :: Lone 216 :: Sticky Note dr2:74","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iU0Yg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#はstruct誤用時にボックス化やコピー増で性能悪化するため利用条件を明示している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"uFeUK","x":582,"y":2396,"name":"L1-7::Lone 282 :: Group 1 :: Lone 209 :: Lone 235 :: Sticky Note dr3:20","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pp4du","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pony の iso と consume は一意所有の移譲を明示し、コピーなしの安全なアクター間転送を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qEYE0","x":1902,"y":2596,"name":"L1-7::Lone 284 :: Group 1 :: Lone 232 :: Lone 261 :: Sticky Note dr4:1","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f3SH6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系言語の多くはB言語とBCPLの流れを受けて{}と;で構造と文末を示す構文を採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Fcc1h","x":1000,"y":2396,"name":"L1-7::Lone 292 :: Group 1 :: Lone 291 :: Lone 333 :: Sticky Note dr4:97","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pO9kC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PHPはstrlen, str_replace, array_push, in_arrayのような命名規則不統一を抱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hS2lN","x":164,"y":5372,"name":"L1-7::Lone 295 :: Group 1 :: Lone 311 :: Lone 354 :: Sticky Note dr5:28","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"crWMK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"関数型言語のモナド連鎖はエラー伝播と合成を両立しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fylNa","x":582,"y":5372,"name":"L1-7::Lone 315 :: Group 1 :: Lone 417 :: Lone 467 :: Sticky Note dr12:27","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cTNtH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LuaのsetpauseとsetstepmulはGC進行量をワークロードに合わせて調整できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eF4XP","x":3924,"y":5172,"name":"L1-7::Lone 318 :: Group 1 :: Lone 431 :: Lone 484 :: Sticky Note dr12:57","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ALfHo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"MLKitはRegion Inferenceを実装した先駆的研究系コンパイラである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VoEkz","x":1000,"y":7420,"name":"L1-7::Lone 319 :: Group 1 :: Lone 433 :: Lone 486 :: Sticky Note dr12:60","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5kFr8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"アリーナアロケータは同寿命オブジェクトを一括破棄して高速化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AzZbJ","x":3924,"y":2196,"name":"L1-7::Lone 320 :: Group 1 :: Lone 437 :: Lone 491 :: Sticky Note dr12:65","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xf6Mv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのCopy-on-Writeは値セマンティクスと性能を両立する中核機構である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XfFVl","x":2186,"y":5500,"name":"L1-7::Lone 321 :: Group 1 :: Lone 442 :: Lone 496 :: Sticky Note dr12:72","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pjOdJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"値の平坦化は同時更新時のtearing対策を言語仕様側へ要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"z3xjn","x":164,"y":2724,"name":"L1-7::Lone 322 :: Group 1 :: Lone 444 :: Lone 498 :: Sticky Note dr12:74","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Yb91j","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DisruptorはMechanical Sympathyに基づき偽共有回避と遅延削減を徹底した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Q1sQx","x":1000,"y":5372,"name":"L1-7::Lone 325 :: Group 1 :: Lone 450 :: Lone 504 :: Sticky Note dr12:80","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OK0bs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"単一の最適解はなくドメイン要件に合わせた選択が必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qJt7b","x":2738,"y":7292,"name":"L1-7::Lone 326 :: Group 1 :: Lone 452 :: Lone 506 :: Sticky Note dr13:2","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"KJEUX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CSPは独立実行単位とチャネル通信で並行制御を構造化する考え方である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2XWGO","x":164,"y":7748,"name":"L1-7::Lone 329 :: Group 1 :: Lone 479 :: Lone 533 :: Sticky Note dr13:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YZUJc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JuliaはTwo-Language Problemを緩和し単一言語内最適化を進めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kIqi2","x":582,"y":2724,"name":"L1-7::Lone 332 :: Group 1 :: Lone 496 :: Lone 551 :: Sticky Note dr14:7","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0yxhN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ABCで導入されたコロンはブロック開始の視覚アンカーとして初心者の理解を補助した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lhLKi","x":1902,"y":7620,"name":"L1-7::Lone 336 :: Group 1 :: Lone 524 :: Lone 584 :: Sticky Note dr14:56","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eNYvP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Gleamは局所エラー後も解析継続してIDEフィードバックを維持する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kMCID","x":4342,"y":5172,"name":"L1-7::Lone 338 :: Group 1 :: Lone 529 :: Lone 589 :: Sticky Note dr14:61","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8XYf7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSPはAST統一ではなく文書位置と診断交換の標準化に焦点を置いた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AF03G","x":1000,"y":2724,"name":"L1-7::Lone 342 :: Group 1 :: Lone 537 :: Lone 597 :: Sticky Note dr14:72","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4W2W0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"主流言語は同図像性を全面採用せず限定的マクロやリフレクションで折衷する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sWXN6","x":2320,"y":2596,"name":"L1-7::Lone 344 :: Group 1 :: Lone 542 :: Lone 602 :: Sticky Note dr15:3","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BM5i5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"再現可能な研究ではデータ処理と分析手順をコード化した実行フローが必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WmKdu","x":164,"y":5700,"name":"L1-7::Lone 345 :: Group 1 :: Lone 543 :: Lone 603 :: Sticky Note dr15:4","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"u0DWv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Stata の .do ファイルは経済学や社会科学で標準的な分析実行単位として使われる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pCDDl","x":2320,"y":7620,"name":"L1-7::Lone 346 :: Group 1 :: Lone 545 :: Lone 605 :: Sticky Note dr15:6","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"lgFw8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"0-master.do は実データ処理よりも環境変数定義と段階実行の制御を担うべきである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lvfzV","x":3506,"y":5500,"name":"L1-7::Lone 348 :: Group 1 :: Lone 551 :: Lone 611 :: Sticky Note dr15:12","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mMNAH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"研究パイプラインはローカル実行だけでなく GitHub Actions や GitLab CI に統合されるべきである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LZSEe","x":582,"y":7748,"name":"L1-7::Lone 349 :: Group 1 :: Lone 552 :: Lone 612 :: Sticky Note dr15:13","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nLgt0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"マルチリポジトリ CI/CD は上流データ変更が下流分析に与える退行を自動検証できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AuFJC","x":4342,"y":2196,"name":"L1-7::Lone 350 :: Group 1 :: Lone 553 :: Lone 613 :: Sticky Note dr15:14","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iCPY2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LLM エージェントを使ったデータラングリング自動化は探索的分析の初期時間を短縮できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wEnKg","x":2604,"y":5500,"name":"L1-7::Lone 351 :: Group 1 :: Lone 554 :: Lone 614 :: Sticky Note dr15:15","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ISvIG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"実行完了後のデータとコードは DOI 付き永続リポジトリへ固定アーカイブするべきである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cTrpe","x":164,"y":3052,"name":"L1-7::Lone 352 :: Group 1 :: Lone 555 :: Lone 615 :: Sticky Note dr15:16","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"03gEV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"研究中のデータ保全には 3-2-1 バックアップルールの遵守が有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LgzK1","x":4192,"y":7292,"name":"L1-7::Lone 353 :: Group 1 :: Lone 564 :: Lone 626 :: Sticky Note dr15:34","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sOLQy","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"EAFP は存在確認と実操作の時間差で起きる race condition を減らせる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TCA4f","x":1000,"y":9212,"name":"L1-7::Lone 357 :: Group 1 :: Lone 586 :: Lone 649 :: Sticky Note dr16:15","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dMDYu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ブラウザ側は非同期ロード要件からAMDとRequireJSが普及した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qvx36","x":3924,"y":5500,"name":"L1-7::Lone 358 :: Group 1 :: Lone 587 :: Lone 650 :: Sticky Note dr16:17","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QBenX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ESMはimport/exportの静的解析を可能にし、ツリーシェイキングを促進した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4CmLN","x":582,"y":3052,"name":"L1-7::Lone 362 :: Group 1 :: Lone 615 :: Lone 679 :: Sticky Note dr16:61","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Zml0m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Nimでは関数やtemplateで足りる場面はマクロを避ける指針が実務的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OxOgS","x":3356,"y":7620,"name":"L1-7::Lone 363 :: Group 1 :: Lone 617 :: Lone 681 :: Sticky Note dr16:65","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QGlP3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TerraはHPC向けに実装特化コードを動的生成しつつC連携を維持する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NPzEL","x":2738,"y":7620,"name":"L1-7::Lone 366 :: Group 1 :: Lone 634 :: Lone 703 :: Sticky Note nishio:21","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fzA5E","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispは呼び出し構文全体を括弧で囲む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yBBrn","x":164,"y":9540,"name":"L1-7::Lone 367 :: Group 1 :: Lone 637 :: Lone 706 :: Sticky Note nishio:25","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"K2wgF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PostScriptとForthは逆ポーランド記法で優先順位括弧への依存を減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"r0AUU","x":4342,"y":5500,"name":"L1-7::Lone 368 :: Group 1 :: Lone 643 :: Lone 713 :: Sticky Note nishio:35","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YrLgS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Perl系でもC3 MROを採用する実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6HFha","x":3506,"y":2524,"name":"L1-7::Lone 370 :: Group 1 :: Lone 648 :: Lone 718 :: Sticky Note nishio:41","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"llMWn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"初期化強制の言語は未定義値起因のバグを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LE3ZU","x":1768,"y":5828,"name":"L1-7::Lone 371 :: Group 1 :: Lone 660 :: Lone 734 :: Sticky Note nishio:65","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fn5b2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pascalは算術と比較と論理の優先順位を明確に分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kI8UU","x":1000,"y":3052,"name":"L1-7::Lone 372 :: Group 1 :: Lone 663 :: Lone 737 :: Sticky Note nishio:69","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"qsozl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellではf -1がf - 1と読まれるため負数引数にはf (-1)が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qL8Gi","x":3774,"y":7620,"name":"L1-7::Lone 373 :: Group 1 :: Lone 668 :: Lone 742 :: Sticky Note nishio:74","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"J8XyK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispは末尾再帰最適化で再帰をループとして使える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xW424","x":1902,"y":7948,"name":"L1-7::Lone 376 :: Group 1 :: Lone 672 :: Lone 746 :: Sticky Note nishio:81","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VcAdb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"QuickBASICはIf ... End Ifで終端の対応関係を明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JTO80","x":582,"y":9540,"name":"L1-7::Lone 377 :: Group 1 :: Lone 673 :: Lone 747 :: Sticky Note nishio:83","width":260,"fill":