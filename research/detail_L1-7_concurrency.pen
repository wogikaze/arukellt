wth":"fixed-width","width":"fill_container","content":"Erlang は let it crash を採用し回復責任をスーパーバイザ層へ分離する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hF1R6","x":2470,"y":284,"name":"L1-7::Group 4 :: Group 1 :: Group 7 :: Group 7 :: Sticky Note dr15:19","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uvgvh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang のアクターモデルは共有メモリを避けメッセージパッシングで障害汚染を局所化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BKY5m","x":2186,"y":484,"name":"L1-7::Group 4 :: Group 1 :: Lone 160 :: Lone 176 :: Sticky Note dr2:23","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DDnAX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/BEAMはグローバルGCポーズを避けることで分散システムのレイテンシ安定性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ast8a","x":2470,"y":484,"name":"L1-7::Group 4 :: Group 1 :: Lone 204 :: Lone 228 :: Sticky Note dr3:8","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1ijzN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/OTP は電話交換機のような停止不能システム向けに、プロセス隔離とホットコード更新を重視した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3pe3A","x":1902,"y":684,"name":"L1-7::Group 4 :: Group 1 :: Lone 205 :: Lone 229 :: Sticky Note dr3:9","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vksu6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/OTP の supervisor tree と gen_server は耐障害分散システムの定番パターンとして定着した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pKeWQ","x":2186,"y":684,"name":"L1-7::Group 4 :: Group 1 :: Lone 207 :: Lone 231 :: Sticky Note dr3:11","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gymq8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang では不変データとアクターモデルの組み合わせが並行バグを減らす実践として広く受容された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wSpPq","x":2470,"y":684,"name":"L1-7::Group 4 :: Group 1 :: Lone 458 :: Lone 512 :: Sticky Note dr13:11","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mTOpP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlangは高可用な通信基盤の実運用で強みを示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BE82H","x":1902,"y":884,"name":"L1-7::Group 4 :: Group 1 :: Lone 659 :: Lone 733 :: Sticky Note nishio:64","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PkyHq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ErlangとOCamlは不変束縛中心だが可変領域を別途提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OSdn0","x":164,"y":3788,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:23","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZpRnl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは通常の関数適用で括弧をほとんど使わない。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tDhjI","x":448,"y":3788,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:63","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"U8zP3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは通常の束縛を再代入不可にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vPM9k","x":164,"y":3988,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Lone 353 :: Sticky Note dr5:27","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IebdT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HaskellのEitherは通常Leftに失敗理由を載せる慣習で運用される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BGXpR","x":448,"y":3988,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Lone 730 :: Sticky Note nishio:59","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZewxL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"HaskellはIntegerを標準で使えば多倍長を自然に扱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GRetu","x":164,"y":4188,"name":"L1-7::Group 15 :: Group 1 :: Group 3 :: Lone 749 :: Sticky Note nishio:86","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bGnYe","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CLOSとHaskellではレシーバ特権を置かず通常引数として扱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xAO3F","x":448,"y":4188,"name":"L1-7::Group 15 :: Group 1 :: Lone 125 :: Group 97 :: Sticky Note dr15:55","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7x3wo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskell の Maybe と Either は失敗をデータとして表現し Monad 合成で短絡伝播できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Uv1tb","x":866,"y":812,"name":"L1-7::Group 22 :: Group 1 :: Group 84 :: Group 91 :: Sticky Note dr4:93","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"llvuI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Denoはformatterとtestとlint同梱でツール乱立の抑制を狙った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ExYCD","x":1150,"y":812,"name":"L1-7::Group 22 :: Group 1 :: Lone 289 :: Lone 331 :: Sticky Note dr4:94","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mug0X","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"DenoはNode互換性と採用実績の壁により普及速度が限定的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XTOpS","x":866,"y":1012,"name":"L1-7::Group 22 :: Group 1 :: Lone 532 :: Lone 592 :: Sticky Note dr14:65","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WTUIp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Denoはnode_modules依存を弱めURLベース取り込みでWeb標準寄りの運用を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6fPEa","x":2186,"y":1212,"name":"L1-7::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr3:66","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"P54Zl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futhark は OpenCL や GPU カーネル生成の詳細をコンパイラに隠蔽し、自動並列化を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hbaej","x":1902,"y":1212,"name":"L1-7::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr13:74","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VjbjB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"FutharkはOpenCL生成で高性能と可搬性の両立を目指す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"7lLD9","x":1902,"y":1412,"name":"L1-7::Group 24 :: Group 1 :: Lone 225 :: Lone 253 :: Sticky Note dr3:65","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vW9FO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futhark は純関数データ並列言語として map、reduce、scan を中核に据える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xe9KF","x":3506,"y":4844,"name":"L1-7::Group 28 :: Group 1 :: Group 53 :: Lone 270 :: Sticky Note dr4:12","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"btSHO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはSmalltalk, Perl, Lispの影響を受けて表現力と楽しさを重視した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"O1LBx","x":164,"y":6236,"name":"L1-7::Group 29 :: Group 1 :: Lone 267 :: Lone 305 :: Sticky Note dr4:61","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"egUF8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elmは修正行動まで示すフレンドリーなコンパイルエラーを中核価値にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6KlX6","x":448,"y":6236,"name":"L1-7::Group 29 :: Group 1 :: Lone 268 :: Lone 306 :: Sticky Note dr4:62","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gdd1m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElmのエラーUXは言語理論に不慣れなフロントエンド層の導入障壁を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6YjJz","x":164,"y":6436,"name":"L1-7::Group 29 :: Group 1 :: Lone 519 :: Lone 579 :: Sticky Note dr14:51","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Lj0j9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ElmはCompiler Errors for Humansで診断を主要UIとして再定義した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"egCMD","x":448,"y":6436,"name":"L1-7::Group 29 :: Group 1 :: Lone 520 :: Lone 580 :: Sticky Note dr14:52","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XGk53","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Elmの診断は該当コード提示と平易な説明で修正ループを短縮する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ma9kl","x":4208,"y":284,"name":"L1-7::Group 30 :: Group 1 :: Group 27 :: Group 37 :: Sticky Note dr14:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZoTWY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのguardで束縛した値は後続スコープで安全に利用できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZF45k","x":4208,"y":484,"name":"L1-7::Group 30 :: Group 1 :: Group 52 :: Group 124 :: Sticky Note dr13:63","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ap0LZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのwithTaskGroupはスコープ外タスク漏出を防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QVxvC","x":2052,"y":3788,"name":"L1-7::Group 31 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr3:54","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oTBpQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Structured Concurrency は fire-and-forget を抑制し、タスク生成と join を同一スコープに閉じる原則を採る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dZKnf","x":1768,"y":3988,"name":"L1-7::Group 31 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr3:55","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1U37u","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Structured Concurrency の目的はエラー伝搬、キャンセル、リソース回収を親子タスク木で一貫化することにある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5FNaS","x":1768,"y":3788,"name":"L1-7::Group 31 :: Group 1 :: Group 5 :: Group 12 :: Sticky Note dr15:66","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TCo31","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Project Loom の Structured Concurrency は親子タスクのライフサイクルを統合管理する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"V6InF","x":2052,"y":3988,"name":"L1-7::Group 31 :: Group 1 :: Lone 474 :: Lone 528 :: Sticky Note dr13:59","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xxO5q","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"構造化並行性はfire-and-forget起因のリークと例外消失を減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"r5GiM","x":448,"y":284,"name":"L1-7::Group 32 :: Group 1 :: Group 7 :: Group 11 :: Sticky Note dr2:22","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fhvks","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Erlang/BEAMは軽量プロセスごとに独立ヒープを持つプロセス局所GCを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TGnFC","x":164,"y":284,"name":"L1-7::Group 32 :: Group 1 :: Group 7 :: Group 11 :: Sticky Note dr12:21","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xBzPT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ErlangのBEAMはプロセスごとに独立ヒープを持ち全体STWを回避しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yyXmg","x":164,"y":484,"name":"L1-7::Group 32 :: Group 1 :: Lone 117 :: Group 11 :: Sticky Note dr12:22","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fXijW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMのプロセス単位GCは他プロセスへの停止波及を抑える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UKn65","x":448,"y":484,"name":"L1-7::Group 32 :: Group 1 :: Lone 118 :: Group 11 :: Sticky Note dr12:24","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IB4Kd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMの短命プロセスは終了時破棄でGCコストを実質回避できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LJoZl","x":2888,"y":1212,"name":"L1-7::Group 34 :: Group 1 :: Group 13 :: Group 25 :: Sticky Note dr4:44","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YiAtt","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは行末セミコロンを不要化してObjective-Cより簡潔な記述を促した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8VA24","x":2604,"y":1412,"name":"L1-7::Group 34 :: Group 1 :: Group 13 :: Group 25 :: Sticky Note dr4:46","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nf49y","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftとObjective-Cの混在環境では構文感覚の切替が必要になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"7z3eM","x":2604,"y":1212,"name":"L1-7::Group 34 :: Group 1 :: Group 13 :: Group 25 :: Sticky Note dr12:32","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MxWPW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftとObjective-CのARCはGCより予測可能な解放タイミングを提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ajBm7","x":1150,"y":3788,"name":"L1-7::Group 35 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr1:52","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CeD7H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはoptionalを早期unwrapして以後をnon-optionalとして記述する文体を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vb2TP","x":866,"y":3788,"name":"L1-7::Group 35 :: Group 1 :: Group 11 :: Group 56 :: Sticky Note dr1:46","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1OFJN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはif letとguard中心の制御構造でoptionalを早期処理する傾向がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nTjI3","x":866,"y":3988,"name":"L1-7::Group 35 :: Group 1 :: Group 27 :: Group 37 :: Sticky Note dr4:53","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0svu4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのguardは早期リターンを促進してネスト肥大を抑える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lwbBz","x":1150,"y":3988,"name":"L1-7::Group 35 :: Group 1 :: Group 27 :: Group 37 :: Sticky Note dr5:22","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8W7UX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのguardは早期リターンで正常系のネストを浅く保つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Q5uTh","x":866,"y":4188,"name":"L1-7::Group 35 :: Group 1 :: Group 27 :: Lone 575 :: Sticky Note dr14:44","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"hyBdg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはguardで前提条件失敗を早期退出に集約し主経路の線形性を保つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TJc3Y","x":1902,"y":6236,"name":"L1-7::Group 36 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr5:20","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QZK1f","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのtry?は失敗をOptionalへ畳み込む簡易ハンドリングである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2LxTt","x":1902,"y":6436,"name":"L1-7::Group 36 :: Group 1 :: Lone 308 :: Lone 350 :: Sticky Note dr5:21","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ySOmm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのtry!は失敗時クラッシュを許容する前提を明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"53IOo","x":3790,"y":484,"name":"L1-7::Group 40 :: Group 1 :: Group 32 :: Group 83 :: Sticky Note dr4:19","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YGVo7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispのホモイコニシティは強力なマクロと言語内変換を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1RR45","x":3506,"y":484,"name":"L1-7::Group 40 :: Group 1 :: Group 32 :: Group 83 :: Sticky Note dr14:69","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WoARw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lisp系の同図像性はコードとデータの表現一致により強力なマクロを可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xJALG","x":3790,"y":284,"name":"L1-7::Group 40 :: Group 1 :: Group 32 :: Group 109 :: Sticky Note dr6:28","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8I4v1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lisp系はコードをデータとして扱うホモイコニシティによりDSL構築と言語内拡張の自由度を最大化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aMmVO","x":3506,"y":284,"name":"L1-7::Group 40 :: Group 1 :: Group 32 :: Group 109 :: Sticky Note dr16:55","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bU4sJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LispはホモイコニシティによりS式を直接変換してDSLを構築できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Hs35N","x":3506,"y":684,"name":"L1-7::Group 40 :: Group 1 :: Lone 239 :: Lone 276 :: Sticky Note dr4:18","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"T1Caf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LispはS式でコードとデータを同じリスト構造として表現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"r2YNq","x":1902,"y":1740,"name":"L1-7::Group 44 :: Group 1 :: Lone 296 :: Lone 338 :: Sticky Note dr4:102","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"x0d5Z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3の簡素化方針はScala 2時代のスタイル分散への反省を含んでいる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JDh5H","x":1902,"y":1940,"name":"L1-7::Group 44 :: Group 1 :: Lone 386 :: Lone 436 :: Sticky Note dr11:38","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bh4qm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3は given と using と Conversion に分離して暗黙変換の危険を抑制した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"mWLtn","x":866,"y":284,"name":"L1-7::Group 52 :: Group 1 :: Group 3 :: Lone 273 :: Sticky Note dr4:15","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AHWu6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellはwhereやletにも及ぶオフサイドルールで構文ノイズを削減した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IwKjM","x":1150,"y":284,"name":"L1-7::Group 52 :: Group 1 :: Group 3 :: Lone 274 :: Sticky Note dr4:16","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"w58S8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellはlayout ruleによりインデント記法と{;}記法を併用できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RJwLC","x":866,"y":484,"name":"L1-7::Group 52 :: Group 1 :: Group 3 :: Lone 725 :: Sticky Note nishio:49","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6B2xW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellはdivとquotを分けて丸め方向を明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xdwwt","x":1150,"y":484,"name":"L1-7::Group 52 :: Group 1 :: Lone 498 :: Lone 555 :: Sticky Note dr14:11","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4gFs2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellではレイアウト規則が宣言的記述と整合し命令型の終端記号依存を減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FUbkQ","x":3790,"y":3788,"name":"L1-7::Group 58 :: Group 1 :: Group 26 :: Group 22 :: Sticky Note dr3:59","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ph2jd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 21 の StructuredTaskScope は関連タスクを一単位で join と結果集約する API を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"n4io2","x":3506,"y":3988,"name":"L1-7::Group 58 :: Group 1 :: Group 26 :: Group 22 :: Sticky Note dr3:60","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cgLiT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java 21 の StructuredTaskScope は shutdown-on-failure などで高水準なキャンセル方針を表現できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qvOlS","x":3506,"y":3788,"name":"L1-7::Group 58 :: Group 1 :: Group 26 :: Group 22 :: Sticky Note dr13:65","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"duDvY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"StructuredTaskScopeは短絡失敗時の一括キャンセルを簡潔に記述できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"j5tKY","x":582,"y":1868,"name":"L1-7::Group 62 :: Group 1 :: Lone 167 :: Lone 186 :: Sticky Note dr2:36","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D0AY1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftのARCはランタイムGCを使わずコンパイル時挿入でretain/releaseを管理する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"njBGm","x":866,"y":8356,"name":"L1-7::Group 67 :: Group 1 :: Group 54 :: Group 35 :: Sticky Note dr13:60","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kYYrr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"TrioのNurseryは開始した子タスクの完了待機をスコープ終端で保証する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"DNLaj","x":866,"y":8556,"name":"L1-7::Group 67 :: Group 1 :: Lone 475 :: Lone 529 :: Sticky Note dr13:61","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"I6W76","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Trioは子タスク失敗時に残りを協調キャンセルして例外伝播を保つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EEhdp","x":448,"y":812,"name":"L1-7::Group 72 :: Group 1 :: Group 80 :: Group 86 :: Sticky Note dr4:52","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8na68","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのletとvarは不変をデフォルト寄りにし安全性を底上げする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2KDsP","x":164,"y":812,"name":"L1-7::Group 72 :: Group 1 :: Group 80 :: Group 86 :: Sticky Note dr14:47","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8J08L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはletとvarの区別で不変性を既定化し状態変異バグを抑制する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"jZzl3","x":164,"y":1012,"name":"L1-7::Group 72 :: Group 1 :: Lone 121 :: Group 56 :: Sticky Note dr1:44","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rKIR1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはif letとguard letによる明示的アンラップを標準的なnull処理手法として定着させた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xmHUX","x":448,"y":1012,"name":"L1-7::Group 72 :: Group 1 :: Lone 257 :: Lone 295 :: Sticky Note dr4:45","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yCYRB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftはApple公式スタイルと連動してコードベースの統一を進めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"j5JxH","x":3356,"y":7292,"name":"L1-7::Group 73 :: Group 1 :: Group 92 :: Group 101 :: Sticky Note dr15:41","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gn9my","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の match 網羅性検査は Err 分岐の取りこぼしを防ぐ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9nuuM","x":164,"y":8356,"name":"L1-7::Group 77 :: Group 1 :: Lone 161 :: Lone 177 :: Sticky Note dr2:25","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HLdv1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMはプロセス間共有を避けるためにデータコピーを基本とするモデルを採用した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FXPMX","x":448,"y":8356,"name":"L1-7::Group 77 :: Group 1 :: Lone 162 :: Lone 178 :: Sticky Note dr2:26","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aSFTV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMは共有ミュータブル状態を減らしてGCと並行実行モデルを単純化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"51tA6","x":164,"y":8556,"name":"L1-7::Group 77 :: Group 1 :: Lone 163 :: Lone 179 :: Sticky Note dr2:27","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"L32FJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMは半空間コピーや世代別GCを比較的単純に保てる利点を得た。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"huisN","x":448,"y":8556,"name":"L1-7::Group 77 :: Group 1 :: Lone 414 :: Lone 464 :: Sticky Note dr12:23","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2RDn7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BEAMは不変データ前提のため世代間参照管理が比較的単純になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wtoMB","x":164,"y":6764,"name":"L1-7::Group 79 :: Group 1 :: Lone 309 :: Lone 351 :: Sticky Note dr5:23","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Uk1KH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのswitchは列挙型の網羅性チェックで分岐漏れを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FFoed","x":4626,"y":284,"name":"L1-7::Group 80 :: Group 1 :: Lone 221 :: Lone 249 :: Sticky Note dr3:61","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4Z8px","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Julia は多重ディスパッチを中核に据え、型に応じた SIMD、マルチスレッド、分散実装の選択を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FX7E7","x":4626,"y":484,"name":"L1-7::Group 80 :: Group 1 :: Lone 480 :: Lone 534 :: Sticky Note dr13:69","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sKpUX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JuliaはLLVM経由でCPUとGPU双方のコード生成に適応する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HjINA","x":2186,"y":4316,"name":"L1-7::Group 81 :: Group 1 :: Lone 482 :: Lone 536 :: Sticky Note dr13:71","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6XY2D","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Mojoは所有権的制御とハードウェア近接最適化をAI用途へ持ち込む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yIG6P","x":3356,"y":6236,"name":"L1-7::Group 83 :: Group 1 :: Lone 322 :: Lone 366 :: Sticky Note dr5:55","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kWb5f","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Algebraic Effectsは効果ハンドラで失敗処理と制御構造を統一的に表現できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8x3e0","x":3640,"y":6236,"name":"L1-7::Group 83 :: Group 1 :: Lone 557 :: Lone 617 :: Sticky Note dr15:21","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7aUx5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"let it crash は再試行可能なステートレス分散処理で特に効果を発揮する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SlQPr","x":3356,"y":6436,"name":"L1-7::Group 83 :: Group 1 :: Lone 570 :: Lone 633 :: Sticky Note dr15:58","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RGuVh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"代数的エフェクトは effect 宣言と handler 実装を分離して再開可能な失敗処理を提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0rSfi","x":2320,"y":6236,"name":"L1-7::Group 86 :: Group 1 :: Lone 595 :: Lone 659 :: Sticky Note dr16:31","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5TGC4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OCamlはFunctorで実装注入を明示化し、依存関係の見通しを高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Pm4fA","x":2320,"y":6436,"name":"L1-7::Group 86 :: Group 1 :: Lone 636 :: Lone 705 :: Sticky Note nishio:24","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AKwts","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OCamlは引数0個をunitで表現し、必要時に()を渡す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8bHWl","x":1284,"y":8356,"name":"L1-7::Group 87 :: Group 1 :: Lone 678 :: Lone 754 :: Sticky Note nishio:96","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LfwaL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Schemeでは1/2を有理数として保持できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UCtbx","x":2604,"y":4316,"name":"L1-7::Group 91 :: Group 1 :: Lone 638 :: Lone 707 :: Sticky Note nishio:27","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YcPSY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"括弧省略を許す言語では関数値そのものを参照する文法を別途整理する必要がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VQruO","x":448,"y":1340,"name":"L1-7::Group 92 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note dr4:42","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UqDnD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptのASIはreturn直後改行などで意図しない挙動を生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XUW02","x":164,"y":1540,"name":"L1-7::Group 92 :: Group 1 :: Group 2 :: G