fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust 2018 Editionはmod.rs必須を廃止し、foo.rsとfoo/bar.rsの構成を許可した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yjmWH","x":3506,"y":1540,"name":"L1-7::Group 140 :: Group 1 :: Lone 539 :: Lone 599 :: Sticky Note dr14:74","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kia6a","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"成功する現代言語は決定論的構文と共感的診断と統合ツールを同時に提供する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aj1OS","x":1284,"y":1340,"name":"L1-7::Group 142 :: Group 1 :: Lone 642 :: Lone 711 :: Sticky Note nishio:33","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8d8qX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyはMix-inで実装再利用を行う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sZKsU","x":1284,"y":1540,"name":"L1-7::Group 142 :: Group 1 :: Lone 657 :: Lone 731 :: Sticky Note nishio:61","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"14vbr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rubyは定数風命名を用意するが再代入は警告止まりの実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"R45mq","x":582,"y":8884,"name":"L1-7::Group 147 :: Group 1 :: Lone 654 :: Lone 726 :: Sticky Note nishio:50","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GiW3L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ruby 1.8はx / 0.0をNaNまたはInfinityで表現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aRLsr","x":3924,"y":1540,"name":"L1-7::Group 150 :: Group 1 :: Lone 661 :: Lone 735 :: Sticky Note nishio:66","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GTi2f","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"0 < x and x < 9のような式は言語ごとの優先順位差で結果が変わる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"szePh","x":2604,"y":4844,"name":"L1-7::Group 151 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note nishio:111","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"auTKc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptはfalseとnullとundefinedと0と空文字列とNaNを偽として扱う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"o7RM4","x":164,"y":7092,"name":"L1-7::Group 159 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note dr14:14","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"q2RX5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaScriptのASIは最小修復的に働くため行連結ハザードを残しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"3pyB7","x":1768,"y":5172,"name":"L1-7::Group 161 :: Group 1 :: Lone 126 :: Group 114 :: Sticky Note dr16:77","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pUR4E","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GraalVMはTruffle ASTを共通基盤にして多言語実行の相互運用を最適化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wsxNL","x":2320,"y":1740,"name":"L1-7::Group 164 :: Group 1 :: Group 3 :: Group 16 :: Sticky Note nishio:75","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"61lOU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellはmapやfoldlなどの高階関数で反復を記述する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"GjbiC","x":2320,"y":1940,"name":"L1-7::Group 164 :: Group 1 :: Lone 594 :: Lone 658 :: Sticky Note dr16:30","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"F4lUn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"BackpackはHaskellにモジュールシグネチャの補助機構を提供した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fon