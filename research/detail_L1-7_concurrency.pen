idth","width":"fill_container","content":"GILはAIと機械学習時代のマルチコア活用で主要制約になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"BjCFq","x":2470,"y":3988,"name":"L1-7::Group 131 :: Group 1 :: Lone 477 :: Lone 531 :: Sticky Note dr13:66","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CXVDQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"データ並列の重点はマルチコアからSIMDとGPU活用へ拡大している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bukpR","x":4058,"y":6236,"name":"L1-7::Group 133 :: Group 1 :: Lone 242 :: Lone 279 :: Sticky Note dr4:22","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nVzBq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaはdo...endやfunction中心の最小構文で文法規模を抑えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bRylG","x":4342,"y":6236,"name":"L1-7::Group 133 :: Group 1 :: Lone 244 :: Lone 281 :: Sticky Note dr4:24","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"J5LNf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaはテーブルとメタテーブルで拡張性を担保し文法追加を抑制した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oQn91","x":4058,"y":6436,"name":"L1-7::Group 133 :: Group 1 :: Lone 443 :: Lone 497 :: Sticky 