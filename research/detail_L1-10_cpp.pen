one_375","name":"Island::Cでは波括弧省略時に追加行が無条件実… (1枚)","x":558,"y":1916,"width":308,"height":208,"fill":"none","stroke":{"thickness":1.5,"fill":"#888888"},"cornerRadius":8},{"type":"rectangle","id":"island_l1_10_comparison","name":"Island::他言語との比較参照","x":2564,"y":1168,"width":340,"height":448,"fill":"none","stroke":{"thickness":2,"fill":"#B9770E","dashPattern":[6,4]},"cornerRadius":10},{"type":"frame","id":"plate_00009","x":100,"y":80,"name":"Nameplate::[L1] C/C++設計の性能優先と安全","width":260,"fill":"#FFCC80","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"plate_00009_t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"[L1] C/C++設計の性能優先と安全性トレードオフ","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"600"}]},{"type":"frame","id":"6j0Vd","x":448,"y":284,"name":"L1-10::Group 5 :: Group 1 :: Group 51 :: Group 110 :: Sticky Note dr6:35","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"teAuN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++プリプロセッサマクロは条件分岐には有効だが型安全性欠如とデバッグ困難を招きやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wuf5V","x":164,"y":284,"name":"L1-10::Group 5 :: Group 1 :: Group 51 :: Group 110 :: Sticky Note dr16:59","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sLrGT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++プリプロセッサマクロは型やスコープ非認識のため副作用バグを生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KVCsa","x":732,"y":284,"name":"L1-10::Group 5 :: Group 1 :: Group 51 :: Lone 390 :: Sticky Note dr6:34","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"fJk35","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++プリプロセッサマクロは実装容易性と移植性を優先したテキスト置換機構として成立した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"k5aex","x":164,"y":484,"name":"L1-10::Group 5 :: Group 1 :: Lone 175 :: Lone 197 :: Sticky Note dr2:51","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"I4ieX","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++は手動確保解放で最大制御性を得る代わりにメモリ安全バグを生みやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WJAJF","x":448,"y":484,"name":"L1-10::Group 5 :: Group 1 :: Lone 176 :: Lone 198 :: Sticky Note dr2:52","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Hfc1m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++は境界検査や所有権追跡を言語が強制しないため脆弱性が実行時まで露出しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MEYkq","x":732,"y":484,"name":"L1-10::Group 5 :: Group 1 :: Lone 338 :: Lone 382 :: Sticky Note dr6:20","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wtQH8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++のヘッダ＋リンカモデルは当時の計算資源制約で分割コンパイルを成立させる実用解だった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"istM5","x":164,"y":684,"name":"L1-10::Group 5 :: Group 1 :: Lone 339 :: Lone 383 :: Sticky Note dr6:21","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DZXoO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++のヘッダ文化は宣言定義二重管理とODR問題と再コンパイル肥大を長期負債として残した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NLOth","x":448,"y":684,"name":"L1-10::Group 5 :: Group 1 :: Lone 446 :: Lone 500 :: Sticky Note dr12:76","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mb5Sm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++のメモリ安全欠陥は重大脆弱性の主要因として長年報告されている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"f2AdU","x":732,"y":684,"name":"L1-10::Group 5 :: Group 1 :: Lone 605 :: Lone 669 :: Sticky Note dr16:46","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"84OVr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++は#include前処理と翻訳単位分割で黎明期ハードウェア制約に適応した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OWmx7","x":164,"y":884,"name":"L1-10::Group 5 :: Group 1 :: Lone 606 :: Lone 670 :: Sticky Note dr16:47","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sAyKp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代C++では巨大ヘッダ再パースがコンパイル時間の主要ボトルネックになっている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nyL0z","x":448,"y":884,"name":"L1-10::Group 5 :: Group 1 :: Lone 623 :: Lone 687 :: Sticky Note dr16:79","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tAuQL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C/C++ヘッダモデルは大規模化でビルド時間破綻を招き、Modules移行が進行中である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QwJ6V","x":732,"y":884,"name":"L1-10::Group 5 :: Group 1 :: Lone 644 :: Lone 714 :: Sticky Note nishio:37","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"juLjk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CとC++はGCを前提にせず、手動管理やRAIIで性能制御を重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"69sBI","x":164,"y":1084,"name":"L1-10::Group 5 :: Group 1 :: Lone 647 :: Lone 717 :: Sticky Note nishio:40","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FT2Bw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CとC++は未初期化を許す設計で、性能と安全性の責任を開発者に置く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Nf5RB","x":1902,"y":484,"name":"L1-10::Group 9 :: Group 1 :: Group 33 :: Group 131 :: Sticky Note nishio:28","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rK2BJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は演算子オーバーロードを許し、表現力と可読性のトレードオフがある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Vi7zJ","x":2186,"y":484,"name":"L1-10::Group 9 :: Group 1 :: Group 50 :: Lone 406 :: Sticky Note dr6:61","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"r2wMv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は`constexpr`とConcepts導入で旧来テンプレートメタプログラミングの難読性を緩和している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"T90Sp","x":1902,"y":284,"name":"L1-10::Group 9 :: Group 1 :: Group 106 :: Group 119 :: Sticky Note dr11:47","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iyAQg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ ConceptsはSFINAE依存の複雑な回避策を減らし安全な汎用設計を促した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"G3xXk","x":2186,"y":284,"name":"L1-10::Group 9 :: Group 1 :: Group 106 :: Group 119 :: Sticky Note dr16:83","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aIyuF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ TMPはSFINAE時代の可読性危機を経てConceptsで制約記述を明示化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"nBVXp","x":1902,"y":684,"name":"L1-10::Group 9 :: Group 1 :: Lone 269 :: Lone 307 :: Sticky Note dr4:63","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7lRpo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++はテンプレート柔軟性の代償として診断が内部表現寄りで長文化しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4I8qB","x":2186,"y":684,"name":"L1-10::Group 9 :: Group 1 :: Lone 293 :: Lone 335 :: Sticky Note dr4:99","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0uBMu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は>>曖昧性やdecltypeやrequiresなど文脈依存が強く完全パースが難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JmLbk","x":1902,"y":884,"name":"L1-10::Group 9 :: Group 1 :: Lone 357 :: Lone 405 :: Sticky Note dr6:60","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IQThL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++テンプレートメタプログラミングは高表現力を得る一方で可読性低下とコンパイル遅延を悪化させやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eB3la","x":2186,"y":884,"name":"L1-10::Group 9 :: Group 1 :: Lone 502 :: Lone 559 :: Sticky Note dr14:18","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ojTJH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のMost Vexing Parseは文脈依存文法が開発体験を悪化させる典型例である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oWGN3","x":3790,"y":284,"name":"L1-10::Group 10 :: Group 1 :: Group 64 :: Group 64 :: Sticky Note dr2:53","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Lpog5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のRAIIはリソース寿命をスコープへ結び付けて例外時解放を自動化する設計である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5ptN0","x":3506,"y":284,"name":"L1-10::Group 10 :: Group 1 :: Group 64 :: Group 64 :: Sticky Note dr12:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"D9u6T","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のRAIIはスコープ終了時解放を言語習慣として定着させた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"gnE2v","x":3506,"y":484,"name":"L1-10::Group 10 :: Group 1 :: Lone 300 :: Lone 342 :: Sticky Note dr5:5","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ACuWH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の例外はRAIIと組み合わせて後始末を自動化できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Btgmj","x":3790,"y":484,"name":"L1-10::Group 10 :: Group 1 :: Lone 301 :: Lone 343 :: Sticky Note dr5:6","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"RK1zJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の例外は例外安全保証とABI懸念の運用コストが高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MnGSC","x":3506,"y":684,"name":"L1-10::Group 10 :: Group 1 :: Lone 326 :: Lone 370 :: Sticky Note dr5:60","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EAZbR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++低遅延領域では例外禁止方針が採られライブラリ設計制約が強くなる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eC8dj","x":3790,"y":684,"name":"L1-10::Group 10 :: Group 1 :: Lone 516 :: Lone 576 :: Sticky Note dr14:48","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nf348","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++とRustのRAIIは安全性が高い一方で制御フローの可視性を下げる場面がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"10sBe","x":3506,"y":884,"name":"L1-10::Group 10 :: Group 1 :: Lone 560 :: Lone 621 :: Sticky Note dr15:29","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5TDPa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ 例外は stack unwinding と RAII に依存し安全性と性能の設計トレードオフが大きい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EkS9a","x":3790,"y":884,"name":"L1-10::Group 10 :: Group 1 :: Lone 563 :: Lone 624 :: Sticky Note dr15:32","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uDxIL","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"高性能領域では C++ 例外を無効化してエラーコードへ戻す運用が今も多い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dxamx","x":2604,"y":284,"name":"L1-10::Group 19 :: Group 1 :: Group 40 :: Group 36 :: Sticky Note dr13:88","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tyhJT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20のstd::jthreadは自動joinと停止要求でこの欠点を補った。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HsrTD","x":2604,"y":484,"name":"L1-10::Group 19 :: Group 1 :: Group 50 :: Group 88 :: Sticky Note dr4:64","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iJXzp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20以降はconceptsなどにより診断可読性が段階的に改善している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RniY9","x":2888,"y":284,"name":"L1-10::Group 19 :: Group 1 :: Group 50 :: Group 88 :: Sticky Note dr11:46","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"zEJ7I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Conceptsはテンプレート要件を境界で明示して診断可読性を大幅に改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"U5vDi","x":2604,"y":684,"name":"L1-10::Group 19 :: Group 1 :: Group 99 :: Group 108 :: Sticky Note dr6:22","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gD1B1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Modulesはテキストインクルード依存を減らしビルド時間とODRリスクを下げる方向を示した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Hj1XH","x":2888,"y":484,"name":"L1-10::Group 19 :: Group 1 :: Group 99 :: Group 108 :: Sticky Note dr16:48","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Fm7Vh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Modulesは前処理依存を減らし、パース済みインターフェース再利用を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5Umpn","x":2888,"y":684,"name":"L1-10::Group 19 :: Group 1 :: Lone 340 :: Lone 384 :: Sticky Note dr6:23","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Glfd7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Modulesの実務普及は既存コードとビルドツール互換の移行コストにより段階的に進んでいる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"p4mXf","x":2604,"y":884,"name":"L1-10::Group 19 :: Group 1 :: Lone 607 :: Lone 671 :: Sticky Note dr16:49","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oCGRh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++20 Modulesはツールチェーン差異と既存資産移行の難しさで普及が漸進的である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"041a5","x":3774,"y":2348,"name":"L1-10::Group 24 :: Group 1 :: Group 19 :: Group 14 :: Sticky Note dr3:67","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TqMz3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Futhark コンパイラは高水準記述を GPU 向けカーネル群とホストコードへ変換して最適化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"6vA39","x":2604,"y":1212,"name":"L1-10::Group 49 :: Group 1 :: Lone 226 :: Lone 254 :: Sticky Note dr3:68","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DXAbP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の std::simd 構想は fearless SIMD を掲げ、unsafe を減らした型安全なベクトル演算を目指す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Fi3IY","x":2604,"y":1412,"name":"L1-10::Group 49 :: Group 1 :: Lone 484 :: Lone 538 :: Sticky Note dr13:76","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Fj3a8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"std::simdは対応命令へ最適化し非対応環境では安全にスカラへフォールバックする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"M53jz","x":4208,"y":284,"name":"L1-10::Group 60 :: Group 1 :: Group 33 :: Lone 701 :: Sticky Note nishio:18","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"pS2bo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は関数オブジェクトで呼び出し演算子をオーバーロードできる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wAhd3","x":4492,"y":284,"name":"L1-10::Group 60 :: Group 1 :: Lone 278 :: Lone 319 :: Sticky Note dr4:78","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3N6nV","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は後方互換を維持しながら機能追加を重ねた結果として仕様が肥大化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"njOvp","x":4208,"y":484,"name":"L1-10::Group 60 :: Group 1 :: Lone 426 :: Lone 476 :: Sticky Note dr12:48","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"O4afi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ Profiles構想は危険操作を制限して既存コードの安全化を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Yjjgn","x":4492,"y":484,"name":"L1-10::Group 60 :: Group 1 :: Lone 629 :: Lone 694 :: Sticky Note nishio:8","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"B6cOR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++は参照渡し構文を導入し、呼び出し側のオブジェクト更新を直接書ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bzFJr","x":866,"y":1412,"name":"L1-10::Group 65 :: Group 1 :: Group 48 :: Group 50 :: Sticky Note nishio:13","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"20NHC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C配列は長さ情報を持たず、範囲外アクセスの危険が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1SzEd","x":866,"y":1612,"name":"L1-10::Group 65 :: Group 1 :: Lone 686 :: Lone 762 :: Sticky Note nishio:120","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MVJAS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cの配列範囲外アクセスは未定義動作でクラッシュや脆弱性につながる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"phdC0","x":3790,"y":1212,"name":"L1-10::Group 70 :: Group 1 :: Group 65 :: Group 65 :: Sticky Note dr2:55","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3DHQi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のunique_ptrは単一所有権を型で表して二重解放とリークを減らす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ivBBx","x":3506,"y":1212,"name":"L1-10::Group 70 :: Group 1 :: Group 65 :: Group 65 :: Sticky Note dr12:46","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aoV77","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のstd::unique_ptrは単一所有権を明示して解放責務を単純化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hNwTJ","x":3790,"y":1412,"name":"L1-10::Group 70 :: Group 1 :: Group 66 :: Group 66 :: Sticky Note dr2:56","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WOa20","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のshared_ptrは共有所有権を実現する一方で循環参照と原子参照更新コストを生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EAV01","x":3506,"y":1412,"name":"L1-10::Group 70 :: Group 1 :: Group 66 :: Group 66 :: Sticky Note dr12:47","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PYFW9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のstd::shared_ptrは共有所有を扱えるが参照カウントコストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ju7vC","x":164,"y":1412,"name":"L1-10::Group 85 :: Group 1 :: Lone 336 :: Lone 380 :: Sticky Note dr6:18","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"G580H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の`friend`は公開APIを増やさず密結合協調を実現する例外アクセス機構として導入された。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hK40i","x":448,"y":1412,"name":"L1-10::Group 85 :: Group 1 :: Lone 337 :: Lone 381 :: Sticky Note dr6:19","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cOiYU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の`friend`は演算子実装などで有効だが乱用するとカプセル化と依存可読性を損なう。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rly2H","x":164,"y":1612,"name":"L1-10::Group 85 :: Group 1 :: Lone 602 :: Lone 666 :: Sticky Note dr16:42","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tUl2a","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ friendは非メンバ演算子や密結合コンポーネントの効率的連携に有効である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TvBw7","x":448,"y":1612,"name":"L1-10::Group 85 :: Group 1 :: Lone 603 :: Lone 667 :: Sticky Note dr16:43","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"748LI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ friendは責務分離不足のコードで乱用されると保守性を悪化させる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VXqVv","x":4392,"y":2348,"name":"L1-10::Group 108 :: Group 1 :: Lone 208 :: Lone 234 :: Sticky Note dr3:19","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ma98b","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Pony は実行時オーバーヘッドを抑えるため、ケイパビリティ検査を主にコンパイル時に行う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eBLmJ","x":2186,"y":1212,"name":"L1-10::Group 109 :: Group 1 :: Group 40 :: Group 36 :: Sticky Note dr3:78","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AtME3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ の std::thread は join と detach の管理責務が重く、低レベル過ぎるという批判を受ける。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"fOKpY","x":1902,"y":1212,"name":"L1-10::Group 109 :: Group 1 :: Group 40 :: Group 36 :: Sticky Note dr13:86","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xrNhd","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++11のstd::threadはjoinまたはdetach忘れでstd::terminateを招く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"C1hEo","x":1902,"y":1412,"name":"L1-10::Group 109 :: Group 1 :: Lone 231 :: Lone 260 :: Sticky Note dr3:79","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AYzql","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ では std::thread の上位抽象として std::async や Boost.Asio や独自スレッドプールの利用が一般化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"WTAot","x":4208,"y":1212,"name":"L1-10::Group 120 :: Group 1 :: Group 101 :: Group 112 :: Sticky Note dr6:44","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PEU9Y","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"D言語CTFEは通常関数をコンパイル時実行可能にしてテンプレート依存を緩和した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1oLOw","x":164,"y":2956,"name":"L1-10::Group 132 :: Group 1 :: Lone 235 :: Lone 265 :: Sticky Note dr4:5","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TxSPz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文では波括弧対応やセミコロン漏れが日常的な構文エラー要因になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qEMNt","x":164,"y":3156,"name":"L1-10::Group 132 :: Group 1 :: Lone 670 :: Lone 744 :: Sticky Note nishio:77","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LKd9z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはインデントと実際の構文ブロックがずれるコードを書けてしまう。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iOgjw","x":1902,"y":2348,"name":"L1-10::Group 136 :: Group 1 :: Lone 294 :: Lone 336 :: Sticky Note dr4:100","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2L2Y7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ClangとGCCはC++実装における事実上の参照実装として重い役割を担う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OMiga","x":1902,"y":2548,"name":"L1-10::Group 136 :: Group 1 :: Lone 568 :: Lone 631 :: Sticky Note dr15:47","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LSQx4","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の実装は C++ 風の重い unwind ではなく戻り値ベース変換で効率を確保する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cJHjv","x":4626,"y":1212,"name":"L1-10::Group 140 :: Group 1 :: Lone 503 :: Lone 560 :: Sticky Note dr14:19","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2a1Dr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代言語はC++的な曖昧性を避けるため決定論的な構文解析を志向する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5hnDs","x":164,"y":2348,"name":"L1-10::Group 141 :: Group 1 :: Lone 561 :: Lone 622 :: Sticky Note dr15:30","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"HFJOc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ の基本保証は例外時でもリソースリークを防ぐことを要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"umOsZ","x":448,"y":2348,"name":"L1-10::Group 141 :: Group 1 :: Lone 562 :: Lone 623 :: Sticky Note dr15:31","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ODtjo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++ の強い保証は失敗時の完全ロールバックを要求し copy-and-swap などのコストを伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lr3IF","x":164,"y":2548,"name":"L1-10::Group 141 :: Group 1 :: Lone 658 :: Lone 732 :: Sticky Note nishio:62","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eOvYS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++とJavaはconstやfinalで再代入禁止を局所的に指定する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"erpVk","x":582,"y":2956,"name":"L1-10::Group 142 :: Group 1 :: Lone 675 :: Lone 750 :: Sticky Note nishio:87","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dsha5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RubyとC++の文字列は破壊的更新を許す実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rlpGL","x":4810,"y":2348,"name":"L1-10::Group 158 :: Group 1 :: Lone 640 :: Lone 709 :: Sticky Note nishio:31","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aWhxK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++の多重継承はダイヤモンド問題を生みうる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"mVz5s","x":1200,"y":2956,"name":"L1-10::Group 163 :: Group 1 :: Group 2 :: Lone 264 :: Sticky Note dr4:4","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ugal5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文の普及はC, C++, Java, C#, JavaScript間の学習移行を容易にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Paw3r","x":1200,"y":3156,"name":"L1-10::Group 163 :: Group 1 :: Lone 681 :: Lone 757 :: Sticky Note nishio:101","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Whz8i","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++はCの型システムを拡張してクラスと継承を導入した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MNrww","x":1284,"y":1412,"name":"L1-10::Group 185 :: Group 1 :: Lone 298 :: Lone 340 :: Sticky Note dr5:3","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MXrH3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはエラーコード返却を中心とするため呼び出し側のチェック漏れが起きやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Stg8g","x":866,"y":2348,"name":"L1-10::Group 201 :: Group 1 :: Lone 177 :: Lone 199 :: Sticky Note dr2:54","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"32Tea","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C++のRAIIは強力だがコピー/ムーブ設計を誤ると所有権バグを招く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Kv1Iz","x":2320,"y":2348,"name":"L1-10::Group 226 :: Group 1 :: Lone 649 :: Lone 720 :: Sticky Note nishio:44","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PwVJz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cはグローバル変数を直接定義できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"2pjkT","x":2738,"y":2348,"name":"L1-10::Group 236 :: Group 1 :: Lone 362 :: Lone 411 :: Sticky Note dr6:67","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VQGdm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"インクリメンタルコンパイルは開発体験を改善するがC/C++とRustでは依存構造次第で限界が残る。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"76IWY","x":1284,"y":2348,"name":"L1-10::Group 241 :: Group 1 :: Lone 425 :: Lone 475 :: Sticky Note dr12:44","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"w6ddC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cのmalloc/free運用はリーク、二重解放、Use-after-freeの温床になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zDsDY","x":3356,"y":2348,"name":"L1-10::Group 254 :: Group 1 :: Lone 628 :: Lone 693 :: Sticky Note nishio:7","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"deVJZ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cの関数引数は値渡しであり、参照的な更新はポインタ値を渡して実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ROti8","x":3356,"y":2548,"name":"L1-10::Group 254 :: Group 1 :: Lone 632 :: Lone 699 :: Sticky Note nishio:16","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xNM5X","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Cは関数ポインタを作成でき、高階的な呼び出しを実装できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZHqiR","x":164,"y":1940,"name":"L1-10::Group 255 :: Group 1 :: Lone 676 :: Lone 751 :: Sticky Note nishio:89","width":260,"fil