amily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FtbMQ","x":1150,"y":284,"name":"L1-6::Group 137 :: Group 1 :: Lone 305 :: Lone 347 :: Sticky Note dr5:12","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UDnas","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのFrom変換は?演算子利用時のエラー型統合を支援する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"A1Kb8","x":866,"y":484,"name":"L1-6::Group 137 :: Group 1 :: Lone 566 :: Lone 629 :: Sticky Note dr15:42","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"l7H64","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の ? 演算子は Err 時の早期 return と Into によるエラー変換を簡潔に実現する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YZM47","x":3640,"y":3004,"name":"L1-6::Group 139 :: Group 1 :: Lone 328 :: Lone 372 :: Sticky Note dr6:1","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JqM25","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust 2018 editionは`extern crate`依存を減らし`crate::`を含む統一的パス解決でモジュール学習コストを下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YI2uh","x":5228,"y":3740,"name":"L1-6::Group 160 :: Group 1 :: Group 2 :: Group 4 :: Sticky Note nishio:118","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"NA2WH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"配列範囲外アクセス時にRubyはnil、JavaScriptはundefinedを返す実装がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Ixz5h","x":582,"y":1740,"name":"L1-6::Group 167 :: Group 1 :: Group 5 :: Group 34 :: Sticky Note dr13:47","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JPqgl","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのFearless Concurrencyは競合不安を減らす開発体験として定着した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qUNHu","x":2738,"y":3740,"name":"L1-6::Group 171 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr11:26","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"kaPSx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの Option<T> は Option<Option<T>> のようなネスト表現を自然に扱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"iraJS","x":4058,"y":3004,"name":"L1-6::Group 179 :: Group 1 :: Group 59 :: Group 57 :: Sticky Note dr2:82","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9VXR3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは安全性向上の代償として一部データ構造設計自由度を下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pSS4V","x":5646,"y":3740,"name":"L1-6::Group 180 :: Group 1 :: Group 62 :: Group 62 :: Sticky Note dr2:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VNZu7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのPoloniusは借用解析をDatalogベースで再定式化して精度と説明性の改善を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8Nt7V","x":3356,"y":3740,"name":"L1-6::Group 182 :: Group 1 :: Group 83 :: Group 90 :: Sticky Note dr4:83","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QO67Z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのcargoはビルド依存公開までを一体化し新規参入障壁を下げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OqBSe","x":3356,"y":3940,"name":"L1-6::Group 182 :: Group 1 :: Group 83 :: Group 90 :: Sticky Note dr4:84","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ec1LB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのcargoはcargo new, cargo test, cargo fmtの統一操作で開発体験を標準化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cA76r","x":3022,"y":2476,"name":"L1-6::Group 183 :: Group 1 :: Group 86 :: Group 94 :: Sticky Note dr5:13","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QmmvD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustではthiserrorがライブラリ向けの厳密なエラー型定義に使われる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"y9LmE","x":3372,"y":1012,"name":"L1-6::Group 184 :: Group 1 :: Group 87 :: Group 95 :: Sticky Note dr5:14","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xaiFQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustではanyhowがアプリ境界での集約的エラー処理に使われる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yBfbq","x":3372,"y":812,"name":"L1-6::Group 184 :: Group 1 :: Group 87 :: Group 95 :: Sticky Note dr15:44","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2Rzoi","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の anyhow はアプリケーション向けに文脈付き集約エラー処理を簡略化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ddCVF","x":866,"y":2476,"name":"L1-6::Group 186 :: Group 1 :: Group 92 :: Group 101 :: Sticky Note dr5:45","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3Lcvj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのmatch式は所有権と組み合わせた網羅的分岐に強い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Hs6rk","x":866,"y":2676,"name":"L1-6::Group 186 :: Group 1 :: Lone 435 :: Lone 489 :: Sticky Note dr12:63","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TeDoz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのbumpaloやtyped-arenaは所有権モデルと併用される実践的手段である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"RxW4Y","x":582,"y":3940,"name":"L1-6::Group 188 :: Group 1 :: Group 97 :: Group 106 :: Sticky Note dr6:10","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"3QELJ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`pub` `pub(crate)` `pub(super)`はデフォルト非公開を維持しつつ段階的公開を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Uzta2","x":582,"y":3740,"name":"L1-6::Group 188 :: Group 1 :: Group 97 :: Group 106 :: Sticky Note dr16:34","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"b0Z2H","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust可視性はprivate既定に加えてpub(crate)やpub(super)で公開範囲を段階化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"7MO9f","x":4810,"y":4268,"name":"L1-6::Group 190 :: Group 1 :: Group 113 :: Group 132 :: Sticky Note nishio:79","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1mCJe","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rubyはendでブロック終端を明示する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Is9Ot","x":1902,"y":3204,"name":"L1-6::Group 193 :: Group 1 :: Lone 129 :: Lone 139 :: Sticky Note dr1:16","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OCrc9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権と借用とライフタイム制約を扱うため一方向推論だけでは実用性が不足する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"xWwQt","x":3356,"y":4268,"name":"L1-6::Group 202 :: Group 1 :: Lone 422 :: Lone 472 :: Sticky Note dr12:39","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MFEK3","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのNLLはMIR制御フロー解析で実用的な受理範囲を広げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ewz1f","x":1000,"y":1740,"name":"L1-6::Group 207 :: Group 1 :: Lone 392 :: Lone 442 :: Sticky Note dr11:44","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"tDrU9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのトレイト境界付き単相化はゼロコスト抽象化を実現する中核戦略である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vQaHd","x":3774,"y":3740,"name":"L1-6::Group 212 :: Group 1 :: Lone 198 :: Lone 221 :: Sticky Note dr2:81","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9fulK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは自己参照構造や循環グラフで安全表現が難しくPinやunsafeや追加抽象が必要になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KGu6u","x":3774,"y":3940,"name":"L1-6::Group 212 :: Group 1 :: Lone 287 :: Lone 329 :: Sticky Note dr4:90","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"V4npB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Go, Rust初期, C/C++はファイル単位実行中心のため試行サイクルが重くなりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5GN0P","x":2604,"y":1012,"name":"L1-6::Group 215 :: Group 1 :: Lone 211 :: Lone 239 :: Sticky Note dr3:29","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DjBVn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の非同期基盤は利用者側を簡潔に保つ一方で、ライブラリ作者には Pin、Poll、Unsafe の複雑性を要求する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"s43DH","x":3790,"y":812,"name":"L1-6::Group 224 :: Group 1 :: Lone 280 :: Lone 322 :: Sticky Note dr4:81","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9CmMS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは入門資料とコンパイラUX改善で初期学習負荷を継続的に緩和している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ZHob5","x":3790,"y":1012,"name":"L1-6::Group 224 :: Group 1 :: Lone 583 :: Lone 646 :: Sticky Note dr16:8","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LMnGK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは旧式のmod.rs構成も維持し、移行コストに配慮した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"O10af","x":1768,"y":1340,"name":"L1-6::Group 225 :: Group 1 :: Lone 505 :: Lone 562 :: Sticky Note dr14:23","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"AOCpW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは複数implブロックで機能群や条件付き実装を整理しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EfkSy","x":1000,"y":1212,"name":"L1-6::Group 227 :: Group 1 :: Lone 303 :: Lone 345 :: Sticky Note dr5:10","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sIN4m","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはpanicをバグや致命的状態に限定する文化を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"odjaB","x":1000,"y":1412,"name":"L1-6::Group 227 :: Group 1 :: Lone 521 :: Lone 581 :: Sticky Note dr14:53","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"YOPYN","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは曖昧な診断をコンパイラ側の不具合として扱う文化を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"h1HNM","x":4192,"y":3740,"name":"L1-6::Group 232 :: Group 1 :: Lone 329 :: Lone 373 :: Sticky Note dr6:2","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MdQma","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのモジュール再設計は2015 editionで指摘されたルート規則の不一致と`mod.rs`中心運用の分かりにくさを是正した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"0qvn7","x":4192,"y":3940,"name":"L1-6::Group 232 :: Group 1 :: Lone 582 :: Lone 645 :: Sticky Note dr16:7","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"TJ2Mu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの新しいモジュール規則はIDEタブのmod.rs氾濫問題を緩和した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8MN3C","x":164,"y":3332,"name":"L1-6::Group 236 :: Group 1 :: Lone 361 :: Lone 410 :: Sticky Note dr6:66","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dxcfg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Java C# Rust SwiftなどはインクリメンタルコンパイルをIDE連携の前提機能として強化してきた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"p7rV7","x":164,"y":2068,"name":"L1-6::Group 247 :: Group 1 :: Lone 635 :: Lone 704 :: Sticky Note nishio:22","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iVHoK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PerlとRubyは文脈によって呼び出し括弧を省略できる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ueRVU","x":2186,"y":1340,"name":"L1-6::Lone 265 :: Group 1 :: Group 11 :: Group 6 :: Sticky Note dr14:29","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BzxIm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rails DoctrineはConvention over Configurationで認知負荷の一部を規約へ移す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9xqER","x":582,"y":3332,"name":"L1-6::Lone 266 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr16:71","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"LB1cj","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust derive macroは実行時リフレクションなしでトレイト実装を静的生成する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"I5q7a","x":1000,"y":3332,"name":"L1-6::Lone 276 :: Group 1 :: Lone 174 :: Lone 196 :: Sticky Note dr2:50","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xGjMT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはunsafe依存部分でUBリスクが残るためレビューと検証負荷が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QMVPF","x":164,"y":4268,"name":"L1-6::Lone 278 :: Group 1 :: Lone 185 :: Lone 207 :: Sticky Note dr2:65","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ffCU6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのアリーナパターンは短命データを一括解放して性能と単純性を両立する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MOHqt","x":582,"y":2068,"name":"L1-6::Lone 287 :: Group 1 :: Lone 264 :: Lone 302 :: Sticky Note dr4:58","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FiUo1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustコンパイラはヒント付き診断で所有権学習を支える教師的UXを志向した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5wnf8","x":582,"y":4268,"name":"L1-6::Lone 288 :: Group 1 :: Lone 266 :: Lone 304 :: Sticky Note dr4:60","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uCiEs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの詳細診断は熟練者には情報量過多と感じられる場合がある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"JL7ZR","x":1618,"y":4268,"name":"L1-6::Lone 301 :: Group 1 :: Lone 369 :: Lone 419 :: Sticky Note dr11:15","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6fy37","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは関数境界の明示注釈を要求しつつ関数内部の強い推論を維持する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Cr4rP","x":2320,"y":3204,"name":"L1-6::Lone 303 :: Group 1 :: Lone 377 :: Lone 427 :: Sticky Note dr11:27","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"woiBT","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustはニッチ最適化でOptionポインタの実行時オーバーヘッドを実質ゼロにできる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rUvsy","x":2604,"y":1340,"name":"L1-6::Lone 305 :: Group 1 :: Lone 380 :: Lone 430 :: Sticky Note dr11:31","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"UkAER","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustとSwiftのenumベースADTはパターンマッチの網羅性検査を可能にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"CpAAM","x":1000,"y":2068,"name":"L1-6::Lone 317 :: Group 1 :: Lone 421 :: Lone 471 :: Sticky Note dr12:36","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"juOft","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの借用規則はエイリアシングと可変更新の同時発生を制限する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"7Vpbl","x":4208,"y":812,"name":"L1-6::Lone 324 :: Group 1 :: Lone 448 :: Lone 502 :: Sticky Note dr12:78","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"F7dca","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust、Go、C#、Java、Swiftは移行候補として政策文書で言及されることが多い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KYcx6","x":2738,"y":3204,"name":"L1-6::Lone 333 :: Group 1 :: Lone 504 :: Lone 561 :: Sticky Note dr14:22","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shado