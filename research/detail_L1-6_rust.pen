":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JwdH5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権とMoveにより送信後アクセス禁止をコンパイル時に保証する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hF9Vp","x":2052,"y":484,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Lone 190 :: Sticky Note dr2:41","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z8O1d","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは実行時コストを抑えて安全性を得る代わりに学習コストをコンパイル時へ移した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yqMOG","x":1768,"y":684,"name":"L1-6::Group 25 :: Group 1 :: Group 21 :: Lone 321 :: Sticky Note dr4:80","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"u1Jth","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは所有権と借用で安全性と性能を両立する代わりに学習曲線を急にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zaHTm","x":2052,"y":684,"name":"L1-6::Group 25 :: Group 1 :: Lone 168 :: Lone 189 :: Sticky Note dr2:40","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"z2B2D","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは初期のGC路線を捨てて所有権と借用による非GCメモリ安全を中核に据えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8Dzf4","x":1000,"y":3740,"name":"L1-6::Group 28 :: Group 1 :: Lone 682 :: Lone 758 :: Sticky Note nishio:106","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PaND6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rubyはアクセス制御を比較的重視する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FeOsD","x":4760,"y":2476,"name":"L1-6::Group 29 :: Group 1 :: Lone 265 :: Lone 303 :: Sticky Note dr4:59","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"8Dl9t","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの診断改善はElm, Gleam, Scalaなど他言語のエラーUX設計にも影響した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XT5OX","x":2186,"y":2476,"name":"L1-6::Group 43 :: Group 1 :: Group 61 :: Group 61 :: Sticky Note dr2:44","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"J5xOQ","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのNLLは不要な借用制約を減らしてワークアラウンド記述を大幅に減らした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Pnc65","x":1902,"y":2476,"name":"L1-6::Group 43 :: Group 1 :: Group 61 :: Group 61 :: Sticky Note dr12:38","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","off