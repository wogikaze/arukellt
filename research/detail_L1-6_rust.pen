ct":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"W8XKf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは高度な型推論を優先してきた歴史から診断難解性の批判が根強い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dnWQp","x":164,"y":484,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr6:30","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"GX0hD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`macro_rules!`はCプリプロセッサより構文安全な宣言的マクロでDSL的記述を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dqR5f","x":448,"y":484,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr6:32","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"EZta6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの`proc_macro`は`#[derive]`や属性マクロで高度なコード生成を可能にした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"rlsXn","x":164,"y":284,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr16:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BG2h2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust macro_rules!は衛生的な定型展開に強く、proc_macroは高度生成に向く。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qGVCF","x":448,"y":284,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Group 15 :: Sticky Note dr16:58","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9NWA5","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust proc_macroはsynやquote依存を含めてコンパイル時間を押し上げやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5uG3d","x":164,"y":684,"name":"L1-6::Group 17 :: Group 1 :: Group 15 :: Lone 402 :: Sticky Note dr6:53","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"4OiCA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustのユーザー定義`derive`は便利だが内部的に`proc_macro`依存を増やしビルド時間に影響する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qaKqG","x":448,"y":684,"name":"L1-6::Group 17 :: Group 1 :: Lone 344 :: Lone 388 :: Sticky Note dr6:31","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MLtyB","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustの宣言的マクロは便利だが展開エラーの読みにくさと設計難度が普及の摩擦になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tA7JH","x":164,"y":884,"name":"L1-6::Grou