Height":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"PBMNL","x":164,"y":3004,"name":"L1-6::Group 46 :: Group 1 :: Lone 469 :: Lone 523 :: Sticky Note dr13:45","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"c179d","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rustは色分けを型で明示して実行制御の厳密性を優先した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"dVLyo","x":3640,"y":2476,"name":"L1-6::Group 49 :: Group 1 :: Lone 227 :: Lone 255 :: Sticky Note dr3:69","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"U9SxK","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の std::simd は intrinsics 依存を緩和し、安全性と性能の両立を狙う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"X2deQ","x":3924,"y":2476,"name":"L1-6::Group 49 :: Group 1 :: Lone 228 :: Lone 256 :: Sticky Note dr3:70","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"0vHrW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust の std::simd は API 形状の議論を継続しつつ安定化へ向けて進んでいる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"I96sa","x":3640,"y":2676,"name":"L1-6::Group 49 :: Group 1 :: Lone 483 :: Lone 537 :: Sticky Note dr13:75","width":260,"fill":"#FADBD8","cornerRadius":4,"eff