0,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yOV8z","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swift の throws は call site の try 明示で失敗可能地点の可読性を保つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ptCuz","x":164,"y":484,"name":"L1-5::Group 39 :: Group 1 :: Group 28 :: Group 46 :: Sticky Note dr6:50","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Rewzp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# Source GeneratorはIDE連携を保ったままコンパイル時コード生成を行い開発体験を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vJmlG","x":164,"y":284,"name":"L1-5::Group 39 :: Group 1 :: Group 28 :: Group 46 :: Sticky Note dr16:73","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZV3Pp","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# Source GeneratorはRoslynでコンパイル時生成を行い起動時反射コストを削減する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vq3aM","x":448,"y":284,"name":"L1-5::Group 39 :: Group 1 :: Group 28 :: Group 46 :: Sticky Note dr16:74","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wtZls","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# Source GeneratorはAOTやトリミング適性を高め、System.Text.Json最適化に寄与した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"IZoII","x":3356,"y":3668,"name":"L1-5::Group 42 :: Group 1 :: Group 57 :: Group 54 :: Sticky Note dr11:22","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"PRXSS","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C# 3.0の var は動的型ではなく静的推論の構文糖でありLINQ可読性を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"26SLz","x":164,"y":3868,"name":"L1-5::Group 44 :: Group 1 :: Group 82 :: Group 89 :: Sticky Note dr4:77","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jU0AD","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3はenum導入や構文整理で教育容易性と可読性を重視する方向に寄せた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"TM3lE","x":448,"y":3668,"name":"L1-5::Group 44 :: Group 1 :: Group 82 :: Group 89 :: Sticky Note dr14:12","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VMrFa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3は任意の波括弧省略を導入し可読性と学習容易性を改善した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"G06cv","x":164,"y":3668,"name":"L1-5::Group 44 :: Group 1 :: Group 105 :: Group 118 :: Sticky Note dr14:37","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"MaKEo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 3はimplicitの分割により抽象化能力を保ったまま予測可能性を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"eHAgE","x":1768,"y":284,"name":"L1-5::Group 48 :: Group 1 :: Lone 166 :: Lone 182 :: Sticky Note dr2:30","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7uSkz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Luaはポーズ分散に有利だが総GC時間と実装複雑性の増加を伴う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"M3JFI","x":2052,"y":284,"name":"L1-5::Group 48 :: Group 1 :: Lone 233 :: Lone 262 :: Sticky Note dr4:2","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dPG4e","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文はパーサ実装が比較的容易で処理系実装コストを抑えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pVGOs","x":1768,"y":484,"name":"L1-5::Group 48 :: Group 1 :: Lone 283 :: Lone 325 :: Sticky Note dr4:86","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Regyg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSP時代では構文複雑性がそのままツール実装コストと普及速度に反映される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"w2yhM","x":2052,"y":484,"name":"L1-5::Group 48 :: Group 1 :: Lone 406 :: Lone 456 :: Sticky Note dr12:9","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Fn0fP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"低レイテンシGCはCPUオーバーヘッドと実装複雑性を代償にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SGx7h","x":1768,"y":684,"name":"L1-5::Group 48 :: Group 1 :: Lone 517 :: Lone 577 :: Sticky Note dr14:49","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"e7weI","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goのdeferは終了処理を単純化するが実装コスト特性の理解は必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"vrToX","x":3506,"y":284,"name":"L1-5::Group 50 :: Group 1 :: Lone 343 :: Lone 387 :: Sticky Note dr6:29","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oxJwP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lisp系マクロ文化は表現力が高い反面で方言ごとの慣習学習を必須にし読解障壁を上げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aXCHl","x":3790,"y":284,"name":"L1-5::Group 50 :: Group 1 :: Lone 346 :: Lone 391 :: Sticky Note dr6:36","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"nrtLm","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"NimのASTマクロはC系文法のままLisp級メタプログラミングを提供しDSL柔軟性を高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SWJaR","x":3506,"y":484,"name":"L1-5::Group 50 :: Group 1 :: Lone 347 :: Lone 392 :: Sticky Note dr6:37","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"OEYaw","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Nimの強力マクロは表現力の対価としてコンパイラ理解と学習コストを増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"AAxvf","x":3790,"y":484,"name":"L1-5::Group 50 :: Group 1 :: Lone 613 :: Lone 677 :: Sticky Note dr16:56","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iz45L","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Lispマクロは言語拡張力が高い一方で構文文化差による学習障壁を持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ILe41","x":3506,"y":684,"name":"L1-5::Group 50 :: Group 1 :: Lone 614 :: Lone 678 :: Sticky Note dr16:60","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wCMoP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"NimはAST操作マクロを静的型付け言語に統合し、DSL実装力を高めた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qavnw","x":2604,"y":2404,"name":"L1-5::Group 61 :: Group 1 :: Group 37 :: Group 31 :: Sticky Note dr2:21","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ANoUf","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"JavaのShenandoahは1〜3ms級ポーズを達成したが実装複雑性とバリアコストが増えた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"w0QD9","x":164,"y":2404,"name":"L1-5::Group 63 :: Group 1 :: Group 41 :: Group 38 :: Sticky Note dr5:50","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"a7BK9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"checked例外は安全性向上を狙うがAPI進化コストを増やしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XqPwN","x":448,"y":2404,"name":"L1-5::Group 63 :: Group 1 :: Group 41 :: Group 38 :: Sticky Note dr5:51","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rY1Op","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"unchecked例外は進化容易性を高めるが契約の明示性が下がる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"VPtM2","x":164,"y":2604,"name":"L1-5::Group 63 :: Group 1 :: Lone 143 :: Lone 158 :: Sticky Note dr1:58","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mRaXU","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OptionやMaybeは安全性向上と引き換えにパターンマッチやアンラップ記述を増やしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"leWUl","x":448,"y":2604,"name":"L1-5::Group 63 :: Group 1 :: Lone 534 :: Lone 594 :: Sticky Note dr14:67","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"xBEwe","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"REPLとライブ環境は探索作業の速度を上げる一方で試行エラー頻度を増やしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"K08Nx","x":164,"y":1012,"name":"L1-5::Group 69 :: Group 1 :: Group 63 :: Group 63 :: Sticky Note dr2:46","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"ZPFEH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"RustのPoloniusは将来性が高い一方でコンパイル時間や実装コストの課題を抱える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"DYI6V","x":164,"y":812,"name":"L1-5::Group 69 :: Group 1 :: Group 63 :: Group 63 :: Sticky Note dr12:41","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jUB3U","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Poloniusは精度向上の代わりにコンパイル時間増加が課題となる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HwVHx","x":164,"y":2932,"name":"L1-5::Group 83 :: Group 1 :: Lone 572 :: Lone 635 :: Sticky Note dr15:61","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"1K00S","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"代数的エフェクト実装の主要課題は continuation 捕捉と再開に伴う性能コストである。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"h0RaQ","x":3640,"y":2404,"name":"L1-5::Group 86 :: Group 1 :: Lone 359 :: Lone 408 :: Sticky Note dr6:63","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Mj0Z8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OCamlのファンクタモジュールは型安全な差し替え構成を可能にするが日常開発では難度が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"P0rS1","x":3640,"y":2604,"name":"L1-5::Group 86 :: Group 1 :: Lone 597 :: Lone 661 :: Sticky Note dr16:33","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"FZe6A","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"OCamlの明示的モジュール適用は保守性を高める代わりに記述量を増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EN6Zk","x":866,"y":284,"name":"L1-5::Group 89 :: Group 1 :: Group 1 :: Lone 183 :: Sticky Note dr2:32","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Kfzmo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"CPythonは対話型利用で決定的解放をしやすい一方で参照更新コストを負う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bQSSm","x":1150,"y":284,"name":"L1-5::Group 89 :: Group 1 :: Lone 419 :: Lone 469 :: Sticky Note dr12:29","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"sH5Zc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"参照カウント系言語は決定論的破棄により外部資源管理をしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"sEkOe","x":866,"y":484,"name":"L1-5::Group 89 :: Group 1 :: Lone 420 :: Lone 470 :: Sticky Note dr12:34","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BuUdr","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"参照カウントは読み取り主体のコードでも原子的更新コストが発生しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"g1aBu","x":4810,"y":3668,"name":"L1-5::Group 95 :: Group 1 :: Group 3 :: Lone 275 :: Sticky Note dr4:17","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"svKKn","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellは整ったコードの可読性が高い一方で初学者には規則理解が難しい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Oe9Ri","x":4810,"y":3868,"name":"L1-5::Group 95 :: Group 1 :: Lone 358 :: Lone 407 :: Sticky Note dr6:62","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"yerKF","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Haskellのモジュールは明示的import中心で理論的単純性を保つが現代的大規模可視性制御では不足もある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"EbTOj","x":164,"y":1340,"name":"L1-5::Group 99 :: Group 1 :: Lone 138 :: Lone 151 :: Sticky Note dr1:33","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Z0dBq","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ALGOL Wのnull導入は実装容易性を優先し安全性検討が不十分だったと回顧されている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Pwqko","x":3640,"y":2932,"name":"L1-5::Group 106 :: Group 1 :: Lone 400 :: Lone 450 :: Sticky Note dr12:2","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9wSvM","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Serial GCは単純だがStop-The-World停止が長くなりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1q25H","x":1902,"y":3668,"name":"L1-5::Group 107 :: Group 1 :: Group 34 :: Group 27 :: Sticky Note dr16:16","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"cMY9E","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"UMDはCommonJSとAMDの互換層として使われたが複雑化を招いた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"NcgM3","x":3022,"y":2404,"name":"L1-5::Group 111 :: Group 1 :: Group 45 :: Group 43 :: Sticky Note dr6:17","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"CBmVP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのpackage-privateはパッケージ設計が弱いコードベースでは可視性を緩め過ぎる結果になりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"aXc34","x":4058,"y":2932,"name":"L1-5::Group 116 :: Group 1 :: Group 98 :: Group 107 :: Sticky Note dr16:40","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eLx8g","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはopenとpublicを分離し、アクセス可能性と継承可能性を別軸で管理する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"qHPvb","x":582,"y":1340,"name":"L1-5::Group 119 :: Group 1 :: Lone 599 :: Lone 663 :: Sticky Note dr16:37","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A111r","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Goの公開規則は可読性に寄与する一方で公開化時に広範囲リネームを伴いやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"MlLil","x":4626,"y":284,"name":"L1-5::Group 120 :: Group 1 :: Lone 353 :: Lone 398 :: Sticky Note dr6:45","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WWEVR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"D言語CTFEは適用範囲の理解が必要で設計判断を誤ると複雑性を増やす。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"lXOut","x":1902,"y":2932,"name":"L1-5::Group 121 :: Group 1 :: Group 105 :: Group 118 :: Sticky Note dr11:37","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5wrew","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scala 2の implicit は表現力を高めた一方で追跡困難性と推論負荷を増大させた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"cPDPA","x":2320,"y":3668,"name":"L1-5::Group 127 :: Group 1 :: Lone 367 :: Lone 417 :: Sticky Note dr11:13","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BAyRh","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"高階多相や複雑なサブタイピング導入時には完全自動推論が理論的に難化する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"7XaPB","x":582,"y":812,"name":"L1-5::Group 129 :: Group 1 :: Lone 184 :: Lone 206 :: Sticky Note dr2:64","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Yc7ia","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"MLKitは長寿命データやリージョン粒度設計が難しく実装難度が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"oeTgs","x":582,"y":1012,"name":"L1-5::Group 129 :: Group 1 :: Lone 432 :: Lone 485 :: Sticky Note dr12:59","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QhIlc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"リージョン推論は寿命過大推定によるSpace Leakが実用上の難点になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"8EpfV","x":3506,"y":1012,"name":"L1-5::Group 130 :: Group 1 :: Lone 335 :: Lone 379 :: Sticky Note dr6:15","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"SData","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftの多段アクセス制御はAPI意図を明示できるが初学者には複雑に映りやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"K0p5f","x":3774,"y":3668,"name":"L1-5::Group 132 :: Group 1 :: Lone 234 :: Lone 263 :: Sticky Note dr4:3","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"rGEaP","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C系構文はインデント崩れがあっても機械的な意味が変わりにくい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"c0nHH","x":1000,"y":1340,"name":"L1-5::Group 139 :: Group 1 :: Lone 330 :: Lone 374 :: Sticky Note dr6:3","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eJBOu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rust 2018の改善で初学者の混乱は減ったが既存慣習との互換整理は引き続き難所になった。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"kIvxb","x":3924,"y":1012,"name":"L1-5::Group 140 :: Group 1 :: Lone 526 :: Lone 586 :: Sticky Note dr14:58","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"16FXA","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"現代言語の競争力は構文仕様だけでなくツール連携能力で決まる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"ITpoF","x":2470,"y":284,"name":"L1-5::Group 168 :: Group 1 :: Group 6 :: Group 58 :: Sticky Note dr1:48","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"aOe8o","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"SwiftとKotlinのnull処理差は言語哲学の違いであり可読性と簡潔性のトレードオフを生む。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"LrYdf","x":2470,"y":484,"name":"L1-5::Group 168 :: Group 1 :: Group 81 :: Group 87 :: Sticky Note dr4:54","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"BP1Xo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftのdeferは後始末処理を局所化して読みやすさを高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UTK2n","x":4342,"y":1012,"name":"L1-5::Group 170 :: Group 1 :: Group 8 :: Lone 416 :: Sticky Note dr11:10","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"A5Lvv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Dartの non-nullable by default はAOT最適化を改善しFlutter実行性能とバイナリ効率を押し上げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"voPhm","x":866,"y":2604,"name":"L1-5::Group 173 :: Group 1 :: Group 16 :: Group 18 :: Sticky Note dr6:49","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"gkEQG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaのアノテーション依存は設定の可視性低下とビルド複雑化を招きアノテーション地獄と批判される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HWxFT","x":866,"y":2404,"name":"L1-5::Group 173 :: Group 1 :: Group 16 :: Group 18 :: Sticky Note dr16:84","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Qvqfo","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Javaアノテーション集中は設定の局所化と引き換えに可読性と追跡性を悪化させやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"jvwOK","x":5228,"y":3668,"name":"L1-5::Group 175 :: Group 1 :: Group 23 :: Lone 481 :: Sticky Note dr12:54","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9Jtko","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Odinはスコープ単位のAllocator切替で一括方針変更をしやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HlvXZ","x":164,"y":1668,"name":"L1-5::Group 179 :: Group 1 :: Group 59 :: Group 57 :: Sticky Note dr1:45","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"g41yH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftは安全性向上の代償として一部コードで記述量が増える。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Z01hZ","x":2738,"y":3668,"name":"L1-5::Group 187 :: Group 1 :: Group 93 :: Group 102 :: Sticky Note dr15:60","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"9yRP8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Unison の Abilities は本番 I/O ハンドラとテスト用モックハンドラの差し替えを容易にする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QLv0I","x":582,"y":1668,"name":"L1-5::Group 189 :: Group 1 :: Group 104 :: Group 117 :: Sticky Note dr11:12","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iZrTY","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Hindley-Milner推論は制約解決の大域性ゆえにエラー位置が遠くなりやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"5C69w","x":866,"y":3668,"name":"L1-5::Group 194 :: Group 1 :: Lone 376 :: Lone 426 :: Sticky Note dr11:23","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"6XAX2","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#の var は匿名型利用を簡潔にする一方で過用時に自己文書性を下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"OFXl7","x":1284,"y":3668,"name":"L1-5::Group 204 :: Group 1 :: Lone 181 :: Lone 203 :: Sticky Note dr2:60","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"dTZtu","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Odinは制御性が高い一方でライフタイムバグ責任を開発者が負う。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"wqDVb","x":582,"y":2932,"name":"L1-5::Group 213 :: Group 1 :: Lone 200 :: Lone 224 :: Sticky Note dr2:86","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"iOYgO","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"手動管理志向言語は予測可能性と性能を優先しつつ責務と学習コストを開発者側へ移す。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"zgYyd","x":4192,"y":3668,"name":"L1-5::Group 222 :: Group 1 :: Lone 275 :: Lone 316 :: Sticky Note dr4:74","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WLvFb","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PerlはTMTOWTDIで表現自由度を最大化した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"QmjcI","x":1284,"y":2404,"name":"L1-5::Group 223 :: Group 1 :: Lone 276 :: Lone 317 :: Sticky Note dr4:75","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"btFlc","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Perlは短い記述力を得た反面で可読性低下からwrite-only language批判を受けた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"yftR7","x":1284,"y":2604,"name":"L1-5::Group 223 :: Group 1 :: Lone 290 :: Lone 332 :: Sticky Note dr4:96","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"XeGU6","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Perlは正規表現中心ワンライナー文化が長期保守コードの可読性を損ないやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"pCS6e","x":5646,"y":3668,"name":"L1-5::Group 225 :: Group 1 :: Lone 295 :: Lone 337 :: Sticky Note dr4:101","width":260,"fill":"#FDEBD0","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"bGxu1","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Scalaはインフィックス記法や暗黙変換の多用でプロジェクト間可読性差が拡大しやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"bhcnW","x":1768,"y":1012,"name":"L1-5::Group 228 :: Group 1 :: Lone 313 :: Lone 357 :: Sticky Note dr5:41","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Wlxta","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"例外は非ローカル制御フローのため影響範囲の把握を難しくする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"B1I7g","x":1000,"y":1668,"name":"L1-5::Group 229 :: Group 1 :: Lone 316 :: Lone 360 :: Sticky Note dr5:44","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"wWZsC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"文ベース言語は分岐と代入が分離されるため定型コードが増えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"1Qum6","x":2320,"y":2932,"name":"L1-5::Group 231 :: Group 1 :: Lone 324 :: Lone 368 :: Sticky Note dr5:58","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"DGIr8","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Effect System実用化には表現力と開発体験のトレードオフ解決が必要である。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"CLOvC","x":2186,"y":1012,"name":"L1-5::Group 238 :: Group 1 :: Lone 395 :: Lone 445 :: Sticky Note dr11:49","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"jPBJk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Swiftはsomeとanyを含む高度型機構により表現力を得る一方で全体複雑度が上がる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"SuQZm","x":3356,"y":3996,"name":"L1-5::Group 242 :: Group 1 :: Lone 494 :: Lone 548 :: Sticky Note dr14:4","width":260,"fill":"#FFD1DC","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"2O9Jg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"字句選択は開発者のチャンク化と視線誘導を通じて読解速度を左右する。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"9gU1q","x":164,"y":4196,"name":"L1-5::Group 244 :: Group 1 :: Lone 462 :: Lone 516 :: Sticky Note dr13:21","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"5fRZ7","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Ponylangは厳格な型規律のため学習コストが高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"4wmRb","x":1902,"y":3996,"name":"L1-5::Group 247 :: Group 1 :: Lone 509 :: Lone 566 :: Sticky Note dr14:28","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"uZeDa","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Rubyのメタプログラミングとモンキーパッチは高い柔軟性と高い統制コストを併せ持つ。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Mquia","x":2604,"y":1012,"name":"L1-5::Group 248 :: Group 1 :: Lone 527 :: Lone 587 :: Sticky Note dr14:59","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"eIVKk","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"LSP以前は言語数とエディタ数の積に比例して統合コストが増大した。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Wf7Mt","x":4208,"y":284,"name":"L1-5::Group 250 :: Group 1 :: Lone 547 :: Lone 607 :: Sticky Note dr15:8","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Ne98U","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Stata 実行では log using logname.txt, replace text のようなテキストログ出力が監査性を高める。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"XzASL","x":4208,"y":484,"name":"L1-5::Group 250 :: Group 1 :: Lone 550 :: Lone 610 :: Sticky Note dr15:11","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"JrDg9","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Stata では * コメントを使って入力データと出力物と理論前提を明示すると査読性が上がる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"HoXQK","x":1000,"y":2932,"name":"L1-5::Lone 293 :: Group 1 :: Lone 292 :: Lone 334 :: Sticky Note dr4:98","width":260,"fill":"#D5F5E3","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"Jkz3I","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"PHPは後方互換制約により関数名と引数順の一貫化を全面的に進めにくい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"hBeOs","x":4476,"y":2932,"name":"L1-5::Lone 296 :: Group 1 :: Lone 314 :: Lone 358 :: Sticky Note dr5:42","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"QKfGg","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"値ベースエラーは制御フローを明示できるが記述量が増えやすい。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"KK8jW","x":164,"y":1996,"name":"L1-5::Lone 299 :: Group 1 :: Lone 356 :: Lone 403 :: Sticky Note dr6:55","width":260,"fill":"#FADBD8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"oqGbz","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"GraalVMのポリグロットは統合余地が大きい一方で既存VM互換性と運用成熟度が普及の制約になる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"FWbbI","x":3640,"y":3260,"name":"L1-5::Lone 306 :: Group 1 :: Lone 381 :: Lone 431 :: Sticky Note dr11:32","width":260,"fill":"#E8DAEF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"f7DKx","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"ADTとmatchは不正状態を実行時ではなくコンパイル時に排除しやすくする。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tgERN","x":1768,"y":1340,"name":"L1-5::Lone 308 :: Group 1 :: Lone 384 :: Lone 434 :: Sticky Note dr11:35","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IrIXW","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Python 3.10のmatchは構造分解能力を拡張したがキャプチャ規則が学習コストを増やした。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"tb8zc","x":2186,"y":1340,"name":"L1-5::Lone 328 :: Group 1 :: Lone 464 :: Lone 518 :: Sticky Note dr13:27","width":260,"fill":"#D4EFDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"WG3nR","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"C#は非同期状態機械をコンパイラ変換で隠蔽して可読性を上げた。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YpdGs","x":2738,"y":2932,"name":"L1-5::Lone 331 :: Group 1 :: Lone 492 :: Lone 546 :: Sticky Note dr14:2","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"99ZCC","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"言語アーキテクチャは理論計算機科学とHCIと実務ソフトウェア工学の交点で最適化される。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"s6Al4","x":582,"y":4196,"name":"L1-5::Lone 334 :: Group 1 :: Lone 518 :: Lone 578 :: Sticky Note dr14:50","width":260,"fill":"#D6EAF8","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"mDpHG","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"コンパイラUXは厳格な拒否装置から学習支援装置へ進化している。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"Y1Kbc","x":2320,"y":3996,"name":"L1-5::Lone 337 :: Group 1 :: Lone 525 :: Lone 585 :: Sticky Note dr14:57","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"IVyDs","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Gleamは表示名に開発者が書いたimport aliasを反映して認知変換コストを下げる。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"DbWlD","x":3506,"y":1340,"name":"L1-5::Lone 340 :: Group 1 :: Lone 533 :: Lone 593 :: Sticky Note dr14:66","width":260,"fill":"#D6DBDF","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"vyazv","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"Deno 2は実務導入拡大のためnpm互換を強化する現実路線を取っている。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"YwfRv","x":1902,"y":3260,"name":"L1-5::Lone 341 :: Group 1 :: Lone 536 :: Lone 596 :: Sticky Note dr14:71","width":260,"fill":"#FFE066","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"7cpCH","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"同図像性は機械処理の一貫性を高める一方で人間の視覚識別性を下げることがある。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"O5PS9","x":2738,"y":3996,"name":"L1-5::Lone 347 :: Group 1 :: Lone 548 :: Lone 608 :: Sticky Note dr15:9","width":260,"fill":"#F9E79F","cornerRadius":4,"effect":{"type":"shadow","shadowType":"outer","color":"#00000026","offset":{"x":2,"y":4},"blur":10},"layout":"vertical","gap":16,"padding":[32,28,28,28],"children":[{"type":"text","id":"VbvH0","name":"body","fill":"#6B5900","textGrowth":"fixed-width","width":"fill_container","content":"プレーンテキストログは SCML よりも外部ツール連携と閲覧互換性が高い。","lineHeight":1.6,"fontFamily":"Inter","fontSize":14,"fontWeight":"normal"}]},{"type":"frame","id":"UJTgj","x":2320,"y":3260,"name":"L1-5::Lone 361 :: Group 1 :: Lone 601 :: Lone